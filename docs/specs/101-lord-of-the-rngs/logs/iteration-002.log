{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GjPX6TWtAnDHcWkmQmVP23","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→pub mod error;\n     4→pub mod instructions;\n     5→pub mod state;\n     6→\n     7→use instructions::*;\n     8→\n     9→declare_id!(\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\");\n    10→\n    11→#[program]\n    12→pub mod coinflip {\n    13→    use super::*;\n    14→\n    15→    pub fn initialize_config(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n    16→        instructions::initialize_config::handler(ctx, treasury)\n    17→    }\n    18→\n    19→    pub fn create_match(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    20→        instructions::create_match::handler(ctx, tier, side)\n    21→    }\n    22→\n    23→    pub fn join_match(ctx: Context<JoinMatch>) -> Result<()> {\n    24→        instructions::join_match::handler(ctx)\n    25→    }\n    26→\n    27→    pub fn claim_payout(ctx: Context<ClaimPayout>) -> Result<()> {\n    28→        instructions::claim_payout::handler(ctx)\n    29→    }\n    30→\n    31→    pub fn cancel_match(ctx: Context<CancelMatch>) -> Result<()> {\n    32→        instructions::cancel_match::handler(ctx)\n    33→    }\n    34→\n    35→    pub fn timeout_cancel(ctx: Context<TimeoutCancel>) -> Result<()> {\n    36→        instructions::timeout_cancel::handler(ctx)\n    37→    }\n    38→\n    39→    pub fn force_close(ctx: Context<ForceClose>) -> Result<()> {\n    40→        instructions::force_close::handler(ctx)\n    41→    }\n    42→}\n    43→"}]},"parent_tool_use_id":"toolu_01NQ98jz4fzqNqNtpYG3urCH","session_id":"dce9785d-7f4b-4c3e-bdf0-c7aac93dbc9e","uuid":"921f8fdd-e40d-4b8b-8103-59702723f36d"}
