only valid after settlement).\"\n            ],\n            \"type\": \"u32\"\n          },\n          {\n            \"name\": \"winner\",\n            \"docs\": [\n              \"The winner's pubkey (Pubkey::default() until settled).\"\n            ],\n            \"type\": \"pubkey\"\n          },\n          {\n            \"name\": \"claimed\",\n            \"docs\": [\n              \"Whether the payout has been claimed.\"\n            ],\n            \"type\": \"bool\"\n          },\n          {\n            \"name\": \"creator\",\n            \"docs\": [\n              \"The creator of the round (receives rent back on close).\"\n            ],\n            \"type\": \"pubkey\"\n          },\n          {\n            \"name\": \"bump\",\n            \"docs\": [\n              \"Bump seed for PDA derivation.\"\n            ],\n            \"type\": \"u8\"\n          }\n        ]\n      }\n    },\n    {\n      \"name\": \"LordConfig\",\n      \"docs\": [\n        \"Global configuration for the Lord of the RNGs program.\",\n        \"PDA seeds: [b\\\"lord_config\\\"]\"\n      ],\n      \"type\": {\n        \"kind\": \"struct\",\n        \"fields\": [\n          {\n            \"name\": \"authority\",\n            \"docs\": [\n              \"Admin authority (can update config).\"\n            ],\n            \"type\": \"pubkey\"\n          },\n          {\n            \"name\": \"treasury\",\n            \"docs\": [\n              \"Fee destination wallet.\"\n            ],\n            \"type\": \"pubkey\"\n          },\n          {\n            \"name\": \"paused\",\n            \"docs\": [\n              \"Whether the game is paused (rejects new rounds).\"\n            ],\n            \"type\": \"bool\"\n          },\n          {\n            \"name\": \"round_counters\",\n            \"docs\": [\n              \"Monotonically increasing round counter per tier.\",\n              \"Index corresponds to tier (0–5).\"\n            ],\n            \"type\": {\n              \"array\": [\n                \"u64\",\n                6\n              ]\n            }\n          },\n          {\n            \"name\": \"bump\",\n            \"docs\": [\n              \"Bump seed for PDA derivation.\"\n            ],\n            \"type\": \"u8\"\n          }\n        ]\n      }\n    },\n    {\n      \"name\": \"PlayerEntry\",\n      \"docs\": [\n        \"A single player's entry in a jackpot round.\"\n      ],\n      \"type\": {\n        \"kind\": \"struct\",\n        \"fields\": [\n          {\n            \"name\": \"player\",\n            \"docs\": [\n              \"Player's wallet address.\"\n            ],\n            \"type\": \"pubkey\"\n          },\n          {\n            \"name\": \"entries\",\n            \"docs\": [\n              \"Number of entries purchased (each entry = one slot on the wheel).\"\n            ],\n            \"type\": \"u32\"\n          }\n        ]\n      }\n    },\n    {\n      \"name\": \"RoundPhase\",\n      \"docs\": [\n        \"Lifecycle phase for every round/match in any game.\"\n      ],\n      \"type\": {\n        \"kind\": \"enum\",\n        \"variants\": [\n          {\n            \"name\": \"Waiting\"\n          },\n          {\n            \"name\": \"Active\"\n          },\n          {\n            \"name\": \"Locked\"\n          },\n          {\n            \"name\": \"Resolving\"\n          },\n          {\n            \"name\": \"Settled\"\n          },\n          {\n            \"name\": \"Refunded\"\n          }\n        ]\n      }\n    },\n    {\n      \"name\": \"RoundSettled\",\n      \"docs\": [\n        \"Event emitted when a round is settled via claim_payout.\"\n      ],\n      \"type\": {\n        \"kind\": \"struct\",\n        \"fields\": [\n          {\n            \"name\": \"tier\",\n            \"docs\": [\n              \"Tier index.\"\n            ],\n            \"type\": \"u8\"\n          },\n          {\n            \"name\": \"round_number\",\n            \"docs\": [\n              \"Round number.\"\n            ],\n            \"type\": \"u64\"\n          },\n          {\n            \"name\": \"winner\",\n            \"docs\": [\n              \"Winner's wallet address.\"\n            ],\n            \"type\": \"pubkey\"\n          },\n          {\n            \"name\": \"randomness\",\n            \"docs\": [\n              \"Raw VRF randomness bytes.\"\n            ],\n            \"type\": {\n              \"array\": [\n                \"u8\",\n                32\n              ]\n            }\n          },\n          {\n            \"name\": \"winning_slot\",\n            \"docs\": [\n              \"The winning slot index (0-based).\"\n            ],\n            \"type\": \"u32\"\n          },\n          {\n            \"name\": \"total_entries\",\n            \"docs\": [\n              \"Total entries in the round.\"\n            ],\n            \"type\": \"u32\"\n          },\n          {\n            \"name\": \"payout_amount\",\n            \"docs\": [\n              \"Net payout to winner (after fee).\"\n            ],\n            \"type\": \"u64\"\n          },\n          {\n            \"name\": \"fee_amount\",\n            \"docs\": [\n              \"Platform fee amount.\"\n            ],\n            \"type\": \"u64\"\n          },\n          {\n            \"name\": \"vrf_request_key\",\n            \"docs\": [\n              \"Address of the Orao VRF request PDA.\"\n            ],\n            \"type\": \"pubkey\"\n          }\n        ]\n      }\n    }\n  ]\n}","numLines":1157,"startLine":1,"totalLines":1157}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KHBqAfaqJCjeeNdpiuQQCK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012ijTVFr7TqYf2p6oo6DuVP","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/mock-simulation.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":14618,"cache_read_input_tokens":58539,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":14618},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8e5d7c3d-ef66-4971-8f66-de7d7c43ed7c","uuid":"50a19407-a356-4099-9356-e84e7a443c6f"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ijTVFr7TqYf2p6oo6DuVP","type":"tool_result","content":"     1→import { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\n     2→import type { Round, PlayerEntry } from \"../types\";\n     3→import { PLAYER_COLORS } from \"../types\";\n     4→import { emitLordOfRngsComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\n     5→import { emitLordOfRngsResults } from \"../../player-profile/utils/profile-event-bus\";\n     6→\n     7→// ============ Constants ============\n     8→\n     9→const COUNTDOWN_DURATION = 60000; // 60 seconds\n    10→const SPIN_DURATION = 5000; // 5 seconds\n    11→const REVEAL_DURATION = 3000; // 3 seconds to show winner before new round\n    12→const MIN_PLAYERS = 2; // Minimum 2 different players (not just entries)\n    13→\n    14→const TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n    15→\n    16→// ============ Mock Store ============\n    17→\n    18→type TimerId = ReturnType<typeof setTimeout>;\n    19→\n    20→interface MockStore {\n    21→  rounds: Map<string, Round>; // roundId -> Round\n    22→  tierRounds: Map<Tier, string>; // tier -> current round ID\n    23→  listeners: Map<string, Set<(round: Round) => void>>;\n    24→  mockPlayerTimers: Map<string, TimerId[]>;\n    25→}\n    26→\n    27→const store: MockStore = {\n    28→  rounds: new Map(),\n    29→  tierRounds: new Map(),\n    30→  listeners: new Map(),\n    31→  mockPlayerTimers: new Map(),\n    32→};\n    33→\n    34→// ============ Helpers ============\n    35→\n    36→function generateRoundId(): string {\n    37→  return `lotr-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n    38→}\n    39→\n    40→function generateMockAddress(): string {\n    41→  const chars = \"123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz\";\n    42→  let addr = \"\";\n    43→  for (let i = 0; i < 44; i++) {\n    44→    addr += chars[Math.floor(Math.random() * chars.length)];\n    45→  }\n    46→  return addr;\n    47→}\n    48→\n    49→// Generate a mock hex string (simulates SHA-256 hash or seed)\n    50→function generateMockHexString(length: number = 64): string {\n    51→  const chars = \"0123456789abcdef\";\n    52→  let result = \"\";\n    53→  for (let i = 0; i < length; i++) {\n    54→    result += chars[Math.floor(Math.random() * chars.length)];\n    55→  }\n    56→  return result;\n    57→}\n    58→\n    59→// Generate mock provably fair data\n    60→function generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string; vrfProof: string } {\n    61→  const serverSeed = generateMockHexString(64); // 256-bit seed\n    62→  const seedHash = generateMockHexString(64); // SHA-256 hash of server seed\n    63→  const blockHash = generateMockHexString(88); // Solana blockhash format\n    64→  const vrfProof = generateMockHexString(128); // VRF proof\n    65→  return { seedHash, serverSeed, blockHash, vrfProof };\n    66→}\n    67→\n    68→export function truncateAddress(address: string): string {\n    69→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n    70→}\n    71→\n    72→function getPlayerColor(index: number, isCurrentUser: boolean): string {\n    73→  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\"; // Neon green for current user\n    74→  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n    75→}\n    76→\n    77→function calculatePayout(poolAmount: number): number {\n    78→  return poolAmount * 0.97; // 97% after 3% fee\n    79→}\n    80→\n    81→function notifyListeners(roundId: string, round: Round): void {\n    82→  const listeners = store.listeners.get(roundId);\n    83→  if (listeners) {\n    84→    const roundCopy = { ...round, players: [...round.players] };\n    85→    listeners.forEach((cb) => cb(roundCopy));\n    86→  }\n    87→}\n    88→\n    89→// ============ Round Management ============\n    90→\n    91→// Store for server seeds (revealed after settlement)\n    92→const serverSeeds = new Map<string, { serverSeed: string; blockHash: string; vrfProof: string }>();\n    93→\n    94→function createRound(tier: Tier): Round {\n    95→  const id = generateRoundId();\n    96→  const fairnessData = generateFairnessData();\n    97→\n    98→  // Store the secret data to reveal later\n    99→  serverSeeds.set(id, {\n   100→    serverSeed: fairnessData.serverSeed,\n   101→    blockHash: fairnessData.blockHash,\n   102→    vrfProof: fairnessData.vrfProof,\n   103→  });\n   104→\n   105→  const round: Round = {\n   106→    id,\n   107→    tier,\n   108→    entryAmount: TIER_AMOUNTS[tier],\n   109→    phase: \"waiting\",\n   110→    players: [],\n   111→    totalEntries: 0,\n   112→    poolAmount: 0,\n   113→    createdAt: Date.now(),\n   114→    seedHash: fairnessData.seedHash, // Public from the start\n   115→  };\n   116→\n   117→  store.rounds.set(id, round);\n   118→  store.tierRounds.set(tier, id);\n   119→\n   120→  return round;\n   121→}\n   122→\n   123→export function getOrCreateRound(tier: Tier): Round {\n   124→  const existingRoundId = store.tierRounds.get(tier);\n   125→  if (existingRoundId) {\n   126→    const existing = store.rounds.get(existingRoundId);\n   127→    if (existing && existing.phase !== \"complete\") {\n   128→      return existing;\n   129→    }\n   130→  }\n   131→\n   132→  return createRound(tier);\n   133→}\n   134→\n   135→export function getRound(roundId: string): Round | undefined {\n   136→  return store.rounds.get(roundId);\n   137→}\n   138→\n   139→export function getRoundByTier(tier: Tier): Round | undefined {\n   140→  const roundId = store.tierRounds.get(tier);\n   141→  return roundId ? store.rounds.get(roundId) : undefined;\n   142→}\n   143→\n   144→export function getAllTierRounds(): Map<Tier, Round> {\n   145→  const result = new Map<Tier, Round>();\n   146→  for (const tier of TIERS) {\n   147→    const round = getOrCreateRound(tier);\n   148→    result.set(tier, round);\n   149→  }\n   150→  return result;\n   151→}\n   152→\n   153→// ============ Player Actions ============\n   154→\n   155→export function joinRound(\n   156→  tier: Tier,\n   157→  playerAddress: string,\n   158→  entries: number,\n   159→  isCurrentUser: boolean = false\n   160→): Round {\n   161→  const round = getOrCreateRound(tier);\n   162→\n   163→  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n   164→    throw new Error(\"Cannot join round in this phase\");\n   165→  }\n   166→\n   167→  // Check if player already exists\n   168→  const existingPlayer = round.players.find((p) => p.address === playerAddress);\n   169→\n   170→  if (existingPlayer) {\n   171→    // Add more entries\n   172→    existingPlayer.entries += entries;\n   173→  } else {\n   174→    // New player\n   175→    const colorIndex = round.players.length;\n   176→    const player: PlayerEntry = {\n   177→      address: playerAddress,\n   178→      entries,\n   179→      color: getPlayerColor(colorIndex, isCurrentUser),\n   180→    };\n   181→    round.players.push(player);\n   182→  }\n   183→\n   184→  round.totalEntries += entries;\n   185→  round.poolAmount += entries * round.entryAmount;\n   186→\n   187→  // Emit wager placed event (triggers RNG buff chest drop check)\n   188→  const wagerAmount = entries * round.entryAmount;\n   189→  emitWagerPlaced(\"lord-of-rngs\", round.id, playerAddress, wagerAmount);\n   190→\n   191→  store.rounds.set(round.id, round);\n   192→  notifyListeners(round.id, round);\n   193→\n   194→  // Check if we should start countdown (2+ players)\n   195→  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n   196→    startCountdown(round.id);\n   197→  }\n   198→\n   199→  // If in waiting phase and this is a real user, schedule mock players\n   200→  if (round.phase === \"waiting\" && isCurrentUser) {\n   201→    scheduleMockPlayers(round.id);\n   202→  }\n   203→\n   204→  return round;\n   205→}\n   206→\n   207→export function buyMoreEntries(\n   208→  roundId: string,\n   209→  playerAddress: string,\n   210→  entries: number\n   211→): Round {\n   212→  const round = store.rounds.get(roundId);\n   213→  if (!round) throw new Error(\"Round not found\");\n   214→\n   215→  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n   216→    throw new Error(\"Cannot buy entries in this phase\");\n   217→  }\n   218→\n   219→  const player = round.players.find((p) => p.address === playerAddress);\n   220→  if (!player) throw new Error(\"Player not in this round\");\n   221→\n   222→  player.entries += entries;\n   223→  round.totalEntries += entries;\n   224→  round.poolAmount += entries * round.entryAmount;\n   225→\n   226→  // Emit wager placed event (triggers RNG buff chest drop check)\n   227→  const wagerAmount = entries * round.entryAmount;\n   228→  emitWagerPlaced(\"lord-of-rngs\", roundId, playerAddress, wagerAmount);\n   229→\n   230→  store.rounds.set(roundId, round);\n   231→  notifyListeners(roundId, round);\n   232→\n   233→  return round;\n   234→}\n   235→\n   236→// ============ Phase Transitions ============\n   237→\n   238→function startCountdown(roundId: string): void {\n   239→  const round = store.rounds.get(roundId);\n   240→  if (!round || round.phase !== \"waiting\") return;\n   241→\n   242→  round.phase = \"countdown\";\n   243→  round.countdownStartedAt = Date.now();\n   244→  round.countdownEndsAt = Date.now() + COUNTDOWN_DURATION;\n   245→\n   246→  store.rounds.set(roundId, round);\n   247→  notifyListeners(roundId, round);\n   248→\n   249→  // Schedule spin when countdown ends\n   250→  setTimeout(() => startSpinning(roundId), COUNTDOWN_DURATION);\n   251→\n   252→  // Schedule more mock players during countdown\n   253→  scheduleMockPlayersDuringCountdown(roundId);\n   254→}\n   255→\n   256→function startSpinning(roundId: string): void {\n   257→  const round = store.rounds.get(roundId);\n   258→  if (!round || round.phase !== \"countdown\") return;\n   259→\n   260→  // Cancel any pending mock player timers\n   261→  cancelMockPlayerTimers(roundId);\n   262→\n   263→  // Simulate VRF - pick a random winning slot\n   264→  const winningSlot = Math.floor(Math.random() * round.totalEntries);\n   265→\n   266→  round.phase = \"spinning\";\n   267→  round.winningSlot = winningSlot;\n   268→\n   269→  store.rounds.set(roundId, round);\n   270→  notifyListeners(roundId, round);\n   271→\n   272→  // Reveal winner after spin animation\n   273→  setTimeout(() => resolveRound(roundId), SPIN_DURATION);\n   274→}\n   275→\n   276→function resolveRound(roundId: string): void {\n   277→  const round = store.rounds.get(roundId);\n   278→  if (!round || round.phase !== \"spinning\") return;\n   279→\n   280→  // Determine winner based on winning slot\n   281→  let slotCount = 0;\n   282→  let winner: string | undefined;\n   283→\n   284→  for (const player of round.players) {\n   285→    slotCount += player.entries;\n   286→    if (round.winningSlot! < slotCount && !winner) {\n   287→      winner = player.address;\n   288→    }\n   289→  }\n   290→\n   291→  // Reveal the fairness data now that the round is settled\n   292→  const secrets = serverSeeds.get(roundId);\n   293→  if (secrets) {\n   294→    round.serverSeed = secrets.serverSeed;\n   295→    round.blockHash = secrets.blockHash;\n   296→    round.vrfProof = secrets.vrfProof;\n   297→  }\n   298→\n   299→  // First enter revealing phase to show the winner\n   300→  round.phase = \"revealing\";\n   301→  round.winner = winner;\n   302→  round.payoutAmount = calculatePayout(round.poolAmount);\n   303→\n   304→  store.rounds.set(roundId, round);\n   305→  notifyListeners(roundId, round);\n   306→\n   307→  // After reveal duration, complete the round and start new one\n   308→  setTimeout(() => completeRound(roundId), REVEAL_DURATION);\n   309→}\n   310→\n   311→function completeRound(roundId: string): void {\n   312→  const round = store.rounds.get(roundId);\n   313→  if (!round || round.phase !== \"revealing\") return;\n   314→\n   315→  round.phase = \"complete\";\n   316→  round.completedAt = Date.now();\n   317→\n   318→  store.rounds.set(roundId, round);\n   319→  notifyListeners(roundId, round);\n   320→\n   321→  // Emit event for Boss Raid\n   322→  if (round.players.length > 0) {\n   323→    const entries = round.players.map((p) => ({\n   324→      address: p.address,\n   325→      entries: p.entries,\n   326→    }));\n   327→    emitLordOfRngsComplete(roundId, entries, round.entryAmount);\n   328→  }\n   329→\n   330→  // Emit event for Player Profile (XP and stats tracking)\n   331→  if (round.players.length > 0 && round.winner) {\n   332→    const participants = round.players.map((p) => ({\n   333→      address: p.address,\n   334→      totalWager: p.entries * round.entryAmount,\n   335→    }));\n   336→    emitLordOfRngsResults(\n   337→      roundId,\n   338→      round.winner,\n   339→      participants,\n   340→      round.payoutAmount ?? 0,\n   341→      round.tier\n   342→    );\n   343→  }\n   344→\n   345→  // Create a new round for this tier immediately\n   346→  store.tierRounds.delete(round.tier);\n   347→  const newRound = getOrCreateRound(round.tier);\n   348→\n   349→  // Schedule mock players for the new round to keep game alive\n   350→  scheduleMockPlayers(newRound.id);\n   351→}\n   352→\n   353→// ============ Mock Player Simulation ============\n   354→\n   355→function scheduleMockPlayers(roundId: string): void {\n   356→  const round = store.rounds.get(roundId);\n   357→  if (!round) return;\n   358→\n   359→  // Schedule 1-3 mock players to join over next 3-8 seconds\n   360→  const mockCount = 1 + Math.floor(Math.random() * 3);\n   361→  const timers: TimerId[] = [];\n   362→\n   363→  for (let i = 0; i < mockCount; i++) {\n   364→    const delay = 3000 + Math.random() * 5000;\n   365→    const timer = setTimeout(() => addMockPlayer(roundId), delay);\n   366→    timers.push(timer);\n   367→  }\n   368→\n   369→  store.mockPlayerTimers.set(roundId, timers);\n   370→}\n   371→\n   372→function scheduleMockPlayersDuringCountdown(roundId: string): void {\n   373→  const round = store.rounds.get(roundId);\n   374→  if (!round) return;\n   375→\n   376→  // Schedule 2-5 more mock players during countdown\n   377→  const mockCount = 2 + Math.floor(Math.random() * 4);\n   378→  const existingTimers = store.mockPlayerTimers.get(roundId) ?? [];\n   379→\n   380→  for (let i = 0; i < mockCount; i++) {\n   381→    const delay = 5000 + Math.random() * 45000; // Spread over first 50s of countdown\n   382→    const timer = setTimeout(() => {\n   383→      const r = store.rounds.get(roundId);\n   384→      if (r?.phase === \"countdown\") {\n   385→        addMockPlayer(roundId);\n   386→      }\n   387→    }, delay);\n   388→    existingTimers.push(timer);\n   389→  }\n   390→\n   391→  store.mockPlayerTimers.set(roundId, existingTimers);\n   392→}\n   393→\n   394→function addMockPlayer(roundId: string): void {\n   395→  const round = store.rounds.get(roundId);\n   396→  if (!round || (round.phase !== \"waiting\" && round.phase !== \"countdown\")) return;\n   397→\n   398→  const address = generateMockAddress();\n   399→  const entries = 1 + Math.floor(Math.random() * 3); // 1-3 entries\n   400→\n   401→  const colorIndex = round.players.length;\n   402→  const player: PlayerEntry = {\n   403→    address,\n   404→    entries,\n   405→    color: getPlayerColor(colorIndex, false),\n   406→  };\n   407→\n   408→  round.players.push(player);\n   409→  round.totalEntries += entries;\n   410→  round.poolAmount += entries * round.entryAmount;\n   411→\n   412→  store.rounds.set(roundId, round);\n   413→  notifyListeners(roundId, round);\n   414→\n   415→  // Start countdown if we now have enough players\n   416→  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n   417→    startCountdown(roundId);\n   418→  }\n   419→}\n   420→\n   421→function cancelMockPlayerTimers(roundId: string): void {\n   422→  const timers = store.mockPlayerTimers.get(roundId);\n   423→  if (timers) {\n   424→    timers.forEach(clearTimeout);\n   425→    store.mockPlayerTimers.delete(roundId);\n   426→  }\n   427→}\n   428→\n   429→// ============ Subscription ============\n   430→\n   431→export function subscribeToRound(\n   432→  roundId: string,\n   433→  callback: (round: Round) => void\n   434→): () => void {\n   435→  if (!store.listeners.has(roundId)) {\n   436→    store.listeners.set(roundId, new Set());\n   437→  }\n   438→  store.listeners.get(roundId)!.add(callback);\n   439→\n   440→  return () => {\n   441→    store.listeners.get(roundId)?.delete(callback);\n   442→  };\n   443→}\n   444→\n   445→// ============ User History ============\n   446→\n   447→export function getUserRounds(playerAddress: string): Round[] {\n   448→  const rounds: Round[] = [];\n   449→\n   450→  store.rounds.forEach((round) => {\n   451→    if (round.players.some((p) => p.address === playerAddress)) {\n   452→      rounds.push(round);\n   453→    }\n   454→  });\n   455→\n   456→  return rounds.sort((a, b) => b.createdAt - a.createdAt);\n   457→}\n   458→\n   459→// ============ Initialize Mock Rounds ============\n   460→\n   461→export function initializeMockRounds(): void {\n   462→  // Create initial rounds for each tier with some mock players\n   463→  for (const tier of TIERS) {\n   464→    const round = getOrCreateRound(tier);\n   465→\n   466→    // Add 0-3 initial mock players to each tier\n   467→    const initialPlayers = Math.floor(Math.random() * 4);\n   468→    for (let i = 0; i < initialPlayers; i++) {\n   469→      const address = generateMockAddress();\n   470→      const entries = 1 + Math.floor(Math.random() * 2);\n   471→      const player: PlayerEntry = {\n   472→        address,\n   473→        entries,\n   474→        color: getPlayerColor(i, false),\n   475→      };\n   476→      round.players.push(player);\n   477→      round.totalEntries += entries;\n   478→      round.poolAmount += entries * round.entryAmount;\n   479→    }\n   480→\n   481→    store.rounds.set(round.id, round);\n   482→\n   483→    // Start countdown if 2+ players already exist\n   484→    if (round.players.length >= MIN_PLAYERS) {\n   485→      startCountdown(round.id);\n   486→    } else if (round.players.length >= 1) {\n   487→      // Schedule more mock players to eventually start the round\n   488→      scheduleMockPlayers(round.id);\n   489→    }\n   490→  }\n   491→}\n   492→"}]},"parent_tool_use_id":null,"session_id":"8e5d7c3d-ef66-4971-8f66-de7d7c43ed7c","uuid":"826ac9fc-53b5-47e2-b896-53805047fbdc","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/mock-simulation.ts","content":"import { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { Round, PlayerEntry } from \"../types\";\nimport { PLAYER_COLORS } from \"../types\";\nimport { emitLordOfRngsComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\nimport { emitLordOfRngsResults } from \"../../player-profile/utils/profile-event-bus\";\n\n// ============ Constants ============\n\nconst COUNTDOWN_DURATION = 60000; // 60 seconds\nconst SPIN_DURATION = 5000; // 5 seconds\nconst REVEAL_DURATION = 3000; // 3 seconds to show winner before new round\nconst MIN_PLAYERS = 2; // Minimum 2 different players (not just entries)\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\n// ============ Mock Store ============\n\ntype TimerId = ReturnType<typeof setTimeout>;\n\ninterface MockStore {\n  rounds: Map<string, Round>; // roundId -> Round\n  tierRounds: Map<Tier, string>; // tier -> current round ID\n  listeners: Map<string, Set<(round: Round) => void>>;\n  mockPlayerTimers: Map<string, TimerId[]>;\n}\n\nconst store: MockStore = {\n  rounds: new Map(),\n  tierRounds: new Map(),\n  listeners: new Map(),\n  mockPlayerTimers: new Map(),\n};\n\n// ============ Helpers ============\n\nfunction generateRoundId(): string {\n  return `lotr-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n}\n\nfunction generateMockAddress(): string {\n  const chars = \"123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz\";\n  let addr = \"\";\n  for (let i = 0; i < 44; i++) {\n    addr += chars[Math.floor(Math.random() * chars.length)];\n  }\n  return addr;\n}\n\n// Generate a mock hex string (simulates SHA-256 hash or seed)\nfunction generateMockHexString(length: number = 64): string {\n  const chars = \"0123456789abcdef\";\n  let result = \"\";\n  for (let i = 0; i < length; i++) {\n    result += chars[Math.floor(Math.random() * chars.length)];\n  }\n  return result;\n}\n\n// Generate mock provably fair data\nfunction generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string; vrfProof: string } {\n  const serverSeed = generateMockHexString(64); // 256-bit seed\n  const seedHash = generateMockHexString(64); // SHA-256 hash of server seed\n  const blockHash = generateMockHexString(88); // Solana blockhash format\n  const vrfProof = generateMockHexString(128); // VRF proof\n  return { seedHash, serverSeed, blockHash, vrfProof };\n}\n\nexport function truncateAddress(address: string): string {\n  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n}\n\nfunction getPlayerColor(index: number, isCurrentUser: boolean): string {\n  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\"; // Neon green for current user\n  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n}\n\nfunction calculatePayout(poolAmount: number): number {\n  return poolAmount * 0.97; // 97% after 3% fee\n}\n\nfunction notifyListeners(roundId: string, round: Round): void {\n  const listeners = store.listeners.get(roundId);\n  if (listeners) {\n    const roundCopy = { ...round, players: [...round.players] };\n    listeners.forEach((cb) => cb(roundCopy));\n  }\n}\n\n// ============ Round Management ============\n\n// Store for server seeds (revealed after settlement)\nconst serverSeeds = new Map<string, { serverSeed: string; blockHash: string; vrfProof: string }>();\n\nfunction createRound(tier: Tier): Round {\n  const id = generateRoundId();\n  const fairnessData = generateFairnessData();\n\n  // Store the secret data to reveal later\n  serverSeeds.set(id, {\n    serverSeed: fairnessData.serverSeed,\n    blockHash: fairnessData.blockHash,\n    vrfProof: fairnessData.vrfProof,\n  });\n\n  const round: Round = {\n    id,\n    tier,\n    entryAmount: TIER_AMOUNTS[tier],\n    phase: \"waiting\",\n    players: [],\n    totalEntries: 0,\n    poolAmount: 0,\n    createdAt: Date.now(),\n    seedHash: fairnessData.seedHash, // Public from the start\n  };\n\n  store.rounds.set(id, round);\n  store.tierRounds.set(tier, id);\n\n  return round;\n}\n\nexport function getOrCreateRound(tier: Tier): Round {\n  const existingRoundId = store.tierRounds.get(tier);\n  if (existingRoundId) {\n    const existing = store.rounds.get(existingRoundId);\n    if (existing && existing.phase !== \"complete\") {\n      return existing;\n    }\n  }\n\n  return createRound(tier);\n}\n\nexport function getRound(roundId: string): Round | undefined {\n  return store.rounds.get(roundId);\n}\n\nexport function getRoundByTier(tier: Tier): Round | undefined {\n  const roundId = store.tierRounds.get(tier);\n  return roundId ? store.rounds.get(roundId) : undefined;\n}\n\nexport function getAllTierRounds(): Map<Tier, Round> {\n  const result = new Map<Tier, Round>();\n  for (const tier of TIERS) {\n    const round = getOrCreateRound(tier);\n    result.set(tier, round);\n  }\n  return result;\n}\n\n// ============ Player Actions ============\n\nexport function joinRound(\n  tier: Tier,\n  playerAddress: string,\n  entries: number,\n  isCurrentUser: boolean = false\n): Round {\n  const round = getOrCreateRound(tier);\n\n  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n    throw new Error(\"Cannot join round in this phase\");\n  }\n\n  // Check if player already exists\n  const existingPlayer = round.players.find((p) => p.address === playerAddress);\n\n  if (existingPlayer) {\n    // Add more entries\n    existingPlayer.entries += entries;\n  } else {\n    // New player\n    const colorIndex = round.players.length;\n    const player: PlayerEntry = {\n      address: playerAddress,\n      entries,\n      color: getPlayerColor(colorIndex, isCurrentUser),\n    };\n    round.players.push(player);\n  }\n\n  round.totalEntries += entries;\n  round.poolAmount += entries * round.entryAmount;\n\n  // Emit wager placed event (triggers RNG buff chest drop check)\n  const wagerAmount = entries * round.entryAmount;\n  emitWagerPlaced(\"lord-of-rngs\", round.id, playerAddress, wagerAmount);\n\n  store.rounds.set(round.id, round);\n  notifyListeners(round.id, round);\n\n  // Check if we should start countdown (2+ players)\n  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n    startCountdown(round.id);\n  }\n\n  // If in waiting phase and this is a real user, schedule mock players\n  if (round.phase === \"waiting\" && isCurrentUser) {\n    scheduleMockPlayers(round.id);\n  }\n\n  return round;\n}\n\nexport function buyMoreEntries(\n  roundId: string,\n  playerAddress: string,\n  entries: number\n): Round {\n  const round = store.rounds.get(roundId);\n  if (!round) throw new Error(\"Round not found\");\n\n  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n    throw new Error(\"Cannot buy entries in this phase\");\n  }\n\n  const player = round.players.find((p) => p.address === playerAddress);\n  if (!player) throw new Error(\"Player not in this round\");\n\n  player.entries += entries;\n  round.totalEntries += entries;\n  round.poolAmount += entries * round.entryAmount;\n\n  // Emit wager placed event (triggers RNG buff chest drop check)\n  const wagerAmount = entries * round.entryAmount;\n  emitWagerPlaced(\"lord-of-rngs\", roundId, playerAddress, wagerAmount);\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  return round;\n}\n\n// ============ Phase Transitions ============\n\nfunction startCountdown(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || round.phase !== \"waiting\") return;\n\n  round.phase = \"countdown\";\n  round.countdownStartedAt = Date.now();\n  round.countdownEndsAt = Date.now() + COUNTDOWN_DURATION;\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // Schedule spin when countdown ends\n  setTimeout(() => startSpinning(roundId), COUNTDOWN_DURATION);\n\n  // Schedule more mock players during countdown\n  scheduleMockPlayersDuringCountdown(roundId);\n}\n\nfunction startSpinning(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || round.phase !== \"countdown\") return;\n\n  // Cancel any pending mock player timers\n  cancelMockPlayerTimers(roundId);\n\n  // Simulate VRF - pick a random winning slot\n  const winningSlot = Math.floor(Math.random() * round.totalEntries);\n\n  round.phase = \"spinning\";\n  round.winningSlot = winningSlot;\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // Reveal winner after spin animation\n  setTimeout(() => resolveRound(roundId), SPIN_DURATION);\n}\n\nfunction resolveRound(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || round.phase !== \"spinning\") return;\n\n  // Determine winner based on winning slot\n  let slotCount = 0;\n  let winner: string | undefined;\n\n  for (const player of round.players) {\n    slotCount += player.entries;\n    if (round.winningSlot! < slotCount && !winner) {\n      winner = player.address;\n    }\n  }\n\n  // Reveal the fairness data now that the round is settled\n  const secrets = serverSeeds.get(roundId);\n  if (secrets) {\n    round.serverSeed = secrets.serverSeed;\n    round.blockHash = secrets.blockHash;\n    round.vrfProof = secrets.vrfProof;\n  }\n\n  // First enter revealing phase to show the winner\n  round.phase = \"revealing\";\n  round.winner = winner;\n  round.payoutAmount = calculatePayout(round.poolAmount);\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // After reveal duration, complete the round and start new one\n  setTimeout(() => completeRound(roundId), REVEAL_DURATION);\n}\n\nfunction completeRound(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || round.phase !== \"revealing\") return;\n\n  round.phase = \"complete\";\n  round.completedAt = Date.now();\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // Emit event for Boss Raid\n  if (round.players.length > 0) {\n    const entries = round.players.map((p) => ({\n      address: p.address,\n      entries: p.entries,\n    }));\n    emitLordOfRngsComplete(roundId, entries, round.entryAmount);\n  }\n\n  // Emit event for Player Profile (XP and stats tracking)\n  if (round.players.length > 0 && round.winner) {\n    const participants = round.players.map((p) => ({\n      address: p.address,\n      totalWager: p.entries * round.entryAmount,\n    }));\n    emitLordOfRngsResults(\n      roundId,\n      round.winner,\n      participants,\n      round.payoutAmount ?? 0,\n      round.tier\n    );\n  }\n\n  // Create a new round for this tier immediately\n  store.tierRounds.delete(round.tier);\n  const newRound = getOrCreateRound(round.tier);\n\n  // Schedule mock players for the new round to keep game alive\n  scheduleMockPlayers(newRound.id);\n}\n\n// ============ Mock Player Simulation ============\n\nfunction scheduleMockPlayers(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round) return;\n\n  // Schedule 1-3 mock players to join over next 3-8 seconds\n  const mockCount = 1 + Math.floor(Math.random() * 3);\n  const timers: TimerId[] = [];\n\n  for (let i = 0; i < mockCount; i++) {\n    const delay = 3000 + Math.random() * 5000;\n    const timer = setTimeout(() => addMockPlayer(roundId), delay);\n    timers.push(timer);\n  }\n\n  store.mockPlayerTimers.set(roundId, timers);\n}\n\nfunction scheduleMockPlayersDuringCountdown(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round) return;\n\n  // Schedule 2-5 more mock players during countdown\n  const mockCount = 2 + Math.floor(Math.random() * 4);\n  const existingTimers = store.mockPlayerTimers.get(roundId) ?? [];\n\n  for (let i = 0; i < mockCount; i++) {\n    const delay = 5000 + Math.random() * 45000; // Spread over first 50s of countdown\n    const timer = setTimeout(() => {\n      const r = store.rounds.get(roundId);\n      if (r?.phase === \"countdown\") {\n        addMockPlayer(roundId);\n      }\n    }, delay);\n    existingTimers.push(timer);\n  }\n\n  store.mockPlayerTimers.set(roundId, existingTimers);\n}\n\nfunction addMockPlayer(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || (round.phase !== \"waiting\" && round.phase !== \"countdown\")) return;\n\n  const address = generateMockAddress();\n  const entries = 1 + Math.floor(Math.random() * 3); // 1-3 entries\n\n  const colorIndex = round.players.length;\n  const player: PlayerEntry = {\n    address,\n    entries,\n    color: getPlayerColor(colorIndex, false),\n  };\n\n  round.players.push(player);\n  round.totalEntries += entries;\n  round.poolAmount += entries * round.entryAmount;\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // Start countdown if we now have enough players\n  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n    startCountdown(roundId);\n  }\n}\n\nfunction cancelMockPlayerTimers(roundId: string): void {\n  const timers = store.mockPlayerTimers.get(roundId);\n  if (timers) {\n    timers.forEach(clearTimeout);\n    store.mockPlayerTimers.delete(roundId);\n  }\n}\n\n// ============ Subscription ============\n\nexport function subscribeToRound(\n  roundId: string,\n  callback: (round: Round) => void\n): () => void {\n  if (!store.listeners.has(roundId)) {\n    store.listeners.set(roundId, new Set());\n  }\n  store.listeners.get(roundId)!.add(callback);\n\n  return () => {\n    store.listeners.get(roundId)?.delete(callback);\n  };\n}\n\n// ============ User History ============\n\nexport function getUserRounds(playerAddress: string): Round[] {\n  const rounds: Round[] = [];\n\n  store.rounds.forEach((round) => {\n    if (round.players.some((p) => p.address === playerAddress)) {\n      rounds.push(round);\n    }\n  });\n\n  return rounds.sort((a, b) => b.createdAt - a.createdAt);\n}\n\n// ============ Initialize Mock Rounds ============\n\nexport function initializeMockRounds(): void {\n  // Create initial rounds for each tier with some mock players\n  for (const tier of TIERS) {\n    const round = getOrCreateRound(tier);\n\n    // Add 0-3 initial mock players to each tier\n    const initialPlayers = Math.floor(Math.random() * 4);\n    for (let i = 0; i < initialPlayers; i++) {\n      const address = generateMockAddress();\n      const entries = 1 + Math.floor(Math.random() * 2);\n      const player: PlayerEntry = {\n        address,\n        entries,\n        color: getPlayerColor(i, false),\n      };\n      round.players.push(player);\n      round.totalEntries += entries;\n      round.poolAmount += entries * round.entryAmount;\n    }\n\n    store.rounds.set(round.id, round);\n\n    // Start countdown if 2+ players already exist\n    if (round.players.length >= MIN_PLAYERS) {\n      startCountdown(round.id);\n    } else if (round.players.length >= 1) {\n      // Schedule more mock players to eventually start the round\n      scheduleMockPlayers(round.id);\n    }\n  }\n}\n","numLines":492,"startLine":1,"totalLines":492}}}
