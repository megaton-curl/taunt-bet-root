   258→        {\n   259→          \"name\": \"round\",\n   260→          \"docs\": [\n   261→            \"The round PDA. Seeds: [b\\\"jackpot_round\\\", tier (1 byte), round_number (8 bytes LE)]\"\n   262→          ],\n   263→          \"writable\": true,\n   264→          \"pda\": {\n   265→            \"seeds\": [\n   266→              {\n   267→                \"kind\": \"const\",\n   268→                \"value\": [\n   269→                  106,\n   270→                  97,\n   271→                  99,\n   272→                  107,\n   273→                  112,\n   274→                  111,\n   275→                  116,\n   276→                  95,\n   277→                  114,\n   278→                  111,\n   279→                  117,\n   280→                  110,\n   281→                  100\n   282→                ]\n   283→              },\n   284→              {\n   285→                \"kind\": \"arg\",\n   286→                \"path\": \"tier\"\n   287→              },\n   288→              {\n   289→                \"kind\": \"arg\",\n   290→                \"path\": \"round_number\"\n   291→              }\n   292→            ]\n   293→          }\n   294→        },\n   295→        {\n   296→          \"name\": \"system_program\",\n   297→          \"address\": \"11111111111111111111111111111111\"\n   298→        }\n   299→      ],\n   300→      \"args\": [\n   301→        {\n   302→          \"name\": \"tier\",\n   303→          \"type\": \"u8\"\n   304→        },\n   305→        {\n   306→          \"name\": \"round_number\",\n   307→          \"type\": \"u64\"\n   308→        },\n   309→        {\n   310→          \"name\": \"num_entries\",\n   311→          \"type\": \"u32\"\n   312→        }\n   313→      ]\n   314→    },\n   315→    {\n   316→      \"name\": \"force_close\",\n   317→      \"discriminator\": [\n   318→        71,\n   319→        1,\n   320→        6,\n   321→        64,\n   322→        15,\n   323→        200,\n   3