{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S1xT6nPHbdLcpEd5pAEgeM","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  TIER_VALUES,\n    11→  COIN_SIDE_VALUES,\n    12→  TIER_AMOUNTS,\n    13→  type Tier,\n    14→  type CoinSide,\n    15→} from \"@rng-utopia/game-engine/browser\";\n    16→import type { UIMatch } from \"../types\";\n    17→\n    18→// ============ Constants ============\n    19→\n    20→const COINFLIP_PROGRAM_ID = new PublicKey(\n    21→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    22→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    23→);\n    24→\n    25→// Orao VRF program (on-chain VRF provider)\n    26→const ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n    27→\n    28→// ============ PDA Derivation ============\n    29→\n    30→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer()],\n    33→    COINFLIP_PROGRAM_ID\n    34→  );\n    35→}\n    36→\n    37→export function getConfigPda(): [PublicKey, number] {\n    38→  return PublicKey.findProgramAddressSync(\n    39→    [Buffer.from(\"coinflip_config\")],\n    40→    COINFLIP_PROGRAM_ID\n    41→  );\n    42→}\n    43→\n    44→/** Orao VRF network state PDA (stores config + treasury). */\n    45→function getOraoNetworkStatePda(): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    48→    ORAO_VRF_PROGRAM_ID\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→/** Orao VRF randomness PDA derived from a 32-byte seed. */\n    54→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    55→  const [pda] = PublicKey.findProgramAddressSync(\n    56→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    57→    ORAO_VRF_PROGRAM_ID\n    58→  );\n    59→  return pda;\n    60→}\n    61→\n    62→// ============ Program Instance ============\n    63→\n    64→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    65→  // Read-only provider (no wallet needed for queries)\n    66→  const provider = new AnchorProvider(\n    67→    connection,\n    68→    {} as AnchorProvider[\"wallet\"],\n    69→    { commitment: \"confirmed\" }\n    70→  );\n    71→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    72→}\n    73→\n    74→// ============ On-Chain Account Types ============\n    75→\n    76→/** Anchor enum variant representation — one key with empty object value. */\n    77→type RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n    78→  | { resolving: object } | { settled: object } | { refunded: object };\n    79→\n    80→interface OnChainMatch {\n    81→  creator: PublicKey;\n    82→  opponent: PublicKey;\n    83→  tier: number;\n    84→  entryAmount: { toNumber(): number };\n    85→  creatorSide: number;\n    86→  phase: RoundPhaseVariant;\n    87→  result: number;\n    88→  winner: PublicKey;\n    89→  claimed: boolean;\n    90→  createdAt: { toNumber(): number };\n    91→  lockedAt: { toNumber(): number };\n    92→  resolveDeadline: { toNumber(): number };\n    93→  vrfRequestKey: PublicKey;\n    94→  bump: number;\n    95→}\n    96→\n    97→// ============ Converters ============\n    98→\n    99→function tierFromIndex(index: number): Tier {\n   100→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   101→  return tiers[index] ?? \"iron\";\n   102→}\n   103→\n   104→function sideFromIndex(index: number): CoinSide {\n   105→  return index === 0 ? \"heads\" : \"tails\";\n   106→}\n   107→\n   108→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   109→  return name in phase;\n   110→}\n   111→\n   112→function phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n   113→  if (isPhase(phase, \"waiting\")) return \"created\";\n   114→  if (isPhase(phase, \"locked\")) return \"ready\";\n   115→  if (isPhase(phase, \"settled\")) return \"complete\";\n   116→  return \"created\";\n   117→}\n   118→\n   119→const DEFAULT_PUBKEY = PublicKey.default;\n   120→\n   121→function isDefaultPubkey(key: PublicKey): boolean {\n   122→  return key.equals(DEFAULT_PUBKEY);\n   123→}\n   124→\n   125→export function onChainMatchToUI(\n   126→  matchPda: PublicKey,\n   127→  data: OnChainMatch\n   128→): UIMatch {\n   129→  const tier = tierFromIndex(data.tier);\n   130→  const creatorSide = sideFromIndex(data.creatorSide);\n   131→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   132→  const phase = phaseToUI(data.phase);\n   133→  const isSettled = isPhase(data.phase, \"settled\");\n   134→\n   135→  const entryAmountSol = TIER_AMOUNTS[tier];\n   136→  const totalPool = entryAmountSol * 2;\n   137→  const payoutAmount = totalPool * 0.97;\n   138→\n   139→  const lockedAt = data.lockedAt.toNumber();\n   140→\n   141→  return {\n   142→    id: matchPda.toBase58(),\n   143→    tier,\n   144→    entryAmount: entryAmountSol,\n   145→    player1: data.creator.toBase58(),\n   146→    player1Side: creatorSide,\n   147→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   148→    player2Side: hasOpponent\n   149→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   150→      : null,\n   151→    phase,\n   152→    createdAt: Date.now(),\n   153→    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n   154→    result: isSettled ? sideFromIndex(data.result) : null,\n   155→    winner: isSettled && !isDefaultPubkey(data.winner)\n   156→      ? data.winner.toBase58()\n   157→      : null,\n   158→    claimed: data.claimed,\n   159→    payoutAmount,\n   160→    seedHash: \"\",\n   161→  };\n   162→}\n   163→\n   164→/** Read fulfilled VRF randomness bytes from an Orao randomness account.\n   165→ *  Returns the first randomness byte (used for coin flip result) or null if not fulfilled. */\n   166→async function readVrfRandomness(\n   167→  connection: Connection,\n   168→  vrfRequestKey: PublicKey\n   169→): Promise<number | null> {\n   170→  try {\n   171→    if (isDefaultPubkey(vrfRequestKey)) return null;\n   172→    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n   173→    if (vrfAccount && vrfAccount.data.length > 8) {\n   174→      // Orao randomness account: 8-byte discriminator then randomness data.\n   175→      const randomnessData = vrfAccount.data.subarray(8, 72);\n   176→      if (randomnessData.some((b: number) => b !== 0)) {\n   177→        return randomnessData[0] ?? null;\n   178→      }\n   179→    }\n   180→  } catch {\n   181→    // Ignore — treat as not fulfilled\n   182→  }\n   183→  return null;\n   184→}\n   185→\n   186→/** Derive client-side winner from VRF randomness for a locked match. */\n   187→function deriveWinnerFromVrf(\n   188→  firstByte: number,\n   189→  data: OnChainMatch\n   190→): { result: CoinSide; winner: string } {\n   191→  const resultSide = firstByte % 2; // 0 = heads, 1 = tails — matches on-chain from_randomness()\n   192→  const creatorWins = resultSide === data.creatorSide;\n   193→  return {\n   194→    result: sideFromIndex(resultSide),\n   195→    winner: creatorWins\n   196→      ? data.creator.toBase58()\n   197→      : data.opponent.toBase58(),\n   198→  };\n   199→}\n   200→\n   201→// ============ Account Queries ============\n   202→\n   203→export async function fetchAllOpenMatches(\n   204→  connection: Connection\n   205→): Promise<UIMatch[]> {\n   206→  const program = getCoinflipProgram(connection);\n   207→  const accounts = await program.account.coinflipMatch.all();\n   208→\n   209→  return accounts\n   210→    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n   211→    .map((acc) =>\n   212→      onChainMatchToUI(\n   213→        acc.publicKey,\n   214→        acc.account as unknown as OnChainMatch\n   215→      )\n   216→    );\n   217→}\n   218→\n   219→/**\n   220→ * Fetch all matches where playerPubkey is creator OR opponent,\n   221→ * claimed == false, and phase is non-terminal (not refunded).\n   222→ * Uses memcmp filters for efficient on-chain filtering.\n   223→ *\n   224→ * Account layout offsets (after 8-byte discriminator):\n   225→ *   creator:  8   (32 bytes)\n   226→ *   opponent: 40  (32 bytes)\n   227→ *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n   228→ */\n   229→export async function fetchClaimableMatches(\n   230→  connection: Connection,\n   231→  playerPubkey: PublicKey\n   232→): Promise<UIMatch[]> {\n   233→  const program = getCoinflipProgram(connection);\n   234→  const playerBase58 = playerPubkey.toBase58();\n   235→\n   236→  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n   237→  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n   238→\n   239→  const [asCreator, asOpponent] = await Promise.all([\n   240→    program.account.coinflipMatch.all([\n   241→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   242→      claimedFalseFilter,\n   243→    ]),\n   244→    program.account.coinflipMatch.all([\n   245→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   246→      claimedFalseFilter,\n   247→    ]),\n   248→  ]);\n   249→\n   250→  // Merge and deduplicate by public key\n   251→  const seen = new Set<string>();\n   252→  const matches: UIMatch[] = [];\n   253→\n   254→  for (const acc of [...asCreator, ...asOpponent]) {\n   255→    const key = acc.publicKey.toBase58();\n   256→    if (seen.has(key)) continue;\n   257→    seen.add(key);\n   258→\n   259→    const data = acc.account as unknown as OnChainMatch;\n   260→    // Skip terminal phase (refunded)\n   261→    if (isPhase(data.phase, \"refunded\")) continue;\n   262→\n   263→    const match = onChainMatchToUI(acc.publicKey, data);\n   264→\n   265→    // Upgrade Locked → complete when VRF has resolved, deriving winner client-side\n   266→    const vrfByte = isPhase(data.phase, \"locked\")\n   267→      ? await readVrfRandomness(connection, data.vrfRequestKey)\n   268→      : null;\n   269→    if (vrfByte !== null) {\n   270→      const derived = deriveWinnerFromVrf(vrfByte, data);\n   271→      matches.push({ ...match, phase: \"complete\", result: derived.result, winner: derived.winner });\n   272→    } else {\n   273→      matches.push(match);\n   274→    }\n   275→  }\n   276→\n   277→  return matches;\n   278→}\n   279→\n   280→export async function fetchMatchByCreator(\n   281→  connection: Connection,\n   282→  creator: PublicKey\n   283→): Promise<UIMatch | null> {\n   284→  const program = getCoinflipProgram(connection);\n   285→  const [matchPda] = getMatchPda(creator);\n   286→\n   287→  try {\n   288→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   289→    const data = account as unknown as OnChainMatch;\n   290→    const match = onChainMatchToUI(matchPda, data);\n   291→\n   292→    const vrfByte = isPhase(data.phase, \"locked\")\n   293→      ? await readVrfRandomness(connection, data.vrfRequestKey)\n   294→      : null;\n   295→    if (vrfByte !== null) {\n   296→      const derived = deriveWinnerFromVrf(vrfByte, data);\n   297→      return { ...match, phase: \"complete\", result: derived.result, winner: derived.winner };\n   298→    }\n   299→\n   300→    return match;\n   301→  } catch {\n   302→    // Account doesn't exist\n   303→    return null;\n   304→  }\n   305→}\n   306→\n   307→export async function fetchMatch(\n   308→  connection: Connection,\n   309→  matchPda: PublicKey\n   310→): Promise<UIMatch | null> {\n   311→  const program = getCoinflipProgram(connection);\n   312→\n   313→  try {\n   314→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   315→    const data = account as unknown as OnChainMatch;\n   316→    const match = onChainMatchToUI(matchPda, data);\n   317→\n   318→    // If on-chain phase is Locked but VRF has resolved, show as \"complete\"\n   319→    // so the Settle button appears instead of Cancel & Refund.\n   320→    const vrfByte = isPhase(data.phase, \"locked\")\n   321→      ? await readVrfRandomness(connection, data.vrfRequestKey)\n   322→      : null;\n   323→    if (vrfByte !== null) {\n   324→      const derived = deriveWinnerFromVrf(vrfByte, data);\n   325→      return { ...match, phase: \"complete\", result: derived.result, winner: derived.winner };\n   326→    }\n   327→\n   328→    return match;\n   329→  } catch {\n   330→    return null;\n   331→  }\n   332→}\n   333→\n   334→// ============ Instruction Builders ============\n   335→\n   336→export async function buildCreateMatchTx(\n   337→  connection: Connection,\n   338→  creator: PublicKey,\n   339→  tier: Tier,\n   340→  side: CoinSide\n   341→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   342→  const program = getCoinflipProgram(connection);\n   343→  const [matchPda] = getMatchPda(creator);\n   344→  const [configPda] = getConfigPda();\n   345→\n   346→  const tierIndex = TIER_VALUES[tier];\n   347→  const sideIndex = COIN_SIDE_VALUES[side];\n   348→\n   349→  const ix = await program.methods\n   350→    .createMatch(tierIndex, sideIndex)\n   351→    .accountsStrict({\n   352→      creator,\n   353→      coinflipMatch: matchPda,\n   354→      config: configPda,\n   355→      systemProgram: SystemProgram.programId,\n   356→    })\n   357→    .instruction();\n   358→\n   359→  const tx = new Transaction().add(ix);\n   360→  tx.feePayer = creator;\n   361→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   362→\n   363→  return { transaction: tx, matchPda };\n   364→}\n   365→\n   366→export async function buildJoinMatchTx(\n   367→  connection: Connection,\n   368→  opponent: PublicKey,\n   369→  matchCreator: PublicKey\n   370→): Promise<Transaction> {\n   371→  const program = getCoinflipProgram(connection);\n   372→  const [matchPda] = getMatchPda(matchCreator);\n   373→  const [configPda] = getConfigPda();\n   374→\n   375→  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n   376→  const oraoNetworkState = getOraoNetworkStatePda();\n   377→  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n   378→  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n   379→  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n   380→  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n   381→  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n   382→\n   383→  const ix = await program.methods\n   384→    .joinMatch()\n   385→    .accountsStrict({\n   386→      opponent,\n   387→      coinflipMatch: matchPda,\n   388→      config: configPda,\n   389→      oraoProgram: ORAO_VRF_PROGRAM_ID,\n   390→      oraoNetworkState,\n   391→      oraoTreasury,\n   392→      oraoRandom,\n   393→      systemProgram: SystemProgram.programId,\n   394→    })\n   395→    .instruction();\n   396→\n   397→  const tx = new Transaction().add(ix);\n   398→  tx.feePayer = opponent;\n   399→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   400→\n   401→  return tx;\n   402→}\n   403→\n   404→export async function buildCancelMatchTx(\n   405→  connection: Connection,\n   406→  creator: PublicKey\n   407→): Promise<Transaction> {\n   408→  const program = getCoinflipProgram(connection);\n   409→  const [matchPda] = getMatchPda(creator);\n   410→\n   411→  const ix = await program.methods\n   412→    .cancelMatch()\n   413→    .accountsStrict({\n   414→      creator,\n   415→      coinflipMatch: matchPda,\n   416→      systemProgram: SystemProgram.programId,\n   417→    })\n   418→    .instruction();\n   419→\n   420→  const tx = new Transaction().add(ix);\n   421→  tx.feePayer = creator;\n   422→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   423→\n   424→  return tx;\n   425→}\n   426→\n   427→export async function buildTimeoutCancelTx(\n   428→  connection: Connection,\n   429→  caller: PublicKey,\n   430→  matchCreator: PublicKey,\n   431→  opponent: PublicKey\n   432→): Promise<Transaction> {\n   433→  const program = getCoinflipProgram(connection);\n   434→  const [matchPda] = getMatchPda(matchCreator);\n   435→\n   436→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   437→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   438→\n   439→  const ix = await program.methods\n   440→    .timeoutCancel()\n   441→    .accountsStrict({\n   442→      caller,\n   443→      creator: matchCreator,\n   444→      opponent,\n   445→      coinflipMatch: matchPda,\n   446→      randomnessAccount,\n   447→    })\n   448→    .instruction();\n   449→\n   450→  const tx = new Transaction().add(ix);\n   451→  tx.feePayer = caller;\n   452→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   453→\n   454→  return tx;\n   455→}\n   456→\n   457→export async function buildClaimPayoutTx(\n   458→  connection: Connection,\n   459→  caller: PublicKey,\n   460→  matchCreator: PublicKey,\n   461→  opponent: PublicKey\n   462→): Promise<Transaction> {\n   463→  const program = getCoinflipProgram(connection);\n   464→  const [matchPda] = getMatchPda(matchCreator);\n   465→  const [configPda] = getConfigPda();\n   466→\n   467→  // Fetch config to get treasury address\n   468→  const config = await program.account.coinflipConfig.fetch(configPda);\n   469→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   470→\n   471→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   472→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   473→\n   474→  // Derive player profile PDAs for CPI\n   475→  const PLATFORM_PROGRAM_ID = new PublicKey(\n   476→    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n   477→      .VITE_PLATFORM_PROGRAM_ID ?? \"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n   478→  );\n   479→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   480→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   481→    PLATFORM_PROGRAM_ID\n   482→  );\n   483→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   484→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   485→    PLATFORM_PROGRAM_ID\n   486→  );\n   487→\n   488→  const ix = await program.methods\n   489→    .claimPayout()\n   490→    .accountsStrict({\n   491→      caller,\n   492→      coinflipMatch: matchPda,\n   493→      config: configPda,\n   494→      treasury,\n   495→      creator: matchCreator,\n   496→      opponent,\n   497→      randomnessAccount,\n   498→      creatorProfile,\n   499→      opponentProfile,\n   500→      platformProgram: PLATFORM_PROGRAM_ID,\n   501→      systemProgram: SystemProgram.programId,\n   502→    })\n   503→    .instruction();\n   504→\n   505→  const tx = new Transaction().add(ix);\n   506→  tx.feePayer = caller;\n   507→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   508→\n   509→  return tx;\n   510→}\n   511→"}]},"parent_tool_use_id":null,"session_id":"8e5d7c3d-ef66-4971-8f66-de7d7c43ed7c","uuid":"7a28603c-0a91-426e-a6a1-6151e1089934","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts","content":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  COIN_SIDE_VALUES,\n  TIER_AMOUNTS,\n  type Tier,\n  type CoinSide,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n);\n\n// Orao VRF program (on-chain VRF provider)\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n\n// ============ PDA Derivation ============\n\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n/** Orao VRF network state PDA (stores config + treasury). */\nfunction getOraoNetworkStatePda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n/** Orao VRF randomness PDA derived from a 32-byte seed. */\nfunction getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ============ Program Instance ============\n\nfunction getCoinflipProgram(connection: Connection): Program<Coinflip> {\n  // Read-only provider (no wallet needed for queries)\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n}\n\n// ============ On-Chain Account Types ============\n\n/** Anchor enum variant representation — one key with empty object value. */\ntype RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n  | { resolving: object } | { settled: object } | { refunded: object };\n\ninterface OnChainMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  tier: number;\n  entryAmount: { toNumber(): number };\n  creatorSide: number;\n  phase: RoundPhaseVariant;\n  result: number;\n  winner: PublicKey;\n  claimed: boolean;\n  createdAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  bump: number;\n}\n\n// ============ Converters ============\n\nfunction tierFromIndex(index: number): Tier {\n  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n  return tiers[index] ?? \"iron\";\n}\n\nfunction sideFromIndex(index: number): CoinSide {\n  return index === 0 ? \"heads\" : \"tails\";\n}\n\nfunction isPhase(phase: RoundPhaseVariant, name: string): boolean {\n  return name in phase;\n}\n\nfunction phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n  if (isPhase(phase, \"waiting\")) return \"created\";\n  if (isPhase(phase, \"locked\")) return \"ready\";\n  if (isPhase(phase, \"settled\")) return \"complete\";\n  return \"created\";\n}\n\nconst DEFAULT_PUBKEY = PublicKey.default;\n\nfunction isDefaultPubkey(key: PublicKey): boolean {\n  return key.equals(DEFAULT_PUBKEY);\n}\n\nexport function onChainMatchToUI(\n  matchPda: PublicKey,\n  data: OnChainMatch\n): UIMatch {\n  const tier = tierFromIndex(data.tier);\n  const creatorSide = sideFromIndex(data.creatorSide);\n  const hasOpponent = !isDefaultPubkey(data.opponent);\n  const phase = phaseToUI(data.phase);\n  const isSettled = isPhase(data.phase, \"settled\");\n\n  const entryAmountSol = TIER_AMOUNTS[tier];\n  const totalPool = entryAmountSol * 2;\n  const payoutAmount = totalPool * 0.97;\n\n  const lockedAt = data.lockedAt.toNumber();\n\n  return {\n    id: matchPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    player1: data.creator.toBase58(),\n    player1Side: creatorSide,\n    player2: hasOpponent ? data.opponent.toBase58() : null,\n    player2Side: hasOpponent\n      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n      : null,\n    phase,\n    createdAt: Date.now(),\n    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n    result: isSettled ? sideFromIndex(data.result) : null,\n    winner: isSettled && !isDefaultPubkey(data.winner)\n      ? data.winner.toBase58()\n      : null,\n    claimed: data.claimed,\n    payoutAmount,\n    seedHash: \"\",\n  };\n}\n\n/** Read fulfilled VRF randomness bytes from an Orao randomness account.\n *  Returns the first randomness byte (used for coin flip result) or null if not fulfilled. */\nasync function readVrfRandomness(\n  connection: Connection,\n  vrfRequestKey: PublicKey\n): Promise<number | null> {\n  try {\n    if (isDefaultPubkey(vrfRequestKey)) return null;\n    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      // Orao randomness account: 8-byte discriminator then randomness data.\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      if (randomnessData.some((b: number) => b !== 0)) {\n        return randomnessData[0] ?? null;\n      }\n    }\n  } catch {\n    // Ignore — treat as not fulfilled\n  }\n  return null;\n}\n\n/** Derive client-side winner from VRF randomness for a locked match. */\nfunction deriveWinnerFromVrf(\n  firstByte: number,\n  data: OnChainMatch\n): { result: CoinSide; winner: string } {\n  const resultSide = firstByte % 2; // 0 = heads, 1 = tails — matches on-chain from_randomness()\n  const creatorWins = resultSide === data.creatorSide;\n  return {\n    result: sideFromIndex(resultSide),\n    winner: creatorWins\n      ? data.creator.toBase58()\n      : data.opponent.toBase58(),\n  };\n}\n\n// ============ Account Queries ============\n\nexport async function fetchAllOpenMatches(\n  connection: Connection\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const accounts = await program.account.coinflipMatch.all();\n\n  return accounts\n    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n    .map((acc) =>\n      onChainMatchToUI(\n        acc.publicKey,\n        acc.account as unknown as OnChainMatch\n      )\n    );\n}\n\n/**\n * Fetch all matches where playerPubkey is creator OR opponent,\n * claimed == false, and phase is non-terminal (not refunded).\n * Uses memcmp filters for efficient on-chain filtering.\n *\n * Account layout offsets (after 8-byte discriminator):\n *   creator:  8   (32 bytes)\n *   opponent: 40  (32 bytes)\n *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n */\nexport async function fetchClaimableMatches(\n  connection: Connection,\n  playerPubkey: PublicKey\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const playerBase58 = playerPubkey.toBase58();\n\n  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n\n  const [asCreator, asOpponent] = await Promise.all([\n    program.account.coinflipMatch.all([\n      { memcmp: { offset: 8, bytes: playerBase58 } },\n      claimedFalseFilter,\n    ]),\n    program.account.coinflipMatch.all([\n      { memcmp: { offset: 40, bytes: playerBase58 } },\n      claimedFalseFilter,\n    ]),\n  ]);\n\n  // Merge and deduplicate by public key\n  const seen = new Set<string>();\n  const matches: UIMatch[] = [];\n\n  for (const acc of [...asCreator, ...asOpponent]) {\n    const key = acc.publicKey.toBase58();\n    if (seen.has(key)) continue;\n    seen.add(key);\n\n    const data = acc.account as unknown as OnChainMatch;\n    // Skip terminal phase (refunded)\n    if (isPhase(data.phase, \"refunded\")) continue;\n\n    const match = onChainMatchToUI(acc.publicKey, data);\n\n    // Upgrade Locked → complete when VRF has resolved, deriving winner client-side\n    const vrfByte = isPhase(data.phase, \"locked\")\n      ? await readVrfRandomness(connection, data.vrfRequestKey)\n      : null;\n    if (vrfByte !== null) {\n      const derived = deriveWinnerFromVrf(vrfByte, data);\n      matches.push({ ...match, phase: \"complete\", result: derived.result, winner: derived.winner });\n    } else {\n      matches.push(match);\n    }\n  }\n\n  return matches;\n}\n\nexport async function fetchMatchByCreator(\n  connection: Connection,\n  creator: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    const data = account as unknown as OnChainMatch;\n    const match = onChainMatchToUI(matchPda, data);\n\n    const vrfByte = isPhase(data.phase, \"locked\")\n      ? await readVrfRandomness(connection, data.vrfRequestKey)\n      : null;\n    if (vrfByte !== null) {\n      const derived = deriveWinnerFromVrf(vrfByte, data);\n      return { ...match, phase: \"complete\", result: derived.result, winner: derived.winner };\n    }\n\n    return match;\n  } catch {\n    // Account doesn't exist\n    return null;\n  }\n}\n\nexport async function fetchMatch(\n  connection: Connection,\n  matchPda: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    const data = account as unknown as OnChainMatch;\n    const match = onChainMatchToUI(matchPda, data);\n\n    // If on-chain phase is Locked but VRF has resolved, show as \"complete\"\n    // so the Settle button appears instead of Cancel & Refund.\n    const vrfByte = isPhase(data.phase, \"locked\")\n      ? await readVrfRandomness(connection, data.vrfRequestKey)\n      : null;\n    if (vrfByte !== null) {\n      const derived = deriveWinnerFromVrf(vrfByte, data);\n      return { ...match, phase: \"complete\", result: derived.result, winner: derived.winner };\n    }\n\n    return match;\n  } catch {\n    return null;\n  }\n}\n\n// ============ Instruction Builders ============\n\nexport async function buildCreateMatchTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n  const [configPda] = getConfigPda();\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const ix = await program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, matchPda };\n}\n\nexport async function buildJoinMatchTx(\n  connection: Connection,\n  opponent: PublicKey,\n  matchCreator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n  const oraoNetworkState = getOraoNetworkStatePda();\n  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n\n  const ix = await program.methods\n    .joinMatch()\n    .accountsStrict({\n      opponent,\n      coinflipMatch: matchPda,\n      config: configPda,\n      oraoProgram: ORAO_VRF_PROGRAM_ID,\n      oraoNetworkState,\n      oraoTreasury,\n      oraoRandom,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = opponent;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildCancelMatchTx(\n  connection: Connection,\n  creator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const ix = await program.methods\n    .cancelMatch()\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildTimeoutCancelTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n\n  // Derive randomness account from match PDA (VRF seed = match PDA key)\n  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n\n  const ix = await program.methods\n    .timeoutCancel()\n    .accountsStrict({\n      caller,\n      creator: matchCreator,\n      opponent,\n      coinflipMatch: matchPda,\n      randomnessAccount,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get treasury address\n  const config = await program.account.coinflipConfig.fetch(configPda);\n  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n\n  // Derive randomness account from match PDA (VRF seed = match PDA key)\n  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n\n  // Derive player profile PDAs for CPI\n  const PLATFORM_PROGRAM_ID = new PublicKey(\n    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n      .VITE_PLATFORM_PROGRAM_ID ?? \"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n  );\n  const [creatorProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  const [opponentProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n\n  const ix = await program.methods\n    .claimPayout()\n    .accountsStrict({\n      caller,\n      coinflipMatch: matchPda,\n      config: configPda,\n      treasury,\n      creator: matchCreator,\n      opponent,\n      randomnessAccount,\n      creatorProfile,\n      opponentProfile,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n","numLines":511,"startLine":1,"totalLines":511}}}
