      ],\n   131→          \"writable\": true,\n   132→          \"signer\": true\n   133→        },\n   134→        {\n   135→          \"name\": \"round\",\n   136→          \"docs\": [\n   137→            \"The round PDA (closed after claim — rent refunded to round creator).\"\n   138→          ],\n   139→          \"writable\": true\n   140→        },\n   141→        {\n   142→          \"name\": \"config\",\n   143→          \"docs\": [\n   144→            \"The config PDA (for treasury address).\"\n   145→          ],\n   146→          \"pda\": {\n   147→            \"seeds\": [\n   148→              {\n   149→                \"kind\": \"const\",\n   150→                \"value\": [\n   151→                  108,\n   152→                  111,\n   153→                  114,\n   154→                  100,\n   155→                  95,\n   156→                  99,\n   157→                  111,\n   158→                  110,\n   159→                  102,\n   160→                  105,\n   161→                  103\n   162→                ]\n   163→              }\n   164→            ]\n   165→          }\n   166→        },\n   167→        {\n   168→          \"name\": \"treasury\",\n   169→          \"docs\": [\n   170→            \"The treasury account to receive fees.\"\n   171→          ],\n   172→          \"writable\": true\n   173→        },\n   174→        {\n   175→          \"name\": \"round_creator\",\n   176→          \"docs\": [\n   177→            \"The round creator account (receives rent refund on close).\"\n   178→          ],\n   179→          \"writable\": true\n   180→        },\n   181→        {\n   182→          \"name\": \"winner_account\",\n   183→          \"docs\": [\n   184→            \"The winner account to receive payout.\"\n   185→          ],\n   186→          \"writable\": true\n   187→        },\n   188→        {\n   189→          \"name\": \"randomness_account\",\n   190→          \"docs\": [\n   191→            \"The Orao ran