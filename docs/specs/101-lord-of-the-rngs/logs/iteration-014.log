{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FgzUhXgr3PFtTzKLQ7Qhrp","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→use rng_shared::fees::calculate_net_payout;\n     4→use rng_shared::lifecycle::RoundPhase;\n     5→use rng_shared::vrf_orao::read_orao_randomness;\n     6→\n     7→use crate::error::LordError;\n     8→use crate::state::{JackpotRound, LordConfig, RoundSettled};\n     9→\n    10→#[derive(Accounts)]\n    11→#[instruction(tier: u8, round_number: u64)]\n    12→pub struct ClaimPayout<'info> {\n    13→    /// Any participant can trigger the claim (permissionless after VRF fulfilled).\n    14→    #[account(mut)]\n    15→    pub caller: Signer<'info>,\n    16→\n    17→    /// The round PDA (closed after claim — rent refunded to round creator).\n    18→    #[account(\n    19→        mut,\n    20→        close = round_creator,\n    21→        seeds = [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()],\n    22→        bump = round.bump,\n    23→    )]\n    24→    pub round: Account<'info, JackpotRound>,\n    25→\n    26→    /// The config PDA (for treasury address).\n    27→    #[account(\n    28→        seeds = [b\"lord_config\"],\n    29→        bump = config.bump,\n    30→    )]\n    31→    pub config: Account<'info, LordConfig>,\n    32→\n    33→    /// The treasury account to receive fees.\n    34→    /// CHECK: Validated against config.treasury in handler.\n    35→    #[account(mut)]\n    36→    pub treasury: AccountInfo<'info>,\n    37→\n    38→    /// The round creator account (receives rent refund on close).\n    39→    /// CHECK: Validated against round.creator in handler.\n    40→    #[account(mut)]\n    41→    pub round_creator: AccountInfo<'info>,\n    42→\n    43→    /// The winner account to receive payout.\n    44→    /// CHECK: Validated against derived winner in handler.\n    45→    #[account(mut)]\n    46→    pub winner_account: AccountInfo<'info>,\n    47→\n    48→    /// The Orao randomness PDA — must match vrf_request_key stored on round.\n    49→    /// CHECK: Key validated against round.vrf_request_key; data read by shared VRF helper.\n    50→    pub randomness_account: AccountInfo<'info>,\n    51→\n    52→    pub system_program: Program<'info, System>,\n    53→}\n    54→\n    55→pub fn handler(ctx: Context<ClaimPayout>, _tier: u8, _round_number: u64) -> Result<()> {\n    56→    let round = &ctx.accounts.round;\n    57→\n    58→    // (1) Must be in LOCKED phase and not already claimed\n    59→    require!(\n    60→        round.phase == RoundPhase::Locked,\n    61→        LordError::InvalidPhase\n    62→    );\n    63→    require!(!round.claimed, LordError::AlreadyClaimed);\n    64→\n    65→    // Validate accounts match stored state\n    66→    require!(\n    67→        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n    68→        LordError::InvalidPhase\n    69→    );\n    70→    require!(\n    71→        ctx.accounts.round_creator.key() == round.creator,\n    72→        LordError::InvalidPhase\n    73→    );\n    74→    require!(\n    75→        ctx.accounts.randomness_account.key() == round.vrf_request_key,\n    76→        LordError::InvalidPhase\n    77→    );\n    78→\n    79→    // (2) Read Orao randomness — rejects if not fulfilled\n    80→    let randomness = read_orao_randomness(&ctx.accounts.randomness_account)?;\n    81→\n    82→    // (3) Derive winning slot from randomness\n    83→    // Use first 8 bytes as u64, mod total_entries → winning slot index\n    84→    let rand_u64 = u64::from_le_bytes(randomness[0..8].try_into().unwrap());\n    85→    let total_entries = round.total_entries as u64;\n    86→    let winning_slot = (rand_u64 % total_entries) as u32;\n    87→\n    88→    // (4) Map winning slot to winner player\n    89→    // Slots are assigned sequentially: player 0 owns slots [0..entries_0),\n    90→    // player 1 owns [entries_0..entries_0+entries_1), etc.\n    91→    let mut cumulative: u32 = 0;\n    92→    let mut winner = Pubkey::default();\n    93→    for entry in &round.players {\n    94→        cumulative += entry.entries;\n    95→        if winning_slot < cumulative {\n    96→            winner = entry.player;\n    97→            break;\n    98→        }\n    99→    }\n   100→\n   101→    // Validate winner_account matches the derived winner\n   102→    require!(\n   103→        ctx.accounts.winner_account.key() == winner,\n   104→        LordError::NotWinner\n   105→    );\n   106→\n   107→    // (5) Compute fee/payout from the total pool\n   108→    let pool = round\n   109→        .entry_amount\n   110→        .checked_mul(total_entries)\n   111→        .ok_or(LordError::ArithmeticOverflow)?;\n   112→    let (fee, payout) = calculate_net_payout(pool);\n   113→\n   114→    // (6) Transfer payout to winner + fee to treasury\n   115→    let round_info = ctx.accounts.round.to_account_info();\n   116→    transfer_lamports_from_pda(&round_info, &ctx.accounts.winner_account, payout)?;\n   117→    transfer_lamports_from_pda(&round_info, &ctx.accounts.treasury, fee)?;\n   118→\n   119→    // (7) Emit RoundSettled event (audit trail persists in tx logs after PDA closed)\n   120→    emit!(RoundSettled {\n   121→        tier: round.tier,\n   122→        round_number: round.round_number,\n   123→        winner,\n   124→        randomness,\n   125→        winning_slot,\n   126→        total_entries: round.total_entries,\n   127→        payout_amount: payout,\n   128→        fee_amount: fee,\n   129→        vrf_request_key: round.vrf_request_key,\n   130→    });\n   131→\n   132→    // (8) Set phase = Settled, claimed = true, store winner + slot\n   133→    // Note: LOCKED → SETTLED is intentionally not in the transition() function;\n   134→    // VRF games handle this phase change directly after reading randomness.\n   135→    let round = &mut ctx.accounts.round;\n   136→    round.phase = RoundPhase::Settled;\n   137→    round.claimed = true;\n   138→    round.winning_slot = winning_slot;\n   139→    round.winner = winner;\n   140→\n   141→    // Account is closed by Anchor's `close = round_creator` constraint after handler returns.\n   142→    // Remaining lamports (rent) are sent to the round creator.\n   143→\n   144→    Ok(())\n   145→}\n   146→"}]},"parent_tool_use_id":null,"session_id":"8e5d7c3d-ef66-4971-8f66-de7d7c43ed7c","uuid":"3b2f9c7a-382b-419a-ba33-906551bdb67a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/lordofrngs/src/instructions/claim_payout.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_from_pda;\nuse rng_shared::fees::calculate_net_payout;\nuse rng_shared::lifecycle::RoundPhase;\nuse rng_shared::vrf_orao::read_orao_randomness;\n\nuse crate::error::LordError;\nuse crate::state::{JackpotRound, LordConfig, RoundSettled};\n\n#[derive(Accounts)]\n#[instruction(tier: u8, round_number: u64)]\npub struct ClaimPayout<'info> {\n    /// Any participant can trigger the claim (permissionless after VRF fulfilled).\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The round PDA (closed after claim — rent refunded to round creator).\n    #[account(\n        mut,\n        close = round_creator,\n        seeds = [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()],\n        bump = round.bump,\n    )]\n    pub round: Account<'info, JackpotRound>,\n\n    /// The config PDA (for treasury address).\n    #[account(\n        seeds = [b\"lord_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, LordConfig>,\n\n    /// The treasury account to receive fees.\n    /// CHECK: Validated against config.treasury in handler.\n    #[account(mut)]\n    pub treasury: AccountInfo<'info>,\n\n    /// The round creator account (receives rent refund on close).\n    /// CHECK: Validated against round.creator in handler.\n    #[account(mut)]\n    pub round_creator: AccountInfo<'info>,\n\n    /// The winner account to receive payout.\n    /// CHECK: Validated against derived winner in handler.\n    #[account(mut)]\n    pub winner_account: AccountInfo<'info>,\n\n    /// The Orao randomness PDA — must match vrf_request_key stored on round.\n    /// CHECK: Key validated against round.vrf_request_key; data read by shared VRF helper.\n    pub randomness_account: AccountInfo<'info>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<ClaimPayout>, _tier: u8, _round_number: u64) -> Result<()> {\n    let round = &ctx.accounts.round;\n\n    // (1) Must be in LOCKED phase and not already claimed\n    require!(\n        round.phase == RoundPhase::Locked,\n        LordError::InvalidPhase\n    );\n    require!(!round.claimed, LordError::AlreadyClaimed);\n\n    // Validate accounts match stored state\n    require!(\n        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n        LordError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.round_creator.key() == round.creator,\n        LordError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.randomness_account.key() == round.vrf_request_key,\n        LordError::InvalidPhase\n    );\n\n    // (2) Read Orao randomness — rejects if not fulfilled\n    let randomness = read_orao_randomness(&ctx.accounts.randomness_account)?;\n\n    // (3) Derive winning slot from randomness\n    // Use first 8 bytes as u64, mod total_entries → winning slot index\n    let rand_u64 = u64::from_le_bytes(randomness[0..8].try_into().unwrap());\n    let total_entries = round.total_entries as u64;\n    let winning_slot = (rand_u64 % total_entries) as u32;\n\n    // (4) Map winning slot to winner player\n    // Slots are assigned sequentially: player 0 owns slots [0..entries_0),\n    // player 1 owns [entries_0..entries_0+entries_1), etc.\n    let mut cumulative: u32 = 0;\n    let mut winner = Pubkey::default();\n    for entry in &round.players {\n        cumulative += entry.entries;\n        if winning_slot < cumulative {\n            winner = entry.player;\n            break;\n        }\n    }\n\n    // Validate winner_account matches the derived winner\n    require!(\n        ctx.accounts.winner_account.key() == winner,\n        LordError::NotWinner\n    );\n\n    // (5) Compute fee/payout from the total pool\n    let pool = round\n        .entry_amount\n        .checked_mul(total_entries)\n        .ok_or(LordError::ArithmeticOverflow)?;\n    let (fee, payout) = calculate_net_payout(pool);\n\n    // (6) Transfer payout to winner + fee to treasury\n    let round_info = ctx.accounts.round.to_account_info();\n    transfer_lamports_from_pda(&round_info, &ctx.accounts.winner_account, payout)?;\n    transfer_lamports_from_pda(&round_info, &ctx.accounts.treasury, fee)?;\n\n    // (7) Emit RoundSettled event (audit trail persists in tx logs after PDA closed)\n    emit!(RoundSettled {\n        tier: round.tier,\n        round_number: round.round_number,\n        winner,\n        randomness,\n        winning_slot,\n        total_entries: round.total_entries,\n        payout_amount: payout,\n        fee_amount: fee,\n        vrf_request_key: round.vrf_request_key,\n    });\n\n    // (8) Set phase = Settled, claimed = true, store winner + slot\n    // Note: LOCKED → SETTLED is intentionally not in the transition() function;\n    // VRF games handle this phase change directly after reading randomness.\n    let round = &mut ctx.accounts.round;\n    round.phase = RoundPhase::Settled;\n    round.claimed = true;\n    round.winning_slot = winning_slot;\n    round.winner = winner;\n\n    // Account is closed by Anchor's `close = round_creator` constraint after handler returns.\n    // Remaining lamports (rent) are sent to the round creator.\n\n    Ok(())\n}\n","numLines":146,"startLine":1,"totalLines":146}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01CMhQR5GV7KzwvatydnUh2L","type":"message","role":"assistant","content":[{"type":"text","text":"Now I have all the information I need. The lordofrngs `claim_payout` is simpler than coinflip's — it doesn't have platform CPI (no remaining_accounts for player profiles). The round PDA is closed after claim.\n\nNow I'll create the `chain.ts` file. The spec says:\n> Create `features/lord-of-rngs/utils/chain.ts` — real on-chain transaction builders and queries: `buildJoinRoundTx`, `buildBuyMoreEntriesTx`, `buildStartSpinTx`, `buildClaimPayoutTx`, `fetchRound`, `fetchAllTierRounds`, `fetchClaimableRounds`. Pattern: mirror coinflip `chain.ts`. Verify: TypeScript compiles."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2288,"cache_read_input_tokens":92068,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2288},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8e5d7c3d-ef66-4971-8f66-de7d7c43ed7c","uuid":"3c4cc20e-ba78-406e-b701-00df9c807095"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01CMhQR5GV7KzwvatydnUh2L","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EtXW7gJBA1F5SKBeau6zt8","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/chain.ts","content":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport { LordofrngsIDL, type Lordofrngs } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_AMOUNTS,\n  TIER_VALUES,\n  type Tier,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { Round, PlayerEntry } from \"../types\";\nimport { PLAYER_COLORS } from \"../types\";\n\n// ============ Constants ============\n\nconst LORDOFRNGS_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_LORDOFRNGS_PROGRAM_ID ?? LordofrngsIDL.address\n);\n\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\n  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\"\n);\n\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\n// ============ PDA Derivation ============\n\nexport function getRoundPda(\n  tier: number,\n  roundNumber: bigint | number\n): [PublicKey, number] {\n  const tierBuf = Buffer.alloc(1);\n  tierBuf.writeUInt8(tier);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\nfunction getOraoNetworkStatePda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ============ Program Instance ============\n\nfunction getLordProgram(connection: Connection): Program<Lordofrngs> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n}\n\n// ============ On-Chain Account Types ============\n\ntype RoundPhaseVariant =\n  | { waiting: object }\n  | { active: object }\n  | { locked: object }\n  | { resolving: object }\n  | { settled: object }\n  | { refunded: object };\n\ninterface OnChainPlayerEntry {\n  player: PublicKey;\n  entries: number;\n}\n\ninterface OnChainRound {\n  tier: number;\n  roundNumber: { toNumber(): number };\n  entryAmount: { toNumber(): number };\n  phase: RoundPhaseVariant;\n  players: OnChainPlayerEntry[];\n  totalEntries: number;\n  createdAt: { toNumber(): number };\n  countdownEndsAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  winningSlot: number;\n  winner: PublicKey;\n  claimed: boolean;\n  creator: PublicKey;\n  bump: number;\n}\n\ninterface OnChainConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  paused: boolean;\n  roundCounters: { toNumber(): number }[];\n  bump: number;\n}\n\n// ============ Converters ============\n\nconst TIERS: Tier[] = [\n  \"iron\",\n  \"bronze\",\n  \"silver\",\n  \"gold\",\n  \"platinum\",\n  \"diamond\",\n];\n\nfunction tierFromIndex(index: number): Tier {\n  return TIERS[index] ?? \"iron\";\n}\n\nfunction isPhase(phase: RoundPhaseVariant, name: string): boolean {\n  return name in phase;\n}\n\nfunction phaseToUI(phase: RoundPhaseVariant): Round[\"phase\"] {\n  if (isPhase(phase, \"waiting\")) return \"waiting\";\n  if (isPhase(phase, \"active\")) return \"countdown\";\n  if (isPhase(phase, \"locked\")) return \"spinning\";\n  if (isPhase(phase, \"settled\")) return \"complete\";\n  // Resolving, Refunded → treat as complete for display\n  return \"complete\";\n}\n\nfunction getPlayerColor(index: number, isCurrentUser: boolean): string {\n  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\";\n  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n}\n\nfunction onChainPlayersToUI(\n  players: OnChainPlayerEntry[],\n  currentWallet?: string\n): PlayerEntry[] {\n  return players.map((p, i) => ({\n    address: p.player.toBase58(),\n    entries: p.entries,\n    color: getPlayerColor(i, p.player.toBase58() === currentWallet),\n  }));\n}\n\nexport function onChainRoundToUI(\n  roundPda: PublicKey,\n  data: OnChainRound,\n  currentWallet?: string\n): Round {\n  const tier = tierFromIndex(data.tier);\n  const entryAmountLamports = data.entryAmount.toNumber();\n  const entryAmountSol = entryAmountLamports / LAMPORTS_PER_SOL;\n  const totalEntries = data.totalEntries;\n  const poolAmount = entryAmountSol * totalEntries;\n  const phase = phaseToUI(data.phase);\n  const isSettled = isPhase(data.phase, \"settled\");\n  const countdownEndsAt = data.countdownEndsAt.toNumber();\n  const lockedAt = data.lockedAt.toNumber();\n\n  const winner = isSettled ? data.winner : undefined;\n  const isDefaultWinner =\n    winner && winner.equals(PublicKey.default) ? undefined : winner;\n\n  return {\n    id: roundPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    phase,\n    players: onChainPlayersToUI(data.players, currentWallet),\n    totalEntries,\n    poolAmount,\n    createdAt: data.createdAt.toNumber() * 1000,\n    countdownStartedAt:\n      countdownEndsAt > 0 ? (countdownEndsAt - 60) * 1000 : undefined,\n    countdownEndsAt: countdownEndsAt > 0 ? countdownEndsAt * 1000 : undefined,\n    winningSlot: isSettled ? data.winningSlot : undefined,\n    winner: isDefaultWinner?.toBase58(),\n    payoutAmount: isSettled ? poolAmount * 0.97 : undefined,\n    claimed: data.claimed,\n    seedHash: data.vrfRequestKey.equals(PublicKey.default)\n      ? \"\"\n      : data.vrfRequestKey.toBase58(),\n    vrfProof: isSettled\n      ? data.vrfRequestKey.toBase58()\n      : undefined,\n  };\n}\n\n/** Read VRF randomness from an Orao account. Returns 32 bytes or null. */\nasync function readVrfRandomness(\n  connection: Connection,\n  vrfRequestKey: PublicKey\n): Promise<Uint8Array | null> {\n  try {\n    if (vrfRequestKey.equals(PublicKey.default)) return null;\n    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      if (randomnessData.some((b: number) => b !== 0)) {\n        return randomnessData.subarray(0, 32);\n      }\n    }\n  } catch {\n    // Ignore\n  }\n  return null;\n}\n\n/** Derive winner from VRF randomness for a locked round. */\nfunction deriveWinnerFromVrf(\n  randomness: Uint8Array,\n  data: OnChainRound\n): { winningSlot: number; winner: PublicKey } {\n  const view = new DataView(\n    randomness.buffer,\n    randomness.byteOffset,\n    8\n  );\n  const raw = view.getBigUint64(0, true);\n  const winningSlot = Number(raw % BigInt(data.totalEntries));\n\n  let cumulative = 0;\n  for (const p of data.players) {\n    cumulative += p.entries;\n    if (winningSlot < cumulative) {\n      return { winningSlot, winner: p.player };\n    }\n  }\n  return { winningSlot, winner: data.players[0]!.player };\n}\n\n// ============ Account Queries ============\n\n/** Fetch a single round by tier and round number. */\nexport async function fetchRound(\n  connection: Connection,\n  tier: number,\n  roundNumber: bigint | number,\n  currentWallet?: string\n): Promise<Round | null> {\n  const program = getLordProgram(connection);\n  const [roundPda] = getRoundPda(tier, roundNumber);\n\n  try {\n    const account = await program.account.jackpotRound.fetch(roundPda);\n    const data = account as unknown as OnChainRound;\n    const round = onChainRoundToUI(roundPda, data, currentWallet);\n\n    // If Locked, check if VRF is fulfilled to upgrade to spinning/revealing\n    if (isPhase(data.phase, \"locked\")) {\n      const randomness = await readVrfRandomness(\n        connection,\n        data.vrfRequestKey\n      );\n      if (randomness) {\n        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n        return {\n          ...round,\n          phase: \"revealing\",\n          winningSlot,\n          winner: winner.toBase58(),\n          payoutAmount: round.poolAmount * 0.97,\n        };\n      }\n    }\n\n    return round;\n  } catch {\n    return null;\n  }\n}\n\n/** Fetch the current round for each tier. Returns a map of tier → Round. */\nexport async function fetchAllTierRounds(\n  connection: Connection,\n  currentWallet?: string\n): Promise<Map<Tier, Round>> {\n  const program = getLordProgram(connection);\n  const result = new Map<Tier, Round>();\n\n  // Fetch all JackpotRound accounts\n  const accounts = await program.account.jackpotRound.all();\n\n  // Group by tier — pick the latest (highest roundNumber) non-terminal round per tier\n  const byTier = new Map<number, { pda: PublicKey; data: OnChainRound }>();\n\n  for (const acc of accounts) {\n    const data = acc.account as unknown as OnChainRound;\n    // Skip terminal phases\n    if (isPhase(data.phase, \"settled\") || isPhase(data.phase, \"refunded\"))\n      continue;\n\n    const existing = byTier.get(data.tier);\n    if (\n      !existing ||\n      data.roundNumber.toNumber() > existing.data.roundNumber.toNumber()\n    ) {\n      byTier.set(data.tier, { pda: acc.publicKey, data });\n    }\n  }\n\n  for (const [tierIndex, { pda, data }] of byTier) {\n    const round = onChainRoundToUI(pda, data, currentWallet);\n\n    // Check VRF for locked rounds\n    if (isPhase(data.phase, \"locked\")) {\n      const randomness = await readVrfRandomness(\n        connection,\n        data.vrfRequestKey\n      );\n      if (randomness) {\n        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n        result.set(tierFromIndex(tierIndex), {\n          ...round,\n          phase: \"revealing\",\n          winningSlot,\n          winner: winner.toBase58(),\n          payoutAmount: round.poolAmount * 0.97,\n        });\n        continue;\n      }\n    }\n\n    result.set(tierFromIndex(tierIndex), round);\n  }\n\n  return result;\n}\n\n/** Fetch all rounds where the player participated and can still claim. */\nexport async function fetchClaimableRounds(\n  connection: Connection,\n  playerPubkey: PublicKey\n): Promise<Round[]> {\n  const program = getLordProgram(connection);\n  const accounts = await program.account.jackpotRound.all();\n  const results: Round[] = [];\n\n  for (const acc of accounts) {\n    const data = acc.account as unknown as OnChainRound;\n\n    // Only interested in Locked (VRF fulfilled) rounds, not yet claimed\n    if (!isPhase(data.phase, \"locked\") || data.claimed) continue;\n\n    // Check if player is in this round\n    const inRound = data.players.some((p) =>\n      p.player.equals(playerPubkey)\n    );\n    if (!inRound) continue;\n\n    // Check if VRF is fulfilled\n    const randomness = await readVrfRandomness(\n      connection,\n      data.vrfRequestKey\n    );\n    if (!randomness) continue;\n\n    const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n    const round = onChainRoundToUI(\n      acc.publicKey,\n      data,\n      playerPubkey.toBase58()\n    );\n    results.push({\n      ...round,\n      phase: \"revealing\",\n      winningSlot,\n      winner: winner.toBase58(),\n      payoutAmount: round.poolAmount * 0.97,\n    });\n  }\n\n  return results;\n}\n\n// ============ Instruction Builders ============\n\n/** Build a transaction to join (or create) a round. */\nexport async function buildJoinRoundTx(\n  connection: Connection,\n  player: PublicKey,\n  tier: Tier,\n  numEntries: number,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  const ix = await program.methods\n    .joinRound(tierIndex, BigInt(roundNumber) as never, numEntries)\n    .accountsStrict({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = player;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to buy more entries in an existing round. */\nexport async function buildBuyMoreEntriesTx(\n  connection: Connection,\n  player: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number,\n  numEntries: number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  const ix = await program.methods\n    .buyMoreEntries(tierIndex, BigInt(roundNumber) as never, numEntries)\n    .accountsStrict({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = player;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to trigger the VRF spin. */\nexport async function buildStartSpinTx(\n  connection: Connection,\n  caller: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  // Orao VRF accounts\n  const oraoNetworkState = getOraoNetworkStatePda();\n  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n  if (!networkInfo)\n    throw new Error(\"Orao VRF network state not found on-chain\");\n  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n  const oraoRandom = getOraoRandomnessPda(roundPda.toBytes());\n\n  const ix = await program.methods\n    .startSpin(tierIndex, BigInt(roundNumber) as never)\n    .accountsStrict({\n      caller,\n      config: configPda,\n      round: roundPda,\n      oraoProgram: ORAO_VRF_PROGRAM_ID,\n      oraoNetworkState,\n      oraoTreasury,\n      oraoRandom,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to claim payout as the winner. */\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  caller: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  // Fetch config for treasury\n  const config = await program.account.lordConfig.fetch(configPda);\n  const configData = config as unknown as OnChainConfig;\n  const treasury = configData.treasury;\n\n  // Fetch round for creator + VRF key + winner derivation\n  const roundAccount = await program.account.jackpotRound.fetch(roundPda);\n  const roundData = roundAccount as unknown as OnChainRound;\n  const roundCreator = roundData.creator;\n  const randomnessAccount = roundData.vrfRequestKey;\n\n  // Read VRF to derive winner\n  const randomness = await readVrfRandomness(connection, randomnessAccount);\n  if (!randomness) throw new Error(\"VRF randomness not yet fulfilled\");\n  const { winner } = deriveWinnerFromVrf(randomness, roundData);\n\n  const ix = await program.methods\n    .claimPayout(tierIndex, BigInt(roundNumber) as never)\n    .accountsStrict({\n      caller,\n      round: roundPda,\n      config: configPda,\n      treasury,\n      roundCreator,\n      winnerAccount: winner,\n      randomnessAccount,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to create a new round (first player). */\nexport async function buildCreateRoundTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  numEntries: number\n): Promise<{ transaction: Transaction; roundPda: PublicKey; roundNumber: bigint }> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get current round counter for this tier\n  const config = await program.account.lordConfig.fetch(configPda);\n  const configData = config as unknown as OnChainConfig;\n  const roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber());\n\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n\n  const ix = await program.methods\n    .createRound(tierIndex, roundNumber as never, numEntries)\n    .accountsStrict({\n      creator,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, roundPda, roundNumber };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2288,"cache_read_input_tokens":92068,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2288},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8e5d7c3d-ef66-4971-8f66-de7d7c43ed7c","uuid":"150a950d-02cd-4da3-9e33-05b0ed474f16"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EtXW7gJBA1F5SKBeau6zt8","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/chain.ts"}]},"parent_tool_use_id":null,"session_id":"8e5d7c3d-ef66-4971-8f66-de7d7c43ed7c","uuid":"0792fcd4-488b-4d7b-ba9f-5782dfebddcc","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/chain.ts","content":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport { LordofrngsIDL, type Lordofrngs } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_AMOUNTS,\n  TIER_VALUES,\n  type Tier,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { Round, PlayerEntry } from \"../types\";\nimport { PLAYER_COLORS } from \"../types\";\n\n// ============ Constants ============\n\nconst LORDOFRNGS_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_LORDOFRNGS_PROGRAM_ID ?? LordofrngsIDL.address\n);\n\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\n  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\"\n);\n\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\n// ============ PDA Derivation ============\n\nexport function getRoundPda(\n  tier: number,\n  roundNumber: bigint | number\n): [PublicKey, number] {\n  const tierBuf = Buffer.alloc(1);\n  tierBuf.writeUInt8(tier);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\nfunction getOraoNetworkStatePda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ============ Program Instance ============\n\nfunction getLordProgram(connection: Connection): Program<Lordofrngs> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n}\n\n// ============ On-Chain Account Types ============\n\ntype RoundPhaseVariant =\n  | { waiting: object }\n  | { active: object }\n  | { locked: object }\n  | { resolving: object }\n  | { settled: object }\n  | { refunded: object };\n\ninterface OnChainPlayerEntry {\n  player: PublicKey;\n  entries: number;\n}\n\ninterface OnChainRound {\n  tier: number;\n  roundNumber: { toNumber(): number };\n  entryAmount: { toNumber(): number };\n  phase: RoundPhaseVariant;\n  players: OnChainPlayerEntry[];\n  totalEntries: number;\n  createdAt: { toNumber(): number };\n  countdownEndsAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  winningSlot: number;\n  winner: PublicKey;\n  claimed: boolean;\n  creator: PublicKey;\n  bump: number;\n}\n\ninterface OnChainConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  paused: boolean;\n  roundCounters: { toNumber(): number }[];\n  bump: number;\n}\n\n// ============ Converters ============\n\nconst TIERS: Tier[] = [\n  \"iron\",\n  \"bronze\",\n  \"silver\",\n  \"gold\",\n  \"platinum\",\n  \"diamond\",\n];\n\nfunction tierFromIndex(index: number): Tier {\n  return TIERS[index] ?? \"iron\";\n}\n\nfunction isPhase(phase: RoundPhaseVariant, name: string): boolean {\n  return name in phase;\n}\n\nfunction phaseToUI(phase: RoundPhaseVariant): Round[\"phase\"] {\n  if (isPhase(phase, \"waiting\")) return \"waiting\";\n  if (isPhase(phase, \"active\")) return \"countdown\";\n  if (isPhase(phase, \"locked\")) return \"spinning\";\n  if (isPhase(phase, \"settled\")) return \"complete\";\n  // Resolving, Refunded → treat as complete for display\n  return \"complete\";\n}\n\nfunction getPlayerColor(index: number, isCurrentUser: boolean): string {\n  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\";\n  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n}\n\nfunction onChainPlayersToUI(\n  players: OnChainPlayerEntry[],\n  currentWallet?: string\n): PlayerEntry[] {\n  return players.map((p, i) => ({\n    address: p.player.toBase58(),\n    entries: p.entries,\n    color: getPlayerColor(i, p.player.toBase58() === currentWallet),\n  }));\n}\n\nexport function onChainRoundToUI(\n  roundPda: PublicKey,\n  data: OnChainRound,\n  currentWallet?: string\n): Round {\n  const tier = tierFromIndex(data.tier);\n  const entryAmountLamports = data.entryAmount.toNumber();\n  const entryAmountSol = entryAmountLamports / LAMPORTS_PER_SOL;\n  const totalEntries = data.totalEntries;\n  const poolAmount = entryAmountSol * totalEntries;\n  const phase = phaseToUI(data.phase);\n  const isSettled = isPhase(data.phase, \"settled\");\n  const countdownEndsAt = data.countdownEndsAt.toNumber();\n  const lockedAt = data.lockedAt.toNumber();\n\n  const winner = isSettled ? data.winner : undefined;\n  const isDefaultWinner =\n    winner && winner.equals(PublicKey.default) ? undefined : winner;\n\n  return {\n    id: roundPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    phase,\n    players: onChainPlayersToUI(data.players, currentWallet),\n    totalEntries,\n    poolAmount,\n    createdAt: data.createdAt.toNumber() * 1000,\n    countdownStartedAt:\n      countdownEndsAt > 0 ? (countdownEndsAt - 60) * 1000 : undefined,\n    countdownEndsAt: countdownEndsAt > 0 ? countdownEndsAt * 1000 : undefined,\n    winningSlot: isSettled ? data.winningSlot : undefined,\n    winner: isDefaultWinner?.toBase58(),\n    payoutAmount: isSettled ? poolAmount * 0.97 : undefined,\n    claimed: data.claimed,\n    seedHash: data.vrfRequestKey.equals(PublicKey.default)\n      ? \"\"\n      : data.vrfRequestKey.toBase58(),\n    vrfProof: isSettled\n      ? data.vrfRequestKey.toBase58()\n      : undefined,\n  };\n}\n\n/** Read VRF randomness from an Orao account. Returns 32 bytes or null. */\nasync function readVrfRandomness(\n  connection: Connection,\n  vrfRequestKey: PublicKey\n): Promise<Uint8Array | null> {\n  try {\n    if (vrfRequestKey.equals(PublicKey.default)) return null;\n    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      if (randomnessData.some((b: number) => b !== 0)) {\n        return randomnessData.subarray(0, 32);\n      }\n    }\n  } catch {\n    // Ignore\n  }\n  return null;\n}\n\n/** Derive winner from VRF randomness for a locked round. */\nfunction deriveWinnerFromVrf(\n  randomness: Uint8Array,\n  data: OnChainRound\n): { winningSlot: number; winner: PublicKey } {\n  const view = new DataView(\n    randomness.buffer,\n    randomness.byteOffset,\n    8\n  );\n  const raw = view.getBigUint64(0, true);\n  const winningSlot = Number(raw % BigInt(data.totalEntries));\n\n  let cumulative = 0;\n  for (const p of data.players) {\n    cumulative += p.entries;\n    if (winningSlot < cumulative) {\n      return { winningSlot, winner: p.player };\n    }\n  }\n  return { winningSlot, winner: data.players[0]!.player };\n}\n\n// ============ Account Queries ============\n\n/** Fetch a single round by tier and round number. */\nexport async function fetchRound(\n  connection: Connection,\n  tier: number,\n  roundNumber: bigint | number,\n  currentWallet?: string\n): Promise<Round | null> {\n  const program = getLordProgram(connection);\n  const [roundPda] = getRoundPda(tier, roundNumber);\n\n  try {\n    const account = await program.account.jackpotRound.fetch(roundPda);\n    const data = account as unknown as OnChainRound;\n    const round = onChainRoundToUI(roundPda, data, currentWallet);\n\n    // If Locked, check if VRF is fulfilled to upgrade to spinning/revealing\n    if (isPhase(data.phase, \"locked\")) {\n      const randomness = await readVrfRandomness(\n        connection,\n        data.vrfRequestKey\n      );\n      if (randomness) {\n        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n        return {\n          ...round,\n          phase: \"revealing\",\n          winningSlot,\n          winner: winner.toBase58(),\n          payoutAmount: round.poolAmount * 0.97,\n        };\n      }\n    }\n\n    return round;\n  } catch {\n    return null;\n  }\n}\n\n/** Fetch the current round for each tier. Returns a map of tier → Round. */\nexport async function fetchAllTierRounds(\n  connection: Connection,\n  currentWallet?: string\n): Promise<Map<Tier, Round>> {\n  const program = getLordProgram(connection);\n  const result = new Map<Tier, Round>();\n\n  // Fetch all JackpotRound accounts\n  const accounts = await program.account.jackpotRound.all();\n\n  // Group by tier — pick the latest (highest roundNumber) non-terminal round per tier\n  const byTier = new Map<number, { pda: PublicKey; data: OnChainRound }>();\n\n  for (const acc of accounts) {\n    const data = acc.account as unknown as OnChainRound;\n    // Skip terminal phases\n    if (isPhase(data.phase, \"settled\") || isPhase(data.phase, \"refunded\"))\n      continue;\n\n    const existing = byTier.get(data.tier);\n    if (\n      !existing ||\n      data.roundNumber.toNumber() > existing.data.roundNumber.toNumber()\n    ) {\n      byTier.set(data.tier, { pda: acc.publicKey, data });\n    }\n  }\n\n  for (const [tierIndex, { pda, data }] of byTier) {\n    const round = onChainRoundToUI(pda, data, currentWallet);\n\n    // Check VRF for locked rounds\n    if (isPhase(data.phase, \"locked\")) {\n      const randomness = await readVrfRandomness(\n        connection,\n        data.vrfRequestKey\n      );\n      if (randomness) {\n        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n        result.set(tierFromIndex(tierIndex), {\n          ...round,\n          phase: \"revealing\",\n          winningSlot,\n          winner: winner.toBase58(),\n          payoutAmount: round.poolAmount * 0.97,\n        });\n        continue;\n      }\n    }\n\n    result.set(tierFromIndex(tierIndex), round);\n  }\n\n  return result;\n}\n\n/** Fetch all rounds where the player participated and can still claim. */\nexport async function fetchClaimableRounds(\n  connection: Connection,\n  playerPubkey: PublicKey\n): Promise<Round[]> {\n  const program = getLordProgram(connection);\n  const accounts = await program.account.jackpotRound.all();\n  const results: Round[] = [];\n\n  for (const acc of accounts) {\n    const data = acc.account as unknown as OnChainRound;\n\n    // Only interested in Locked (VRF fulfilled) rounds, not yet claimed\n    if (!isPhase(data.phase, \"locked\") || data.claimed) continue;\n\n    // Check if player is in this round\n    const inRound = data.players.some((p) =>\n      p.player.equals(playerPubkey)\n    );\n    if (!inRound) continue;\n\n    // Check if VRF is fulfilled\n    const randomness = await readVrfRandomness(\n      connection,\n      data.vrfRequestKey\n    );\n    if (!randomness) continue;\n\n    const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n    const round = onChainRoundToUI(\n      acc.publicKey,\n      data,\n      playerPubkey.toBase58()\n    );\n    results.push({\n      ...round,\n      phase: \"revealing\",\n      winningSlot,\n      winner: winner.toBase58(),\n      payoutAmount: round.poolAmount * 0.97,\n    });\n  }\n\n  return results;\n}\n\n// ============ Instruction Builders ============\n\n/** Build a transaction to join (or create) a round. */\nexport async function buildJoinRoundTx(\n  connection: Connection,\n  player: PublicKey,\n  tier: Tier,\n  numEntries: number,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  const ix = await program.methods\n    .joinRound(tierIndex, BigInt(roundNumber) as never, numEntries)\n    .accountsStrict({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = player;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to buy more entries in an existing round. */\nexport async function buildBuyMoreEntriesTx(\n  connection: Connection,\n  player: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number,\n  numEntries: number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  const ix = await program.methods\n    .buyMoreEntries(tierIndex, BigInt(roundNumber) as never, numEntries)\n    .accountsStrict({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = player;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to trigger the VRF spin. */\nexport async function buildStartSpinTx(\n  connection: Connection,\n  caller: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  // Orao VRF accounts\n  const oraoNetworkState = getOraoNetworkStatePda();\n  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n  if (!networkInfo)\n    throw new Error(\"Orao VRF network state not found on-chain\");\n  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n  const oraoRandom = getOraoRandomnessPda(roundPda.toBytes());\n\n  const ix = await program.methods\n    .startSpin(tierIndex, BigInt(roundNumber) as never)\n    .accountsStrict({\n      caller,\n      config: configPda,\n      round: roundPda,\n      oraoProgram: ORAO_VRF_PROGRAM_ID,\n      oraoNetworkState,\n      oraoTreasury,\n      oraoRandom,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to claim payout as the winner. */\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  caller: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  // Fetch config for treasury\n  const config = await program.account.lordConfig.fetch(configPda);\n  const configData = config as unknown as OnChainConfig;\n  const treasury = configData.treasury;\n\n  // Fetch round for creator + VRF key + winner derivation\n  const roundAccount = await program.account.jackpotRound.fetch(roundPda);\n  const roundData = roundAccount as unknown as OnChainRound;\n  const roundCreator = roundData.creator;\n  const randomnessAccount = roundData.vrfRequestKey;\n\n  // Read VRF to derive winner\n  const randomness = await readVrfRandomness(connection, randomnessAccount);\n  if (!randomness) throw new Error(\"VRF randomness not yet fulfilled\");\n  const { winner } = deriveWinnerFromVrf(randomness, roundData);\n\n  const ix = await program.methods\n    .claimPayout(tierIndex, BigInt(roundNumber) as never)\n    .accountsStrict({\n      caller,\n      round: roundPda,\n      config: configPda,\n      treasury,\n      roundCreator,\n      winnerAccount: winner,\n      randomnessAccount,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to create a new round (first player). */\nexport async function buildCreateRoundTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  numEntries: number\n): Promise<{ transaction: Transaction; roundPda: PublicKey; roundNumber: bigint }> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get current round counter for this tier\n  const config = await program.account.lordConfig.fetch(configPda);\n  const configData = config as unknown as OnChainConfig;\n  const roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber());\n\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n\n  const ix = await program.methods\n    .createRound(tierIndex, roundNumber as never, numEntries)\n    .accountsStrict({\n      creator,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, roundPda, roundNumber };\n}\n","structuredPatch":[],"originalFile":null}}
