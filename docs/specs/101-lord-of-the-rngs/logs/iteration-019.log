  } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n      }\n    });\n  });\n\n  describe(\"start_spin\", () => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":837,"cache_read_input_tokens":82614,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":837},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"85aaa064-eec9-43d4-a388-edad27776e60","uuid":"31de3fc3-0910-4e72-88de-b84f4b94fbf4"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L1c9wPsCQRZ3TXn6Dw3udi","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/solana/tests/lordofrngs.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"85aaa064-eec9-43d4-a388-edad27776e60","uuid":"43a37451-df2d-49cc-bf14-c1d9cd668878","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/lordofrngs.ts","oldString":"    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      try {\n        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 0);\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n\n  describe(\"start_spin\", () => {","newString":"    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      try {\n        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 0);\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n\n    it(\"rejects buy_more_entries when phase is Locked\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round, player2 joins (triggers countdown → Active)\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Warp past countdown and lock the round\n      await warpPastCountdown(t);\n      await startSpin(t.creatorProgram, t.creator, t);\n\n      // Creator tries to buy more entries in Locked phase\n      try {\n        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n      }\n    });\n  });\n\n  describe(\"start_spin\", () => {","originalFile":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { AnchorError, Program } from \"@coral-xyz/anchor\";\nimport { Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport { Clock } from \"solana-bankrun\";\nimport type { Lordofrngs } from \"../target/types/lordofrngs\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\nimport BN from \"bn.js\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\n// Tier constants (from shared crate)\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\nconst COUNTDOWN_SECONDS = 60;\n\n// Mock VRF randomness buffers (32 bytes each)\n// Unfulfilled: all zeros → is_fulfilled=false\nconst RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getRoundPda(tier: number, roundNumber: number | bigint): PublicKey {\n  const tierBuf = Buffer.from([tier]);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Test context factory\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  treasury: Keypair;\n  creatorProgram: Program<Lordofrngs>;\n  configPda: PublicKey;\n  player2: Keypair;\n  player2Program: Program<Lordofrngs>;\n  mockRandomness: Keypair;\n  mockOraoProgram: Keypair;\n  mockOraoNetworkState: Keypair;\n  mockOraoTreasury: Keypair;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const treasury = Keypair.generate();\n  const player2 = Keypair.generate();\n  const mockRandomness = Keypair.generate();\n  const mockOraoProgram = Keypair.generate();\n  const mockOraoNetworkState = Keypair.generate();\n  const mockOraoTreasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: treasury.publicKey, info: fundedAccountData() },\n    { address: player2.publicKey, info: fundedAccountData() },\n    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n    // Mock randomness account — starts unfulfilled (32 zero bytes)\n    {\n      address: mockRandomness.publicKey,\n      info: {\n        lamports: LAMPORTS_PER_SOL,\n        data: RANDOMNESS_UNFULFILLED,\n        owner: SystemProgram.programId,\n        executable: false,\n      },\n    },\n  ]);\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n\n  const player2Provider = new BankrunProvider(context, new Wallet(player2));\n  const player2Program = new Program<Lordofrngs>(IDL, player2Provider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n\n  return {\n    context,\n    creator,\n    treasury,\n    creatorProgram,\n    configPda,\n    player2,\n    player2Program,\n    mockRandomness,\n    mockOraoProgram,\n    mockOraoNetworkState,\n    mockOraoTreasury,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Clock warp helpers\n// ---------------------------------------------------------------------------\nasync function warpPastCountdown(t: TestContext) {\n  const clock = await t.context.banksClient.getClock();\n  t.context.setClock(\n    new Clock(\n      clock.slot + BigInt(200),\n      clock.epochStartTimestamp,\n      clock.epoch,\n      clock.leaderScheduleEpoch,\n      clock.unixTimestamp + BigInt(COUNTDOWN_SECONDS + 10)\n    )\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Instruction helpers\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createRound(\n  t: TestContext,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n  creator?: PublicKey,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await t.creatorProgram.methods\n    .createRound(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      creator: creator ?? t.creator,\n      config: t.configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\nasync function joinRound(\n  program: Program<Lordofrngs>,\n  player: PublicKey,\n  configPda: PublicKey,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .joinRound(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\nasync function buyMoreEntries(\n  program: Program<Lordofrngs>,\n  player: PublicKey,\n  configPda: PublicKey,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .buyMoreEntries(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\nasync function startSpin(\n  program: Program<Lordofrngs>,\n  caller: PublicKey,\n  t: TestContext,\n  tier = TIER_IRON,\n  roundNumber = 0,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .startSpin(tier, new BN(roundNumber))\n    .accounts({\n      caller,\n      config: t.configPda,\n      round: roundPda,\n      oraoProgram: t.mockOraoProgram.publicKey,\n      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n      oraoTreasury: t.mockOraoTreasury.publicKey,\n      oraoRandom: t.mockRandomness.publicKey,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\n// Fee constant (3% = 300 bps)\nconst TOTAL_FEE_BPS = 300;\n\n// ---------------------------------------------------------------------------\n// Mock VRF + balance helpers\n// ---------------------------------------------------------------------------\nfunction setMockRandomness(t: TestContext, data: Buffer) {\n  t.context.setAccount(t.mockRandomness.publicKey, {\n    lamports: LAMPORTS_PER_SOL,\n    data,\n    owner: SystemProgram.programId,\n    executable: false,\n  });\n}\n\nasync function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n  const account = await t.context.banksClient.getAccount(pubkey);\n  return account ? Number(account.lamports) : 0;\n}\n\n/**\n * Build randomness buffer where the first 8 bytes (as u64 LE) mod totalEntries\n * yields the desired winningSlot.\n */\nfunction buildRandomness(winningSlot: number, totalEntries: number): Buffer {\n  const buf = Buffer.alloc(32);\n  // Write winningSlot as u64 LE — since winningSlot < totalEntries, mod is identity\n  buf.writeBigUInt64LE(BigInt(winningSlot));\n  // Ensure at least one byte is non-zero so is_fulfilled returns true\n  if (winningSlot === 0) buf[8] = 1;\n  return buf;\n}\n\n/**\n * Determine the winner from randomness, totalEntries, and players list.\n * Mirrors the on-chain logic: rand_u64 % total_entries → slot → owner.\n */\nfunction deriveWinner(\n  randomness: Buffer,\n  totalEntries: number,\n  players: Array<{ player: PublicKey; entries: number }>\n): { winningSlot: number; winner: PublicKey } {\n  const randU64 = randomness.readBigUInt64LE(0);\n  const winningSlot = Number(randU64 % BigInt(totalEntries));\n  let cumulative = 0;\n  for (const entry of players) {\n    cumulative += entry.entries;\n    if (winningSlot < cumulative) {\n      return { winningSlot, winner: entry.player };\n    }\n  }\n  throw new Error(\"Failed to derive winner\");\n}\n\nasync function claimPayout(\n  program: Program<Lordofrngs>,\n  caller: PublicKey,\n  t: TestContext,\n  winnerAccount: PublicKey,\n  tier = TIER_IRON,\n  roundNumber = 0,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .claimPayout(tier, new BN(roundNumber))\n    .accounts({\n      caller,\n      round: roundPda,\n      config: t.configPda,\n      treasury: t.treasury.publicKey,\n      roundCreator: t.creator,\n      winnerAccount,\n      randomnessAccount: t.mockRandomness.publicKey,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\n// Timeout constant (matches shared crate DEFAULT_RESOLVE_TIMEOUT_SECONDS)\nconst RESOLVE_TIMEOUT_SECONDS = 120;\n\nasync function timeoutRefund(\n  program: Program<Lordofrngs>,\n  caller: PublicKey,\n  t: TestContext,\n  playerAccounts: PublicKey[],\n  tier = TIER_IRON,\n  roundNumber = 0,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .timeoutRefund(tier, new BN(roundNumber))\n    .accounts({\n      caller,\n      round: roundPda,\n      config: t.configPda,\n      roundCreator: t.creator,\n      randomnessAccount: t.mockRandomness.publicKey,\n    })\n    .remainingAccounts(\n      playerAccounts.map((pk) => ({\n        pubkey: pk,\n        isSigner: false,\n        isWritable: true,\n      }))\n    )\n    .rpc();\n}\n\nasync function warpPastResolveDeadline(t: TestContext) {\n  const clock = await t.context.banksClient.getClock();\n  t.context.setClock(\n    new Clock(\n      clock.slot + BigInt(400),\n      clock.epochStartTimestamp,\n      clock.epoch,\n      clock.leaderScheduleEpoch,\n      // Past countdown (60s) + past resolve deadline (120s) + buffer\n      clock.unixTimestamp + BigInt(COUNTDOWN_SECONDS + RESOLVE_TIMEOUT_SECONDS + 20)\n    )\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\ndescribe(\"lordofrngs\", () => {\n  describe(\"initialize_config\", () => {\n    it(\"creates config with treasury and paused=false\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.lordConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n      expect(config.paused).to.equal(false);\n      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n    });\n  });\n\n  describe(\"create_round\", () => {\n    it(\"creates round with correct PDA data and escrow balance\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Verify round state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.tier).to.equal(TIER_IRON);\n      expect(round.roundNumber.toNumber()).to.equal(0);\n      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n      expect(round.players).to.have.length(1);\n      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.players[0].entries).to.equal(1);\n      expect(round.totalEntries).to.equal(1);\n      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n      expect(round.lockedAt.toNumber()).to.equal(0);\n      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.claimed).to.equal(false);\n\n      // Verify escrow balance: account holds rent + entry amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n\n      // Verify config round counter incremented\n      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n    });\n\n    it(\"creates round with multiple entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const numEntries = 5;\n      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[0].entries).to.equal(numEntries);\n      expect(round.totalEntries).to.equal(numEntries);\n\n      // Escrow should hold numEntries × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n    });\n\n    it(\"increments round counter per tier\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Create first round (round 0)\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Config counter should be 1\n      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n\n      // Create second round (round 1) — need a new PDA\n      await createRound(t, TIER_IRON, 1, 1);\n\n      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n    });\n\n    it(\"rejects invalid tier (tier 6)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const invalidTier = 6;\n      const roundPda = getRoundPda(invalidTier, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(invalidTier, new BN(0), 1)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n        // PDA derivation time, resulting in an Anchor error\n        expect(err).to.be.instanceOf(Error);\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = getRoundPda(TIER_IRON, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(TIER_IRON, new BN(0), 0)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n\n  describe(\"join_round\", () => {\n    it(\"2nd player joins and triggers countdown (Waiting → Active)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round (player 1)\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Player 2 joins\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Verify round state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players).to.have.length(2);\n      expect(round.players[1].player.toBase58()).to.equal(t.player2.publicKey.toBase58());\n      expect(round.players[1].entries).to.equal(1);\n      expect(round.totalEntries).to.equal(2);\n\n      // Phase should be Active (countdown started)\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n      expect(round.countdownEndsAt.toNumber()).to.be.greaterThan(0);\n\n      // Escrow should hold 2 × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 2);\n    });\n\n    it(\"3rd player joins during Active phase without re-triggering countdown\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const player3 = Keypair.generate();\n      const player3Account = fundedAccountData();\n      t.context.setAccount(player3.publicKey, player3Account);\n      const player3Provider = new BankrunProvider(t.context, new Wallet(player3));\n      const player3Program = new Program<Lordofrngs>(IDL, player3Provider);\n\n      // Creator starts round, player2 joins (triggers countdown)\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      const roundBefore = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      const countdownBefore = roundBefore.countdownEndsAt.toNumber();\n\n      // Player 3 joins\n      await joinRound(player3Program, player3.publicKey, t.configPda);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(round.players).to.have.length(3);\n      expect(round.totalEntries).to.equal(3);\n      // Countdown should not have changed\n      expect(round.countdownEndsAt.toNumber()).to.equal(countdownBefore);\n    });\n\n    it(\"player can join with multiple entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Player 2 joins with 5 entries\n      const roundPda = await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, 5);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[1].entries).to.equal(5);\n      expect(round.totalEntries).to.equal(6); // 1 (creator) + 5 (player2)\n\n      // Escrow: 1 × amount (creator) + 5 × amount (player2)\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 6);\n    });\n\n    it(\"rejects duplicate player\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Creator tries to join their own round again\n      try {\n        await joinRound(t.creatorProgram, t.creator, t.configPda);\n        expect.fail(\"Expected PlayerAlreadyInRound error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerAlreadyInRound\");\n      }\n    });\n\n    it(\"rejects 21st player (max 20)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Add 19 more players (total 20)\n      for (let i = 0; i < 19; i++) {\n        const p = Keypair.generate();\n        t.context.setAccount(p.publicKey, fundedAccountData());\n        const pProvider = new BankrunProvider(t.context, new Wallet(p));\n        const pProgram = new Program<Lordofrngs>(IDL, pProvider);\n        await joinRound(pProgram, p.publicKey, t.configPda);\n      }\n\n      // Verify we have 20 players\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(round.players).to.have.length(20);\n\n      // 21st player should be rejected\n      const extra = Keypair.generate();\n      t.context.setAccount(extra.publicKey, fundedAccountData());\n      const extraProvider = new BankrunProvider(t.context, new Wallet(extra));\n      const extraProgram = new Program<Lordofrngs>(IDL, extraProvider);\n\n      try {\n        await joinRound(extraProgram, extra.publicKey, t.configPda);\n        expect.fail(\"Expected MaxPlayersReached error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"MaxPlayersReached\");\n      }\n    });\n\n    it(\"rejects join when phase is Locked\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round, player2 joins (triggers countdown → Active)\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Warp past countdown and lock the round\n      await warpPastCountdown(t);\n      await startSpin(t.creatorProgram, t.creator, t);\n\n      // Player3 tries to join Locked round\n      const player3 = Keypair.generate();\n      t.context.setAccount(player3.publicKey, fundedAccountData());\n      const player3Provider = new BankrunProvider(t.context, new Wallet(player3));\n      const player3Program = new Program<Lordofrngs>(IDL, player3Provider);\n\n      try {\n        await joinRound(player3Program, player3.publicKey, t.configPda);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n      }\n    });\n  });\n\n  describe(\"buy_more_entries\", () => {\n    it(\"existing player buys more entries (updated count + escrow)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round with 1 entry\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Creator buys 3 more entries\n      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 3);\n\n      // Verify updated state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players).to.have.length(1);\n      expect(round.players[0].entries).to.equal(4); // 1 + 3\n      expect(round.totalEntries).to.equal(4);\n\n      // Escrow should hold 4 × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 4);\n    });\n\n    it(\"works during Active phase (after countdown starts)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round, player2 joins (triggers countdown → Active)\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Creator buys 2 more during Active phase\n      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 2);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[0].entries).to.equal(3); // 1 + 2\n      expect(round.totalEntries).to.equal(4); // 3 (creator) + 1 (player2)\n    });\n\n    it(\"rejects player not in round\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Player2 (not in round) tries to buy more\n      try {\n        await buyMoreEntries(t.player2Program, t.player2.publicKey, t.configPda);\n        expect.fail(\"Expected PlayerNotInRound error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerNotInRound\");\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      try {\n        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 0);\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n\n  describe(\"start_spin\", () => {\n    it(\"transitions Active → Locked after countdown expires\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator creates round, player2 joins (triggers countdown → Active)\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Verify Active phase\n      let round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n\n      // Warp past countdown\n      await warpPastCountdown(t);\n\n      // Start spin\n      await startSpin(t.creatorProgram, t.creator, t);\n\n      // Verify Locked phase + VRF fields set\n      round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n      expect(round.lockedAt.toNumber()).to.be.greaterThan(0);\n      expect(round.resolveDeadline.toNumber()).to.be.greaterThan(round.lockedAt.toNumber());\n      expect(round.vrfRequestKey.toBase58()).to.equal(t.mockRandomness.publicKey.toBase58());\n    });\n\n    it(\"is idempotent (no error when already Locked)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n      await warpPastCountdown(t);\n\n      // First spin succeeds\n      await startSpin(t.creatorProgram, t.creator, t);\n\n      // Second spin from a different player also succeeds (idempotent no-op)\n      await startSpin(t.player2Program, t.player2.publicKey, t);\n\n      // Still Locked\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n    });\n\n    it(\"rejects spin before countdown expires\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Don't warp — countdown is still running\n      try {\n        await startSpin(t.creatorProgram, t.creator, t);\n        expect.fail(\"Expected CountdownNotExpired error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"CountdownNotExpired\");\n      }\n    });\n\n    it(\"rejects spin when phase is Waiting (only 1 player)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Phase is Waiting — no second player joined yet\n      try {\n        await startSpin(t.creatorProgram, t.creator, t);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n      }\n    });\n  });\n\n  describe(\"claim_payout\", () => {\n    /** Helper: set up a round in Locked phase (creator 1 entry, player2 1 entry) */\n    async function setupLockedRound(t: TestContext, creatorEntries = 1, player2Entries = 1) {\n      await initConfig(t);\n      const roundPda = await createRound(t, TIER_IRON, 0, creatorEntries);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, player2Entries);\n      await warpPastCountdown(t);\n      await startSpin(t.creatorProgram, t.creator, t);\n      return roundPda;\n    }\n\n    it(\"creator wins — correct payout and fee to treasury\", async () => {\n      const t = await createTestContext();\n      const roundPda = await setupLockedRound(t);\n\n      const totalEntries = 2;\n      const pool = TIER_IRON_AMOUNT * totalEntries;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Randomness: slot 0 → creator wins (creator owns slots [0,1), player2 owns [1,2))\n      const randomness = buildRandomness(0, totalEntries);\n      setMockRandomness(t, randomness);\n\n      const winnerBefore = await getBalance(t, t.creator);\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n\n      await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n\n      const winnerAfter = await getBalance(t, t.creator);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      // Creator receives payout + rent refund from closed PDA (minus tx fee)\n      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n      // Treasury receives exact fee\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n    });\n\n    it(\"player2 wins — payout goes to player2\", async () => {\n      const t = await createTestContext();\n      const roundPda = await setupLockedRound(t);\n\n      const totalEntries = 2;\n      const pool = TIER_IRON_AMOUNT * totalEntries;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Randomness: slot 1 → player2 wins (creator owns [0,1), player2 owns [1,2))\n      const randomness = buildRandomness(1, totalEntries);\n      setMockRandomness(t, randomness);\n\n      const player2Before = await getBalance(t, t.player2.publicKey);\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n\n      // Creator triggers claim, but payout goes to player2\n      await claimPayout(t.creatorProgram, t.creator, t, t.player2.publicKey);\n\n      const player2After = await getBalance(t, t.player2.publicKey);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      // Player2 receives exact payout (they didn't sign the tx, so no tx fee)\n      expect(player2After - player2Before).to.equal(payout);\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n    });\n\n    it(\"multiple entries increases win probability proportionally\", async () => {\n      const t = await createTestContext();\n      // Creator has 3 entries, player2 has 1 entry → 4 total\n      // Creator owns slots [0,1,2), player2 owns [3)\n      const roundPda = await setupLockedRound(t, 3, 1);\n\n      const totalEntries = 4;\n      const pool = TIER_IRON_AMOUNT * totalEntries;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Randomness: slot 2 → creator wins (creator owns [0,3))\n      const randomness = buildRandomness(2, totalEntries);\n      setMockRandomness(t, randomness);\n\n      const winnerBefore = await getBalance(t, t.creator);\n      await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n      const winnerAfter = await getBalance(t, t.creator);\n\n      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n    });\n\n    it(\"round PDA closed after claim (account no longer exists)\", async () => {\n      const t = await createTestContext();\n      const roundPda = await setupLockedRound(t);\n\n      const randomness = buildRandomness(0, 2);\n      setMockRandomness(t, randomness);\n\n      await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n\n      // Round PDA should be closed\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      expect(roundAccount).to.be.null;\n    });\n\n    it(\"rejects claim with unfulfilled randomness\", async () => {\n      const t = await createTestContext();\n      await setupLockedRound(t);\n\n      // Randomness stays all zeros (unfulfilled — set during context creation)\n\n      try {\n        await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n        expect.fail(\"Expected RandomnessNotFulfilled error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"RandomnessNotFulfilled\"\n        );\n      }\n    });\n\n    it(\"rejects claim with wrong winner_account\", async () => {\n      const t = await createTestContext();\n      await setupLockedRound(t);\n\n      // Randomness: slot 0 → creator wins\n      const randomness = buildRandomness(0, 2);\n      setMockRandomness(t, randomness);\n\n      // Pass player2 as winner_account, but creator actually won\n      try {\n        await claimPayout(t.creatorProgram, t.creator, t, t.player2.publicKey);\n        expect.fail(\"Expected NotWinner error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"NotWinner\");\n      }\n    });\n\n    it(\"rejects claim when phase is not Locked\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n      // Phase is Active (not Locked)\n\n      const randomness = buildRandomness(0, 2);\n      setMockRandomness(t, randomness);\n\n      try {\n        await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n      }\n    });\n  });\n\n  describe(\"timeout_refund\", () => {\n    /** Helper: set up a round in Locked phase with unfulfilled VRF */\n    async function setupLockedRoundUnfulfilled(t: TestContext, creatorEntries = 1, player2Entries = 1) {\n      await initConfig(t);\n      const roundPda = await createRound(t, TIER_IRON, 0, creatorEntries);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, player2Entries);\n      await warpPastCountdown(t);\n      await startSpin(t.creatorProgram, t.creator, t);\n      // VRF stays unfulfilled (all zeros from context setup)\n      return roundPda;\n    }\n\n    it(\"refunds all players after timeout with unfulfilled VRF\", async () => {\n      const t = await createTestContext();\n      const roundPda = await setupLockedRoundUnfulfilled(t);\n\n      const creatorBefore = await getBalance(t, t.creator);\n      const player2Before = await getBalance(t, t.player2.publicKey);\n\n      // Warp past resolve deadline\n      await warpPastResolveDeadline(t);\n\n      await timeoutRefund(\n        t.creatorProgram,\n        t.creator,\n        t,\n        [t.creator, t.player2.publicKey]\n      );\n\n      const creatorAfter = await getBalance(t, t.creator);\n      const player2After = await getBalance(t, t.player2.publicKey);\n\n      // Creator gets entry refund + rent refund (minus tx fee)\n      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(TIER_IRON_AMOUNT);\n      // Player2 gets exact entry refund (no tx fee, not signer)\n      expect(player2After - player2Before).to.equal(TIER_IRON_AMOUNT);\n\n      // Round PDA closed\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      expect(roundAccount).to.be.null;\n    });\n\n    it(\"refunds proportional to entries purchased\", async () => {\n      const t = await createTestContext();\n      // Creator has 3 entries, player2 has 2 entries\n      const roundPda = await setupLockedRoundUnfulfilled(t, 3, 2);\n\n      const player2Before = await getBalance(t, t.player2.publicKey);\n\n      await warpPastResolveDeadline(t);\n\n      await timeoutRefund(\n        t.creatorProgram,\n        t.creator,\n        t,\n        [t.creator, t.player2.publicKey]\n      );\n\n      const player2After = await getBalance(t, t.player2.publicKey);\n\n      // Player2 gets 2 × entry_amount refunded\n      expect(player2After - player2Before).to.equal(TIER_IRON_AMOUNT * 2);\n    });\n\n    it(\"rejects when VRF is fulfilled (must use claim_payout instead)\", async () => {\n      const t = await createTestContext();\n      await setupLockedRoundUnfulfilled(t);\n\n      // Fulfill the VRF\n      const randomness = buildRandomness(0, 2);\n      setMockRandomness(t, randomness);\n\n      await warpPastResolveDeadline(t);\n\n      try {\n        await timeoutRefund(\n          t.creatorProgram,\n          t.creator,\n          t,\n          [t.creator, t.player2.publicKey]\n        );\n        expect.fail(\"Expected VrfAlreadyFulfilled error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"VrfAlreadyFulfilled\");\n      }\n    });\n\n    it(\"rejects when timeout has not elapsed\", async () => {\n      const t = await createTestContext();\n      await setupLockedRoundUnfulfilled(t);\n\n      // Don't warp past resolve deadline — just stay at post-countdown time\n      // (warpPastCountdown was called in setupLockedRoundUnfulfilled)\n\n      try {\n        await timeoutRefund(\n          t.creatorProgram,\n          t.creator,\n          t,\n          [t.creator, t.player2.publicKey]\n        );\n        expect.fail(\"Expected LockTimeoutNotElapsed error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"LockTimeoutNotElapsed\");\n      }\n    });\n\n    it(\"rejects when phase is not Locked (Active phase)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n      // Phase is Active, not Locked\n\n      await warpPastResolveDeadline(t);\n\n      try {\n        await timeoutRefund(\n          t.creatorProgram,\n          t.creator,\n          t,\n          [t.creator, t.player2.publicKey]\n        );\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n      }\n    });\n  });\n\n  // ---------------------------------------------------------------------------\n  // force_close\n  // ---------------------------------------------------------------------------\n  describe(\"force_close\", () => {\n    async function forceClose(\n      program: Program<Lordofrngs>,\n      authority: PublicKey,\n      t: TestContext,\n      playerAccounts: PublicKey[],\n      tier = TIER_IRON,\n      roundNumber = 0,\n    ) {\n      const roundPda = getRoundPda(tier, roundNumber);\n      await program.methods\n        .forceClose(tier, new BN(roundNumber))\n        .accounts({\n          authority,\n          round: roundPda,\n          config: t.configPda,\n          roundCreator: t.creator,\n        })\n        .remainingAccounts(\n          playerAccounts.map((pk) => ({\n            pubkey: pk,\n            isSigner: false,\n            isWritable: true,\n          }))\n        )\n        .rpc();\n    }\n\n    it(\"admin force-closes a Waiting round and refunds all players\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createRound(t, TIER_IRON, 0, 2); // creator buys 2 entries\n\n      const creatorBalBefore = await getBalance(t, t.creator);\n      const roundPda = getRoundPda(TIER_IRON, 0);\n      const roundBalBefore = await getBalance(t, roundPda);\n\n      // Force close (admin = creator since creator is the authority)\n      await forceClose(\n        t.creatorProgram,\n        t.creator,\n        t,\n        [t.creator],\n      );\n\n      const creatorBalAfter = await getBalance(t, t.creator);\n      // Creator should get refund (2 entries × TIER_IRON_AMOUNT) + rent back\n      // The round account is closed, so the PDA balance is 0\n      expect(creatorBalAfter).to.be.greaterThan(creatorBalBefore);\n\n      // Round PDA should no longer exist\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      expect(roundAccount).to.be.null;\n    });\n\n    it(\"admin force-closes an Active round and refunds all players\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n      // Phase is Active (2 players, countdown started)\n\n      const creatorBalBefore = await getBalance(t, t.creator);\n      const player2BalBefore = await getBalance(t, t.player2.publicKey);\n\n      await forceClose(\n        t.creatorProgram,\n        t.creator,\n        t,\n        [t.creator, t.player2.publicKey],\n      );\n\n      const creatorBalAfter = await getBalance(t, t.creator);\n      const player2BalAfter = await getBalance(t, t.player2.publicKey);\n\n      // Both players should get refunds\n      expect(creatorBalAfter).to.be.greaterThan(creatorBalBefore);\n      expect(player2BalAfter).to.be.greaterThan(player2BalBefore);\n\n      // Round PDA should no longer exist\n      const roundPda = getRoundPda(TIER_IRON, 0);\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      expect(roundAccount).to.be.null;\n    });\n\n    it(\"rejects non-admin caller\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createRound(t, TIER_IRON, 0, 1);\n\n      try {\n        // player2 is not the authority\n        await forceClose(\n          t.player2Program,\n          t.player2.publicKey,\n          t,\n          [t.creator],\n        );\n        expect.fail(\"Expected error for non-admin\");\n      } catch (err) {\n        // Anchor has_one constraint error (ConstraintHasOne = 2001)\n        expect((err as AnchorError).error.errorCode.number).to.equal(2001);\n      }\n    });\n\n    it(\"rejects when phase is Settled (terminal)\", async () => {\n      // Can't easily create a Settled round since claim_payout closes the PDA.\n      // Instead, verify force_close works on Locked phase (non-terminal).\n      const t = await createTestContext();\n      await initConfig(t);\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n      await warpPastCountdown(t);\n      await startSpin(t.creatorProgram, t.creator, t);\n      // Phase is now Locked — force_close should work\n\n      await forceClose(\n        t.creatorProgram,\n        t.creator,\n        t,\n        [t.creator, t.player2.publicKey],\n      );\n\n      // Round PDA should no longer exist\n      const roundPda = getRoundPda(TIER_IRON, 0);\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      expect(roundAccount).to.be.null;\n    });\n  });\n});\n","structuredPatch":[{"oldStart":742,"oldLines":6,"newStart":742,"newLines":27,"lines":["         expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");","       }","     });","+","+    it(\"rejects buy_more_entries when phase is Locked\", async () => {","+      const t = await createTestContext();","+      await initConfig(t);","+","+      // Creator starts round, player2 joins (triggers countdown → Active)","+      await createRound(t, TIER_IRON, 0, 1);","+      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);","+","+      // Warp past countdown and lock the round","+      await warpPastCountdown(t);","+      await startSpin(t.creatorProgram, t.creator, t);","+","+      // Creator tries to buy more entries in Locked phase","+      try {","+        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda);","+        expect.fail(\"Expected InvalidPhase error\");","+      } catch (err) {","+        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");","+      }","+    });","   });"," ","   describe(\"start_spin\", () => {"]}],"userModified":false,"replaceAll":false}}
