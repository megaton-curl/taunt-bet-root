{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016iGQe2szgYhjf6W6YiQFfC","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→use rng_shared::fees::calculate_net_payout;\n     4→use rng_shared::lifecycle::RoundPhase;\n     5→use rng_shared::vrf_orao::read_orao_randomness;\n     6→\n     7→use crate::error::LordError;\n     8→use crate::state::{JackpotRound, LordConfig, RoundSettled};\n     9→\n    10→#[derive(Accounts)]\n    11→#[instruction(tier: u8, round_number: u64)]\n    12→pub struct ClaimPayout<'info> {\n    13→    /// Any participant can trigger the claim (permissionless after VRF fulfilled).\n    14→    #[account(mut)]\n    15→    pub caller: Signer<'info>,\n    16→\n    17→    /// The round PDA (closed after claim — rent refunded to round creator).\n    18→    #[account(\n    19→        mut,\n    20→        close = round_creator,\n    21→        seeds = [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()],\n    22→        bump = round.bump,\n    23→    )]\n    24→    pub round: Account<'info, JackpotRound>,\n    25→\n    26→    /// The config PDA (for treasury address).\n    27→    #[account(\n    28→        seeds = [b\"lord_config\"],\n    29→        bump = config.bump,\n    30→    )]\n    31→    pub config: Account<'info, LordConfig>,\n    32→\n    33→    /// The treasury account to receive fees.\n    34→    /// CHECK: Validated against config.treasury in handler.\n    35→    #[account(mut)]\n    36→    pub treasury: AccountInfo<'info>,\n    37→\n    38→    /// The round creator account (receives rent refund on close).\n    39→    /// CHECK: Validated against round.creator in handler.\n    40→    #[account(mut)]\n    41→    pub round_creator: AccountInfo<'info>,\n    42→\n    43→    /// The winner account to receive payout.\n    44→    /// CHECK: Validated against derived winner in handler.\n    45→    #[account(mut)]\n    46→    pub winner_account: AccountInfo<'info>,\n    47→\n    48→    /// The Orao randomness PDA — must match vrf_request_key stored on round.\n    49→    /// CHECK: Key validated against round.vrf_request_key; data read by shared VRF helper.\n    50→    pub randomness_account: AccountInfo<'info>,\n    51→\n    52→    pub system_program: Program<'info, System>,\n    53→}\n    54→\n    55→pub fn handler(ctx: Context<ClaimPayout>, _tier: u8, _round_number: u64) -> Result<()> {\n    56→    let round = &ctx.accounts.round;\n    57→\n    58→    // (1) Must be in LOCKED phase and not already claimed\n    59→    require!(\n    60→        round.phase == RoundPhase::Locked,\n    61→        LordError::InvalidPhase\n    62→    );\n    63→    require!(!round.claimed, LordError::AlreadyClaimed);\n    64→\n    65→    // Validate accounts match stored state\n    66→    require!(\n    67→        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n    68→        LordError::InvalidPhase\n    69→    );\n    70→    require!(\n    71→        ctx.accounts.round_creator.key() == round.creator,\n    72→        LordError::InvalidPhase\n    73→    );\n    74→    require!(\n    75→        ctx.accounts.randomness_account.key() == round.vrf_request_key,\n    76→        LordError::InvalidPhase\n    77→    );\n    78→\n    79→    // (2) Read Orao randomness — rejects if not fulfilled\n    80→    let randomness = read_orao_randomness(&ctx.accounts.randomness_account)?;\n    81→\n    82→    // (3) Derive winning slot from randomness\n    83→    // Use first 8 bytes as u64, mod total_entries → winning slot index\n    84→    let rand_u64 = u64::from_le_bytes(randomness[0..8].try_into().unwrap());\n    85→    let total_entries = round.total_entries as u64;\n    86→    let winning_slot = (rand_u64 % total_entries) as u32;\n    87→\n    88→    // (4) Map winning slot to winner player\n    89→    // Slots are assigned sequentially: player 0 owns slots [0..entries_0),\n    90→    // player 1 owns [entries_0..entries_0+entries_1), etc.\n    91→    let mut cumulative: u32 = 0;\n    92→    let mut winner = Pubkey::default();\n    93→    for entry in &round.players {\n    94→        cumulative += entry.entries;\n    95→        if winning_slot < cumulative {\n    96→            winner = entry.player;\n    97→            break;\n    98→        }\n    99→    }\n   100→\n   101→    // Validate winner_account matches the derived winner\n   102→    require!(\n   103→        ctx.accounts.winner_account.key() == winner,\n   104→        LordError::NotWinner\n   105→    );\n   106→\n   107→    // (5) Compute fee/payout from the total pool\n   108→    let pool = round\n   109→        .entry_amount\n   110→        .checked_mul(total_entries)\n   111→        .ok_or(LordError::ArithmeticOverflow)?;\n   112→    let (fee, payout) = calculate_net_payout(pool);\n   113→\n   114→    // (6) Transfer payout to winner + fee to treasury\n   115→    let round_info = ctx.accounts.round.to_account_info();\n   116→    transfer_lamports_from_pda(&round_info, &ctx.accounts.winner_account, payout)?;\n   117→    transfer_lamports_from_pda(&round_info, &ctx.accounts.treasury, fee)?;\n   118→\n   119→    // (7) Emit RoundSettled event (audit trail persists in tx logs after PDA closed)\n   120→    emit!(RoundSettled {\n   121→        tier: round.tier,\n   122→        round_number: round.round_number,\n   123→        winner,\n   124→        randomness,\n   125→        winning_slot,\n   126→        total_entries: round.total_entries,\n   127→        payout_amount: payout,\n   128→        fee_amount: fee,\n   129→        vrf_request_key: round.vrf_request_key,\n   130→    });\n   131→\n   132→    // (8) Set phase = Settled, claimed = true, store winner + slot\n   133→    // Note: LOCKED → SETTLED is intentionally not in the transition() function;\n   134→    // VRF games handle this phase change directly after reading randomness.\n   135→    let round = &mut ctx.accounts.round;\n   136→    round.phase = RoundPhase::Settled;\n   137→    round.claimed = true;\n   138→    round.winning_slot = winning_slot;\n   139→    round.winner = winner;\n   140→\n   141→    // Account is closed by Anchor's `close = round_creator` constraint after handler returns.\n   142→    // Remaining lamports (rent) are sent to the round creator.\n   143→\n   144→    Ok(())\n   145→}\n   146→"}]},"parent_tool_use_id":"toolu_01PTyxp5Wgg3MNw4vGDgyR9f","session_id":"85aaa064-eec9-43d4-a388-edad27776e60","uuid":"c9ff0798-3141-4bc0-be7e-3a7979d9dca7"}
