{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SYjxyrkaL6RuHUMdjacnjV","type":"tool_result","content":"     1→/**\n     2→ * Devnet integration test: full coinflip lifecycle with real VRF.\n     3→ *\n     4→ * Tests: create → join (VRF request) → poll for resolve → claim payout\n     5→ * Uses two funded accounts: creator (deployer wallet) + opponent (ephemeral).\n     6→ *\n     7→ * Usage:\n     8→ *   npx tsx scripts/test-devnet-lifecycle.ts\n     9→ *\n    10→ * Prerequisites:\n    11→ *   - Coinflip + platform programs deployed to devnet (without mock-oracle)\n    12→ *   - Config initialized (init-devnet-config.ts)\n    13→ *   - Deployer wallet at ~/.config/solana/id.json with devnet SOL\n    14→ */\n    15→\n    16→import {\n    17→  Connection,\n    18→  Keypair,\n    19→  PublicKey,\n    20→  SystemProgram,\n    21→  SYSVAR_SLOT_HASHES_PUBKEY,\n    22→  LAMPORTS_PER_SOL,\n    23→  Transaction,\n    24→  sendAndConfirmTransaction,\n    25→} from \"@solana/web3.js\";\n    26→import { AnchorProvider, Program, Wallet } from \"@coral-xyz/anchor\";\n    27→import { readFileSync } from \"fs\";\n    28→import { dirname, join } from \"path\";\n    29→import { fileURLToPath } from \"url\";\n    30→\n    31→const __filename = fileURLToPath(import.meta.url);\n    32→const __dirname = dirname(__filename);\n    33→\n    34→// ---------------------------------------------------------------------------\n    35→// Setup\n    36→// ---------------------------------------------------------------------------\n    37→\n    38→const COINFLIP_IDL = JSON.parse(\n    39→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n    40→);\n    41→const PLATFORM_IDL = JSON.parse(\n    42→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    43→);\n    44→\n    45→const COINFLIP_ID = new PublicKey(COINFLIP_IDL.address);\n    46→const PLATFORM_ID = new PublicKey(PLATFORM_IDL.address);\n    47→\n    48→// VRF constants\n    49→const VRF_PROGRAM_ID = new PublicKey(\"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\");\n    50→const VRF_DEFAULT_QUEUE = new PublicKey(\"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\");\n    51→const [PROGRAM_IDENTITY_PDA] = PublicKey.findProgramAddressSync(\n    52→  [Buffer.from(\"identity\")],\n    53→  COINFLIP_ID\n    54→);\n    55→\n    56→// On-chain constants\n    57→const SIDE_HEADS = 0;\n    58→const PHASE_WAITING = 0;\n    59→const PHASE_LOCKED = 1;\n    60→const PHASE_SETTLED = 2;\n    61→const TIER_IRON = 0;\n    62→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n    63→\n    64→// ---------------------------------------------------------------------------\n    65→// PDA helpers\n    66→// ---------------------------------------------------------------------------\n    67→\n    68→function getMatchPda(creator: PublicKey): PublicKey {\n    69→  return PublicKey.findProgramAddressSync(\n    70→    [Buffer.from(\"match\"), creator.toBuffer()],\n    71→    COINFLIP_ID\n    72→  )[0];\n    73→}\n    74→\n    75→function getConfigPda(): PublicKey {\n    76→  return PublicKey.findProgramAddressSync(\n    77→    [Buffer.from(\"coinflip_config\")],\n    78→    COINFLIP_ID\n    79→  )[0];\n    80→}\n    81→\n    82→function getPlayerProfilePda(wallet: PublicKey): PublicKey {\n    83→  return PublicKey.findProgramAddressSync(\n    84→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    85→    PLATFORM_ID\n    86→  )[0];\n    87→}\n    88→\n    89→// ---------------------------------------------------------------------------\n    90→// Helpers\n    91→// ---------------------------------------------------------------------------\n    92→\n    93→function sleep(ms: number) {\n    94→  return new Promise((resolve) => setTimeout(resolve, ms));\n    95→}\n    96→\n    97→function log(phase: string, msg: string) {\n    98→  const ts = new Date().toISOString().slice(11, 19);\n    99→  console.log(`[${ts}] [${phase}] ${msg}`);\n   100→}\n   101→\n   102→interface MatchAccount {\n   103→  creator: PublicKey;\n   104→  opponent: PublicKey;\n   105→  tier: number;\n   106→  entryAmount: { toNumber(): number };\n   107→  creatorSide: number;\n   108→  phase: number;\n   109→  result: number;\n   110→  winner: PublicKey;\n   111→  claimed: boolean;\n   112→  lockedAt: { toNumber(): number };\n   113→  bump: number;\n   114→}\n   115→\n   116→// ---------------------------------------------------------------------------\n   117→// Main test\n   118→// ---------------------------------------------------------------------------\n   119→\n   120→async function main() {\n   121→  const connection = new Connection(\"https://api.devnet.solana.com\", \"confirmed\");\n   122→\n   123→  // Load deployer wallet (creator)\n   124→  const walletPath = join(process.env.HOME ?? \"~\", \".config/solana/id.json\");\n   125→  const creatorKeypair = Keypair.fromSecretKey(\n   126→    Uint8Array.from(JSON.parse(readFileSync(walletPath, \"utf8\")))\n   127→  );\n   128→  const creatorWallet = new Wallet(creatorKeypair);\n   129→\n   130→  // Generate ephemeral opponent\n   131→  const opponentKeypair = Keypair.generate();\n   132→\n   133→  log(\"SETUP\", `Creator:  ${creatorKeypair.publicKey.toBase58()}`);\n   134→  log(\"SETUP\", `Opponent: ${opponentKeypair.publicKey.toBase58()}`);\n   135→\n   136→  // Check creator balance\n   137→  const creatorBal = await connection.getBalance(creatorKeypair.publicKey);\n   138→  log(\"SETUP\", `Creator balance: ${(creatorBal / LAMPORTS_PER_SOL).toFixed(4)} SOL`);\n   139→  if (creatorBal < 0.1 * LAMPORTS_PER_SOL) {\n   140→    throw new Error(\"Creator needs at least 0.1 SOL\");\n   141→  }\n   142→\n   143→  // Fund opponent with enough for entry + fees\n   144→  log(\"SETUP\", \"Funding opponent...\");\n   145→  const fundTx = new Transaction().add(\n   146→    SystemProgram.transfer({\n   147→      fromPubkey: creatorKeypair.publicKey,\n   148→      toPubkey: opponentKeypair.publicKey,\n   149→      lamports: 0.05 * LAMPORTS_PER_SOL,\n   150→    })\n   151→  );\n   152→  await sendAndConfirmTransaction(connection, fundTx, [creatorKeypair]);\n   153→  log(\"SETUP\", \"Opponent funded with 0.05 SOL\");\n   154→\n   155→  // Programs\n   156→  const creatorProvider = new AnchorProvider(connection, creatorWallet, {\n   157→    commitment: \"confirmed\",\n   158→  });\n   159→  const opponentProvider = new AnchorProvider(\n   160→    connection,\n   161→    new Wallet(opponentKeypair),\n   162→    { commitment: \"confirmed\" }\n   163→  );\n   164→  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   165→  const creatorProgram = new Program(COINFLIP_IDL as any, creatorProvider);\n   166→  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   167→  const opponentProgram = new Program(COINFLIP_IDL as any, opponentProvider);\n   168→\n   169→  const configPda = getConfigPda();\n   170→  const matchPda = getMatchPda(creatorKeypair.publicKey);\n   171→\n   172→  // =========================================================================\n   173→  // 1. CREATE MATCH\n   174→  // =========================================================================\n   175→  log(\"CREATE\", \"Creating match (Iron tier, Heads)...\");\n   176→  const createTx = await creatorProgram.methods\n   177→    .createMatch(TIER_IRON, SIDE_HEADS)\n   178→    .accountsStrict({\n   179→      creator: creatorKeypair.publicKey,\n   180→      coinflipMatch: matchPda,\n   181→      systemProgram: SystemProgram.programId,\n   182→    })\n   183→    .rpc();\n   184→  log(\"CREATE\", `tx: ${createTx}`);\n   185→\n   186→  // Verify WAITING phase\n   187→  const matchAfterCreate = (await creatorProgram.account.coinflipMatch.fetch(\n   188→    matchPda\n   189→  )) as unknown as MatchAccount;\n   190→  assert(matchAfterCreate.phase === PHASE_WAITING, `Expected WAITING(0), got ${matchAfterCreate.phase}`);\n   191→  assert(matchAfterCreate.tier === TIER_IRON, `Expected tier 0, got ${matchAfterCreate.tier}`);\n   192→  assert(matchAfterCreate.creatorSide === SIDE_HEADS, `Expected side 0, got ${matchAfterCreate.creatorSide}`);\n   193→  assert(\n   194→    matchAfterCreate.entryAmount.toNumber() === TIER_IRON_AMOUNT,\n   195→    `Expected ${TIER_IRON_AMOUNT}, got ${matchAfterCreate.entryAmount.toNumber()}`\n   196→  );\n   197→  log(\"CREATE\", \"PASS: phase=WAITING, tier=Iron, side=Heads, amount=0.005 SOL\");\n   198→\n   199→  // =========================================================================\n   200→  // 2. JOIN MATCH (triggers VRF request)\n   201→  // =========================================================================\n   202→  log(\"JOIN\", \"Opponent joining match (triggers VRF request)...\");\n   203→  const joinTx = await opponentProgram.methods\n   204→    .joinMatch()\n   205→    .accountsStrict({\n   206→      opponent: opponentKeypair.publicKey,\n   207→      coinflipMatch: matchPda,\n   208→      config: configPda,\n   209→      oracleQueue: VRF_DEFAULT_QUEUE,\n   210→      programIdentity: PROGRAM_IDENTITY_PDA,\n   211→      vrfProgram: VRF_PROGRAM_ID,\n   212→      slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n   213→      systemProgram: SystemProgram.programId,\n   214→    })\n   215→    .rpc();\n   216→  log(\"JOIN\", `tx: ${joinTx}`);\n   217→\n   218→  // Verify LOCKED phase\n   219→  const matchAfterJoin = (await creatorProgram.account.coinflipMatch.fetch(\n   220→    matchPda\n   221→  )) as unknown as MatchAccount;\n   222→  assert(matchAfterJoin.phase === PHASE_LOCKED, `Expected LOCKED(1), got ${matchAfterJoin.phase}`);\n   223→  assert(\n   224→    matchAfterJoin.opponent.equals(opponentKeypair.publicKey),\n   225→    \"Opponent mismatch\"\n   226→  );\n   227→  assert(matchAfterJoin.lockedAt.toNumber() > 0, \"lockedAt should be set\");\n   228→  log(\"JOIN\", `PASS: phase=LOCKED, opponent set, lockedAt=${matchAfterJoin.lockedAt.toNumber()}`);\n   229→\n   230→  // =========================================================================\n   231→  // 3. POLL FOR VRF RESOLUTION (LOCKED → SETTLED)\n   232→  // =========================================================================\n   233→  log(\"RESOLVE\", \"Waiting for VRF callback to resolve match...\");\n   234→  const maxWaitMs = 60_000;\n   235→  const pollMs = 2_000;\n   236→  const startTime = Date.now();\n   237→  let matchResolved: MatchAccount | null = null;\n   238→\n   239→  while (Date.now() - startTime < maxWaitMs) {\n   240→    await sleep(pollMs);\n   241→    const current = (await creatorProgram.account.coinflipMatch.fetch(\n   242→      matchPda\n   243→    )) as unknown as MatchAccount;\n   244→\n   245→    if (current.phase === PHASE_SETTLED) {\n   246→      matchResolved = current;\n   247→      break;\n   248→    }\n   249→    const elapsed = ((Date.now() - startTime) / 1000).toFixed(0);\n   250→    log(\"RESOLVE\", `Still LOCKED... (${elapsed}s elapsed)`);\n   251→  }\n   252→\n   253→  if (!matchResolved) {\n   254→    log(\"RESOLVE\", \"FAIL: VRF callback did not resolve within 60s\");\n   255→    log(\"RESOLVE\", \"The match is stuck in LOCKED. Check Orao VRF service.\");\n   256→\n   257→    // Clean up: wait for timeout then cancel\n   258→    log(\"CLEANUP\", \"Match will need timeout_cancel after 2 min lock timeout.\");\n   259→    process.exit(1);\n   260→  }\n   261→\n   262→  const resultSide = matchResolved.result === 0 ? \"HEADS\" : \"TAILS\";\n   263→  const winnerIsCreator = matchResolved.winner.equals(creatorKeypair.publicKey);\n   264→  log(\"RESOLVE\", `PASS: phase=SETTLED, result=${resultSide}, winner=${winnerIsCreator ? \"CREATOR\" : \"OPPONENT\"}`);\n   265→\n   266→  // =========================================================================\n   267→  // 4. CLAIM PAYOUT\n   268→  // =========================================================================\n   269→  const winnerKeypair = winnerIsCreator ? creatorKeypair : opponentKeypair;\n   270→  const winnerProgram = winnerIsCreator ? creatorProgram : opponentProgram;\n   271→\n   272→  // Fetch treasury from config\n   273→  const config = await creatorProgram.account.coinflipConfig.fetch(configPda);\n   274→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   275→\n   276→  const creatorProfilePda = getPlayerProfilePda(creatorKeypair.publicKey);\n   277→  const opponentProfilePda = getPlayerProfilePda(opponentKeypair.publicKey);\n   278→\n   279→  // Ensure player profiles exist (claim_payout CPIs into platform::update_player_profile)\n   280→  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   281→  const platformProgram = new Program(PLATFORM_IDL as any, creatorProvider);\n   282→  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   283→  const opponentPlatformProgram = new Program(PLATFORM_IDL as any, opponentProvider);\n   284→\n   285→  for (const [program, player, profilePda] of [\n   286→    [platformProgram, creatorKeypair.publicKey, creatorProfilePda],\n   287→    [opponentPlatformProgram, opponentKeypair.publicKey, opponentProfilePda],\n   288→  ] as const) {\n   289→    try {\n   290→      await program.account.playerProfile.fetch(profilePda);\n   291→    } catch {\n   292→      log(\"CLAIM\", `Creating player profile for ${player.toBase58().slice(0, 8)}...`);\n   293→      await program.methods\n   294→        .createPlayerProfile()\n   295→        .accountsStrict({\n   296→          player,\n   297→          profile: profilePda,\n   298→          systemProgram: SystemProgram.programId,\n   299→        })\n   300→        .rpc();\n   301→    }\n   302→  }\n   303→\n   304→  const winnerBalBefore = await connection.getBalance(winnerKeypair.publicKey);\n   305→\n   306→  log(\"CLAIM\", `Winner (${winnerIsCreator ? \"creator\" : \"opponent\"}) claiming payout...`);\n   307→  const claimTx = await winnerProgram.methods\n   308→    .claimPayout()\n   309→    .accountsStrict({\n   310→      winner: winnerKeypair.publicKey,\n   311→      coinflipMatch: matchPda,\n   312→      config: configPda,\n   313→      treasury,\n   314→      creator: creatorKeypair.publicKey,\n   315→      creatorProfile: creatorProfilePda,\n   316→      opponentProfile: opponentProfilePda,\n   317→      platformProgram: PLATFORM_ID,\n   318→      systemProgram: SystemProgram.programId,\n   319→    })\n   320→    .rpc();\n   321→  log(\"CLAIM\", `tx: ${claimTx}`);\n   322→\n   323→  const winnerBalAfter = await connection.getBalance(winnerKeypair.publicKey);\n   324→  const expectedPayout = TIER_IRON_AMOUNT * 2 * 0.97;\n   325→  const actualGain = winnerBalAfter - winnerBalBefore;\n   326→\n   327→  // Winner gets payout. If winner is also the creator, they also get the rent\n   328→  // refund from closing the match account (~2M lamports). Subtract tx fee (~5k).\n   329→  assert(\n   330→    actualGain >= expectedPayout - 10_000,\n   331→    `Payout too low: expected at least ~${expectedPayout}, got ${actualGain}`\n   332→  );\n   333→  log(\"CLAIM\", `PASS: payout received (~${(actualGain / LAMPORTS_PER_SOL).toFixed(6)} SOL, includes rent refund if creator)`);\n   334→\n   335→  // Verify match account is closed\n   336→  const matchInfo = await connection.getAccountInfo(matchPda);\n   337→  assert(\n   338→    matchInfo === null || matchInfo.lamports === 0,\n   339→    \"Match account should be closed after claim\"\n   340→  );\n   341→  log(\"CLAIM\", \"PASS: match account closed\");\n   342→\n   343→  // =========================================================================\n   344→  // SUMMARY\n   345→  // =========================================================================\n   346→  console.log(\"\\n========================================\");\n   347→  console.log(\"  DEVNET LIFECYCLE TEST: ALL PASSED\");\n   348→  console.log(\"========================================\");\n   349→  console.log(`  Create:  WAITING (tier=Iron, side=Heads)`);\n   350→  console.log(`  Join:    LOCKED  (VRF requested, lockedAt set)`);\n   351→  console.log(`  Resolve: SETTLED (result=${resultSide}, winner=${winnerIsCreator ? \"creator\" : \"opponent\"})`);\n   352→  console.log(`  Claim:   CLOSED  (payout=${(actualGain / LAMPORTS_PER_SOL).toFixed(6)} SOL)`);\n   353→  console.log(\"========================================\\n\");\n   354→}\n   355→\n   356→function assert(condition: boolean, msg: string) {\n   357→  if (!condition) {\n   358→    throw new Error(`ASSERTION FAILED: ${msg}`);\n   359→  }\n   360→}\n   361→\n   362→main().catch((e) => {\n   363→  console.error(\"\\nTEST FAILED:\", e.message || e);\n   364→  process.exit(1);\n   365→});\n   366→"}]},"parent_tool_use_id":"toolu_01PRSLefhQeBwpvqapfE6EQp","session_id":"e8e7bcc0-e29f-4246-996e-49dc6d7211e9","uuid":"71dd7ab0-e6ba-4354-b11e-ce0e0a2e01e4"}
