{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JKQuwh7u3hPHkSwqWp8Sg8","type":"tool_result","content":"     1→/**\n     2→ * Join an active coinflip match on devnet.\n     3→ *\n     4→ * Usage:\n     5→ *   npx ts-node --esm scripts/join-devnet-match.ts [MATCH_PDA]\n     6→ *\n     7→ * If MATCH_PDA is omitted, lists all open matches and joins the first one.\n     8→ *\n     9→ * Prerequisites:\n    10→ *   - Programs deployed to devnet\n    11→ *   - Wallet at ~/.config/solana/id.json (with devnet SOL)\n    12→ */\n    13→\n    14→import {\n    15→  Connection,\n    16→  Keypair,\n    17→  PublicKey,\n    18→  SystemProgram,\n    19→  SYSVAR_SLOT_HASHES_PUBKEY,\n    20→  Transaction,\n    21→} from \"@solana/web3.js\";\n    22→import { AnchorProvider, Program, Wallet } from \"@coral-xyz/anchor\";\n    23→import { readFileSync } from \"fs\";\n    24→import { dirname, join } from \"path\";\n    25→import { fileURLToPath } from \"url\";\n    26→\n    27→const __filename = fileURLToPath(import.meta.url);\n    28→const __dirname = dirname(__filename);\n    29→\n    30→// ============ Constants ============\n    31→\n    32→const COINFLIP_PROGRAM_ID = new PublicKey(\n    33→  \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n    34→);\n    35→\n    36→// Orao VRF constants (legacy devnet script — may need update for Orao accounts)\n    37→const VRF_DEFAULT_QUEUE = new PublicKey(\n    38→  \"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\"\n    39→);\n    40→const VRF_PROGRAM_ID = new PublicKey(\n    41→  \"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\"\n    42→);\n    43→const [VRF_PROGRAM_IDENTITY] = PublicKey.findProgramAddressSync(\n    44→  [Buffer.from(\"identity\")],\n    45→  COINFLIP_PROGRAM_ID\n    46→);\n    47→\n    48→// ============ PDA Helpers ============\n    49→\n    50→function getConfigPda(): PublicKey {\n    51→  const [pda] = PublicKey.findProgramAddressSync(\n    52→    [Buffer.from(\"coinflip_config\")],\n    53→    COINFLIP_PROGRAM_ID\n    54→  );\n    55→  return pda;\n    56→}\n    57→\n    58→function getMatchPda(creator: PublicKey): PublicKey {\n    59→  const [pda] = PublicKey.findProgramAddressSync(\n    60→    [Buffer.from(\"match\"), creator.toBuffer()],\n    61→    COINFLIP_PROGRAM_ID\n    62→  );\n    63→  return pda;\n    64→}\n    65→\n    66→// ============ Main ============\n    67→\n    68→async function main() {\n    69→  // Load wallet\n    70→  const walletPath = join(\n    71→    process.env.HOME ?? \"~\",\n    72→    \".config/solana/id.json\"\n    73→  );\n    74→  const secretKey = JSON.parse(readFileSync(walletPath, \"utf8\"));\n    75→  const keypair = Keypair.fromSecretKey(Uint8Array.from(secretKey));\n    76→  const wallet = new Wallet(keypair);\n    77→\n    78→  // Connect to devnet\n    79→  const connection = new Connection(\n    80→    \"https://api.devnet.solana.com\",\n    81→    \"confirmed\"\n    82→  );\n    83→  const provider = new AnchorProvider(connection, wallet, {\n    84→    commitment: \"confirmed\",\n    85→  });\n    86→\n    87→  // Load IDL\n    88→  const coinflipIdl = JSON.parse(\n    89→    readFileSync(\n    90→      join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"),\n    91→      \"utf8\"\n    92→    )\n    93→  );\n    94→  const program = new Program(coinflipIdl, provider);\n    95→\n    96→  console.log(\"=== Join Devnet Match ===\");\n    97→  console.log(\"Opponent (you):\", wallet.publicKey.toBase58());\n    98→  const balance = await connection.getBalance(wallet.publicKey);\n    99→  console.log(\"Balance:\", (balance / 1e9).toFixed(4), \"SOL\\n\");\n   100→\n   101→  // Resolve target match\n   102→  const matchPdaArg = process.argv[2];\n   103→  let matchPda: PublicKey;\n   104→  let matchData: any;\n   105→\n   106→  if (matchPdaArg) {\n   107→    // User specified a match PDA\n   108→    matchPda = new PublicKey(matchPdaArg);\n   109→    console.log(\"Target match PDA:\", matchPda.toBase58());\n   110→    matchData = await (program.account as any).coinflipMatch.fetch(matchPda);\n   111→  } else {\n   112→    // Find all open matches\n   113→    console.log(\"Searching for open matches (phase=WAITING)...\");\n   114→    const allAccounts = await (program.account as any).coinflipMatch.all();\n   115→    const openMatches = allAccounts.filter(\n   116→      (acc: any) => acc.account.phase === 0\n   117→    );\n   118→\n   119→    if (openMatches.length === 0) {\n   120→      console.log(\"No open matches found on devnet.\");\n   121→      process.exit(0);\n   122→    }\n   123→\n   124→    console.log(`Found ${openMatches.length} open match(es):\\n`);\n   125→    const tiers = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   126→    for (const m of openMatches) {\n   127→      const d = m.account;\n   128→      const entrySOL = (Number(d.entryAmount) / 1e9).toFixed(4);\n   129→      console.log(`  PDA:     ${m.publicKey.toBase58()}`);\n   130→      console.log(`  Creator: ${d.creator.toBase58()}`);\n   131→      console.log(`  Tier:    ${tiers[d.tier] ?? d.tier} (${entrySOL} SOL)`);\n   132→      console.log(`  Side:    ${d.creatorSide === 0 ? \"heads\" : \"tails\"}`);\n   133→      console.log();\n   134→    }\n   135→\n   136→    // Pick first open match\n   137→    matchPda = openMatches[0].publicKey;\n   138→    matchData = openMatches[0].account;\n   139→    console.log(`Joining first open match: ${matchPda.toBase58()}\\n`);\n   140→  }\n   141→\n   142→  // Validate\n   143→  if (matchData.phase !== 0) {\n   144→    console.error(\n   145→      `Match is not in WAITING phase (current phase: ${matchData.phase}). Cannot join.`\n   146→    );\n   147→    process.exit(1);\n   148→  }\n   149→\n   150→  if (matchData.creator.equals(wallet.publicKey)) {\n   151→    console.error(\"You are the creator of this match — cannot join your own!\");\n   152→    process.exit(1);\n   153→  }\n   154→\n   155→  const entrySOL = Number(matchData.entryAmount) / 1e9;\n   156→  console.log(`Entry amount: ${entrySOL.toFixed(4)} SOL`);\n   157→\n   158→  if (balance < Number(matchData.entryAmount) + 10_000) {\n   159→    console.error(\n   160→      `Insufficient balance. Need at least ${(entrySOL + 0.00001).toFixed(5)} SOL`\n   161→    );\n   162→    process.exit(1);\n   163→  }\n   164→\n   165→  // Build and send join transaction\n   166→  const configPda = getConfigPda();\n   167→\n   168→  console.log(\"Sending joinMatch transaction...\");\n   169→  const tx = await (program.methods as any)\n   170→    .joinMatch()\n   171→    .accountsStrict({\n   172→      opponent: wallet.publicKey,\n   173→      coinflipMatch: matchPda,\n   174→      config: configPda,\n   175→      oracleQueue: VRF_DEFAULT_QUEUE,\n   176→      programIdentity: VRF_PROGRAM_IDENTITY,\n   177→      vrfProgram: VRF_PROGRAM_ID,\n   178→      slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n   179→      systemProgram: SystemProgram.programId,\n   180→    })\n   181→    .rpc();\n   182→\n   183→  console.log(\"\\nJoined successfully!\");\n   184→  console.log(\"Transaction:\", tx);\n   185→  console.log(`Explorer: https://explorer.solana.com/tx/${tx}?cluster=devnet`);\n   186→\n   187→  // Fetch updated match state\n   188→  const updated = await (program.account as any).coinflipMatch.fetch(matchPda);\n   189→  console.log(\"\\n--- Updated Match State ---\");\n   190→  console.log(\"Phase:\", updated.phase === 1 ? \"LOCKED (VRF pending)\" : updated.phase);\n   191→  console.log(\"Opponent:\", updated.opponent.toBase58());\n   192→}\n   193→\n   194→main().catch((e) => {\n   195→  console.error(\"Error:\", e.message ?? e);\n   196→  process.exit(1);\n   197→});\n   198→"}]},"parent_tool_use_id":"toolu_01PRSLefhQeBwpvqapfE6EQp","session_id":"e8e7bcc0-e29f-4246-996e-49dc6d7211e9","uuid":"50890f6b-69ae-4798-a3d0-c03275aea6e7"}
