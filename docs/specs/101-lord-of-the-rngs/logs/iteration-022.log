{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D3pXqf7aEfVo2Rx3NKd1yy","type":"tool_result","content":"     1→/**\n     2→ * Initialize platform + coinflip configs on devnet.\n     3→ *\n     4→ * Usage: npx ts-node --esm scripts/init-devnet-config.ts\n     5→ *\n     6→ * Prerequisites:\n     7→ *   - Programs deployed to devnet (run deploy-devnet.sh first)\n     8→ *   - Deployer wallet at ~/.config/solana/id.json\n     9→ *   - IDLs generated in target/idl/\n    10→ */\n    11→\n    12→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n    13→import { AnchorProvider, Program, Wallet } from \"@coral-xyz/anchor\";\n    14→import { readFileSync } from \"fs\";\n    15→import { dirname, join } from \"path\";\n    16→import { fileURLToPath } from \"url\";\n    17→\n    18→const __filename = fileURLToPath(import.meta.url);\n    19→const __dirname = dirname(__filename);\n    20→\n    21→async function main() {\n    22→  // Load wallet\n    23→  const walletPath = join(\n    24→    process.env.HOME ?? \"~\",\n    25→    \".config/solana/id.json\"\n    26→  );\n    27→  const secretKey = JSON.parse(readFileSync(walletPath, \"utf8\"));\n    28→  const keypair = Keypair.fromSecretKey(Uint8Array.from(secretKey));\n    29→  const wallet = new Wallet(keypair);\n    30→\n    31→  // Connect to devnet\n    32→  const connection = new Connection(\"https://api.devnet.solana.com\", \"confirmed\");\n    33→  const provider = new AnchorProvider(connection, wallet, {\n    34→    commitment: \"confirmed\",\n    35→  });\n    36→\n    37→  console.log(\"=== Init Devnet Config ===\");\n    38→  console.log(\"Authority:\", wallet.publicKey.toBase58());\n    39→  const balance = await connection.getBalance(wallet.publicKey);\n    40→  console.log(\"Balance:\", (balance / 1e9).toFixed(4), \"SOL\");\n    41→\n    42→  // Load IDLs\n    43→  const platformIdl = JSON.parse(\n    44→    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    45→  );\n    46→  const coinflipIdl = JSON.parse(\n    47→    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n    48→  );\n    49→\n    50→  const platformProgram = new Program(platformIdl, provider);\n    51→  const coinflipProgram = new Program(coinflipIdl, provider);\n    52→\n    53→  const treasury = wallet.publicKey; // deployer = treasury for devnet\n    54→\n    55→  // 1. Initialize Platform\n    56→  console.log(\"\\n--- Platform ---\");\n    57→  try {\n    58→    const tx = await (platformProgram.methods as any)\n    59→      .initializePlatform(treasury)\n    60→      .accounts({ authority: wallet.publicKey })\n    61→      .rpc();\n    62→    console.log(\"Platform initialized. tx:\", tx);\n    63→  } catch (e: any) {\n    64→    if (e.message?.includes(\"already in use\")) {\n    65→      console.log(\"Platform config already initialized (skipping).\");\n    66→    } else {\n    67→      throw e;\n    68→    }\n    69→  }\n    70→\n    71→  // 2. Initialize Coinflip Config\n    72→  console.log(\"\\n--- Coinflip ---\");\n    73→  try {\n    74→    const tx = await (coinflipProgram.methods as any)\n    75→      .initializeConfig(treasury)\n    76→      .accounts({ authority: wallet.publicKey })\n    77→      .rpc();\n    78→    console.log(\"Coinflip config initialized. tx:\", tx);\n    79→  } catch (e: any) {\n    80→    if (e.message?.includes(\"already in use\")) {\n    81→      console.log(\"Coinflip config already initialized (skipping).\");\n    82→    } else {\n    83→      throw e;\n    84→    }\n    85→  }\n    86→\n    87→  console.log(\"\\n=== Done ===\");\n    88→}\n    89→\n    90→main().catch((e) => {\n    91→  console.error(e);\n    92→  process.exit(1);\n    93→});\n    94→"}]},"parent_tool_use_id":"toolu_01PRSLefhQeBwpvqapfE6EQp","session_id":"e8e7bcc0-e29f-4246-996e-49dc6d7211e9","uuid":"b04c6a9b-9aee-4699-9f7c-03280b593337"}
