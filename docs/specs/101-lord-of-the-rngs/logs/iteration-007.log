{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QzRs9LJKQBXaqfkHtKYjG8","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::solana_program::{\n     3→    instruction::{AccountMeta, Instruction},\n     4→    program::invoke_signed,\n     5→};\n     6→use solana_sha256_hasher::hashv;\n     7→\n     8→/// Calls the platform program's `update_player_profile` instruction via CPI.\n     9→///\n    10→/// If the profile account has no data (player hasn't created a profile), the call\n    11→/// is silently skipped — returns `Ok(())` without emitting a CPI.\n    12→///\n    13→/// This helper constructs the CPI instruction manually (discriminator + borsh args)\n    14→/// to avoid a circular dependency between `rng-shared` and `platform`.\n    15→///\n    16→/// # Arguments\n    17→///\n    18→/// * `platform_program` — The platform program account.\n    19→/// * `profile` — The player's profile PDA (mutable). Skipped if empty.\n    20→/// * `authority` — The game config PDA that signs the CPI.\n    21→/// * `signer_seeds` — Seeds for PDA signing (e.g., `&[b\"coinflip_config\", &[bump]]`).\n    22→/// * `total_games_delta` — Reserved; platform always increments by 1 per call.\n    23→/// * `wins_delta` — If > 0, player is marked as winner.\n    24→/// * `total_wagered_delta` — Lamports wagered in this game (maps to `wager_amount`).\n    25→/// * `total_won_delta` — Lamports won in this game (maps to `won_amount`, 0 if lost).\n    26→///\n    27→/// # Example\n    28→///\n    29→/// ```ignore\n    30→/// update_player_profile_cpi(\n    31→///     &ctx.accounts.platform_program,\n    32→///     &ctx.accounts.creator_profile,\n    33→///     &ctx.accounts.config.to_account_info(),\n    34→///     &[b\"coinflip_config\", &[config_bump]],\n    35→///     1,                    // total_games_delta\n    36→///     if is_winner { 1 } else { 0 }, // wins_delta\n    37→///     entry_amount,         // total_wagered_delta\n    38→///     if is_winner { payout } else { 0 }, // total_won_delta\n    39→/// )?;\n    40→/// ```\n    41→pub fn update_player_profile_cpi<'a>(\n    42→    platform_program: &AccountInfo<'a>,\n    43→    profile: &AccountInfo<'a>,\n    44→    authority: &AccountInfo<'a>,\n    45→    signer_seeds: &[&[u8]],\n    46→    _total_games_delta: u64,\n    47→    wins_delta: u64,\n    48→    total_wagered_delta: u64,\n    49→    total_won_delta: u64,\n    50→) -> Result<()> {\n    51→    // Guard: skip if profile hasn't been created yet\n    52→    if profile.data_is_empty() {\n    53→        return Ok(());\n    54→    }\n    55→\n    56→    // Map to platform program's actual parameters\n    57→    let wager_amount = total_wagered_delta;\n    58→    let won_amount = total_won_delta;\n    59→    let is_winner = wins_delta > 0;\n    60→\n    61→    // Discriminator = sha256(\"global:update_player_profile\")[0..8]\n    62→    let disc = hashv(&[b\"global:update_player_profile\"]);\n    63→\n    64→    // Instruction data: 8-byte discriminator + wager_amount(u64) + won_amount(u64) + is_winner(bool)\n    65→    let mut data = [0u8; 25];\n    66→    data[..8].copy_from_slice(&disc.to_bytes()[..8]);\n    67→    data[8..16].copy_from_slice(&wager_amount.to_le_bytes());\n    68→    data[16..24].copy_from_slice(&won_amount.to_le_bytes());\n    69→    data[24] = u8::from(is_winner);\n    70→\n    71→    let accounts = vec![\n    72→        AccountMeta::new_readonly(*authority.key, true), // caller (signer)\n    73→        AccountMeta::new(*profile.key, false),           // profile (mutable)\n    74→    ];\n    75→\n    76→    let ix = Instruction {\n    77→        program_id: *platform_program.key,\n    78→        accounts,\n    79→        data: data.to_vec(),\n    80→    };\n    81→\n    82→    invoke_signed(\n    83→        &ix,\n    84→        &[authority.clone(), profile.clone(), platform_program.clone()],\n    85→        &[signer_seeds],\n    86→    )?;\n    87→\n    88→    Ok(())\n    89→}\n    90→"}]},"parent_tool_use_id":null,"session_id":"d619c696-fe84-4ada-8f1c-c53696e9582f","uuid":"2c98883f-96c6-4980-adb6-27cedd088339","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/cpi.rs","content":"use anchor_lang::prelude::*;\nuse anchor_lang::solana_program::{\n    instruction::{AccountMeta, Instruction},\n    program::invoke_signed,\n};\nuse solana_sha256_hasher::hashv;\n\n/// Calls the platform program's `update_player_profile` instruction via CPI.\n///\n/// If the profile account has no data (player hasn't created a profile), the call\n/// is silently skipped — returns `Ok(())` without emitting a CPI.\n///\n/// This helper constructs the CPI instruction manually (discriminator + borsh args)\n/// to avoid a circular dependency between `rng-shared` and `platform`.\n///\n/// # Arguments\n///\n/// * `platform_program` — The platform program account.\n/// * `profile` — The player's profile PDA (mutable). Skipped if empty.\n/// * `authority` — The game config PDA that signs the CPI.\n/// * `signer_seeds` — Seeds for PDA signing (e.g., `&[b\"coinflip_config\", &[bump]]`).\n/// * `total_games_delta` — Reserved; platform always increments by 1 per call.\n/// * `wins_delta` — If > 0, player is marked as winner.\n/// * `total_wagered_delta` — Lamports wagered in this game (maps to `wager_amount`).\n/// * `total_won_delta` — Lamports won in this game (maps to `won_amount`, 0 if lost).\n///\n/// # Example\n///\n/// ```ignore\n/// update_player_profile_cpi(\n///     &ctx.accounts.platform_program,\n///     &ctx.accounts.creator_profile,\n///     &ctx.accounts.config.to_account_info(),\n///     &[b\"coinflip_config\", &[config_bump]],\n///     1,                    // total_games_delta\n///     if is_winner { 1 } else { 0 }, // wins_delta\n///     entry_amount,         // total_wagered_delta\n///     if is_winner { payout } else { 0 }, // total_won_delta\n/// )?;\n/// ```\npub fn update_player_profile_cpi<'a>(\n    platform_program: &AccountInfo<'a>,\n    profile: &AccountInfo<'a>,\n    authority: &AccountInfo<'a>,\n    signer_seeds: &[&[u8]],\n    _total_games_delta: u64,\n    wins_delta: u64,\n    total_wagered_delta: u64,\n    total_won_delta: u64,\n) -> Result<()> {\n    // Guard: skip if profile hasn't been created yet\n    if profile.data_is_empty() {\n        return Ok(());\n    }\n\n    // Map to platform program's actual parameters\n    let wager_amount = total_wagered_delta;\n    let won_amount = total_won_delta;\n    let is_winner = wins_delta > 0;\n\n    // Discriminator = sha256(\"global:update_player_profile\")[0..8]\n    let disc = hashv(&[b\"global:update_player_profile\"]);\n\n    // Instruction data: 8-byte discriminator + wager_amount(u64) + won_amount(u64) + is_winner(bool)\n    let mut data = [0u8; 25];\n    data[..8].copy_from_slice(&disc.to_bytes()[..8]);\n    data[8..16].copy_from_slice(&wager_amount.to_le_bytes());\n    data[16..24].copy_from_slice(&won_amount.to_le_bytes());\n    data[24] = u8::from(is_winner);\n\n    let accounts = vec![\n        AccountMeta::new_readonly(*authority.key, true), // caller (signer)\n        AccountMeta::new(*profile.key, false),           // profile (mutable)\n    ];\n\n    let ix = Instruction {\n        program_id: *platform_program.key,\n        accounts,\n        data: data.to_vec(),\n    };\n\n    invoke_signed(\n        &ix,\n        &[authority.clone(), profile.clone(), platform_program.clone()],\n        &[signer_seeds],\n    )?;\n\n    Ok(())\n}\n","numLines":90,"startLine":1,"totalLines":90}}}
