{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SSK8RVVtoKz4jpWVpxwCBM","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { AnchorError, Program } from \"@coral-xyz/anchor\";\n     5→import { Wallet } from \"@coral-xyz/anchor\";\n     6→import {\n     7→  Keypair,\n     8→  PublicKey,\n     9→  SystemProgram,\n    10→  LAMPORTS_PER_SOL,\n    11→} from \"@solana/web3.js\";\n    12→import { Clock } from \"solana-bankrun\";\n    13→import type { Lordofrngs } from \"../target/types/lordofrngs\";\n    14→import { readFileSync } from \"fs\";\n    15→import { dirname, join } from \"path\";\n    16→import { fileURLToPath } from \"url\";\n    17→import BN from \"bn.js\";\n    18→\n    19→const __filename = fileURLToPath(import.meta.url);\n    20→const __dirname = dirname(__filename);\n    21→\n    22→const IDL = JSON.parse(\n    23→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n    24→);\n    25→const PROGRAM_ID = new PublicKey(IDL.address);\n    26→\n    27→// Tier constants (from shared crate)\n    28→const TIER_IRON = 0;\n    29→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n    30→const COUNTDOWN_SECONDS = 60;\n    31→\n    32→// Mock VRF randomness buffers (32 bytes each)\n    33→// Unfulfilled: all zeros → is_fulfilled=false\n    34→const RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n    35→\n    36→// ---------------------------------------------------------------------------\n    37→// PDA helpers\n    38→// ---------------------------------------------------------------------------\n    39→function getConfigPda(): PublicKey {\n    40→  const [pda] = PublicKey.findProgramAddressSync(\n    41→    [Buffer.from(\"lord_config\")],\n    42→    PROGRAM_ID\n    43→  );\n    44→  return pda;\n    45→}\n    46→\n    47→function getRoundPda(tier: number, roundNumber: number | bigint): PublicKey {\n    48→  const tierBuf = Buffer.from([tier]);\n    49→  const roundBuf = Buffer.alloc(8);\n    50→  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n    51→  const [pda] = PublicKey.findProgramAddressSync(\n    52→    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    53→    PROGRAM_ID\n    54→  );\n    55→  return pda;\n    56→}\n    57→\n    58→// ---------------------------------------------------------------------------\n    59→// Test context factory\n    60→// ---------------------------------------------------------------------------\n    61→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n    62→  return {\n    63→    lamports,\n    64→    data: Buffer.alloc(0),\n    65→    owner: SystemProgram.programId,\n    66→    executable: false,\n    67→  };\n    68→}\n    69→\n    70→interface TestContext {\n    71→  context: Awaited<ReturnType<typeof startAnchor>>;\n    72→  creator: PublicKey;\n    73→  treasury: Keypair;\n    74→  creatorProgram: Program<Lordofrngs>;\n    75→  configPda: PublicKey;\n    76→  player2: Keypair;\n    77→  player2Program: Program<Lordofrngs>;\n    78→  mockRandomness: Keypair;\n    79→  mockOraoProgram: Keypair;\n    80→  mockOraoNetworkState: Keypair;\n    81→  mockOraoTreasury: Keypair;\n    82→}\n    83→\n    84→async function createTestContext(): Promise<TestContext> {\n    85→  const treasury = Keypair.generate();\n    86→  const player2 = Keypair.generate();\n    87→  const mockRandomness = Keypair.generate();\n    88→  const mockOraoProgram = Keypair.generate();\n    89→  const mockOraoNetworkState = Keypair.generate();\n    90→  const mockOraoTreasury = Keypair.generate();\n    91→\n    92→  const context = await startAnchor(\"./\", [], [\n    93→    { address: treasury.publicKey, info: fundedAccountData() },\n    94→    { address: player2.publicKey, info: fundedAccountData() },\n    95→    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n    96→    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n    97→    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n    98→    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n    99→    // Mock randomness account — starts unfulfilled (32 zero bytes)\n   100→    {\n   101→      address: mockRandomness.publicKey,\n   102→      info: {\n   103→        lamports: LAMPORTS_PER_SOL,\n   104→        data: RANDOMNESS_UNFULFILLED,\n   105→        owner: SystemProgram.programId,\n   106→        executable: false,\n   107→      },\n   108→    },\n   109→  ]);\n   110→\n   111→  const creatorProvider = new BankrunProvider(context);\n   112→  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n   113→\n   114→  const player2Provider = new BankrunProvider(context, new Wallet(player2));\n   115→  const player2Program = new Program<Lordofrngs>(IDL, player2Provider);\n   116→\n   117→  const creator = creatorProvider.wallet.publicKey;\n   118→  const configPda = getConfigPda();\n   119→\n   120→  return {\n   121→    context,\n   122→    creator,\n   123→    treasury,\n   124→    creatorProgram,\n   125→    configPda,\n   126→    player2,\n   127→    player2Program,\n   128→    mockRandomness,\n   129→    mockOraoProgram,\n   130→    mockOraoNetworkState,\n   131→    mockOraoTreasury,\n   132→  };\n   133→}\n   134→\n   135→// ---------------------------------------------------------------------------\n   136→// Clock warp helpers\n   137→// ---------------------------------------------------------------------------\n   138→async function warpPastCountdown(t: TestContext) {\n   139→  const clock = await t.context.banksClient.getClock();\n   140→  t.context.setClock(\n   141→    new Clock(\n   142→      clock.slot + BigInt(200),\n   143→      clock.epochStartTimestamp,\n   144→      clock.epoch,\n   145→      clock.leaderScheduleEpoch,\n   146→      clock.unixTimestamp + BigInt(COUNTDOWN_SECONDS + 10)\n   147→    )\n   148→  );\n   149→}\n   150→\n   151→// ---------------------------------------------------------------------------\n   152→// Instruction helpers\n   153→// ---------------------------------------------------------------------------\n   154→async function initConfig(t: TestContext) {\n   155→  await t.creatorProgram.methods\n   156→    .initializeConfig(t.treasury.publicKey)\n   157→    .accounts({\n   158→      authority: t.creator,\n   159→      config: t.configPda,\n   160→      systemProgram: SystemProgram.programId,\n   161→    })\n   162→    .rpc();\n   163→}\n   164→\n   165→async function createRound(\n   166→  t: TestContext,\n   167→  tier = TIER_IRON,\n   168→  roundNumber = 0,\n   169→  numEntries = 1,\n   170→  creator?: PublicKey,\n   171→) {\n   172→  const roundPda = getRoundPda(tier, roundNumber);\n   173→  await t.creatorProgram.methods\n   174→    .createRound(tier, new BN(roundNumber), numEntries)\n   175→    .accounts({\n   176→      creator: creator ?? t.creator,\n   177→      config: t.configPda,\n   178→      round: roundPda,\n   179→      systemProgram: SystemProgram.programId,\n   180→    })\n   181→    .rpc();\n   182→  return roundPda;\n   183→}\n   184→\n   185→async function joinRound(\n   186→  program: Program<Lordofrngs>,\n   187→  player: PublicKey,\n   188→  configPda: PublicKey,\n   189→  tier = TIER_IRON,\n   190→  roundNumber = 0,\n   191→  numEntries = 1,\n   192→) {\n   193→  const roundPda = getRoundPda(tier, roundNumber);\n   194→  await program.methods\n   195→    .joinRound(tier, new BN(roundNumber), numEntries)\n   196→    .accounts({\n   197→      player,\n   198→      config: configPda,\n   199→      round: roundPda,\n   200→      systemProgram: SystemProgram.programId,\n   201→    })\n   202→    .rpc();\n   203→  return roundPda;\n   204→}\n   205→\n   206→async function buyMoreEntries(\n   207→  program: Program<Lordofrngs>,\n   208→  player: PublicKey,\n   209→  configPda: PublicKey,\n   210→  tier = TIER_IRON,\n   211→  roundNumber = 0,\n   212→  numEntries = 1,\n   213→) {\n   214→  const roundPda = getRoundPda(tier, roundNumber);\n   215→  await program.methods\n   216→    .buyMoreEntries(tier, new BN(roundNumber), numEntries)\n   217→    .accounts({\n   218→      player,\n   219→      config: configPda,\n   220→      round: roundPda,\n   221→      systemProgram: SystemProgram.programId,\n   222→    })\n   223→    .rpc();\n   224→  return roundPda;\n   225→}\n   226→\n   227→async function startSpin(\n   228→  program: Program<Lordofrngs>,\n   229→  caller: PublicKey,\n   230→  t: TestContext,\n   231→  tier = TIER_IRON,\n   232→  roundNumber = 0,\n   233→) {\n   234→  const roundPda = getRoundPda(tier, roundNumber);\n   235→  await program.methods\n   236→    .startSpin(tier, new BN(roundNumber))\n   237→    .accounts({\n   238→      caller,\n   239→      config: t.configPda,\n   240→      round: roundPda,\n   241→      oraoProgram: t.mockOraoProgram.publicKey,\n   242→      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   243→      oraoTreasury: t.mockOraoTreasury.publicKey,\n   244→      oraoRandom: t.mockRandomness.publicKey,\n   245→      systemProgram: SystemProgram.programId,\n   246→    })\n   247→    .rpc();\n   248→  return roundPda;\n   249→}\n   250→\n   251→// ---------------------------------------------------------------------------\n   252→// Tests\n   253→// ---------------------------------------------------------------------------\n   254→describe(\"lordofrngs\", () => {\n   255→  describe(\"initialize_config\", () => {\n   256→    it(\"creates config with treasury and paused=false\", async () => {\n   257→      const t = await createTestContext();\n   258→      await initConfig(t);\n   259→\n   260→      const config = await t.creatorProgram.account.lordConfig.fetch(\n   261→        t.configPda\n   262→      );\n   263→      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n   264→      expect(config.treasury.toBase58()).to.equal(\n   265→        t.treasury.publicKey.toBase58()\n   266→      );\n   267→      expect(config.paused).to.equal(false);\n   268→      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n   269→    });\n   270→  });\n   271→\n   272→  describe(\"create_round\", () => {\n   273→    it(\"creates round with correct PDA data and escrow balance\", async () => {\n   274→      const t = await createTestContext();\n   275→      await initConfig(t);\n   276→\n   277→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   278→\n   279→      // Verify round state\n   280→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   281→      expect(round.tier).to.equal(TIER_IRON);\n   282→      expect(round.roundNumber.toNumber()).to.equal(0);\n   283→      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   284→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n   285→      expect(round.players).to.have.length(1);\n   286→      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n   287→      expect(round.players[0].entries).to.equal(1);\n   288→      expect(round.totalEntries).to.equal(1);\n   289→      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n   290→      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n   291→      expect(round.lockedAt.toNumber()).to.equal(0);\n   292→      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n   293→      expect(round.claimed).to.equal(false);\n   294→\n   295→      // Verify escrow balance: account holds rent + entry amount\n   296→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   297→      const rent = await t.context.banksClient.getRent();\n   298→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   299→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   300→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n   301→\n   302→      // Verify config round counter incremented\n   303→      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   304→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n   305→    });\n   306→\n   307→    it(\"creates round with multiple entries\", async () => {\n   308→      const t = await createTestContext();\n   309→      await initConfig(t);\n   310→\n   311→      const numEntries = 5;\n   312→      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n   313→\n   314→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   315→      expect(round.players[0].entries).to.equal(numEntries);\n   316→      expect(round.totalEntries).to.equal(numEntries);\n   317→\n   318→      // Escrow should hold numEntries × entry_amount\n   319→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   320→      const rent = await t.context.banksClient.getRent();\n   321→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   322→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   323→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n   324→    });\n   325→\n   326→    it(\"increments round counter per tier\", async () => {\n   327→      const t = await createTestContext();\n   328→      await initConfig(t);\n   329→\n   330→      // Create first round (round 0)\n   331→      await createRound(t, TIER_IRON, 0, 1);\n   332→\n   333→      // Config counter should be 1\n   334→      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   335→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n   336→\n   337→      // Create second round (round 1) — need a new PDA\n   338→      await createRound(t, TIER_IRON, 1, 1);\n   339→\n   340→      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   341→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n   342→    });\n   343→\n   344→    it(\"rejects invalid tier (tier 6)\", async () => {\n   345→      const t = await createTestContext();\n   346→      await initConfig(t);\n   347→\n   348→      const invalidTier = 6;\n   349→      const roundPda = getRoundPda(invalidTier, 0);\n   350→\n   351→      try {\n   352→        await t.creatorProgram.methods\n   353→          .createRound(invalidTier, new BN(0), 1)\n   354→          .accounts({\n   355→            creator: t.creator,\n   356→            config: t.configPda,\n   357→            round: roundPda,\n   358→            systemProgram: SystemProgram.programId,\n   359→          })\n   360→          .rpc();\n   361→        expect.fail(\"Expected InvalidTier error\");\n   362→      } catch (err) {\n   363→        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n   364→        // PDA derivation time, resulting in an Anchor error\n   365→        expect(err).to.be.instanceOf(Error);\n   366→      }\n   367→    });\n   368→\n   369→    it(\"rejects zero entries\", async () => {\n   370→      const t = await createTestContext();\n   371→      await initConfig(t);\n   372→\n   373→      const roundPda = getRoundPda(TIER_IRON, 0);\n   374→\n   375→      try {\n   376→        await t.creatorProgram.methods\n   377→          .createRound(TIER_IRON, new BN(0), 0)\n   378→          .accounts({\n   379→            creator: t.creator,\n   380→            config: t.configPda,\n   381→            round: roundPda,\n   382→            systemProgram: SystemProgram.programId,\n   383→          })\n   384→          .rpc();\n   385→        expect.fail(\"Expected ZeroEntries error\");\n   386→      } catch (err) {\n   387→        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n   388→      }\n   389→    });\n   390→  });\n   391→\n   392→  describe(\"join_round\", () => {\n   393→    it(\"2nd player joins and triggers countdown (Waiting → Active)\", async () => {\n   394→      const t = await createTestContext();\n   395→      await initConfig(t);\n   396→\n   397→      // Creator starts round (player 1)\n   398→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   399→\n   400→      // Player 2 joins\n   401→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   402→\n   403→      // Verify round state\n   404→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   405→      expect(round.players).to.have.length(2);\n   406→      expect(round.players[1].player.toBase58()).to.equal(t.player2.publicKey.toBase58());\n   407→      expect(round.players[1].entries).to.equal(1);\n   408→      expect(round.totalEntries).to.equal(2);\n   409→\n   410→      // Phase should be Active (countdown started)\n   411→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n   412→      expect(round.countdownEndsAt.toNumber()).to.be.greaterThan(0);\n   413→\n   414→      // Escrow should hold 2 × entry_amount\n   415→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   416→      const rent = await t.context.banksClient.getRent();\n   417→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   418→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   419→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 2);\n   420→    });\n   421→\n   422→    it(\"3rd player joins during Active phase without re-triggering countdown\", async () => {\n   423→      const t = await createTestContext();\n   424→      await initConfig(t);\n   425→\n   426→      const player3 = Keypair.generate();\n   427→      const player3Account = fundedAccountData();\n   428→      t.context.setAccount(player3.publicKey, player3Account);\n   429→      const player3Provider = new BankrunProvider(t.context, new Wallet(player3));\n   430→      const player3Program = new Program<Lordofrngs>(IDL, player3Provider);\n   431→\n   432→      // Creator starts round, player2 joins (triggers countdown)\n   433→      await createRound(t, TIER_IRON, 0, 1);\n   434→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   435→\n   436→      const roundBefore = await t.creatorProgram.account.jackpotRound.fetch(\n   437→        getRoundPda(TIER_IRON, 0)\n   438→      );\n   439→      const countdownBefore = roundBefore.countdownEndsAt.toNumber();\n   440→\n   441→      // Player 3 joins\n   442→      await joinRound(player3Program, player3.publicKey, t.configPda);\n   443→\n   444→      const round = await t.creatorProgram.account.jackpotRound.fetch(\n   445→        getRoundPda(TIER_IRON, 0)\n   446→      );\n   447→      expect(round.players).to.have.length(3);\n   448→      expect(round.totalEntries).to.equal(3);\n   449→      // Countdown should not have changed\n   450→      expect(round.countdownEndsAt.toNumber()).to.equal(countdownBefore);\n   451→    });\n   452→\n   453→    it(\"player can join with multiple entries\", async () => {\n   454→      const t = await createTestContext();\n   455→      await initConfig(t);\n   456→\n   457→      await createRound(t, TIER_IRON, 0, 1);\n   458→\n   459→      // Player 2 joins with 5 entries\n   460→      const roundPda = await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, 5);\n   461→\n   462→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   463→      expect(round.players[1].entries).to.equal(5);\n   464→      expect(round.totalEntries).to.equal(6); // 1 (creator) + 5 (player2)\n   465→\n   466→      // Escrow: 1 × amount (creator) + 5 × amount (player2)\n   467→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   468→      const rent = await t.context.banksClient.getRent();\n   469→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   470→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   471→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 6);\n   472→    });\n   473→\n   474→    it(\"rejects duplicate player\", async () => {\n   475→      const t = await createTestContext();\n   476→      await initConfig(t);\n   477→\n   478→      await createRound(t, TIER_IRON, 0, 1);\n   479→\n   480→      // Creator tries to join their own round again\n   481→      try {\n   482→        await joinRound(t.creatorProgram, t.creator, t.configPda);\n   483→        expect.fail(\"Expected PlayerAlreadyInRound error\");\n   484→      } catch (err) {\n   485→        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerAlreadyInRound\");\n   486→      }\n   487→    });\n   488→\n   489→    it(\"rejects 21st player (max 20)\", async () => {\n   490→      const t = await createTestContext();\n   491→      await initConfig(t);\n   492→\n   493→      // Creator starts round\n   494→      await createRound(t, TIER_IRON, 0, 1);\n   495→\n   496→      // Add 19 more players (total 20)\n   497→      for (let i = 0; i < 19; i++) {\n   498→        const p = Keypair.generate();\n   499→        t.context.setAccount(p.publicKey, fundedAccountData());\n   500→        const pProvider = new BankrunProvider(t.context, new Wallet(p));\n   501→        const pProgram = new Program<Lordofrngs>(IDL, pProvider);\n   502→        await joinRound(pProgram, p.publicKey, t.configPda);\n   503→      }\n   504→\n   505→      // Verify we have 20 players\n   506→      const round = await t.creatorProgram.account.jackpotRound.fetch(\n   507→        getRoundPda(TIER_IRON, 0)\n   508→      );\n   509→      expect(round.players).to.have.length(20);\n   510→\n   511→      // 21st player should be rejected\n   512→      const extra = Keypair.generate();\n   513→      t.context.setAccount(extra.publicKey, fundedAccountData());\n   514→      const extraProvider = new BankrunProvider(t.context, new Wallet(extra));\n   515→      const extraProgram = new Program<Lordofrngs>(IDL, extraProvider);\n   516→\n   517→      try {\n   518→        await joinRound(extraProgram, extra.publicKey, t.configPda);\n   519→        expect.fail(\"Expected MaxPlayersReached error\");\n   520→      } catch (err) {\n   521→        expect((err as AnchorError).error.errorCode.code).to.equal(\"MaxPlayersReached\");\n   522→      }\n   523→    });\n   524→\n   525→    it(\"rejects join when phase is Locked\", async () => {\n   526→      // We can't easily get to Locked phase without VRF, so we test that\n   527→      // only Waiting and Active phases are accepted. We'll simulate by\n   528→      // checking the phase validation works with a round that's in a state\n   529→      // we can't join.\n   530→      // For now, we verify the InvalidPhase error by checking that joining\n   531→      // a round that doesn't exist fails (Anchor account constraint).\n   532→      // The full phase rejection test will be covered in the start_spin tests.\n   533→\n   534→      // Instead, test that joining during Waiting phase (before 2nd player) works,\n   535→      // which is already covered above. The Locked phase test will be\n   536→      // in the start_spin + claim_payout iteration when we can create Locked rounds.\n   537→      // Skip for now — covered by the phase check in the instruction.\n   538→    });\n   539→  });\n   540→\n   541→  describe(\"buy_more_entries\", () => {\n   542→    it(\"existing player buys more entries (updated count + escrow)\", async () => {\n   543→      const t = await createTestContext();\n   544→      await initConfig(t);\n   545→\n   546→      // Creator starts round with 1 entry\n   547→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   548→\n   549→      // Creator buys 3 more entries\n   550→      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 3);\n   551→\n   552→      // Verify updated state\n   553→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   554→      expect(round.players).to.have.length(1);\n   555→      expect(round.players[0].entries).to.equal(4); // 1 + 3\n   556→      expect(round.totalEntries).to.equal(4);\n   557→\n   558→      // Escrow should hold 4 × entry_amount\n   559→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   560→      const rent = await t.context.banksClient.getRent();\n   561→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   562→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   563→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 4);\n   564→    });\n   565→\n   566→    it(\"works during Active phase (after countdown starts)\", async () => {\n   567→      const t = await createTestContext();\n   568→      await initConfig(t);\n   569→\n   570→      // Creator starts round, player2 joins (triggers countdown → Active)\n   571→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   572→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   573→\n   574→      // Creator buys 2 more during Active phase\n   575→      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 2);\n   576→\n   577→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   578→      expect(round.players[0].entries).to.equal(3); // 1 + 2\n   579→      expect(round.totalEntries).to.equal(4); // 3 (creator) + 1 (player2)\n   580→    });\n   581→\n   582→    it(\"rejects player not in round\", async () => {\n   583→      const t = await createTestContext();\n   584→      await initConfig(t);\n   585→\n   586→      // Creator starts round\n   587→      await createRound(t, TIER_IRON, 0, 1);\n   588→\n   589→      // Player2 (not in round) tries to buy more\n   590→      try {\n   591→        await buyMoreEntries(t.player2Program, t.player2.publicKey, t.configPda);\n   592→        expect.fail(\"Expected PlayerNotInRound error\");\n   593→      } catch (err) {\n   594→        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerNotInRound\");\n   595→      }\n   596→    });\n   597→\n   598→    it(\"rejects zero entries\", async () => {\n   599→      const t = await createTestContext();\n   600→      await initConfig(t);\n   601→\n   602→      await createRound(t, TIER_IRON, 0, 1);\n   603→\n   604→      try {\n   605→        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 0);\n   606→        expect.fail(\"Expected ZeroEntries error\");\n   607→      } catch (err) {\n   608→        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n   609→      }\n   610→    });\n   611→  });\n   612→\n   613→  describe(\"start_spin\", () => {\n   614→    it(\"transitions Active → Locked after countdown expires\", async () => {\n   615→      const t = await createTestContext();\n   616→      await initConfig(t);\n   617→\n   618→      // Creator creates round, player2 joins (triggers countdown → Active)\n   619→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   620→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   621→\n   622→      // Verify Active phase\n   623→      let round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   624→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n   625→\n   626→      // Warp past countdown\n   627→      await warpPastCountdown(t);\n   628→\n   629→      // Start spin\n   630→      await startSpin(t.creatorProgram, t.creator, t);\n   631→\n   632→      // Verify Locked phase + VRF fields set\n   633→      round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   634→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n   635→      expect(round.lockedAt.toNumber()).to.be.greaterThan(0);\n   636→      expect(round.resolveDeadline.toNumber()).to.be.greaterThan(round.lockedAt.toNumber());\n   637→      expect(round.vrfRequestKey.toBase58()).to.equal(t.mockRandomness.publicKey.toBase58());\n   638→    });\n   639→\n   640→    it(\"is idempotent (no error when already Locked)\", async () => {\n   641→      const t = await createTestContext();\n   642→      await initConfig(t);\n   643→\n   644→      await createRound(t, TIER_IRON, 0, 1);\n   645→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   646→      await warpPastCountdown(t);\n   647→\n   648→      // First spin succeeds\n   649→      await startSpin(t.creatorProgram, t.creator, t);\n   650→\n   651→      // Second spin from a different player also succeeds (idempotent no-op)\n   652→      await startSpin(t.player2Program, t.player2.publicKey, t);\n   653→\n   654→      // Still Locked\n   655→      const round = await t.creatorProgram.account.jackpotRound.fetch(\n   656→        getRoundPda(TIER_IRON, 0)\n   657→      );\n   658→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n   659→    });\n   660→\n   661→    it(\"rejects spin before countdown expires\", async () => {\n   662→      const t = await createTestContext();\n   663→      await initConfig(t);\n   664→\n   665→      await createRound(t, TIER_IRON, 0, 1);\n   666→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   667→\n   668→      // Don't warp — countdown is still running\n   669→      try {\n   670→        await startSpin(t.creatorProgram, t.creator, t);\n   671→        expect.fail(\"Expected CountdownNotExpired error\");\n   672→      } catch (err) {\n   673→        expect((err as AnchorError).error.errorCode.code).to.equal(\"CountdownNotExpired\");\n   674→      }\n   675→    });\n   676→\n   677→    it(\"rejects spin when phase is Waiting (only 1 player)\", async () => {\n   678→      const t = await createTestContext();\n   679→      await initConfig(t);\n   680→\n   681→      await createRound(t, TIER_IRON, 0, 1);\n   682→\n   683→      // Phase is Waiting — no second player joined yet\n   684→      try {\n   685→        await startSpin(t.creatorProgram, t.creator, t);\n   686→        expect.fail(\"Expected InvalidPhase error\");\n   687→      } catch (err) {\n   688→        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n   689→      }\n   690→    });\n   691→  });\n   692→});\n   693→"}]},"parent_tool_use_id":null,"session_id":"d619c696-fe84-4ada-8f1c-c53696e9582f","uuid":"2e033197-3724-40f4-94bd-12bc3b82f941","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/lordofrngs.ts","content":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { AnchorError, Program } from \"@coral-xyz/anchor\";\nimport { Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport { Clock } from \"solana-bankrun\";\nimport type { Lordofrngs } from \"../target/types/lordofrngs\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\nimport BN from \"bn.js\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\n// Tier constants (from shared crate)\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\nconst COUNTDOWN_SECONDS = 60;\n\n// Mock VRF randomness buffers (32 bytes each)\n// Unfulfilled: all zeros → is_fulfilled=false\nconst RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getRoundPda(tier: number, roundNumber: number | bigint): PublicKey {\n  const tierBuf = Buffer.from([tier]);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Test context factory\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  treasury: Keypair;\n  creatorProgram: Program<Lordofrngs>;\n  configPda: PublicKey;\n  player2: Keypair;\n  player2Program: Program<Lordofrngs>;\n  mockRandomness: Keypair;\n  mockOraoProgram: Keypair;\n  mockOraoNetworkState: Keypair;\n  mockOraoTreasury: Keypair;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const treasury = Keypair.generate();\n  const player2 = Keypair.generate();\n  const mockRandomness = Keypair.generate();\n  const mockOraoProgram = Keypair.generate();\n  const mockOraoNetworkState = Keypair.generate();\n  const mockOraoTreasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: treasury.publicKey, info: fundedAccountData() },\n    { address: player2.publicKey, info: fundedAccountData() },\n    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n    // Mock randomness account — starts unfulfilled (32 zero bytes)\n    {\n      address: mockRandomness.publicKey,\n      info: {\n        lamports: LAMPORTS_PER_SOL,\n        data: RANDOMNESS_UNFULFILLED,\n        owner: SystemProgram.programId,\n        executable: false,\n      },\n    },\n  ]);\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n\n  const player2Provider = new BankrunProvider(context, new Wallet(player2));\n  const player2Program = new Program<Lordofrngs>(IDL, player2Provider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n\n  return {\n    context,\n    creator,\n    treasury,\n    creatorProgram,\n    configPda,\n    player2,\n    player2Program,\n    mockRandomness,\n    mockOraoProgram,\n    mockOraoNetworkState,\n    mockOraoTreasury,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Clock warp helpers\n// ---------------------------------------------------------------------------\nasync function warpPastCountdown(t: TestContext) {\n  const clock = await t.context.banksClient.getClock();\n  t.context.setClock(\n    new Clock(\n      clock.slot + BigInt(200),\n      clock.epochStartTimestamp,\n      clock.epoch,\n      clock.leaderScheduleEpoch,\n      clock.unixTimestamp + BigInt(COUNTDOWN_SECONDS + 10)\n    )\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Instruction helpers\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createRound(\n  t: TestContext,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n  creator?: PublicKey,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await t.creatorProgram.methods\n    .createRound(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      creator: creator ?? t.creator,\n      config: t.configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\nasync function joinRound(\n  program: Program<Lordofrngs>,\n  player: PublicKey,\n  configPda: PublicKey,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .joinRound(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\nasync function buyMoreEntries(\n  program: Program<Lordofrngs>,\n  player: PublicKey,\n  configPda: PublicKey,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .buyMoreEntries(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\nasync function startSpin(\n  program: Program<Lordofrngs>,\n  caller: PublicKey,\n  t: TestContext,\n  tier = TIER_IRON,\n  roundNumber = 0,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .startSpin(tier, new BN(roundNumber))\n    .accounts({\n      caller,\n      config: t.configPda,\n      round: roundPda,\n      oraoProgram: t.mockOraoProgram.publicKey,\n      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n      oraoTreasury: t.mockOraoTreasury.publicKey,\n      oraoRandom: t.mockRandomness.publicKey,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\ndescribe(\"lordofrngs\", () => {\n  describe(\"initialize_config\", () => {\n    it(\"creates config with treasury and paused=false\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.lordConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n      expect(config.paused).to.equal(false);\n      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n    });\n  });\n\n  describe(\"create_round\", () => {\n    it(\"creates round with correct PDA data and escrow balance\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Verify round state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.tier).to.equal(TIER_IRON);\n      expect(round.roundNumber.toNumber()).to.equal(0);\n      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n      expect(round.players).to.have.length(1);\n      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.players[0].entries).to.equal(1);\n      expect(round.totalEntries).to.equal(1);\n      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n      expect(round.lockedAt.toNumber()).to.equal(0);\n      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.claimed).to.equal(false);\n\n      // Verify escrow balance: account holds rent + entry amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n\n      // Verify config round counter incremented\n      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n    });\n\n    it(\"creates round with multiple entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const numEntries = 5;\n      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[0].entries).to.equal(numEntries);\n      expect(round.totalEntries).to.equal(numEntries);\n\n      // Escrow should hold numEntries × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n    });\n\n    it(\"increments round counter per tier\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Create first round (round 0)\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Config counter should be 1\n      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n\n      // Create second round (round 1) — need a new PDA\n      await createRound(t, TIER_IRON, 1, 1);\n\n      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n    });\n\n    it(\"rejects invalid tier (tier 6)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const invalidTier = 6;\n      const roundPda = getRoundPda(invalidTier, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(invalidTier, new BN(0), 1)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n        // PDA derivation time, resulting in an Anchor error\n        expect(err).to.be.instanceOf(Error);\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = getRoundPda(TIER_IRON, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(TIER_IRON, new BN(0), 0)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n\n  describe(\"join_round\", () => {\n    it(\"2nd player joins and triggers countdown (Waiting → Active)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round (player 1)\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Player 2 joins\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Verify round state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players).to.have.length(2);\n      expect(round.players[1].player.toBase58()).to.equal(t.player2.publicKey.toBase58());\n      expect(round.players[1].entries).to.equal(1);\n      expect(round.totalEntries).to.equal(2);\n\n      // Phase should be Active (countdown started)\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n      expect(round.countdownEndsAt.toNumber()).to.be.greaterThan(0);\n\n      // Escrow should hold 2 × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 2);\n    });\n\n    it(\"3rd player joins during Active phase without re-triggering countdown\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const player3 = Keypair.generate();\n      const player3Account = fundedAccountData();\n      t.context.setAccount(player3.publicKey, player3Account);\n      const player3Provider = new BankrunProvider(t.context, new Wallet(player3));\n      const player3Program = new Program<Lordofrngs>(IDL, player3Provider);\n\n      // Creator starts round, player2 joins (triggers countdown)\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      const roundBefore = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      const countdownBefore = roundBefore.countdownEndsAt.toNumber();\n\n      // Player 3 joins\n      await joinRound(player3Program, player3.publicKey, t.configPda);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(round.players).to.have.length(3);\n      expect(round.totalEntries).to.equal(3);\n      // Countdown should not have changed\n      expect(round.countdownEndsAt.toNumber()).to.equal(countdownBefore);\n    });\n\n    it(\"player can join with multiple entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Player 2 joins with 5 entries\n      const roundPda = await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, 5);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[1].entries).to.equal(5);\n      expect(round.totalEntries).to.equal(6); // 1 (creator) + 5 (player2)\n\n      // Escrow: 1 × amount (creator) + 5 × amount (player2)\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 6);\n    });\n\n    it(\"rejects duplicate player\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Creator tries to join their own round again\n      try {\n        await joinRound(t.creatorProgram, t.creator, t.configPda);\n        expect.fail(\"Expected PlayerAlreadyInRound error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerAlreadyInRound\");\n      }\n    });\n\n    it(\"rejects 21st player (max 20)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Add 19 more players (total 20)\n      for (let i = 0; i < 19; i++) {\n        const p = Keypair.generate();\n        t.context.setAccount(p.publicKey, fundedAccountData());\n        const pProvider = new BankrunProvider(t.context, new Wallet(p));\n        const pProgram = new Program<Lordofrngs>(IDL, pProvider);\n        await joinRound(pProgram, p.publicKey, t.configPda);\n      }\n\n      // Verify we have 20 players\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(round.players).to.have.length(20);\n\n      // 21st player should be rejected\n      const extra = Keypair.generate();\n      t.context.setAccount(extra.publicKey, fundedAccountData());\n      const extraProvider = new BankrunProvider(t.context, new Wallet(extra));\n      const extraProgram = new Program<Lordofrngs>(IDL, extraProvider);\n\n      try {\n        await joinRound(extraProgram, extra.publicKey, t.configPda);\n        expect.fail(\"Expected MaxPlayersReached error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"MaxPlayersReached\");\n      }\n    });\n\n    it(\"rejects join when phase is Locked\", async () => {\n      // We can't easily get to Locked phase without VRF, so we test that\n      // only Waiting and Active phases are accepted. We'll simulate by\n      // checking the phase validation works with a round that's in a state\n      // we can't join.\n      // For now, we verify the InvalidPhase error by checking that joining\n      // a round that doesn't exist fails (Anchor account constraint).\n      // The full phase rejection test will be covered in the start_spin tests.\n\n      // Instead, test that joining during Waiting phase (before 2nd player) works,\n      // which is already covered above. The Locked phase test will be\n      // in the start_spin + claim_payout iteration when we can create Locked rounds.\n      // Skip for now — covered by the phase check in the instruction.\n    });\n  });\n\n  describe(\"buy_more_entries\", () => {\n    it(\"existing player buys more entries (updated count + escrow)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round with 1 entry\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Creator buys 3 more entries\n      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 3);\n\n      // Verify updated state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players).to.have.length(1);\n      expect(round.players[0].entries).to.equal(4); // 1 + 3\n      expect(round.totalEntries).to.equal(4);\n\n      // Escrow should hold 4 × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 4);\n    });\n\n    it(\"works during Active phase (after countdown starts)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round, player2 joins (triggers countdown → Active)\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Creator buys 2 more during Active phase\n      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 2);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[0].entries).to.equal(3); // 1 + 2\n      expect(round.totalEntries).to.equal(4); // 3 (creator) + 1 (player2)\n    });\n\n    it(\"rejects player not in round\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Player2 (not in round) tries to buy more\n      try {\n        await buyMoreEntries(t.player2Program, t.player2.publicKey, t.configPda);\n        expect.fail(\"Expected PlayerNotInRound error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerNotInRound\");\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      try {\n        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 0);\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n\n  describe(\"start_spin\", () => {\n    it(\"transitions Active → Locked after countdown expires\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator creates round, player2 joins (triggers countdown → Active)\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Verify Active phase\n      let round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n\n      // Warp past countdown\n      await warpPastCountdown(t);\n\n      // Start spin\n      await startSpin(t.creatorProgram, t.creator, t);\n\n      // Verify Locked phase + VRF fields set\n      round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n      expect(round.lockedAt.toNumber()).to.be.greaterThan(0);\n      expect(round.resolveDeadline.toNumber()).to.be.greaterThan(round.lockedAt.toNumber());\n      expect(round.vrfRequestKey.toBase58()).to.equal(t.mockRandomness.publicKey.toBase58());\n    });\n\n    it(\"is idempotent (no error when already Locked)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n      await warpPastCountdown(t);\n\n      // First spin succeeds\n      await startSpin(t.creatorProgram, t.creator, t);\n\n      // Second spin from a different player also succeeds (idempotent no-op)\n      await startSpin(t.player2Program, t.player2.publicKey, t);\n\n      // Still Locked\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n    });\n\n    it(\"rejects spin before countdown expires\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Don't warp — countdown is still running\n      try {\n        await startSpin(t.creatorProgram, t.creator, t);\n        expect.fail(\"Expected CountdownNotExpired error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"CountdownNotExpired\");\n      }\n    });\n\n    it(\"rejects spin when phase is Waiting (only 1 player)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Phase is Waiting — no second player joined yet\n      try {\n        await startSpin(t.creatorProgram, t.creator, t);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n      }\n    });\n  });\n});\n","numLines":693,"startLine":1,"totalLines":693}}}
