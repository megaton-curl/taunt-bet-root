{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015zGAy9iyFf99numEGJPooW","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::lifecycle::{self, RoundPhase};\n     3→use rng_shared::timeout::DEFAULT_RESOLVE_TIMEOUT_SECONDS;\n     4→use rng_shared::vrf_orao;\n     5→\n     6→use crate::error::LordError;\n     7→use crate::state::{JackpotRound, LordConfig};\n     8→\n     9→/// Permissionless, idempotent instruction to trigger the wheel spin.\n    10→/// Any player can call this after the countdown has expired.\n    11→/// Transitions phase Active → Locked and requests Orao VRF.\n    12→/// If phase is already Locked, returns Ok (idempotent no-op).\n    13→#[derive(Accounts)]\n    14→#[instruction(tier: u8, round_number: u64)]\n    15→pub struct StartSpin<'info> {\n    16→    /// The caller (any player can trigger the spin).\n    17→    #[account(mut)]\n    18→    pub caller: Signer<'info>,\n    19→\n    20→    /// The config PDA (read-only, for pause check).\n    21→    #[account(\n    22→        seeds = [b\"lord_config\"],\n    23→        bump = config.bump,\n    24→    )]\n    25→    pub config: Account<'info, LordConfig>,\n    26→\n    27→    /// The round PDA to spin.\n    28→    #[account(\n    29→        mut,\n    30→        seeds = [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()],\n    31→        bump = round.bump,\n    32→    )]\n    33→    pub round: Account<'info, JackpotRound>,\n    34→\n    35→    /// Orao VRF program.\n    36→    /// CHECK: Validated by Orao VRF CPI internally.\n    37→    pub orao_program: UncheckedAccount<'info>,\n    38→\n    39→    /// Orao network state PDA.\n    40→    /// CHECK: Validated by Orao VRF CPI internally.\n    41→    #[account(mut)]\n    42→    pub orao_network_state: UncheckedAccount<'info>,\n    43→\n    44→    /// Orao treasury for VRF fee payment.\n    45→    /// CHECK: Validated by Orao VRF CPI internally.\n    46→    #[account(mut)]\n    47→    pub orao_treasury: UncheckedAccount<'info>,\n    48→\n    49→    /// Orao randomness account (created by Orao CPI).\n    50→    /// CHECK: Orao VRF CPI validates and initializes this account.\n    51→    #[account(mut)]\n    52→    pub orao_random: UncheckedAccount<'info>,\n    53→\n    54→    pub system_program: Program<'info, System>,\n    55→}\n    56→\n    57→pub fn handler(ctx: Context<StartSpin>, _tier: u8, _round_number: u64) -> Result<()> {\n    58→    let round = &ctx.accounts.round;\n    59→\n    60→    // Idempotent: if already Locked (or beyond), silently succeed\n    61→    if round.phase != RoundPhase::Active {\n    62→        if round.phase == RoundPhase::Locked {\n    63→            return Ok(());\n    64→        }\n    65→        // Any other non-Active phase is invalid\n    66→        return Err(LordError::InvalidPhase.into());\n    67→    }\n    68→\n    69→    // Validate countdown has expired\n    70→    let now = Clock::get()?.unix_timestamp;\n    71→    require!(\n    72→        now >= round.countdown_ends_at,\n    73→        LordError::CountdownNotExpired\n    74→    );\n    75→\n    76→    // Validate Active → Locked transition via shared lifecycle\n    77→    lifecycle::transition(round.phase, RoundPhase::Locked)?;\n    78→\n    79→    // Request Orao VRF — use round PDA key as unique seed\n    80→    let seed: [u8; 32] = ctx.accounts.round.key().to_bytes();\n    81→    vrf_orao::request_orao_randomness(\n    82→        &ctx.accounts.orao_program.to_account_info(),\n    83→        &ctx.accounts.orao_network_state.to_account_info(),\n    84→        &ctx.accounts.orao_treasury.to_account_info(),\n    85→        &ctx.accounts.orao_random.to_account_info(),\n    86→        &ctx.accounts.caller.to_account_info(),\n    87→        &ctx.accounts.system_program.to_account_info(),\n    88→        seed,\n    89→    )?;\n    90→\n    91→    // Update round state\n    92→    let round = &mut ctx.accounts.round;\n    93→    round.phase = RoundPhase::Locked;\n    94→    round.locked_at = now;\n    95→    round.resolve_deadline = now + DEFAULT_RESOLVE_TIMEOUT_SECONDS;\n    96→    round.vrf_request_key = ctx.accounts.orao_random.key();\n    97→\n    98→    Ok(())\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_01Rmsqwovx163Ps7JM4tbBU1","session_id":"d619c696-fe84-4ada-8f1c-c53696e9582f","uuid":"ce91b199-38d0-4700-914a-1b33ff296522"}
