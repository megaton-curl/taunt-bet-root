rs Vec. Each receives their entry refund.\n    44→}\n    45→\n    46→pub fn handler<'info>(\n    47→    ctx: Context<'_, '_, 'info, 'info, TimeoutRefund<'info>>,\n    48→    _tier: u8,\n    49→    _round_number: u64,\n    50→) -> Result<()> {\n    51→    let round = &ctx.accounts.round;\n    52→\n    53→    // (1) Must be in LOCKED phase\n    54→    require!(\n    55→        round.phase == RoundPhase::Locked,\n    56→        LordError::InvalidPhase\n    57→    );\n    58→\n    59→    // (2) Validate accounts match stored state\n    60→    require_keys_eq!(ctx.accounts.round_creator.key(), round.creator);\n    61→    require_keys_eq!(\n    62→        ctx.accounts.randomness_account.key(),\n    63→        round.vrf_request_key\n    64→    );\n    65→\n    66→    // (3) Check timeout has elapsed\n    67→    let now = Clock::get()?.unix_timestamp;\n    68→    require!(\n    69→        is_expired(round.resolve_deadline, now),\n    70→        LordError::LockTimeoutNotElapsed\n    71→    );\n    72→\n    73→    // (4) Check that VRF randomness is NOT fulfilled — if fulfilled, must use claim_payout\n    74→    let vrf_is_fulfilled = read_orao_randomness(&ctx.accounts.randomness_account)\n    75→        .map(|r| is_fulfilled(&r))\n    76→        .unwrap_or(false);\n    77→    require!(!vrf_is_fulfilled, LordError::VrfAlreadyFulfilled);\n    78→\n    79→    // (5) Refund all players their entry amounts\n    80→    let remaining = ctx.remaining_accounts;\n    81→    let players = &round.players;\n    82→    require!(\n    83→        remaining.len() == players.len(),\n    84→        LordError::InvalidPhase // wrong number of remaining accounts\n    85→    );\n    86→\n    87→    let entry_amount = round.entry_amount;\n    88→    let round_info = ctx.accounts.round.to_account_info();\n    89→\n    90→    for (i, player_entry) in players.iter().enumerate() {\n    91→        let player_account = &remaining[i];\n    92→        // Validate each remaining account matches the player in the Vec\n    93→        require_keys_eq!(player_account.key(), player_entry.player);\n    94→\n    95→        let refund = entry_amount\n    96→            .checked_mul(player_entry.entries as u64)\n    97→            .ok_or(LordError::ArithmeticOverflow)?;\n    98→        transfer_lamports_from_pda(&round_info, player_account, refund)?;\n    99→    }\n   100→\n   101→    // (6) Transition to Refunded\n   102→    lifecycle::transition(round.phase, RoundPhase::Refunded)?;\n   103→    let round = &mut ctx.accounts.round;\n   104→    round.phase = RoundPhase::Refunded;\n   105→\n   106→    // Account is closed by Anchor's `close = round_creator` constraint.\n   107→    Ok(())\n   108→}\n   109→"}]},"parent_tool_use_id":null,"session_id":"d3bf4c03-8136-45c3-a2a1-9d51b20ea4ea","uuid":"26f548ba-0811-4cf9-9f77-ee1ee31f5159","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/lordofrngs/src/instructions/timeout_refund.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_from_pda;\nuse rng_shared::lifecycle::{self, RoundPhase};\nuse rng_shared::timeout::is_expired;\nuse rng_shared::vrf_orao::{is_fulfilled, read_orao_randomness};\n\nuse crate::error::LordError;\nuse crate::state::{JackpotRound, LordConfig};\n\n#[derive(Accounts)]\n#[instruction(tier: u8, round_number: u64)]\npub struct TimeoutRefund<'info> {\n    /// Any signer can trigger a timeout refund (permissionless after deadline).\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The round PDA (closed after refunds — rent goes to round creator).\n    #[account(\n        mut,\n        close = round_creator,\n        seeds = [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()],\n        bump = round.bump,\n    )]\n    pub round: Account<'info, JackpotRound>,\n\n    /// The config PDA (for validation only).\n    #[account(\n        seeds = [b\"lord_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, LordConfig>,\n\n    /// The round creator account (receives rent refund on close).\n    /// CHECK: Validated against round.creator in handler.\n    #[account(mut)]\n    pub round_creator: AccountInfo<'info>,\n\n    /// The Orao randomness PDA — used to check VRF is NOT fulfilled.\n    /// CHECK: Key validated against round.vrf_request_key; data read by shared VRF helper.\n    pub randomness_account: AccountInfo<'info>,\n\n    /// Remaining accounts: one mutable AccountInfo per player in round.players[],\n    /// in the same order as the players Vec. Each receives their entry refund.\n}\n\npub fn handler<'info>(\n    ctx: Context<'_, '_, 'info, 'info, TimeoutRefund<'info>>,\n    _tier: u8,\n    _round_number: u64,\n) -> Result<()> {\n    let round = &ctx.accounts.round;\n\n    // (1) Must be in LOCKED phase\n    require!(\n        round.phase == RoundPhase::Locked,\n        LordError::InvalidPhase\n    );\n\n    // (2) Validate accounts match stored state\n    require_keys_eq!(ctx.accounts.round_creator.key(), round.creator);\n    require_keys_eq!(\n        ctx.accounts.randomness_account.key(),\n        round.vrf_request_key\n    );\n\n    // (3) Check timeout has elapsed\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        is_expired(round.resolve_deadline, now),\n        LordError::LockTimeoutNotElapsed\n    );\n\n    // (4) Check that VRF randomness is NOT fulfilled — if fulfilled, must use claim_payout\n    let vrf_is_fulfilled = read_orao_randomness(&ctx.accounts.randomness_account)\n        .map(|r| is_fulfilled(&r))\n        .unwrap_or(false);\n    require!(!vrf_is_fulfilled, LordError::VrfAlreadyFulfilled);\n\n    // (5) Refund all players their entry amounts\n    let remaining = ctx.remaining_accounts;\n    let players = &round.players;\n    require!(\n        remaining.len() == players.len(),\n        LordError::InvalidPhase // wrong number of remaining accounts\n    );\n\n    let entry_amount = round.entry_amount;\n    let round_info = ctx.accounts.round.to_account_info();\n\n    for (i, player_entry) in players.iter().enumerate() {\n        let player_account = &remaining[i];\n        // Validate each remaining account matches the player in the Vec\n        require_keys_eq!(player_account.key(), player_entry.player);\n\n        let refund = entry_amount\n            .checked_mul(player_entry.entries as u64)\n            .ok_or(LordError::ArithmeticOverflow)?;\n        transfer_lamports_from_pda(&round_info, player_account, refund)?;\n    }\n\n    // (6) Transition to Refunded\n    lifecycle::transition(round.phase, RoundPhase::Refunded)?;\n    let round = &mut ctx.accounts.round;\n    round.phase = RoundPhase::Refunded;\n\n    // Account is closed by Anchor's `close = round_creator` constraint.\n    Ok(())\n}\n","numLines":109,"startLine":1,"totalLines":109}}}
