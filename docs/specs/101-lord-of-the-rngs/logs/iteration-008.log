\n    /// Remaining accounts: one mutable AccountInfo per player in round.players[],\n    /// in the same order as the players Vec. Each receives their entry refund.\n}\n\npub fn handler<'info>(\n    ctx: Context<'_, '_, 'info, 'info, TimeoutRefund<'info>>,\n    _tier: u8,\n    _round_number: u64,\n) -> Result<()> {\n    let round = &ctx.accounts.round;\n\n    // (1) Must be in LOCKED phase\n    require!(\n        round.phase == RoundPhase::Locked,\n        LordError::InvalidPhase\n    );\n\n    // (2) Validate accounts match stored state\n    require_keys_eq!(ctx.accounts.round_creator.key(), round.creator);\n    require_keys_eq!(\n        ctx.accounts.randomness_account.key(),\n        round.vrf_request_key\n    );\n\n    // (3) Check timeout has elapsed\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        is_expired(round.resolve_deadline, now),\n        LordError::LockTimeoutNotElapsed\n    );\n\n    // (4) Check that VRF randomness is NOT fulfilled — if fulfilled, must use claim_payout\n    let vrf_is_fulfilled = read_orao_randomness(&ctx.accounts.randomness_account)\n        .map(|r| is_fulfilled(&r))\n        .unwrap_or(false);\n    require!(!vrf_is_fulfilled, LordError::VrfAlreadyFulfilled);\n\n    // (5) Refund all players their entry amounts\n    let remaining = ctx.remaining_accounts;\n    let players = &round.players;\n    require!(\n        remaining.len() == players.len(),\n        LordError::InvalidPhase // wrong number of remaining accounts\n    );\n\n    let entry_amount = round.entry_amount;\n    let round_info = ctx.accounts.round.to_account_info();\n\n    for (i, player_entry) in players.iter().enumerate() {\n        let player_account = &remaining[i];\n        // Validate each remaining account matches the player in the Vec\n        require_keys_eq!(player_account.key(), player_entry.player);\n\n        let refund = entry_amount\n            .checked_mul(player_entry.entries as u64)\n            .ok_or(LordError::ArithmeticOverflow)?;\n        transfer_lamports_from_pda(&round_info, player_account, refund)?;\n    }\n\n    // (6) Transition to Refunded\n    lifecycle::transition(round.phase, RoundPhase::Refunded)?;\n    let round = &mut ctx.accounts.round;\n    round.phase = RoundPhase::Refunded;\n\n    // Account is closed by Anchor's `close = round_creator` constraint.\n    Ok(())\n}\n","structuredPatch":[],"originalFile":null}}
