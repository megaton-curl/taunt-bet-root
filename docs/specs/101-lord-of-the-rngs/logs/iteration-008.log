{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S7ZJaUCfwytm1SsqV2mFbA","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→pub mod error;\n     4→pub mod instructions;\n     5→pub mod state;\n     6→\n     7→use instructions::*;\n     8→\n     9→declare_id!(\"B9Lufh9GvuucDxDRZBr3qPNe4cJaS5MQBQKZxgUT5qYa\");\n    10→\n    11→#[program]\n    12→pub mod lordofrngs {\n    13→    use super::*;\n    14→\n    15→    pub fn initialize_config(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n    16→        instructions::initialize_config::handler(ctx, treasury)\n    17→    }\n    18→\n    19→    pub fn create_round(ctx: Context<CreateRound>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n    20→        instructions::create_round::handler(ctx, tier, round_number, num_entries)\n    21→    }\n    22→\n    23→    pub fn join_round(ctx: Context<JoinRound>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n    24→        instructions::join_round::handler(ctx, tier, round_number, num_entries)\n    25→    }\n    26→\n    27→    pub fn buy_more_entries(ctx: Context<BuyMoreEntries>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n    28→        instructions::buy_more_entries::handler(ctx, tier, round_number, num_entries)\n    29→    }\n    30→\n    31→    pub fn start_spin(ctx: Context<StartSpin>, tier: u8, round_number: u64) -> Result<()> {\n    32→        instructions::start_spin::handler(ctx, tier, round_number)\n    33→    }\n    34→\n    35→    pub fn claim_payout(ctx: Context<ClaimPayout>, tier: u8, round_number: u64) -> Result<()> {\n    36→        instructions::claim_payout::handler(ctx, tier, round_number)\n    37→    }\n    38→}\n    39→"}]},"parent_tool_use_id":"toolu_01PNHGwHpC2X1umxrw3xbve2","session_id":"d3bf4c03-8136-45c3-a2a1-9d51b20ea4ea","uuid":"6da27f8f-fabf-4456-ad21-66fd30cc7eb9"}
