rt type { Coinflip } from \"../target/types/coinflip\";\nimport type { Platform } from \"../target/types/platform\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\nconst PLATFORM_IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n);\nconst PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n\n// ---------------------------------------------------------------------------\n// Constants matching shared crate\n// ---------------------------------------------------------------------------\nconst SIDE_HEADS = 0;\nconst SIDE_TAILS = 1;\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL in lamports\nconst TOTAL_FEE_BPS = 300;\nconst DEFAULT_RESOLVE_TIMEOUT = 120; // seconds\n\n// Mock VRF randomness buffers (32 bytes each)\n// HEADS: byte[0]=2 → 2%2=0=HEADS, non-zero so is_fulfilled=true\nconst RANDOMNESS_HEADS = (() => {\n  const buf = Buffer.alloc(32);\n  buf[0] = 2;\n  return buf;\n})();\n// TAILS: byte[0]=1 → 1%2=1=TAILS, non-zero so is_fulfilled=true\nconst RANDOMNESS_TAILS = (() => {\n  const buf = Buffer.alloc(32);\n  buf[0] = 1;\n  return buf;\n})();\n// Unfulfilled: all zeros → is_fulfilled=false\nconst RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getMatchPda(creator: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlatformConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlayerProfilePda(wallet: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Test context factory\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  opponent: Keypair;\n  treasury: Keypair;\n  mockRandomness: Keypair;\n  mockOraoProgram: Keypair;\n  mockOraoNetworkState: Keypair;\n  mockOraoTreasury: Keypair;\n  creatorProgram: Program<Coinflip>;\n  opponentProgram: Program<Coinflip>;\n  platformProgram: Program<Platform>;\n  opponentPlatformProgram: Program<Platform>;\n  configPda: PublicKey;\n  matchPda: PublicKey;\n  platformConfigPda: PublicKey;\n  creatorProfilePda: PublicKey;\n  opponentProfilePda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const opponent = Keypair.generate();\n  const treasury = Keypair.generate();\n  const mockRandomness = Keypair.generate();\n  const mockOraoProgram = Keypair.generate();\n  const mockOraoNetworkState = Keypair.generate();\n  const mockOraoTreasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: opponent.publicKey, info: fundedAccountData() },\n    { address: treasury.publicKey, info: fundedAccountData() },\n    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n    // Mock randomness account — starts unfulfilled (32 zero bytes)\n    {\n      address: mockRandomness.publicKey,\n      info: {\n        lamports: LAMPORTS_PER_SOL,\n        data: RANDOMNESS_UNFULFILLED,\n        owner: SystemProgram.programId,\n        executable: false,\n      },\n    },\n  ]);\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n\n  const opponentProvider = new BankrunProvider(context, new Wallet(opponent));\n  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n\n  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n  const opponentPlatformProgram = new Program<Platform>(\n    PLATFORM_IDL,\n    opponentProvider\n  );\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n  const matchPda = getMatchPda(creator);\n  const platformConfigPda = getPlatformConfigPda();\n  const creatorProfilePda = getPlayerProfilePda(creator);\n  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n\n  return {\n    context,\n    creator,\n    opponent,\n    treasury,\n    mockRandomness,\n    mockOraoProgram,\n    mockOraoNetworkState,\n    mockOraoTreasury,\n    creatorProgram,\n    opponentProgram,","numLines":180,"startLine":1,"totalLines":1011}}}
