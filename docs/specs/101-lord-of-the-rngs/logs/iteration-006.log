count(mut)]\n    pub opponent: Signer<'info>,\n\n    /// The match PDA to join.\n    #[account(\n        mut,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA.\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// Orao VRF program.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    pub orao_program: UncheckedAccount<'info>,\n\n    /// Orao network state PDA.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_network_state: UncheckedAccount<'info>,\n\n    /// Orao treasury for VRF fee payment.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_treasury: UncheckedAccount<'info>,\n\n    /// Orao randomness account (created by Orao CPI).\n    /// CHECK: Orao VRF CPI validates and initializes this account.\n    #[account(mut)]\n    pub orao_random: UncheckedAccount<'info>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<JoinMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Validate Waiting → Locked transition via shared lifecycle\n    lifecycle::transition(coinflip_match.phase, RoundPhase::Locked)?;\n\n    // Opponent cannot be the creator\n    require!(\n        ctx.accounts.opponent.key() != coinflip_match.creator,\n        CoinflipError::CannotJoinOwnMatch\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n    let opponent_key = ctx.accounts.opponent.key();\n\n    // Transfer entry_amount from opponent to match PDA (escrow) via shared helper\n    transfer_lamports_to_pda(\n        &ctx.accounts.opponent.to_account_info(),\n        &ctx.accounts.coinflip_match.to_account_info(),\n        entry_amount,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    // Request Orao VRF — use match PDA key as unique seed\n    let seed: [u8; 32] = ctx.accounts.coinflip_match.key().to_bytes();\n    vrf_orao::request_orao_randomness(\n        &ctx.accounts.orao_program.to_account_info(),\n        &ctx.accounts.orao_network_state.to_account_info(),\n        &ctx.accounts.orao_treasury.to_account_info(),\n        &ctx.accounts.orao_random.to_account_info(),\n        &ctx.accounts.opponent.to_account_info(),\n        &ctx.accounts.system_program.to_account_info(),\n        seed,\n    )?;\n\n    // Update match state\n    let now = Clock::get()?.unix_timestamp;\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.opponent = opponent_key;\n    coinflip_match.phase = RoundPhase::Locked;\n    coinflip_match.locked_at = now;\n    coinflip_match.resolve_deadline = now + DEFAULT_RESOLVE_TIMEOUT_SECONDS;\n    coinflip_match.vrf_request_key = ctx.accounts.orao_random.key();\n\n    Ok(())\n}\n```\n\n---\n\n## 2. `/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/vrf_orao.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\n/// Audit fields stored on match/round accounts for VRF traceability.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, InitSpace)]\npub struct VrfAuditFields {\n    /// Address of the Orao randomness PDA for this match/round.\n    pub vrf_request_key: Pubkey,\n    /// Unix timestamp when VRF was requested.\n    pub vrf_requested_at: i64,\n}\n\n/// Error codes for VRF operations.\n#[error_code]\npub enum VrfError {\n    /// Randomness has not been fulfilled by the VRF oracle.\n    #[msg(\"VRF randomness not yet fulfilled\")]\n    RandomnessNotFulfilled,\n}\n\n/// Returns true if the 32-byte randomness is non-zero (i.e., fulfilled).\npub fn is_fulfilled(randomness: &[u8; 32]) -> bool {\n    randomness.iter().any(|&b| b != 0)\n}\n\n// ---------------------------------------------------------------------------\n// Real Orao mode — CPI into Orao VRF program\n// ---------------------------------------------------------------------------\n\n/// CPI into Orao VRF to request randomness.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn request_orao_randomness<'info>(\n    orao_program: &AccountInfo<'info>,\n    network_state: &AccountInfo<'info>,\n    treasury: &AccountInfo<'info>,\n    random: &AccountInfo<'info>,\n    payer: &AccountInfo<'info>,\n    system_program: &AccountInfo<'info>,\n    seed: [u8; 32],\n) -> Result<()> {\n    let cpi_accounts = orao_solana_vrf::cpi::accounts::RequestV2 {\n        payer: payer.clone(),\n        network_state: network_state.clone(),\n        treasury: treasury.clone(),\n        request: random.clone(),\n        system_program: system_program.clone(),\n    };\n    let cpi_ctx = CpiContext::new(orao_program.clone(), cpi_accounts);\n    orao_solana_vrf::cpi::request_v2(cpi_ctx, seed)\n}\n\n/// Read fulfilled randomness from an Orao randomness account.\n///\n/// Deserializes the Orao `RandomnessAccountData` (supports both V1 and V2\n/// accounts) and returns the first 32 bytes of the 64-byte randomness.\n/// Returns an error if randomness has not been fulfilled yet.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    use anchor_lang::AccountDeserialize;\n\n    let data = randomness_account.try_borrow_data()?;\n    let mut buf: &[u8] = &data;\n    let account_data =\n        orao_solana_vrf::state::RandomnessAccountData::try_deserialize_unchecked(&mut buf)?;\n\n    match account_data.fulfilled_randomness() {\n        Some(randomness_64) => {\n            let mut result = [0u8; 32];\n            result.copy_from_slice(&randomness_64[..32]);\n            Ok(result)\n        }\n        None => Err(error!(VrfError::RandomnessNotFulfilled)),\n    }\n}\n\n// ---------------------------------------------------------------------------\n// Mock VRF mode — no Orao CPI, reads raw bytes from test account\n// ---------------------------------------------------------------------------\n\n/// No-op in mock mode. Test authority writes mock randomness directly.\n#[cfg(feature = \"mock-vrf\")]\npub fn request_orao_randomness<'info>(\n    _orao_program: &AccountInfo<'info>,\n    _network_state: &AccountInfo<'info>,\n    _treasury: &AccountInfo<'info>,\n    _random: &AccountInfo<'info>,\n    _payer: &AccountInfo<'info>,\n    _system_program: &AccountInfo<'info>,\n    _seed: [u8; 32],\n) -> Result<()> {\n    Ok(())\n}\n\n/// In mock mode, reads raw 32 bytes from account data as randomness.\n/// All-zeros = unfulfilled (returns error).\n#[cfg(feature = \"mock-vrf\")]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    let data = randomness_account.try_borrow_data()?;\n    require!(data.len() >= 32, VrfError::RandomnessNotFulfilled);\n\n    let mut randomness = [0u8; 32];\n    randomness.copy_from_slice(&data[..32]);\n\n    require!(is_fulfilled(&randomness), VrfError::RandomnessNotFulfilled);\n    Ok(randomness)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_is_fulfilled_all_zeros() {\n        let zeros = [0u8; 32];\n        assert!(!is_fulfilled(&zeros));\n    }\n\n    #[test]\n    fn test_is_fulfilled_non_zero() {\n        let mut data = [0u8; 32];\n        data[0] = 1;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_is_fulfilled_all_ones() {\n        let ones = [0xFF; 32];\n        assert!(is_fulfilled(&ones));\n    }\n\n    #[test]\n    fn test_is_fulfilled_single_byte_set() {\n        let mut data = [0u8; 32];\n        data[31] = 42;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_vrf_audit_fields_size() {\n        // Pubkey (32) + i64 (8) = 40 bytes\n        assert_eq!(<VrfAuditFields as anchor_lang::Space>::INIT_SPACE, 40);\n    }\n}\n```\n\n---\n\n## 3. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/lordofrngs/src/lib.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\npub mod error;\npub mod instructions;\npub mod state;\n\nuse instructions::*;\n\ndeclare_id!(\"B9Lufh9GvuucDxDRZBr3qPNe4cJaS5MQBQKZxgUT5qYa\");\n\n#[program]\npub mod lordofrngs {\n    use super::*;\n\n    pub fn initialize_config(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n        instructions::initialize_config::handler(ctx, treasury)\n    }\n\n    pub fn create_round(ctx: Context<CreateRound>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n        instructions::create_round::handler(ctx, tier, round_number, num_entries)\n    }\n\n    pub fn join_round(ctx: Context<JoinRound>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n        instructions::join_round::handler(ctx, tier, round_number, num_entries)\n    }\n\n    pub fn buy_more_entries(ctx: Context<BuyMoreEntries>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n        instructions::buy_more_entries::handler(ctx, tier, round_number, num_entries)\n    }\n}\n```\n\n---\n\n## 4. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/lordofrngs/src/state.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::lifecycle::RoundPhase;\n\n/// Maximum number of players per round.\npub const MAX_PLAYERS: usize = 20;\n\n/// Global configuration for the Lord of the RNGs program.\n/// PDA seeds: [b\"lord_config\"]\n#[account]\n#[derive(InitSpace)]\npub struct LordConfig {\n    /// Admin authority (can update config).\n    pub authority: Pubkey,\n    /// Fee destination wallet.\n    pub treasury: Pubkey,\n    /// Whether the game is paused (rejects new rounds).\n    pub paused: bool,\n    /// Monotonically increasing round counter per tier.\n    /// Index corresponds to tier (0–5).\n    pub round_counters: [u64; 6],\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// A single player's entry in a jackpot round.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug, InitSpace)]\npub struct PlayerEntry {\n    /// Player's wallet address.\n    pub player: Pubkey,\n    /// Number of entries purchased (each entry = one slot on the wheel).\n    pub entries: u32,\n}\n\n/// A jackpot round for a specific tier.\n/// PDA seeds: [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()]\n#[account]\n#[derive(InitSpace)]\npub struct JackpotRound {\n    /// Tier index (0–5).\n    pub tier: u8,\n    /// Round number within this tier.\n    pub round_number: u64,\n    /// Entry amount in lamports (derived from tier).\n    pub entry_amount: u64,\n    /// Current phase of the round.\n    pub phase: RoundPhase,\n    /// Players in this round.\n    #[max_len(20)]\n    pub players: Vec<PlayerEntry>,\n    /// Total entries across all players.\n    pub total_entries: u32,\n    /// Unix timestamp when the round was created.\n    pub created_at: i64,\n    /// Unix timestamp when countdown ends (0 if not yet started).\n    pub countdown_ends_at: i64,\n    /// Unix timestamp when the round entered Locked phase (0 if not yet).\n    pub locked_at: i64,\n    /// Deadline for VRF resolution; after this, timeout refund is available.\n    pub resolve_deadline: i64,\n    /// Address of the Orao randomness PDA for VRF lookup at claim time.\n    pub vrf_request_key: Pubkey,\n    /// The winning slot index (only valid after settlement).\n    pub winning_slot: u32,\n    /// The winner's pubkey (Pubkey::default() until settled).\n    pub winner: Pubkey,\n    /// Whether the payout has been claimed.\n    pub claimed: bool,\n    /// The creator of the round (receives rent back on close).\n    pub creator: Pubkey,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// Event emitted when a round is settled via claim_payout.\n#[event]\npub struct RoundSettled {\n    /// Tier index.\n    pub tier: u8,\n    /// Round number.\n    pub round_number: u64,\n    /// Winner's wallet address.\n    pub winner: Pubkey,\n    /// Raw VRF randomness bytes.\n    pub randomness: [u8; 32],\n    /// The winning slot index (0-based).\n    pub winning_slot: u32,\n    /// Total entries in the round.\n    pub total_entries: u32,\n    /// Net payout to winner (after fee).\n    pub payout_amount: u64,\n    /// Platform fee amount.\n    pub fee_amount: u64,\n    /// Address of the Orao VRF request PDA.\n    pub vrf_request_key: Pubkey,\n}\n```\n\n---\n\n## 5. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/lordofrngs/src/error.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\n#[error_code]\npub enum LordError {\n    /// 6100 (Anchor adds 6000 base offset)\n    #[msg(\"Invalid tier index\")]\n    InvalidTier = 100,\n\n    /// 6101\n    #[msg(\"Round is not in the expected phase\")]\n    InvalidPhase,\n\n    /// 6102\n    #[msg(\"Player is already in this round\")]\n    PlayerAlreadyInRound,\n\n    /// 6103\n    #[msg(\"Player is not in this round\")]\n    PlayerNotInRound,\n\n    /// 6104\n    #[msg(\"Maximum number of players reached\")]\n    MaxPlayersReached,\n\n    /// 6105\n    #[msg(\"Countdown has not expired yet\")]\n    CountdownNotExpired,\n\n    /// 6106\n    #[msg(\"Payout has already been claimed\")]\n    AlreadyClaimed,\n\n    /// 6107\n    #[msg(\"Only the winner can claim the payout\")]\n    NotWinner,\n\n    /// 6108\n    #[msg(\"VRF randomness request failed\")]\n    VrfRequestFailed,\n\n    /// 6109\n    #[msg(\"Lock timeout has not elapsed yet\")]\n    LockTimeoutNotElapsed,\n\n    /// 6110\n    #[msg(\"VRF randomness has already been fulfilled\")]\n    VrfAlreadyFulfilled,\n\n    /// 6111\n    #[msg(\"Must purchase at least one entry\")]\n    ZeroEntries,\n\n    /// 6112\n    #[msg(\"Arithmetic overflow\")]\n    ArithmeticOverflow,\n}\n```\n\n---\n\n## 6. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/lordofrngs/src/instructions/mod.rs`\n\n```rust\npub mod buy_more_entries;\npub mod create_round;\npub mod initialize_config;\npub mod join_round;\n\npub use buy_more_entries::*;\npub use create_round::*;\npub use initialize_config::*;\npub use join_round::*;\n```\n\n---\n\n## Summary\n\nYou now have:\n\n1. **VRF request pattern** from `join_match.rs` — shows how coinflip requests Orao VRF via CPI, using the round PDA key as the seed and storing `vrf_request_key` after.\n\n2. **Shared VRF helper** (`vrf_orao.rs`) — provides `request_orao_randomness()` which wraps the Orao CPI, and supports both real and mock-VRF modes.\n\n3. **Lord program structure** — lib.rs, state.rs, error.rs, and instructions/mod.rs — ready for your `start_spin` instruction implementation.\n\nThe key pattern for `start_spin` will be:\n- Validate phase is Active and countdown has expired\n- Transition Active → Locked\n- Call `vrf_orao::request_orao_randomness()` with the round PDA key as seed\n- Store the `orao_random` account key as `vrf_request_key`\n- Update `locked_at` and `resolve_deadline` timestamps"}],"totalDurationMs":65702,"totalTokens":40505,"totalToolUseCount":17,"usage":{"input_tokens":5,"cache_creation_input_tokens":8598,"cache_read_input_tokens":26852,"output_tokens":5050,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":8598,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}}}
