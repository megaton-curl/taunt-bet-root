ee payment.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_treasury: UncheckedAccount<'info>,\n\n    /// Orao randomness account (created by Orao CPI).\n    /// CHECK: Orao VRF CPI validates and initializes this account.\n    #[account(mut)]\n    pub orao_random: UncheckedAccount<'info>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<StartSpin>, _tier: u8, _round_number: u64) -> Result<()> {\n    let round = &ctx.accounts.round;\n\n    // Idempotent: if already Locked (or beyond), silently succeed\n    if round.phase != RoundPhase::Active {\n        if round.phase == RoundPhase::Locked {\n            return Ok(());\n        }\n        // Any other non-Active phase is invalid\n        return Err(LordError::InvalidPhase.into());\n    }\n\n    // Validate countdown has expired\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        now >= round.countdown_ends_at,\n        LordError::CountdownNotExpired\n    );\n\n    // Validate Active → Locked transition via shared lifecycle\n    lifecycle::transition(round.phase, RoundPhase::Locked)?;\n\n    // Request Orao VRF — use round PDA key as unique seed\n    let seed: [u8; 32] = ctx.accounts.round.key().to_bytes();\n    vrf_orao::request_orao_randomness(\n        &ctx.accounts.orao_program.to_account_info(),\n        &ctx.accounts.orao_network_state.to_account_info(),\n        &ctx.accounts.orao_treasury.to_account_info(),\n        &ctx.accounts.orao_random.to_account_info(),\n        &ctx.accounts.caller.to_account_info(),\n        &ctx.accounts.system_program.to_account_info(),\n        seed,\n    )?;\n\n    // Update round state\n    let round = &mut ctx.accounts.round;\n    round.phase = RoundPhase::Locked;\n    round.locked_at = now;\n    round.resolve_deadline = now + DEFAULT_RESOLVE_TIMEOUT_SECONDS;\n    round.vrf_request_key = ctx.accounts.orao_random.key();\n\n    Ok(())\n}\n","structuredPatch":[],"originalFile":null}}
