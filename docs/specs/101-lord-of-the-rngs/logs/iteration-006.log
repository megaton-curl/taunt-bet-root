torProgram, t.creator, t);\n\n      // Verify Locked phase + VRF fields set\n      round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n      expect(round.lockedAt.toNumber()).to.be.greaterThan(0);\n      expect(round.resolveDeadline.toNumber()).to.be.greaterThan(round.lockedAt.toNumber());\n      expect(round.vrfRequestKey.toBase58()).to.equal(t.mockRandomness.publicKey.toBase58());\n    });\n\n    it(\"is idempotent (no error when already Locked)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n      await warpPastCountdown(t);\n\n      // First spin succeeds\n      await startSpin(t.creatorProgram, t.creator, t);\n\n      // Second spin from a different player also succeeds (idempotent no-op)\n      await startSpin(t.player2Program, t.player2.publicKey, t);\n\n      // Still Locked\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n    });\n\n    it(\"rejects spin before countdown expires\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Don't warp — countdown is still running\n      try {\n        await startSpin(t.creatorProgram, t.creator, t);\n        expect.fail(\"Expected CountdownNotExpired error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"CountdownNotExpired\");\n      }\n    });\n\n    it(\"rejects spin when phase is Waiting (only 1 player)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Phase is Waiting — no second player joined yet\n      try {\n        await startSpin(t.creatorProgram, t.creator, t);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n      }\n    });\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":653,"cache_read_input_tokens":77718,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":653},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"323ff130-207c-4bae-9ff2-11a67812c4db","uuid":"e6286d28-38ec-4d80-9d2c-74a94698353e"}
