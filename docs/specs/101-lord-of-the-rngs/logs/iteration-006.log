{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KdwNwGyoxHTjroX8N5RogS","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→pub mod error;\n     4→pub mod instructions;\n     5→pub mod state;\n     6→\n     7→use instructions::*;\n     8→\n     9→declare_id!(\"B9Lufh9GvuucDxDRZBr3qPNe4cJaS5MQBQKZxgUT5qYa\");\n    10→\n    11→#[program]\n    12→pub mod lordofrngs {\n    13→    use super::*;\n    14→\n    15→    pub fn initialize_config(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n    16→        instructions::initialize_config::handler(ctx, treasury)\n    17→    }\n    18→\n    19→    pub fn create_round(ctx: Context<CreateRound>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n    20→        instructions::create_round::handler(ctx, tier, round_number, num_entries)\n    21→    }\n    22→\n    23→    pub fn join_round(ctx: Context<JoinRound>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n    24→        instructions::join_round::handler(ctx, tier, round_number, num_entries)\n    25→    }\n    26→\n    27→    pub fn buy_more_entries(ctx: Context<BuyMoreEntries>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n    28→        instructions::buy_more_entries::handler(ctx, tier, round_number, num_entries)\n    29→    }\n    30→}\n    31→"}]},"parent_tool_use_id":"toolu_01UM6eGSqiUCKzXqvMke8UxE","session_id":"323ff130-207c-4bae-9ff2-11a67812c4db","uuid":"8cbfd812-f7a0-4506-990e-2b1b2acb5ab2"}
