    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    47→    PROGRAM_ID\n    48→  );\n    49→  return pda;\n    50→}\n    51→\n    52→// ---------------------------------------------------------------------------\n    53→// Test context factory\n    54→// ---------------------------------------------------------------------------\n    55→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n    56→  return {\n    57→    lamports,\n    58→    data: Buffer.alloc(0),\n    59→    owner: SystemProgram.programId,\n    60→    executable: false,\n    61→  };\n    62→}\n    63→\n    64→interface TestContext {\n    65→  context: Awaited<ReturnType<typeof startAnchor>>;\n    66→  creator: PublicKey;\n    67→  treasury: Keypair;\n    68→  creatorProgram: Program<Lordofrngs>;\n    69→  configPda: PublicKey;\n    70→  player2: Keypair;\n    71→  player2Program: Program<Lordofrngs>;\n    72→}\n    73→\n    74→async function createTestContext(): Promise<TestContext> {\n    75→  const treasury = Keypair.generate();\n    76→  const player2 = Keypair.generate();\n    77→\n    78→  const context = await startAnchor(\"./\", [], [\n    79→    { address: treasury.publicKey, info: fundedAccountData() },\n    80→    { address: player2.publicKey, info: fundedAccountData() },\n    81→  ]);\n    82→\n    83→  const creatorProvider = new BankrunProvider(context);\n    84→  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n    85→\n    86→  const player2Provider = new BankrunProvider(context, new Wallet(player2));\n    87→  const player2Program = new Program<Lordofrngs>(IDL, player2Provider);\n    88→\n    89→  const creator = creatorProvider.wallet.publicKey;\n    90→  const configPda = getConfigPda();\n    91→\n    92→  return {\n    93→    context,\n    94→    creator,\n    95→    treasury,\n    96→    creatorProgram,\n    97→    configPda,\n    98→    player2,\n    99→    player2Program,\n   100→  };\n   101→}\n   102→\n   103→// ---------------------------------------------------------------------------\n   104→// Instruction helpers\n   105→// ---------------------------------------------------------------------------\n   106→async function initConfig(t: TestContext) {\n   107→  await t.creatorProgram.methods\n   108→    .initializeConfig(t.treasury.publicKey)\n   109→    .accounts({\n   110→      authority: t.creator,\n   111→      config: t.configPda,\n   112→      systemProgram: SystemProgram.programId,\n   113→    })\n   114→    .rpc();\n   115→}\n   116→\n   117→async function createRound(\n   118→  t: TestContext,\n   119→  tier = TIER_IRON,\n   120→  roundNumber = 0,\n   121→  numEntries = 1,\n   122→  creator?: PublicKey,\n   123→) {\n   124→  const roundPda = getRoundPda(tier, roundNumber);\n   125→  await t.creatorProgram.methods\n   126→    .createRound(tier, new BN(roundNumber), numEntries)\n   127→    .accounts({\n   128→      creator: creator ?? t.creator,\n   129→      config: t.configPda,\n   130→      round: roundPda,\n   131→      systemProgram: SystemProgram.programId,\n   132→    })\n   133→    .rpc();\n   134→  return roundPda;\n   135→}\n   136→\n   137→async function joinRound(\n   138→  program: Program<Lordofrngs>,\n   139→  player: PublicKey,\n   140→  configPda: PublicKey,\n   141→  tier = TIER_IRON,\n   142→  roundNumber = 0,\n   143→  numEntries = 1,\n   144→) {\n   145→  const roundPda = getRoundPda(tier, roundNumber);\n   146→  await program.methods\n   147→    .joinRound(tier, new BN(roundNumber), numEntries)\n   148→    .accounts({\n   149→      player,\n   150→      config: configPda,\n   151→      round: roundPda,\n   152→      systemProgram: SystemProgram.programId,\n   153→    })\n   154→    .rpc();\n   155→  return roundPda;\n   156→}\n   157→\n   158→async function buyMoreEntries(\n   159→  program: Program<Lordofrngs>,\n   160→  player: PublicKey,\n   161→  configPda: PublicKey,\n   162→  tier = TIER_IRON,\n   163→  roundNumber = 0,\n   164→  numEntries = 1,\n   165→) {\n   166→  const roundPda = getRoundPda(tier, roundNumber);\n   167→  await program.methods\n   168→    .buyMoreEntries(tier, new BN(roundNumber), numEntries)\n   169→    .accounts({\n   170→      player,\n   171→      config: configPda,\n   172→      round: roundPda,\n   173→      systemProgram: SystemProgram.programId,\n   174→    })\n   175→    .rpc();\n   176→  return roundPda;\n   177→}\n   178→\n   179→// ---------------------------------------------------------------------------\n   180→// Tests\n   181→// ---------------------------------------------------------------------------\n   182→describe(\"lordofrngs\", () => {\n   183→  describe(\"initialize_config\", () => {\n   184→    it(\"creates config with treasury and paused=false\", async () => {\n   185→      const t = await createTestContext();\n   186→      await initConfig(t);\n   187→\n   188→      const config = await t.creatorProgram.account.lordConfig.fetch(\n   189→        t.configPda\n   190→      );\n   191→      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n   192→      expect(config.treasury.toBase58()).to.equal(\n   193→        t.treasury.publicKey.toBase58()\n   194→      );\n   195→      expect(config.paused).to.equal(false);\n   196→      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n   197→    });\n   198→  });\n   199→\n   200→  describe(\"create_round\", () => {\n   201→    it(\"creates round with correct PDA data and escrow balance\", async () => {\n   202→      const t = await createTestContext();\n   203→      await initConfig(t);\n   204→\n   205→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   206→\n   207→      // Verify round state\n   208→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   209→      expect(round.tier).to.equal(TIER_IRON);\n   210→      expect(round.roundNumber.toNumber()).to.equal(0);\n   211→      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   212→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n   213→      expect(round.players).to.have.length(1);\n   214→      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n   215→      expect(round.players[0].entries).to.equal(1);\n   216→      expect(round.totalEntries).to.equal(1);\n   217→      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n   218→      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n   219→      expect(round.lockedAt.toNumber()).to.equal(0);\n   220→      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n   221→      expect(round.claimed).to.equal(false);\n   222→\n   223→      // Verify escrow balance: account holds rent + entry amount\n   224→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   225→      const rent = await t.context.banksClient.getRent();\n   226→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   227→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   228→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n   229→\n   230→      // Verify config round counter incremented\n   231→      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   232→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n   233→    });\n   234→\n   235→    it(\"creates round with multiple entries\", async () => {\n   236→      const t = await createTestContext();\n   237→      await initConfig(t);\n   238→\n   239→      const numEntries = 5;\n   240→      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n   241→\n   242→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   243→      expect(round.players[0].entries).to.equal(numEntries);\n   244→      expect(round.totalEntries).to.equal(numEntries);\n   245→\n   246→      // Escrow should hold numEntries × entry_amount\n   247→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   248→      const rent = await t.context.banksClient.getRent();\n   249→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   250→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   251→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n   252→    });\n   253→\n   254→    it(\"increments round counter per tier\", async () => {\n   255→      const t = await createTestContext();\n   256→      await initConfig(t);\n   257→\n   258→      // Create first round (round 0)\n   259→      await createRound(t, TIER_IRON, 0, 1);\n   260→\n   261→      // Config counter should be 1\n   262→      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   263→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n   264→\n   265→      // Create second round (round 1) — need a new PDA\n   266→      await createRound(t, TIER_IRON, 1, 1);\n   267→\n   268→      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   269→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n   270→    });\n   271→\n   272→    it(\"rejects invalid tier (tier 6)\", async () => {\n   273→      const t = await createTestContext();\n   274→      await initConfig(t);\n   275→\n   276→      const invalidTier = 6;\n   277→      const roundPda = getRoundPda(invalidTier, 0);\n   278→\n   279→      try {\n   280→        await t.creatorProgram.methods\n   281→          .createRound(invalidTier, new BN(0), 1)\n   282→          .accounts({\n   283→            creator: t.creator,\n   284→            config: t.configPda,\n   285→            round: roundPda,\n   286→            systemProgram: SystemProgram.programId,\n   287→          })\n   288→          .rpc();\n   289→        expect.fail(\"Expected InvalidTier error\");\n   290→      } catch (err) {\n   291→        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n   292→        // PDA derivation time, resulting in an Anchor error\n   293→        expect(err).to.be.instanceOf(Error);\n   294→      }\n   295→    });\n   296→\n   297→    it(\"rejects zero entries\", async () => {\n   298→      const t = await createTestContext();\n   299→      await initConfig(t);\n   300→\n   301→      const roundPda = getRoundPda(TIER_IRON, 0);\n   302→\n   303→      try {\n   304→        await t.creatorProgram.methods\n   305→          .createRound(TIER_IRON, new BN(0), 0)\n   306→          .accounts({\n   307→            creator: t.creator,\n   308→            config: t.configPda,\n   309→            round: roundPda,\n   310→            systemProgram: SystemProgram.programId,\n   311→          })\n   312→          .rpc();\n   313→        expect.fail(\"Expected ZeroEntries error\");\n   314→      } catch (err) {\n   315→        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n   316→      }\n   317→    });\n   318→  });\n   319→\n   320→  describe(\"join_round\", () => {\n   321→    it(\"2nd player joins and triggers countdown (Waiting → Active)\", async () => {\n   322→      const t = await createTestContext();\n   323→      await initConfig(t);\n   324→\n   325→      // Creator starts round (player 1)\n   326→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   327→\n   328→      // Player 2 joins\n   329→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   330→\n   331→      // Verify round state\n   332→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   333→      expect(round.players).to.have.length(2);\n   334→      expect(round.players[1].player.toBase58()).to.equal(t.player2.publicKey.toBase58());\n   335→      expect(round.players[1].entries).to.equal(1);\n   336→      expect(round.totalEntries).to.equal(2);\n   337→\n   338→      // Phase should be Active (countdown started)\n   339→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n   340→      expect(round.countdownEndsAt.toNumber()).to.be.greaterThan(0);\n   341→\n   342→      // Escrow should hold 2 × entry_amount\n   343→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   344→      const rent = await t.context.banksClient.getRent();\n   345→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   346→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   347→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 2);\n   348→    });\n   349→\n   350→    it(\"3rd player joins during Active phase without re-triggering countdown\", async () => {\n   351→      const t = await createTestContext();\n   352→      await initConfig(t);\n   353→\n   354→      const player3 = Keypair.generate();\n   355→      const player3Account = fundedAccountData();\n   356→      t.context.setAccount(player3.publicKey, player3Account);\n   357→      const player3Provider = new BankrunProvider(t.context, new Wallet(player3));\n   358→      const player3Program = new Program<Lordofrngs>(IDL, player3Provider);\n   359→\n   360→      // Creator starts round, player2 joins (triggers countdown)\n   361→      await createRound(t, TIER_IRON, 0, 1);\n   362→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   363→\n   364→      const roundBefore = await t.creatorProgram.account.jackpotRound.fetch(\n   365→        getRoundPda(TIER_IRON, 0)\n   366→      );\n   367→      const countdownBefore = roundBefore.countdownEndsAt.toNumber();\n   368→\n   369→      // Player 3 joins\n   370→      await joinRound(player3Program, player3.publicKey, t.configPda);\n   371→\n   372→      const round = await t.creatorProgram.account.jackpotRound.fetch(\n   373→        getRoundPda(TIER_IRON, 0)\n   374→      );\n   375→      expect(round.players).to.have.length(3);\n   376→      expect(round.totalEntries).to.equal(3);\n   377→      // Countdown should not have changed\n   378→      expect(round.countdownEndsAt.toNumber()).to.equal(countdownBefore);\n   379→    });\n   380→\n   381→    it(\"player can join with multiple entries\", async () => {\n   382→      const t = await createTestContext();\n   383→      await initConfig(t);\n   384→\n   385→      await createRound(t, TIER_IRON, 0, 1);\n   386→\n   387→      // Player 2 joins with 5 entries\n   388→      const roundPda = await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, 5);\n   389→\n   390→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   391→      expect(round.players[1].entries).to.equal(5);\n   392→      expect(round.totalEntries).to.equal(6); // 1 (creator) + 5 (player2)\n   393→\n   394→      // Escrow: 1 × amount (creator) + 5 × amount (player2)\n   395→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   396→      const rent = await t.context.banksClient.getRent();\n   397→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   398→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   399→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 6);\n   400→    });\n   401→\n   402→    it(\"rejects duplicate player\", async () => {\n   403→      const t = await createTestContext();\n   404→      await initConfig(t);\n   405→\n   406→      await createRound(t, TIER_IRON, 0, 1);\n   407→\n   408→      // Creator tries to join their own round again\n   409→      try {\n   410→        await joinRound(t.creatorProgram, t.creator, t.configPda);\n   411→        expect.fail(\"Expected PlayerAlreadyInRound error\");\n   412→      } catch (err) {\n   413→        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerAlreadyInRound\");\n   414→      }\n   415→    });\n   416→\n   417→    it(\"rejects 21st player (max 20)\", async () => {\n   418→      const t = await createTestContext();\n   419→      await initConfig(t);\n   420→\n   421→      // Creator starts round\n   422→      await createRound(t, TIER_IRON, 0, 1);\n   423→\n   424→      // Add 19 more players (total 20)\n   425→      for (let i = 0; i < 19; i++) {\n   426→        const p = Keypair.generate();\n   427→        t.context.setAccount(p.publicKey, fundedAccountData());\n   428→        const pProvider = new BankrunProvider(t.context, new Wallet(p));\n   429→        const pProgram = new Program<Lordofrngs>(IDL, pProvider);\n   430→        await joinRound(pProgram, p.publicKey, t.configPda);\n   431→      }\n   432→\n   433→      // Verify we have 20 players\n   434→      const round = await t.creatorProgram.account.jackpotRound.fetch(\n   435→        getRoundPda(TIER_IRON, 0)\n   436→      );\n   437→      expect(round.players).to.have.length(20);\n   438→\n   439→      // 21st player should be rejected\n   440→      const extra = Keypair.generate();\n   441→      t.context.setAccount(extra.publicKey, fundedAccountData());\n   442→      const extraProvider = new BankrunProvider(t.context, new Wallet(extra));\n   443→      const extraProgram = new Program<Lordofrngs>(IDL, extraProvider);\n   444→\n   445→      try {\n   446→        await joinRound(extraProgram, extra.publicKey, t.configPda);\n   447→        expect.fail(\"Expected MaxPlayersReached error\");\n   448→      } catch (err) {\n   449→        expect((err as AnchorError).error.errorCode.code).to.equal(\"MaxPlayersReached\");\n   450→      }\n   451→    });\n   452→\n   453→    it(\"rejects join when phase is Locked\", async () => {\n   454→      // We can't easily get to Locked phase without VRF, so we test that\n   455→      // only Waiting and Active phases are accepted. We'll simulate by\n   456→      // checking the phase validation works with a round that's in a state\n   457→      // we can't join.\n   458→      // For now, we verify the InvalidPhase error by checking that joining\n   459→      // a round that doesn't exist fails (Anchor account constraint).\n   460→      // The full phase rejection test will be covered in the start_spin tests.\n   461→\n   462→      // Instead, test that joining during Waiting phase (before 2nd player) works,\n   463→      // which is already covered above. The Locked phase test will be\n   464→      // in the start_spin + claim_payout iteration when we can create Locked rounds.\n   465→      // Skip for now — covered by the phase check in the instruction.\n   466→    });\n   467→  });\n   468→\n   469→  describe(\"buy_more_entries\", () => {\n   470→    it(\"existing player buys more entries (updated count + escrow)\", async () => {\n   471→      const t = await createTestContext();\n   472→      await initConfig(t);\n   473→\n   474→      // Creator starts round with 1 entry\n   475→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   476→\n   477→      // Creator buys 3 more entries\n   478→      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 3);\n   479→\n   480→      // Verify updated state\n   481→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   482→      expect(round.players).to.have.length(1);\n   483→      expect(round.players[0].entries).to.equal(4); // 1 + 3\n   484→      expect(round.totalEntries).to.equal(4);\n   485→\n   486→      // Escrow should hold 4 × entry_amount\n   487→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   488→      const rent = await t.context.banksClient.getRent();\n   489→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   490→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   491→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 4);\n   492→    });\n   493→\n   494→    it(\"works during Active phase (after countdown starts)\", async () => {\n   495→      const t = await createTestContext();\n   496→      await initConfig(t);\n   497→\n   498→      // Creator starts round, player2 joins (triggers countdown → Active)\n   499→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   500→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   501→\n   502→      // Creator buys 2 more during Active phase\n   503→      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 2);\n   504→\n   505→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   506→      expect(round.players[0].entries).to.equal(3); // 1 + 2\n   507→      expect(round.totalEntries).to.equal(4); // 3 (creator) + 1 (player2)\n   508→    });\n   509→\n   510→    it(\"rejects player not in round\", async () => {\n   511→      const t = await createTestContext();\n   512→      await initConfig(t);\n   513→\n   514→      // Creator starts round\n   515→      await createRound(t, TIER_IRON, 0, 1);\n   516→\n   517→      // Player2 (not in round) tries to buy more\n   518→      try {\n   519→        await buyMoreEntries(t.player2Program, t.player2.publicKey, t.configPda);\n   520→        expect.fail(\"Expected PlayerNotInRound error\");\n   521→      } catch (err) {\n   522→        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerNotInRound\");\n   523→      }\n   524→    });\n   525→\n   526→    it(\"rejects zero entries\", async () => {\n   527→      const t = await createTestContext();\n   528→      await initConfig(t);\n   529→\n   530→      await createRound(t, TIER_IRON, 0, 1);\n   531→\n   532→      try {\n   533→        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 0);\n   534→        expect.fail(\"Expected ZeroEntries error\");\n   535→      } catch (err) {\n   536→        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n   537→      }\n   538→    });\n   539→  });\n   540→});\n   541→"}]},"parent_tool_use_id":null,"session_id":"323ff130-207c-4bae-9ff2-11a67812c4db","uuid":"d8b7b737-5f02-45ad-a6ce-bf56668d81bc","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/lordofrngs.ts","content":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { AnchorError, Program } from \"@coral-xyz/anchor\";\nimport { Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Lordofrngs } from \"../target/types/lordofrngs\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\nimport BN from \"bn.js\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\n// Tier constants (from shared crate)\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getRoundPda(tier: number, roundNumber: number | bigint): PublicKey {\n  const tierBuf = Buffer.from([tier]);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Test context factory\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  treasury: Keypair;\n  creatorProgram: Program<Lordofrngs>;\n  configPda: PublicKey;\n  player2: Keypair;\n  player2Program: Program<Lordofrngs>;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const treasury = Keypair.generate();\n  const player2 = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: treasury.publicKey, info: fundedAccountData() },\n    { address: player2.publicKey, info: fundedAccountData() },\n  ]);\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n\n  const player2Provider = new BankrunProvider(context, new Wallet(player2));\n  const player2Program = new Program<Lordofrngs>(IDL, player2Provider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n\n  return {\n    context,\n    creator,\n    treasury,\n    creatorProgram,\n    configPda,\n    player2,\n    player2Program,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Instruction helpers\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createRound(\n  t: TestContext,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n  creator?: PublicKey,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await t.creatorProgram.methods\n    .createRound(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      creator: creator ?? t.creator,\n      config: t.configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\nasync function joinRound(\n  program: Program<Lordofrngs>,\n  player: PublicKey,\n  configPda: PublicKey,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .joinRound(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\nasync function buyMoreEntries(\n  program: Program<Lordofrngs>,\n  player: PublicKey,\n  configPda: PublicKey,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await program.methods\n    .buyMoreEntries(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\ndescribe(\"lordofrngs\", () => {\n  describe(\"initialize_config\", () => {\n    it(\"creates config with treasury and paused=false\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.lordConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n      expect(config.paused).to.equal(false);\n      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n    });\n  });\n\n  describe(\"create_round\", () => {\n    it(\"creates round with correct PDA data and escrow balance\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Verify round state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.tier).to.equal(TIER_IRON);\n      expect(round.roundNumber.toNumber()).to.equal(0);\n      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n      expect(round.players).to.have.length(1);\n      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.players[0].entries).to.equal(1);\n      expect(round.totalEntries).to.equal(1);\n      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n      expect(round.lockedAt.toNumber()).to.equal(0);\n      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.claimed).to.equal(false);\n\n      // Verify escrow balance: account holds rent + entry amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n\n      // Verify config round counter incremented\n      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n    });\n\n    it(\"creates round with multiple entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const numEntries = 5;\n      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[0].entries).to.equal(numEntries);\n      expect(round.totalEntries).to.equal(numEntries);\n\n      // Escrow should hold numEntries × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n    });\n\n    it(\"increments round counter per tier\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Create first round (round 0)\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Config counter should be 1\n      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n\n      // Create second round (round 1) — need a new PDA\n      await createRound(t, TIER_IRON, 1, 1);\n\n      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n    });\n\n    it(\"rejects invalid tier (tier 6)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const invalidTier = 6;\n      const roundPda = getRoundPda(invalidTier, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(invalidTier, new BN(0), 1)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n        // PDA derivation time, resulting in an Anchor error\n        expect(err).to.be.instanceOf(Error);\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = getRoundPda(TIER_IRON, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(TIER_IRON, new BN(0), 0)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n\n  describe(\"join_round\", () => {\n    it(\"2nd player joins and triggers countdown (Waiting → Active)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round (player 1)\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Player 2 joins\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Verify round state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players).to.have.length(2);\n      expect(round.players[1].player.toBase58()).to.equal(t.player2.publicKey.toBase58());\n      expect(round.players[1].entries).to.equal(1);\n      expect(round.totalEntries).to.equal(2);\n\n      // Phase should be Active (countdown started)\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n      expect(round.countdownEndsAt.toNumber()).to.be.greaterThan(0);\n\n      // Escrow should hold 2 × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 2);\n    });\n\n    it(\"3rd player joins during Active phase without re-triggering countdown\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const player3 = Keypair.generate();\n      const player3Account = fundedAccountData();\n      t.context.setAccount(player3.publicKey, player3Account);\n      const player3Provider = new BankrunProvider(t.context, new Wallet(player3));\n      const player3Program = new Program<Lordofrngs>(IDL, player3Provider);\n\n      // Creator starts round, player2 joins (triggers countdown)\n      await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      const roundBefore = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      const countdownBefore = roundBefore.countdownEndsAt.toNumber();\n\n      // Player 3 joins\n      await joinRound(player3Program, player3.publicKey, t.configPda);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(round.players).to.have.length(3);\n      expect(round.totalEntries).to.equal(3);\n      // Countdown should not have changed\n      expect(round.countdownEndsAt.toNumber()).to.equal(countdownBefore);\n    });\n\n    it(\"player can join with multiple entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Player 2 joins with 5 entries\n      const roundPda = await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, 5);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[1].entries).to.equal(5);\n      expect(round.totalEntries).to.equal(6); // 1 (creator) + 5 (player2)\n\n      // Escrow: 1 × amount (creator) + 5 × amount (player2)\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 6);\n    });\n\n    it(\"rejects duplicate player\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Creator tries to join their own round again\n      try {\n        await joinRound(t.creatorProgram, t.creator, t.configPda);\n        expect.fail(\"Expected PlayerAlreadyInRound error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerAlreadyInRound\");\n      }\n    });\n\n    it(\"rejects 21st player (max 20)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Add 19 more players (total 20)\n      for (let i = 0; i < 19; i++) {\n        const p = Keypair.generate();\n        t.context.setAccount(p.publicKey, fundedAccountData());\n        const pProvider = new BankrunProvider(t.context, new Wallet(p));\n        const pProgram = new Program<Lordofrngs>(IDL, pProvider);\n        await joinRound(pProgram, p.publicKey, t.configPda);\n      }\n\n      // Verify we have 20 players\n      const round = await t.creatorProgram.account.jackpotRound.fetch(\n        getRoundPda(TIER_IRON, 0)\n      );\n      expect(round.players).to.have.length(20);\n\n      // 21st player should be rejected\n      const extra = Keypair.generate();\n      t.context.setAccount(extra.publicKey, fundedAccountData());\n      const extraProvider = new BankrunProvider(t.context, new Wallet(extra));\n      const extraProgram = new Program<Lordofrngs>(IDL, extraProvider);\n\n      try {\n        await joinRound(extraProgram, extra.publicKey, t.configPda);\n        expect.fail(\"Expected MaxPlayersReached error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"MaxPlayersReached\");\n      }\n    });\n\n    it(\"rejects join when phase is Locked\", async () => {\n      // We can't easily get to Locked phase without VRF, so we test that\n      // only Waiting and Active phases are accepted. We'll simulate by\n      // checking the phase validation works with a round that's in a state\n      // we can't join.\n      // For now, we verify the InvalidPhase error by checking that joining\n      // a round that doesn't exist fails (Anchor account constraint).\n      // The full phase rejection test will be covered in the start_spin tests.\n\n      // Instead, test that joining during Waiting phase (before 2nd player) works,\n      // which is already covered above. The Locked phase test will be\n      // in the start_spin + claim_payout iteration when we can create Locked rounds.\n      // Skip for now — covered by the phase check in the instruction.\n    });\n  });\n\n  describe(\"buy_more_entries\", () => {\n    it(\"existing player buys more entries (updated count + escrow)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round with 1 entry\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Creator buys 3 more entries\n      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 3);\n\n      // Verify updated state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players).to.have.length(1);\n      expect(round.players[0].entries).to.equal(4); // 1 + 3\n      expect(round.totalEntries).to.equal(4);\n\n      // Escrow should hold 4 × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 4);\n    });\n\n    it(\"works during Active phase (after countdown starts)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round, player2 joins (triggers countdown → Active)\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n\n      // Creator buys 2 more during Active phase\n      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 2);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[0].entries).to.equal(3); // 1 + 2\n      expect(round.totalEntries).to.equal(4); // 3 (creator) + 1 (player2)\n    });\n\n    it(\"rejects player not in round\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Creator starts round\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Player2 (not in round) tries to buy more\n      try {\n        await buyMoreEntries(t.player2Program, t.player2.publicKey, t.configPda);\n        expect.fail(\"Expected PlayerNotInRound error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerNotInRound\");\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createRound(t, TIER_IRON, 0, 1);\n\n      try {\n        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 0);\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n});\n","numLines":541,"startLine":1,"totalLines":541}}}
