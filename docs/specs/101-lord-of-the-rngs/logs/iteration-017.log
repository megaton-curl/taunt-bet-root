{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V1yfVhX6U2MdBgeufBTB9Q","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { type Transaction } from \"@solana/web3.js\";\n    11→import { TIER_VALUES, type Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { Round, TierStatus } from \"../types\";\n    13→import {\n    14→  fetchAllTierRounds,\n    15→  fetchRound,\n    16→  buildCreateRoundTx,\n    17→  buildJoinRoundTx,\n    18→  buildBuyMoreEntriesTx,\n    19→  buildStartSpinTx,\n    20→  buildClaimPayoutTx,\n    21→  getLordProgram,\n    22→  getConfigPda,\n    23→} from \"../utils/chain\";\n    24→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    25→\n    26→/** Parse transaction errors into user-friendly messages */\n    27→function parseTransactionError(err: unknown): string {\n    28→  const msg = err instanceof Error ? err.message : String(err);\n    29→\n    30→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    31→    return \"Wallet not connected. Please connect your wallet first.\";\n    32→  }\n    33→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    34→    return \"Transaction cancelled by user.\";\n    35→  }\n    36→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    37→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    38→  }\n    39→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    40→    return \"Network error. Please check your connection and try again.\";\n    41→  }\n    42→  if (msg.includes(\"InvalidPhase\")) {\n    43→    return \"This round is no longer accepting entries.\";\n    44→  }\n    45→  if (msg.includes(\"MaxPlayersReached\")) {\n    46→    return \"This round is full (max 20 players).\";\n    47→  }\n    48→  if (msg.includes(\"PlayerAlreadyInRound\")) {\n    49→    return \"You are already in this round. Use 'Buy More' to add entries.\";\n    50→  }\n    51→  if (msg.includes(\"CountdownNotExpired\")) {\n    52→    return \"Countdown has not finished yet.\";\n    53→  }\n    54→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    55→    return \"Transaction simulation failed. The round state may have changed.\";\n    56→  }\n    57→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    58→    return \"Transaction expired. Please try again.\";\n    59→  }\n    60→\n    61→  console.error(\"[lord-of-rngs] unhandled transaction error:\", err);\n    62→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    63→}\n    64→\n    65→/** Metadata for the active round needed to build transactions */\n    66→interface RoundMeta {\n    67→  tierIndex: number;\n    68→  roundNumber: bigint;\n    69→}\n    70→\n    71→/** Fetch the current round number for a tier from the on-chain config */\n    72→async function fetchRoundNumberForTier(\n    73→  connection: Parameters<typeof getLordProgram>[0],\n    74→  tierIndex: number,\n    75→): Promise<bigint> {\n    76→  const program = getLordProgram(connection);\n    77→  const [configPda] = getConfigPda();\n    78→  const config = await program.account.lordConfig.fetch(configPda);\n    79→  const configData = config as unknown as { roundCounters: { toNumber(): number }[] };\n    80→  // Active round is the last created = counter - 1\n    81→  return BigInt(configData.roundCounters[tierIndex]!.toNumber() - 1);\n    82→}\n    83→\n    84→interface LordOfRngsContextValue {\n    85→  // State\n    86→  activeRound: Round | null;\n    87→  tierStatuses: TierStatus[];\n    88→  userHistory: Round[];\n    89→  selectedTier: Tier | null;\n    90→  entryCount: number;\n    91→\n    92→  // Loading states\n    93→  loading: boolean;\n    94→  joining: boolean;\n    95→  buyingMore: boolean;\n    96→  claiming: boolean;\n    97→  spinning: boolean;\n    98→\n    99→  // Error state\n   100→  error: string | null;\n   101→  clearError: () => void;\n   102→\n   103→  // Actions\n   104→  setSelectedTier: (tier: Tier | null) => void;\n   105→  setEntryCount: (count: number) => void;\n   106→  joinTierRound: () => Promise<void>;\n   107→  buyMoreEntriesAction: (entries: number) => Promise<void>;\n   108→  startSpin: () => Promise<void>;\n   109→  claimPayout: () => Promise<void>;\n   110→  leaveRound: () => void;\n   111→  refreshRounds: () => void;\n   112→}\n   113→\n   114→const LordOfRngsContext = createContext<LordOfRngsContextValue | null>(null);\n   115→\n   116→const TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   117→\n   118→export function LordOfRngsProvider({ children }: { children: ReactNode }) {\n   119→  const { connected, publicKey, sendTransaction } = useWallet();\n   120→  const { connection } = useConnection();\n   121→  const { refresh: refreshBalance } = useBalance();\n   122→\n   123→  // Selection state\n   124→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   125→  const [entryCount, setEntryCount] = useState(1);\n   126→\n   127→  // Round state\n   128→  const [activeRound, setActiveRound] = useState<Round | null>(null);\n   129→  const [activeRoundMeta, setActiveRoundMeta] = useState<RoundMeta | null>(null);\n   130→  const [tierStatuses, setTierStatuses] = useState<TierStatus[]>([]);\n   131→  const [userHistory] = useState<Round[]>([]);\n   132→\n   133→  // Loading states\n   134→  const [loading, setLoading] = useState(true);\n   135→  const [joining, setJoining] = useState(false);\n   136→  const [buyingMore, setBuyingMore] = useState(false);\n   137→  const [claiming, setClaiming] = useState(false);\n   138→  const [spinning, setSpinning] = useState(false);\n   139→\n   140→  // Error state\n   141→  const [error, setError] = useState<string | null>(null);\n   142→  const clearError = useCallback(() => setError(null), []);\n   143→\n   144→  // Track if user explicitly left the round\n   145→  const [userLeftRound, setUserLeftRound] = useState(false);\n   146→\n   147→  // Ref to prevent multiple completion timeouts\n   148→  const completionTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n   149→  const refreshInFlightRef = useRef(false);\n   150→  // Ref to access latest claiming state in polling callback\n   151→  const claimingRef = useRef(false);\n   152→  useEffect(() => { claimingRef.current = claiming; }, [claiming]);\n   153→\n   154→  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n   155→  const sendAndConfirm = useCallback(\n   156→    async (transaction: Transaction): Promise<string> => {\n   157→      const { blockhash, lastValidBlockHeight } =\n   158→        await connection.getLatestBlockhash(\"confirmed\");\n   159→      transaction.recentBlockhash = blockhash;\n   160→      const signature = await sendTransaction(transaction);\n   161→      await connection.confirmTransaction(\n   162→        { signature, blockhash, lastValidBlockHeight },\n   163→        \"confirmed\",\n   164→      );\n   165→      await refreshBalance();\n   166→      return signature;\n   167→    },\n   168→    [connection, sendTransaction, refreshBalance],\n   169→  );\n   170→\n   171→  // Refresh tier statuses from on-chain\n   172→  const refreshRounds = useCallback(async () => {\n   173→    if (refreshInFlightRef.current) return;\n   174→    refreshInFlightRef.current = true;\n   175→\n   176→    try {\n   177→      const wallet = publicKey?.toBase58();\n   178→      const allRounds = await fetchAllTierRounds(connection, wallet);\n   179→      const statuses: TierStatus[] = TIERS.map((tier) => {\n   180→        const round = allRounds.get(tier) ?? null;\n   181→        return {\n   182→          tier,\n   183→          entryAmount: round?.entryAmount ?? 0,\n   184→          currentRound: round,\n   185→        };\n   186→      });\n   187→      setTierStatuses(statuses);\n   188→    } catch {\n   189→      // Ignore transient RPC failures; polling will retry\n   190→    } finally {\n   191→      setLoading(false);\n   192→      refreshInFlightRef.current = false;\n   193→    }\n   194→  }, [connection, publicKey]);\n   195→\n   196→  /** Auto-claim payout when the player wins */\n   197→  const handleAutoClaim = useCallback(async () => {\n   198→    if (!publicKey || !activeRound || !activeRoundMeta) return;\n   199→\n   200→    setClaiming(true);\n   201→    setError(null);\n   202→    try {\n   203→      const tx = await buildClaimPayoutTx(\n   204→        connection,\n   205→        publicKey,\n   206→        activeRound.tier,\n   207→        activeRoundMeta.roundNumber,\n   208→      );\n   209→      await sendAndConfirm(tx);\n   210→\n   211→      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n   212→\n   213→      // Auto-transition back to lobby after showing win result\n   214→      completionTimeoutRef.current = setTimeout(() => {\n   215→        completionTimeoutRef.current = null;\n   216→        setActiveRound(null);\n   217→        setActiveRoundMeta(null);\n   218→        void refreshRounds();\n   219→      }, 5000);\n   220→    } catch (err) {\n   221→      // If auto-claim fails, user can manually retry via claimPayout\n   222→      setError(parseTransactionError(err));\n   223→    } finally {\n   224→      setClaiming(false);\n   225→    }\n   226→  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n   227→\n   228→  // Initial load\n   229→  useEffect(() => {\n   230→    setLoading(true);\n   231→    void refreshRounds();\n   232→  }, [refreshRounds]);\n   233→\n   234→  // Poll for updates — faster when in active round, slower for lobby\n   235→  const pollInterval = activeRound ? 5000 : 15000;\n   236→\n   237→  useEffect(() => {\n   238→    const interval = setInterval(() => {\n   239→      if (activeRound && activeRoundMeta) {\n   240→        // Poll the active round account\n   241→        fetchRound(\n   242→          connection,\n   243→          activeRoundMeta.tierIndex,\n   244→          activeRoundMeta.roundNumber,\n   245→          publicKey?.toBase58()\n   246→        )\n   247→          .then((updated) => {\n   248→            if (!updated) {\n   249→              // Round account closed (claimed or cancelled) — return to lobby\n   250→              setActiveRound(null);\n   251→              setActiveRoundMeta(null);\n   252→              void refreshRounds();\n   253→              return;\n   254→            }\n   255→\n   256→            setActiveRound(updated);\n   257→\n   258→            // If VRF fulfilled (revealing phase) and we're the winner, auto-claim\n   259→            if (\n   260→              updated.phase === \"revealing\" &&\n   261→              updated.winner === publicKey?.toBase58() &&\n   262→              !updated.claimed &&\n   263→              !claimingRef.current\n   264→            ) {\n   265→              void handleAutoClaim();\n   266→            }\n   267→\n   268→            // If round settled and we're not the winner, auto-return to lobby\n   269→            if (\n   270→              updated.phase === \"complete\" &&\n   271→              !completionTimeoutRef.current\n   272→            ) {\n   273→              const isWinner = updated.winner === publicKey?.toBase58();\n   274→              completionTimeoutRef.current = setTimeout(() => {\n   275→                completionTimeoutRef.current = null;\n   276→                setActiveRound(null);\n   277→                setActiveRoundMeta(null);\n   278→                void refreshRounds();\n   279→              }, isWinner ? 5000 : 3000);\n   280→            }\n   281→          })\n   282→          .catch(() => {\n   283→            // Ignore polling errors\n   284→          });\n   285→      } else {\n   286→        // Lobby: poll tier statuses\n   287→        void refreshRounds();\n   288→      }\n   289→    }, pollInterval);\n   290→    return () => clearInterval(interval);\n   291→  }, [refreshRounds, activeRound, activeRoundMeta, connection, pollInterval, publicKey, handleAutoClaim]);\n   292→\n   293→  // Cleanup completion timeout on unmount\n   294→  useEffect(() => {\n   295→    return () => {\n   296→      if (completionTimeoutRef.current) {\n   297→        clearTimeout(completionTimeoutRef.current);\n   298→      }\n   299→    };\n   300→  }, []);\n   301→\n   302→  // Join a tier's round\n   303→  const joinTierRound = useCallback(async () => {\n   304→    if (!connected || !publicKey) {\n   305→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   306→      return;\n   307→    }\n   308→    if (!selectedTier) {\n   309→      setError(\"Select a tier first.\");\n   310→      return;\n   311→    }\n   312→    if (entryCount < 1) {\n   313→      setError(\"Select at least 1 entry.\");\n   314→      return;\n   315→    }\n   316→\n   317→    setJoining(true);\n   318→    setError(null);\n   319→    try {\n   320→      // Check if a round exists for this tier\n   321→      const wallet = publicKey.toBase58();\n   322→      const allRounds = await fetchAllTierRounds(connection, wallet);\n   323→      const existingRound = allRounds.get(selectedTier);\n   324→\n   325→      let roundNumber: bigint;\n   326→      let tierIndex: number;\n   327→\n   328→      if (existingRound && existingRound.phase !== \"complete\") {\n   329→        // Join existing round\n   330→        tierIndex = TIER_VALUES[selectedTier];\n   331→        roundNumber = await fetchRoundNumberForTier(connection, tierIndex);\n   332→\n   333→        const tx = await buildJoinRoundTx(\n   334→          connection,\n   335→          publicKey,\n   336→          selectedTier,\n   337→          entryCount,\n   338→          roundNumber,\n   339→        );\n   340→        await sendAndConfirm(tx);\n   341→      } else {\n   342→        // Create a new round (we are the first player)\n   343→        const result = await buildCreateRoundTx(\n   344→          connection,\n   345→          publicKey,\n   346→          selectedTier,\n   347→          entryCount,\n   348→        );\n   349→        await sendAndConfirm(result.transaction);\n   350→\n   351→        roundNumber = result.roundNumber;\n   352→        tierIndex = TIER_VALUES[selectedTier];\n   353→      }\n   354→\n   355→      // Fetch the round we just joined/created\n   356→      const round = await fetchRound(\n   357→        connection,\n   358→        tierIndex,\n   359→        roundNumber,\n   360→        publicKey.toBase58(),\n   361→      );\n   362→      if (round) {\n   363→        setActiveRound(round);\n   364→        setActiveRoundMeta({ tierIndex, roundNumber });\n   365→        setUserLeftRound(false);\n   366→      }\n   367→\n   368→      void refreshRounds();\n   369→    } catch (err) {\n   370→      setError(parseTransactionError(err));\n   371→    } finally {\n   372→      setJoining(false);\n   373→    }\n   374→  }, [connected, publicKey, selectedTier, entryCount, connection, sendAndConfirm, refreshRounds]);\n   375→\n   376→  // Buy more entries in current round\n   377→  const buyMoreEntriesAction = useCallback(\n   378→    async (entries: number) => {\n   379→      if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n   380→        setError(\"No active round.\");\n   381→        return;\n   382→      }\n   383→\n   384→      setBuyingMore(true);\n   385→      setError(null);\n   386→      try {\n   387→        const tx = await buildBuyMoreEntriesTx(\n   388→          connection,\n   389→          publicKey,\n   390→          activeRound.tier,\n   391→          activeRoundMeta.roundNumber,\n   392→          entries,\n   393→        );\n   394→        await sendAndConfirm(tx);\n   395→\n   396→        // Refresh active round\n   397→        const updated = await fetchRound(\n   398→          connection,\n   399→          activeRoundMeta.tierIndex,\n   400→          activeRoundMeta.roundNumber,\n   401→          publicKey.toBase58(),\n   402→        );\n   403→        if (updated) {\n   404→          setActiveRound(updated);\n   405→        }\n   406→\n   407→        void refreshRounds();\n   408→      } catch (err) {\n   409→        setError(parseTransactionError(err));\n   410→      } finally {\n   411→        setBuyingMore(false);\n   412→      }\n   413→    },\n   414→    [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds],\n   415→  );\n   416→\n   417→  // Start the VRF spin (permissionless — any player can trigger after countdown)\n   418→  const startSpin = useCallback(async () => {\n   419→    if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n   420→      setError(\"No active round.\");\n   421→      return;\n   422→    }\n   423→\n   424→    setSpinning(true);\n   425→    setError(null);\n   426→    try {\n   427→      const tx = await buildStartSpinTx(\n   428→        connection,\n   429→        publicKey,\n   430→        activeRound.tier,\n   431→        activeRoundMeta.roundNumber,\n   432→      );\n   433→      await sendAndConfirm(tx);\n   434→\n   435→      // Refresh active round — should now be in \"spinning\" phase\n   436→      const updated = await fetchRound(\n   437→        connection,\n   438→        activeRoundMeta.tierIndex,\n   439→        activeRoundMeta.roundNumber,\n   440→        publicKey.toBase58(),\n   441→      );\n   442→      if (updated) {\n   443→        setActiveRound(updated);\n   444→      }\n   445→    } catch (err) {\n   446→      setError(parseTransactionError(err));\n   447→    } finally {\n   448→      setSpinning(false);\n   449→    }\n   450→  }, [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm]);\n   451→\n   452→  // Claim payout for winning round (manual trigger)\n   453→  const claimPayout = useCallback(async () => {\n   454→    if (!publicKey || !activeRound || !activeRoundMeta) {\n   455→      setError(\"No active round to claim.\");\n   456→      return;\n   457→    }\n   458→\n   459→    setClaiming(true);\n   460→    setError(null);\n   461→    try {\n   462→      const tx = await buildClaimPayoutTx(\n   463→        connection,\n   464→        publicKey,\n   465→        activeRound.tier,\n   466→        activeRoundMeta.roundNumber,\n   467→      );\n   468→      await sendAndConfirm(tx);\n   469→\n   470→      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n   471→\n   472→      // Auto-transition back to lobby\n   473→      completionTimeoutRef.current = setTimeout(() => {\n   474→        completionTimeoutRef.current = null;\n   475→        setActiveRound(null);\n   476→        setActiveRoundMeta(null);\n   477→        void refreshRounds();\n   478→      }, 5000);\n   479→    } catch (err) {\n   480→      setError(parseTransactionError(err));\n   481→    } finally {\n   482→      setClaiming(false);\n   483→    }\n   484→  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n   485→\n   486→  // Leave round (just clears UI — funds are committed on-chain)\n   487→  const leaveRound = useCallback(() => {\n   488→    if (completionTimeoutRef.current) {\n   489→      clearTimeout(completionTimeoutRef.current);\n   490→      completionTimeoutRef.current = null;\n   491→    }\n   492→    setActiveRound(null);\n   493→    setActiveRoundMeta(null);\n   494→    setUserLeftRound(true);\n   495→    void refreshRounds();\n   496→  }, [refreshRounds]);\n   497→\n   498→  // Auto-select tier based on active round\n   499→  useEffect(() => {\n   500→    if (activeRound && !selectedTier) {\n   501→      setSelectedTier(activeRound.tier);\n   502→    }\n   503→  }, [activeRound, selectedTier]);\n   504→\n   505→  // Reset userLeftRound when joining a new round\n   506→  useEffect(() => {\n   507→    if (activeRound) {\n   508→      setUserLeftRound(false);\n   509→    }\n   510→  }, [activeRound]);\n   511→\n   512→  // Check for existing active round on wallet connect\n   513→  // (look through tier statuses for a round where user is a participant)\n   514→  useEffect(() => {\n   515→    if (publicKey && !activeRound && !userLeftRound && tierStatuses.length > 0) {\n   516→      const wallet = publicKey.toBase58();\n   517→      for (const status of tierStatuses) {\n   518→        if (\n   519→          status.currentRound &&\n   520→          status.currentRound.phase !== \"complete\" &&\n   521→          status.currentRound.players.some((p) => p.address === wallet)\n   522→        ) {\n   523→          setActiveRound(status.currentRound);\n   524→          // Derive round meta\n   525→          const tierIndex = TIER_VALUES[status.tier];\n   526→          void fetchRoundNumberForTier(connection, tierIndex)\n   527→            .then((roundNumber) => {\n   528→              setActiveRoundMeta({ tierIndex, roundNumber });\n   529→            })\n   530→            .catch(() => {\n   531→              // Ignore — meta will be set on next poll\n   532→            });\n   533→          break;\n   534→        }\n   535→      }\n   536→    }\n   537→  }, [publicKey, activeRound, userLeftRound, tierStatuses, connection]);\n   538→\n   539→  const value: LordOfRngsContextValue = {\n   540→    activeRound,\n   541→    tierStatuses,\n   542→    userHistory,\n   543→    selectedTier,\n   544→    entryCount,\n   545→    loading,\n   546→    joining,\n   547→    buyingMore,\n   548→    claiming,\n   549→    spinning,\n   550→    error,\n   551→    clearError,\n   552→    setSelectedTier,\n   553→    setEntryCount,\n   554→    joinTierRound,\n   555→    buyMoreEntriesAction,\n   556→    startSpin,\n   557→    claimPayout,\n   558→    leaveRound,\n   559→    refreshRounds,\n   560→  };\n   561→\n   562→  return (\n   563→    <LordOfRngsContext.Provider value={value}>\n   564→      {children}\n   565→    </LordOfRngsContext.Provider>\n   566→  );\n   567→}\n   568→\n   569→export function useLordOfRngs(): LordOfRngsContextValue {\n   570→  const context = useContext(LordOfRngsContext);\n   571→  if (!context) {\n   572→    throw new Error(\"useLordOfRngs must be used within LordOfRngsProvider\");\n   573→  }\n   574→  return context;\n   575→}\n   576→"}]},"parent_tool_use_id":"toolu_018DDqz12txRzTy3MKnFxeyx","session_id":"460d6ed6-55a6-44c8-8f2f-a24854f1a42b","uuid":"94fd83cc-d15d-409a-af56-2d06cb1cac77"}
