{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KgmsaJMAEd29s2Q9q8cz2u","type":"tool_result","content":"   891→function FairnessPage() {\n   892→  const { connection } = useConnection();\n   893→  const [activeTab, setActiveTab] = useState<'how' | 'verify' | 'seeds' | 'history'>('how');\n   894→  const [serverSeed, setServerSeed] = useState('');\n   895→  const [publicSeed, setPublicSeed] = useState('');\n   896→  // Coinflip VRF verification state\n   897→  const [coinflipTxSig, setCoinflipTxSig] = useState('');\n   898→  const [coinflipResult, setCoinflipResult] = useState<CoinflipVerificationResult | null>(null);\n   899→  const [coinflipVerifying, setCoinflipVerifying] = useState(false);\n   900→  const [coinflipError, setCoinflipError] = useState<string | null>(null);\n   901→  const [roundId, setRoundId] = useState('');\n   902→  const [gameId, setGameId] = useState('crash');\n   903→  const [commitmentHash, setCommitmentHash] = useState('');\n   904→  const [verificationResult, setVerificationResult] = useState<{\n   905→    valid: boolean;\n   906→    message: string;\n   907→    crashPoint?: string;\n   908→  } | null>(null);\n   909→\n   910→  // SHA-256 hash function (using Web Crypto API)\n   911→  const sha256 = async (message: string): Promise<string> => {\n   912→    const encoder = new TextEncoder();\n   913→    const data = encoder.encode(message);\n   914→    const hashBuffer = await crypto.subtle.digest('SHA-256', data);\n   915→    const hashArray = Array.from(new Uint8Array(hashBuffer));\n   916→    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n   917→  };\n   918→\n   919→  // HMAC-SHA256 function\n   920→  const hmacSha256 = async (key: string, message: string): Promise<string> => {\n   921→    const encoder = new TextEncoder();\n   922→    const keyData = encoder.encode(key);\n   923→    const messageData = encoder.encode(message);\n   924→\n   925→    const cryptoKey = await crypto.subtle.importKey(\n   926→      'raw',\n   927→      keyData,\n   928→      { name: 'HMAC', hash: 'SHA-256' },\n   929→      false,\n   930→      ['sign']\n   931→    );\n   932→\n   933→    const signature = await crypto.subtle.sign('HMAC', cryptoKey, messageData);\n   934→    const hashArray = Array.from(new Uint8Array(signature));\n   935→    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n   936→  };\n   937→\n   938→  // Convert hash to crash point (standard algorithm)\n   939→  const hashToCrashPoint = (hash: string): number => {\n   940→    // Take first 13 hex characters (52 bits)\n   941→    const h = parseInt(hash.substring(0, 13), 16);\n   942→    // House edge: 1% (1 in 100 instant crash)\n   943→    const e = Math.pow(2, 52);\n   944→    const result = Math.floor((100 * e - h) / (e - h)) / 100;\n   945→    return Math.max(1.00, result);\n   946→  };\n   947→\n   948→  // Verify commitment\n   949→  const verifyCommitment = async () => {\n   950→    if (!serverSeed) {\n   951→      setVerificationResult({\n   952→        valid: false,\n   953→        message: 'Please enter a server seed'\n   954→      });\n   955→      return;\n   956→    }\n   957→\n   958→    const computedHash = await sha256(serverSeed);\n   959→\n   960→    if (commitmentHash) {\n   961→      const isValid = computedHash.toLowerCase() === commitmentHash.toLowerCase();\n   962→      setVerificationResult({\n   963→        valid: isValid,\n   964→        message: isValid\n   965→          ? 'Commitment verified! The server seed matches the published hash.'\n   966→          : 'Commitment FAILED! The server seed does not match the published hash.'\n   967→      });\n   968→    } else {\n   969→      setVerificationResult({\n   970→        valid: true,\n   971→        message: `Computed commitment hash: ${computedHash}`\n   972→      });\n   973→    }\n   974→  };\n   975→\n   976→  // Calculate crash point\n   977→  const calculateCrashPoint = async () => {\n   978→    if (!serverSeed || !publicSeed) {\n   979→      setVerificationResult({\n   980→        valid: false,\n   981→        message: 'Please enter both server seed and public seed'\n   982→      });\n   983→      return;\n   984→    }\n   985→\n   986→    // Combine seeds with round info\n   987→    const message = `${publicSeed}:${roundId}:${gameId}`;\n   988→    const hash = await hmacSha256(serverSeed, message);\n   989→    const crashPoint = hashToCrashPoint(hash);\n   990→\n   991→    setVerificationResult({\n   992→      valid: true,\n   993→      message: `Round outcome verified successfully.`,\n   994→      crashPoint: crashPoint.toFixed(2)\n   995→    });\n   996→  };\n   997→\n   998→  // Coinflip VRF verification\n   999→  const verifyCoinflipTx = async () => {\n  1000→    if (!coinflipTxSig.trim()) {\n  1001→      setCoinflipError('Please enter a claim transaction signature');\n  1002→      return;\n  1003→    }\n  1004→    setCoinflipVerifying(true);\n  1005→    setCoinflipError(null);\n  1006→    setCoinflipResult(null);\n  1007→    try {\n  1008→      const result = await verifyCoinflipMatch(connection, coinflipTxSig.trim());\n  1009→      setCoinflipResult(result);\n  1010→    } catch (err) {\n  1011→      setCoinflipError(err instanceof Error ? err.message : 'Verification failed');\n  1012→    } finally {\n  1013→      setCoinflipVerifying(false);\n  1014→    }\n  1015→  };\n  1016→\n  1017→  // Mock recent rounds data\n  1018→  const recentRounds = [\n  1019→    { id: '847291', game: 'Crash', result: '2.47x', commitment: 'a3f2...8e1c', verified: true },\n  1020→    { id: '847290', game: 'Crash', result: '1.23x', commitment: 'b7e1...2f9a', verified: true },\n  1021→    { id: '847289', game: 'Lord of the RNGs', result: 'Player_42', commitment: 'c9d3...7b4e', verified: true },\n  1022→    { id: '847288', game: 'Close Call', result: 'GREEN', commitment: 'd2a8...1c5f', verified: true },\n  1023→    { id: '847287', game: 'Coinflip', result: 'HEADS', commitment: 'e5f6...9d2b', verified: true },\n  1024→  ];\n  1025→\n  1026→  // Mock active seeds\n  1027→  const activeSeeds = [\n  1028→    { game: 'Crash', tier: 'All', commitment: 'f1e2d3c4b5a6978...', status: 'Active', expiresIn: '2:34' },\n  1029→    { game: 'Lord of the RNGs', tier: 'Gold', commitment: '9a8b7c6d5e4f321...', status: 'Betting', expiresIn: '0:45' },\n  1030→    { game: 'Close Call', tier: 'All', commitment: '1a2b3c4d5e6f789...', status: 'Active', expiresIn: '0:12' },\n  1031→  ];\n  1032→\n  1033→  return (\n  1034→    <div className=\"fairness-page\">\n  1035→      <div className=\"fairness-header\">\n  1036→        <h2>Provably Fair Verification</h2>\n  1037→        <p className=\"fairness-subtitle\">Every outcome is cryptographically verifiable</p>\n  1038→      </div>\n  1039→\n  1040→      {/* Tab Navigation */}\n  1041→      <div className=\"fairness-tabs\">\n  1042→        <button\n  1043→          className={`fairness-tab ${activeTab === 'how' ? 'active' : ''}`}\n  1044→          onClick={() => setActiveTab('how')}\n  1045→        >\n  1046→          How It Works\n  1047→        </button>\n  1048→        <button\n  1049→          className={`fairness-tab ${activeTab === 'verify' ? 'active' : ''}`}\n  1050→          onClick={() => setActiveTab('verify')}\n  1051→        >\n  1052→          Verify Round\n  1053→        </button>\n  1054→        <button\n  1055→          className={`fairness-tab ${activeTab === 'seeds' ? 'active' : ''}`}\n  1056→          onClick={() => setActiveTab('seeds')}\n  1057→        >\n  1058→          Active Seeds\n  1059→        </button>\n  1060→        <button\n  1061→          className={`fairness-tab ${activeTab === 'history' ? 'active' : ''}`}\n  1062→          onClick={() => setActiveTab('history')}\n  1063→        >\n  1064→          History\n  1065→        </button>\n  1066→      </div>\n  1067→\n  1068→      {/* Tab Content */}\n  1069→      <div className=\"fairness-content\">\n  1070→        {activeTab === 'how' && (\n  1071→          <div className=\"fairness-how\">\n  1072→            <div className=\"fairness-section\">\n  1073→              <h3>Why Provably Fair?</h3>\n  1074→              <p>\n  1075→                Traditional online games require you to trust that the house isn't cheating.\n  1076→                Provably fair systems eliminate this trust requirement by using cryptographic\n  1077→                commitments that can be independently verified by anyone.\n  1078→              </p>\n  1079→            </div>\n  1080→\n  1081→            <div className=\"fairness-section\">\n  1082→              <h3>Pattern 1: Commit-Reveal + Blockhash</h3>\n  1083→              <p className=\"pattern-label\">Used by: Crash, Close Call, Game of Trades</p>\n  1084→              <div className=\"fairness-steps\">\n  1085→                <div className=\"step\">\n  1086→                  <span className=\"step-num\">1</span>\n  1087→                  <div className=\"step-content\">\n  1088→                    <strong>Before Betting Opens</strong>\n  1089→                    <p>Server generates a random seed and publishes its SHA-256 hash (commitment)</p>\n  1090→                  </div>\n  1091→                </div>\n  1092→                <div className=\"step\">\n  1093→                  <span className=\"step-num\">2</span>\n  1094→                  <div className=\"step-content\">\n  1095→                    <strong>During Betting</strong>\n  1096→                    <p>Players place bets. The server cannot change its seed (hash is already public)</p>\n  1097→                  </div>\n  1098→                </div>\n  1099→                <div className=\"step\">\n  1100→                  <span className=\"step-num\">3</span>\n  1101→                  <div className=\"step-content\">\n  1102→                    <strong>At Round Start</strong>\n  1103→                    <p>A future Solana blockhash becomes the public seed (unpredictable by server)</p>\n  1104→                  </div>\n  1105→                </div>\n  1106→                <div className=\"step\">\n  1107→                  <span className=\"step-num\">4</span>\n  1108→                  <div className=\"step-content\">\n  1109→                    <strong>After Round</strong>\n  1110→                    <p>Server reveals its seed. Anyone can verify: SHA-256(seed) = commitment</p>\n  1111→                  </div>\n  1112→                </div>\n  1113→              </div>\n  1114→              <div className=\"formula-box\">\n  1115→                <code>outcome = HMAC-SHA256(serverSeed, publicSeed || roundId || gameId)</code>\n  1116→              </div>\n  1117→            </div>\n  1118→\n  1119→            <div className=\"fairness-section\">\n  1120→              <h3>Pattern 2: On-Chain VRF</h3>\n  1121→              <p className=\"pattern-label\">Used by: Lord of the RNGs, Coinflip, Tug of Earn</p>\n  1122→              <div className=\"fairness-steps\">\n  1123→                <div className=\"step\">\n  1124→                  <span className=\"step-num\">1</span>\n  1125→                  <div className=\"step-content\">\n  1126→                    <strong>Round Enters Resolution</strong>\n  1127→                    <p>The on-chain program requests randomness from a VRF provider</p>\n  1128→                  </div>\n  1129→                </div>\n  1130→                <div className=\"step\">\n  1131→                  <span className=\"step-num\">2</span>\n  1132→                  <div className=\"step-content\">\n  1133→                    <strong>VRF Fulfillment</strong>\n  1134→                    <p>Provider generates verifiable random bytes with a cryptographic proof</p>\n  1135→                  </div>\n  1136→                </div>\n  1137→                <div className=\"step\">\n  1138→                  <span className=\"step-num\">3</span>\n  1139→                  <div className=\"step-content\">\n  1140→                    <strong>On-Chain Verification</strong>\n  1141→                    <p>Program verifies the proof and uses the result for winner selection</p>\n  1142→                  </div>\n  1143→                </div>\n  1144→                <div className=\"step\">\n  1145→                  <span className=\"step-num\">4</span>\n  1146→                  <div className=\"step-content\">\n  1147→                    <strong>Permanent Record</strong>\n  1148→                    <p>Result and proof stored on-chain forever - viewable on Solana explorer</p>\n  1149→                  </div>\n  1150→                </div>\n  1151→              </div>\n  1152→            </div>\n  1153→\n  1154→            <div className=\"fairness-section\">\n  1155→              <h3>What Can't Be Manipulated</h3>\n  1156→              <div className=\"guarantees\">\n  1157→                <div className=\"guarantee\">\n  1158→                  <span className=\"check-icon\">✓</span>\n  1159→                  <span>Server cannot predict the blockhash used as public seed</span>\n  1160→                </div>\n  1161→                <div className=\"guarantee\">\n  1162→                  <span className=\"check-icon\">✓</span>\n  1163→                  <span>Server cannot change its seed after publishing the commitment</span>\n  1164→                </div>\n  1165→                <div className=\"guarantee\">\n  1166→                  <span className=\"check-icon\">✓</span>\n  1167→                  <span>VRF proofs are mathematically verifiable - forgery is impossible</span>\n  1168→                </div>\n  1169→                <div className=\"guarantee\">\n  1170→                  <span className=\"check-icon\">✓</span>\n  1171→                  <span>All settlement happens on-chain with public transaction history</span>\n  1172→                </div>\n  1173→              </div>\n  1174→            </div>\n  1175→          </div>\n  1176→        )}\n  1177→\n  1178→        {activeTab === 'verify' && (\n  1179→          <div className=\"fairness-verify\">\n  1180→            <div className=\"verify-section\">\n  1181→              <h3>Verify a Round</h3>\n  1182→              <p>Enter the seeds from a completed round to independently verify the outcome.</p>\n  1183→\n  1184→              <div className=\"verify-form\">\n  1185→                <div className=\"form-group\">\n  1186→                  <label>Game</label>\n  1187→                  <select\n  1188→                    value={gameId}\n  1189→                    onChange={(e) => setGameId(e.target.value)}\n  1190→                    className=\"verify-select\"\n  1191→                  >\n  1192→                    <option value=\"crash\">Crypto Crash Simulator</option>\n  1193→                    <option value=\"close-call\">Close Call</option>\n  1194→                    <option value=\"lord-of-rngs\">Lord of the RNGs</option>\n  1195→                    <option value=\"coinflip\">Coinflip</option>\n  1196→                    <option value=\"game-of-trades\">Game of Trades</option>\n  1197→                  </select>\n  1198→                </div>\n  1199→\n  1200→                <div className=\"form-group\">\n  1201→                  <label>Server Seed (revealed after round)</label>\n  1202→                  <input\n  1203→                    type=\"text\"\n  1204→                    value={serverSeed}\n  1205→                    onChange={(e) => setServerSeed(e.target.value)}\n  1206→                    placeholder=\"e.g., a1b2c3d4e5f6...\"\n  1207→                    className=\"verify-input\"\n  1208→                  />\n  1209→                </div>\n  1210→\n  1211→                <div className=\"form-group\">\n  1212→                  <label>Public Seed (Solana blockhash)</label>\n  1213→                  <input\n  1214→                    type=\"text\"\n  1215→                    value={publicSeed}\n  1216→                    onChange={(e) => setPublicSeed(e.target.value)}\n  1217→                    placeholder=\"e.g., 5eykt4UsFv8P8NJdTREpY1vzqKqZKvdpKuc147dw2N9d\"\n  1218→                    className=\"verify-input\"\n  1219→                  />\n  1220→                </div>\n  1221→\n  1222→                <div className=\"form-row\">\n  1223→                  <div className=\"form-group\">\n  1224→                    <label>Round ID</label>\n  1225→                    <input\n  1226→                      type=\"text\"\n  1227→                      value={roundId}\n  1228→                      onChange={(e) => setRoundId(e.target.value)}\n  1229→                      placeholder=\"e.g., 847291\"\n  1230→                      className=\"verify-input\"\n  1231→                    />\n  1232→                  </div>\n  1233→\n  1234→                  <div className=\"form-group\">\n  1235→                    <label>Commitment Hash (optional)</label>\n  1236→                    <input\n  1237→                      type=\"text\"\n  1238→                      value={commitmentHash}\n  1239→                      onChange={(e) => setCommitmentHash(e.target.value)}\n  1240→                      placeholder=\"SHA-256 hash to verify against\"\n  1241→                      className=\"verify-input\"\n  1242→                    />\n  1243→                  </div>\n  1244→                </div>\n  1245→\n  1246→                <div className=\"verify-buttons\">\n  1247→                  <button onClick={verifyCommitment} className=\"verify-action-btn\">\n  1248→                    Verify Commitment\n  1249→                  </button>\n  1250→                  <button onClick={calculateCrashPoint} className=\"verify-action-btn primary\">\n  1251→                    Calculate Outcome\n  1252→                  </button>\n  1253→                </div>\n  1254→\n  1255→                {verificationResult && (\n  1256→                  <div className={`verification-result ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n  1257→                    <div className=\"result-status\">\n  1258→                      <span className={`status-icon ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n  1259→                        {verificationResult.valid ? '✓' : '✗'}\n  1260→                      </span>\n  1261→                      <span className=\"status-text\">{verificationResult.message}</span>\n  1262→                    </div>\n  1263→                    {verificationResult.crashPoint && (\n  1264→                      <div className=\"result-value\">\n  1265→                        <span className=\"result-label\">Crash Point:</span>\n  1266→                        <span className=\"crash-point\">{verificationResult.crashPoint}x</span>\n  1267→                      </div>\n  1268→                    )}\n  1269→                  </div>\n  1270→                )}\n  1271→              </div>\n  1272→            </div>\n  1273→\n  1274→            <div className=\"verify-section\">\n  1275→              <h3>Quick Lookup</h3>\n  1276→              <p>Enter a round ID to fetch its verification data automatically.</p>\n  1277→              <div className=\"quick-lookup\">\n  1278→                <input\n  1279→                  type=\"text\"\n  1280→                  placeholder=\"Enter Round ID...\"\n  1281→                  className=\"verify-input\"\n  1282→                />\n  1283→                <button className=\"lookup-btn\">Lookup</button>\n  1284→              </div>\n  1285→            </div>\n  1286→\n  1287→            <div className=\"verify-section\">\n  1288→              <h3>Coinflip VRF Verification</h3>\n  1289→              <p>Paste a coinflip claim transaction signature to verify the outcome using on-chain VRF data.</p>\n  1290→              <div className=\"verify-form\">\n  1291→                <div className=\"form-group\">\n  1292→                  <label>Claim Transaction Signature</label>\n  1293→                  <input\n  1294→                    type=\"text\"\n  1295→                    value={coinflipTxSig}\n  1296→                    onChange={(e) => setCoinflipTxSig(e.target.value)}\n  1297→                    placeholder=\"e.g., 5wH...3kF\"\n  1298→                    className=\"verify-input\"\n  1299→                  />\n  1300→                </div>\n  1301→                <div className=\"verify-buttons\">\n  1302→                  <button\n  1303→                    onClick={verifyCoinflipTx}\n  1304→                    className=\"verify-action-btn primary\"\n  1305→                    disabled={coinflipVerifying}\n  1306→                  >\n  1307→                    {coinflipVerifying ? 'Verifying...' : 'Verify Coinflip'}\n  1308→                  </button>\n  1309→                </div>\n  1310→                {coinflipError && (\n  1311→                  <div className=\"verification-result invalid\">\n  1312→                    <div className=\"result-status\">\n  1313→                      <span className=\"status-icon invalid\">&#10007;</span>\n  1314→                      <span className=\"status-text\">{coinflipError}</span>\n  1315→                    </div>\n  1316→                  </div>\n  1317→                )}\n  1318→                {coinflipResult && (\n  1319→                  <div className={`verification-result ${coinflipResult.verified ? 'valid' : 'invalid'}`}>\n  1320→                    <div className=\"result-status\">\n  1321→                      <span className={`status-icon ${coinflipResult.verified ? 'valid' : 'invalid'}`}>\n  1322→                        {coinflipResult.verified ? '\\u2713' : '\\u2717'}\n  1323→                      </span>\n  1324→                      <span className=\"status-text\">\n  1325→                        {coinflipResult.verified ? 'VRF verification passed' : 'VRF verification failed'}\n  1326→                      </span>\n  1327→                    </div>\n  1328→                    <div className=\"coinflip-vrf-details\">\n  1329→                      <div className=\"coinflip-vrf-row\">\n  1330→                        <span>Derived Result</span>\n  1331→                        <span className={coinflipResult.derivedResult === 'heads' ? 'vrf-heads' : 'vrf-tails'}>\n  1332→                          {coinflipResult.derivedResult.toUpperCase()}\n  1333→                        </span>\n  1334→                      </div>\n  1335→                      <div className=\"coinflip-vrf-row\">\n  1336→                        <span>Winner</span>\n  1337→                        <span className=\"vrf-hash\" title={coinflipResult.winner}>\n  1338→                          {coinflipResult.winner.slice(0, 8)}...{coinflipResult.winner.slice(-8)}\n  1339→                        </span>\n  1340→                      </div>\n  1341→                      <div className=\"coinflip-vrf-row\">\n  1342→                        <span>Randomness</span>\n  1343→                        <span className=\"vrf-hash\" title={coinflipResult.randomnessHex}>\n  1344→                          {coinflipResult.randomnessHex.slice(0, 16)}...\n  1345→                        </span>\n  1346→                      </div>\n  1347→                      <div className=\"coinflip-vrf-row\">\n  1348→                        <span>VRF Fulfilled</span>\n  1349→                        <span>{coinflipResult.vrfFulfilled ? 'Yes' : 'No'}</span>\n  1350→                      </div>\n  1351→                      <div className=\"coinflip-vrf-row\">\n  1352→                        <span>Creator</span>\n  1353→                        <span className=\"vrf-hash\" title={coinflipResult.creator}>\n  1354→                          {coinflipResult.creator.slice(0, 8)}...{coinflipResult.creator.slice(-8)}\n  1355→                        </span>\n  1356→                      </div>\n  1357→                      <div className=\"coinflip-vrf-row\">\n  1358→                        <span>Opponent</span>\n  1359→                        <span className=\"vrf-hash\" title={coinflipResult.opponent}>\n  1360→                          {coinflipResult.opponent.slice(0, 8)}...{coinflipResult.opponent.slice(-8)}\n  1361→                        </span>\n  1362→                      </div>\n  1363→                    </div>\n  1364→                  </div>\n  1365→                )}\n  1366→              </div>\n  1367→            </div>\n  1368→          </div>\n  1369→        )}\n  1370→\n  1371→        {activeTab === 'seeds' && (\n  1372→          <div className=\"fairness-seeds\">\n  1373→            <h3>Active Commitments</h3>\n  1374→            <p>These are the current seed commitments for ongoing rounds. The actual seeds will be revealed after each round completes.</p>\n  1375→\n  1376→            <div className=\"seeds-table\">\n  1377→              <div className=\"seeds-header\">\n  1378→                <span>Game</span>\n  1379→                <span>Tier</span>\n  1380→                <span>Commitment Hash</span>\n  1381→                <span>Status</span>\n  1382→                <span>Time</span>\n  1383→              </div>\n  1384→              {activeSeeds.map((seed, i) => (\n  1385→                <div className=\"seed-row\" key={i}>\n  1386→                  <span className=\"seed-game\">{seed.game}</span>\n  1387→                  <span className=\"seed-tier\">{seed.tier}</span>\n  1388→                  <span className=\"seed-hash\">{seed.commitment}</span>\n  1389→                  <span className={`seed-status ${seed.status.toLowerCase()}`}>{seed.status}</span>\n  1390→                  <span className=\"seed-time\">{seed.expiresIn}</span>\n  1391→                </div>\n  1392→              ))}\n  1393→            </div>\n  1394→\n  1395→            <div className=\"seeds-info\">\n  1396→              <h4>Understanding Commitments</h4>\n  1397→              <p>\n  1398→                A commitment is the SHA-256 hash of the server's secret seed. It's published before\n  1399→                betting opens, ensuring the server cannot change its seed after seeing player bets.\n  1400→                After the round, you can verify that SHA-256(revealed_seed) equals the commitment.\n  1401→              </p>\n  1402→            </div>\n  1403→          </div>\n  1404→        )}\n  1405→\n  1406→        {activeTab === 'history' && (\n  1407→          <div className=\"fairness-history\">\n  1408→            <h3>Recent Verified Rounds</h3>\n  1409→            <p>All completed rounds with their verification status.</p>\n  1410→\n  1411→            <div className=\"history-table\">\n  1412→              <div className=\"history-header\">\n  1413→                <span>Round</span>\n  1414→                <span>Game</span>\n  1415→                <span>Result</span>\n  1416→                <span>Commitment</span>\n  1417→                <span>Status</span>\n  1418→                <span>Action</span>\n  1419→              </div>\n  1420→              {recentRounds.map((round) => (\n  1421→                <div className=\"history-row\" key={round.id}>\n  1422→                  <span className=\"round-id\">#{round.id}</span>\n  1423→                  <span className=\"round-game\">{round.game}</span>\n  1424→                  <span className=\"round-result\">{round.result}</span>\n  1425→                  <span className=\"round-commitment\">{round.commitment}</span>\n  1426→                  <span className={`round-status ${round.verified ? 'verified' : 'pending'}`}>\n  1427→                    {round.verified ? 'Verified' : 'Pending'}\n  1428→                  </span>\n  1429→                  <button className=\"round-verify-btn\">Verify</button>\n  1430→                </div>\n  1431→              ))}\n  1432→            </div>\n  1433→\n  1434→            <div className=\"history-pagination\">\n  1435→              <button className=\"page-btn\" disabled>Previous</button>\n  1436→              <span className=\"page-info\">Page 1 of 1</span>\n  1437→              <button className=\"page-btn\" disabled>Next</button>\n  1438→            </div>\n  1439→          </div>\n  1440→        )}\n  1441→      </div>\n  1442→    </div>\n  1443→  );\n  1444→}\n  1445→\n  1446→function NotFoundPage() {\n  1447→  return (\n  1448→    <div className=\"not-found\">\n  1449→      <div className=\"error-code\">\n  1450→        <span className=\"digit\">4</span>\n  1451→        <span className=\"digit zero\">0</span>\n  1452→        <span className=\"digit\">4</span>\n  1453→      </div>\n  1454→      <h2>Game Over</h2>\n  1455→      <p>The level you're looking for doesn't exist.</p>\n  1456→      <p className=\"hint\">Maybe try a different warp pipe?</p>\n  1457→      <Link to=\"/\" className=\"continue-btn\">\n  1458→        Continue?\n  1459→      </Link>\n  1460→    </div>\n  1461→  );\n  1462→}\n  1463→"}]},"parent_tool_use_id":null,"session_id":"460d6ed6-55a6-44c8-8f2f-a24854f1a42b","uuid":"8c23b6b3-a7ab-4ea4-a298-b6892ecab71f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/App.tsx","content":"function FairnessPage() {\n  const { connection } = useConnection();\n  const [activeTab, setActiveTab] = useState<'how' | 'verify' | 'seeds' | 'history'>('how');\n  const [serverSeed, setServerSeed] = useState('');\n  const [publicSeed, setPublicSeed] = useState('');\n  // Coinflip VRF verification state\n  const [coinflipTxSig, setCoinflipTxSig] = useState('');\n  const [coinflipResult, setCoinflipResult] = useState<CoinflipVerificationResult | null>(null);\n  const [coinflipVerifying, setCoinflipVerifying] = useState(false);\n  const [coinflipError, setCoinflipError] = useState<string | null>(null);\n  const [roundId, setRoundId] = useState('');\n  const [gameId, setGameId] = useState('crash');\n  const [commitmentHash, setCommitmentHash] = useState('');\n  const [verificationResult, setVerificationResult] = useState<{\n    valid: boolean;\n    message: string;\n    crashPoint?: string;\n  } | null>(null);\n\n  // SHA-256 hash function (using Web Crypto API)\n  const sha256 = async (message: string): Promise<string> => {\n    const encoder = new TextEncoder();\n    const data = encoder.encode(message);\n    const hashBuffer = await crypto.subtle.digest('SHA-256', data);\n    const hashArray = Array.from(new Uint8Array(hashBuffer));\n    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n  };\n\n  // HMAC-SHA256 function\n  const hmacSha256 = async (key: string, message: string): Promise<string> => {\n    const encoder = new TextEncoder();\n    const keyData = encoder.encode(key);\n    const messageData = encoder.encode(message);\n\n    const cryptoKey = await crypto.subtle.importKey(\n      'raw',\n      keyData,\n      { name: 'HMAC', hash: 'SHA-256' },\n      false,\n      ['sign']\n    );\n\n    const signature = await crypto.subtle.sign('HMAC', cryptoKey, messageData);\n    const hashArray = Array.from(new Uint8Array(signature));\n    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n  };\n\n  // Convert hash to crash point (standard algorithm)\n  const hashToCrashPoint = (hash: string): number => {\n    // Take first 13 hex characters (52 bits)\n    const h = parseInt(hash.substring(0, 13), 16);\n    // House edge: 1% (1 in 100 instant crash)\n    const e = Math.pow(2, 52);\n    const result = Math.floor((100 * e - h) / (e - h)) / 100;\n    return Math.max(1.00, result);\n  };\n\n  // Verify commitment\n  const verifyCommitment = async () => {\n    if (!serverSeed) {\n      setVerificationResult({\n        valid: false,\n        message: 'Please enter a server seed'\n      });\n      return;\n    }\n\n    const computedHash = await sha256(serverSeed);\n\n    if (commitmentHash) {\n      const isValid = computedHash.toLowerCase() === commitmentHash.toLowerCase();\n      setVerificationResult({\n        valid: isValid,\n        message: isValid\n          ? 'Commitment verified! The server seed matches the published hash.'\n          : 'Commitment FAILED! The server seed does not match the published hash.'\n      });\n    } else {\n      setVerificationResult({\n        valid: true,\n        message: `Computed commitment hash: ${computedHash}`\n      });\n    }\n  };\n\n  // Calculate crash point\n  const calculateCrashPoint = async () => {\n    if (!serverSeed || !publicSeed) {\n      setVerificationResult({\n        valid: false,\n        message: 'Please enter both server seed and public seed'\n      });\n      return;\n    }\n\n    // Combine seeds with round info\n    const message = `${publicSeed}:${roundId}:${gameId}`;\n    const hash = await hmacSha256(serverSeed, message);\n    const crashPoint = hashToCrashPoint(hash);\n\n    setVerificationResult({\n      valid: true,\n      message: `Round outcome verified successfully.`,\n      crashPoint: crashPoint.toFixed(2)\n    });\n  };\n\n  // Coinflip VRF verification\n  const verifyCoinflipTx = async () => {\n    if (!coinflipTxSig.trim()) {\n      setCoinflipError('Please enter a claim transaction signature');\n      return;\n    }\n    setCoinflipVerifying(true);\n    setCoinflipError(null);\n    setCoinflipResult(null);\n    try {\n      const result = await verifyCoinflipMatch(connection, coinflipTxSig.trim());\n      setCoinflipResult(result);\n    } catch (err) {\n      setCoinflipError(err instanceof Error ? err.message : 'Verification failed');\n    } finally {\n      setCoinflipVerifying(false);\n    }\n  };\n\n  // Mock recent rounds data\n  const recentRounds = [\n    { id: '847291', game: 'Crash', result: '2.47x', commitment: 'a3f2...8e1c', verified: true },\n    { id: '847290', game: 'Crash', result: '1.23x', commitment: 'b7e1...2f9a', verified: true },\n    { id: '847289', game: 'Lord of the RNGs', result: 'Player_42', commitment: 'c9d3...7b4e', verified: true },\n    { id: '847288', game: 'Close Call', result: 'GREEN', commitment: 'd2a8...1c5f', verified: true },\n    { id: '847287', game: 'Coinflip', result: 'HEADS', commitment: 'e5f6...9d2b', verified: true },\n  ];\n\n  // Mock active seeds\n  const activeSeeds = [\n    { game: 'Crash', tier: 'All', commitment: 'f1e2d3c4b5a6978...', status: 'Active', expiresIn: '2:34' },\n    { game: 'Lord of the RNGs', tier: 'Gold', commitment: '9a8b7c6d5e4f321...', status: 'Betting', expiresIn: '0:45' },\n    { game: 'Close Call', tier: 'All', commitment: '1a2b3c4d5e6f789...', status: 'Active', expiresIn: '0:12' },\n  ];\n\n  return (\n    <div className=\"fairness-page\">\n      <div className=\"fairness-header\">\n        <h2>Provably Fair Verification</h2>\n        <p className=\"fairness-subtitle\">Every outcome is cryptographically verifiable</p>\n      </div>\n\n      {/* Tab Navigation */}\n      <div className=\"fairness-tabs\">\n        <button\n          className={`fairness-tab ${activeTab === 'how' ? 'active' : ''}`}\n          onClick={() => setActiveTab('how')}\n        >\n          How It Works\n        </button>\n        <button\n          className={`fairness-tab ${activeTab === 'verify' ? 'active' : ''}`}\n          onClick={() => setActiveTab('verify')}\n        >\n          Verify Round\n        </button>\n        <button\n          className={`fairness-tab ${activeTab === 'seeds' ? 'active' : ''}`}\n          onClick={() => setActiveTab('seeds')}\n        >\n          Active Seeds\n        </button>\n        <button\n          className={`fairness-tab ${activeTab === 'history' ? 'active' : ''}`}\n          onClick={() => setActiveTab('history')}\n        >\n          History\n        </button>\n      </div>\n\n      {/* Tab Content */}\n      <div className=\"fairness-content\">\n        {activeTab === 'how' && (\n          <div className=\"fairness-how\">\n            <div className=\"fairness-section\">\n              <h3>Why Provably Fair?</h3>\n              <p>\n                Traditional online games require you to trust that the house isn't cheating.\n                Provably fair systems eliminate this trust requirement by using cryptographic\n                commitments that can be independently verified by anyone.\n              </p>\n            </div>\n\n            <div className=\"fairness-section\">\n              <h3>Pattern 1: Commit-Reveal + Blockhash</h3>\n              <p className=\"pattern-label\">Used by: Crash, Close Call, Game of Trades</p>\n              <div className=\"fairness-steps\">\n                <div className=\"step\">\n                  <span className=\"step-num\">1</span>\n                  <div className=\"step-content\">\n                    <strong>Before Betting Opens</strong>\n                    <p>Server generates a random seed and publishes its SHA-256 hash (commitment)</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">2</span>\n                  <div className=\"step-content\">\n                    <strong>During Betting</strong>\n                    <p>Players place bets. The server cannot change its seed (hash is already public)</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">3</span>\n                  <div className=\"step-content\">\n                    <strong>At Round Start</strong>\n                    <p>A future Solana blockhash becomes the public seed (unpredictable by server)</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">4</span>\n                  <div className=\"step-content\">\n                    <strong>After Round</strong>\n                    <p>Server reveals its seed. Anyone can verify: SHA-256(seed) = commitment</p>\n                  </div>\n                </div>\n              </div>\n              <div className=\"formula-box\">\n                <code>outcome = HMAC-SHA256(serverSeed, publicSeed || roundId || gameId)</code>\n              </div>\n            </div>\n\n            <div className=\"fairness-section\">\n              <h3>Pattern 2: On-Chain VRF</h3>\n              <p className=\"pattern-label\">Used by: Lord of the RNGs, Coinflip, Tug of Earn</p>\n              <div className=\"fairness-steps\">\n                <div className=\"step\">\n                  <span className=\"step-num\">1</span>\n                  <div className=\"step-content\">\n                    <strong>Round Enters Resolution</strong>\n                    <p>The on-chain program requests randomness from a VRF provider</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">2</span>\n                  <div className=\"step-content\">\n                    <strong>VRF Fulfillment</strong>\n                    <p>Provider generates verifiable random bytes with a cryptographic proof</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">3</span>\n                  <div className=\"step-content\">\n                    <strong>On-Chain Verification</strong>\n                    <p>Program verifies the proof and uses the result for winner selection</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">4</span>\n                  <div className=\"step-content\">\n                    <strong>Permanent Record</strong>\n                    <p>Result and proof stored on-chain forever - viewable on Solana explorer</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"fairness-section\">\n              <h3>What Can't Be Manipulated</h3>\n              <div className=\"guarantees\">\n                <div className=\"guarantee\">\n                  <span className=\"check-icon\">✓</span>\n                  <span>Server cannot predict the blockhash used as public seed</span>\n                </div>\n                <div className=\"guarantee\">\n                  <span className=\"check-icon\">✓</span>\n                  <span>Server cannot change its seed after publishing the commitment</span>\n                </div>\n                <div className=\"guarantee\">\n                  <span className=\"check-icon\">✓</span>\n                  <span>VRF proofs are mathematically verifiable - forgery is impossible</span>\n                </div>\n                <div className=\"guarantee\">\n                  <span className=\"check-icon\">✓</span>\n                  <span>All settlement happens on-chain with public transaction history</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {activeTab === 'verify' && (\n          <div className=\"fairness-verify\">\n            <div className=\"verify-section\">\n              <h3>Verify a Round</h3>\n              <p>Enter the seeds from a completed round to independently verify the outcome.</p>\n\n              <div className=\"verify-form\">\n                <div className=\"form-group\">\n                  <label>Game</label>\n                  <select\n                    value={gameId}\n                    onChange={(e) => setGameId(e.target.value)}\n                    className=\"verify-select\"\n                  >\n                    <option value=\"crash\">Crypto Crash Simulator</option>\n                    <option value=\"close-call\">Close Call</option>\n                    <option value=\"lord-of-rngs\">Lord of the RNGs</option>\n                    <option value=\"coinflip\">Coinflip</option>\n                    <option value=\"game-of-trades\">Game of Trades</option>\n                  </select>\n                </div>\n\n                <div className=\"form-group\">\n                  <label>Server Seed (revealed after round)</label>\n                  <input\n                    type=\"text\"\n                    value={serverSeed}\n                    onChange={(e) => setServerSeed(e.target.value)}\n                    placeholder=\"e.g., a1b2c3d4e5f6...\"\n                    className=\"verify-input\"\n                  />\n                </div>\n\n                <div className=\"form-group\">\n                  <label>Public Seed (Solana blockhash)</label>\n                  <input\n                    type=\"text\"\n                    value={publicSeed}\n                    onChange={(e) => setPublicSeed(e.target.value)}\n                    placeholder=\"e.g., 5eykt4UsFv8P8NJdTREpY1vzqKqZKvdpKuc147dw2N9d\"\n                    className=\"verify-input\"\n                  />\n                </div>\n\n                <div className=\"form-row\">\n                  <div className=\"form-group\">\n                    <label>Round ID</label>\n                    <input\n                      type=\"text\"\n                      value={roundId}\n                      onChange={(e) => setRoundId(e.target.value)}\n                      placeholder=\"e.g., 847291\"\n                      className=\"verify-input\"\n                    />\n                  </div>\n\n                  <div className=\"form-group\">\n                    <label>Commitment Hash (optional)</label>\n                    <input\n                      type=\"text\"\n                      value={commitmentHash}\n                      onChange={(e) => setCommitmentHash(e.target.value)}\n                      placeholder=\"SHA-256 hash to verify against\"\n                      className=\"verify-input\"\n                    />\n                  </div>\n                </div>\n\n                <div className=\"verify-buttons\">\n                  <button onClick={verifyCommitment} className=\"verify-action-btn\">\n                    Verify Commitment\n                  </button>\n                  <button onClick={calculateCrashPoint} className=\"verify-action-btn primary\">\n                    Calculate Outcome\n                  </button>\n                </div>\n\n                {verificationResult && (\n                  <div className={`verification-result ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n                    <div className=\"result-status\">\n                      <span className={`status-icon ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n                        {verificationResult.valid ? '✓' : '✗'}\n                      </span>\n                      <span className=\"status-text\">{verificationResult.message}</span>\n                    </div>\n                    {verificationResult.crashPoint && (\n                      <div className=\"result-value\">\n                        <span className=\"result-label\">Crash Point:</span>\n                        <span className=\"crash-point\">{verificationResult.crashPoint}x</span>\n                      </div>\n                    )}\n                  </div>\n                )}\n              </div>\n            </div>\n\n            <div className=\"verify-section\">\n              <h3>Quick Lookup</h3>\n              <p>Enter a round ID to fetch its verification data automatically.</p>\n              <div className=\"quick-lookup\">\n                <input\n                  type=\"text\"\n                  placeholder=\"Enter Round ID...\"\n                  className=\"verify-input\"\n                />\n                <button className=\"lookup-btn\">Lookup</button>\n              </div>\n            </div>\n\n            <div className=\"verify-section\">\n              <h3>Coinflip VRF Verification</h3>\n              <p>Paste a coinflip claim transaction signature to verify the outcome using on-chain VRF data.</p>\n              <div className=\"verify-form\">\n                <div className=\"form-group\">\n                  <label>Claim Transaction Signature</label>\n                  <input\n                    type=\"text\"\n                    value={coinflipTxSig}\n                    onChange={(e) => setCoinflipTxSig(e.target.value)}\n                    placeholder=\"e.g., 5wH...3kF\"\n                    className=\"verify-input\"\n                  />\n                </div>\n                <div className=\"verify-buttons\">\n                  <button\n                    onClick={verifyCoinflipTx}\n                    className=\"verify-action-btn primary\"\n                    disabled={coinflipVerifying}\n                  >\n                    {coinflipVerifying ? 'Verifying...' : 'Verify Coinflip'}\n                  </button>\n                </div>\n                {coinflipError && (\n                  <div className=\"verification-result invalid\">\n                    <div className=\"result-status\">\n                      <span className=\"status-icon invalid\">&#10007;</span>\n                      <span className=\"status-text\">{coinflipError}</span>\n                    </div>\n                  </div>\n                )}\n                {coinflipResult && (\n                  <div className={`verification-result ${coinflipResult.verified ? 'valid' : 'invalid'}`}>\n                    <div className=\"result-status\">\n                      <span className={`status-icon ${coinflipResult.verified ? 'valid' : 'invalid'}`}>\n                        {coinflipResult.verified ? '\\u2713' : '\\u2717'}\n                      </span>\n                      <span className=\"status-text\">\n                        {coinflipResult.verified ? 'VRF verification passed' : 'VRF verification failed'}\n                      </span>\n                    </div>\n                    <div className=\"coinflip-vrf-details\">\n                      <div className=\"coinflip-vrf-row\">\n                        <span>Derived Result</span>\n                        <span className={coinflipResult.derivedResult === 'heads' ? 'vrf-heads' : 'vrf-tails'}>\n                          {coinflipResult.derivedResult.toUpperCase()}\n                        </span>\n                      </div>\n                      <div className=\"coinflip-vrf-row\">\n                        <span>Winner</span>\n                        <span className=\"vrf-hash\" title={coinflipResult.winner}>\n                          {coinflipResult.winner.slice(0, 8)}...{coinflipResult.winner.slice(-8)}\n                        </span>\n                      </div>\n                      <div className=\"coinflip-vrf-row\">\n                        <span>Randomness</span>\n                        <span className=\"vrf-hash\" title={coinflipResult.randomnessHex}>\n                          {coinflipResult.randomnessHex.slice(0, 16)}...\n                        </span>\n                      </div>\n                      <div className=\"coinflip-vrf-row\">\n                        <span>VRF Fulfilled</span>\n                        <span>{coinflipResult.vrfFulfilled ? 'Yes' : 'No'}</span>\n                      </div>\n                      <div className=\"coinflip-vrf-row\">\n                        <span>Creator</span>\n                        <span className=\"vrf-hash\" title={coinflipResult.creator}>\n                          {coinflipResult.creator.slice(0, 8)}...{coinflipResult.creator.slice(-8)}\n                        </span>\n                      </div>\n                      <div className=\"coinflip-vrf-row\">\n                        <span>Opponent</span>\n                        <span className=\"vrf-hash\" title={coinflipResult.opponent}>\n                          {coinflipResult.opponent.slice(0, 8)}...{coinflipResult.opponent.slice(-8)}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                )}\n              </div>\n            </div>\n          </div>\n        )}\n\n        {activeTab === 'seeds' && (\n          <div className=\"fairness-seeds\">\n            <h3>Active Commitments</h3>\n            <p>These are the current seed commitments for ongoing rounds. The actual seeds will be revealed after each round completes.</p>\n\n            <div className=\"seeds-table\">\n              <div className=\"seeds-header\">\n                <span>Game</span>\n                <span>Tier</span>\n                <span>Commitment Hash</span>\n                <span>Status</span>\n                <span>Time</span>\n              </div>\n              {activeSeeds.map((seed, i) => (\n                <div className=\"seed-row\" key={i}>\n                  <span className=\"seed-game\">{seed.game}</span>\n                  <span className=\"seed-tier\">{seed.tier}</span>\n                  <span className=\"seed-hash\">{seed.commitment}</span>\n                  <span className={`seed-status ${seed.status.toLowerCase()}`}>{seed.status}</span>\n                  <span className=\"seed-time\">{seed.expiresIn}</span>\n                </div>\n              ))}\n            </div>\n\n            <div className=\"seeds-info\">\n              <h4>Understanding Commitments</h4>\n              <p>\n                A commitment is the SHA-256 hash of the server's secret seed. It's published before\n                betting opens, ensuring the server cannot change its seed after seeing player bets.\n                After the round, you can verify that SHA-256(revealed_seed) equals the commitment.\n              </p>\n            </div>\n          </div>\n        )}\n\n        {activeTab === 'history' && (\n          <div className=\"fairness-history\">\n            <h3>Recent Verified Rounds</h3>\n            <p>All completed rounds with their verification status.</p>\n\n            <div className=\"history-table\">\n              <div className=\"history-header\">\n                <span>Round</span>\n                <span>Game</span>\n                <span>Result</span>\n                <span>Commitment</span>\n                <span>Status</span>\n                <span>Action</span>\n              </div>\n              {recentRounds.map((round) => (\n                <div className=\"history-row\" key={round.id}>\n                  <span className=\"round-id\">#{round.id}</span>\n                  <span className=\"round-game\">{round.game}</span>\n                  <span className=\"round-result\">{round.result}</span>\n                  <span className=\"round-commitment\">{round.commitment}</span>\n                  <span className={`round-status ${round.verified ? 'verified' : 'pending'}`}>\n                    {round.verified ? 'Verified' : 'Pending'}\n                  </span>\n                  <button className=\"round-verify-btn\">Verify</button>\n                </div>\n              ))}\n            </div>\n\n            <div className=\"history-pagination\">\n              <button className=\"page-btn\" disabled>Previous</button>\n              <span className=\"page-info\">Page 1 of 1</span>\n              <button className=\"page-btn\" disabled>Next</button>\n            </div>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n\nfunction NotFoundPage() {\n  return (\n    <div className=\"not-found\">\n      <div className=\"error-code\">\n        <span className=\"digit\">4</span>\n        <span className=\"digit zero\">0</span>\n        <span className=\"digit\">4</span>\n      </div>\n      <h2>Game Over</h2>\n      <p>The level you're looking for doesn't exist.</p>\n      <p className=\"hint\">Maybe try a different warp pipe?</p>\n      <Link to=\"/\" className=\"continue-btn\">\n        Continue?\n      </Link>\n    </div>\n  );\n}\n","numLines":573,"startLine":891,"totalLines":1463}}}
