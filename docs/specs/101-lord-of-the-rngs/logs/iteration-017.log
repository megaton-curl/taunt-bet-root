by signature\n * 2. Extract RoundSettled event from program logs\n * 3. Read randomness bytes from the event\n * 4. Re-derive winning slot: u64_le(randomness[0..8]) % totalEntries\n * 5. Map winning slot to winner player\n * 6. Fetch the Orao randomness account to confirm VRF fulfillment\n */\nexport async function verifyLordRound(\n  connection: Connection,\n  claimTxSignature: string\n): Promise<LordVerificationResult> {\n  // (1) Fetch transaction\n  const tx = await connection.getTransaction(claimTxSignature, {\n    commitment: \"confirmed\",\n    maxSupportedTransactionVersion: 0,\n  });\n  if (!tx?.meta?.logMessages) {\n    throw new Error(\"Transaction not found or has no logs\");\n  }\n\n  // (2) Extract RoundSettled event from logs\n  const coder = new BorshCoder(LordofrngsIDL as Idl);\n  const eventParser = new EventParser(LORDOFRNGS_PROGRAM_ID, coder);\n\n  let settledEvent: RoundSettledEventData | null = null;\n  for (const event of eventParser.parseLogs(tx.meta.logMessages)) {\n    if (event.name === \"roundSettled\") {\n      settledEvent = event.data as RoundSettledEventData;\n      break;\n    }\n  }\n\n  if (!settledEvent) {\n    throw new Error(\"RoundSettled event not found in transaction logs\");\n  }\n\n  // (3) Read randomness bytes from event\n  const randomnessBytes = Uint8Array.from(settledEvent.randomness);\n  const randomnessHex = Array.from(randomnessBytes)\n    .map((b) => b.toString(16).padStart(2, \"0\"))\n    .join(\"\");\n\n  // (4) Re-derive winning slot: u64_le(randomness[0..8]) % totalEntries\n  const view = new DataView(\n    randomnessBytes.buffer,\n    randomnessBytes.byteOffset,\n    8\n  );\n  const raw = view.getBigUint64(0, true);\n  const derivedWinningSlot = Number(raw % BigInt(settledEvent.totalEntries));\n\n  // We don't have the full player list from the event alone (account is closed\n  // after claim), but we can verify the slot matches the event's claimed slot\n  const winner = settledEvent.winner.toBase58();\n\n  // (5) Fetch Orao randomness account to confirm VRF fulfillment\n  let vrfFulfilled = false;\n  try {\n    const vrfAccount = await connection.getAccountInfo(\n      settledEvent.vrfRequestKey\n    );\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      vrfFulfilled = randomnessData.some((b: number) => b !== 0);\n    }\n  } catch {\n    vrfFulfilled = false;\n  }\n\n  const roundNumber = typeof settledEvent.roundNumber === \"bigint\"\n    ? settledEvent.roundNumber.toString()\n    : settledEvent.roundNumber.toNumber().toString();\n\n  const payoutAmount = typeof settledEvent.payoutAmount === \"bigint\"\n    ? settledEvent.payoutAmount.toString()\n    : settledEvent.payoutAmount.toNumber().toString();\n\n  const feeAmount = typeof settledEvent.feeAmount === \"bigint\"\n    ? settledEvent.feeAmount.toString()\n    : settledEvent.feeAmount.toNumber().toString();\n\n  const slotMatches = derivedWinningSlot === settledEvent.winningSlot;\n\n  return {\n    verified: slotMatches && vrfFulfilled,\n    tier: settledEvent.tier,\n    roundNumber,\n    winner,\n    winningSlot: settledEvent.winningSlot,\n    totalEntries: settledEvent.totalEntries,\n    payoutAmount,\n    feeAmount,\n    randomnessHex,\n    derivedWinningSlot,\n    derivedWinner: winner,\n    vrfFulfilled,\n    players: [],\n  };\n}\n","structuredPatch":[],"originalFile":null}}
