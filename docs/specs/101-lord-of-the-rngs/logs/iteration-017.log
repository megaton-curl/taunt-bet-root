eRound.blockHash}>\n                      {activeRound.blockHash.slice(0, 8)}...{activeRound.blockHash.slice(-4)}\n                    </span>\n                  </div>\n                )}\n              </>\n            )}\n          </div>","newString":"          {/* Round Fairness Info — VRF-based */}\n          <div className=\"lotr-sidebar__fairness\">\n            <h4 className=\"lotr-sidebar__fairness-title\">Round Fairness</h4>\n            <div className=\"lotr-sidebar__fairness-row\">\n              <span>Round ID</span>\n              <span className=\"lotr-sidebar__hash\" title={activeRound.id}>\n                {activeRound.id.slice(-8)}\n              </span>\n            </div>\n            {activeRound.seedHash && (\n              <div className=\"lotr-sidebar__fairness-row\">\n                <span>VRF Request</span>\n                <span className=\"lotr-sidebar__hash\" title={activeRound.seedHash}>\n                  {activeRound.seedHash.slice(0, 8)}...{activeRound.seedHash.slice(-4)}\n                </span>\n              </div>\n            )}\n            {(activeRound.phase === \"revealing\" || activeRound.phase === \"complete\") && activeRound.vrfProof && (\n              <div className=\"lotr-sidebar__fairness-row\">\n                <span>VRF Proof</span>\n                <span className=\"lotr-sidebar__hash lotr-sidebar__hash--revealed\" title={activeRound.vrfProof}>\n                  {activeRound.vrfProof.slice(0, 8)}...{activeRound.vrfProof.slice(-4)}\n                </span>\n              </div>\n            )}\n            {activeRound.winningSlot !== undefined && (\n              <div className=\"lotr-sidebar__fairness-row\">\n                <span>Winning Slot</span>\n                <span>{activeRound.winningSlot} / {activeRound.totalEntries}</span>\n              </div>\n            )}\n          </div>","originalFile":"import { useState } from \"react\";\nimport {\n  GameLayout,\n  TIER_COLORS,\n  Modal,\n  type HistoryEntry,\n} from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\nimport {\n  LordOfRngsProvider,\n  useLordOfRngs,\n  TierLobby,\n  TierRoundView,\n  ActiveRoundView,\n  calculateOdds,\n  type Round,\n} from \"../features/lord-of-rngs\";\nimport { PlayerAvatarCompact } from \"../features/player-profile\";\n\nfunction LordOfRngsPageContent() {\n  const { connected, address, connect } = useWallet();\n  const {\n    activeRound,\n    tierStatuses,\n    userHistory,\n    selectedTier,\n    loading,\n    joining,\n    buyingMore,\n    setSelectedTier,\n    joinTierRound,\n    buyMoreEntriesAction,\n    leaveRound,\n  } = useLordOfRngs();\n\n  // State for history detail modal\n  const [selectedHistoryRound, setSelectedHistoryRound] = useState<Round | null>(null);\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((round) => {\n    const isWinner = round.winner === address;\n    const tierColor = TIER_COLORS[round.tier];\n    const tierCapitalized = round.tier.charAt(0).toUpperCase() + round.tier.slice(1);\n\n    return {\n      roundId: round.id.slice(-6),\n      result: (\n        <span className=\"lotr-history-result\">\n          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n            {tierCapitalized}\n          </span>\n          <span className=\"lotr-history-result__separator\">|</span>\n          <span style={{ color: isWinner ? \"#45b058\" : \"#888\" }}>\n            {round.winner ? <PlayerAvatarCompact address={round.winner} /> : \"—\"}\n          </span>\n        </span>\n      ),\n      payout: round.payoutAmount ?? 0,\n      timestamp: new Date(round.completedAt ?? round.createdAt),\n      verified: true,\n      won: isWinner,\n      onClick: () => setSelectedHistoryRound(round),\n    };\n  });\n\n  const handleJoin = async () => {\n    try {\n      await joinTierRound();\n    } catch (error) {\n      console.error(\"Failed to join round:\", error);\n    }\n  };\n\n  const handleBuyMore = async () => {\n    try {\n      await buyMoreEntriesAction(1);\n    } catch (error) {\n      console.error(\"Failed to buy more entries:\", error);\n    }\n  };\n\n  const handleBack = () => {\n    if (activeRound) {\n      leaveRound();\n    }\n    setSelectedTier(null);\n  };\n\n  // Get the current round for the selected tier\n  const selectedTierStatus = tierStatuses.find((s) => s.tier === selectedTier);\n  const selectedTierRound = selectedTierStatus?.currentRound ?? null;\n\n  // Calculate values for tier round sidebar\n  const entryAmount = selectedTier ? TIER_AMOUNTS[selectedTier] : 0;\n  const poolAmount = selectedTierRound?.poolAmount ?? 0;\n  const canJoin = selectedTierRound && (selectedTierRound.phase === \"waiting\" || selectedTierRound.phase === \"countdown\");\n\n  // Calculate user stats for sidebar\n  const currentRound = activeRound ?? selectedTierRound;\n  const myPlayer = currentRound?.players.find((p) => p.address === address);\n  const myEntries = myPlayer?.entries ?? 0;\n  // Use calculateOdds to ensure consistency with wheel display (odds sum to 100%)\n  const playerOdds = currentRound && currentRound.players.length > 0\n    ? calculateOdds(currentRound.players, currentRound.totalEntries)\n    : [];\n  const myOddsValue = playerOdds.find((p) => p.address === address)?.percentage ?? 0;\n  const myOdds = myOddsValue.toFixed(1);\n  const hasEntered = myEntries > 0;\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"lotr-sidebar\">\n      {activeRound ? (\n        // Active round sidebar\n        <>\n          <h3 className=\"lotr-sidebar__title\">Current Round</h3>\n\n          <div className=\"lotr-sidebar__game-info\">\n            <div className=\"lotr-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"lotr-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[activeRound.tier],\n                  textShadow: `0 0 8px ${TIER_COLORS[activeRound.tier]}`\n                }}\n              >\n                {activeRound.tier}\n              </span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Players</span>\n              <span>{activeRound.players.length}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Total Entries</span>\n              <span>{activeRound.totalEntries}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Entry Cost</span>\n              <span>{`$${TIER_AMOUNTS[activeRound.tier].toFixed(2)}`}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Prize Pool</span>\n              <span className=\"lotr-sidebar__pot\">{`$${activeRound.poolAmount.toFixed(2)}`}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Status</span>\n              <span className=\"lotr-sidebar__status\">\n                {activeRound.phase === \"waiting\" && \"Waiting...\"}\n                {activeRound.phase === \"countdown\" && \"Countdown!\"}\n                {activeRound.phase === \"spinning\" && \"RNG Revealing...\"}\n                {activeRound.phase === \"revealing\" && \"Winner!\"}\n                {activeRound.phase === \"complete\" && \"Complete\"}\n              </span>\n            </div>\n          </div>\n\n          {/* Your Stats - always visible */}\n          <div className=\"lotr-sidebar__your-stats\">\n            <div className=\"lotr-sidebar__stat\">\n              <span className=\"lotr-sidebar__stat-label\">Your Entries</span>\n              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? myEntries : \"-\"}</span>\n            </div>\n            <div className=\"lotr-sidebar__stat\">\n              <span className=\"lotr-sidebar__stat-label\">Your Odds</span>\n              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? `${myOdds}%` : \"-\"}</span>\n            </div>\n          </div>\n\n          {/* Action buttons */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : (activeRound.phase === \"waiting\" || activeRound.phase === \"countdown\") ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              onClick={handleBuyMore}\n              disabled={buyingMore}\n            >\n              {buyingMore ? \"Buying...\" : \"Buy Entry\"}\n            </button>\n          ) : (activeRound.phase === \"spinning\" || activeRound.phase === \"revealing\") ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              disabled\n            >\n              RNG Revealing...\n            </button>\n          ) : activeRound.phase === \"complete\" && activeRound.winner === address ? (\n            <p className=\"lotr-claimed-text\">{`+$${activeRound.payoutAmount?.toFixed(2)}`} received!</p>\n          ) : null}\n\n          {/* Round Fairness Info */}\n          <div className=\"lotr-sidebar__fairness\">\n            <h4 className=\"lotr-sidebar__fairness-title\">Round Fairness</h4>\n            <div className=\"lotr-sidebar__fairness-row\">\n              <span>Round ID</span>\n              <span className=\"lotr-sidebar__hash\" title={activeRound.id}>\n                {activeRound.id.slice(-8)}\n              </span>\n            </div>\n            <div className=\"lotr-sidebar__fairness-row\">\n              <span>Seed Hash</span>\n              <span className=\"lotr-sidebar__hash\" title={activeRound.seedHash}>\n                {activeRound.seedHash.slice(0, 8)}...{activeRound.seedHash.slice(-4)}\n              </span>\n            </div>\n            {(activeRound.phase === \"revealing\" || activeRound.phase === \"complete\") && activeRound.serverSeed && (\n              <>\n                <div className=\"lotr-sidebar__fairness-row\">\n                  <span>Server Seed</span>\n                  <span className=\"lotr-sidebar__hash lotr-sidebar__hash--revealed\" title={activeRound.serverSeed}>\n                    {activeRound.serverSeed.slice(0, 8)}...{activeRound.serverSeed.slice(-4)}\n                  </span>\n                </div>\n                {activeRound.blockHash && (\n                  <div className=\"lotr-sidebar__fairness-row\">\n                    <span>Block Hash</span>\n                    <span className=\"lotr-sidebar__hash\" title={activeRound.blockHash}>\n                      {activeRound.blockHash.slice(0, 8)}...{activeRound.blockHash.slice(-4)}\n                    </span>\n                  </div>\n                )}\n              </>\n            )}\n          </div>\n        </>\n      ) : selectedTier ? (\n        // Tier selected - show join controls\n        <>\n          <h3 className=\"lotr-sidebar__title\">Current Round</h3>\n\n          <div className=\"lotr-sidebar__game-info\">\n            <div className=\"lotr-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"lotr-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[selectedTier],\n                  textShadow: `0 0 8px ${TIER_COLORS[selectedTier]}`\n                }}\n              >\n                {selectedTier}\n              </span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Players</span>\n              <span>{selectedTierRound?.players.length ?? 0}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Total Entries</span>\n              <span>{selectedTierRound?.totalEntries ?? 0}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Entry Cost</span>\n              <span>{`$${entryAmount.toFixed(2)}`}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Prize Pool</span>\n              <span className=\"lotr-sidebar__pot\">{`$${poolAmount.toFixed(2)}`}</span>\n            </div>\n          </div>\n\n          {/* Your Stats - always visible */}\n          <div className=\"lotr-sidebar__your-stats\">\n            <div className=\"lotr-sidebar__stat\">\n              <span className=\"lotr-sidebar__stat-label\">Your Entries</span>\n              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? myEntries : \"-\"}</span>\n            </div>\n            <div className=\"lotr-sidebar__stat\">\n              <span className=\"lotr-sidebar__stat-label\">Your Odds</span>\n              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? `${myOdds}%` : \"-\"}</span>\n            </div>\n          </div>\n\n          {/* Action buttons */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : canJoin ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              onClick={handleJoin}\n              disabled={joining}\n            >\n              {joining ? \"Joining...\" : \"Join Round\"}\n            </button>\n          ) : (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              disabled\n            >\n              {selectedTierRound?.phase === \"spinning\" ? \"Round in progress...\" : \"Waiting for new round...\"}\n            </button>\n          )}\n\n          {/* Round Fairness Info */}\n          {selectedTierRound && (\n            <div className=\"lotr-sidebar__fairness\">\n              <h4 className=\"lotr-sidebar__fairness-title\">Round Fairness</h4>\n              <div className=\"lotr-sidebar__fairness-row\">\n                <span>Round ID</span>\n                <span className=\"lotr-sidebar__hash\" title={selectedTierRound.id}>\n                  {selectedTierRound.id.slice(-8)}\n                </span>\n              </div>\n              <div className=\"lotr-sidebar__fairness-row\">\n                <span>Seed Hash</span>\n                <span className=\"lotr-sidebar__hash\" title={selectedTierRound.seedHash}>\n                  {selectedTierRound.seedHash.slice(0, 8)}...{selectedTierRound.seedHash.slice(-4)}\n                </span>\n              </div>\n            </div>\n          )}\n        </>\n      ) : null}\n    </div>\n  );\n\n  // Determine which view to show\n  const renderMainContent = () => {\n    // If user is in an active round, show ActiveRoundView\n    if (activeRound) {\n      return (\n        <ActiveRoundView\n          round={activeRound}\n          currentUserAddress={address ?? \"\"}\n          onBackToTiers={handleBack}\n        />\n      );\n    }\n\n    // If a tier is selected, show TierRoundView\n    if (selectedTier) {\n      return (\n        <TierRoundView\n          tier={selectedTier}\n          round={selectedTierRound}\n          onBack={handleBack}\n        />\n      );\n    }\n\n    // Otherwise, show TierLobby\n    return (\n      <TierLobby\n        tierStatuses={tierStatuses}\n        selectedTier={selectedTier}\n        onSelectTier={setSelectedTier}\n        loading={loading}\n      />\n    );\n  };\n\n  // Only show sidebar when viewing a round (not on tier selection)\n  const showSidebar = activeRound || selectedTier;\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Lord of the RNGs\"\n        gameDescription=\"One RNG to win them all\"\n        sidebar={showSidebar ? sidebar : undefined}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"lotr-main\">\n          {renderMainContent()}\n        </div>\n      </GameLayout>\n\n      {/* History Detail Modal */}\n      <Modal\n        isOpen={selectedHistoryRound !== null}\n        onClose={() => setSelectedHistoryRound(null)}\n        title=\"Round Details\"\n      >\n        {selectedHistoryRound && (\n          <div className=\"lotr-history-modal\">\n            {/* Round Stats */}\n            <div className=\"lotr-history-modal__section\">\n              <h4 className=\"lotr-history-modal__section-title\">Round Stats</h4>\n              <div className=\"lotr-history-modal__row\">\n                <span>Tier</span>\n                <span\n                  style={{\n                    color: TIER_COLORS[selectedHistoryRound.tier],\n                    textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryRound.tier]}`,\n                    textTransform: \"capitalize\",\n                  }}\n                >\n                  {selectedHistoryRound.tier}\n                </span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Players</span>\n                <span>{selectedHistoryRound.players.length}</span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Total Entries</span>\n                <span>{selectedHistoryRound.totalEntries}</span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Prize Pool</span>\n                <span className=\"lotr-history-modal__highlight\">\n                  {`$${selectedHistoryRound.poolAmount.toFixed(2)}`}\n                </span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Winner</span>\n                <span\n                  className={\n                    selectedHistoryRound.winner === address\n                      ? \"lotr-history-modal__winner--you\"\n                      : \"\"\n                  }\n                >\n                  {selectedHistoryRound.winner\n                    ? <PlayerAvatarCompact address={selectedHistoryRound.winner} />\n                    : \"—\"}\n                </span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Payout</span>\n                <span className=\"lotr-history-modal__highlight\">\n                  {`$${selectedHistoryRound.payoutAmount?.toFixed(2)}`}\n                </span>\n              </div>\n            </div>\n\n            {/* Round Fairness */}\n            <div className=\"lotr-history-modal__section\">\n              <h4 className=\"lotr-history-modal__section-title\">\n                <span className=\"lotr-history-modal__lock\">🔒</span>\n                Round Fairness\n              </h4>\n              <div className=\"lotr-history-modal__row\">\n                <span>Round ID</span>\n                <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.id}>\n                  {selectedHistoryRound.id}\n                </span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Seed Hash</span>\n                <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.seedHash}>\n                  {selectedHistoryRound.seedHash}\n                </span>\n              </div>\n              {selectedHistoryRound.serverSeed && (\n                <div className=\"lotr-history-modal__row\">\n                  <span>Server Seed</span>\n                  <span\n                    className=\"lotr-history-modal__hash lotr-history-modal__hash--revealed\"\n                    title={selectedHistoryRound.serverSeed}\n                  >\n                    {selectedHistoryRound.serverSeed}\n                  </span>\n                </div>\n              )}\n              {selectedHistoryRound.blockHash && (\n                <div className=\"lotr-history-modal__row\">\n                  <span>Block Hash</span>\n                  <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.blockHash}>\n                    {selectedHistoryRound.blockHash}\n                  </span>\n                </div>\n              )}\n              {selectedHistoryRound.vrfProof && (\n                <div className=\"lotr-history-modal__row\">\n                  <span>VRF Proof</span>\n                  <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.vrfProof}>\n                    {selectedHistoryRound.vrfProof.slice(0, 32)}...\n                  </span>\n                </div>\n              )}\n            </div>\n\n            {/* Verify Link */}\n            <a href=\"/fairness\" className=\"lotr-history-modal__verify-link\">\n              Verify on Fairness Page →\n            </a>\n          </div>\n        )}\n      </Modal>\n    </>\n  );\n}\n\nexport function LordOfRngsPage() {\n  return (\n    <LordOfRngsProvider>\n      <LordOfRngsPageContent />\n    </LordOfRngsProvider>\n  );\n}\n","structuredPatch":[{"oldStart":199,"oldLines":7,"newStart":199,"newLines":7,"lines":["             <p className=\"lotr-claimed-text\">{`+$${activeRound.payoutAmount?.toFixed(2)}`} received!</p>","           ) : null}"," ","-          {/* Round Fairness Info */}","+          {/* Round Fairness Info — VRF-based */}","           <div className=\"lotr-sidebar__fairness\">","             <h4 className=\"lotr-sidebar__fairness-title\">Round Fairness</h4>","             <div className=\"lotr-sidebar__fairness-row\">"]},{"oldStart":208,"oldLines":30,"newStart":208,"newLines":28,"lines":["                 {activeRound.id.slice(-8)}","               </span>","             </div>","-            <div className=\"lotr-sidebar__fairness-row\">","-              <span>Seed Hash</span>","-              <span className=\"lotr-sidebar__hash\" title={activeRound.seedHash}>","-