{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EnuaLJgptc8mmq7GFJSPZJ","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→import { Tier, TIER_AMOUNTS } from \"./types\";\n     3→\n     4→// ============ Program IDs ============\n     5→\n     6→export const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n     7→  \"B9Lufh9GvuucDxDRZBr3qPNe4cJaS5MQBQKZxgUT5qYa\"\n     8→);\n     9→\n    10→// ============ PDA Derivation ============\n    11→\n    12→/**\n    13→ * Derive the round PDA for a specific tier and round number.\n    14→ * Seeds: [\"jackpot_round\", tier (1 byte LE), round_number (8 bytes LE)]\n    15→ */\n    16→export function getRoundPda(\n    17→  tier: number,\n    18→  roundNumber: bigint | number\n    19→): [PublicKey, number] {\n    20→  const tierBuf = Buffer.alloc(1);\n    21→  tierBuf.writeUInt8(tier);\n    22→  const roundBuf = Buffer.alloc(8);\n    23→  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n    24→  return PublicKey.findProgramAddressSync(\n    25→    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    26→    LORDOFRNGS_PROGRAM_ID\n    27→  );\n    28→}\n    29→\n    30→/**\n    31→ * Derive the global config PDA.\n    32→ * Seeds: [\"lord_config\"]\n    33→ */\n    34→export function getConfigPda(): [PublicKey, number] {\n    35→  return PublicKey.findProgramAddressSync(\n    36→    [Buffer.from(\"lord_config\")],\n    37→    LORDOFRNGS_PROGRAM_ID\n    38→  );\n    39→}\n    40→\n    41→// ============ Helper Types ============\n    42→\n    43→export interface LordPlayerEntry {\n    44→  player: PublicKey;\n    45→  entries: number;\n    46→}\n    47→\n    48→/** Data extracted from a RoundSettled event (on-chain log). */\n    49→export interface RoundSettledEvent {\n    50→  tier: number;\n    51→  roundNumber: bigint;\n    52→  winner: PublicKey;\n    53→  randomness: Uint8Array; // 32 bytes\n    54→  winningSlot: number;\n    55→  totalEntries: number;\n    56→  payoutAmount: bigint;\n    57→  feeAmount: bigint;\n    58→  vrfRequestKey: PublicKey;\n    59→}\n    60→\n    61→/** Result of verifying a Lord of the RNGs round. */\n    62→export interface LordVerificationResult {\n    63→  valid: boolean;\n    64→  errors: string[];\n    65→  computedWinningSlot?: number;\n    66→  computedWinner?: PublicKey;\n    67→}\n    68→\n    69→// ============ Helper Functions ============\n    70→\n    71→/**\n    72→ * Calculate the entry amount for a tier (in SOL)\n    73→ */\n    74→export function getLordEntryAmount(tier: Tier): number {\n    75→  return TIER_AMOUNTS[tier];\n    76→}\n    77→\n    78→/**\n    79→ * Determine the winning slot from VRF randomness.\n    80→ * Matches on-chain logic: u64::from_le_bytes(randomness[0..8]) % total_entries\n    81→ */\n    82→export function determineWinnerFromRandomness(\n    83→  randomness: Uint8Array,\n    84→  totalEntries: number,\n    85→  players: LordPlayerEntry[]\n    86→): { winningSlot: number; winner: PublicKey } {\n    87→  const winningSlot = deriveWinningSlot(randomness, totalEntries);\n    88→  const winner = mapSlotToPlayer(winningSlot, players);\n    89→  return { winningSlot, winner };\n    90→}\n    91→\n    92→/**\n    93→ * Derive the winning slot index from raw randomness bytes.\n    94→ * Uses first 8 bytes as little-endian u64, then mod total_entries.\n    95→ */\n    96→function deriveWinningSlot(\n    97→  randomness: Uint8Array,\n    98→  totalEntries: number\n    99→): number {\n   100→  // Read first 8 bytes as little-endian u64\n   101→  const view = new DataView(randomness.buffer, randomness.byteOffset, 8);\n   102→  const raw = view.getBigUint64(0, true); // little-endian\n   103→  return Number(raw % BigInt(totalEntries));\n   104→}\n   105→\n   106→/**\n   107→ * Map a winning slot index to the player who owns that slot.\n   108→ * Players own contiguous ranges: player 0 owns slots [0, entries0),\n   109→ * player 1 owns [entries0, entries0+entries1), etc.\n   110→ */\n   111→export function mapSlotToPlayer(\n   112→  winningSlot: number,\n   113→  players: LordPlayerEntry[]\n   114→): PublicKey {\n   115→  let cumulative = 0;\n   116→  for (const p of players) {\n   117→    cumulative += p.entries;\n   118→    if (winningSlot < cumulative) {\n   119→      return p.player;\n   120→    }\n   121→  }\n   122→  // Should never happen if winningSlot < totalEntries\n   123→  throw new Error(\n   124→    `Winning slot ${winningSlot} exceeds total entries ${cumulative}`\n   125→  );\n   126→}\n   127→\n   128→// ============ Verification ============\n   129→\n   130→/**\n   131→ * Verify a Lord of the RNGs round's fairness.\n   132→ *\n   133→ * Given the RoundSettled event data and the player list from the round,\n   134→ * re-derives the winning slot from VRF randomness and checks that it\n   135→ * matches the claimed winner.\n   136→ *\n   137→ * @param event  - Data extracted from the on-chain RoundSettled event\n   138→ * @param players - Player entries from the round (order must match on-chain Vec)\n   139→ */\n   140→export function verifyLordRound(\n   141→  event: RoundSettledEvent,\n   142→  players: LordPlayerEntry[]\n   143→): LordVerificationResult {\n   144→  const errors: string[] = [];\n   145→\n   146→  // (1) Re-derive winning slot from randomness\n   147→  const { winningSlot: computedSlot, winner: computedWinner } =\n   148→    determineWinnerFromRandomness(\n   149→      event.randomness,\n   150→      event.totalEntries,\n   151→      players\n   152→    );\n   153→\n   154→  // (2) Verify winning slot matches\n   155→  if (computedSlot !== event.winningSlot) {\n   156→    errors.push(\n   157→      `Winning slot mismatch: computed ${computedSlot}, event claims ${event.winningSlot}`\n   158→    );\n   159→  }\n   160→\n   161→  // (3) Verify winner matches\n   162→  if (!computedWinner.equals(event.winner)) {\n   163→    errors.push(\n   164→      `Winner mismatch: computed ${computedWinner.toBase58()}, event claims ${event.winner.toBase58()}`\n   165→    );\n   166→  }\n   167→\n   168→  // (4) Verify payout + fee equals total pool\n   169→  const totalPool = event.payoutAmount + event.feeAmount;\n   170→  // total_pool should equal entry_amount * total_entries but we can't know\n   171→  // the tier amount without the tier. Instead verify fee ≈ 3% of pool.\n   172→  const expectedFee = (totalPool * 3n) / 100n;\n   173→  if (event.feeAmount !== expectedFee) {\n   174→    errors.push(\n   175→      `Fee mismatch: expected ${expectedFee} (3% of ${totalPool}), got ${event.feeAmount}`\n   176→    );\n   177→  }\n   178→\n   179→  return {\n   180→    valid: errors.length === 0,\n   181→    errors,\n   182→    computedWinningSlot: computedSlot,\n   183→    computedWinner,\n   184→  };\n   185→}\n   186→\n   187→/**\n   188→ * Calculate total jackpot payout for a tier with N entries (pool × 0.97).\n   189→ */\n   190→export function calculateJackpotPayout(\n   191→  tier: Tier,\n   192→  totalEntries: number\n   193→): number {\n   194→  const entryAmount = TIER_AMOUNTS[tier];\n   195→  const totalPool = entryAmount * totalEntries;\n   196→  const fee = Math.floor(totalPool * 0.03);\n   197→  return totalPool - fee;\n   198→}\n   199→"}]},"parent_tool_use_id":"toolu_01NfB17w2VpJUvk3AA6UCz7r","session_id":"460d6ed6-55a6-44c8-8f2f-a24854f1a42b","uuid":"06f45ce3-ac4b-43b5-b8d3-5571b2a120f6"}
