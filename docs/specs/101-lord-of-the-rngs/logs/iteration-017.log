{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013yj5aH5d3nWgqV8ZHfjgGY","type":"tool_result","content":"     1→import { useState } from \"react\";\n     2→import {\n     3→  GameLayout,\n     4→  TIER_COLORS,\n     5→  Modal,\n     6→  type HistoryEntry,\n     7→} from \"@rng-utopia/ui\";\n     8→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     9→import { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\n    10→import {\n    11→  LordOfRngsProvider,\n    12→  useLordOfRngs,\n    13→  TierLobby,\n    14→  TierRoundView,\n    15→  ActiveRoundView,\n    16→  calculateOdds,\n    17→  type Round,\n    18→} from \"../features/lord-of-rngs\";\n    19→import { PlayerAvatarCompact } from \"../features/player-profile\";\n    20→\n    21→function LordOfRngsPageContent() {\n    22→  const { connected, address, connect } = useWallet();\n    23→  const {\n    24→    activeRound,\n    25→    tierStatuses,\n    26→    userHistory,\n    27→    selectedTier,\n    28→    loading,\n    29→    joining,\n    30→    buyingMore,\n    31→    setSelectedTier,\n    32→    joinTierRound,\n    33→    buyMoreEntriesAction,\n    34→    leaveRound,\n    35→  } = useLordOfRngs();\n    36→\n    37→  // State for history detail modal\n    38→  const [selectedHistoryRound, setSelectedHistoryRound] = useState<Round | null>(null);\n    39→\n    40→  // Convert user history to HistoryEntry format\n    41→  const historyEntries: HistoryEntry[] = userHistory.map((round) => {\n    42→    const isWinner = round.winner === address;\n    43→    const tierColor = TIER_COLORS[round.tier];\n    44→    const tierCapitalized = round.tier.charAt(0).toUpperCase() + round.tier.slice(1);\n    45→\n    46→    return {\n    47→      roundId: round.id.slice(-6),\n    48→      result: (\n    49→        <span className=\"lotr-history-result\">\n    50→          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n    51→            {tierCapitalized}\n    52→          </span>\n    53→          <span className=\"lotr-history-result__separator\">|</span>\n    54→          <span style={{ color: isWinner ? \"#45b058\" : \"#888\" }}>\n    55→            {round.winner ? <PlayerAvatarCompact address={round.winner} /> : \"—\"}\n    56→          </span>\n    57→        </span>\n    58→      ),\n    59→      payout: round.payoutAmount ?? 0,\n    60→      timestamp: new Date(round.completedAt ?? round.createdAt),\n    61→      verified: true,\n    62→      won: isWinner,\n    63→      onClick: () => setSelectedHistoryRound(round),\n    64→    };\n    65→  });\n    66→\n    67→  const handleJoin = async () => {\n    68→    try {\n    69→      await joinTierRound();\n    70→    } catch (error) {\n    71→      console.error(\"Failed to join round:\", error);\n    72→    }\n    73→  };\n    74→\n    75→  const handleBuyMore = async () => {\n    76→    try {\n    77→      await buyMoreEntriesAction(1);\n    78→    } catch (error) {\n    79→      console.error(\"Failed to buy more entries:\", error);\n    80→    }\n    81→  };\n    82→\n    83→  const handleBack = () => {\n    84→    if (activeRound) {\n    85→      leaveRound();\n    86→    }\n    87→    setSelectedTier(null);\n    88→  };\n    89→\n    90→  // Get the current round for the selected tier\n    91→  const selectedTierStatus = tierStatuses.find((s) => s.tier === selectedTier);\n    92→  const selectedTierRound = selectedTierStatus?.currentRound ?? null;\n    93→\n    94→  // Calculate values for tier round sidebar\n    95→  const entryAmount = selectedTier ? TIER_AMOUNTS[selectedTier] : 0;\n    96→  const poolAmount = selectedTierRound?.poolAmount ?? 0;\n    97→  const canJoin = selectedTierRound && (selectedTierRound.phase === \"waiting\" || selectedTierRound.phase === \"countdown\");\n    98→\n    99→  // Calculate user stats for sidebar\n   100→  const currentRound = activeRound ?? selectedTierRound;\n   101→  const myPlayer = currentRound?.players.find((p) => p.address === address);\n   102→  const myEntries = myPlayer?.entries ?? 0;\n   103→  // Use calculateOdds to ensure consistency with wheel display (odds sum to 100%)\n   104→  const playerOdds = currentRound && currentRound.players.length > 0\n   105→    ? calculateOdds(currentRound.players, currentRound.totalEntries)\n   106→    : [];\n   107→  const myOddsValue = playerOdds.find((p) => p.address === address)?.percentage ?? 0;\n   108→  const myOdds = myOddsValue.toFixed(1);\n   109→  const hasEntered = myEntries > 0;\n   110→\n   111→  // Sidebar content\n   112→  const sidebar = (\n   113→    <div className=\"lotr-sidebar\">\n   114→      {activeRound ? (\n   115→        // Active round sidebar\n   116→        <>\n   117→          <h3 className=\"lotr-sidebar__title\">Current Round</h3>\n   118→\n   119→          <div className=\"lotr-sidebar__game-info\">\n   120→            <div className=\"lotr-sidebar__row\">\n   121→              <span>Tier</span>\n   122→              <span\n   123→                className=\"lotr-sidebar__tier\"\n   124→                style={{\n   125→                  color: TIER_COLORS[activeRound.tier],\n   126→                  textShadow: `0 0 8px ${TIER_COLORS[activeRound.tier]}`\n   127→                }}\n   128→              >\n   129→                {activeRound.tier}\n   130→              </span>\n   131→            </div>\n   132→            <div className=\"lotr-sidebar__row\">\n   133→              <span>Players</span>\n   134→              <span>{activeRound.players.length}</span>\n   135→            </div>\n   136→            <div className=\"lotr-sidebar__row\">\n   137→              <span>Total Entries</span>\n   138→              <span>{activeRound.totalEntries}</span>\n   139→            </div>\n   140→            <div className=\"lotr-sidebar__row\">\n   141→              <span>Entry Cost</span>\n   142→              <span>{`$${TIER_AMOUNTS[activeRound.tier].toFixed(2)}`}</span>\n   143→            </div>\n   144→            <div className=\"lotr-sidebar__row\">\n   145→              <span>Prize Pool</span>\n   146→              <span className=\"lotr-sidebar__pot\">{`$${activeRound.poolAmount.toFixed(2)}`}</span>\n   147→            </div>\n   148→            <div className=\"lotr-sidebar__row\">\n   149→              <span>Status</span>\n   150→              <span className=\"lotr-sidebar__status\">\n   151→                {activeRound.phase === \"waiting\" && \"Waiting...\"}\n   152→                {activeRound.phase === \"countdown\" && \"Countdown!\"}\n   153→                {activeRound.phase === \"spinning\" && \"RNG Revealing...\"}\n   154→                {activeRound.phase === \"revealing\" && \"Winner!\"}\n   155→                {activeRound.phase === \"complete\" && \"Complete\"}\n   156→              </span>\n   157→            </div>\n   158→          </div>\n   159→\n   160→          {/* Your Stats - always visible */}\n   161→          <div className=\"lotr-sidebar__your-stats\">\n   162→            <div className=\"lotr-sidebar__stat\">\n   163→              <span className=\"lotr-sidebar__stat-label\">Your Entries</span>\n   164→              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? myEntries : \"-\"}</span>\n   165→            </div>\n   166→            <div className=\"lotr-sidebar__stat\">\n   167→              <span className=\"lotr-sidebar__stat-label\">Your Odds</span>\n   168→              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? `${myOdds}%` : \"-\"}</span>\n   169→            </div>\n   170→          </div>\n   171→\n   172→          {/* Action buttons */}\n   173→          {!connected ? (\n   174→            <button\n   175→              type=\"button\"\n   176→              className=\"lotr-action-btn\"\n   177→              onClick={connect}\n   178→            >\n   179→              Connect Wallet\n   180→            </button>\n   181→          ) : (activeRound.phase === \"waiting\" || activeRound.phase === \"countdown\") ? (\n   182→            <button\n   183→              type=\"button\"\n   184→              className=\"lotr-action-btn\"\n   185→              onClick={handleBuyMore}\n   186→              disabled={buyingMore}\n   187→            >\n   188→              {buyingMore ? \"Buying...\" : \"Buy Entry\"}\n   189→            </button>\n   190→          ) : (activeRound.phase === \"spinning\" || activeRound.phase === \"revealing\") ? (\n   191→            <button\n   192→              type=\"button\"\n   193→              className=\"lotr-action-btn\"\n   194→              disabled\n   195→            >\n   196→              RNG Revealing...\n   197→            </button>\n   198→          ) : activeRound.phase === \"complete\" && activeRound.winner === address ? (\n   199→            <p className=\"lotr-claimed-text\">{`+$${activeRound.payoutAmount?.toFixed(2)}`} received!</p>\n   200→          ) : null}\n   201→\n   202→          {/* Round Fairness Info */}\n   203→          <div className=\"lotr-sidebar__fairness\">\n   204→            <h4 className=\"lotr-sidebar__fairness-title\">Round Fairness</h4>\n   205→            <div className=\"lotr-sidebar__fairness-row\">\n   206→              <span>Round ID</span>\n   207→              <span className=\"lotr-sidebar__hash\" title={activeRound.id}>\n   208→                {activeRound.id.slice(-8)}\n   209→              </span>\n   210→            </div>\n   211→            <div className=\"lotr-sidebar__fairness-row\">\n   212→              <span>Seed Hash</span>\n   213→              <span className=\"lotr-sidebar__hash\" title={activeRound.seedHash}>\n   214→                {activeRound.seedHash.slice(0, 8)}...{activeRound.seedHash.slice(-4)}\n   215→              </span>\n   216→            </div>\n   217→            {(activeRound.phase === \"revealing\" || activeRound.phase === \"complete\") && activeRound.serverSeed && (\n   218→              <>\n   219→                <div className=\"lotr-sidebar__fairness-row\">\n   220→                  <span>Server Seed</span>\n   221→                  <span className=\"lotr-sidebar__hash lotr-sidebar__hash--revealed\" title={activeRound.serverSeed}>\n   222→                    {activeRound.serverSeed.slice(0, 8)}...{activeRound.serverSeed.slice(-4)}\n   223→                  </span>\n   224→                </div>\n   225→                {activeRound.blockHash && (\n   226→                  <div className=\"lotr-sidebar__fairness-row\">\n   227→                    <span>Block Hash</span>\n   228→                    <span className=\"lotr-sidebar__hash\" title={activeRound.blockHash}>\n   229→                      {activeRound.blockHash.slice(0, 8)}...{activeRound.blockHash.slice(-4)}\n   230→                    </span>\n   231→                  </div>\n   232→                )}\n   233→              </>\n   234→            )}\n   235→          </div>\n   236→        </>\n   237→      ) : selectedTier ? (\n   238→        // Tier selected - show join controls\n   239→        <>\n   240→          <h3 className=\"lotr-sidebar__title\">Current Round</h3>\n   241→\n   242→          <div className=\"lotr-sidebar__game-info\">\n   243→            <div className=\"lotr-sidebar__row\">\n   244→              <span>Tier</span>\n   245→              <span\n   246→                className=\"lotr-sidebar__tier\"\n   247→                style={{\n   248→                  color: TIER_COLORS[selectedTier],\n   249→                  textShadow: `0 0 8px ${TIER_COLORS[selectedTier]}`\n   250→                }}\n   251→              >\n   252→                {selectedTier}\n   253→              </span>\n   254→            </div>\n   255→            <div className=\"lotr-sidebar__row\">\n   256→              <span>Players</span>\n   257→              <span>{selectedTierRound?.players.length ?? 0}</span>\n   258→            </div>\n   259→            <div className=\"lotr-sidebar__row\">\n   260→              <span>Total Entries</span>\n   261→              <span>{selectedTierRound?.totalEntries ?? 0}</span>\n   262→            </div>\n   263→            <div className=\"lotr-sidebar__row\">\n   264→              <span>Entry Cost</span>\n   265→              <span>{`$${entryAmount.toFixed(2)}`}</span>\n   266→            </div>\n   267→            <div className=\"lotr-sidebar__row\">\n   268→              <span>Prize Pool</span>\n   269→              <span className=\"lotr-sidebar__pot\">{`$${poolAmount.toFixed(2)}`}</span>\n   270→            </div>\n   271→          </div>\n   272→\n   273→          {/* Your Stats - always visible */}\n   274→          <div className=\"lotr-sidebar__your-stats\">\n   275→            <div className=\"lotr-sidebar__stat\">\n   276→              <span className=\"lotr-sidebar__stat-label\">Your Entries</span>\n   277→              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? myEntries : \"-\"}</span>\n   278→            </div>\n   279→            <div className=\"lotr-sidebar__stat\">\n   280→              <span className=\"lotr-sidebar__stat-label\">Your Odds</span>\n   281→              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? `${myOdds}%` : \"-\"}</span>\n   282→            </div>\n   283→          </div>\n   284→\n   285→          {/* Action buttons */}\n   286→          {!connected ? (\n   287→            <button\n   288→              type=\"button\"\n   289→              className=\"lotr-action-btn\"\n   290→              onClick={connect}\n   291→            >\n   292→              Connect Wallet\n   293→            </button>\n   294→          ) : canJoin ? (\n   295→            <button\n   296→              type=\"button\"\n   297→              className=\"lotr-action-btn\"\n   298→              onClick={handleJoin}\n   299→              disabled={joining}\n   300→            >\n   301→              {joining ? \"Joining...\" : \"Join Round\"}\n   302→            </button>\n   303→          ) : (\n   304→            <button\n   305→              type=\"button\"\n   306→              className=\"lotr-action-btn\"\n   307→              disabled\n   308→            >\n   309→              {selectedTierRound?.phase === \"spinning\" ? \"Round in progress...\" : \"Waiting for new round...\"}\n   310→            </button>\n   311→          )}\n   312→\n   313→          {/* Round Fairness Info */}\n   314→          {selectedTierRound && (\n   315→            <div className=\"lotr-sidebar__fairness\">\n   316→              <h4 className=\"lotr-sidebar__fairness-title\">Round Fairness</h4>\n   317→              <div className=\"lotr-sidebar__fairness-row\">\n   318→                <span>Round ID</span>\n   319→                <span className=\"lotr-sidebar__hash\" title={selectedTierRound.id}>\n   320→                  {selectedTierRound.id.slice(-8)}\n   321→                </span>\n   322→              </div>\n   323→              <div className=\"lotr-sidebar__fairness-row\">\n   324→                <span>Seed Hash</span>\n   325→                <span className=\"lotr-sidebar__hash\" title={selectedTierRound.seedHash}>\n   326→                  {selectedTierRound.seedHash.slice(0, 8)}...{selectedTierRound.seedHash.slice(-4)}\n   327→                </span>\n   328→              </div>\n   329→            </div>\n   330→          )}\n   331→        </>\n   332→      ) : null}\n   333→    </div>\n   334→  );\n   335→\n   336→  // Determine which view to show\n   337→  const renderMainContent = () => {\n   338→    // If user is in an active round, show ActiveRoundView\n   339→    if (activeRound) {\n   340→      return (\n   341→        <ActiveRoundView\n   342→          round={activeRound}\n   343→          currentUserAddress={address ?? \"\"}\n   344→          onBackToTiers={handleBack}\n   345→        />\n   346→      );\n   347→    }\n   348→\n   349→    // If a tier is selected, show TierRoundView\n   350→    if (selectedTier) {\n   351→      return (\n   352→        <TierRoundView\n   353→          tier={selectedTier}\n   354→          round={selectedTierRound}\n   355→          onBack={handleBack}\n   356→        />\n   357→      );\n   358→    }\n   359→\n   360→    // Otherwise, show TierLobby\n   361→    return (\n   362→      <TierLobby\n   363→        tierStatuses={tierStatuses}\n   364→        selectedTier={selectedTier}\n   365→        onSelectTier={setSelectedTier}\n   366→        loading={loading}\n   367→      />\n   368→    );\n   369→  };\n   370→\n   371→  // Only show sidebar when viewing a round (not on tier selection)\n   372→  const showSidebar = activeRound || selectedTier;\n   373→\n   374→  return (\n   375→    <>\n   376→      <GameLayout\n   377→        gameName=\"Lord of the RNGs\"\n   378→        gameDescription=\"One RNG to win them all\"\n   379→        sidebar={showSidebar ? sidebar : undefined}\n   380→        historyEntries={historyEntries}\n   381→        showHistory={true}\n   382→      >\n   383→        <div className=\"lotr-main\">\n   384→          {renderMainContent()}\n   385→        </div>\n   386→      </GameLayout>\n   387→\n   388→      {/* History Detail Modal */}\n   389→      <Modal\n   390→        isOpen={selectedHistoryRound !== null}\n   391→        onClose={() => setSelectedHistoryRound(null)}\n   392→        title=\"Round Details\"\n   393→      >\n   394→        {selectedHistoryRound && (\n   395→          <div className=\"lotr-history-modal\">\n   396→            {/* Round Stats */}\n   397→            <div className=\"lotr-history-modal__section\">\n   398→              <h4 className=\"lotr-history-modal__section-title\">Round Stats</h4>\n   399→              <div className=\"lotr-history-modal__row\">\n   400→                <span>Tier</span>\n   401→                <span\n   402→                  style={{\n   403→                    color: TIER_COLORS[selectedHistoryRound.tier],\n   404→                    textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryRound.tier]}`,\n   405→                    textTransform: \"capitalize\",\n   406→                  }}\n   407→                >\n   408→                  {selectedHistoryRound.tier}\n   409→                </span>\n   410→              </div>\n   411→              <div className=\"lotr-history-modal__row\">\n   412→                <span>Players</span>\n   413→                <span>{selectedHistoryRound.players.length}</span>\n   414→              </div>\n   415→              <div className=\"lotr-history-modal__row\">\n   416→                <span>Total Entries</span>\n   417→                <span>{selectedHistoryRound.totalEntries}</span>\n   418→              </div>\n   419→              <div className=\"lotr-history-modal__row\">\n   420→                <span>Prize Pool</span>\n   421→                <span className=\"lotr-history-modal__highlight\">\n   422→                  {`$${selectedHistoryRound.poolAmount.toFixed(2)}`}\n   423→                </span>\n   424→              </div>\n   425→              <div className=\"lotr-history-modal__row\">\n   426→                <span>Winner</span>\n   427→                <span\n   428→                  className={\n   429→                    selectedHistoryRound.winner === address\n   430→                      ? \"lotr-history-modal__winner--you\"\n   431→                      : \"\"\n   432→                  }\n   433→                >\n   434→                  {selectedHistoryRound.winner\n   435→                    ? <PlayerAvatarCompact address={selectedHistoryRound.winner} />\n   436→                    : \"—\"}\n   437→                </span>\n   438→              </div>\n   439→              <div className=\"lotr-history-modal__row\">\n   440→                <span>Payout</span>\n   441→                <span className=\"lotr-history-modal__highlight\">\n   442→                  {`$${selectedHistoryRound.payoutAmount?.toFixed(2)}`}\n   443→                </span>\n   444→              </div>\n   445→            </div>\n   446→\n   447→            {/* Round Fairness */}\n   448→            <div className=\"lotr-history-modal__section\">\n   449→              <h4 className=\"lotr-history-modal__section-title\">\n   450→                <span className=\"lotr-history-modal__lock\">🔒</span>\n   451→                Round Fairness\n   452→              </h4>\n   453→              <div className=\"lotr-history-modal__row\">\n   454→                <span>Round ID</span>\n   455→                <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.id}>\n   456→                  {selectedHistoryRound.id}\n   457→                </span>\n   458→              </div>\n   459→              <div className=\"lotr-history-modal__row\">\n   460→                <span>Seed Hash</span>\n   461→                <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.seedHash}>\n   462→                  {selectedHistoryRound.seedHash}\n   463→                </span>\n   464→              </div>\n   465→              {selectedHistoryRound.serverSeed && (\n   466→                <div className=\"lotr-history-modal__row\">\n   467→                  <span>Server Seed</span>\n   468→                  <span\n   469→                    className=\"lotr-history-modal__hash lotr-history-modal__hash--revealed\"\n   470→                    title={selectedHistoryRound.serverSeed}\n   471→                  >\n   472→                    {selectedHistoryRound.serverSeed}\n   473→                  </span>\n   474→                </div>\n   475→              )}\n   476→              {selectedHistoryRound.blockHash && (\n   477→                <div className=\"lotr-history-modal__row\">\n   478→                  <span>Block Hash</span>\n   479→                  <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.blockHash}>\n   480→                    {selectedHistoryRound.blockHash}\n   481→                  </span>\n   482→                </div>\n   483→              )}\n   484→              {selectedHistoryRound.vrfProof && (\n   485→                <div className=\"lotr-history-modal__row\">\n   486→                  <span>VRF Proof</span>\n   487→                  <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.vrfProof}>\n   488→                    {selectedHistoryRound.vrfProof.slice(0, 32)}...\n   489→                  </span>\n   490→                </div>\n   491→              )}\n   492→            </div>\n   493→\n   494→            {/* Verify Link */}\n   495→            <a href=\"/fairness\" className=\"lotr-history-modal__verify-link\">\n   496→              Verify on Fairness Page →\n   497→            </a>\n   498→          </div>\n   499→        )}\n   500→      </Modal>\n   501→    </>\n   502→  );\n   503→}\n   504→\n   505→export function LordOfRngsPage() {\n   506→  return (\n   507→    <LordOfRngsProvider>\n   508→      <LordOfRngsPageContent />\n   509→    </LordOfRngsProvider>\n   510→  );\n   511→}\n   512→"}]},"parent_tool_use_id":null,"session_id":"460d6ed6-55a6-44c8-8f2f-a24854f1a42b","uuid":"da0ca33e-63da-44b7-8ba0-26c42f4d3879","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/pages/LordOfRngsPage.tsx","content":"import { useState } from \"react\";\nimport {\n  GameLayout,\n  TIER_COLORS,\n  Modal,\n  type HistoryEntry,\n} from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\nimport {\n  LordOfRngsProvider,\n  useLordOfRngs,\n  TierLobby,\n  TierRoundView,\n  ActiveRoundView,\n  calculateOdds,\n  type Round,\n} from \"../features/lord-of-rngs\";\nimport { PlayerAvatarCompact } from \"../features/player-profile\";\n\nfunction LordOfRngsPageContent() {\n  const { connected, address, connect } = useWallet();\n  const {\n    activeRound,\n    tierStatuses,\n    userHistory,\n    selectedTier,\n    loading,\n    joining,\n    buyingMore,\n    setSelectedTier,\n    joinTierRound,\n    buyMoreEntriesAction,\n    leaveRound,\n  } = useLordOfRngs();\n\n  // State for history detail modal\n  const [selectedHistoryRound, setSelectedHistoryRound] = useState<Round | null>(null);\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((round) => {\n    const isWinner = round.winner === address;\n    const tierColor = TIER_COLORS[round.tier];\n    const tierCapitalized = round.tier.charAt(0).toUpperCase() + round.tier.slice(1);\n\n    return {\n      roundId: round.id.slice(-6),\n      result: (\n        <span className=\"lotr-history-result\">\n          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n            {tierCapitalized}\n          </span>\n          <span className=\"lotr-history-result__separator\">|</span>\n          <span style={{ color: isWinner ? \"#45b058\" : \"#888\" }}>\n            {round.winner ? <PlayerAvatarCompact address={round.winner} /> : \"—\"}\n          </span>\n        </span>\n      ),\n      payout: round.payoutAmount ?? 0,\n      timestamp: new Date(round.completedAt ?? round.createdAt),\n      verified: true,\n      won: isWinner,\n      onClick: () => setSelectedHistoryRound(round),\n    };\n  });\n\n  const handleJoin = async () => {\n    try {\n      await joinTierRound();\n    } catch (error) {\n      console.error(\"Failed to join round:\", error);\n    }\n  };\n\n  const handleBuyMore = async () => {\n    try {\n      await buyMoreEntriesAction(1);\n    } catch (error) {\n      console.error(\"Failed to buy more entries:\", error);\n    }\n  };\n\n  const handleBack = () => {\n    if (activeRound) {\n      leaveRound();\n    }\n    setSelectedTier(null);\n  };\n\n  // Get the current round for the selected tier\n  const selectedTierStatus = tierStatuses.find((s) => s.tier === selectedTier);\n  const selectedTierRound = selectedTierStatus?.currentRound ?? null;\n\n  // Calculate values for tier round sidebar\n  const entryAmount = selectedTier ? TIER_AMOUNTS[selectedTier] : 0;\n  const poolAmount = selectedTierRound?.poolAmount ?? 0;\n  const canJoin = selectedTierRound && (selectedTierRound.phase === \"waiting\" || selectedTierRound.phase === \"countdown\");\n\n  // Calculate user stats for sidebar\n  const currentRound = activeRound ?? selectedTierRound;\n  const myPlayer = currentRound?.players.find((p) => p.address === address);\n  const myEntries = myPlayer?.entries ?? 0;\n  // Use calculateOdds to ensure consistency with wheel display (odds sum to 100%)\n  const playerOdds = currentRound && currentRound.players.length > 0\n    ? calculateOdds(currentRound.players, currentRound.totalEntries)\n    : [];\n  const myOddsValue = playerOdds.find((p) => p.address === address)?.percentage ?? 0;\n  const myOdds = myOddsValue.toFixed(1);\n  const hasEntered = myEntries > 0;\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"lotr-sidebar\">\n      {activeRound ? (\n        // Active round sidebar\n        <>\n          <h3 className=\"lotr-sidebar__title\">Current Round</h3>\n\n          <div className=\"lotr-sidebar__game-info\">\n            <div className=\"lotr-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"lotr-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[activeRound.tier],\n                  textShadow: `0 0 8px ${TIER_COLORS[activeRound.tier]}`\n                }}\n              >\n                {activeRound.tier}\n              </span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Players</span>\n              <span>{activeRound.players.length}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Total Entries</span>\n              <span>{activeRound.totalEntries}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Entry Cost</span>\n              <span>{`$${TIER_AMOUNTS[activeRound.tier].toFixed(2)}`}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Prize Pool</span>\n              <span className=\"lotr-sidebar__pot\">{`$${activeRound.poolAmount.toFixed(2)}`}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Status</span>\n              <span className=\"lotr-sidebar__status\">\n                {activeRound.phase === \"waiting\" && \"Waiting...\"}\n                {activeRound.phase === \"countdown\" && \"Countdown!\"}\n                {activeRound.phase === \"spinning\" && \"RNG Revealing...\"}\n                {activeRound.phase === \"revealing\" && \"Winner!\"}\n                {activeRound.phase === \"complete\" && \"Complete\"}\n              </span>\n            </div>\n          </div>\n\n          {/* Your Stats - always visible */}\n          <div className=\"lotr-sidebar__your-stats\">\n            <div className=\"lotr-sidebar__stat\">\n              <span className=\"lotr-sidebar__stat-label\">Your Entries</span>\n              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? myEntries : \"-\"}</span>\n            </div>\n            <div className=\"lotr-sidebar__stat\">\n              <span className=\"lotr-sidebar__stat-label\">Your Odds</span>\n              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? `${myOdds}%` : \"-\"}</span>\n            </div>\n          </div>\n\n          {/* Action buttons */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : (activeRound.phase === \"waiting\" || activeRound.phase === \"countdown\") ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              onClick={handleBuyMore}\n              disabled={buyingMore}\n            >\n              {buyingMore ? \"Buying...\" : \"Buy Entry\"}\n            </button>\n          ) : (activeRound.phase === \"spinning\" || activeRound.phase === \"revealing\") ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              disabled\n            >\n              RNG Revealing...\n            </button>\n          ) : activeRound.phase === \"complete\" && activeRound.winner === address ? (\n            <p className=\"lotr-claimed-text\">{`+$${activeRound.payoutAmount?.toFixed(2)}`} received!</p>\n          ) : null}\n\n          {/* Round Fairness Info */}\n          <div className=\"lotr-sidebar__fairness\">\n            <h4 className=\"lotr-sidebar__fairness-title\">Round Fairness</h4>\n            <div className=\"lotr-sidebar__fairness-row\">\n              <span>Round ID</span>\n              <span className=\"lotr-sidebar__hash\" title={activeRound.id}>\n                {activeRound.id.slice(-8)}\n              </span>\n            </div>\n            <div className=\"lotr-sidebar__fairness-row\">\n              <span>Seed Hash</span>\n              <span className=\"lotr-sidebar__hash\" title={activeRound.seedHash}>\n                {activeRound.seedHash.slice(0, 8)}...{activeRound.seedHash.slice(-4)}\n              </span>\n            </div>\n            {(activeRound.phase === \"revealing\" || activeRound.phase === \"complete\") && activeRound.serverSeed && (\n              <>\n                <div className=\"lotr-sidebar__fairness-row\">\n                  <span>Server Seed</span>\n                  <span className=\"lotr-sidebar__hash lotr-sidebar__hash--revealed\" title={activeRound.serverSeed}>\n                    {activeRound.serverSeed.slice(0, 8)}...{activeRound.serverSeed.slice(-4)}\n                  </span>\n                </div>\n                {activeRound.blockHash && (\n                  <div className=\"lotr-sidebar__fairness-row\">\n                    <span>Block Hash</span>\n                    <span className=\"lotr-sidebar__hash\" title={activeRound.blockHash}>\n                      {activeRound.blockHash.slice(0, 8)}...{activeRound.blockHash.slice(-4)}\n                    </span>\n                  </div>\n                )}\n              </>\n            )}\n          </div>\n        </>\n      ) : selectedTier ? (\n        // Tier selected - show join controls\n        <>\n          <h3 className=\"lotr-sidebar__title\">Current Round</h3>\n\n          <div className=\"lotr-sidebar__game-info\">\n            <div className=\"lotr-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"lotr-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[selectedTier],\n                  textShadow: `0 0 8px ${TIER_COLORS[selectedTier]}`\n                }}\n              >\n                {selectedTier}\n              </span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Players</span>\n              <span>{selectedTierRound?.players.length ?? 0}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Total Entries</span>\n              <span>{selectedTierRound?.totalEntries ?? 0}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Entry Cost</span>\n              <span>{`$${entryAmount.toFixed(2)}`}</span>\n            </div>\n            <div className=\"lotr-sidebar__row\">\n              <span>Prize Pool</span>\n              <span className=\"lotr-sidebar__pot\">{`$${poolAmount.toFixed(2)}`}</span>\n            </div>\n          </div>\n\n          {/* Your Stats - always visible */}\n          <div className=\"lotr-sidebar__your-stats\">\n            <div className=\"lotr-sidebar__stat\">\n              <span className=\"lotr-sidebar__stat-label\">Your Entries</span>\n              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? myEntries : \"-\"}</span>\n            </div>\n            <div className=\"lotr-sidebar__stat\">\n              <span className=\"lotr-sidebar__stat-label\">Your Odds</span>\n              <span className=\"lotr-sidebar__stat-value\">{hasEntered ? `${myOdds}%` : \"-\"}</span>\n            </div>\n          </div>\n\n          {/* Action buttons */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : canJoin ? (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              onClick={handleJoin}\n              disabled={joining}\n            >\n              {joining ? \"Joining...\" : \"Join Round\"}\n            </button>\n          ) : (\n            <button\n              type=\"button\"\n              className=\"lotr-action-btn\"\n              disabled\n            >\n              {selectedTierRound?.phase === \"spinning\" ? \"Round in progress...\" : \"Waiting for new round...\"}\n            </button>\n          )}\n\n          {/* Round Fairness Info */}\n          {selectedTierRound && (\n            <div className=\"lotr-sidebar__fairness\">\n              <h4 className=\"lotr-sidebar__fairness-title\">Round Fairness</h4>\n              <div className=\"lotr-sidebar__fairness-row\">\n                <span>Round ID</span>\n                <span className=\"lotr-sidebar__hash\" title={selectedTierRound.id}>\n                  {selectedTierRound.id.slice(-8)}\n                </span>\n              </div>\n              <div className=\"lotr-sidebar__fairness-row\">\n                <span>Seed Hash</span>\n                <span className=\"lotr-sidebar__hash\" title={selectedTierRound.seedHash}>\n                  {selectedTierRound.seedHash.slice(0, 8)}...{selectedTierRound.seedHash.slice(-4)}\n                </span>\n              </div>\n            </div>\n          )}\n        </>\n      ) : null}\n    </div>\n  );\n\n  // Determine which view to show\n  const renderMainContent = () => {\n    // If user is in an active round, show ActiveRoundView\n    if (activeRound) {\n      return (\n        <ActiveRoundView\n          round={activeRound}\n          currentUserAddress={address ?? \"\"}\n          onBackToTiers={handleBack}\n        />\n      );\n    }\n\n    // If a tier is selected, show TierRoundView\n    if (selectedTier) {\n      return (\n        <TierRoundView\n          tier={selectedTier}\n          round={selectedTierRound}\n          onBack={handleBack}\n        />\n      );\n    }\n\n    // Otherwise, show TierLobby\n    return (\n      <TierLobby\n        tierStatuses={tierStatuses}\n        selectedTier={selectedTier}\n        onSelectTier={setSelectedTier}\n        loading={loading}\n      />\n    );\n  };\n\n  // Only show sidebar when viewing a round (not on tier selection)\n  const showSidebar = activeRound || selectedTier;\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Lord of the RNGs\"\n        gameDescription=\"One RNG to win them all\"\n        sidebar={showSidebar ? sidebar : undefined}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"lotr-main\">\n          {renderMainContent()}\n        </div>\n      </GameLayout>\n\n      {/* History Detail Modal */}\n      <Modal\n        isOpen={selectedHistoryRound !== null}\n        onClose={() => setSelectedHistoryRound(null)}\n        title=\"Round Details\"\n      >\n        {selectedHistoryRound && (\n          <div className=\"lotr-history-modal\">\n            {/* Round Stats */}\n            <div className=\"lotr-history-modal__section\">\n              <h4 className=\"lotr-history-modal__section-title\">Round Stats</h4>\n              <div className=\"lotr-history-modal__row\">\n                <span>Tier</span>\n                <span\n                  style={{\n                    color: TIER_COLORS[selectedHistoryRound.tier],\n                    textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryRound.tier]}`,\n                    textTransform: \"capitalize\",\n                  }}\n                >\n                  {selectedHistoryRound.tier}\n                </span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Players</span>\n                <span>{selectedHistoryRound.players.length}</span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Total Entries</span>\n                <span>{selectedHistoryRound.totalEntries}</span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Prize Pool</span>\n                <span className=\"lotr-history-modal__highlight\">\n                  {`$${selectedHistoryRound.poolAmount.toFixed(2)}`}\n                </span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Winner</span>\n                <span\n                  className={\n                    selectedHistoryRound.winner === address\n                      ? \"lotr-history-modal__winner--you\"\n                      : \"\"\n                  }\n                >\n                  {selectedHistoryRound.winner\n                    ? <PlayerAvatarCompact address={selectedHistoryRound.winner} />\n                    : \"—\"}\n                </span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Payout</span>\n                <span className=\"lotr-history-modal__highlight\">\n                  {`$${selectedHistoryRound.payoutAmount?.toFixed(2)}`}\n                </span>\n              </div>\n            </div>\n\n            {/* Round Fairness */}\n            <div className=\"lotr-history-modal__section\">\n              <h4 className=\"lotr-history-modal__section-title\">\n                <span className=\"lotr-history-modal__lock\">🔒</span>\n                Round Fairness\n              </h4>\n              <div className=\"lotr-history-modal__row\">\n                <span>Round ID</span>\n                <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.id}>\n                  {selectedHistoryRound.id}\n                </span>\n              </div>\n              <div className=\"lotr-history-modal__row\">\n                <span>Seed Hash</span>\n                <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.seedHash}>\n                  {selectedHistoryRound.seedHash}\n                </span>\n              </div>\n              {selectedHistoryRound.serverSeed && (\n                <div className=\"lotr-history-modal__row\">\n                  <span>Server Seed</span>\n                  <span\n                    className=\"lotr-history-modal__hash lotr-history-modal__hash--revealed\"\n                    title={selectedHistoryRound.serverSeed}\n                  >\n                    {selectedHistoryRound.serverSeed}\n                  </span>\n                </div>\n              )}\n              {selectedHistoryRound.blockHash && (\n                <div className=\"lotr-history-modal__row\">\n                  <span>Block Hash</span>\n                  <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.blockHash}>\n                    {selectedHistoryRound.blockHash}\n                  </span>\n                </div>\n              )}\n              {selectedHistoryRound.vrfProof && (\n                <div className=\"lotr-history-modal__row\">\n                  <span>VRF Proof</span>\n                  <span className=\"lotr-history-modal__hash\" title={selectedHistoryRound.vrfProof}>\n                    {selectedHistoryRound.vrfProof.slice(0, 32)}...\n                  </span>\n                </div>\n              )}\n            </div>\n\n            {/* Verify Link */}\n            <a href=\"/fairness\" className=\"lotr-history-modal__verify-link\">\n              Verify on Fairness Page →\n            </a>\n          </div>\n        )}\n      </Modal>\n    </>\n  );\n}\n\nexport function LordOfRngsPage() {\n  return (\n    <LordOfRngsProvider>\n      <LordOfRngsPageContent />\n    </LordOfRngsProvider>\n  );\n}\n","numLines":512,"startLine":1,"totalLines":512}}}
