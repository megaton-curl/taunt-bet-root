{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VctoKXGqSeUeGm48hTca1b","type":"tool_result","content":"     1→import { defineConfig, devices } from \"@playwright/test\";\n     2→\n     3→export default defineConfig({\n     4→  testDir: \"./e2e\",\n     5→  fullyParallel: true,\n     6→  forbidOnly: !!process.env.CI,\n     7→  retries: 0,\n     8→  workers: 1,\n     9→  reporter: \"list\",\n    10→\n    11→  snapshotPathTemplate:\n    12→    \"{testDir}/__snapshots__/{testFilePath}/{arg}{ext}\",\n    13→\n    14→  expect: {\n    15→    toHaveScreenshot: {\n    16→      maxDiffPixelRatio: 0.015,\n    17→    },\n    18→  },\n    19→\n    20→  use: {\n    21→    baseURL: \"http://localhost:3000\",\n    22→    screenshot: \"off\",\n    23→    trace: \"off\",\n    24→    ...devices[\"Desktop Chrome\"],\n    25→    viewport: { width: 1280, height: 1080 },\n    26→  },\n    27→\n    28→  projects: [\n    29→    {\n    30→      name: \"chromium\",\n    31→      testMatch: \"visual/**/*.spec.ts\",\n    32→      use: { ...devices[\"Desktop Chrome\"], viewport: { width: 1280, height: 1080 } },\n    33→    },\n    34→  ],\n    35→\n    36→  webServer: {\n    37→    command: \"pnpm dev\",\n    38→    url: \"http://localhost:3000\",\n    39→    reuseExistingServer: !process.env.CI,\n    40→    timeout: 30_000,\n    41→    env: {\n    42→      VITE_MOCK_MODE: \"true\",\n    43→    },\n    44→  },\n    45→});\n    46→"}]},"parent_tool_use_id":"toolu_01PjYakwH8CSLk839qjDuUMR","session_id":"099dd0b0-a222-4d0c-a064-f7a4d8b48847","uuid":"50aa41cf-e493-4af8-bc1f-5357b1139f6f"}
