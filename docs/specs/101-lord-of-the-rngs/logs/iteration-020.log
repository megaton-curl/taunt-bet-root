{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UjmHXaWtHd7UHuQfubioAa","type":"tool_result","content":"     1→import { test as base, expect, type Page, type ConsoleMessage } from \"@playwright/test\";\n     2→\n     3→const FREEZE_CSS = `\n     4→  *, *::before, *::after {\n     5→    animation-duration: 0s !important;\n     6→    animation-delay: 0s !important;\n     7→    transition-duration: 0s !important;\n     8→    transition-delay: 0s !important;\n     9→    scroll-behavior: auto !important;\n    10→  }\n    11→  /* Pause SVG SMIL animations */\n    12→  svg { animation-play-state: paused !important; }\n    13→`;\n    14→\n    15→/**\n    16→ * Shared visual-regression fixture.\n    17→ *\n    18→ * Extends the default Playwright `test` with a `stablePage` fixture that:\n    19→ *  (a) Seeds Math.random() and Date.now() for determinism\n    20→ *  (b) Injects CSS to disable all CSS + SVG animations/transitions\n    21→ *  (c) Pauses SVG SMIL animations via JS\n    22→ *  (d) Waits for document.fonts.ready and network idle\n    23→ *  (e) Collects console errors and fails the test if any are found\n    24→ */\n    25→export const test = base.extend<{ stablePage: Page }>({\n    26→  stablePage: async ({ page }, use) => {\n    27→    // (e) Collect console errors throughout the test\n    28→    const consoleErrors: string[] = [];\n    29→    page.on(\"console\", (msg: ConsoleMessage) => {\n    30→      if (msg.type() === \"error\") {\n    31→        consoleErrors.push(msg.text());\n    32→      }\n    33→    });\n    34→\n    35→    // (a) Deterministic Math.random, crypto.getRandomValues, and frozen Date.now\n    36→    await page.addInitScript(() => {\n    37→      // Mulberry32 seeded PRNG — deterministic sequence from seed 42\n    38→      let seed = 42;\n    39→      function mulberry32(): number {\n    40→        seed |= 0;\n    41→        seed = (seed + 0x6d2b79f5) | 0;\n    42→        let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);\n    43→        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;\n    44→        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n    45→      }\n    46→\n    47→      Math.random = mulberry32;\n    48→\n    49→      // Also seed crypto.getRandomValues so Keypair.generate() is deterministic\n    50→      crypto.getRandomValues = <T extends ArrayBufferView | null>(array: T): T => {\n    51→        if (array === null) return array;\n    52→        const view = new Uint8Array(\n    53→          (array as ArrayBufferView).buffer,\n    54→          (array as ArrayBufferView).byteOffset,\n    55→          (array as ArrayBufferView).byteLength,\n    56→        );\n    57→        for (let i = 0; i < view.length; i++) {\n    58→          view[i] = Math.floor(mulberry32() * 256);\n    59→        }\n    60→        return array;\n    61→      };\n    62→\n    63→      // Freeze Date.now to a fixed timestamp (2026-01-01T00:00:00Z)\n    64→      const frozen = 1767225600000;\n    65→      Date.now = () => frozen;\n    66→    });\n    67→\n    68→    // Store the original goto so we can wrap it\n    69→    const originalGoto = page.goto.bind(page);\n    70→\n    71→    // Override goto to always wait for fonts + network idle after navigation\n    72→    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n    73→      const response = await originalGoto(url, {\n    74→        waitUntil: \"networkidle\",\n    75→        ...options,\n    76→      });\n    77→\n    78→      // (b) Inject animation-disabling CSS (navigation clears addStyleTag)\n    79→      await page.addStyleTag({ content: FREEZE_CSS });\n    80→\n    81→      // (c) Pause all SVG SMIL animations\n    82→      await page.evaluate(() => {\n    83→        document.querySelectorAll(\"svg\").forEach((svg) => {\n    84→          if (typeof svg.pauseAnimations === \"function\") {\n    85→            svg.pauseAnimations();\n    86→          }\n    87→        });\n    88→      });\n    89→\n    90→      // (d) Wait for all fonts to finish loading\n    91→      await page.evaluate(() => document.fonts.ready);\n    92→\n    93→      // Settle time for remaining paints\n    94→      await page.waitForTimeout(300);\n    95→\n    96→      return response;\n    97→    };\n    98→\n    99→    await use(page);\n   100→\n   101→    // (e) Assert no console errors after test completes\n   102→    if (consoleErrors.length > 0) {\n   103→      throw new Error(\n   104→        `Console errors detected during test:\\n${consoleErrors.map((e) => `  - ${e}`).join(\"\\n\")}`\n   105→      );\n   106→    }\n   107→  },\n   108→});\n   109→\n   110→export { expect };\n   111→"}]},"parent_tool_use_id":"toolu_01PjYakwH8CSLk839qjDuUMR","session_id":"099dd0b0-a222-4d0c-a064-f7a4d8b48847","uuid":"0a2d0c36-9d91-48cf-8175-db3749a13f37"}
