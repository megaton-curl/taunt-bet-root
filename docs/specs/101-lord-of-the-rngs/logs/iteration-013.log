DL_SRC\" ]; then\n  echo \"Error: IDL directory not found at $IDL_SRC\"\n  echo \"Run 'anchor build' in solana/ first.\"\n  exit 1\nfi\n\nmkdir -p \"$DEST\"\n\n# Copy IDL JSON files\nfor f in \"$IDL_SRC\"/*.json; do\n  [ -f \"$f\" ] || continue\n  cp \"$f\" \"$DEST/\"\n  echo \"Copied $(basename \"$f\")\"\ndone\n\n# Copy TypeScript type files\nfor f in \"$TYPES_SRC\"/*.ts; do\n  [ -f \"$f\" ] || continue\n  cp \"$f\" \"$DEST/\"\n  echo \"Copied $(basename \"$f\")\"\ndone\n\necho \"IDL sync complete.\"\n","numLines":36,"startLine":1,"totalLines":36}}}
