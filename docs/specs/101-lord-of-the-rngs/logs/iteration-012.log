atch,\n  // Legacy types\n  PoolState,\n  LegacyPlayerEntry,\n} from \"./types\";\n\nexport {\n  TIER_VALUES,\n  TIER_AMOUNTS,\n  POOL_PHASE_VALUES,\n  SIDE_VALUES,\n  COIN_SIDE_VALUES,\n  COINFLIP_PHASE_VALUES,\n  GAME_IDS,\n  XP_BY_TIER,\n  FEE_CONSTANTS,\n} from \"./types\";\n\n// Coinflip game client\nexport {\n  COINFLIP_PROGRAM_ID,\n  PROGRAM_IDS,\n  getMatchPda,\n  getConfigPda,\n  getEntryAmount,\n  calculatePotentialPayout,\n  getOppositeSide,\n  determineWinnerFromRandomness,\n} from \"./coinflip\";\n\n// Lord of the RNGs game client\nexport {\n  LORDOFRNGS_PROGRAM_ID,\n  getRoundPda,\n  getConfigPda as getLordConfigPda,\n  getLordEntryAmount,\n  determineWinnerFromRandomness as determineLordWinnerFromRandomness,\n  mapSlotToPlayer,\n  type LordPlayerEntry,\n} from \"./lordofrngs\";\n","structuredPatch":[{"oldStart":65,"oldLines":5,"newStart":65,"newLines":9,"lines":["   getLordEntryAmount,","   determineWinnerFromRandomness as determineLordWinnerFromRandomness,","   mapSlotToPlayer,","+  verifyLordRound,","+  calculateJackpotPayout,","   type LordPlayerEntry,","+  type RoundSettledEvent,","+  type LordVerificationResult,"," } from \"./lordofrngs\";"]}],"userModified":false,"replaceAll":false}}
