{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FqJjGmQ4LTbBnJhb7DS3L9","type":"tool_result","content":"     1→const PLATFORM_FEE_BPS = 300; // 3%\n     2→\n     3→/**\n     4→ * Calculate pari-mutuel payout for a player\n     5→ * NOTE: This is for UI display/verification only. On-chain is authoritative.\n     6→ */\n     7→export function calculatePariMutuelPayout(\n     8→  playerBet: number,\n     9→  winningPool: number,\n    10→  totalPool: number,\n    11→  feeBps: number = PLATFORM_FEE_BPS\n    12→): number {\n    13→  if (winningPool === 0) return 0;\n    14→\n    15→  const feeMultiplier = 1 - feeBps / 10000;\n    16→  const poolAfterFees = totalPool * feeMultiplier;\n    17→  const playerShare = playerBet / winningPool;\n    18→\n    19→  return poolAfterFees * playerShare;\n    20→}\n    21→\n    22→/**\n    23→ * Calculate winner-takes-all payout\n    24→ * NOTE: This is for UI display/verification only. On-chain is authoritative.\n    25→ */\n    26→export function calculateWinnerPayout(\n    27→  totalPool: number,\n    28→  feeBps: number = PLATFORM_FEE_BPS\n    29→): number {\n    30→  const feeMultiplier = 1 - feeBps / 10000;\n    31→  return totalPool * feeMultiplier;\n    32→}\n    33→\n    34→/**\n    35→ * Verify that payouts + fees = total pool (invariant check)\n    36→ */\n    37→export function verifyPayoutInvariant(\n    38→  payouts: number[],\n    39→  fees: number,\n    40→  totalPool: number,\n    41→  tolerance: number = 0.000001\n    42→): boolean {\n    43→  const totalPayouts = payouts.reduce((sum, p) => sum + p, 0);\n    44→  return Math.abs(totalPayouts + fees - totalPool) < tolerance;\n    45→}\n    46→"}]},"parent_tool_use_id":"toolu_01JvKj8yFv1VCGKHF516Dvye","session_id":"d59010d9-1bac-40d3-83bc-cafa01465d5f","uuid":"730c802f-993e-40fe-baa7-edbafdc3f036"}
