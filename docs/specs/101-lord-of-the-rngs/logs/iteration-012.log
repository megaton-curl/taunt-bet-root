{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cbns9iZ558jG9Yr6XyLeEw","type":"tool_result","content":"     1→export type GameEventType =\n     2→  | \"round:created\"\n     3→  | \"round:betting_open\"\n     4→  | \"round:betting_closed\"\n     5→  | \"round:started\"\n     6→  | \"round:resolved\"\n     7→  | \"player:joined\"\n     8→  | \"player:cashed_out\"\n     9→  | \"state:updated\";\n    10→\n    11→export interface GameEvent {\n    12→  type: GameEventType;\n    13→  roundId: string;\n    14→  timestamp: number;\n    15→  payload: unknown;\n    16→}\n    17→\n    18→type EventHandler = (event: GameEvent) => void;\n    19→\n    20→export class GameEventEmitter {\n    21→  private handlers: Map<GameEventType | \"*\", Set<EventHandler>> = new Map();\n    22→\n    23→  on(type: GameEventType | \"*\", handler: EventHandler): () => void {\n    24→    if (!this.handlers.has(type)) {\n    25→      this.handlers.set(type, new Set());\n    26→    }\n    27→    this.handlers.get(type)!.add(handler);\n    28→    return () => this.off(type, handler);\n    29→  }\n    30→\n    31→  off(type: GameEventType | \"*\", handler: EventHandler): void {\n    32→    this.handlers.get(type)?.delete(handler);\n    33→  }\n    34→\n    35→  emit(event: GameEvent): void {\n    36→    // Notify specific handlers\n    37→    this.handlers.get(event.type)?.forEach((handler) => handler(event));\n    38→    // Notify wildcard handlers\n    39→    this.handlers.get(\"*\")?.forEach((handler) => handler(event));\n    40→  }\n    41→}\n    42→"}]},"parent_tool_use_id":"toolu_01JvKj8yFv1VCGKHF516Dvye","session_id":"d59010d9-1bac-40d3-83bc-cafa01465d5f","uuid":"c3d18d5d-f65d-4c78-b85e-8a0f82674f17"}
