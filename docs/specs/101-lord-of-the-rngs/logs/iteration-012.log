{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VJPFy1vyczDUUSksnYQHsC","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→import { Tier, TIER_AMOUNTS } from \"./types\";\n     3→\n     4→// ============ Program IDs ============\n     5→\n     6→export const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n     7→  \"B9Lufh9GvuucDxDRZBr3qPNe4cJaS5MQBQKZxgUT5qYa\"\n     8→);\n     9→\n    10→// ============ PDA Derivation ============\n    11→\n    12→/**\n    13→ * Derive the round PDA for a specific tier and round number.\n    14→ * Seeds: [\"jackpot_round\", tier (1 byte LE), round_number (8 bytes LE)]\n    15→ */\n    16→export function getRoundPda(\n    17→  tier: number,\n    18→  roundNumber: bigint | number\n    19→): [PublicKey, number] {\n    20→  const tierBuf = Buffer.alloc(1);\n    21→  tierBuf.writeUInt8(tier);\n    22→  const roundBuf = Buffer.alloc(8);\n    23→  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n    24→  return PublicKey.findProgramAddressSync(\n    25→    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    26→    LORDOFRNGS_PROGRAM_ID\n    27→  );\n    28→}\n    29→\n    30→/**\n    31→ * Derive the global config PDA.\n    32→ * Seeds: [\"lord_config\"]\n    33→ */\n    34→export function getConfigPda(): [PublicKey, number] {\n    35→  return PublicKey.findProgramAddressSync(\n    36→    [Buffer.from(\"lord_config\")],\n    37→    LORDOFRNGS_PROGRAM_ID\n    38→  );\n    39→}\n    40→\n    41→// ============ Helper Types ============\n    42→\n    43→export interface LordPlayerEntry {\n    44→  player: PublicKey;\n    45→  entries: number;\n    46→}\n    47→\n    48→// ============ Helper Functions ============\n    49→\n    50→/**\n    51→ * Calculate the entry amount for a tier (in SOL)\n    52→ */\n    53→export function getLordEntryAmount(tier: Tier): number {\n    54→  return TIER_AMOUNTS[tier];\n    55→}\n    56→\n    57→/**\n    58→ * Determine the winning slot from VRF randomness.\n    59→ * Matches on-chain logic: u64::from_le_bytes(randomness[0..8]) % total_entries\n    60→ */\n    61→export function determineWinnerFromRandomness(\n    62→  randomness: Uint8Array,\n    63→  totalEntries: number,\n    64→  players: LordPlayerEntry[]\n    65→): { winningSlot: number; winner: PublicKey } {\n    66→  const winningSlot = deriveWinningSlot(randomness, totalEntries);\n    67→  const winner = mapSlotToPlayer(winningSlot, players);\n    68→  return { winningSlot, winner };\n    69→}\n    70→\n    71→/**\n    72→ * Derive the winning slot index from raw randomness bytes.\n    73→ * Uses first 8 bytes as little-endian u64, then mod total_entries.\n    74→ */\n    75→function deriveWinningSlot(\n    76→  randomness: Uint8Array,\n    77→  totalEntries: number\n    78→): number {\n    79→  // Read first 8 bytes as little-endian u64\n    80→  const view = new DataView(randomness.buffer, randomness.byteOffset, 8);\n    81→  const raw = view.getBigUint64(0, true); // little-endian\n    82→  return Number(raw % BigInt(totalEntries));\n    83→}\n    84→\n    85→/**\n    86→ * Map a winning slot index to the player who owns that slot.\n    87→ * Players own contiguous ranges: player 0 owns slots [0, entries0),\n    88→ * player 1 owns [entries0, entries0+entries1), etc.\n    89→ */\n    90→export function mapSlotToPlayer(\n    91→  winningSlot: number,\n    92→  players: LordPlayerEntry[]\n    93→): PublicKey {\n    94→  let cumulative = 0;\n    95→  for (const p of players) {\n    96→    cumulative += p.entries;\n    97→    if (winningSlot < cumulative) {\n    98→      return p.player;\n    99→    }\n   100→  }\n   101→  // Should never happen if winningSlot < totalEntries\n   102→  throw new Error(\n   103→    `Winning slot ${winningSlot} exceeds total entries ${cumulative}`\n   104→  );\n   105→}\n   106→"}]},"parent_tool_use_id":null,"session_id":"d59010d9-1bac-40d3-83bc-cafa01465d5f","uuid":"bb334a49-ac5f-4b29-9c0f-7eb9dc7dc394","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/lordofrngs.ts","content":"import { PublicKey } from \"@solana/web3.js\";\nimport { Tier, TIER_AMOUNTS } from \"./types\";\n\n// ============ Program IDs ============\n\nexport const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n  \"B9Lufh9GvuucDxDRZBr3qPNe4cJaS5MQBQKZxgUT5qYa\"\n);\n\n// ============ PDA Derivation ============\n\n/**\n * Derive the round PDA for a specific tier and round number.\n * Seeds: [\"jackpot_round\", tier (1 byte LE), round_number (8 bytes LE)]\n */\nexport function getRoundPda(\n  tier: number,\n  roundNumber: bigint | number\n): [PublicKey, number] {\n  const tierBuf = Buffer.alloc(1);\n  tierBuf.writeUInt8(tier);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\n/**\n * Derive the global config PDA.\n * Seeds: [\"lord_config\"]\n */\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\n// ============ Helper Types ============\n\nexport interface LordPlayerEntry {\n  player: PublicKey;\n  entries: number;\n}\n\n// ============ Helper Functions ============\n\n/**\n * Calculate the entry amount for a tier (in SOL)\n */\nexport function getLordEntryAmount(tier: Tier): number {\n  return TIER_AMOUNTS[tier];\n}\n\n/**\n * Determine the winning slot from VRF randomness.\n * Matches on-chain logic: u64::from_le_bytes(randomness[0..8]) % total_entries\n */\nexport function determineWinnerFromRandomness(\n  randomness: Uint8Array,\n  totalEntries: number,\n  players: LordPlayerEntry[]\n): { winningSlot: number; winner: PublicKey } {\n  const winningSlot = deriveWinningSlot(randomness, totalEntries);\n  const winner = mapSlotToPlayer(winningSlot, players);\n  return { winningSlot, winner };\n}\n\n/**\n * Derive the winning slot index from raw randomness bytes.\n * Uses first 8 bytes as little-endian u64, then mod total_entries.\n */\nfunction deriveWinningSlot(\n  randomness: Uint8Array,\n  totalEntries: number\n): number {\n  // Read first 8 bytes as little-endian u64\n  const view = new DataView(randomness.buffer, randomness.byteOffset, 8);\n  const raw = view.getBigUint64(0, true); // little-endian\n  return Number(raw % BigInt(totalEntries));\n}\n\n/**\n * Map a winning slot index to the player who owns that slot.\n * Players own contiguous ranges: player 0 owns slots [0, entries0),\n * player 1 owns [entries0, entries0+entries1), etc.\n */\nexport function mapSlotToPlayer(\n  winningSlot: number,\n  players: LordPlayerEntry[]\n): PublicKey {\n  let cumulative = 0;\n  for (const p of players) {\n    cumulative += p.entries;\n    if (winningSlot < cumulative) {\n      return p.player;\n    }\n  }\n  // Should never happen if winningSlot < totalEntries\n  throw new Error(\n    `Winning slot ${winningSlot} exceeds total entries ${cumulative}`\n  );\n}\n","numLines":106,"startLine":1,"totalLines":106}}}
