rdConfigPda,\n    65→  getLordEntryAmount,\n    66→  determineWinnerFromRandomness as determineLordWinnerFromRandomness,\n    67→  mapSlotToPlayer,\n    68→  type LordPlayerEntry,\n    69→} from \"./lordofrngs\";\n    70→"}]},"parent_tool_use_id":null,"session_id":"d59010d9-1bac-40d3-83bc-cafa01465d5f","uuid":"0ea09e91-22e1-4ad6-9578-facc507a24ae","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/index.ts","content":"// Round state machine\nexport { RoundStateMachine, type RoundState, type RoundPhase } from \"./RoundStateMachine\";\n\n// Payout calculations (UI-side, verification only - on-chain is authoritative)\nexport {\n  calculatePariMutuelPayout,\n  calculateWinnerPayout,\n  verifyPayoutInvariant,\n} from \"./payouts\";\n\n// Event emitter for UI updates\nexport { GameEventEmitter, type GameEvent, type GameEventType } from \"./GameEventEmitter\";\n\n// Legacy instruction builders (deprecated - use game-specific modules)\nexport { buildEntryInstruction, buildCashoutInstruction } from \"./instructions\";\n\n// Types\nexport type {\n  Tier,\n  Pool,\n  PoolPhase,\n  PlayerEntry,\n  Side,\n  GameConfig,\n  GameId,\n  // Coinflip types\n  CoinSide,\n  CoinflipPhase,\n  CoinflipState,\n  CoinflipMatch,\n  // Legacy types\n  PoolState,\n  LegacyPlayerEntry,\n} from \"./types\";\n\nexport {\n  TIER_VALUES,\n  TIER_AMOUNTS,\n  POOL_PHASE_VALUES,\n  SIDE_VALUES,\n  COIN_SIDE_VALUES,\n  COINFLIP_PHASE_VALUES,\n  GAME_IDS,\n  XP_BY_TIER,\n  FEE_CONSTANTS,\n} from \"./types\";\n\n// Coinflip game client\nexport {\n  COINFLIP_PROGRAM_ID,\n  PROGRAM_IDS,\n  getMatchPda,\n  getConfigPda,\n  getEntryAmount,\n  calculatePotentialPayout,\n  getOppositeSide,\n  determineWinnerFromRandomness,\n} from \"./coinflip\";\n\n// Lord of the RNGs game client\nexport {\n  LORDOFRNGS_PROGRAM_ID,\n  getRoundPda,\n  getConfigPda as getLordConfigPda,\n  getLordEntryAmount,\n  determineWinnerFromRandomness as determineLordWin