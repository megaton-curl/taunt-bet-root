oundPhase::Active,\n        LordError::InvalidPhase\n    );\n\n    // Must buy at least one entry\n    require!(num_entries > 0, LordError::ZeroEntries);\n\n    // Player must already be in the round\n    let player_key = ctx.accounts.player.key();\n    let player_idx = round\n        .players\n        .iter()\n        .position(|p| p.player == player_key)\n        .ok_or(LordError::PlayerNotInRound)?;\n\n    // Calculate cost\n    let entry_amount = round.entry_amount;\n    let total_cost = entry_amount\n        .checked_mul(num_entries as u64)\n        .ok_or(LordError::ArithmeticOverflow)?;\n\n    // Transfer lamports to round PDA (escrow)\n    transfer_lamports_to_pda(\n        &ctx.accounts.player.to_account_info(),\n        &ctx.accounts.round.to_account_info(),\n        total_cost,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    // Update round state\n    let round = &mut ctx.accounts.round;\n\n    round.players[player_idx].entries = round.players[player_idx]\n        .entries\n        .checked_add(num_entries)\n        .ok_or(LordError::ArithmeticOverflow)?;\n\n    round.total_entries = round\n        .total_entries\n        .checked_add(num_entries)\n        .ok_or(LordError::ArithmeticOverflow)?;\n\n    Ok(())\n}\n","structuredPatch":[],"originalFile":null}}
