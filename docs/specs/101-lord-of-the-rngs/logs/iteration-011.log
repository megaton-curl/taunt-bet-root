{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DJyUYDDV3CV2Yo2uGLTMfZ","type":"tool_result","content":"     1→import { PublicKey, TransactionInstruction, SystemProgram } from \"@solana/web3.js\";\n     2→import { Tier } from \"./types\";\n     3→\n     4→// Placeholder program ID - will be replaced with actual deployed program\n     5→const POOL_MANAGER_PROGRAM_ID = new PublicKey(\n     6→  \"11111111111111111111111111111111\"\n     7→);\n     8→\n     9→export interface EntryParams {\n    10→  player: PublicKey;\n    11→  gameId: string;\n    12→  roundId: string;\n    13→  tier: Tier;\n    14→}\n    15→\n    16→export interface CashoutParams {\n    17→  player: PublicKey;\n    18→  gameId: string;\n    19→  roundId: string;\n    20→}\n    21→\n    22→/**\n    23→ * Build instruction for entering a game pool\n    24→ * NOTE: This is a placeholder. Actual implementation depends on deployed program.\n    25→ */\n    26→export function buildEntryInstruction(params: EntryParams): TransactionInstruction {\n    27→  const { player, gameId, roundId, tier } = params;\n    28→  // Note: TIER_AMOUNTS[tier] will be used for instruction data in full implementation\n    29→\n    30→  // Derive pool PDA\n    31→  const [poolPda] = PublicKey.findProgramAddressSync(\n    32→    [\n    33→      Buffer.from(\"pool\"),\n    34→      Buffer.from(gameId),\n    35→      Buffer.from(roundId),\n    36→      Buffer.from(tier),\n    37→    ],\n    38→    POOL_MANAGER_PROGRAM_ID\n    39→  );\n    40→\n    41→  // Derive player entry PDA\n    42→  const [entryPda] = PublicKey.findProgramAddressSync(\n    43→    [Buffer.from(\"entry\"), poolPda.toBuffer(), player.toBuffer()],\n    44→    POOL_MANAGER_PROGRAM_ID\n    45→  );\n    46→\n    47→  // Placeholder instruction - actual data layout depends on Anchor IDL\n    48→  return new TransactionInstruction({\n    49→    keys: [\n    50→      { pubkey: player, isSigner: true, isWritable: true },\n    51→      { pubkey: poolPda, isSigner: false, isWritable: true },\n    52→      { pubkey: entryPda, isSigner: false, isWritable: true },\n    53→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    54→    ],\n    55→    programId: POOL_MANAGER_PROGRAM_ID,\n    56→    data: Buffer.from([]), // Placeholder\n    57→  });\n    58→}\n    59→\n    60→/**\n    61→ * Build instruction for cashing out (Crash game)\n    62→ * NOTE: This is a placeholder. Actual implementation depends on deployed program.\n    63→ */\n    64→export function buildCashoutInstruction(\n    65→  params: CashoutParams\n    66→): TransactionInstruction {\n    67→  const { player, gameId, roundId } = params;\n    68→\n    69→  const [poolPda] = PublicKey.findProgramAddressSync(\n    70→    [Buffer.from(\"pool\"), Buffer.from(gameId), Buffer.from(roundId)],\n    71→    POOL_MANAGER_PROGRAM_ID\n    72→  );\n    73→\n    74→  const [entryPda] = PublicKey.findProgramAddressSync(\n    75→    [Buffer.from(\"entry\"), poolPda.toBuffer(), player.toBuffer()],\n    76→    POOL_MANAGER_PROGRAM_ID\n    77→  );\n    78→\n    79→  return new TransactionInstruction({\n    80→    keys: [\n    81→      { pubkey: player, isSigner: true, isWritable: true },\n    82→      { pubkey: poolPda, isSigner: false, isWritable: true },\n    83→      { pubkey: entryPda, isSigner: false, isWritable: true },\n    84→    ],\n    85→    programId: POOL_MANAGER_PROGRAM_ID,\n    86→    data: Buffer.from([]), // Placeholder\n    87→  });\n    88→}\n    89→"}]},"parent_tool_use_id":"toolu_018qcbhpTvHZjgWodHgqJMSW","session_id":"d859bc11-91b4-4b69-a88e-12eb400e4b26","uuid":"9a6d71b0-5e57-4697-9888-f8835ef35c34"}
