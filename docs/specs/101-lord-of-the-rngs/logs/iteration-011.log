{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017FgAWQkhSyZ3PCwbvtTGKt","type":"tool_result","content":"     1→// Browser-only exports - no Node.js dependencies (no Buffer usage)\n     2→// Use this entry point for browser apps that don't need blockchain instructions\n     3→\n     4→// Types (no Buffer dependencies)\n     5→export type {\n     6→  Tier,\n     7→  Pool,\n     8→  PoolPhase,\n     9→  PlayerEntry,\n    10→  Side,\n    11→  GameConfig,\n    12→  GameId,\n    13→  CoinSide,\n    14→  CoinflipPhase,\n    15→  CoinflipState,\n    16→  CoinflipMatch,\n    17→  PoolState,\n    18→  LegacyPlayerEntry,\n    19→} from \"./types\";\n    20→\n    21→export {\n    22→  TIER_VALUES,\n    23→  TIER_AMOUNTS,\n    24→  POOL_PHASE_VALUES,\n    25→  SIDE_VALUES,\n    26→  COIN_SIDE_VALUES,\n    27→  COINFLIP_PHASE_VALUES,\n    28→  GAME_IDS,\n    29→  XP_BY_TIER,\n    30→  FEE_CONSTANTS,\n    31→} from \"./types\";\n    32→\n    33→// Round state machine (browser-safe)\n    34→export { RoundStateMachine, type RoundState, type RoundPhase } from \"./RoundStateMachine\";\n    35→\n    36→// Payout calculations (browser-safe, verification only)\n    37→export {\n    38→  calculatePariMutuelPayout,\n    39→  calculateWinnerPayout,\n    40→  verifyPayoutInvariant,\n    41→} from \"./payouts\";\n    42→\n    43→// Event emitter (browser-safe)\n    44→export { GameEventEmitter, type GameEvent, type GameEventType } from \"./GameEventEmitter\";\n    45→"}]},"parent_tool_use_id":"toolu_018qcbhpTvHZjgWodHgqJMSW","session_id":"d859bc11-91b4-4b69-a88e-12eb400e4b26","uuid":"f4362818-6dcd-458b-9171-d6e1278b0666"}
