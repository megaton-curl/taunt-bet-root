{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013KBtNYdGPGpke1cDdL9UnF","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::lifecycle::RoundPhase;\n     3→\n     4→/// Maximum number of players per round.\n     5→pub const MAX_PLAYERS: usize = 20;\n     6→\n     7→/// Global configuration for the Lord of the RNGs program.\n     8→/// PDA seeds: [b\"lord_config\"]\n     9→#[account]\n    10→#[derive(InitSpace)]\n    11→pub struct LordConfig {\n    12→    /// Admin authority (can update config).\n    13→    pub authority: Pubkey,\n    14→    /// Fee destination wallet.\n    15→    pub treasury: Pubkey,\n    16→    /// Whether the game is paused (rejects new rounds).\n    17→    pub paused: bool,\n    18→    /// Monotonically increasing round counter per tier.\n    19→    /// Index corresponds to tier (0–5).\n    20→    pub round_counters: [u64; 6],\n    21→    /// Bump seed for PDA derivation.\n    22→    pub bump: u8,\n    23→}\n    24→\n    25→/// A single player's entry in a jackpot round.\n    26→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug, InitSpace)]\n    27→pub struct PlayerEntry {\n    28→    /// Player's wallet address.\n    29→    pub player: Pubkey,\n    30→    /// Number of entries purchased (each entry = one slot on the wheel).\n    31→    pub entries: u32,\n    32→}\n    33→\n    34→/// A jackpot round for a specific tier.\n    35→/// PDA seeds: [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()]\n    36→#[account]\n    37→#[derive(InitSpace)]\n    38→pub struct JackpotRound {\n    39→    /// Tier index (0–5).\n    40→    pub tier: u8,\n    41→    /// Round number within this tier.\n    42→    pub round_number: u64,\n    43→    /// Entry amount in lamports (derived from tier).\n    44→    pub entry_amount: u64,\n    45→    /// Current phase of the round.\n    46→    pub phase: RoundPhase,\n    47→    /// Players in this round.\n    48→    #[max_len(20)]\n    49→    pub players: Vec<PlayerEntry>,\n    50→    /// Total entries across all players.\n    51→    pub total_entries: u32,\n    52→    /// Unix timestamp when the round was created.\n    53→    pub created_at: i64,\n    54→    /// Unix timestamp when countdown ends (0 if not yet started).\n    55→    pub countdown_ends_at: i64,\n    56→    /// Unix timestamp when the round entered Locked phase (0 if not yet).\n    57→    pub locked_at: i64,\n    58→    /// Deadline for VRF resolution; after this, timeout refund is available.\n    59→    pub resolve_deadline: i64,\n    60→    /// Address of the Orao randomness PDA for VRF lookup at claim time.\n    61→    pub vrf_request_key: Pubkey,\n    62→    /// The winning slot index (only valid after settlement).\n    63→    pub winning_slot: u32,\n    64→    /// The winner's pubkey (Pubkey::default() until settled).\n    65→    pub winner: Pubkey,\n    66→    /// Whether the payout has been claimed.\n    67→    pub claimed: bool,\n    68→    /// The creator of the round (receives rent back on close).\n    69→    pub creator: Pubkey,\n    70→    /// Bump seed for PDA derivation.\n    71→    pub bump: u8,\n    72→}\n    73→\n    74→/// Event emitted when a round is settled via claim_payout.\n    75→#[event]\n    76→pub struct RoundSettled {\n    77→    /// Tier index.\n    78→    pub tier: u8,\n    79→    /// Round number.\n    80→    pub round_number: u64,\n    81→    /// Winner's wallet address.\n    82→    pub winner: Pubkey,\n    83→    /// Raw VRF randomness bytes.\n    84→    pub randomness: [u8; 32],\n    85→    /// The winning slot index (0-based).\n    86→    pub winning_slot: u32,\n    87→    /// Total entries in the round.\n    88→    pub total_entries: u32,\n    89→    /// Net payout to winner (after fee).\n    90→    pub payout_amount: u64,\n    91→    /// Platform fee amount.\n    92→    pub fee_amount: u64,\n    93→    /// Address of the Orao VRF request PDA.\n    94→    pub vrf_request_key: Pubkey,\n    95→}\n    96→"}]},"parent_tool_use_id":null,"session_id":"d859bc11-91b4-4b69-a88e-12eb400e4b26","uuid":"8adeb632-17d1-441d-a820-12c74d4b0024","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/lordofrngs/src/state.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::lifecycle::RoundPhase;\n\n/// Maximum number of players per round.\npub const MAX_PLAYERS: usize = 20;\n\n/// Global configuration for the Lord of the RNGs program.\n/// PDA seeds: [b\"lord_config\"]\n#[account]\n#[derive(InitSpace)]\npub struct LordConfig {\n    /// Admin authority (can update config).\n    pub authority: Pubkey,\n    /// Fee destination wallet.\n    pub treasury: Pubkey,\n    /// Whether the game is paused (rejects new rounds).\n    pub paused: bool,\n    /// Monotonically increasing round counter per tier.\n    /// Index corresponds to tier (0–5).\n    pub round_counters: [u64; 6],\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// A single player's entry in a jackpot round.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug, InitSpace)]\npub struct PlayerEntry {\n    /// Player's wallet address.\n    pub player: Pubkey,\n    /// Number of entries purchased (each entry = one slot on the wheel).\n    pub entries: u32,\n}\n\n/// A jackpot round for a specific tier.\n/// PDA seeds: [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()]\n#[account]\n#[derive(InitSpace)]\npub struct JackpotRound {\n    /// Tier index (0–5).\n    pub tier: u8,\n    /// Round number within this tier.\n    pub round_number: u64,\n    /// Entry amount in lamports (derived from tier).\n    pub entry_amount: u64,\n    /// Current phase of the round.\n    pub phase: RoundPhase,\n    /// Players in this round.\n    #[max_len(20)]\n    pub players: Vec<PlayerEntry>,\n    /// Total entries across all players.\n    pub total_entries: u32,\n    /// Unix timestamp when the round was created.\n    pub created_at: i64,\n    /// Unix timestamp when countdown ends (0 if not yet started).\n    pub countdown_ends_at: i64,\n    /// Unix timestamp when the round entered Locked phase (0 if not yet).\n    pub locked_at: i64,\n    /// Deadline for VRF resolution; after this, timeout refund is available.\n    pub resolve_deadline: i64,\n    /// Address of the Orao randomness PDA for VRF lookup at claim time.\n    pub vrf_request_key: Pubkey,\n    /// The winning slot index (only valid after settlement).\n    pub winning_slot: u32,\n    /// The winner's pubkey (Pubkey::default() until settled).\n    pub winner: Pubkey,\n    /// Whether the payout has been claimed.\n    pub claimed: bool,\n    /// The creator of the round (receives rent back on close).\n    pub creator: Pubkey,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// Event emitted when a round is settled via claim_payout.\n#[event]\npub struct RoundSettled {\n    /// Tier index.\n    pub tier: u8,\n    /// Round number.\n    pub round_number: u64,\n    /// Winner's wallet address.\n    pub winner: Pubkey,\n    /// Raw VRF randomness bytes.\n    pub randomness: [u8; 32],\n    /// The winning slot index (0-based).\n    pub winning_slot: u32,\n    /// Total entries in the round.\n    pub total_entries: u32,\n    /// Net payout to winner (after fee).\n    pub payout_amount: u64,\n    /// Platform fee amount.\n    pub fee_amount: u64,\n    /// Address of the Orao VRF request PDA.\n    pub vrf_request_key: Pubkey,\n}\n","numLines":96,"startLine":1,"totalLines":96}}}
