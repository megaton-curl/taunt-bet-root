{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01A2dbf172FWDZCDewtRhRgV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VVJ9eEB7M16EwepCcmrXdM","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/lordofrngs.ts","content":"import { PublicKey } from \"@solana/web3.js\";\nimport { Tier, TIER_AMOUNTS } from \"./types\";\n\n// ============ Program IDs ============\n\nexport const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n  \"B9Lufh9GvuucDxDRZBr3qPNe4cJaS5MQBQKZxgUT5qYa\"\n);\n\n// ============ PDA Derivation ============\n\n/**\n * Derive the round PDA for a specific tier and round number.\n * Seeds: [\"jackpot_round\", tier (1 byte LE), round_number (8 bytes LE)]\n */\nexport function getRoundPda(\n  tier: number,\n  roundNumber: bigint | number\n): [PublicKey, number] {\n  const tierBuf = Buffer.alloc(1);\n  tierBuf.writeUInt8(tier);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\n/**\n * Derive the global config PDA.\n * Seeds: [\"lord_config\"]\n */\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\n// ============ Helper Types ============\n\nexport interface LordPlayerEntry {\n  player: PublicKey;\n  entries: number;\n}\n\n// ============ Helper Functions ============\n\n/**\n * Calculate the entry amount for a tier (in SOL)\n */\nexport function getLordEntryAmount(tier: Tier): number {\n  return TIER_AMOUNTS[tier];\n}\n\n/**\n * Determine the winning slot from VRF randomness.\n * Matches on-chain logic: u64::from_le_bytes(randomness[0..8]) % total_entries\n */\nexport function determineWinnerFromRandomness(\n  randomness: Uint8Array,\n  totalEntries: number,\n  players: LordPlayerEntry[]\n): { winningSlot: number; winner: PublicKey } {\n  const winningSlot = deriveWinningSlot(randomness, totalEntries);\n  const winner = mapSlotToPlayer(winningSlot, players);\n  return { winningSlot, winner };\n}\n\n/**\n * Derive the winning slot index from raw randomness bytes.\n * Uses first 8 bytes as little-endian u64, then mod total_entries.\n */\nfunction deriveWinningSlot(\n  randomness: Uint8Array,\n  totalEntries: number\n): number {\n  // Read first 8 bytes as little-endian u64\n  const view = new DataView(randomness.buffer, randomness.byteOffset, 8);\n  const raw = view.getBigUint64(0, true); // little-endian\n  return Number(raw % BigInt(totalEntries));\n}\n\n/**\n * Map a winning slot index to the player who owns that slot.\n * Players own contiguous ranges: player 0 owns slots [0, entries0),\n * player 1 owns [entries0, entries0+entries1), etc.\n */\nexport function mapSlotToPlayer(\n  winningSlot: number,\n  players: LordPlayerEntry[]\n): PublicKey {\n  let cumulative = 0;\n  for (const p of players) {\n    cumulative += p.entries;\n    if (winningSlot < cumulative) {\n      return p.player;\n    }\n  }\n  // Should never happen if winningSlot < totalEntries\n  throw new Error(\n    `Winning slot ${winningSlot} exceeds total entries ${cumulative}`\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":242,"cache_read_input_tokens":61501,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":242},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d859bc11-91b4-4b69-a88e-12eb400e4b26","uuid":"2521839d-c75b-4d79-ae4c-16e6b325e59b"}
