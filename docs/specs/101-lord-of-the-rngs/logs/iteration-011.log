{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V1G2jHqqKD28kPqpqHr6h5","type":"tool_result","content":"     1→export type RoundPhase = \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"complete\";\n     2→\n     3→export interface RoundState {\n     4→  phase: RoundPhase;\n     5→  roundId: string;\n     6→  playerCount: number;\n     7→  poolTotal: number;\n     8→  startedAt?: number;\n     9→  endsAt?: number;\n    10→}\n    11→\n    12→type TransitionHandler = (state: RoundState) => void;\n    13→\n    14→export class RoundStateMachine {\n    15→  private state: RoundState;\n    16→  private listeners: Set<TransitionHandler> = new Set();\n    17→\n    18→  constructor(roundId: string) {\n    19→    this.state = {\n    20→      phase: \"waiting\",\n    21→      roundId,\n    22→      playerCount: 0,\n    23→      poolTotal: 0,\n    24→    };\n    25→  }\n    26→\n    27→  getState(): RoundState {\n    28→    return { ...this.state };\n    29→  }\n    30→\n    31→  subscribe(handler: TransitionHandler): () => void {\n    32→    this.listeners.add(handler);\n    33→    return () => this.listeners.delete(handler);\n    34→  }\n    35→\n    36→  private emit() {\n    37→    const state = this.getState();\n    38→    this.listeners.forEach((handler) => handler(state));\n    39→  }\n    40→\n    41→  // State transitions\n    42→  openBetting(): void {\n    43→    if (this.state.phase !== \"waiting\") {\n    44→      throw new Error(`Cannot open betting from ${this.state.phase}`);\n    45→    }\n    46→    this.state.phase = \"betting\";\n    47→    this.state.startedAt = Date.now();\n    48→    this.emit();\n    49→  }\n    50→\n    51→  closeBetting(): void {\n    52→    if (this.state.phase !== \"betting\") {\n    53→      throw new Error(`Cannot close betting from ${this.state.phase}`);\n    54→    }\n    55→    this.state.phase = \"active\";\n    56→    this.emit();\n    57→  }\n    58→\n    59→  startResolving(): void {\n    60→    if (this.state.phase !== \"active\") {\n    61→      throw new Error(`Cannot start resolving from ${this.state.phase}`);\n    62→    }\n    63→    this.state.phase = \"resolving\";\n    64→    this.emit();\n    65→  }\n    66→\n    67→  complete(): void {\n    68→    if (this.state.phase !== \"resolving\") {\n    69→      throw new Error(`Cannot complete from ${this.state.phase}`);\n    70→    }\n    71→    this.state.phase = \"complete\";\n    72→    this.emit();\n    73→  }\n    74→\n    75→  // State updates (don't change phase)\n    76→  addPlayer(amount: number): void {\n    77→    this.state.playerCount++;\n    78→    this.state.poolTotal += amount;\n    79→    this.emit();\n    80→  }\n    81→}\n    82→"}]},"parent_tool_use_id":"toolu_018qcbhpTvHZjgWodHgqJMSW","session_id":"d859bc11-91b4-4b69-a88e-12eb400e4b26","uuid":"df5d0fa8-4760-43af-a517-e77225dcc12b"}
