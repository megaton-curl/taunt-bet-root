{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GHuZjiWCveXuJPeMzMRmtu","type":"tool_result","content":"     1→// Round state machine\n     2→export { RoundStateMachine, type RoundState, type RoundPhase } from \"./RoundStateMachine\";\n     3→\n     4→// Payout calculations (UI-side, verification only - on-chain is authoritative)\n     5→export {\n     6→  calculatePariMutuelPayout,\n     7→  calculateWinnerPayout,\n     8→  verifyPayoutInvariant,\n     9→} from \"./payouts\";\n    10→\n    11→// Event emitter for UI updates\n    12→export { GameEventEmitter, type GameEvent, type GameEventType } from \"./GameEventEmitter\";\n    13→\n    14→// Legacy instruction builders (deprecated - use game-specific modules)\n    15→export { buildEntryInstruction, buildCashoutInstruction } from \"./instructions\";\n    16→\n    17→// Types\n    18→export type {\n    19→  Tier,\n    20→  Pool,\n    21→  PoolPhase,\n    22→  PlayerEntry,\n    23→  Side,\n    24→  GameConfig,\n    25→  GameId,\n    26→  // Coinflip types\n    27→  CoinSide,\n    28→  CoinflipPhase,\n    29→  CoinflipState,\n    30→  CoinflipMatch,\n    31→  // Legacy types\n    32→  PoolState,\n    33→  LegacyPlayerEntry,\n    34→} from \"./types\";\n    35→\n    36→export {\n    37→  TIER_VALUES,\n    38→  TIER_AMOUNTS,\n    39→  POOL_PHASE_VALUES,\n    40→  SIDE_VALUES,\n    41→  COIN_SIDE_VALUES,\n    42→  COINFLIP_PHASE_VALUES,\n    43→  GAME_IDS,\n    44→  XP_BY_TIER,\n    45→  FEE_CONSTANTS,\n    46→} from \"./types\";\n    47→\n    48→// Coinflip game client\n    49→export {\n    50→  COINFLIP_PROGRAM_ID,\n    51→  PROGRAM_IDS,\n    52→  getMatchPda,\n    53→  getConfigPda,\n    54→  getEntryAmount,\n    55→  calculatePotentialPayout,\n    56→  getOppositeSide,\n    57→  determineWinnerFromRandomness,\n    58→} from \"./coinflip\";\n    59→"}]},"parent_tool_use_id":"toolu_018qcbhpTvHZjgWodHgqJMSW","session_id":"d859bc11-91b4-4b69-a88e-12eb400e4b26","uuid":"695f2918-a276-4abf-bf86-66