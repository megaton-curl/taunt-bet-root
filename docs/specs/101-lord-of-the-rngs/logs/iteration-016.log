sName=\"lotr-tier-lobby\">\n    55→      <p className=\"lotr-tier-lobby__instruction\">Choose a tier to join the jackpot</p>\n    56→\n    57→      <div className=\"lotr-tier-lobby__grid\">\n    58→        {TIERS.map((tier) => {\n    59→          const status = tierStatuses.find((s) => s.tier === tier);\n    60→          const round = status?.currentRound;\n    61→          const isSelected = selectedTier === tier;\n    62→          const tierColor = TIER_COLORS[tier];\n    63→\n    64→          return (\n    65→            <button\n    66→              key={tier}\n    67→              type=\"button\"\n    68→              className={`lotr-tier-card ${getPhaseClass(status!)} ${isSelected ? \"lotr-tier-card--selected\" : \"\"}`}\n    69→              style={{\n    70→                \"--tier-color\": tierColor,\n    71→              } as React.CSSProperties}\n    72→              onClick={() => onSelectTier(tier)}\n    73→            >\n    74→              <div className=\"lotr-tier-card__header\">\n    75→                <span className={`rng-tier-gem rng-tier-gem--${tier}`} />\n    76→                <span className=\"lotr-tier-card__name\">{tier}</span>\n    77→                <span className=\"lotr-tier-card__amount\">\n    78→                  {\"$\"}{TIER_AMOUNTS[tier]}\n    79→                </span>\n    80→              </div>\n    81→\n    82→              <div className=\"lotr-tier-card__stats\">\n    83→                <div className=\"lotr-tier-card__stat\">\n    84→                  <span className=\"lotr-tier-card__stat-label\">Players</span>\n    85→                  <span className=\"lotr-tier-card__stat-value\">\n    86→                    {round?.players.length ?? 0}\n    87→                  </span>\n    88→                </div>\n    89→                <div className=\"lotr-tier-card__stat\">\n    90→                  <span className=\"lotr-tier-card__stat-label\">Pool</span>\n    91→                  <span className=\"lotr-tier-card__stat-value\">\n    92→                    {\"$\"}{round?.poolAmount.toFixed(2) ?? \"0.00\"}\n    93→                  </span>\n    94→                </div>\n    95→                <div className=\"lotr-tier-card__stat\">\n    96→                  <span className=\"lotr-tier-card__stat-label\">Entries</span>\n    97→                  <span className=\"lotr-tier-card__stat-value\">\n    98→                    {round?.totalEntries ?? 0}\n    99→                  </span>\n   100→                </div>\n   101→              </div>\n   102→\n   103→              <div className=\"lotr-tier-card__phase\">\n   104→                {round?.phase === \"countdown\" && round.countdownEndsAt ? (\n   105→                  <CountdownTimer endsAt={round.countdownEndsAt} size=\"small\" />\n   106→                ) : (\n   107→                  <span className=\"lotr-tier-card__phase-text\">\n   108→                    {getPhaseLabel(status!)}\n   109→                  </span>\n   110→                )}\n   111→              </div>\n   112→            </button>\n   113→          );\n   114→        })}\n   115→      </div>\n   116→    </div>\n   117→  );\n   118→}\n   119→"}]},"parent_tool_use_id":null,"session_id":"2c77e434-3462-4e56-b7cd-45edfd147cc2","uuid":"1285fd8d-ebe9-44a4-a44d-90a3ebd8c4ec","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/components/TierLobby.tsx","content":"import { TIER_COLORS } from \"@rng-utopia/ui\";\nimport { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { TierStatus } from \"../types\";\nimport { CountdownTimer } from \"./CountdownTimer\";\n\ninterface TierLobbyProps {\n  tierStatuses: TierStatus[];\n  selectedTier: Tier | null;\n  onSelectTier: (tier: Tier) => void;\n  loading?: boolean;\n}\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\nexport function TierLobby({\n  tierStatuses,\n  selectedTier,\n  onSelectTier,\n  loading,\n}: TierLobbyProps) {\n  const getPhaseLabel = (status: TierStatus): string => {\n    const round = status.currentRound;\n    if (!round) return \"Starting...\";\n\n    switch (round.phase) {\n      case \"waiting\":\n        return \"Waiting for players\";\n      case \"countdown\":\n        return \"Countdown active\";\n      case \"spinning\":\n        return \"Spinning!\";\n      case \"complete\":\n        return \"Round complete\";\n      default:\n        return \"Unknown\";\n    }\n  };\n\n  const getPhaseClass = (status: TierStatus): string => {\n    const round = status.currentRound;\n    if (!round) return \"\";\n    return `lotr-tier-card--${round.phase}`;\n  };\n\n  if (loading) {\n    return (\n      <div className=\"lotr-tier-lobby lotr-tier-lobby--loading\">\n        <div className=\"lotr-tier-lobby__loading\">Loading rounds...</div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"lotr-tier-lobby\">\n      <p className=\"lotr-tier-lobby__instruction\">Choose a tier to join the jackpot</p>\n\n      <div className=\"lotr-tier-lobby__grid\">\n        {TIERS.map((tier) => {\n          const status = tierStatuses.find((s) => s.tier === tier);\n          const round = status?.currentRound;\n          const isSelected = selectedTier === tier;\n          const tierColor = TIER_COLORS[tier];\n\n          return (\n            <button\n              key={tier}\n              type=\"button\"\n              className={`lotr-tier-card ${getPhaseClass(status!)} ${isSelected ? \"lotr-tier-card--selected\" : \"\"}`}\n              style={{\n                \"--tier-color\": tierColor,\n              } as React.CSSProperties}\n              onClick={() => onSelectTier(tier)}\n            >\n              <div className=\"lotr-tier-card__header\">\n                <span className={`rng-tier-gem rng-tier-gem--${tier}`} />\n                <span className=\"lotr-tier-card__name\">{tier}</span>\n                <span className=\"lotr-tier-card__amount\">\n                  {\"$\"}{TIER_AMOUNTS[tier]}\n                </span>\n              </div>\n\n              <div className=\"lotr-tier-card__stats\">\n                <div className=\"lotr-tier-card__stat\">\n                  <span className=\"lotr-tier-card__stat-label\">Players</span>\n                  <span className=\"lotr-tier-card__stat-value\">\n                    {round?.players.length ?? 0}\n                  </span>\n                </div>\n                <div className=\"lotr-tier-card__stat\">\n                  <span className=\"lotr-tier-card__stat-label\">Pool</span>\n                  <span className=\"lotr-tier-card__stat-value\">\n                    {\"$\"}{round?.poolAmount.toFixed(2) ?? \"0.00\"}\n                  </span>\n                </div>\n                <div className=\"lotr-tier-card__stat\">\n                  <span className=\"lotr-tier-card__stat-label\">Entries</span>\n                  <span className=\"lotr-tier-card__stat-value\">\n                    {round?.totalEntries ?? 0}\n                  </span>\n                </div>\n              </div>\n\n              <div className=\"lotr-tier-card__phase\">\n                {round?.phase === \"countdown\" && round.countdownEndsAt ? (\n                  <CountdownTimer endsAt={round.countdownEndsAt} size=\"small\" />\n                ) : (\n                  <span className=\"lotr-tier-card__phase-text\">\n                    {getPhaseLabel(status!)}\n                  </span>\n                )}\n              </div>\n            </button>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n","numLines":119,"startLine":1,"totalLines":119}}}
