{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TDwfX5J6BnML2f1y91BZeF","type":"tool_result","content":"   100→  totalEntries: number;\n   101→  createdAt: { toNumber(): number };\n   102→  countdownEndsAt: { toNumber(): number };\n   103→  lockedAt: { toNumber(): number };\n   104→  resolveDeadline: { toNumber(): number };\n   105→  vrfRequestKey: PublicKey;\n   106→  winningSlot: number;\n   107→  winner: PublicKey;\n   108→  claimed: boolean;\n   109→  creator: PublicKey;\n   110→  bump: number;\n   111→}\n   112→\n   113→interface OnChainConfig {\n   114→  authority: PublicKey;\n   115→  treasury: PublicKey;\n   116→  paused: boolean;\n   117→  roundCounters: { toNumber(): number }[];\n   118→  bump: number;\n   119→}\n   120→\n   121→// ============ Converters ============\n   122→\n   123→const TIERS: Tier[] = [\n   124→  \"iron\",\n   125→  \"bronze\",\n   126→  \"silver\",\n   127→  \"gold\",\n   128→  \"platinum\",\n   129→  \"diamond\",\n   130→];\n   131→\n   132→function tierFromIndex(index: number): Tier {\n   133→  return TIERS[index] ?? \"iron\";\n   134→}\n   135→\n   136→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   137→  return name in phase;\n   138→}\n   139→\n   140→function phaseToUI(phase: RoundPhaseVariant): Round[\"phase\"] {\n   141→  if (isPhase(phase, \"waiting\")) return \"waiting\";\n   142→  if (isPhase(phase, \"active\")) return \"countdown\";\n   143→  if (isPhase(phase, \"locked\")) return \"spinning\";\n   144→  if (isPhase(phase, \"settled\")) return \"complete\";\n   145→  // Resolving, Refunded → treat as complete for display\n   146→  return \"complete\";\n   147→}\n   148→\n   149→function getPlayerColor(index: number, isCurrentUser: boolean): string {\n   150→  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\";\n   151→  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n   152→}\n   153→\n   154→function onChainPlayersToUI(\n   155→  players: OnChainPlayerEntry[],\n   156→  currentWallet?: string\n   157→): PlayerEntry[] {\n   158→  return players.map((p, i) => ({\n   159→    address: p.player.toBase58(),\n   160→    entries: p.entries,\n   161→    color: getPlayerColor(i, p.player.toBase58() === currentWallet),\n   162→  }));\n   163→}\n   164→\n   165→export function onChainRoundToUI(\n   166→  roundPda: PublicKey,\n   167→  data: OnChainRound,\n   168→  currentWallet?: string\n   169→): Round {\n   170→  const tier = tierFromIndex(data.tier);\n   171→  const entryAmountLamports = data.entryAmount.toNumber();\n   172→  const entryAmountSol = entryAmountLamports / LAMPORTS_PER_SOL;\n   173→  const totalEntries = data.totalEntries;\n   174→  const poolAmount = entryAmountSol * totalEntries;\n   175→  const phase = phaseToUI(data.phase);\n   176→  const isSettled = isPhase(data.phase, \"settled\");\n   177→  const countdownEndsAt = data.countdownEndsAt.toNumber();\n   178→\n   179→  const winner = isSettled ? data.winner : undefined;\n   180→  const isDefaultWinner =\n   181→    winner && winner.equals(PublicKey.default) ? undefined : winner;\n   182→\n   183→  return {\n   184→    id: roundPda.toBase58(),\n   185→    tier,\n   186→    entryAmount: entryAmountSol,\n   187→    phase,\n   188→    players: onChainPlayersToUI(data.players, currentWallet),\n   189→    totalEntries,\n   190→    poolAmount,\n   191→    createdAt: data.createdAt.toNumber() * 1000,\n   192→    countdownStartedAt:\n   193→      countdownEndsAt > 0 ? (countdownEndsAt - 60) * 1000 : undefined,\n   194→    countdownEndsAt: countdownEndsAt > 0 ? countdownEndsAt * 1000 : undefined,\n   195→    winningSlot: isSettled ? data.winningSlot : undefined,\n   196→    winner: isDefaultWinner?.toBase58(),\n   197→    payoutAmount: isSettled ? poolAmount * 0.97 : undefined,\n   198→    claimed: data.claimed,\n   199→    seedHash: data.vrfRequestKey.equals(PublicKey.default)\n   200→      ? \"\"\n   201→      : data.vrfRequestKey.toBase58(),\n   202→    vrfProof: isSettled\n   203→      ? data.vrfRequestKey.toBase58()\n   204→      : undefined,\n   205→  };\n   206→}\n   207→\n   208→/** Read VRF randomness from an Orao account. Returns 32 bytes or null. */\n   209→async function readVrfRandomness(\n   210→  connection: Connection,\n   211→  vrfRequestKey: PublicKey\n   212→): Promise<Uint8Array | null> {\n   213→  try {\n   214→    if (vrfRequestKey.equals(PublicKey.default)) return null;\n   215→    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n   216→    if (vrfAccount && vrfAccount.data.length > 8) {\n   217→      const randomnessData = vrfAccount.data.subarray(8, 72);\n   218→      if (randomnessData.some((b: number) => b !== 0)) {\n   219→        return randomnessData.subarray(0, 32);\n   220→      }\n   221→    }\n   222→  } catch {\n   223→    // Ignore\n   224→  }\n   225→  return null;\n   226→}\n   227→\n   228→/** Derive winner from VRF randomness for a locked round. */\n   229→function deriveWinnerFromVrf(\n   230→  randomness: Uint8Array,\n   231→  data: OnChainRound\n   232→): { winningSlot: number; winner: PublicKey } {\n   233→  const view = new DataView(\n   234→    randomness.buffer,\n   235→    randomness.byteOffset,\n   236→    8\n   237→  );\n   238→  const raw = view.getBigUint64(0, true);\n   239→  const winningSlot = Number(raw % BigInt(data.totalEntries));\n   240→\n   241→  let cumulative = 0;\n   242→  for (const p of data.players) {\n   243→    cumulative += p.entries;\n   244→    if (winningSlot < cumulative) {\n   245→      return { winningSlot, winner: p.player };\n   246→    }\n   247→  }\n   248→  return { winningSlot, winner: data.players[0]!.player };\n   249→}\n   250→\n   251→// ============ Account Queries ============\n   252→\n   253→/** Fetch a single round by tier and round number. */\n   254→export async function fetchRound(\n   255→  connection: Connection,\n   256→  tier: number,\n   257→  roundNumber: bigint | number,\n   258→  currentWallet?: string\n   259→): Promise<Round | null> {\n   260→  const program = getLordProgram(connection);\n   261→  const [roundPda] = getRoundPda(tier, roundNumber);\n   262→\n   263→  try {\n   264→    const account = await program.account.jackpotRound.fetch(roundPda);\n   265→    const data = account as unknown as OnChainRound;\n   266→    const round = onChainRoundToUI(roundPda, data, currentWallet);\n   267→\n   268→    // If Locked, check if VRF is fulfilled to upgrade to spinning/revealing\n   269→    if (isPhase(data.phase, \"locked\")) {\n   270→      const randomness = await readVrfRandomness(\n   271→        connection,\n   272→        data.vrfRequestKey\n   273→      );\n   274→      if (randomness) {\n   275→        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n   276→        return {\n   277→          ...round,\n   278→          phase: \"revealing\",\n   279→          winningSlot,\n   280→          winner: winner.toBase58(),\n   281→          payoutAmount: round.poolAmount * 0.97,\n   282→        };\n   283→      }\n   284→    }\n   285→\n   286→    return round;\n   287→  } catch {\n   288→    return null;\n   289→  }\n   290→}\n   291→\n   292→/** Fetch the current round for each tier. Returns a map of tier → Round. */\n   293→export async function fetchAllTierRounds(\n   294→  connection: Connection,\n   295→  currentWallet?: string\n   296→): Promise<Map<Tier, Round>> {\n   297→  const program = getLordProgram(connection);\n   298→  const result = new Map<Tier, Round>();\n   299→"}]},"parent_tool_use_id":null,"session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"3992b7d8-2357-42ab-8e49-586a36b32886","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/chain.ts","content":"  totalEntries: number;\n  createdAt: { toNumber(): number };\n  countdownEndsAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  winningSlot: number;\n  winner: PublicKey;\n  claimed: boolean;\n  creator: PublicKey;\n  bump: number;\n}\n\ninterface OnChainConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  paused: boolean;\n  roundCounters: { toNumber(): number }[];\n  bump: number;\n}\n\n// ============ Converters ============\n\nconst TIERS: Tier[] = [\n  \"iron\",\n  \"bronze\",\n  \"silver\",\n  \"gold\",\n  \"platinum\",\n  \"diamond\",\n];\n\nfunction tierFromIndex(index: number): Tier {\n  return TIERS[index] ?? \"iron\";\n}\n\nfunction isPhase(phase: RoundPhaseVariant, name: string): boolean {\n  return name in phase;\n}\n\nfunction phaseToUI(phase: RoundPhaseVariant): Round[\"phase\"] {\n  if (isPhase(phase, \"waiting\")) return \"waiting\";\n  if (isPhase(phase, \"active\")) return \"countdown\";\n  if (isPhase(phase, \"locked\")) return \"spinning\";\n  if (isPhase(phase, \"settled\")) return \"complete\";\n  // Resolving, Refunded → treat as complete for display\n  return \"complete\";\n}\n\nfunction getPlayerColor(index: number, isCurrentUser: boolean): string {\n  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\";\n  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n}\n\nfunction onChainPlayersToUI(\n  players: OnChainPlayerEntry[],\n  currentWallet?: string\n): PlayerEntry[] {\n  return players.map((p, i) => ({\n    address: p.player.toBase58(),\n    entries: p.entries,\n    color: getPlayerColor(i, p.player.toBase58() === currentWallet),\n  }));\n}\n\nexport function onChainRoundToUI(\n  roundPda: PublicKey,\n  data: OnChainRound,\n  currentWallet?: string\n): Round {\n  const tier = tierFromIndex(data.tier);\n  const entryAmountLamports = data.entryAmount.toNumber();\n  const entryAmountSol = entryAmountLamports / LAMPORTS_PER_SOL;\n  const totalEntries = data.totalEntries;\n  const poolAmount = entryAmountSol * totalEntries;\n  const phase = phaseToUI(data.phase);\n  const isSettled = isPhase(data.phase, \"settled\");\n  const countdownEndsAt = data.countdownEndsAt.toNumber();\n\n  const winner = isSettled ? data.winner : undefined;\n  const isDefaultWinner =\n    winner && winner.equals(PublicKey.default) ? undefined : winner;\n\n  return {\n    id: roundPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    phase,\n    players: onChainPlayersToUI(data.players, currentWallet),\n    totalEntries,\n    poolAmount,\n    createdAt: data.createdAt.toNumber() * 1000,\n    countdownStartedAt:\n      countdownEndsAt > 0 ? (countdownEndsAt - 60) * 1000 : undefined,\n    countdownEndsAt: countdownEndsAt > 0 ? countdownEndsAt * 1000 : undefined,\n    winningSlot: isSettled ? data.winningSlot : undefined,\n    winner: isDefaultWinner?.toBase58(),\n    payoutAmount: isSettled ? poolAmount * 0.97 : undefined,\n    claimed: data.claimed,\n    seedHash: data.vrfRequestKey.equals(PublicKey.default)\n      ? \"\"\n      : data.vrfRequestKey.toBase58(),\n    vrfProof: isSettled\n      ? data.vrfRequestKey.toBase58()\n      : undefined,\n  };\n}\n\n/** Read VRF randomness from an Orao account. Returns 32 bytes or null. */\nasync function readVrfRandomness(\n  connection: Connection,\n  vrfRequestKey: PublicKey\n): Promise<Uint8Array | null> {\n  try {\n    if (vrfRequestKey.equals(PublicKey.default)) return null;\n    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      if (randomnessData.some((b: number) => b !== 0)) {\n        return randomnessData.subarray(0, 32);\n      }\n    }\n  } catch {\n    // Ignore\n  }\n  return null;\n}\n\n/** Derive winner from VRF randomness for a locked round. */\nfunction deriveWinnerFromVrf(\n  randomness: Uint8Array,\n  data: OnChainRound\n): { winningSlot: number; winner: PublicKey } {\n  const view = new DataView(\n    randomness.buffer,\n    randomness.byteOffset,\n    8\n  );\n  const raw = view.getBigUint64(0, true);\n  const winningSlot = Number(raw % BigInt(data.totalEntries));\n\n  let cumulative = 0;\n  for (const p of data.players) {\n    cumulative += p.entries;\n    if (winningSlot < cumulative) {\n      return { winningSlot, winner: p.player };\n    }\n  }\n  return { winningSlot, winner: data.players[0]!.player };\n}\n\n// ============ Account Queries ============\n\n/** Fetch a single round by tier and round number. */\nexport async function fetchRound(\n  connection: Connection,\n  tier: number,\n  roundNumber: bigint | number,\n  currentWallet?: string\n): Promise<Round | null> {\n  const program = getLordProgram(connection);\n  const [roundPda] = getRoundPda(tier, roundNumber);\n\n  try {\n    const account = await program.account.jackpotRound.fetch(roundPda);\n    const data = account as unknown as OnChainRound;\n    const round = onChainRoundToUI(roundPda, data, currentWallet);\n\n    // If Locked, check if VRF is fulfilled to upgrade to spinning/revealing\n    if (isPhase(data.phase, \"locked\")) {\n      const randomness = await readVrfRandomness(\n        connection,\n        data.vrfRequestKey\n      );\n      if (randomness) {\n        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n        return {\n          ...round,\n          phase: \"revealing\",\n          winningSlot,\n          winner: winner.toBase58(),\n          payoutAmount: round.poolAmount * 0.97,\n        };\n      }\n    }\n\n    return round;\n  } catch {\n    return null;\n  }\n}\n\n/** Fetch the current round for each tier. Returns a map of tier → Round. */\nexport async function fetchAllTierRounds(\n  connection: Connection,\n  currentWallet?: string\n): Promise<Map<Tier, Round>> {\n  const program = getLordProgram(connection);\n  const result = new Map<Tier, Round>();\n","numLines":200,"startLine":100,"totalLines":581}}}
