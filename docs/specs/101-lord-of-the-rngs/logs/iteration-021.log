{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q2t418ZWSQHPVPXZc6NBc4","type":"tool_result","content":"     1→import { defineConfig, devices } from \"@playwright/test\";\n     2→\n     3→/**\n     4→ * Playwright config for local E2E integration tests.\n     5→ *\n     6→ * Runs against a local solana-test-validator with real wallet mode.\n     7→ * The validator + program deploy is handled by external bootstrap scripts;\n     8→ * this config only starts the Vite dev server.\n     9→ */\n    10→export default defineConfig({\n    11→  testDir: \"./e2e\",\n    12→  fullyParallel: false,\n    13→  forbidOnly: !!process.env.CI,\n    14→  retries: 0,\n    15→  workers: 1,\n    16→  reporter: \"list\",\n    17→  timeout: 60_000,\n    18→\n    19→  use: {\n    20→    baseURL: \"http://localhost:3002\",\n    21→    screenshot: \"off\",\n    22→    trace: \"retain-on-failure\",\n    23→    ...devices[\"Desktop Chrome\"],\n    24→    viewport: { width: 1280, height: 1080 },\n    25→  },\n    26→\n    27→  projects: [\n    28→    {\n    29→      name: \"local-e2e\",\n    30→      testMatch: \"local/**/*.spec.ts\",\n    31→      use: { ...devices[\"Desktop Chrome\"], viewport: { width: 1280, height: 1080 } },\n    32→    },\n    33→  ],\n    34→\n    35→  webServer: {\n    36→    command: \"npx vite --port 3002\",\n    37→    url: \"http://localhost:3002\",\n    38→    reuseExistingServer: !process.env.CI,\n    39→    timeout: 30_000,\n    40→    env: {\n    41→      VITE_MOCK_MODE: \"false\",\n    42→      VITE_TEST_WALLET: \"true\",\n    43→      VITE_RPC_URL: \"http://127.0.0.1:8899\",\n    44→      VITE_SOLANA_NETWORK: \"localnet\",\n    45→    },\n    46→  },\n    47→});\n    48→"}]},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"00d4071f-601f-4ed4-a232-39ec1312bd0c"}
