{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NPQF4swTgtXKwR1iwaJzP1","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# localnet-teardown.sh — Stop solana-test-validator and clean temp files.\n     3→# Usage: ./scripts/localnet-teardown.sh [--keep-logs]\n     4→# Reads PID from .localnet.pid (written by localnet-bootstrap.sh).\n     5→# Safe to call multiple times or when no validator is running.\n     6→set -euo pipefail\n     7→\n     8→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     9→PLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n    10→\n    11→PID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\n    12→LEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\n    13→LOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n    14→\n    15→KEEP_LOGS=false\n    16→if [[ \"${1:-}\" == \"--keep-logs\" ]]; then\n    17→  KEEP_LOGS=true\n    18→fi\n    19→\n    20→CLEANED=false\n    21→\n    22→# ── Stop validator by PID file ───────────────────────────────────────\n    23→if [[ -f \"$PID_FILE\" ]]; then\n    24→  PID=$(cat \"$PID_FILE\")\n    25→  if kill -0 \"$PID\" 2>/dev/null; then\n    26→    echo \"Stopping validator (PID $PID)...\"\n    27→    kill \"$PID\" 2>/dev/null || true\n    28→    # Wait up to 5s for graceful shutdown\n    29→    for _ in $(seq 1 10); do\n    30→      if ! kill -0 \"$PID\" 2>/dev/null; then\n    31→        break\n    32→      fi\n    33→      sleep 0.5\n    34→    done\n    35→    # Force kill if still running\n    36→    if kill -0 \"$PID\" 2>/dev/null; then\n    37→      echo \"Force-killing validator (PID $PID)...\"\n    38→      kill -9 \"$PID\" 2>/dev/null || true\n    39→    fi\n    40→    CLEANED=true\n    41→  fi\n    42→  rm -f \"$PID_FILE\"\n    43→fi\n    44→\n    45→# ── Kill any stray validator on port 8899 ────────────────────────────\n    46→if command -v lsof &>/dev/null && lsof -ti :8899 &>/dev/null; then\n    47→  STRAY_PID=$(lsof -ti :8899)\n    48→  echo \"Killing stray process on port 8899 (PID $STRAY_PID)...\"\n    49→  kill \"$STRAY_PID\" 2>/dev/null || true\n    50→  sleep 1\n    51→  kill -9 \"$STRAY_PID\" 2>/dev/null || true\n    52→  CLEANED=true\n    53→fi\n    54→\n    55→# ── Clean temp ledger ────────────────────────────────────────────────\n    56→if [[ -d \"$LEDGER_DIR\" ]]; then\n    57→  echo \"Removing ledger directory: $LEDGER_DIR\"\n    58→  rm -rf \"$LEDGER_DIR\"\n    59→  CLEANED=true\n    60→fi\n    61→\n    62→# ── Clean log file (unless --keep-logs) ──────────────────────────────\n    63→if [[ \"$KEEP_LOGS\" == false && -f \"$LOG_FILE\" ]]; then\n    64→  echo \"Removing log file: $LOG_FILE\"\n    65→  rm -f \"$LOG_FILE\"\n    66→  CLEANED=true\n    67→fi\n    68→\n    69→if [[ \"$CLEANED\" == true ]]; then\n    70→  echo \"Localnet teardown complete.\"\n    71→else\n    72→  echo \"Nothing to clean up (no running validator or temp files found).\"\n    73→fi\n    74→"}]},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"2b3a7033-cdf9-4f4e-bd85-739034c1a3e3"}
