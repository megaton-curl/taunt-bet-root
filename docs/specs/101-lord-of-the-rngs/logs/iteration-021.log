{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HAAvf7odfmVU8mRVrSe8yM","type":"tool_result","content":"     1→import { defineConfig, devices } from \"@playwright/test\";\n     2→\n     3→/**\n     4→ * Playwright config for devnet E2E integration tests.\n     5→ *\n     6→ * Runs against deployed devnet contracts with real VRF fulfillment.\n     7→ * Does NOT start a local validator or deploy programs — requires\n     8→ * pre-deployed contracts and env vars (see e2e/devnet/helpers/env.ts).\n     9→ *\n    10→ * Required env vars (set before running, or in .env.devnet):\n    11→ *   VITE_RPC_URL                — Devnet RPC endpoint\n    12→ *   VITE_COINFLIP_PROGRAM_ID   — Deployed coinflip program address\n    13→ *   VITE_PLATFORM_PROGRAM_ID   — Deployed platform program address\n    14→ *\n    15→ * Optional:\n    16→ *   VITE_SOLANA_NETWORK        — Cluster name (default: \"devnet\")\n    17→ */\n    18→export default defineConfig({\n    19→  testDir: \"./e2e\",\n    20→  fullyParallel: false,\n    21→  forbidOnly: !!process.env.CI,\n    22→  retries: 0,\n    23→  workers: 1,\n    24→  reporter: \"list\",\n    25→  // Longer timeout: real VRF fulfillment can take 30–60+ seconds\n    26→  timeout: 120_000,\n    27→\n    28→  use: {\n    29→    baseURL: \"http://localhost:3003\",\n    30→    screenshot: \"off\",\n    31→    trace: \"retain-on-failure\",\n    32→    ...devices[\"Desktop Chrome\"],\n    33→    viewport: { width: 1280, height: 1080 },\n    34→  },\n    35→\n    36→  projects: [\n    37→    {\n    38→      name: \"devnet-e2e\",\n    39→      testMatch: \"devnet/**/*.spec.ts\",\n    40→      use: {\n    41→        ...devices[\"Desktop Chrome\"],\n    42→        viewport: { width: 1280, height: 1080 },\n    43→      },\n    44→    },\n    45→  ],\n    46→\n    47→  webServer: {\n    48→    command: \"npx vite --port 3003\",\n    49→    url: \"http://localhost:3003\",\n    50→    reuseExistingServer: !process.env.CI,\n    51→    timeout: 30_000,\n    52→    env: {\n    53→      VITE_MOCK_MODE: \"false\",\n    54→      VITE_TEST_WALLET: \"true\",\n    55→      // RPC URL and program IDs are inherited from the process environment.\n    56→      // They must be set before running this config (see env.ts validation).\n    57→      // VITE_SOLANA_NETWORK defaults to \"devnet\" in the app if not set.\n    58→    },\n    59→  },\n    60→});\n    61→"}]},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"baa9ba9b-a242-468d-990a-60a75a99e901"}
