{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_014NTvKfZkd8JooUc6CgeH5T","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WMmELU4w1a5BqZWunpo9cJ","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/on-chain.ts","old_string":"  return {\n    totalGames: profile.totalGames.toNumber(),\n    wins: profile.wins.toNumber(),\n    totalWagered: profile.totalWagered.toNumber(),\n    totalWon: profile.totalWon.toNumber(),\n  };\n}","new_string":"  return {\n    totalGames: profile.totalGames.toNumber(),\n    wins: profile.wins.toNumber(),\n    totalWagered: profile.totalWagered.toNumber(),\n    totalWon: profile.totalWon.toNumber(),\n  };\n}\n\n// ============ Lord of RNGs Helpers ============\n\n/** Derive a Lord of RNGs round PDA. Seeds: [\"jackpot_round\", tier(u8), roundNumber(u64 LE)]. */\nexport function getLordRoundPda(tier: number, roundNumber: bigint | number): [PublicKey, number] {\n  const tierBuf = Buffer.alloc(1);\n  tierBuf.writeUInt8(tier);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    LORDOFRNGS_PROGRAM_ID,\n  );\n}\n\n/** Derive the Lord of RNGs config PDA. Seeds: [\"lord_config\"]. */\nexport function getLordConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID,\n  );\n}\n\n/** Create a read-only Lord of RNGs program instance. */\nexport function getLordProgram(connection: Connection): Program<Lordofrngs> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" },\n  );\n  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n}\n\n/** Deserialized jackpot round account shape. */\nexport interface JackpotRoundAccount {\n  tier: number;\n  roundNumber: { toNumber(): number };\n  entryAmount: { toNumber(): number };\n  phase: Record<string, object>;\n  players: { player: PublicKey; entries: number }[];\n  totalEntries: number;\n  creator: PublicKey;\n  claimed: boolean;\n  winner: PublicKey;\n  winningSlot: number;\n  vrfRequestKey: PublicKey;\n  bump: number;\n}\n\n/** Fetch a Lord of RNGs round PDA. Returns null if closed/missing. */\nexport async function fetchLordRound(\n  connection: Connection,\n  roundPda: PublicKey,\n): Promise<JackpotRoundAccount | null> {\n  const program = getLordProgram(connection);\n  try {\n    return (await program.account.jackpotRound.fetch(\n      roundPda,\n    )) as unknown as JackpotRoundAccount;\n  } catch {\n    return null;\n  }\n}\n\n/** Assert a Lord of RNGs round PDA is closed. */\nexport async function assertLordRoundClosed(\n  connection: Connection,\n  roundPda: PublicKey,\n): Promise<void> {\n  const round = await fetchLordRound(connection, roundPda);\n  if (round !== null) {\n    const phase = Object.keys(round.phase)[0];\n    throw new Error(\n      `Expected round PDA to be closed, but it still exists (phase: ${phase})`,\n    );\n  }\n}\n\n/**\n * Calculate the expected fee and net payout for a Lord of RNGs jackpot round.\n * pool = entryAmount * totalEntries; fee = floor(pool * 300 / 10_000).\n */\nexport function calculateLordExpectedFee(\n  entryAmount: number,\n  totalEntries: number,\n): { pool: number; fee: number; payout: number } {\n  const pool = entryAmount * totalEntries;\n  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n  const payout = pool - fee;\n  return { pool, fee, payout };\n}\n\n/**\n * Assert that the treasury received the expected Lord of RNGs fee.\n */\nexport async function assertLordTreasuryFee(\n  connection: Connection,\n  treasury: PublicKey,\n  balanceBefore: number,\n  entryAmount: number,\n  totalEntries: number,\n): Promise<void> {\n  const balanceAfter = await getBalanceLamports(connection, treasury);\n  const { fee } = calculateLordExpectedFee(entryAmount, totalEntries);\n  const actualDelta = balanceAfter - balanceBefore;\n\n  if (actualDelta !== fee) {\n    throw new Error(\n      `Lord treasury fee mismatch: expected ${fee} lamports, got delta ${actualDelta}`,\n    );\n  }\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":325,"cache_read_input_tokens":122489,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":325},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"0df94ea8-542a-4151-9a94-fc348257b310"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WMmELU4w1a5BqZWunpo9cJ","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/on-chain.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"3cf059bd-aa6a-44d5-a3f4-4804ef0f21a5","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/on-chain.ts","oldString":"  return {\n    totalGames: profile.totalGames.toNumber(),\n    wins: profile.wins.toNumber(),\n    totalWagered: profile.totalWagered.toNumber(),\n    totalWon: profile.totalWon.toNumber(),\n  };\n}","newString":"  return {\n    totalGames: profile.totalGames.toNumber(),\n    wins: profile.wins.toNumber(),\n    totalWagered: profile.totalWagered.toNumber(),\n    totalWon: profile.totalWon.toNumber(),\n  };\n}\n\n// ============ Lord of RNGs Helpers ============\n\n/** Derive a Lord of RNGs round PDA. Seeds: [\"jackpot_round\", tier(u8), roundNumber(u64 LE)]. */\nexport function getLordRoundPda(tier: number, roundNumber: bigint | number): [PublicKey, number] {\n  const tierBuf = Buffer.alloc(1);\n  tierBuf.writeUInt8(tier);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    LORDOFRNGS_PROGRAM_ID,\n  );\n}\n\n/** Derive the Lord of RNGs config PDA. Seeds: [\"lord_config\"]. */\nexport function getLordConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID,\n  );\n}\n\n/** Create a read-only Lord of RNGs program instance. */\nexport function getLordProgram(connection: Connection): Program<Lordofrngs> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" },\n  );\n  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n}\n\n/** Deserialized jackpot round account shape. */\nexport interface JackpotRoundAccount {\n  tier: number;\n  roundNumber: { toNumber(): number };\n  entryAmount: { toNumber(): number };\n  phase: Record<string, object>;\n  players: { player: PublicKey; entries: number }[];\n  totalEntries: number;\n  creator: PublicKey;\n  claimed: boolean;\n  winner: PublicKey;\n  winningSlot: number;\n  vrfRequestKey: PublicKey;\n  bump: number;\n}\n\n/** Fetch a Lord of RNGs round PDA. Returns null if closed/missing. */\nexport async function fetchLordRound(\n  connection: Connection,\n  roundPda: PublicKey,\n): Promise<JackpotRoundAccount | null> {\n  const program = getLordProgram(connection);\n  try {\n    return (await program.account.jackpotRound.fetch(\n      roundPda,\n    )) as unknown as JackpotRoundAccount;\n  } catch {\n    return null;\n  }\n}\n\n/** Assert a Lord of RNGs round PDA is closed. */\nexport async function assertLordRoundClosed(\n  connection: Connection,\n  roundPda: PublicKey,\n): Promise<void> {\n  const round = await fetchLordRound(connection, roundPda);\n  if (round !== null) {\n    const phase = Object.keys(round.phase)[0];\n    throw new Error(\n      `Expected round PDA to be closed, but it still exists (phase: ${phase})`,\n    );\n  }\n}\n\n/**\n * Calculate the expected fee and net payout for a Lord of RNGs jackpot round.\n * pool = entryAmount * totalEntries; fee = floor(pool * 300 / 10_000).\n */\nexport function calculateLordExpectedFee(\n  entryAmount: number,\n  totalEntries: number,\n): { pool: number; fee: number; payout: number } {\n  const pool = entryAmount * totalEntries;\n  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n  const payout = pool - fee;\n  return { pool, fee, payout };\n}\n\n/**\n * Assert that the treasury received the expected Lord of RNGs fee.\n */\nexport async function assertLordTreasuryFee(\n  connection: Connection,\n  treasury: PublicKey,\n  balanceBefore: number,\n  entryAmount: number,\n  totalEntries: number,\n): Promise<void> {\n  const balanceAfter = await getBalanceLamports(connection, treasury);\n  const { fee } = calculateLordExpectedFee(entryAmount, totalEntries);\n  const actualDelta = balanceAfter - balanceBefore;\n\n  if (actualDelta !== fee) {\n    throw new Error(\n      `Lord treasury fee mismatch: expected ${fee} lamports, got delta ${actualDelta}`,\n    );\n  }\n}","originalFile":"/**\n * On-chain assertion helpers for local E2E tests.\n *\n * Provides RPC-based helpers to query and assert match PDA state,\n * treasury fee deltas, and player profile stat updates.\n */\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  CoinflipIDL,\n  PlatformIDL,\n  LordofrngsIDL,\n  type Coinflip,\n  type Platform,\n  type Lordofrngs,\n} from \"@rng-utopia/anchor-client\";\n\n// ============ Program IDs ============\n\n/** Coinflip program address (from IDL). */\nexport const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n\n/** Platform program address (from IDL). */\nexport const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n\n/** Lord of RNGs program address (from IDL). */\nexport const LORDOFRNGS_PROGRAM_ID = new PublicKey(LordofrngsIDL.address);\n\n/** Platform fee: 300 basis points = 3%. */\nexport const FEE_BPS = 300;\n\n// ============ PDA Derivation ============\n\n/** Derive the match PDA for a creator. Seeds: [\"match\", creator]. */\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n\n/** Derive the coinflip config PDA. Seeds: [\"coinflip_config\"]. */\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n\n/** Derive a player profile PDA. Seeds: [\"player_profile\", wallet]. */\nexport function getPlayerProfilePda(wallet: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PLATFORM_PROGRAM_ID,\n  );\n}\n\n// ============ Program Instances ============\n\n/**\n * Create a read-only Coinflip program instance.\n *\n * @param connection - Solana RPC connection\n */\nexport function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" },\n  );\n  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n}\n\n/**\n * Create a read-only Platform program instance.\n *\n * @param connection - Solana RPC connection\n */\nexport function getPlatformProgram(connection: Connection): Program<Platform> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" },\n  );\n  return new Program(PlatformIDL as Idl as Platform, provider);\n}\n\n// ============ Account Types ============\n\n/** Deserialized match account shape. */\nexport interface MatchAccount {\n  creator: PublicKey;\n  opponent: PublicKey;\n  tier: number;\n  entryAmount: { toNumber(): number };\n  creatorSide: number;\n  phase: Record<string, object>;\n  result: number;\n  winner: PublicKey;\n  claimed: boolean;\n  createdAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  bump: number;\n}\n\n/** Deserialized player profile account shape. */\nexport interface PlayerProfileAccount {\n  authority: PublicKey;\n  totalGames: { toNumber(): number };\n  wins: { toNumber(): number };\n  totalWagered: { toNumber(): number };\n  totalWon: { toNumber(): number };\n  bump: number;\n}\n\n// ============ Fetch Helpers ============\n\n/**\n * Fetch a match PDA account. Returns null if the account is closed.\n *\n * @param connection - Solana RPC connection\n * @param matchPda - The match PDA address\n */\nexport async function fetchMatch(\n  connection: Connection,\n  matchPda: PublicKey,\n): Promise<MatchAccount | null> {\n  const program = getCoinflipProgram(connection);\n  try {\n    return (await program.account.coinflipMatch.fetch(\n      matchPda,\n    )) as unknown as MatchAccount;\n  } catch {\n    // Account not found (closed or never created)\n    return null;\n  }\n}\n\n/**\n * Fetch a player profile PDA account. Returns null if it doesn't exist.\n *\n * @param connection - Solana RPC connection\n * @param profilePda - The player profile PDA address\n */\nexport async function fetchPlayerProfile(\n  connection: Connection,\n  profilePda: PublicKey,\n): Promise<PlayerProfileAccount | null> {\n  const program = getPlatformProgram(connection);\n  try {\n    return (await program.account.playerProfile.fetch(\n      profilePda,\n    )) as unknown as PlayerProfileAccount;\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Get the treasury wallet address from the coinflip config PDA.\n *\n * @param connection - Solana RPC connection\n */\nexport async function getTreasuryAddress(\n  connection: Connection,\n): Promise<PublicKey> {\n  const program = getCoinflipProgram(connection);\n  const [configPda] = getConfigPda();\n  const config = await program.account.coinflipConfig.fetch(configPda);\n  return (config as unknown as { treasury: PublicKey }).treasury;\n}\n\n// ============ Balance Helpers ============\n\n/**\n * Get the SOL balance of an address in lamports.\n *\n * @param connection - Solana RPC connection\n * @param address - Public key to check\n */\nexport async function getBalanceLamports(\n  connection: Connection,\n  address: PublicKey,\n): Promise<number> {\n  return connection.getBalance(address);\n}\n\n/**\n * Capture a balance snapshot for later delta comparison.\n *\n * @param connection - Solana RPC connection\n * @param address - Public key to snapshot\n */\nexport async function snapshotBalance(\n  connection: Connection,\n  address: PublicKey,\n): Promise<number> {\n  return connection.getBalance(address);\n}\n\n// ============ Fee Calculation ============\n\n/**\n * Calculate the expected fee and net payout for a coinflip match.\n * Mirrors on-chain logic: fee = floor(pool * FEE_BPS / 10_000).\n *\n * @param entryAmount - Single player's entry in lamports\n * @returns Object with pool, fee, and payout amounts in lamports\n */\nexport function calculateExpectedFee(entryAmount: number): {\n  pool: number;\n  fee: number;\n  payout: number;\n} {\n  const pool = entryAmount * 2;\n  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n  const payout = pool - fee;\n  return { pool, fee, payout };\n}\n\n// ============ Assertion Helpers ============\n\n/**\n * Assert match PDA state after creation (Waiting phase).\n *\n * @param connection - Solana RPC connection\n * @param creator - Creator's public key\n * @param expectedTier - Expected tier index\n * @param expectedSide - Expected creator side (0 = heads, 1 = tails)\n */\nexport async function assertMatchCreated(\n  connection: Connection,\n  creator: PublicKey,\n  expectedTier: number,\n  expectedSide: number,\n): Promise<{ matchPda: PublicKey; match: MatchAccount }> {\n  const [matchPda] = getMatchPda(creator);\n  const match = await fetchMatch(connection, matchPda);\n  if (!match) throw new Error(`Match PDA not found for creator ${creator}`);\n\n  const phase = Object.keys(match.phase)[0];\n  if (phase !== \"waiting\") {\n    throw new Error(`Expected phase 'waiting', got '${phase}'`);\n  }\n  if (match.creator.toBase58() !== creator.toBase58()) {\n    throw new Error(\"Match creator does not match expected creator\");\n  }\n  if (match.tier !== expectedTier) {\n    throw new Error(`Expected tier ${expectedTier}, got ${match.tier}`);\n  }\n  if (match.creatorSide !== expectedSide) {\n    throw new Error(`Expected side ${expectedSide}, got ${match.creatorSide}`);\n  }\n  if (match.opponent.toBase58() !== PublicKey.default.toBase58()) {\n    throw new Error(\"Expected no opponent in waiting phase\");\n  }\n  if (match.claimed) {\n    throw new Error(\"Expected claimed=false after creation\");\n  }\n\n  return { matchPda, match };\n}\n\n/**\n * Assert match PDA is closed (account no longer exists).\n *\n * @param connection - Solana RPC connection\n * @param matchPda - The match PDA address to check\n */\nexport async function assertMatchClosed(\n  connection: Connection,\n  matchPda: PublicKey,\n): Promise<void> {\n  const match = await fetchMatch(connection, matchPda);\n  if (match !== null) {\n    const phase = Object.keys(match.phase)[0];\n    throw new Error(\n      `Expected match PDA to be closed, but it still exists (phase: ${phase})`,\n    );\n  }\n}\n\n/**\n * Assert that the treasury received the expected fee.\n * Call snapshotBalance before the payout, then call this after.\n *\n * @param connection - Solana RPC connection\n * @param treasury - Treasury public key\n * @param balanceBefore - Treasury balance in lamports before claim\n * @param entryAmount - Single player's entry in lamports\n */\nexport async function assertTreasuryFee(\n  connection: Connection,\n  treasury: PublicKey,\n  balanceBefore: number,\n  entryAmount: number,\n): Promise<void> {\n  const balanceAfter = await getBalanceLamports(connection, treasury);\n  const { fee } = calculateExpectedFee(entryAmount);\n  const actualDelta = balanceAfter - balanceBefore;\n\n  if (actualDelta !== fee) {\n    throw new Error(\n      `Treasury fee mismatch: expected ${fee} lamports, got delta ${actualDelta}`,\n    );\n  }\n}\n\n/**\n * Assert player profile stats after a game.\n *\n * @param connection - Solana RPC connection\n * @param wallet - Player's wallet public key\n * @param expected - Expected stat values\n */\nexport async function assertPlayerProfile(\n  connection: Connection,\n  wallet: PublicKey,\n  expected: {\n    totalGames: number;\n    wins: number;\n    totalWagered: number;\n    totalWon: number;\n  },\n): Promise<void> {\n  const [profilePda] = getPlayerProfilePda(wallet);\n  const profile = await fetchPlayerProfile(connection, profilePda);\n  if (!profile) {\n    throw new Error(`Player profile not found for ${wallet}`);\n  }\n\n  const actual = {\n    totalGames: profile.totalGames.toNumber(),\n    wins: profile.wins.toNumber(),\n    totalWagered: profile.totalWagered.toNumber(),\n    totalWon: profile.totalWon.toNumber(),\n  };\n\n  for (const key of Object.keys(expected) as (keyof typeof expected)[]) {\n    if (actual[key] !== expected[key]) {\n      throw new Error(\n        `Profile ${key} mismatch for ${wallet}: expected ${expected[key]}, got ${actual[key]}`,\n      );\n    }\n  }\n}\n\n/**\n * Assert player profile stats changed by a specific delta since a snapshot.\n *\n * @param connection - Solana RPC connection\n * @param wallet - Player's wallet public key\n * @param before - Profile stats snapshot before the action\n * @param delta - Expected stat deltas\n */\nexport async function assertPlayerProfileDelta(\n  connection: Connection,\n  wallet: PublicKey,\n  before: { totalGames: number; wins: number; totalWagered: number; totalWon: number },\n  delta: { totalGames: number; wins: number; totalWagered: number; totalWon: number },\n): Promise<void> {\n  const expected = {\n    totalGames: before.totalGames + delta.totalGames,\n    wins: before.wins + delta.wins,\n    totalWagered: before.totalWagered + delta.totalWagered,\n    totalWon: before.totalWon + delta.totalWon,\n  };\n  await assertPlayerProfile(connection, wallet, expected);\n}\n\n/**\n * Snapshot a player profile's current stats (for later delta comparison).\n * Returns zero-stats if the profile doesn't exist yet.\n *\n * @param connection - Solana RPC connection\n * @param wallet - Player's wallet public key\n */\nexport async function snapshotPlayerProfile(\n  connection: Connection,\n  wallet: PublicKey,\n): Promise<{ totalGames: number; wins: number; totalWagered: number; totalWon: number }> {\n  const [profilePda] = getPlayerProfilePda(wallet);\n  const profile = await fetchPlayerProfile(connection, profilePda);\n  if (!profile) {\n    return { totalGames: 0, wins: 0, totalWagered: 0, totalWon: 0 };\n  }\n  return {\n    totalGames: profile.totalGames.toNumber(),\n    wins: profile.wins.toNumber(),\n    totalWagered: profile.totalWagered.toNumber(),\n    totalWon: profile.totalWon.toNumber(),\n  };\n}\n","structuredPatch":[{"oldStart":393,"oldLines":3,"newStart":393,"newLines":115,"lines":["     totalWon: profile.totalWon.toNumber(),","   };"," }","+","+// ============ Lord of RNGs Helpers ============","+","+/** Derive a Lord of RNGs round PDA. Seeds: [\"jackpot_round\", tier(u8), roundNumber(u64 LE)]. */","+export function getLordRoundPda(tier: number, roundNumber: bigint | number): [PublicKey, number] {","+  const tierBuf = Buffer.alloc(1);","+  tierBuf.writeUInt8(tier);","+  const roundBuf = Buffer.alloc(8);","+  roundBuf.writeBigUInt64LE(BigInt(roundNumber));","+  return PublicKey.findProgramAddressSync(","+    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],","+    LORDOFRNGS_PROGRAM_ID,","+  );","+}","+","+/** Derive the Lord of RNGs config PDA. Seeds: [\"lord_config\"]. */","+export function getLordConfigPda(): [PublicKey, number] {","+  return PublicKey.findProgramAddressSync(","+    [Buffer.from(\"lord_config\")],","+    LORDOFRNGS_PROGRAM_ID,","+  );","+}","+","+/** Create a read-only Lord of RNGs program instance. */","+export function getLordProgram(connection: Connection): Program<Lordofrngs> {","+  const provider = new AnchorProvider(","+    connection,","+    {} as AnchorProvider[\"wallet\"],","+    { commitment: \"confirmed\" },","+  );","+  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);","+}","+","+/** Deserialized jackpot round account shape. */","+export interface JackpotRoundAccount {","+  tier: number;","+  roundNumber: { toNumber(): number };","+  entryAmount: { toNumber(): number };","+  phase: Record<string, object>;","+  players: { player: PublicKey; entries: number }[];","+  totalEntries: number;","+  creator: PublicKey;","+  claimed: boolean;","+  winner: PublicKey;","+  winningSlot: number;","+  vrfRequestKey: PublicKey;","+  bump: number;","+}","+","+/** Fetch a Lord of RNGs round PDA. Returns null if closed/missing. */","+export async function fetchLordRound(","+  connection: Connection,","+  roundPda: PublicKey,","+): Promise<JackpotRoundAccount | null> {","+  const program = getLordProgram(connection);","+  try {","+    return (await program.account.jackpotRound.fetch(","+      roundPda,","+    )) as unknown as JackpotRoundAccount;","+  } catch {","+    return null;","+  }","+}","+","+/** Assert a Lord of RNGs round PDA is closed. */","+export async function assertLordRoundClosed(","+  connection: Connection,","+  roundPda: PublicKey,","+): Promise<void> {","+  const round = await fetchLordRound(connection, roundPda);","+  if (round !== null) {","+    const phase = Object.keys(round.phase)[0];","+    throw new Error(","+      `Expected round PDA to be closed, but it still exists (phase: ${phase})`,","+    );","+  }","+}","+","+/**","+ * Calculate the expected fee and net payout for a Lord of RNGs jackpot round.","+ * pool = entryAmount * totalEntries; fee = floor(pool * 300 / 10_000).","+ */","+export function calculateLordExpectedFee(","+  entryAmount: number,","+  totalEntries: number,","+): { pool: number; fee: number; payout: number } {","+  const pool = entryAmount * totalEntries;","+  const fee = Math.floor((pool * FEE_BPS) / 10_000);","+  const payout = pool - fee;","+  return { pool, fee, payout };","+}","+","+/**","+ * Assert that the treasury received the expected Lord of RNGs fee.","+ */","+export async function assertLordTreasuryFee(","+  connection: Connection,","+  treasury: PublicKey,","+  balanceBefore: number,","+  entryAmount: number,","+  totalEntries: number,","+): Promise<void> {","+  const balanceAfter = await getBalanceLamports(connection, treasury);","+  const { fee } = calculateLordExpectedFee(entryAmount, totalEntries);","+  const actualDelta = balanceAfter - balanceBefore;","+","+  if (actualDelta !== fee) {","+    throw new Error(","+      `Lord treasury fee mismatch: expected ${fee} lamports, got delta ${actualDelta}`,","+    );","+  }","+}"]}],"userModified":false,"replaceAll":false}}
