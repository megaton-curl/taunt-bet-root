= PublicKey.findProgramAddressSync(\n    54→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    55→    ORAO_VRF_PROGRAM_ID\n    56→  );\n    57→  return pda;\n    58→}\n    59→\n    60→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    61→  const [pda] = PublicKey.findProgramAddressSync(\n    62→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    63→    ORAO_VRF_PROGRAM_ID\n    64→  );\n    65→  return pda;\n    66→}\n    67→\n    68→// ============ Program Instance ============\n    69→\n    70→export function getLordProgram(connection: Connection): Program<Lordofrngs> {\n    71→  const provider = new AnchorProvider(\n    72→    connection,\n    73→    {} as AnchorProvider[\"wallet\"],\n    74→    { commitment: \"confirmed\" }\n    75→  );\n    76→  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n    77→}\n    78→\n    79→// ============ On-Chain Account Types ============\n    80→\n    81→type RoundPhaseVariant =\n    82→  | { waiting: object }\n    83→  | { active: object }\n    84→  | { locked: object }\n    85→  | { resolving: object }\n    86→  | { settled: object }\n    87→  | { refunded: object };\n    88→\n    89→interface OnChainPlayerEntry {\n    90→  player: PublicKey;\n    91→  entries: number;\n    92→}\n    93→\n    94→interface OnChainRound {\n    95→  tier: number;\n    96→  roundNumber: { toNumber(): number };\n    97→  entryAmount: { toNumber(): number };\n    98→  phase: RoundPhaseVariant;\n    99→  players: OnChainPlayerEntry[];\n   100→  totalEntries: number;"}]},"parent_tool_use_id":null,"session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"7022ccd4-6389-4020-9b75-24cb975688c1","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/chain.ts","content":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport { LordofrngsIDL, type Lordofrngs } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  type Tier,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { Round, PlayerEntry } from \"../types\";\nimport { PLAYER_COLORS } from \"../types\";\n\n// ============ Constants ============\n\nconst LORDOFRNGS_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_LORDOFRNGS_PROGRAM_ID ?? LordofrngsIDL.address\n);\n\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\n  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\"\n);\n\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\n// ============ PDA Derivation ============\n\nexport function getRoundPda(\n  tier: number,\n  roundNumber: bigint | number\n): [PublicKey, number] {\n  const tierBuf = Buffer.alloc(1);\n  tierBuf.writeUInt8(tier);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\nfunction getOraoNetworkStatePda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ============ Program Instance ============\n\nexport function getLordProgram(connection: Connection): Program<Lordofrngs> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n}\n\n// ============ On-Chain Account Types ============\n\ntype RoundPhaseVariant =\n  | { waiting: object }\n  | { active: object }\n  | { locked: object }\n  | { resolving: object }\n  | { settled: object }\n  | { refunded: object };\n\ninterface OnChainPlayerEntry {\n  player: PublicKey;\n  entries: number;\n}\n\ninterface OnChainRound {\n  tier: number;\n  roundNumber: { toNumber(): number };\n  entryAmount: { toNumber(): number };\n  phase: RoundPhaseVariant;\n  players: OnChainPlayerEntry[];\n  totalEntries: number;","numLines":100,"startLine":1,"totalLines":581}}}
