iles();\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"lord lifecycle: create → join → countdown → spin → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // On-chain constants for iron tier\n  const TIER_IRON = 0;\n  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates to Lord of the RNGs and selects iron tier\n  await po.navigateToLord(playerAPage);\n  await po.selectTier(playerAPage, TIER_IRON);\n\n  // Player A joins the round (creates it as first player)\n  await po.joinRound(playerAPage);\n\n  // Verify round PDA exists on-chain (tier=0, round=0)\n  const [roundPda] = getLordRoundPda(TIER_IRON, 0);\n  const round = await fetchLordRound(connection, roundPda);\n  expect(round).not.toBeNull();\n  expect(round!.players.length).toBe(1);\n  expect(round!.players[0]!.player.toBase58()).toBe(PLAYER_A.publicKey.toBase58());\n\n  // 2. Player B navigates and selects the same tier\n  await po.navigateToLord(playerBPage);\n  await po.selectTier(playerBPage, TIER_IRON);\n\n  // Player B joins the round (triggers countdown as 2nd unique player)\n  await po.joinRound(playerBPage);\n\n  // Verify on-chain: 2 players, phase is Active (countdown started)\n  const roundAfterJoin = await fetchLordRound(connection, roundPda);\n  expect(roundAfterJoin).not.toBeNull();\n  expect(roundAfterJoin!.players.length).toBe(2);\n  const phase = Object.keys(roundAfterJoin!.phase)[0];\n  expect(phase).toBe(\"active\");\n\n  // 3. Wait for countdown to expire (~60 seconds)\n  // The frontend polls every 5s and shows the countdown timer.\n  // After countdown expires, the \"Spin\" button should appear/enable.\n  // We wait for the Spin button to become visible (polls detect countdown expiry).\n  await expect(\n    playerAPage.locator(po.sel.actionButton, { hasText: /Spin/i }),\n  ).toBeVisible({ timeout: 75_000 }); // 60s countdown + poll interval + buffer\n\n  // ── On-chain: snapshot treasury before spin/claim ──\n  const treasury = await getTreasuryAddress(connection);\n  const treasuryBefore = await snapshotBalance(connection, treasury);\n\n  // 4. Player A triggers the spin\n  await po.startSpin(playerAPage);\n\n  // 5. Wait for the winner to be revealed.\n  // VRF is pre-fulfilled → frontend detects immediately on next poll.\n  // The winning_slot=0 → Player A (creator) wins.\n  const playerAWon = await po.waitForWinnerAnnouncement(playerAPage, 30_000);\n  expect(playerAWon).toBe(true);\n\n  // Player B should also see the result (either announcement or auto-return)\n  // Give Player B some time to detect the result\n  await playerBPage.waitForTimeout(5_000);\n\n  // 6. Wait for claim to complete (auto-claim triggered by frontend)\n  await po.waitForClaimComplete(playerAPage, 30_000);\n\n  // 7. Verify on-chain state\n\n  // Round PDA should be closed after claim\n  await assertLordRoundClosed(connection, roundPda);\n\n  // Treasury should have received the 3% fee\n  // 2 entries × 0.005 SOL = 0.01 SOL pool, 3% fee = 300 lamports\n  const TOTAL_ENTRIES = 2;\n  await assertLordTreasuryFee(\n    connection,\n    treasury,\n    treasuryBefore,\n    ENTRY_AMOUNT,\n    TOTAL_ENTRIES,\n  );\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","structuredPatch":[],"originalFile":null}}
