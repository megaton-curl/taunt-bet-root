{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0155hUxzmR81KsQCiZEViYtE","type":"tool_result","content":"     1→import { test, expect } from \"./fixtures\";\n     2→import * as po from \"./helpers/page-objects\";\n     3→\n     4→/**\n     5→ * Smoke test for the local E2E environment.\n     6→ * Verifies the app starts in real wallet mode against the local validator.\n     7→ *\n     8→ * Uses dual-player fixtures so that the test wallet seed is injected,\n     9→ * preventing TestWalletWrapper from throwing on missing seed.\n    10→ */\n    11→test.describe(\"Local E2E smoke\", () => {\n    12→  test(\"app loads in real mode against local validator\", async ({\n    13→    playerAPage,\n    14→  }) => {\n    15→    const consoleTracker = po.trackConsoleErrors(playerAPage);\n    16→\n    17→    await playerAPage.goto(\"/\", { waitUntil: \"networkidle\" });\n    18→\n    19→    // App renders the main title\n    20→    await expect(playerAPage.locator(\".rpg-title\")).toBeVisible({\n    21→      timeout: 10_000,\n    22→    });\n    23→\n    24→    // Wallet icon is visible\n    25→    await expect(playerAPage.locator(\".rpg-wallet-icon\")).toBeVisible();\n    26→\n    27→    // No critical console errors\n    28→    consoleTracker.assertClean();\n    29→  });\n    30→});\n    31→"}]},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"ac624a73-ea11-40c5-b9b2-99eaa08a78a6"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01Q48CFvqCUe6PDWuSpEuVCc","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0133QEmMDuHQUWgeHAej7iu5","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/01-error-flow.spec.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":3573,"cache_read_input_tokens":32009,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3573},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"557f67ef-efb2-4a39-8e71-3c6315d222b6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0133QEmMDuHQUWgeHAej7iu5","type":"tool_result","content":"     1→/**\n     2→ * Local error-flow E2E tests: insufficient balance, join unavailable match,\n     3→ * settle already-claimed match.\n     4→ *\n     5→ * Tests run serially because later tests depend on chain state left by earlier\n     6→ * ones (e.g. additional airdrop in test 2).\n     7→ *\n     8→ * Prerequisites (handled by localnet-bootstrap.sh):\n     9→ * - solana-test-validator running with coinflip + platform programs\n    10→ * - Orao mock accounts pre-loaded (required for lifecycle in test 3)\n    11→ */\n    12→import { Connection } from \"@solana/web3.js\";\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import {\n    16→  fundWallet,\n    17→  PLAYER_A,\n    18→  PLAYER_B,\n    19→  LOCAL_RPC_URL,\n    20→} from \"./helpers/wallets\";\n    21→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    22→import { assertMatchClosed, getMatchPda } from \"./helpers/on-chain\";\n    23→\n    24→// ── Serial execution: skip remaining tests if one fails ───────────────\n    25→\n    26→test.describe(\"Error flow tests\", () => {\n    27→  test.describe.configure({ mode: \"serial\" });\n    28→\n    29→  test.beforeAll(async () => {\n    30→    await initializeLocalnet();\n    31→    const connection = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    32→    // Fund Player A with minimal SOL — insufficient for iron tier (0.005 SOL)\n    33→    await fundWallet(connection, PLAYER_A.publicKey, 0.001);\n    34→    // Fund Player B with standard amount\n    35→    await fundWallet(connection, PLAYER_B.publicKey, 10);\n    36→  });\n    37→\n    38→  // ── Test 1: Insufficient balance ─────────────────────────────────────\n    39→\n    40→  test(\"insufficient balance: creating match shows error toast\", async ({\n    41→    playerAPage,\n    42→    connection,\n    43→  }) => {\n    44→    await po.navigateToCoinflip(playerAPage);\n    45→    await po.selectTier(playerAPage, \"iron\");\n    46→    await po.selectSide(playerAPage, \"heads\");\n    47→\n    48→    // Click \"Create Game\" — balance (0.001 SOL) < iron entry (0.005 SOL)\n    49→    const createBtn = playerAPage.locator(po.sel.actionButton, {\n    50→      hasText: \"Create Game\",\n    51→    });\n    52→    await expect(createBtn).toBeEnabled();\n    53→    await createBtn.click();\n    54→\n    55→    // Error toast should appear with insufficient balance message\n    56→    await po.assertErrorToast(playerAPage, \"Insufficient balance\", 10_000);\n    57→\n    58→    // Verify no match was created on-chain\n    59→    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    60→    await assertMatchClosed(connection, matchPda);\n    61→  });\n    62→\n    63→  // ── Test 2: Join unavailable (cancelled) match ───────────────────────\n    64→\n    65→  test(\"joining unavailable match shows error toast\", async ({\n    66→    playerAPage,\n    67→    playerBPage,\n    68→    connection,\n    69→  }) => {\n    70→    // Fund A properly for this test (previous test left A with 0.001 SOL)\n    71→    await fundWallet(connection, PLAYER_A.publicKey, 10);\n    72→\n    73→    // A creates a match (iron tier, heads)\n    74→    await po.navigateToCoinflip(playerAPage);\n    75→    await po.createMatch(playerAPage, \"iron\", \"heads\");\n    76→\n    77→    // B navigates and sees the match in lobby\n    78→    await po.navigateToCoinflip(playerBPage);\n    79→    await po.waitForLobbyMatch(playerBPage, 15_000);\n    80→\n    81→    // A cancels the match — PDA closes on-chain\n    82→    await po.cancelMatch(playerAPage);\n    83→    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    84→    await assertMatchClosed(connection, matchPda);\n    85→\n    86→    // B tries to join the stale lobby card (lobby hasn't re-polled yet)\n    87→    const joinBtn = playerBPage\n    88→      .locator(\n    89→        `${po.sel.matchCard}:not(${po.sel.matchCardOwn}):not(${po.sel.matchCardClaimable})`,\n    90→      )\n    91→      .first()\n    92→      .locator(po.sel.matchCardJoinBtn);\n    93→    await joinBtn.click();\n    94→\n    95→    // Error toast should appear on B's page\n    96→    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n    97→      timeout: 10_000,\n    98→    });\n    99→  });\n   100→\n   101→  // ── Test 3: Settle already-claimed match ─────────────────────────────\n   102→\n   103→  test(\"settling already-claimed match shows error toast\", async ({\n   104→    playerAPage,\n   105→    playerBPage,\n   106→    connection,\n   107→  }) => {\n   108→    // A creates a match (iron tier, heads)\n   109→    await po.navigateToCoinflip(playerAPage);\n   110→    await po.createMatch(playerAPage, \"iron\", \"heads\");\n   111→\n   112→    // B navigates and joins\n   113→    await po.navigateToCoinflip(playerBPage);\n   114→    await po.waitForLobbyMatch(playerBPage, 15_000);\n   115→    await po.joinMatch(playerBPage);\n   116→\n   117→    // Both wait for VRF resolution (pre-loaded: HEADS → A wins)\n   118→    const [resultA, resultB] = await Promise.all([\n   119→      po.waitForResult(playerAPage, 30_000),\n   120→      po.waitForResult(playerBPage, 30_000),\n   121→    ]);\n   122→    expect(resultA).toBe(\"won\");\n   123→    expect(resultB).toBe(\"lost\");\n   124→\n   125→    // A (winner) claims payout — match PDA closes\n   126→    await po.claimOrSettle(playerAPage);\n   127→    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n   128→    await assertMatchClosed(connection, matchPda);\n   129→\n   130→    // B still sees \"Settle & Return\" because B's context hasn't refreshed.\n   131→    // B tries to settle — fails because match PDA is already closed.\n   132→    const settleBtn = playerBPage\n   133→      .locator(po.sel.sidebar)\n   134→      .locator(po.sel.actionButton)\n   135→      .first();\n   136→    await expect(settleBtn).toBeVisible({ timeout: 5_000 });\n   137→    await settleBtn.click();\n   138→\n   139→    // Error toast should appear on B's page\n   140→    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n   141→      timeout: 10_000,\n   142→    });\n   143→  });\n   144→});\n   145→"}]},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"95fcfd05-0869-4211-8a68-aa85789c5453"}
