{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DbnMFMuvhtHe7HWYoEjwPF","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\n     5→import {\n     6→  Keypair,\n     7→  PublicKey,\n     8→  SystemProgram,\n     9→  LAMPORTS_PER_SOL,\n    10→} from \"@solana/web3.js\";\n    11→import { Clock } from \"solana-bankrun\";\n    12→import type { Coinflip } from \"../target/types/coinflip\";\n    13→import type { Platform } from \"../target/types/platform\";\n    14→import { readFileSync } from \"fs\";\n    15→import { dirname, join } from \"path\";\n    16→import { fileURLToPath } from \"url\";\n    17→\n    18→const __filename = fileURLToPath(import.meta.url);\n    19→const __dirname = dirname(__filename);\n    20→\n    21→const IDL = JSON.parse(\n    22→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n    23→);\n    24→const PROGRAM_ID = new PublicKey(IDL.address);\n    25→\n    26→const PLATFORM_IDL = JSON.parse(\n    27→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    28→);\n    29→const PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Constants matching shared crate\n    33→// ---------------------------------------------------------------------------\n    34→const SIDE_HEADS = 0;\n    35→const SIDE_TAILS = 1;\n    36→const TIER_IRON = 0;\n    37→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n    38→const TOTAL_FEE_BPS = 300;\n    39→const DEFAULT_RESOLVE_TIMEOUT = 120; // seconds\n    40→\n    41→// Mock VRF randomness buffers (32 bytes each)\n    42→// HEADS: byte[0]=2 → 2%2=0=HEADS, non-zero so is_fulfilled=true\n    43→const RANDOMNESS_HEADS = (() => {\n    44→  const buf = Buffer.alloc(32);\n    45→  buf[0] = 2;\n    46→  return buf;\n    47→})();\n    48→// TAILS: byte[0]=1 → 1%2=1=TAILS, non-zero so is_fulfilled=true\n    49→const RANDOMNESS_TAILS = (() => {\n    50→  const buf = Buffer.alloc(32);\n    51→  buf[0] = 1;\n    52→  return buf;\n    53→})();\n    54→// Unfulfilled: all zeros → is_fulfilled=false\n    55→const RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n    56→\n    57→// ---------------------------------------------------------------------------\n    58→// PDA helpers\n    59→// ---------------------------------------------------------------------------\n    60→function getMatchPda(creator: PublicKey): PublicKey {\n    61→  const [pda] = PublicKey.findProgramAddressSync(\n    62→    [Buffer.from(\"match\"), creator.toBuffer()],\n    63→    PROGRAM_ID\n    64→  );\n    65→  return pda;\n    66→}\n    67→\n    68→function getConfigPda(): PublicKey {\n    69→  const [pda] = PublicKey.findProgramAddressSync(\n    70→    [Buffer.from(\"coinflip_config\")],\n    71→    PROGRAM_ID\n    72→  );\n    73→  return pda;\n    74→}\n    75→\n    76→function getPlatformConfigPda(): PublicKey {\n    77→  const [pda] = PublicKey.findProgramAddressSync(\n    78→    [Buffer.from(\"platform_config\")],\n    79→    PLATFORM_PROGRAM_ID\n    80→  );\n    81→  return pda;\n    82→}\n    83→\n    84→function getPlayerProfilePda(wallet: PublicKey): PublicKey {\n    85→  const [pda] = PublicKey.findProgramAddressSync(\n    86→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    87→    PLATFORM_PROGRAM_ID\n    88→  );\n    89→  return pda;\n    90→}\n    91→\n    92→// ---------------------------------------------------------------------------\n    93→// Test context factory\n    94→// ---------------------------------------------------------------------------\n    95→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n    96→  return {\n    97→    lamports,\n    98→    data: Buffer.alloc(0),\n    99→    owner: SystemProgram.programId,\n   100→    executable: false,\n   101→  };\n   102→}\n   103→\n   104→interface TestContext {\n   105→  context: Awaited<ReturnType<typeof startAnchor>>;\n   106→  creator: PublicKey;\n   107→  opponent: Keypair;\n   108→  treasury: Keypair;\n   109→  mockRandomness: Keypair;\n   110→  mockOraoProgram: Keypair;\n   111→  mockOraoNetworkState: Keypair;\n   112→  mockOraoTreasury: Keypair;\n   113→  creatorProgram: Program<Coinflip>;\n   114→  opponentProgram: Program<Coinflip>;\n   115→  platformProgram: Program<Platform>;\n   116→  opponentPlatformProgram: Program<Platform>;\n   117→  configPda: PublicKey;\n   118→  matchPda: PublicKey;\n   119→  platformConfigPda: PublicKey;\n   120→  creatorProfilePda: PublicKey;\n   121→  opponentProfilePda: PublicKey;\n   122→}\n   123→\n   124→async function createTestContext(): Promise<TestContext> {\n   125→  const opponent = Keypair.generate();\n   126→  const treasury = Keypair.generate();\n   127→  const mockRandomness = Keypair.generate();\n   128→  const mockOraoProgram = Keypair.generate();\n   129→  const mockOraoNetworkState = Keypair.generate();\n   130→  const mockOraoTreasury = Keypair.generate();\n   131→\n   132→  const context = await startAnchor(\"./\", [], [\n   133→    { address: opponent.publicKey, info: fundedAccountData() },\n   134→    { address: treasury.publicKey, info: fundedAccountData() },\n   135→    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n   136→    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n   137→    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n   138→    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n   139→    // Mock randomness account — starts unfulfilled (32 zero bytes)\n   140→    {\n   141→      address: mockRandomness.publicKey,\n   142→      info: {\n   143→        lamports: LAMPORTS_PER_SOL,\n   144→        data: RANDOMNESS_UNFULFILLED,\n   145→        owner: SystemProgram.programId,\n   146→        executable: false,\n   147→      },\n   148→    },\n   149→  ]);\n   150→\n   151→  const creatorProvider = new BankrunProvider(context);\n   152→  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n   153→\n   154→  const opponentProvider = new BankrunProvider(context, new Wallet(opponent));\n   155→  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n   156→\n   157→  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n   158→  const opponentPlatformProgram = new Program<Platform>(\n   159→    PLATFORM_IDL,\n   160→    opponentProvider\n   161→  );\n   162→\n   163→  const creator = creatorProvider.wallet.publicKey;\n   164→  const configPda = getConfigPda();\n   165→  const matchPda = getMatchPda(creator);\n   166→  const platformConfigPda = getPlatformConfigPda();\n   167→  const creatorProfilePda = getPlayerProfilePda(creator);\n   168→  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n   169→\n   170→  return {\n   171→    context,\n   172→    creator,\n   173→    opponent,\n   174→    treasury,\n   175→    mockRandomness,\n   176→    mockOraoProgram,\n   177→    mockOraoNetworkState,\n   178→    mockOraoTreasury,\n   179→    creatorProgram,\n   180→    opponentProgram,\n   181→    platformProgram,\n   182→    opponentPlatformProgram,\n   183→    configPda,\n   184→    matchPda,\n   185→    platformConfigPda,\n   186→    creatorProfilePda,\n   187→    opponentProfilePda,\n   188→  };\n   189→}\n   190→\n   191→// ---------------------------------------------------------------------------\n   192→// Instruction helpers\n   193→// ---------------------------------------------------------------------------\n   194→async function initConfig(t: TestContext) {\n   195→  await t.creatorProgram.methods\n   196→    .initializeConfig(t.treasury.publicKey)\n   197→    .accounts({\n   198→      authority: t.creator,\n   199→      config: t.configPda,\n   200→      systemProgram: SystemProgram.programId,\n   201→    })\n   202→    .rpc();\n   203→}\n   204→\n   205→async function initPlatform(t: TestContext) {\n   206→  await t.platformProgram.methods\n   207→    .initializePlatform(t.treasury.publicKey)\n   208→    .accounts({\n   209→      authority: t.creator,\n   210→      config: t.platformConfigPda,\n   211→      systemProgram: SystemProgram.programId,\n   212→    })\n   213→    .rpc();\n   214→}\n   215→\n   216→async function createPlayerProfile(\n   217→  t: TestContext,\n   218→  program: Program<Platform>,\n   219→  player: PublicKey\n   220→) {\n   221→  const profilePda = getPlayerProfilePda(player);\n   222→  await program.methods\n   223→    .createPlayerProfile()\n   224→    .accounts({\n   225→      player,\n   226→      profile: profilePda,\n   227→      systemProgram: SystemProgram.programId,\n   228→    })\n   229→    .rpc();\n   230→}\n   231→\n   232→async function setupPlatform(t: TestContext) {\n   233→  await initPlatform(t);\n   234→  await createPlayerProfile(t, t.platformProgram, t.creator);\n   235→  await createPlayerProfile(\n   236→    t,\n   237→    t.opponentPlatformProgram,\n   238→    t.opponent.publicKey\n   239→  );\n   240→}\n   241→\n   242→async function createMatch(\n   243→  t: TestContext,\n   244→  tier = TIER_IRON,\n   245→  side = SIDE_HEADS\n   246→) {\n   247→  await t.creatorProgram.methods\n   248→    .createMatch(tier, side)\n   249→    .accounts({\n   250→      creator: t.creator,\n   251→      coinflipMatch: t.matchPda,\n   252→      config: t.configPda,\n   253→      systemProgram: SystemProgram.programId,\n   254→    })\n   255→    .rpc();\n   256→}\n   257→\n   258→async function joinMatch(t: TestContext) {\n   259→  await t.opponentProgram.methods\n   260→    .joinMatch()\n   261→    .accounts({\n   262→      opponent: t.opponent.publicKey,\n   263→      coinflipMatch: t.matchPda,\n   264→      config: t.configPda,\n   265→      oraoProgram: t.mockOraoProgram.publicKey,\n   266→      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   267→      oraoTreasury: t.mockOraoTreasury.publicKey,\n   268→      oraoRandom: t.mockRandomness.publicKey,\n   269→      systemProgram: SystemProgram.programId,\n   270→    })\n   271→    .rpc();\n   272→}\n   273→\n   274→async function claimPayout(\n   275→  t: TestContext,\n   276→  callerProgram: Program<Coinflip>,\n   277→  callerPubkey: PublicKey\n   278→) {\n   279→  await callerProgram.methods\n   280→    .claimPayout()\n   281→    .accounts({\n   282→      caller: callerPubkey,\n   283→      coinflipMatch: t.matchPda,\n   284→      config: t.configPda,\n   285→      treasury: t.treasury.publicKey,\n   286→      creator: t.creator,\n   287→      opponent: t.opponent.publicKey,\n   288→      randomnessAccount: t.mockRandomness.publicKey,\n   289→      creatorProfile: t.creatorProfilePda,\n   290→      opponentProfile: t.opponentProfilePda,\n   291→      platformProgram: PLATFORM_PROGRAM_ID,\n   292→      systemProgram: SystemProgram.programId,\n   293→    })\n   294→    .rpc();\n   295→}\n   296→\n   297→async function cancelMatch(t: TestContext) {\n   298→  await t.creatorProgram.methods\n   299→    .cancelMatch()\n   300→    .accounts({"}]},"parent_tool_use_id":"toolu_018QXifUfXe5KVGL4ALLeHmQ","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"1a702ad7-42a8-4e66-9bfb-1604ac32e267"}
