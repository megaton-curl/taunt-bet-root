{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014ia2a49L2A1fJ1tGGxAk8L","type":"tool_result","content":"     1→import { TIER_COLORS } from \"@rng-utopia/ui\";\n     2→import { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\n     3→import type { TierStatus } from \"../types\";\n     4→import { CountdownTimer } from \"./CountdownTimer\";\n     5→\n     6→interface TierLobbyProps {\n     7→  tierStatuses: TierStatus[];\n     8→  selectedTier: Tier | null;\n     9→  onSelectTier: (tier: Tier) => void;\n    10→  loading?: boolean;\n    11→}\n    12→\n    13→const TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n    14→\n    15→export function TierLobby({\n    16→  tierStatuses,\n    17→  selectedTier,\n    18→  onSelectTier,\n    19→  loading,\n    20→}: TierLobbyProps) {\n    21→  const getPhaseLabel = (status: TierStatus): string => {\n    22→    const round = status.currentRound;\n    23→    if (!round) return \"Starting...\";\n    24→\n    25→    switch (round.phase) {\n    26→      case \"waiting\":\n    27→        return \"Waiting for players\";\n    28→      case \"countdown\":\n    29→        return \"Countdown active\";\n    30→      case \"spinning\":\n    31→        return \"Spinning!\";\n    32→      case \"complete\":\n    33→        return \"Round complete\";\n    34→      default:\n    35→        return \"Unknown\";\n    36→    }\n    37→  };\n    38→\n    39→  const getPhaseClass = (status: TierStatus): string => {\n    40→    const round = status.currentRound;\n    41→    if (!round) return \"\";\n    42→    return `lotr-tier-card--${round.phase}`;\n    43→  };\n    44→\n    45→  if (loading) {\n    46→    return (\n    47→      <div className=\"lotr-tier-lobby lotr-tier-lobby--loading\">\n    48→        <div className=\"lotr-tier-lobby__loading\">Loading rounds...</div>\n    49→      </div>\n    50→    );\n    51→  }\n    52→\n    53→  return (\n    54→    <div className=\"lotr-tier-lobby\">\n    55→      <p className=\"lotr-tier-lobby__instruction\">Choose a tier to join the jackpot</p>\n    56→\n    57→      <div className=\"lotr-tier-lobby__grid\">\n    58→        {TIERS.map((tier) => {\n    59→          const status = tierStatuses.find((s) => s.tier === tier);\n    60→          const round = status?.currentRound;\n    61→          const isSelected = selectedTier === tier;\n    62→          const tierColor = TIER_COLORS[tier];\n    63→\n    64→          return (\n    65→            <button\n    66→              key={tier}\n    67→              type=\"button\"\n    68→              className={`lotr-tier-card ${getPhaseClass(status!)} ${isSelected ? \"lotr-tier-card--selected\" : \"\"}`}\n    69→              style={{\n    70→                \"--tier-color\": tierColor,\n    71→              } as React.CSSProperties}\n    72→              onClick={() => onSelectTier(tier)}\n    73→            >\n    74→              <div className=\"lotr-tier-card__header\">\n    75→                <span className={`rng-tier-gem rng-tier-gem--${tier}`} />\n    76→                <span className=\"lotr-tier-card__name\">{tier}</span>\n    77→                <span className=\"lotr-tier-card__amount\">\n    78→                  {TIER_AMOUNTS[tier]} SOL\n    79→                </span>\n    80→              </div>\n    81→\n    82→              <div className=\"lotr-tier-card__stats\">\n    83→                <div className=\"lotr-tier-card__stat\">\n    84→                  <span className=\"lotr-tier-card__stat-label\">Players</span>\n    85→                  <span className=\"lotr-tier-card__stat-value\">\n    86→                    {round?.players.length ?? 0}\n    87→                  </span>\n    88→                </div>\n    89→                <div className=\"lotr-tier-card__stat\">\n    90→                  <span className=\"lotr-tier-card__stat-label\">Pool</span>\n    91→                  <span className=\"lotr-tier-card__stat-value\">\n    92→                    {round?.poolAmount.toFixed(3) ?? \"0.000\"} SOL\n    93→                  </span>\n    94→                </div>\n    95→                <div className=\"lotr-tier-card__stat\">\n    96→                  <span className=\"lotr-tier-card__stat-label\">Entries</span>\n    97→                  <span className=\"lotr-tier-card__stat-value\">\n    98→                    {round?.totalEntries ?? 0}\n    99→                  </span>\n   100→                </div>\n   101→              </div>\n   102→\n   103→              <div className=\"lotr-tier-card__phase\">\n   104→                {round?.phase === \"countdown\" && round.countdownEndsAt ? (\n   105→                  <CountdownTimer endsAt={round.countdownEndsAt} size=\"small\" />\n   106→                ) : (\n   107→                  <span className=\"lotr-tier-card__phase-text\">\n   108→                    {getPhaseLabel(status!)}\n   109→                  </span>\n   110→                )}\n   111→              </div>\n   112→            </button>\n   113→          );\n   114→        })}\n   115→      </div>\n   116→    </div>\n   117→  );\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_01GY7cqnfJyMNU4xCHt3RoTx","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"d69e2ffa-5958-4dd0-b344-f8253e727b9d"}
