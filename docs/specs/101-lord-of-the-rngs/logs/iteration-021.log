{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QGzpEj5Fu2xXc6nm6Ti21C","type":"tool_result","content":"     1→import { useState, useEffect } from \"react\";\n     2→\n     3→interface CountdownTimerProps {\n     4→  endsAt: number;\n     5→  size?: \"small\" | \"large\";\n     6→  onComplete?: () => void;\n     7→}\n     8→\n     9→export function CountdownTimer({\n    10→  endsAt,\n    11→  size = \"large\",\n    12→  onComplete,\n    13→}: CountdownTimerProps) {\n    14→  const [timeLeft, setTimeLeft] = useState(() => {\n    15→    const remaining = Math.max(0, Math.ceil((endsAt - Date.now()) / 1000));\n    16→    return remaining;\n    17→  });\n    18→\n    19→  useEffect(() => {\n    20→    const interval = setInterval(() => {\n    21→      const remaining = Math.max(0, Math.ceil((endsAt - Date.now()) / 1000));\n    22→      setTimeLeft(remaining);\n    23→\n    24→      if (remaining === 0) {\n    25→        clearInterval(interval);\n    26→        onComplete?.();\n    27→      }\n    28→    }, 100);\n    29→\n    30→    return () => clearInterval(interval);\n    31→  }, [endsAt, onComplete]);\n    32→\n    33→  const minutes = Math.floor(timeLeft / 60);\n    34→  const seconds = timeLeft % 60;\n    35→\n    36→  const isUrgent = timeLeft <= 10;\n    37→  const isFinalCountdown = timeLeft <= 5;\n    38→\n    39→  return (\n    40→    <div\n    41→      className={`lotr-countdown lotr-countdown--${size} ${isUrgent ? \"lotr-countdown--urgent\" : \"\"} ${isFinalCountdown ? \"lotr-countdown--final\" : \"\"}`}\n    42→    >\n    43→      <span className=\"lotr-countdown__time\">\n    44→        {minutes}:{seconds.toString().padStart(2, \"0\")}\n    45→      </span>\n    46→      {size === \"large\" && (\n    47→        <span className=\"lotr-countdown__label\">until reveal</span>\n    48→      )}\n    49→    </div>\n    50→  );\n    51→}\n    52→"}]},"parent_tool_use_id":"toolu_01GY7cqnfJyMNU4xCHt3RoTx","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"e1552ba9-af7e-4d78-aa53-fd4fde4071ef"}
