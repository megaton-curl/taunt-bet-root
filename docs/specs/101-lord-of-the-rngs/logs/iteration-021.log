{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HJVZzLtjgAGNArT4vZr8Mh","type":"tool_result","content":"     1→/**\n     2→ * Local lifecycle E2E test: create → join → resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. The local validator has mock-VRF enabled,\n     6→ * and the randomness account is pre-loaded with fulfilled data\n     7→ * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n     8→ *\n     9→ * Prerequisites (handled by localnet-bootstrap.sh):\n    10→ * - solana-test-validator running with coinflip + platform programs\n    11→ * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n    12→ */\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import { fundTestWallets, PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    16→import { initializeLocalnet, ensurePlayerProfiles } from \"./helpers/localnet-setup\";\n    17→import {\n    18→  assertMatchCreated,\n    19→  assertMatchClosed,\n    20→  assertTreasuryFee,\n    21→  assertPlayerProfileDelta,\n    22→  snapshotBalance,\n    23→  snapshotPlayerProfile,\n    24→  getTreasuryAddress,\n    25→  calculateExpectedFee,\n    26→} from \"./helpers/on-chain\";\n    27→\n    28→// ── Suite setup ────────────────────────────────────────────────────────\n    29→\n    30→test.beforeAll(async () => {\n    31→  // Fund test wallets, initialize program configs, and create player profiles\n    32→  await fundTestWallets();\n    33→  await initializeLocalnet();\n    34→  await ensurePlayerProfiles();\n    35→});\n    36→\n    37→// ── Full lifecycle test ────────────────────────────────────────────────\n    38→\n    39→test(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n    40→  playerAPage,\n    41→  playerBPage,\n    42→  connection,\n    43→}) => {\n    44→  // On-chain constants for iron tier\n    45→  const TIER_IRON = 0;\n    46→  const SIDE_HEADS = 0;\n    47→  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n    48→\n    49→  // Track console errors in both contexts\n    50→  const consoleA = po.trackConsoleErrors(playerAPage);\n    51→  const consoleB = po.trackConsoleErrors(playerBPage);\n    52→\n    53→  // 1. Player A navigates and creates a match (iron tier, heads)\n    54→  await po.navigateToCoinflip(playerAPage);\n    55→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n    56→\n    57→  // Player A should see the active match in \"waiting\" state\n    58→  await expect(\n    59→    playerAPage.locator(po.sel.activeMatchWaiting),\n    60→  ).toBeVisible({ timeout: 10_000 });\n    61→\n    62→  // ── On-chain: verify match PDA after creation ──\n    63→  const { matchPda } = await assertMatchCreated(\n    64→    connection,\n    65→    PLAYER_A.publicKey,\n    66→    TIER_IRON,\n    67→    SIDE_HEADS,\n    68→  );\n    69→\n    70→  // 2. Player B navigates (after match is created) and sees it in the lobby\n    71→  await po.navigateToCoinflip(playerBPage);\n    72→  await po.waitForLobbyMatch(playerBPage, 15_000);\n    73→\n    74→  // 3. Player B joins the match\n    75→  await po.joinMatch(playerBPage);\n    76→\n    77→  // ── On-chain: snapshot treasury + profiles before resolution/claim ──\n    78→  const treasury = await getTreasuryAddress(connection);\n    79→  const treasuryBefore = await snapshotBalance(connection, treasury);\n    80→  const profileABefore = await snapshotPlayerProfile(connection, PLAYER_A.publicKey);\n    81→  const profileBBefore = await snapshotPlayerProfile(connection, PLAYER_B.publicKey);\n    82→\n    83→  // 4. Both players wait for the result.\n    84→  //    VRF is pre-fulfilled (HEADS) → creator (Player A) wins.\n    85→  //    The frontend polls every 5s for VRF fulfillment, then shows\n    86→  //    a 3s flip animation before the \"complete\" phase.\n    87→  const [resultA, resultB] = await Promise.all([\n    88→    po.waitForResult(playerAPage, 30_000),\n    89→    po.waitForResult(playerBPage, 30_000),\n    90→  ]);\n    91→\n    92→  // 5. Verify results: Player A (creator, chose HEADS) should win\n    93→  expect(resultA).toBe(\"won\");\n    94→  expect(resultB).toBe(\"lost\");\n    95→\n    96→  // 6. Player A (winner) claims payout\n    97→  await po.claimOrSettle(playerAPage);\n    98→\n    99→  // Player A sees \"Back to Lobby\" after successful claim (scoped to sidebar)\n   100→  await expect(\n   101→    playerAPage.locator(po.sel.sidebar).locator(\"button\", { hasText: \"Back to Lobby\" }),\n   102→  ).toBeVisible();\n   103→\n   104→  // ── On-chain: verify match PDA is closed after claim ──\n   105→  await assertMatchClosed(connection, matchPda);\n   106→\n   107→  // ── On-chain: verify treasury received the 3% fee ──\n   108→  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n   109→\n   110→  // ── On-chain: verify player profile updates ──\n   111→  const { payout } = calculateExpectedFee(ENTRY_AMOUNT);\n   112→\n   113→  // Player A (winner): +1 game, +1 win, wagered entry, won payout\n   114→  await assertPlayerProfileDelta(connection, PLAYER_A.publicKey, profileABefore, {\n   115→    totalGames: 1,\n   116→    wins: 1,\n   117→    totalWagered: ENTRY_AMOUNT,\n   118→    totalWon: payout,\n   119→  });\n   120→\n   121→  // Player B (loser): +1 game, +0 wins, wagered entry, won nothing\n   122→  await assertPlayerProfileDelta(connection, PLAYER_B.publicKey, profileBBefore, {\n   123→    totalGames: 1,\n   124→    wins: 0,\n   125→    totalWagered: ENTRY_AMOUNT,\n   126→    totalWon: 0,\n   127→  });\n   128→\n   129→  // 7. Player A returns to lobby — match should be gone\n   130→  await po.backToLobby(playerAPage);\n   131→  await po.assertLobbyEmpty(playerAPage);\n   132→\n   133→  // No unhandled console errors in either context\n   134→  consoleA.assertClean();\n   135→  consoleB.assertClean();\n   136→});\n   137→"}]},"parent_tool_use_id":null,"session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"37bd733c-24ac-4b2d-9387-7ed8e7736cfc","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/03-lifecycle.spec.ts","content":"/**\n * Local lifecycle E2E test: create → join → resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. The local validator has mock-VRF enabled,\n * and the randomness account is pre-loaded with fulfilled data\n * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n *\n * Prerequisites (handled by localnet-bootstrap.sh):\n * - solana-test-validator running with coinflip + platform programs\n * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport { fundTestWallets, PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\nimport { initializeLocalnet, ensurePlayerProfiles } from \"./helpers/localnet-setup\";\nimport {\n  assertMatchCreated,\n  assertMatchClosed,\n  assertTreasuryFee,\n  assertPlayerProfileDelta,\n  snapshotBalance,\n  snapshotPlayerProfile,\n  getTreasuryAddress,\n  calculateExpectedFee,\n} from \"./helpers/on-chain\";\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  // Fund test wallets, initialize program configs, and create player profiles\n  await fundTestWallets();\n  await initializeLocalnet();\n  await ensurePlayerProfiles();\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // On-chain constants for iron tier\n  const TIER_IRON = 0;\n  const SIDE_HEADS = 0;\n  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 10_000 });\n\n  // ── On-chain: verify match PDA after creation ──\n  const { matchPda } = await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    TIER_IRON,\n    SIDE_HEADS,\n  );\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 15_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // ── On-chain: snapshot treasury + profiles before resolution/claim ──\n  const treasury = await getTreasuryAddress(connection);\n  const treasuryBefore = await snapshotBalance(connection, treasury);\n  const profileABefore = await snapshotPlayerProfile(connection, PLAYER_A.publicKey);\n  const profileBBefore = await snapshotPlayerProfile(connection, PLAYER_B.publicKey);\n\n  // 4. Both players wait for the result.\n  //    VRF is pre-fulfilled (HEADS) → creator (Player A) wins.\n  //    The frontend polls every 5s for VRF fulfillment, then shows\n  //    a 3s flip animation before the \"complete\" phase.\n  const [resultA, resultB] = await Promise.all([\n    po.waitForResult(playerAPage, 30_000),\n    po.waitForResult(playerBPage, 30_000),\n  ]);\n\n  // 5. Verify results: Player A (creator, chose HEADS) should win\n  expect(resultA).toBe(\"won\");\n  expect(resultB).toBe(\"lost\");\n\n  // 6. Player A (winner) claims payout\n  await po.claimOrSettle(playerAPage);\n\n  // Player A sees \"Back to Lobby\" after successful claim (scoped to sidebar)\n  await expect(\n    playerAPage.locator(po.sel.sidebar).locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible();\n\n  // ── On-chain: verify match PDA is closed after claim ──\n  await assertMatchClosed(connection, matchPda);\n\n  // ── On-chain: verify treasury received the 3% fee ──\n  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n\n  // ── On-chain: verify player profile updates ──\n  const { payout } = calculateExpectedFee(ENTRY_AMOUNT);\n\n  // Player A (winner): +1 game, +1 win, wagered entry, won payout\n  await assertPlayerProfileDelta(connection, PLAYER_A.publicKey, profileABefore, {\n    totalGames: 1,\n    wins: 1,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: payout,\n  });\n\n  // Player B (loser): +1 game, +0 wins, wagered entry, won nothing\n  await assertPlayerProfileDelta(connection, PLAYER_B.publicKey, profileBBefore, {\n    totalGames: 1,\n    wins: 0,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: 0,\n  });\n\n  // 7. Player A returns to lobby — match should be gone\n  await po.backToLobby(playerAPage);\n  await po.assertLobbyEmpty(playerAPage);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","numLines":137,"startLine":1,"totalLines":137}}}
