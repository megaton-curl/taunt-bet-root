{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A5wzj3FdaQtYY2UmoWJqZT","type":"tool_result","content":"     1→import type { Round } from \"../types\";\n     2→import { WheelVisualization } from \"./WheelVisualization\";\n     3→import { CountdownTimer } from \"./CountdownTimer\";\n     4→\n     5→interface ActiveRoundViewProps {\n     6→  round: Round;\n     7→  currentUserAddress: string;\n     8→  onBackToTiers?: () => void;\n     9→}\n    10→\n    11→export function ActiveRoundView({\n    12→  round,\n    13→  currentUserAddress,\n    14→  onBackToTiers,\n    15→}: ActiveRoundViewProps) {\n    16→  const { phase } = round;\n    17→\n    18→  const getPhaseMessage = (): string => {\n    19→    switch (phase) {\n    20→      case \"waiting\":\n    21→        return \"Waiting for more players to join...\";\n    22→      case \"countdown\":\n    23→        return \"Round starting soon!\";\n    24→      case \"spinning\":\n    25→        return \"The wheel is spinning!\";\n    26→      default:\n    27→        return \"\";\n    28→    }\n    29→  };\n    30→\n    31→  return (\n    32→    <div className={`lotr-active-round lotr-active-round--${phase}`}>\n    33→      {/* Back button - always visible */}\n    34→      {onBackToTiers && (\n    35→        <button\n    36→          type=\"button\"\n    37→          className=\"lotr-tier-round__back\"\n    38→          onClick={onBackToTiers}\n    39→        >\n    40→          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n    41→            <path d=\"M19 12H5M12 19l-7-7 7-7\" />\n    42→          </svg>\n    43→          <span>Back to Tiers</span>\n    44→        </button>\n    45→      )}\n    46→\n    47→      {/* Phase indicator / Countdown - only show during non-reveal phases */}\n    48→      <div className=\"lotr-active-round__phase\">\n    49→        {phase === \"countdown\" && round.countdownEndsAt ? (\n    50→          <CountdownTimer endsAt={round.countdownEndsAt} size=\"large\" />\n    51→        ) : phase !== \"revealing\" && phase !== \"complete\" ? (\n    52→          <div className=\"lotr-active-round__phase-message\">\n    53→            {getPhaseMessage()}\n    54→          </div>\n    55→        ) : null}\n    56→      </div>\n    57→\n    58→      {/* Wheel */}\n    59→      <div className=\"lotr-active-round__wheel\">\n    60→        <WheelVisualization round={round} currentUserAddress={currentUserAddress} />\n    61→      </div>\n    62→    </div>\n    63→  );\n    64→}\n    65→"}]},"parent_tool_use_id":"toolu_01GY7cqnfJyMNU4xCHt3RoTx","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"83f7ef50-322e-479e-a0c8-a4fb57bfcf3f"}
