{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018Msd7fyyuByEeicFvY7Lco","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CRKw3XmeKw9Z3TehizaJ99","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/lord-page-objects.ts","content":"/**\n * Shared E2E page-object helpers for Lord of the RNGs tests.\n *\n * CSS-class-based selectors matching the actual component markup.\n * Provides tier selection, join, buy entry, spin, and reusable wait/assert primitives.\n */\nimport { type Page, type Locator, expect } from \"@playwright/test\";\n\n// ---------------------------------------------------------------------------\n// Selectors (CSS classes from LordOfRngsPage, TierLobby, ActiveRoundView, etc.)\n// ---------------------------------------------------------------------------\n\nexport const sel = {\n  // Page structure\n  main: \".lotr-main\",\n  sidebar: \".lotr-sidebar\",\n\n  // Tier lobby\n  tierLobby: \".lotr-tier-lobby\",\n  tierCard: \".lotr-tier-card\",\n  tierCardSelected: \".lotr-tier-card--selected\",\n  tierCardByPhase: (phase: string) => `.lotr-tier-card--${phase}`,\n  tierCardName: \".lotr-tier-card__name\",\n  tierCardAmount: \".lotr-tier-card__amount\",\n  tierCardStatValue: \".lotr-tier-card__stat-value\",\n  tierCardPhaseText: \".lotr-tier-card__phase-text\",\n\n  // Active round view\n  activeRound: \".lotr-active-round\",\n  activeRoundPhase: (phase: string) => `.lotr-active-round--${phase}`,\n  activeRoundPhaseMessage: \".lotr-active-round__phase-message\",\n\n  // Tier round view (selected tier but not joined)\n  tierRound: \".lotr-tier-round\",\n  tierRoundBack: \".lotr-tier-round__back\",\n\n  // Countdown timer\n  countdown: \".lotr-countdown\",\n  countdownTime: \".lotr-countdown__time\",\n  countdownUrgent: \".lotr-countdown--urgent\",\n\n  // Wheel visualization\n  wheel: \".lotr-hwheel\",\n  wheelSlot: \".lotr-hwheel__slot\",\n  wheelSlotYou: \".lotr-hwheel__slot--you\",\n  wheelSlotWinner: \".lotr-hwheel__slot--winner\",\n  wheelLegend: \".lotr-hwheel__legend\",\n  wheelLegendItem: \".lotr-hwheel__legend-item\",\n  wheelLegendItemYou: \".lotr-hwheel__legend-item--you\",\n  wheelLegendItemWinner: \".lotr-hwheel__legend-item--winner\",\n  wheelWinnerAnnounce: \".lotr-hwheel__winner-announce\",\n  wheelWinnerTextYou: \".lotr-hwheel__winner-text--you\",\n\n  // Sidebar\n  sidebarTitle: \".lotr-sidebar__title\",\n  sidebarPot: \".lotr-sidebar__pot\",\n  sidebarStatus: \".lotr-sidebar__status\",\n  sidebarStat: \".lotr-sidebar__stat\",\n  sidebarStatLabel: \".lotr-sidebar__stat-label\",\n  sidebarStatValue: \".lotr-sidebar__stat-value\",\n\n  // Action button\n  actionButton: \".lotr-action-btn\",\n\n  // Claimed text\n  claimedText: \".lotr-claimed-text\",\n} as const;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type Tier =\n  | \"iron\"\n  | \"bronze\"\n  | \"silver\"\n  | \"gold\"\n  | \"platinum\"\n  | \"diamond\";\n\n// ---------------------------------------------------------------------------\n// Page-object actions\n// ---------------------------------------------------------------------------\n\n/**\n * Navigate to the Lord of the RNGs page and wait for the lobby to render.\n */\nexport async function navigateToLord(page: Page): Promise<void> {\n  await page.goto(\"/lord-of-the-rngs\", { waitUntil: \"networkidle\" });\n  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 10_000 });\n}\n\n/**\n * Select a tier card in the lobby.\n */\nexport async function selectTier(page: Page, tierIndex: number): Promise<void> {\n  const cards = page.locator(sel.tierCard);\n  await cards.nth(tierIndex).click();\n}\n\n/**\n * Join a round by clicking the \"Join Round\" action button.\n * Waits for the active round view to appear.\n */\nexport async function joinRound(page: Page): Promise<void> {\n  const joinBtn = page.locator(sel.actionButton, { hasText: \"Join Round\" });\n  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n  await joinBtn.click();\n\n  // Wait for active round or tier round to reflect the join\n  await page.waitForSelector(`${sel.activeRound}, ${sel.wheelLegendItem}`, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Buy an additional entry in the current round.\n */\nexport async function buyEntry(page: Page): Promise<void> {\n  const buyBtn = page.locator(sel.actionButton, { hasText: \"Buy Entry\" });\n  await expect(buyBtn).toBeEnabled({ timeout: 10_000 });\n  await buyBtn.click();\n}\n\n/**\n * Click the \"Spin\" button to trigger the wheel spin (start_spin instruction).\n */\nexport async function startSpin(page: Page): Promise<void> {\n  const spinBtn = page.locator(sel.actionButton, { hasText: \"Spin\" });\n  await expect(spinBtn).toBeEnabled({ timeout: 10_000 });\n  await spinBtn.click();\n}\n\n/**\n * Go back from tier/round view to the tier lobby.\n */\nexport async function backToLobby(page: Page): Promise<void> {\n  const backBtn = page.locator(sel.tierRoundBack);\n  if (await backBtn.isVisible()) {\n    await backBtn.click();\n    await page.waitForSelector(sel.tierLobby, {\n      state: \"visible\",\n      timeout: 10_000,\n    });\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Wait / assert primitives\n// ---------------------------------------------------------------------------\n\n/**\n * Wait for the winner announcement to appear (spinning → revealing → complete).\n * Returns whether the current player won.\n */\nexport async function waitForWinnerAnnouncement(\n  page: Page,\n  timeout = 60_000,\n): Promise<boolean> {\n  // Wait for the winner announcement OR the claimed text to appear\n  await expect(\n    page.locator(sel.wheelWinnerAnnounce).or(page.locator(sel.claimedText)),\n  ).toBeVisible({ timeout });\n\n  // Check if \"YOU WON!\" text is visible\n  const youWon = page.locator(sel.wheelWinnerTextYou);\n  return youWon.isVisible();\n}\n\n/**\n * Wait for the action button to show a payout/claimed message.\n */\nexport async function waitForClaimComplete(\n  page: Page,\n  timeout = 30_000,\n): Promise<void> {\n  await expect(page.locator(sel.claimedText)).toBeVisible({ timeout });\n}\n\n/**\n * Wait for the sidebar pot to display a specific expected amount.\n */\nexport async function waitForPotUpdate(\n  page: Page,\n  expectedText: string,\n  timeout = 10_000,\n): Promise<void> {\n  await expect(page.locator(sel.sidebarPot)).toContainText(expectedText, {\n    timeout,\n  });\n}\n\n/**\n * Assert the tier lobby is visible with the expected number of tier cards.\n */\nexport async function assertTierLobbyVisible(\n  page: Page,\n  expectedCards = 6,\n  timeout = 10_000,\n): Promise<void> {\n  await expect(page.locator(sel.tierLobby)).toBeVisible({ timeout });\n  await expect(page.locator(sel.tierCard)).toHaveCount(expectedCards);\n}\n\n/**\n * Assert no error toasts (reusable — checks for common toast classes).\n */\nexport async function assertNoErrors(page: Page): Promise<void> {\n  await expect(page.locator(\".rng-toast--error\")).toHaveCount(0);\n}\n\n/**\n * Collect console errors from a page. Returns a cleanup function\n * and an array that accumulates errors.\n */\nexport function trackConsoleErrors(page: Page): {\n  errors: string[];\n  assertClean: () => void;\n} {\n  const errors: string[] = [];\n  page.on(\"console\", (msg) => {\n    if (msg.type() === \"error\") errors.push(msg.text());\n  });\n  return {\n    errors,\n    assertClean: () => {\n      // Filter out known non-critical browser noise\n      const real = errors.filter(\n        (e) =>\n          !e.includes(\"favicon.ico\") &&\n          !e.includes(\"downloadable font\") &&\n          !e.includes(\"third-party cookie\"),\n      );\n      expect(real).toEqual([]);\n    },\n  };\n}\n\n/**\n * Wait for a specific text to appear anywhere on the page.\n */\nexport async function waitForText(\n  page: Page,\n  text: string,\n  timeout = 10_000,\n): Promise<void> {\n  await expect(page.getByText(text).first()).toBeVisible({ timeout });\n}\n\n/**\n * Get a locator for the wheel legend item matching a player address (truncated).\n */\nexport function getLegendItemForAddress(\n  page: Page,\n  address: string,\n): Locator {\n  const truncated = address.slice(0, 4) + \"...\" + address.slice(-4);\n  return page.locator(sel.wheelLegendItem, { hasText: truncated });\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":384,"cache_read_input_tokens":124296,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":384},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"74365b05-570d-48f4-bb83-22a9e55302dc"}
