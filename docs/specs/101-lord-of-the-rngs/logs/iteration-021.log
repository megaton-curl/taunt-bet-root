p-keypair.json\"\nPLATFORM_KEYPAIR=\"$SOLANA_DIR/target/deploy/platform-keypair.json\"\n\nCOINFLIP_ID=\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\nPLATFORM_ID=\"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n\n# Mock Orao VRF accounts (pre-loaded for deterministic local E2E tests)\nACCOUNTS_DIR=\"$SCRIPT_DIR/localnet-accounts\"\n\nRPC_URL=\"http://127.0.0.1:8899\"\nPID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\nLEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\nLOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n\nMAX_WAIT=30  # seconds to wait for RPC readiness\n\n# ── Preflight checks ─────────────────────────────────────────────────\nfor f in \"$COINFLIP_SO\" \"$PLATFORM_SO\" \"$COINFLIP_KEYPAIR\" \"$PLATFORM_KEYPAIR\"; do\n  if [[ ! -f \"$f\" ]]; then\n    echo \"ERROR: Missing $f — run 'anchor build' first.\" >&2\n    exit 1\n  fi\ndone\n\nif ! command -v solana-test-validator &>/dev/null; then\n  echo \"ERROR: solana-test-validator not found on PATH.\" >&2\n  exit 1\nfi\n\n# Solana 3.x requires io_uring; Docker blocks it unless --security-opt=seccomp=unconfined.\n# We skip the preflight syscall probe (unreliable in containers) and let the validator\n# fail naturally with a clear error if io_uring is truly unavailable.\n\n# ── Kill any existing validator ───────────────────────────────────────\nif [[ -f \"$PID_FILE\" ]]; then\n  OLD_PID=$(cat \"$PID_FILE\")\n  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    kill \"$OLD_PID\" 2>/dev/null || true\n    sleep 1\n    kill -9 \"$OLD_PID\" 2>/dev/null || true\n  fi\n  rm -f \"$PID_FILE\"\nfi\n\n# Also kill any stray validator on the same port\nif lsof -ti :8899 &>/dev/null; then\n  echo \"Killing process on port 8899...\"\n  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n  sleep 1\nfi\n\n# ── Clean ledger for fresh state ──────────────────────────────────────\nrm -rf \"$LEDGER_DIR\"\n\n# ── Start validator with programs preloaded at genesis ────────────────\necho \"Starting solana-test-validator...\"\nsolana-test-validator \\\n  --ledger \"$LEDGER_DIR\" \\\n  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n  --account 5ER1oENnV4srxYdAynUfRzWeQCPQaqMiAp4VqyMbSqnK \"$ACCOUNTS_DIR/orao-network-state.json\" \\\n  --account S4ne8ejGPUwNMNsE8L7gtjbTaBLBfVGdWNH6VQrL58a \"$ACCOUNTS_DIR/orao-random-player-a.json\" \\\n  --account Ecs89dz8NsNoSxyUtp54G2HPbmvJr8qZnxnWUqiLT92r \"$ACCOUNTS_DIR/orao-treasury.json\" \\\n  --reset \\\n  --quiet \\\n  > \"$LOG_FILE\" 2>&1 &\n\nVALIDATOR_PID=$!\necho \"$VALIDATOR_PID\" > \"$PID_FILE\"\necho \"Validator PID: $VALIDATOR_PID\"\n\n# ── Wait for RPC readiness ────────────────────────────────────────────\necho -n \"Waiting for RPC at $RPC_URL\"\nELAPSED=0\nwhile (( ELAPSED < MAX_WAIT )); do\n  if curl -s \"$RPC_URL\" \\\n    -X POST \\\n    -H \"Content-Type: application/json\" \\\n    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    | grep -q '\"result\"'; then\n    echo \" ready (${ELAPSED}s)\"\n    echo \"Localnet bootstrap complete.\"\n    exit 0\n  fi\n\n  # Check validator is still running\n  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n    echo \"\"\n    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n    tail -20 \"$LOG_FILE\" >&2\n    rm -f \"$PID_FILE\"\n    exit 1\n  fi\n\n  sleep 1\n  ELAPSED=$(( ELAPSED + 1 ))\n  echo -n \".\"\ndone\n\necho \"\"\necho \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\ntail -20 \"$LOG_FILE\" >&2\nkill \"$VALIDATOR_PID\" 2>/dev/null || true\nrm -f \"$PID_FILE\"\nexit 1\n","numLines":119,"startLine":1,"totalLines":119}}}
