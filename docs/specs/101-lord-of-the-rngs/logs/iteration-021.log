{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KLNRP5nv5Ak9V8qABXNp3D","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { LordofrngsIDL, type Lordofrngs } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  TIER_VALUES,\n    11→  type Tier,\n    12→} from \"@rng-utopia/game-engine/browser\";\n    13→import type { Round, PlayerEntry } from \"../types\";\n    14→import { PLAYER_COLORS } from \"../types\";\n    15→\n    16→// ============ Constants ============\n    17→\n    18→const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n    19→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    20→    .VITE_LORDOFRNGS_PROGRAM_ID ?? LordofrngsIDL.address\n    21→);\n    22→\n    23→const ORAO_VRF_PROGRAM_ID = new PublicKey(\n    24→  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\"\n    25→);\n    26→\n    27→const LAMPORTS_PER_SOL = 1_000_000_000;\n    28→\n    29→// ============ PDA Derivation ============\n    30→\n    31→export function getRoundPda(\n    32→  tier: number,\n    33→  roundNumber: bigint | number\n    34→): [PublicKey, number] {\n    35→  const tierBuf = Buffer.alloc(1);\n    36→  tierBuf.writeUInt8(tier);\n    37→  const roundBuf = Buffer.alloc(8);\n    38→  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n    39→  return PublicKey.findProgramAddressSync(\n    40→    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    41→    LORDOFRNGS_PROGRAM_ID\n    42→  );\n    43→}\n    44→\n    45→export function getConfigPda(): [PublicKey, number] {\n    46→  return PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"lord_config\")],\n    48→    LORDOFRNGS_PROGRAM_ID\n    49→  );\n    50→}\n    51→\n    52→function getOraoNetworkStatePda(): PublicKey {\n    53→  const [pda] = PublicKey.findProgramAddressSync(\n    54→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    55→    ORAO_VRF_PROGRAM_ID\n    56→  );\n    57→  return pda;\n    58→}\n    59→\n    60→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    61→  const [pda] = PublicKey.findProgramAddressSync(\n    62→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    63→    ORAO_VRF_PROGRAM_ID\n    64→  );\n    65→  return pda;\n    66→}\n    67→\n    68→// ============ Program Instance ============\n    69→\n    70→export function getLordProgram(connection: Connection): Program<Lordofrngs> {\n    71→  const provider = new AnchorProvider(\n    72→    connection,\n    73→    {} as AnchorProvider[\"wallet\"],\n    74→    { commitment: \"confirmed\" }\n    75→  );\n    76→  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n    77→}\n    78→\n    79→// ============ On-Chain Account Types ============\n    80→\n    81→type RoundPhaseVariant =\n    82→  | { waiting: object }\n    83→  | { active: object }\n    84→  | { locked: object }\n    85→  | { resolving: object }\n    86→  | { settled: object }\n    87→  | { refunded: object };\n    88→\n    89→interface OnChainPlayerEntry {\n    90→  player: PublicKey;\n    91→  entries: number;\n    92→}\n    93→\n    94→interface OnChainRound {\n    95→  tier: number;\n    96→  roundNumber: { toNumber(): number };\n    97→  entryAmount: { toNumber(): number };\n    98→  phase: RoundPhaseVariant;\n    99→  players: OnChainPlayerEntry[];\n   100→  totalEntries: number;\n   101→  createdAt: { toNumber(): number };\n   102→  countdownEndsAt: { toNumber(): number };\n   103→  lockedAt: { toNumber(): number };\n   104→  resolveDeadline: { toNumber(): number };\n   105→  vrfRequestKey: PublicKey;\n   106→  winningSlot: number;\n   107→  winner: PublicKey;\n   108→  claimed: boolean;\n   109→  creator: PublicKey;\n   110→  bump: number;\n   111→}\n   112→\n   113→interface OnChainConfig {\n   114→  authority: PublicKey;\n   115→  treasury: PublicKey;\n   116→  paused: boolean;\n   117→  roundCounters: { toNumber(): number }[];\n   118→  bump: number;\n   119→}\n   120→\n   121→// ============ Converters ============\n   122→\n   123→const TIERS: Tier[] = [\n   124→  \"iron\",\n   125→  \"bronze\",\n   126→  \"silver\",\n   127→  \"gold\",\n   128→  \"platinum\",\n   129→  \"diamond\",\n   130→];\n   131→\n   132→function tierFromIndex(index: number): Tier {\n   133→  return TIERS[index] ?? \"iron\";\n   134→}\n   135→\n   136→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   137→  return name in phase;\n   138→}\n   139→\n   140→function phaseToUI(phase: RoundPhaseVariant): Round[\"phase\"] {\n   141→  if (isPhase(phase, \"waiting\")) return \"waiting\";\n   142→  if (isPhase(phase, \"active\")) return \"countdown\";\n   143→  if (isPhase(phase, \"locked\")) return \"spinning\";\n   144→  if (isPhase(phase, \"settled\")) return \"complete\";\n   145→  // Resolving, Refunded → treat as complete for display\n   146→  return \"complete\";\n   147→}\n   148→\n   149→function getPlayerColor(index: number, isCurrentUser: boolean): string {\n   150→  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\";\n   151→  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n   152→}\n   153→\n   154→function onChainPlayersToUI(\n   155→  players: OnChainPlayerEntry[],\n   156→  currentWallet?: string\n   157→): PlayerEntry[] {\n   158→  return players.map((p, i) => ({\n   159→    address: p.player.toBase58(),\n   160→    entries: p.entries,\n   161→    color: getPlayerColor(i, p.player.toBase58() === currentWallet),\n   162→  }));\n   163→}\n   164→\n   165→export function onChainRoundToUI(\n   166→  roundPda: PublicKey,\n   167→  data: OnChainRound,\n   168→  currentWallet?: string\n   169→): Round {\n   170→  const tier = tierFromIndex(data.tier);\n   171→  const entryAmountLamports = data.entryAmount.toNumber();\n   172→  const entryAmountSol = entryAmountLamports / LAMPORTS_PER_SOL;\n   173→  const totalEntries = data.totalEntries;\n   174→  const poolAmount = entryAmountSol * totalEntries;\n   175→  const phase = phaseToUI(data.phase);\n   176→  const isSettled = isPhase(data.phase, \"settled\");\n   177→  const countdownEndsAt = data.countdownEndsAt.toNumber();\n   178→\n   179→  const winner = isSettled ? data.winner : undefined;\n   180→  const isDefaultWinner =\n   181→    winner && winner.equals(PublicKey.default) ? undefined : winner;\n   182→\n   183→  return {\n   184→    id: roundPda.toBase58(),\n   185→    tier,\n   186→    entryAmount: entryAmountSol,\n   187→    phase,\n   188→    players: onChainPlayersToUI(data.players, currentWallet),\n   189→    totalEntries,\n   190→    poolAmount,\n   191→    createdAt: data.createdAt.toNumber() * 1000,\n   192→    countdownStartedAt:\n   193→      countdownEndsAt > 0 ? (countdownEndsAt - 60) * 1000 : undefined,\n   194→    countdownEndsAt: countdownEndsAt > 0 ? countdownEndsAt * 1000 : undefined,\n   195→    winningSlot: isSettled ? data.winningSlot : undefined,\n   196→    winner: isDefaultWinner?.toBase58(),\n   197→    payoutAmount: isSettled ? poolAmount * 0.97 : undefined,\n   198→    claimed: data.claimed,\n   199→    seedHash: data.vrfRequestKey.equals(PublicKey.default)\n   200→      ? \"\""}]},"parent_tool_use_id":"toolu_018QXifUfXe5KVGL4ALLeHmQ","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"7e34c976-789d-49ec-89e3-87a4745ab972"}
