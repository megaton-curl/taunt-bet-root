{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Vkf9RVftFznRDBxvCUJiH","type":"tool_result","content":"     1→/**\n     2→ * Deterministic wallet-funding helper for local E2E tests.\n     3→ *\n     4→ * Generates fixed keypairs from seed bytes so tests are reproducible,\n     5→ * then airdrops SOL and confirms before tests run.\n     6→ */\n     7→import {\n     8→  Connection,\n     9→  Keypair,\n    10→  LAMPORTS_PER_SOL,\n    11→  PublicKey,\n    12→} from \"@solana/web3.js\";\n    13→\n    14→// --- Deterministic keypairs ---\n    15→// Fixed 32-byte seeds produce the same keypairs on every run.\n    16→const SEED_PLAYER_A = new Uint8Array(32).fill(0xaa);\n    17→const SEED_PLAYER_B = new Uint8Array(32).fill(0xbb);\n    18→\n    19→export const PLAYER_A = Keypair.fromSeed(SEED_PLAYER_A);\n    20→export const PLAYER_B = Keypair.fromSeed(SEED_PLAYER_B);\n    21→\n    22→/** Default RPC URL for local test validator. */\n    23→export const LOCAL_RPC_URL = \"http://127.0.0.1:8899\";\n    24→\n    25→/** Default airdrop amount per wallet (10 SOL). */\n    26→const DEFAULT_AIRDROP_SOL = 10;\n    27→\n    28→/**\n    29→ * Airdrop SOL to a single wallet and confirm the transaction.\n    30→ *\n    31→ * @param connection - Solana RPC connection\n    32→ * @param to - Public key to fund\n    33→ * @param solAmount - Amount in SOL (default: 10)\n    34→ */\n    35→export async function fundWallet(\n    36→  connection: Connection,\n    37→  to: PublicKey,\n    38→  solAmount = DEFAULT_AIRDROP_SOL,\n    39→): Promise<void> {\n    40→  const lamports = solAmount * LAMPORTS_PER_SOL;\n    41→  const sig = await connection.requestAirdrop(to, lamports);\n    42→  const { blockhash, lastValidBlockHeight } =\n    43→    await connection.getLatestBlockhash();\n    44→  await connection.confirmTransaction(\n    45→    { signature: sig, blockhash, lastValidBlockHeight },\n    46→    \"confirmed\",\n    47→  );\n    48→}\n    49→\n    50→/**\n    51→ * Fund both test players on the local validator.\n    52→ * Call this in a `beforeAll` or global setup before the E2E suite starts.\n    53→ *\n    54→ * @param rpcUrl - RPC endpoint (default: local validator)\n    55→ * @param solAmount - SOL to airdrop per player (default: 10)\n    56→ */\n    57→export async function fundTestWallets(\n    58→  rpcUrl = LOCAL_RPC_URL,\n    59→  solAmount = DEFAULT_AIRDROP_SOL,\n    60→): Promise<{ playerA: Keypair; playerB: Keypair; connection: Connection }> {\n    61→  const connection = new Connection(rpcUrl, \"confirmed\");\n    62→\n    63→  await Promise.all([\n    64→    fundWallet(connection, PLAYER_A.publicKey, solAmount),\n    65→    fundWallet(connection, PLAYER_B.publicKey, solAmount),\n    66→  ]);\n    67→\n    68→  // Sanity-check: verify balances are present\n    69→  const [balA, balB] = await Promise.all([\n    70→    connection.getBalance(PLAYER_A.publicKey),\n    71→    connection.getBalance(PLAYER_B.publicKey),\n    72→  ]);\n    73→\n    74→  const minExpected = solAmount * LAMPORTS_PER_SOL;\n    75→  if (balA < minExpected) {\n    76→    throw new Error(\n    77→      `Player A funding failed: expected >= ${minExpected} lamports, got ${balA}`,\n    78→    );\n    79→  }\n    80→  if (balB < minExpected) {\n    81→    throw new Error(\n    82→      `Player B funding failed: expected >= ${minExpected} lamports, got ${balB}`,\n    83→    );\n    84→  }\n    85→\n    86→  return { playerA: PLAYER_A, playerB: PLAYER_B, connection };\n    87→}\n    88→"}]},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"2e7b438a-4bab-43ed-bb6b-004742c7453a"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01Q48CFvqCUe6PDWuSpEuVCc","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Di7LvjSHhzWk5Ky527LNqY","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/page-objects.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":3573,"cache_read_input_tokens":32009,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3573},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"6f412caf-522f-49f9-8f14-0d8fe6ddffe8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Di7LvjSHhzWk5Ky527LNqY","type":"tool_result","content":"     1→/**\n     2→ * Shared E2E page-object helpers for coinflip tests.\n     3→ *\n     4→ * CSS-class-based selectors matching the actual component markup.\n     5→ * Provides create, join, claim, cancel actions and reusable wait/assert primitives.\n     6→ */\n     7→import { type Page, type Locator, expect } from \"@playwright/test\";\n     8→\n     9→// ---------------------------------------------------------------------------\n    10→// Selectors (CSS classes from CoinflipPage, ActiveMatchView, OpenMatchesList)\n    11→// ---------------------------------------------------------------------------\n    12→\n    13→export const sel = {\n    14→  // Page structure\n    15→  lobby: \".coinflip-lobby\",\n    16→  sidebar: \".coinflip-sidebar\",\n    17→  main: \".coinflip-main\",\n    18→\n    19→  // Sidebar — create flow\n    20→  sidebarTitle: \".coinflip-sidebar__title\",\n    21→  tierSelector: \".rng-tier-selector\",\n    22→  tierButton: (tier: string) => `.rng-tier-btn:has(.rng-tier-gem--${tier})`,\n    23→  tierButtonSelected: \".rng-tier-btn--selected\",\n    24→  sideSelector: \".coinflip-side-selector\",\n    25→  sideButtonHeads: \".coinflip-side-btn--heads\",\n    26→  sideButtonTails: \".coinflip-side-btn--tails\",\n    27→  sideButtonSelected: \".coinflip-side-btn--selected\",\n    28→  summary: \".coinflip-sidebar__summary\",\n    29→  actionButton: \".coinflip-action-btn\",\n    30→  actionButtonSecondary: \".coinflip-action-btn--secondary\",\n    31→\n    32→  // Lobby — open matches\n    33→  matchesList: \".coinflip-matches__list\",\n    34→  matchesCount: \".coinflip-matches__count\",\n    35→  matchCard: \".coinflip-match-card\",\n    36→  matchCardOwn: \".coinflip-match-card--own\",\n    37→  matchCardClaimable: \".coinflip-match-card--claimable\",\n    38→  matchCardJoinBtn: \".coinflip-match-card__join-btn\",\n    39→  matchCardAmount: \".coinflip-match-card__amount\",\n    40→  matchCardAddress: \".coinflip-match-card__address\",\n    41→\n    42→  // Active match view\n    43→  activeMatch: \".coinflip-active-match\",\n    44→  activeMatchTitle: \".coinflip-active-match__title\",\n    45→  activeMatchTitleWon: \".coinflip-active-match__title--won\",\n    46→  activeMatchTitleLost: \".coinflip-active-match__title--lost\",\n    47→  activeMatchWaiting: \".coinflip-active-match__waiting\",\n    48→  activeMatchPlaying: \".coinflip-active-match__playing\",\n    49→\n    50→  // Result\n    51→  resultOutcome: \".coinflip-result__outcome\",\n    52→  resultPayout: \".coinflip-result__payout\",\n    53→\n    54→  // Post-claim\n    55→  postClaim: \".coinflip-active-match__post-claim\",\n    56→\n    57→  // Error\n    58→  errorToast: \".coinflip-error-toast\",\n    59→  toastMessage: \".rng-toast__message\",\n    60→\n    61→  // Sidebar — active match info\n    62→  sidebarStatus: \".coinflip-sidebar__status\",\n    63→  sidebarPot: \".coinflip-sidebar__pot\",\n    64→} as const;\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Types\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export type CoinSide = \"heads\" | \"tails\";\n    71→export type Tier =\n    72→  | \"iron\"\n    73→  | \"bronze\"\n    74→  | \"silver\"\n    75→  | \"gold\"\n    76→  | \"platinum\"\n    77→  | \"diamond\";\n    78→\n    79→// ---------------------------------------------------------------------------\n    80→// Page-object actions\n    81→// ---------------------------------------------------------------------------\n    82→\n    83→/**\n    84→ * Navigate to the coinflip page and wait for the lobby to render.\n    85→ */\n    86→export async function navigateToCoinflip(page: Page): Promise<void> {\n    87→  await page.goto(\"/coinflip\", { waitUntil: \"networkidle\" });\n    88→  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 10_000 });\n    89→}\n    90→\n    91→/**\n    92→ * Select a tier in the sidebar tier selector.\n    93→ */\n    94→export async function selectTier(page: Page, tier: Tier): Promise<void> {\n    95→  await page.click(sel.tierButton(tier));\n    96→  await expect(page.locator(sel.tierButton(tier))).toHaveClass(/rng-tier-btn--selected/);\n    97→}\n    98→\n    99→/**\n   100→ * Select a coin side (heads or tails) in the sidebar.\n   101→ */\n   102→export async function selectSide(page: Page, side: CoinSide): Promise<void> {\n   103→  const selector =\n   104→    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n   105→  await page.click(selector);\n   106→  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n   107→}\n   108→\n   109→/**\n   110→ * Create a match: select tier, select side, click \"Create Game\".\n   111→ * Returns when the active match view (waiting state) is visible.\n   112→ */\n   113→export async function createMatch(\n   114→  page: Page,\n   115→  tier: Tier,\n   116→  side: CoinSide,\n   117→): Promise<void> {\n   118→  await selectTier(page, tier);\n   119→  await selectSide(page, side);\n   120→\n   121→  // Click create — button text is \"Create Game\"\n   122→  const createBtn = page.locator(sel.actionButton, {\n   123→    hasText: \"Create Game\",\n   124→  });\n   125→  await expect(createBtn).toBeEnabled();\n   126→  await createBtn.click();\n   127→\n   128→  // Wait for transition to active match (waiting for opponent)\n   129→  await page.waitForSelector(sel.activeMatch, {\n   130→    state: \"visible\",\n   131→    timeout: 15_000,\n   132→  });\n   133→}\n   134→\n   135→/**\n   136→ * Join a match visible in the lobby. If `matchIndex` is provided, join that\n   137→ * specific card (0-based). Otherwise joins the first joinable match.\n   138→ */\n   139→export async function joinMatch(\n   140→  page: Page,\n   141→  matchIndex = 0,\n   142→): Promise<void> {\n   143→  const cards = page.locator(\n   144→    `${sel.matchCard}:not(${sel.matchCardOwn}):not(${sel.matchCardClaimable})`,\n   145→  );\n   146→  const joinBtn = cards.nth(matchIndex).locator(sel.matchCardJoinBtn);\n   147→  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n   148→  await joinBtn.click();\n   149→\n   150→  // Wait for active match view to appear\n   151→  await page.waitForSelector(sel.activeMatch, {\n   152→    state: \"visible\",\n   153→    timeout: 15_000,\n   154→  });\n   155→}\n   156→\n   157→/**\n   158→ * Cancel the currently active match (phase = \"created\", waiting for opponent).\n   159→ * Clicks \"Cancel Match\" button in the ActiveMatchView.\n   160→ */\n   161→export async function cancelMatch(page: Page): Promise<void> {\n   162→  const cancelBtn = page.locator(\"button\", { hasText: \"Cancel Match\" });\n   163→  await expect(cancelBtn).toBeVisible({ timeout: 5_000 });\n   164→  await cancelBtn.click();\n   165→\n   166→  // Wait for lobby to reappear\n   167→  await page.waitForSelector(sel.lobby, {\n   168→    state: \"visible\",\n   169→    timeout: 15_000,\n   170→  });\n   171→}\n   172→\n   173→/**\n   174→ * Claim payout for the winner, or settle for the loser.\n   175→ * Clicks the \"Claim Payout\" or \"Settle & Return\" button in the sidebar.\n   176→ */\n   177→export async function claimOrSettle(page: Page): Promise<void> {\n   178→  // The claim/settle button is in the sidebar (CoinflipPage renders it there)\n   179→  const claimBtn = page.locator(sel.sidebar).locator(sel.actionButton).first();\n   180→  await expect(claimBtn).toBeEnabled({ timeout: 15_000 });\n   181→  await claimBtn.click();\n   182→\n   183→  // Wait for \"Back to Lobby\" button to confirm claim completed (scoped to sidebar)\n   184→  await expect(\n   185→    page.locator(sel.sidebar).locator(\"button\", { hasText: \"Back to Lobby\" }),\n   186→  ).toBeVisible({ timeout: 15_000 });\n   187→}\n   188→\n   189→/**\n   190→ * Click \"Back to Lobby\" to return after claiming.\n   191→ */\n   192→export async function backToLobby(page: Page): Promise<void> {\n   193→  const btn = page.locator(sel.sidebar).locator(\"button\", { hasText: \"Back to Lobby\" });\n   194→  await expect(btn).toBeVisible();\n   195→  await btn.click();\n   196→  await page.waitForSelector(sel.lobby, {\n   197→    state: \"visible\",\n   198→    timeout: 10_000,\n   199→  });\n   200→}\n   201→\n   202→// ---------------------------------------------------------------------------\n   203→// Wait / assert primitives\n   204→// ---------------------------------------------------------------------------\n   205→\n   206→/**\n   207→ * Wait until the sidebar status text matches the expected phase label.\n   208→ * Phase labels: \"Waiting...\", \"Ready!\", \"Countdown...\", \"Flipping...\", \"Complete\"\n   209→ */\n   210→export async function waitForPhaseLabel(\n   211→  page: Page,\n   212→  label: string,\n   213→  timeout = 30_000,\n   214→): Promise<void> {\n   215→  await expect(page.locator(sel.sidebarStatus)).toHaveText(label, {\n   216→    timeout,\n   217→  });\n   218→}\n   219→\n   220→/**\n   221→ * Wait for the active match title to indicate a win or loss.\n   222→ */\n   223→export async function waitForResult(\n   224→  page: Page,\n   225→  timeout = 30_000,\n   226→): Promise<\"won\" | \"lost\"> {\n   227→  // Wait for either won or lost title class to appear\n   228→  const wonLocator = page.locator(sel.activeMatchTitleWon);\n   229→  const lostLocator = page.locator(sel.activeMatchTitleLost);\n   230→\n   231→  await expect(wonLocator.or(lostLocator)).toBeVisible({ timeout });\n   232→\n   233→  if (await wonLocator.isVisible()) return \"won\";\n   234→  return \"lost\";\n   235→}\n   236→\n   237→/**\n   238→ * Wait for a match to appear in the lobby's open match list.\n   239→ */\n   240→export async function waitForLobbyMatch(\n   241→  page: Page,\n   242→  timeout = 15_000,\n   243→): Promise<Locator> {\n   244→  const card = page.locator(\n   245→    `${sel.matchCard}:not(${sel.matchCardClaimable})`,\n   246→  ).first();\n   247→  await expect(card).toBeVisible({ timeout });\n   248→  return card;\n   249→}\n   250→\n   251→/**\n   252→ * Assert the lobby is empty (no open matches).\n   253→ */\n   254→export async function assertLobbyEmpty(\n   255→  page: Page,\n   256→  timeout = 10_000,\n   257→): Promise<void> {\n   258→  // Either the empty state text or zero non-claimable match cards\n   259→  await expect(\n   260→    page.locator(`${sel.matchCard}:not(${sel.matchCardClaimable})`),\n   261→  ).toHaveCount(0, { timeout });\n   262→}\n   263→\n   264→/**\n   265→ * Assert that an error toast is visible with the given message substring.\n   266→ */\n   267→export async function assertErrorToast(\n   268→  page: Page,\n   269→  messageSubstring: string,\n   270→  timeout = 5_000,\n   271→): Promise<void> {\n   272→  const toast = page.locator(sel.errorToast);\n   273→  await expect(toast).toBeVisible({ timeout });\n   274→  await expect(toast).toContainText(messageSubstring);\n   275→}\n   276→\n   277→/**\n   278→ * Assert that no error toasts are visible.\n   279→ */\n   280→export async function assertNoErrorToast(page: Page): Promise<void> {\n   281→  await expect(page.locator(sel.errorToast)).toHaveCount(0);\n   282→}\n   283→\n   284→/**\n   285→ * Get the current balance displayed or fetched from connection for a wallet.\n   286→ * This is a convenience wrapper for reading SOL balance via RPC, not UI-based.\n   287→ */\n   288→export async function getSolBalance(\n   289→  page: Page,\n   290→  walletAddress: string,\n   291→  rpcUrl = \"http://127.0.0.1:8899\",\n   292→): Promise<number> {\n   293→  return page.evaluate(\n   294→    async ({ address, rpc }) => {\n   295→      const res = await fetch(rpc, {\n   296→        method: \"POST\",\n   297→        headers: { \"Content-Type\": \"application/json\" },\n   298→        body: JSON.stringify({\n   299→          jsonrpc: \"2.0\",\n   300→          id: 1,\n   301→          method: \"getBalance\",\n   302→          params: [address, { commitment: \"confirmed\" }],\n   303→        }),\n   304→      });\n   305→      const json = await res.json();\n   306→      return (json.result?.value ?? 0) / 1_000_000_000;\n   307→    },\n   308→    { address: walletAddress, rpc: rpcUrl },\n   309→  );\n   310→}\n   311→\n   312→/**\n   313→ * Collect console errors from a page. Returns a cleanup function\n   314→ * and an array that accumulates errors.\n   315→ */\n   316→export function trackConsoleErrors(page: Page): {\n   317→  errors: string[];\n   318→  assertClean: () => void;\n   319→} {\n   320→  const errors: string[] = [];\n   321→  page.on(\"console\", (msg) => {\n   322→    if (msg.type() === \"error\") errors.push(msg.text());\n   323→  });\n   324→  return {\n   325→    errors,\n   326→    assertClean: () => {\n   327→      // Filter out known non-critical browser noise\n   328→      const real = errors.filter(\n   329→        (e) =>\n   330→          !e.includes(\"favicon.ico\") &&\n   331→          !e.includes(\"downloadable font\") &&\n   332→          !e.includes(\"third-party cookie\"),\n   333→      );\n   334→      expect(real).toEqual([]);\n   335→    },\n   336→  };\n   337→}\n   338→\n   339→/**\n   340→ * Wait for a specific text to appear anywhere on the page.\n   341→ */\n   342→export async function waitForText(\n   343→  page: Page,\n   344→  text: string,\n   345→  timeout = 10_000,\n   346→): Promise<void> {\n   347→  await expect(page.getByText(text).first()).toBeVisible({ timeout });\n   348→}\n   349→\n   350→/**\n   351→ * Wait for the lobby to be visible (no active match).\n   352→ */\n   353→export async function waitForLobby(\n   354→  page: Page,\n   355→  timeout = 15_000,\n   356→): Promise<void> {\n   357→  await page.waitForSelector(sel.lobby, {\n   358→    state: \"visible\",\n   359→    timeout,\n   360→  });\n   361→}\n   362→"}]},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"9a87f376-a36a-4eaa-b002-83b2aeaaadca"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01MSgjf8DmU5xp2CreCwQpX2","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Cq48xiDx7pcaQP9LRdJj5N","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/on-chain.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":8086,"cache_read_input_tokens":35582,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":8086},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"e5f9a23c-893e-469a-9368-d55f5d871d42"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cq48xiDx7pcaQP9LRdJj5N","type":"tool_result","content":"     1→/**\n     2→ * On-chain assertion helpers for local E2E tests.\n     3→ *\n     4→ * Provides RPC-based helpers to query and assert match PDA state,\n     5→ * treasury fee deltas, and player profile stat updates.\n     6→ */\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     9→import {\n    10→  CoinflipIDL,\n    11→  PlatformIDL,\n    12→  type Coinflip,\n    13→  type Platform,\n    14→} from \"@rng-utopia/anchor-client\";\n    15→\n    16→// ============ Program IDs ============\n    17→\n    18→/** Coinflip program address (from IDL). */\n    19→export const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    20→\n    21→/** Platform program address (from IDL). */\n    22→export const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n    23→\n    24→/** Platform fee: 300 basis points = 3%. */\n    25→export const FEE_BPS = 300;\n    26→\n    27→// ============ PDA Derivation ============\n    28→\n    29→/** Derive the match PDA for a creator. Seeds: [\"match\", creator]. */\n    30→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer()],\n    33→    COINFLIP_PROGRAM_ID,\n    34→  );\n    35→}\n    36→\n    37→/** Derive the coinflip config PDA. Seeds: [\"coinflip_config\"]. */\n    38→export function getConfigPda(): [PublicKey, number] {\n    39→  return PublicKey.findProgramAddressSync(\n    40→    [Buffer.from(\"coinflip_config\")],\n    41→    COINFLIP_PROGRAM_ID,\n    42→  );\n    43→}\n    44→\n    45→/** Derive a player profile PDA. Seeds: [\"player_profile\", wallet]. */\n    46→export function getPlayerProfilePda(wallet: PublicKey): [PublicKey, number] {\n    47→  return PublicKey.findProgramAddressSync(\n    48→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    49→    PLATFORM_PROGRAM_ID,\n    50→  );\n    51→}\n    52→\n    53→// ============ Program Instances ============\n    54→\n    55→/**\n    56→ * Create a read-only Coinflip program instance.\n    57→ *\n    58→ * @param connection - Solana RPC connection\n    59→ */\n    60→export function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    61→  const provider = new AnchorProvider(\n    62→    connection,\n    63→    {} as AnchorProvider[\"wallet\"],\n    64→    { commitment: \"confirmed\" },\n    65→  );\n    66→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    67→}\n    68→\n    69→/**\n    70→ * Create a read-only Platform program instance.\n    71→ *\n    72→ * @param connection - Solana RPC connection\n    73→ */\n    74→export function getPlatformProgram(connection: Connection): Program<Platform> {\n    75→  const provider = new AnchorProvider(\n    76→    connection,\n    77→    {} as AnchorProvider[\"wallet\"],\n    78→    { commitment: \"confirmed\" },\n    79→  );\n    80→  return new Program(PlatformIDL as Idl as Platform, provider);\n    81→}\n    82→\n    83→// ============ Account Types ============\n    84→\n    85→/** Deserialized match account shape. */\n    86→export interface MatchAccount {\n    87→  creator: PublicKey;\n    88→  opponent: PublicKey;\n    89→  tier: number;\n    90→  entryAmount: { toNumber(): number };\n    91→  creatorSide: number;\n    92→  phase: Record<string, object>;\n    93→  result: number;\n    94→  winner: PublicKey;\n    95→  claimed: boolean;\n    96→  createdAt: { toNumber(): number };\n    97→  lockedAt: { toNumber(): number };\n    98→  resolveDeadline: { toNumber(): number };\n    99→  vrfRequestKey: PublicKey;\n   100→  bump: number;\n   101→}\n   102→\n   103→/** Deserialized player profile account shape. */\n   104→export interface PlayerProfileAccount {\n   105→  authority: PublicKey;\n   106→  totalGames: { toNumber(): number };\n   107→  wins: { toNumber(): number };\n   108→  totalWagered: { toNumber(): number };\n   109→  totalWon: { toNumber(): number };\n   110→  bump: number;\n   111→}\n   112→\n   113→// ============ Fetch Helpers ============\n   114→\n   115→/**\n   116→ * Fetch a match PDA account. Returns null if the account is closed.\n   117→ *\n   118→ * @param connection - Solana RPC connection\n   119→ * @param matchPda - The match PDA address\n   120→ */\n   121→export async function fetchMatch(\n   122→  connection: Connection,\n   123→  matchPda: PublicKey,\n   124→): Promise<MatchAccount | null> {\n   125→  const program = getCoinflipProgram(connection);\n   126→  try {\n   127→    return (await program.account.coinflipMatch.fetch(\n   128→      matchPda,\n   129→    )) as unknown as MatchAccount;\n   130→  } catch {\n   131→    // Account not found (closed or never created)\n   132→    return null;\n   133→  }\n   134→}\n   135→\n   136→/**\n   137→ * Fetch a player profile PDA account. Returns null if it doesn't exist.\n   138→ *\n   139→ * @param connection - Solana RPC connection\n   140→ * @param profilePda - The player profile PDA address\n   141→ */\n   142→export async function fetchPlayerProfile(\n   143→  connection: Connection,\n   144→  profilePda: PublicKey,\n   145→): Promise<PlayerProfileAccount | null> {\n   146→  const program = getPlatformProgram(connection);\n   147→  try {\n   148→    return (await program.account.playerProfile.fetch(\n   149→      profilePda,\n   150→    )) as unknown as PlayerProfileAccount;\n   151→  } catch {\n   152→    return null;\n   153→  }\n   154→}\n   155→\n   156→/**\n   157→ * Get the treasury wallet address from the coinflip config PDA.\n   158→ *\n   159→ * @param connection - Solana RPC connection\n   160→ */\n   161→export async function getTreasuryAddress(\n   162→  connection: Connection,\n   163→): Promise<PublicKey> {\n   164→  const program = getCoinflipProgram(connection);\n   165→  const [configPda] = getConfigPda();\n   166→  const config = await program.account.coinflipConfig.fetch(configPda);\n   167→  return (config as unknown as { treasury: PublicKey }).treasury;\n   168→}\n   169→\n   170→// ============ Balance Helpers ============\n   171→\n   172→/**\n   173→ * Get the SOL balance of an address in lamports.\n   174→ *\n   175→ * @param connection - Solana RPC connection\n   176→ * @param address - Public key to check\n   177→ */\n   178→export async function getBalanceLamports(\n   179→  connection: Connection,\n   180→  address: PublicKey,\n   181→): Promise<number> {\n   182→  return connection.getBalance(address);\n   183→}\n   184→\n   185→/**\n   186→ * Capture a balance snapshot for later delta comparison.\n   187→ *\n   188→ * @param connection - Solana RPC connection\n   189→ * @param address - Public key to snapshot\n   190→ */\n   191→export async function snapshotBalance(\n   192→  connection: Connection,\n   193→  address: PublicKey,\n   194→): Promise<number> {\n   195→  return connection.getBalance(address);\n   196→}\n   197→\n   198→// ============ Fee Calculation ============\n   199→\n   200→/**\n   201→ * Calculate the expected fee and net payout for a coinflip match.\n   202→ * Mirrors on-chain logic: fee = floor(pool * FEE_BPS / 10_000).\n   203→ *\n   204→ * @param entryAmount - Single player's entry in lamports\n   205→ * @returns Object with pool, fee, and payout amounts in lamports\n   206→ */\n   207→export function calculateExpectedFee(entryAmount: number): {\n   208→  pool: number;\n   209→  fee: number;\n   210→  payout: number;\n   211→} {\n   212→  const pool = entryAmount * 2;\n   213→  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n   214→  const payout = pool - fee;\n   215→  return { pool, fee, payout };\n   216→}\n   217→\n   218→// ============ Assertion Helpers ============\n   219→\n   220→/**\n   221→ * Assert match PDA state after creation (Waiting phase).\n   222→ *\n   223→ * @param connection - Solana RPC connection\n   224→ * @param creator - Creator's public key\n   225→ * @param expectedTier - Expected tier index\n   226→ * @param expectedSide - Expected creator side (0 = heads, 1 = tails)\n   227→ */\n   228→export async function assertMatchCreated(\n   229→  connection: Connection,\n   230→  creator: PublicKey,\n   231→  expectedTier: number,\n   232→  expectedSide: number,\n   233→): Promise<{ matchPda: PublicKey; match: MatchAccount }> {\n   234→  const [matchPda] = getMatchPda(creator);\n   235→  const match = await fetchMatch(connection, matchPda);\n   236→  if (!match) throw new Error(`Match PDA not found for creator ${creator}`);\n   237→\n   238→  const phase = Object.keys(match.phase)[0];\n   239→  if (phase !== \"waiting\") {\n   240→    throw new Error(`Expected phase 'waiting', got '${phase}'`);\n   241→  }\n   242→  if (match.creator.toBase58() !== creator.toBase58()) {\n   243→    throw new Error(\"Match creator does not match expected creator\");\n   244→  }\n   245→  if (match.tier !== expectedTier) {\n   246→    throw new Error(`Expected tier ${expectedTier}, got ${match.tier}`);\n   247→  }\n   248→  if (match.creatorSide !== expectedSide) {\n   249→    throw new Error(`Expected side ${expectedSide}, got ${match.creatorSide}`);\n   250→  }\n   251→  if (match.opponent.toBase58() !== PublicKey.default.toBase58()) {\n   252→    throw new Error(\"Expected no opponent in waiting phase\");\n   253→  }\n   254→  if (match.claimed) {\n   255→    throw new Error(\"Expected claimed=false after creation\");\n   256→  }\n   257→\n   258→  return { matchPda, match };\n   259→}\n   260→\n   261→/**\n   262→ * Assert match PDA is closed (account no longer exists).\n   263→ *\n   264→ * @param connection - Solana RPC connection\n   265→ * @param matchPda - The match PDA address to check\n   266→ */\n   267→export async function assertMatchClosed(\n   268→  connection: Connection,\n   269→  matchPda: PublicKey,\n   270→): Promise<void> {\n   271→  const match = await fetchMatch(connection, matchPda);\n   272→  if (match !== null) {\n   273→    const phase = Object.keys(match.phase)[0];\n   274→    throw new Error(\n   275→      `Expected match PDA to be closed, but it still exists (phase: ${phase})`,\n   276→    );\n   277→  }\n   278→}\n   279→\n   280→/**\n   281→ * Assert that the treasury received the expected fee.\n   282→ * Call snapshotBalance before the payout, then call this after.\n   283→ *\n   284→ * @param connection - Solana RPC connection\n   285→ * @param treasury - Treasury public key\n   286→ * @param balanceBefore - Treasury balance in lamports before claim\n   287→ * @param entryAmount - Single player's entry in lamports\n   288→ */\n   289→export async function assertTreasuryFee(\n   290→  connection: Connection,\n   291→  treasury: PublicKey,\n   292→  balanceBefore: number,\n   293→  entryAmount: number,\n   294→): Promise<void> {\n   295→  const balanceAfter = await getBalanceLamports(connection, treasury);\n   296→  const { fee } = calculateExpectedFee(entryAmount);\n   297→  const actualDelta = balanceAfter - balanceBefore;\n   298→\n   299→  if (actualDelta !== fee) {\n   300→    throw new Error(\n   301→      `Treasury fee mismatch: expected ${fee} lamports, got delta ${actualDelta}`,\n   302→    );\n   303→  }\n   304→}\n   305→\n   306→/**\n   307→ * Assert player profile stats after a game.\n   308→ *\n   309→ * @param connection - Solana RPC connection\n   310→ * @param wallet - Player's wallet public key\n   311→ * @param expected - Expected stat values\n   312→ */\n   313→export async function assertPlayerProfile(\n   314→  connection: Connection,\n   315→  wallet: PublicKey,\n   316→  expected: {\n   317→    totalGames: number;\n   318→    wins: number;\n   319→    totalWagered: number;\n   320→    totalWon: number;\n   321→  },\n   322→): Promise<void> {\n   323→  const [profilePda] = getPlayerProfilePda(wallet);\n   324→  const profile = await fetchPlayerProfile(connection, profilePda);\n   325→  if (!profile) {\n   326→    throw new Error(`Player profile not found for ${wallet}`);\n   327→  }\n   328→\n   329→  const actual = {\n   330→    totalGames: profile.totalGames.toNumber(),\n   331→    wins: profile.wins.toNumber(),\n   332→    totalWagered: profile.totalWagered.toNumber(),\n   333→    totalWon: profile.totalWon.toNumber(),\n   334→  };\n   335→\n   336→  for (const key of Object.keys(expected) as (keyof typeof expected)[]) {\n   337→    if (actual[key] !== expected[key]) {\n   338→      throw new Error(\n   339→        `Profile ${key} mismatch for ${wallet}: expected ${expected[key]}, got ${actual[key]}`,\n   340→      );\n   341→    }\n   342→  }\n   343→}\n   344→\n   345→/**\n   346→ * Assert player profile stats changed by a specific delta since a snapshot.\n   347→ *\n   348→ * @param connection - Solana RPC connection\n   349→ * @param wallet - Player's wallet public key\n   350→ * @param before - Profile stats snapshot before the action\n   351→ * @param delta - Expected stat deltas\n   352→ */\n   353→export async function assertPlayerProfileDelta(\n   354→  connection: Connection,\n   355→  wallet: PublicKey,\n   356→  before: { totalGames: number; wins: number; totalWagered: number; totalWon: number },\n   357→  delta: { totalGames: number; wins: number; totalWagered: number; totalWon: number },\n   358→): Promise<void> {\n   359→  const expected = {\n   360→    totalGames: before.totalGames + delta.totalGames,\n   361→    wins: before.wins + delta.wins,\n   362→    totalWagered: before.totalWagered + delta.totalWagered,\n   363→    totalWon: before.totalWon + delta.totalWon,\n   364→  };\n   365→  await assertPlayerProfile(connection, wallet, expected);\n   366→}\n   367→\n   368→/**\n   369→ * Snapshot a player profile's current stats (for later delta comparison).\n   370→ * Returns zero-stats if the profile doesn't exist yet.\n   371→ *\n   372→ * @param connection - Solana RPC connection\n   373→ * @param wallet - Player's wallet public key\n   374→ */\n   375→export async function snapshotPlayerProfile(\n   376→  connection: Connection,\n   377→  wallet: PublicKey,\n   378→): Promise<{ totalGames: number; wins: number; totalWagered: number; totalWon: number }> {\n   379→  const [profilePda] = getPlayerProfilePda(wallet);\n   380→  const profile = await fetchPlayerProfile(connection, profilePda);\n   381→  if (!profile) {\n   382→    return { totalGames: 0, wins: 0, totalWagered: 0, totalWon: 0 };\n   383→  }\n   384→  return {\n   385→    totalGames: profile.totalGames.toNumber(),\n   386→    wins: profile.wins.toNumber(),\n   387→    totalWagered: profile.totalWagered.toNumber(),\n   388→    totalWon: profile.totalWon.toNumber(),\n   389→  };\n   390→}\n   391→"}]},"parent_tool_use_id":"toolu_01TZpHg3AKpmaPdxmtoZJEKs","session_id":"3430a832-47ac-41dd-bbc6-e4b8a98508e0","uuid":"23e653e4-01b3-4481-ad44-10136bce9e64"}
