{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013zXPXE625u3sgSW7Cf8yGU","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { AnchorError, Program } from \"@coral-xyz/anchor\";\n     5→import { Wallet } from \"@coral-xyz/anchor\";\n     6→import {\n     7→  Keypair,\n     8→  PublicKey,\n     9→  SystemProgram,\n    10→  LAMPORTS_PER_SOL,\n    11→} from \"@solana/web3.js\";\n    12→import { Clock } from \"solana-bankrun\";\n    13→import type { Lordofrngs } from \"../target/types/lordofrngs\";\n    14→import { readFileSync } from \"fs\";\n    15→import { dirname, join } from \"path\";\n    16→import { fileURLToPath } from \"url\";\n    17→import BN from \"bn.js\";\n    18→\n    19→const __filename = fileURLToPath(import.meta.url);\n    20→const __dirname = dirname(__filename);\n    21→\n    22→const IDL = JSON.parse(\n    23→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n    24→);\n    25→const PROGRAM_ID = new PublicKey(IDL.address);\n    26→\n    27→// Tier constants (from shared crate)\n    28→const TIER_IRON = 0;\n    29→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n    30→const COUNTDOWN_SECONDS = 60;\n    31→\n    32→// Mock VRF randomness buffers (32 bytes each)\n    33→// Unfulfilled: all zeros → is_fulfilled=false\n    34→const RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n    35→\n    36→// ---------------------------------------------------------------------------\n    37→// PDA helpers\n    38→// ---------------------------------------------------------------------------\n    39→function getConfigPda(): PublicKey {\n    40→  const [pda] = PublicKey.findProgramAddressSync(\n    41→    [Buffer.from(\"lord_config\")],\n    42→    PROGRAM_ID\n    43→  );\n    44→  return pda;\n    45→}\n    46→\n    47→function getRoundPda(tier: number, roundNumber: number | bigint): PublicKey {\n    48→  const tierBuf = Buffer.from([tier]);\n    49→  const roundBuf = Buffer.alloc(8);\n    50→  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n    51→  const [pda] = PublicKey.findProgramAddressSync(\n    52→    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    53→    PROGRAM_ID\n    54→  );\n    55→  return pda;\n    56→}\n    57→\n    58→// ---------------------------------------------------------------------------\n    59→// Test context factory\n    60→// ---------------------------------------------------------------------------\n    61→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n    62→  return {\n    63→    lamports,\n    64→    data: Buffer.alloc(0),\n    65→    owner: SystemProgram.programId,\n    66→    executable: false,\n    67→  };\n    68→}\n    69→\n    70→interface TestContext {\n    71→  context: Awaited<ReturnType<typeof startAnchor>>;\n    72→  creator: PublicKey;\n    73→  treasury: Keypair;\n    74→  creatorProgram: Program<Lordofrngs>;\n    75→  configPda: PublicKey;\n    76→  player2: Keypair;\n    77→  player2Program: Program<Lordofrngs>;\n    78→  mockRandomness: Keypair;\n    79→  mockOraoProgram: Keypair;\n    80→  mockOraoNetworkState: Keypair;\n    81→  mockOraoTreasury: Keypair;\n    82→}\n    83→\n    84→async function createTestContext(): Promise<TestContext> {\n    85→  const treasury = Keypair.generate();\n    86→  const player2 = Keypair.generate();\n    87→  const mockRandomness = Keypair.generate();\n    88→  const mockOraoProgram = Keypair.generate();\n    89→  const mockOraoNetworkState = Keypair.generate();\n    90→  const mockOraoTreasury = Keypair.generate();\n    91→\n    92→  const context = await startAnchor(\"./\", [], [\n    93→    { address: treasury.publicKey, info: fundedAccountData() },\n    94→    { address: player2.publicKey, info: fundedAccountData() },\n    95→    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n    96→    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n    97→    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n    98→    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n    99→    // Mock randomness account — starts unfulfilled (32 zero bytes)\n   100→    {\n   101→      address: mockRandomness.publicKey,\n   102→      info: {\n   103→        lamports: LAMPORTS_PER_SOL,\n   104→        data: RANDOMNESS_UNFULFILLED,\n   105→        owner: SystemProgram.programId,\n   106→        executable: false,\n   107→      },\n   108→    },\n   109→  ]);\n   110→\n   111→  const creatorProvider = new BankrunProvider(context);\n   112→  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n   113→\n   114→  const player2Provider = new BankrunProvider(context, new Wallet(player2));\n   115→  const player2Program = new Program<Lordofrngs>(IDL, player2Provider);\n   116→\n   117→  const creator = creatorProvider.wallet.publicKey;\n   118→  const configPda = getConfigPda();\n   119→\n   120→  return {\n   121→    context,\n   122→    creator,\n   123→    treasury,\n   124→    creatorProgram,\n   125→    configPda,\n   126→    player2,\n   127→    player2Program,\n   128→    mockRandomness,\n   129→    mockOraoProgram,\n   130→    mockOraoNetworkState,\n   131→    mockOraoTreasury,\n   132→  };\n   133→}\n   134→\n   135→// ---------------------------------------------------------------------------\n   136→// Clock warp helpers\n   137→// ---------------------------------------------------------------------------\n   138→async function warpPastCountdown(t: TestContext) {\n   139→  const clock = await t.context.banksClient.getClock();\n   140→  t.context.setClock(\n   141→    new Clock(\n   142→      clock.slot + BigInt(200),\n   143→      clock.epochStartTimestamp,\n   144→      clock.epoch,\n   145→      clock.leaderScheduleEpoch,\n   146→      clock.unixTimestamp + BigInt(COUNTDOWN_SECONDS + 10)\n   147→    )\n   148→  );\n   149→}\n   150→\n   151→// ---------------------------------------------------------------------------\n   152→// Instruction helpers\n   153→// ---------------------------------------------------------------------------\n   154→async function initConfig(t: TestContext) {\n   155→  await t.creatorProgram.methods\n   156→    .initializeConfig(t.treasury.publicKey)\n   157→    .accounts({\n   158→      authority: t.creator,\n   159→      config: t.configPda,\n   160→      systemProgram: SystemProgram.programId,\n   161→    })\n   162→    .rpc();\n   163→}\n   164→\n   165→async function createRound(\n   166→  t: TestContext,\n   167→  tier = TIER_IRON,\n   168→  roundNumber = 0,\n   169→  numEntries = 1,\n   170→  creator?: PublicKey,\n   171→) {\n   172→  const roundPda = getRoundPda(tier, roundNumber);\n   173→  await t.creatorProgram.methods\n   174→    .createRound(tier, new BN(roundNumber), numEntries)\n   175→    .accounts({\n   176→      creator: creator ?? t.creator,\n   177→      config: t.configPda,\n   178→      round: roundPda,\n   179→      systemProgram: SystemProgram.programId,\n   180→    })\n   181→    .rpc();\n   182→  return roundPda;\n   183→}\n   184→\n   185→async function joinRound(\n   186→  program: Program<Lordofrngs>,\n   187→  player: PublicKey,\n   188→  configPda: PublicKey,\n   189→  tier = TIER_IRON,\n   190→  roundNumber = 0,\n   191→  numEntries = 1,\n   192→) {\n   193→  const roundPda = getRoundPda(tier, roundNumber);\n   194→  await program.methods\n   195→    .joinRound(tier, new BN(roundNumber), numEntries)\n   196→    .accounts({\n   197→      player,\n   198→      config: configPda,\n   199→      round: roundPda,\n   200→      systemProgram: SystemProgram.programId,\n   201→    })\n   202→    .rpc();\n   203→  return roundPda;\n   204→}\n   205→\n   206→async function buyMoreEntries(\n   207→  program: Program<Lordofrngs>,\n   208→  player: PublicKey,\n   209→  configPda: PublicKey,\n   210→  tier = TIER_IRON,\n   211→  roundNumber = 0,\n   212→  numEntries = 1,\n   213→) {\n   214→  const roundPda = getRoundPda(tier, roundNumber);\n   215→  await program.methods\n   216→    .buyMoreEntries(tier, new BN(roundNumber), numEntries)\n   217→    .accounts({\n   218→      player,\n   219→      config: configPda,\n   220→      round: roundPda,\n   221→      systemProgram: SystemProgram.programId,\n   222→    })\n   223→    .rpc();\n   224→  return roundPda;\n   225→}\n   226→\n   227→async function startSpin(\n   228→  program: Program<Lordofrngs>,\n   229→  caller: PublicKey,\n   230→  t: TestContext,\n   231→  tier = TIER_IRON,\n   232→  roundNumber = 0,\n   233→) {\n   234→  const roundPda = getRoundPda(tier, roundNumber);\n   235→  await program.methods\n   236→    .startSpin(tier, new BN(roundNumber))\n   237→    .accounts({\n   238→      caller,\n   239→      config: t.configPda,\n   240→      round: roundPda,\n   241→      oraoProgram: t.mockOraoProgram.publicKey,\n   242→      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   243→      oraoTreasury: t.mockOraoTreasury.publicKey,\n   244→      oraoRandom: t.mockRandomness.publicKey,\n   245→      systemProgram: SystemProgram.programId,\n   246→    })\n   247→    .rpc();\n   248→  return roundPda;\n   249→}\n   250→\n   251→// Fee constant (3% = 300 bps)\n   252→const TOTAL_FEE_BPS = 300;\n   253→\n   254→// ---------------------------------------------------------------------------\n   255→// Mock VRF + balance helpers\n   256→// ---------------------------------------------------------------------------\n   257→function setMockRandomness(t: TestContext, data: Buffer) {\n   258→  t.context.setAccount(t.mockRandomness.publicKey, {\n   259→    lamports: LAMPORTS_PER_SOL,\n   260→    data,\n   261→    owner: SystemProgram.programId,\n   262→    executable: false,\n   263→  });\n   264→}\n   265→\n   266→async function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n   267→  const account = await t.context.banksClient.getAccount(pubkey);\n   268→  return account ? Number(account.lamports) : 0;\n   269→}\n   270→\n   271→/**\n   272→ * Build randomness buffer where the first 8 bytes (as u64 LE) mod totalEntries\n   273→ * yields the desired winningSlot.\n   274→ */\n   275→function buildRandomness(winningSlot: number, totalEntries: number): Buffer {\n   276→  const buf = Buffer.alloc(32);\n   277→  // Write winningSlot as u64 LE — since winningSlot < totalEntries, mod is identity\n   278→  buf.writeBigUInt64LE(BigInt(winningSlot));\n   279→  // Ensure at least one byte is non-zero so is_fulfilled returns true\n   280→  if (winningSlot === 0) buf[8] = 1;\n   281→  return buf;\n   282→}\n   283→\n   284→/**\n   285→ * Determine the winner from randomness, totalEntries, and players list.\n   286→ * Mirrors the on-chain logic: rand_u64 % total_entries → slot → owner.\n   287→ */\n   288→function deriveWinner(\n   289→  randomness: Buffer,\n   290→  totalEntries: number,\n   291→  players: Array<{ player: PublicKey; entries: number }>\n   292→): { winningSlot: number; winner: PublicKey } {\n   293→  const randU64 = randomness.readBigUInt64LE(0);\n   294→  const winningSlot = Number(randU64 % BigInt(totalEntries));\n   295→  let cumulative = 0;\n   296→  for (const entry of players) {\n   297→    cumulative += entry.entries;\n   298→    if (winningSlot < cumulative) {\n   299→      return { winningSlot, winner: entry.player };\n   300→    }\n   301→  }\n   302→  throw new Error(\"Failed to derive winner\");\n   303→}\n   304→\n   305→async function claimPayout(\n   306→  program: Program<Lordofrngs>,\n   307→  caller: PublicKey,\n   308→  t: TestContext,\n   309→  winnerAccount: PublicKey,\n   310→  tier = TIER_IRON,\n   311→  roundNumber = 0,\n   312→) {\n   313→  const roundPda = getRoundPda(tier, roundNumber);\n   314→  await program.methods\n   315→    .claimPayout(tier, new BN(roundNumber))\n   316→    .accounts({\n   317→      caller,\n   318→      round: roundPda,\n   319→      config: t.configPda,\n   320→      treasury: t.treasury.publicKey,\n   321→      roundCreator: t.creator,\n   322→      winnerAccount,\n   323→      randomnessAccount: t.mockRandomness.publicKey,\n   324→      systemProgram: SystemProgram.programId,\n   325→    })\n   326→    .rpc();\n   327→}\n   328→\n   329→// Timeout constant (matches shared crate DEFAULT_RESOLVE_TIMEOUT_SECONDS)\n   330→const RESOLVE_TIMEOUT_SECONDS = 120;\n   331→\n   332→async function timeoutRefund(\n   333→  program: Program<Lordofrngs>,\n   334→  caller: PublicKey,\n   335→  t: TestContext,\n   336→  playerAccounts: PublicKey[],\n   337→  tier = TIER_IRON,\n   338→  roundNumber = 0,\n   339→) {\n   340→  const roundPda = getRoundPda(tier, roundNumber);\n   341→  await program.methods\n   342→    .timeoutRefund(tier, new BN(roundNumber))\n   343→    .accounts({\n   344→      caller,\n   345→      round: roundPda,\n   346→      config: t.configPda,\n   347→      roundCreator: t.creator,\n   348→      randomnessAccount: t.mockRandomness.publicKey,\n   349→    })\n   350→    .remainingAccounts(\n   351→      playerAccounts.map((pk) => ({\n   352→        pubkey: pk,\n   353→        isSigner: false,\n   354→        isWritable: true,\n   355→      }))\n   356→    )\n   357→    .rpc();\n   358→}\n   359→\n   360→async function warpPastResolveDeadline(t: TestContext) {\n   361→  const clock = await t.context.banksClient.getClock();\n   362→  t.context.setClock(\n   363→    new Clock(\n   364→      clock.slot + BigInt(400),\n   365→      clock.epochStartTimestamp,\n   366→      clock.epoch,\n   367→      clock.leaderScheduleEpoch,\n   368→      // Past countdown (60s) + past resolve deadline (120s) + buffer\n   369→      clock.unixTimestamp + BigInt(COUNTDOWN_SECONDS + RESOLVE_TIMEOUT_SECONDS + 20)\n   370→    )\n   371→  );\n   372→}\n   373→\n   374→// ---------------------------------------------------------------------------\n   375→// Tests\n   376→// ---------------------------------------------------------------------------\n   377→describe(\"lordofrngs\", () => {\n   378→  describe(\"initialize_config\", () => {\n   379→    it(\"creates config with treasury and paused=false\", async () => {\n   380→      const t = await createTestContext();\n   381→      await initConfig(t);\n   382→\n   383→      const config = await t.creatorProgram.account.lordConfig.fetch(\n   384→        t.configPda\n   385→      );\n   386→      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n   387→      expect(config.treasury.toBase58()).to.equal(\n   388→        t.treasury.publicKey.toBase58()\n   389→      );\n   390→      expect(config.paused).to.equal(false);\n   391→      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n   392→    });\n   393→  });\n   394→\n   395→  describe(\"create_round\", () => {\n   396→    it(\"creates round with correct PDA data and escrow balance\", async () => {\n   397→      const t = await createTestContext();\n   398→      await initConfig(t);\n   399→\n   400→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   401→\n   402→      // Verify round state\n   403→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   404→      expect(round.tier).to.equal(TIER_IRON);\n   405→      expect(round.roundNumber.toNumber()).to.equal(0);\n   406→      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   407→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n   408→      expect(round.players).to.have.length(1);\n   409→      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n   410→      expect(round.players[0].entries).to.equal(1);\n   411→      expect(round.totalEntries).to.equal(1);\n   412→      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n   413→      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n   414→      expect(round.lockedAt.toNumber()).to.equal(0);\n   415→      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n   416→      expect(round.claimed).to.equal(false);\n   417→\n   418→      // Verify escrow balance: account holds rent + entry amount\n   419→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   420→      const rent = await t.context.banksClient.getRent();\n   421→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   422→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   423→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n   424→\n   425→      // Verify config round counter incremented\n   426→      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   427→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n   428→    });\n   429→\n   430→    it(\"creates round with multiple entries\", async () => {\n   431→      const t = await createTestContext();\n   432→      await initConfig(t);\n   433→\n   434→      const numEntries = 5;\n   435→      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n   436→\n   437→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   438→      expect(round.players[0].entries).to.equal(numEntries);\n   439→      expect(round.totalEntries).to.equal(numEntries);\n   440→\n   441→      // Escrow should hold numEntries × entry_amount\n   442→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   443→      const rent = await t.context.banksClient.getRent();\n   444→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   445→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   446→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n   447→    });\n   448→\n   449→    it(\"increments round counter per tier\", async () => {\n   450→      const t = await createTestContext();\n   451→      await initConfig(t);\n   452→\n   453→      // Create first round (round 0)\n   454→      await createRound(t, TIER_IRON, 0, 1);\n   455→\n   456→      // Config counter should be 1\n   457→      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   458→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n   459→\n   460→      // Create second round (round 1) — need a new PDA\n   461→      await createRound(t, TIER_IRON, 1, 1);\n   462→\n   463→      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   464→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n   465→    });\n   466→\n   467→    it(\"rejects invalid tier (tier 6)\", async () => {\n   468→      const t = await createTestContext();\n   469→      await initConfig(t);\n   470→\n   471→      const invalidTier = 6;\n   472→      const roundPda = getRoundPda(invalidTier, 0);\n   473→\n   474→      try {\n   475→        await t.creatorProgram.methods\n   476→          .createRound(invalidTier, new BN(0), 1)\n   477→          .accounts({\n   478→            creator: t.creator,\n   479→            config: t.configPda,\n   480→            round: roundPda,\n   481→            systemProgram: SystemProgram.programId,\n   482→          })\n   483→          .rpc();\n   484→        expect.fail(\"Expected InvalidTier error\");\n   485→      } catch (err) {\n   486→        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n   487→        // PDA derivation time, resulting in an Anchor error\n   488→        expect(err).to.be.instanceOf(Error);\n   489→      }\n   490→    });\n   491→\n   492→    it(\"rejects zero entries\", async () => {\n   493→      const t = await createTestContext();\n   494→      await initConfig(t);\n   495→\n   496→      const roundPda = getRoundPda(TIER_IRON, 0);\n   497→\n   498→      try {\n   499→        await t.creatorProgram.methods\n   500→          .createRound(TIER_IRON, new BN(0), 0)\n   501→          .accounts({\n   502→            creator: t.creator,\n   503→            config: t.configPda,\n   504→            round: roundPda,\n   505→            systemProgram: SystemProgram.programId,\n   506→          })\n   507→          .rpc();\n   508→        expect.fail(\"Expected ZeroEntries error\");\n   509→      } catch (err) {\n   510→        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n   511→      }\n   512→    });\n   513→  });\n   514→\n   515→  describe(\"join_round\", () => {\n   516→    it(\"2nd player joins and triggers countdown (Waiting → Active)\", async () => {\n   517→      const t = await createTestContext();\n   518→      await initConfig(t);\n   519→\n   520→      // Creator starts round (player 1)\n   521→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   522→\n   523→      // Player 2 joins\n   524→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   525→\n   526→      // Verify round state\n   527→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   528→      expect(round.players).to.have.length(2);\n   529→      expect(round.players[1].player.toBase58()).to.equal(t.player2.publicKey.toBase58());\n   530→      expect(round.players[1].entries).to.equal(1);\n   531→      expect(round.totalEntries).to.equal(2);\n   532→\n   533→      // Phase should be Active (countdown started)\n   534→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n   535→      expect(round.countdownEndsAt.toNumber()).to.be.greaterThan(0);\n   536→\n   537→      // Escrow should hold 2 × entry_amount\n   538→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   539→      const rent = await t.context.banksClient.getRent();\n   540→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   541→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   542→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 2);\n   543→    });\n   544→\n   545→    it(\"3rd player joins during Active phase without re-triggering countdown\", async () => {\n   546→      const t = await createTestContext();\n   547→      await initConfig(t);\n   548→\n   549→      const player3 = Keypair.generate();\n   550→      const player3Account = fundedAccountData();\n   551→      t.context.setAccount(player3.publicKey, player3Account);\n   552→      const player3Provider = new BankrunProvider(t.context, new Wallet(player3));\n   553→      const player3Program = new Program<Lordofrngs>(IDL, player3Provider);\n   554→\n   555→      // Creator starts round, player2 joins (triggers countdown)\n   556→      await createRound(t, TIER_IRON, 0, 1);\n   557→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   558→\n   559→      const roundBefore = await t.creatorProgram.account.jackpotRound.fetch(\n   560→        getRoundPda(TIER_IRON, 0)\n   561→      );\n   562→      const countdownBefore = roundBefore.countdownEndsAt.toNumber();\n   563→\n   564→      // Player 3 joins\n   565→      await joinRound(player3Program, player3.publicKey, t.configPda);\n   566→\n   567→      const round = await t.creatorProgram.account.jackpotRound.fetch(\n   568→        getRoundPda(TIER_IRON, 0)\n   569→      );\n   570→      expect(round.players).to.have.length(3);\n   571→      expect(round.totalEntries).to.equal(3);\n   572→      // Countdown should not have changed\n   573→      expect(round.countdownEndsAt.toNumber()).to.equal(countdownBefore);\n   574→    });\n   575→\n   576→    it(\"player can join with multiple entries\", async () => {\n   577→      const t = await createTestContext();\n   578→      await initConfig(t);\n   579→\n   580→      await createRound(t, TIER_IRON, 0, 1);\n   581→\n   582→      // Player 2 joins with 5 entries\n   583→      const roundPda = await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, 5);\n   584→\n   585→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   586→      expect(round.players[1].entries).to.equal(5);\n   587→      expect(round.totalEntries).to.equal(6); // 1 (creator) + 5 (player2)\n   588→\n   589→      // Escrow: 1 × amount (creator) + 5 × amount (player2)\n   590→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   591→      const rent = await t.context.banksClient.getRent();\n   592→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   593→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   594→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 6);\n   595→    });\n   596→\n   597→    it(\"rejects duplicate player\", async () => {\n   598→      const t = await createTestContext();\n   599→      await initConfig(t);\n   600→\n   601→      await createRound(t, TIER_IRON, 0, 1);\n   602→\n   603→      // Creator tries to join their own round again\n   604→      try {\n   605→        await joinRound(t.creatorProgram, t.creator, t.configPda);\n   606→        expect.fail(\"Expected PlayerAlreadyInRound error\");\n   607→      } catch (err) {\n   608→        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerAlreadyInRound\");\n   609→      }\n   610→    });\n   611→\n   612→    it(\"rejects 21st player (max 20)\", async () => {\n   613→      const t = await createTestContext();\n   614→      await initConfig(t);\n   615→\n   616→      // Creator starts round\n   617→      await createRound(t, TIER_IRON, 0, 1);\n   618→\n   619→      // Add 19 more players (total 20)\n   620→      for (let i = 0; i < 19; i++) {\n   621→        const p = Keypair.generate();\n   622→        t.context.setAccount(p.publicKey, fundedAccountData());\n   623→        const pProvider = new BankrunProvider(t.context, new Wallet(p));\n   624→        const pProgram = new Program<Lordofrngs>(IDL, pProvider);\n   625→        await joinRound(pProgram, p.publicKey, t.configPda);\n   626→      }\n   627→\n   628→      // Verify we have 20 players\n   629→      const round = await t.creatorProgram.account.jackpotRound.fetch(\n   630→        getRoundPda(TIER_IRON, 0)\n   631→      );\n   632→      expect(round.players).to.have.length(20);\n   633→\n   634→      // 21st player should be rejected\n   635→      const extra = Keypair.generate();\n   636→      t.context.setAccount(extra.publicKey, fundedAccountData());\n   637→      const extraProvider = new BankrunProvider(t.context, new Wallet(extra));\n   638→      const extraProgram = new Program<Lordofrngs>(IDL, extraProvider);\n   639→\n   640→      try {\n   641→        await joinRound(extraProgram, extra.publicKey, t.configPda);\n   642→        expect.fail(\"Expected MaxPlayersReached error\");\n   643→      } catch (err) {\n   644→        expect((err as AnchorError).error.errorCode.code).to.equal(\"MaxPlayersReached\");\n   645→      }\n   646→    });\n   647→\n   648→    it(\"rejects join when phase is Locked\", async () => {\n   649→      // We can't easily get to Locked phase without VRF, so we test that\n   650→      // only Waiting and Active phases are accepted. We'll simulate by\n   651→      // checking the phase validation works with a round that's in a state\n   652→      // we can't join.\n   653→      // For now, we verify the InvalidPhase error by checking that joining\n   654→      // a round that doesn't exist fails (Anchor account constraint).\n   655→      // The full phase rejection test will be covered in the start_spin tests.\n   656→\n   657→      // Instead, test that joining during Waiting phase (before 2nd player) works,\n   658→      // which is already covered above. The Locked phase test will be\n   659→      // in the start_spin + claim_payout iteration when we can create Locked rounds.\n   660→      // Skip for now — covered by the phase check in the instruction.\n   661→    });\n   662→  });\n   663→\n   664→  describe(\"buy_more_entries\", () => {\n   665→    it(\"existing player buys more entries (updated count + escrow)\", async () => {\n   666→      const t = await createTestContext();\n   667→      await initConfig(t);\n   668→\n   669→      // Creator starts round with 1 entry\n   670→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   671→\n   672→      // Creator buys 3 more entries\n   673→      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 3);\n   674→\n   675→      // Verify updated state\n   676→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   677→      expect(round.players).to.have.length(1);\n   678→      expect(round.players[0].entries).to.equal(4); // 1 + 3\n   679→      expect(round.totalEntries).to.equal(4);\n   680→\n   681→      // Escrow should hold 4 × entry_amount\n   682→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   683→      const rent = await t.context.banksClient.getRent();\n   684→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   685→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   686→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * 4);\n   687→    });\n   688→\n   689→    it(\"works during Active phase (after countdown starts)\", async () => {\n   690→      const t = await createTestContext();\n   691→      await initConfig(t);\n   692→\n   693→      // Creator starts round, player2 joins (triggers countdown → Active)\n   694→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   695→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   696→\n   697→      // Creator buys 2 more during Active phase\n   698→      await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 2);\n   699→\n   700→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   701→      expect(round.players[0].entries).to.equal(3); // 1 + 2\n   702→      expect(round.totalEntries).to.equal(4); // 3 (creator) + 1 (player2)\n   703→    });\n   704→\n   705→    it(\"rejects player not in round\", async () => {\n   706→      const t = await createTestContext();\n   707→      await initConfig(t);\n   708→\n   709→      // Creator starts round\n   710→      await createRound(t, TIER_IRON, 0, 1);\n   711→\n   712→      // Player2 (not in round) tries to buy more\n   713→      try {\n   714→        await buyMoreEntries(t.player2Program, t.player2.publicKey, t.configPda);\n   715→        expect.fail(\"Expected PlayerNotInRound error\");\n   716→      } catch (err) {\n   717→        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerNotInRound\");\n   718→      }\n   719→    });\n   720→\n   721→    it(\"rejects zero entries\", async () => {\n   722→      const t = await createTestContext();\n   723→      await initConfig(t);\n   724→\n   725→      await createRound(t, TIER_IRON, 0, 1);\n   726→\n   727→      try {\n   728→        await buyMoreEntries(t.creatorProgram, t.creator, t.configPda, TIER_IRON, 0, 0);\n   729→        expect.fail(\"Expected ZeroEntries error\");\n   730→      } catch (err) {\n   731→        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n   732→      }\n   733→    });\n   734→  });\n   735→\n   736→  describe(\"start_spin\", () => {\n   737→    it(\"transitions Active → Locked after countdown expires\", async () => {\n   738→      const t = await createTestContext();\n   739→      await initConfig(t);\n   740→\n   741→      // Creator creates round, player2 joins (triggers countdown → Active)\n   742→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   743→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   744→\n   745→      // Verify Active phase\n   746→      let round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   747→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ active: {} }));\n   748→\n   749→      // Warp past countdown\n   750→      await warpPastCountdown(t);\n   751→\n   752→      // Start spin\n   753→      await startSpin(t.creatorProgram, t.creator, t);\n   754→\n   755→      // Verify Locked phase + VRF fields set\n   756→      round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   757→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n   758→      expect(round.lockedAt.toNumber()).to.be.greaterThan(0);\n   759→      expect(round.resolveDeadline.toNumber()).to.be.greaterThan(round.lockedAt.toNumber());\n   760→      expect(round.vrfRequestKey.toBase58()).to.equal(t.mockRandomness.publicKey.toBase58());\n   761→    });\n   762→\n   763→    it(\"is idempotent (no error when already Locked)\", async () => {\n   764→      const t = await createTestContext();\n   765→      await initConfig(t);\n   766→\n   767→      await createRound(t, TIER_IRON, 0, 1);\n   768→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   769→      await warpPastCountdown(t);\n   770→\n   771→      // First spin succeeds\n   772→      await startSpin(t.creatorProgram, t.creator, t);\n   773→\n   774→      // Second spin from a different player also succeeds (idempotent no-op)\n   775→      await startSpin(t.player2Program, t.player2.publicKey, t);\n   776→\n   777→      // Still Locked\n   778→      const round = await t.creatorProgram.account.jackpotRound.fetch(\n   779→        getRoundPda(TIER_IRON, 0)\n   780→      );\n   781→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ locked: {} }));\n   782→    });\n   783→\n   784→    it(\"rejects spin before countdown expires\", async () => {\n   785→      const t = await createTestContext();\n   786→      await initConfig(t);\n   787→\n   788→      await createRound(t, TIER_IRON, 0, 1);\n   789→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   790→\n   791→      // Don't warp — countdown is still running\n   792→      try {\n   793→        await startSpin(t.creatorProgram, t.creator, t);\n   794→        expect.fail(\"Expected CountdownNotExpired error\");\n   795→      } catch (err) {\n   796→        expect((err as AnchorError).error.errorCode.code).to.equal(\"CountdownNotExpired\");\n   797→      }\n   798→    });\n   799→\n   800→    it(\"rejects spin when phase is Waiting (only 1 player)\", async () => {\n   801→      const t = await createTestContext();\n   802→      await initConfig(t);\n   803→\n   804→      await createRound(t, TIER_IRON, 0, 1);\n   805→\n   806→      // Phase is Waiting — no second player joined yet\n   807→      try {\n   808→        await startSpin(t.creatorProgram, t.creator, t);\n   809→        expect.fail(\"Expected InvalidPhase error\");\n   810→      } catch (err) {\n   811→        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n   812→      }\n   813→    });\n   814→  });\n   815→\n   816→  describe(\"claim_payout\", () => {\n   817→    /** Helper: set up a round in Locked phase (creator 1 entry, player2 1 entry) */\n   818→    async function setupLockedRound(t: TestContext, creatorEntries = 1, player2Entries = 1) {\n   819→      await initConfig(t);\n   820→      const roundPda = await createRound(t, TIER_IRON, 0, creatorEntries);\n   821→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, player2Entries);\n   822→      await warpPastCountdown(t);\n   823→      await startSpin(t.creatorProgram, t.creator, t);\n   824→      return roundPda;\n   825→    }\n   826→\n   827→    it(\"creator wins — correct payout and fee to treasury\", async () => {\n   828→      const t = await createTestContext();\n   829→      const roundPda = await setupLockedRound(t);\n   830→\n   831→      const totalEntries = 2;\n   832→      const pool = TIER_IRON_AMOUNT * totalEntries;\n   833→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   834→      const payout = pool - fee;\n   835→\n   836→      // Randomness: slot 0 → creator wins (creator owns slots [0,1), player2 owns [1,2))\n   837→      const randomness = buildRandomness(0, totalEntries);\n   838→      setMockRandomness(t, randomness);\n   839→\n   840→      const winnerBefore = await getBalance(t, t.creator);\n   841→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   842→\n   843→      await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n   844→\n   845→      const winnerAfter = await getBalance(t, t.creator);\n   846→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   847→\n   848→      // Creator receives payout + rent refund from closed PDA (minus tx fee)\n   849→      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n   850→      // Treasury receives exact fee\n   851→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   852→    });\n   853→\n   854→    it(\"player2 wins — payout goes to player2\", async () => {\n   855→      const t = await createTestContext();\n   856→      const roundPda = await setupLockedRound(t);\n   857→\n   858→      const totalEntries = 2;\n   859→      const pool = TIER_IRON_AMOUNT * totalEntries;\n   860→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   861→      const payout = pool - fee;\n   862→\n   863→      // Randomness: slot 1 → player2 wins (creator owns [0,1), player2 owns [1,2))\n   864→      const randomness = buildRandomness(1, totalEntries);\n   865→      setMockRandomness(t, randomness);\n   866→\n   867→      const player2Before = await getBalance(t, t.player2.publicKey);\n   868→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   869→\n   870→      // Creator triggers claim, but payout goes to player2\n   871→      await claimPayout(t.creatorProgram, t.creator, t, t.player2.publicKey);\n   872→\n   873→      const player2After = await getBalance(t, t.player2.publicKey);\n   874→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   875→\n   876→      // Player2 receives exact payout (they didn't sign the tx, so no tx fee)\n   877→      expect(player2After - player2Before).to.equal(payout);\n   878→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   879→    });\n   880→\n   881→    it(\"multiple entries increases win probability proportionally\", async () => {\n   882→      const t = await createTestContext();\n   883→      // Creator has 3 entries, player2 has 1 entry → 4 total\n   884→      // Creator owns slots [0,1,2), player2 owns [3)\n   885→      const roundPda = await setupLockedRound(t, 3, 1);\n   886→\n   887→      const totalEntries = 4;\n   888→      const pool = TIER_IRON_AMOUNT * totalEntries;\n   889→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   890→      const payout = pool - fee;\n   891→\n   892→      // Randomness: slot 2 → creator wins (creator owns [0,3))\n   893→      const randomness = buildRandomness(2, totalEntries);\n   894→      setMockRandomness(t, randomness);\n   895→\n   896→      const winnerBefore = await getBalance(t, t.creator);\n   897→      await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n   898→      const winnerAfter = await getBalance(t, t.creator);\n   899→\n   900→      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n   901→    });\n   902→\n   903→    it(\"round PDA closed after claim (account no longer exists)\", async () => {\n   904→      const t = await createTestContext();\n   905→      const roundPda = await setupLockedRound(t);\n   906→\n   907→      const randomness = buildRandomness(0, 2);\n   908→      setMockRandomness(t, randomness);\n   909→\n   910→      await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n   911→\n   912→      // Round PDA should be closed\n   913→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   914→      expect(roundAccount).to.be.null;\n   915→    });\n   916→\n   917→    it(\"rejects claim with unfulfilled randomness\", async () => {\n   918→      const t = await createTestContext();\n   919→      await setupLockedRound(t);\n   920→\n   921→      // Randomness stays all zeros (unfulfilled — set during context creation)\n   922→\n   923→      try {\n   924→        await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n   925→        expect.fail(\"Expected RandomnessNotFulfilled error\");\n   926→      } catch (err) {\n   927→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   928→          \"RandomnessNotFulfilled\"\n   929→        );\n   930→      }\n   931→    });\n   932→\n   933→    it(\"rejects claim with wrong winner_account\", async () => {\n   934→      const t = await createTestContext();\n   935→      await setupLockedRound(t);\n   936→\n   937→      // Randomness: slot 0 → creator wins\n   938→      const randomness = buildRandomness(0, 2);\n   939→      setMockRandomness(t, randomness);\n   940→\n   941→      // Pass player2 as winner_account, but creator actually won\n   942→      try {\n   943→        await claimPayout(t.creatorProgram, t.creator, t, t.player2.publicKey);\n   944→        expect.fail(\"Expected NotWinner error\");\n   945→      } catch (err) {\n   946→        expect((err as AnchorError).error.errorCode.code).to.equal(\"NotWinner\");\n   947→      }\n   948→    });\n   949→\n   950→    it(\"rejects claim when phase is not Locked\", async () => {\n   951→      const t = await createTestContext();\n   952→      await initConfig(t);\n   953→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   954→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n   955→      // Phase is Active (not Locked)\n   956→\n   957→      const randomness = buildRandomness(0, 2);\n   958→      setMockRandomness(t, randomness);\n   959→\n   960→      try {\n   961→        await claimPayout(t.creatorProgram, t.creator, t, t.creator);\n   962→        expect.fail(\"Expected InvalidPhase error\");\n   963→      } catch (err) {\n   964→        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n   965→      }\n   966→    });\n   967→  });\n   968→\n   969→  describe(\"timeout_refund\", () => {\n   970→    /** Helper: set up a round in Locked phase with unfulfilled VRF */\n   971→    async function setupLockedRoundUnfulfilled(t: TestContext, creatorEntries = 1, player2Entries = 1) {\n   972→      await initConfig(t);\n   973→      const roundPda = await createRound(t, TIER_IRON, 0, creatorEntries);\n   974→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda, TIER_IRON, 0, player2Entries);\n   975→      await warpPastCountdown(t);\n   976→      await startSpin(t.creatorProgram, t.creator, t);\n   977→      // VRF stays unfulfilled (all zeros from context setup)\n   978→      return roundPda;\n   979→    }\n   980→\n   981→    it(\"refunds all players after timeout with unfulfilled VRF\", async () => {\n   982→      const t = await createTestContext();\n   983→      const roundPda = await setupLockedRoundUnfulfilled(t);\n   984→\n   985→      const creatorBefore = await getBalance(t, t.creator);\n   986→      const player2Before = await getBalance(t, t.player2.publicKey);\n   987→\n   988→      // Warp past resolve deadline\n   989→      await warpPastResolveDeadline(t);\n   990→\n   991→      await timeoutRefund(\n   992→        t.creatorProgram,\n   993→        t.creator,\n   994→        t,\n   995→        [t.creator, t.player2.publicKey]\n   996→      );\n   997→\n   998→      const creatorAfter = await getBalance(t, t.creator);\n   999→      const player2After = await getBalance(t, t.player2.publicKey);\n  1000→\n  1001→      // Creator gets entry refund + rent refund (minus tx fee)\n  1002→      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(TIER_IRON_AMOUNT);\n  1003→      // Player2 gets exact entry refund (no tx fee, not signer)\n  1004→      expect(player2After - player2Before).to.equal(TIER_IRON_AMOUNT);\n  1005→\n  1006→      // Round PDA closed\n  1007→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n  1008→      expect(roundAccount).to.be.null;\n  1009→    });\n  1010→\n  1011→    it(\"refunds proportional to entries purchased\", async () => {\n  1012→      const t = await createTestContext();\n  1013→      // Creator has 3 entries, player2 has 2 entries\n  1014→      const roundPda = await setupLockedRoundUnfulfilled(t, 3, 2);\n  1015→\n  1016→      const player2Before = await getBalance(t, t.player2.publicKey);\n  1017→\n  1018→      await warpPastResolveDeadline(t);\n  1019→\n  1020→      await timeoutRefund(\n  1021→        t.creatorProgram,\n  1022→        t.creator,\n  1023→        t,\n  1024→        [t.creator, t.player2.publicKey]\n  1025→      );\n  1026→\n  1027→      const player2After = await getBalance(t, t.player2.publicKey);\n  1028→\n  1029→      // Player2 gets 2 × entry_amount refunded\n  1030→      expect(player2After - player2Before).to.equal(TIER_IRON_AMOUNT * 2);\n  1031→    });\n  1032→\n  1033→    it(\"rejects when VRF is fulfilled (must use claim_payout instead)\", async () => {\n  1034→      const t = await createTestContext();\n  1035→      await setupLockedRoundUnfulfilled(t);\n  1036→\n  1037→      // Fulfill the VRF\n  1038→      const randomness = buildRandomness(0, 2);\n  1039→      setMockRandomness(t, randomness);\n  1040→\n  1041→      await warpPastResolveDeadline(t);\n  1042→\n  1043→      try {\n  1044→        await timeoutRefund(\n  1045→          t.creatorProgram,\n  1046→          t.creator,\n  1047→          t,\n  1048→          [t.creator, t.player2.publicKey]\n  1049→        );\n  1050→        expect.fail(\"Expected VrfAlreadyFulfilled error\");\n  1051→      } catch (err) {\n  1052→        expect((err as AnchorError).error.errorCode.code).to.equal(\"VrfAlreadyFulfilled\");\n  1053→      }\n  1054→    });\n  1055→\n  1056→    it(\"rejects when timeout has not elapsed\", async () => {\n  1057→      const t = await createTestContext();\n  1058→      await setupLockedRoundUnfulfilled(t);\n  1059→\n  1060→      // Don't warp past resolve deadline — just stay at post-countdown time\n  1061→      // (warpPastCountdown was called in setupLockedRoundUnfulfilled)\n  1062→\n  1063→      try {\n  1064→        await timeoutRefund(\n  1065→          t.creatorProgram,\n  1066→          t.creator,\n  1067→          t,\n  1068→          [t.creator, t.player2.publicKey]\n  1069→        );\n  1070→        expect.fail(\"Expected LockTimeoutNotElapsed error\");\n  1071→      } catch (err) {\n  1072→        expect((err as AnchorError).error.errorCode.code).to.equal(\"LockTimeoutNotElapsed\");\n  1073→      }\n  1074→    });\n  1075→\n  1076→    it(\"rejects when phase is not Locked (Active phase)\", async () => {\n  1077→      const t = await createTestContext();\n  1078→      await initConfig(t);\n  1079→      await createRound(t, TIER_IRON, 0, 1);\n  1080→      await joinRound(t.player2Program, t.player2.publicKey, t.configPda);\n  1081→      // Phase is Active, not Locked\n  1082→\n  1083→      await warpPastResolveDeadline(t);\n  1084→\n  1085→      try {\n  1086→        await timeoutRefund(\n  1087→          t.creatorProgram,\n  1088→          t.creator,\n  1089→          t,\n  1090→          [t.creator, t.player2.publicKey]\n  1091→        );\n  1092→        expect.fail(\"Expected InvalidPhase error\");\n  1093→      } catch (err) {\n  1094→        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidPhase\");\n  1095→      }\n  1096→    });\n  1097→  });\n  1098→});\n  1099→"}]},"parent_tool_use_id":"toolu_01AbWAP4pzMsxrFdVQpc6rBg","session_id":"cd70fe61-545b-465a-ae36-fc0d70c24914","uuid":"274a7039-6170-4fcf-80ae-4121fb962a02"}
