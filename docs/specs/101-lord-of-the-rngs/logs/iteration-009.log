{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VdLrM3KtJiaZe3eMCrsERq","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→use rng_shared::lifecycle::{self, RoundPhase};\n     4→use rng_shared::timeout::is_expired;\n     5→use rng_shared::vrf_orao::{is_fulfilled, read_orao_randomness};\n     6→\n     7→use crate::error::LordError;\n     8→use crate::state::{JackpotRound, LordConfig};\n     9→\n    10→#[derive(Accounts)]\n    11→#[instruction(tier: u8, round_number: u64)]\n    12→pub struct TimeoutRefund<'info> {\n    13→    /// Any signer can trigger a timeout refund (permissionless after deadline).\n    14→    #[account(mut)]\n    15→    pub caller: Signer<'info>,\n    16→\n    17→    /// The round PDA (closed after refunds — rent goes to round creator).\n    18→    #[account(\n    19→        mut,\n    20→        close = round_creator,\n    21→        seeds = [b\"jackpot_round\", &[tier], &round_number.to_le_bytes()],\n    22→        bump = round.bump,\n    23→    )]\n    24→    pub round: Account<'info, JackpotRound>,\n    25→\n    26→    /// The config PDA (for validation only).\n    27→    #[account(\n    28→        seeds = [b\"lord_config\"],\n    29→        bump = config.bump,\n    30→    )]\n    31→    pub config: Account<'info, LordConfig>,\n    32→\n    33→    /// The round creator account (receives rent refund on close).\n    34→    /// CHECK: Validated against round.creator in handler.\n    35→    #[account(mut)]\n    36→    pub round_creator: AccountInfo<'info>,\n    37→\n    38→    /// The Orao randomness PDA — used to check VRF is NOT fulfilled.\n    39→    /// CHECK: Key validated against round.vrf_request_key; data read by shared VRF helper.\n    40→    pub randomness_account: AccountInfo<'info>,\n    41→\n    42→    // Remaining accounts: one mutable AccountInfo per player in round.players[],\n    43→    // in the same order as the players Vec. Each receives their entry refund.\n    44→}\n    45→\n    46→pub fn handler<'info>(\n    47→    ctx: Context<'_, '_, 'info, 'info, TimeoutRefund<'info>>,\n    48→    _tier: u8,\n    49→    _round_number: u64,\n    50→) -> Result<()> {\n    51→    let round = &ctx.accounts.round;\n    52→\n    53→    // (1) Must be in LOCKED phase\n    54→    require!(\n    55→        round.phase == RoundPhase::Locked,\n    56→        LordError::InvalidPhase\n    57→    );\n    58→\n    59→    // (2) Validate accounts match stored state\n    60→    require_keys_eq!(ctx.accounts.round_creator.key(), round.creator);\n    61→    require_keys_eq!(\n    62→        ctx.accounts.randomness_account.key(),\n    63→        round.vrf_request_key\n    64→    );\n    65→\n    66→    // (3) Check timeout has elapsed\n    67→    let now = Clock::get()?.unix_timestamp;\n    68→    require!(\n    69→        is_expired(round.resolve_deadline, now),\n    70→        LordError::LockTimeoutNotElapsed\n    71→    );\n    72→\n    73→    // (4) Check that VRF randomness is NOT fulfilled — if fulfilled, must use claim_payout\n    74→    let vrf_is_fulfilled = read_orao_randomness(&ctx.accounts.randomness_account)\n    75→        .map(|r| is_fulfilled(&r))\n    76→        .unwrap_or(false);\n    77→    require!(!vrf_is_fulfilled, LordError::VrfAlreadyFulfilled);\n    78→\n    79→    // (5) Refund all players their entry amounts\n    80→    let remaining = ctx.remaining_accounts;\n    81→    let players = &round.players;\n    82→    require!(\n    83→        remaining.len() == players.len(),\n    84→        LordError::InvalidPhase // wrong number of remaining accounts\n    85→    );\n    86→\n    87→    let entry_amount = round.entry_amount;\n    88→    let round_info = ctx.accounts.round.to_account_info();\n    89→\n    90→    for (i, player_entry) in players.iter().enumerate() {\n    91→        let player_account = &remaining[i];\n    92→        // Validate each remaining account matches the player in the Vec\n    93→        require_keys_eq!(player_account.key(), player_entry.player);\n    94→\n    95→        let refund = entry_amount\n    96→            .checked_mul(player_entry.entries as u64)\n    97→            .ok_or(LordError::ArithmeticOverflow)?;\n    98→        transfer_lamports_from_pda(&round_info, player_account, refund)?;\n    99→    }\n   100→\n   101→    // (6) Transition to Refunded\n   102→    lifecycle::transition(round.phase, RoundPhase::Refunded)?;\n   103→    let round = &mut ctx.accounts.round;\n   104→    round.phase = RoundPhase::Refunded;\n   105→\n   106→    // Account is closed by Anchor's `close = round_creator` constraint.\n   107→    Ok(())\n   108→}\n   109→"}]},"parent_tool_use_id":"toolu_01PyvkeGuQU7ueoMWiVKtQER","session_id":"cd70fe61-545b-465a-ae36-fc0d70c24914","uuid":"c6ea03e4-9467-42f8-b5a8-68b91ceaf4ed"}
