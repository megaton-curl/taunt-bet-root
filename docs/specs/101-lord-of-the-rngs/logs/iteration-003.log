{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HUW65hvdACWHqWNtJLxwda","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::lifecycle::RoundPhase;\n     3→\n     4→/// Global configuration for the coinflip program.\n     5→/// PDA seeds: [b\"coinflip_config\"]\n     6→#[account]\n     7→#[derive(InitSpace)]\n     8→pub struct CoinflipConfig {\n     9→    /// Admin authority (can update config).\n    10→    pub authority: Pubkey,\n    11→    /// Fee destination wallet.\n    12→    pub treasury: Pubkey,\n    13→    /// Whether the game is paused (rejects new matches).\n    14→    pub paused: bool,\n    15→    /// Bump seed for PDA derivation.\n    16→    pub bump: u8,\n    17→}\n    18→\n    19→/// A coinflip match between two players.\n    20→/// PDA seeds: [b\"match\", creator.key().as_ref()]\n    21→#[account]\n    22→#[derive(InitSpace)]\n    23→pub struct CoinflipMatch {\n    24→    /// The player who created the match.\n    25→    pub creator: Pubkey,\n    26→    /// The player who joined (Pubkey::default() if empty).\n    27→    pub opponent: Pubkey,\n    28→    /// Tier index (0-5).\n    29→    pub tier: u8,\n    30→    /// Entry amount in lamports (derived from tier).\n    31→    pub entry_amount: u64,\n    32→    /// Side chosen by creator (0 = Heads, 1 = Tails).\n    33→    pub creator_side: u8,\n    34→    /// Current phase of the match (shared lifecycle enum).\n    35→    pub phase: RoundPhase,\n    36→    /// The winning side after VRF resolution (0 or 1, only valid when settled).\n    37→    pub result: u8,\n    38→    /// The winner's pubkey (Pubkey::default() until settled).\n    39→    pub winner: Pubkey,\n    40→    /// Whether the payout has been claimed.\n    41→    pub claimed: bool,\n    42→    /// Unix timestamp when the match was created.\n    43→    pub created_at: i64,\n    44→    /// Unix timestamp when the match entered LOCKED phase (0 if still WAITING).\n    45→    pub locked_at: i64,\n    46→    /// Deadline for VRF resolution; after this, timeout refund is available.\n    47→    pub resolve_deadline: i64,\n    48→    /// Address of the Orao randomness PDA for VRF lookup at claim time.\n    49→    pub vrf_request_key: Pubkey,\n    50→    /// Bump seed for PDA derivation.\n    51→    pub bump: u8,\n    52→}\n    53→\n    54→/// Event emitted when a match is settled via claim_payout.\n    55→#[event]\n    56→pub struct MatchSettled {\n    57→    pub creator: Pubkey,\n    58→    pub opponent: Pubkey,\n    59→    pub winner: Pubkey,\n    60→    pub randomness: [u8; 32],\n    61→    pub payout_amount: u64,\n    62→    pub fee_amount: u64,\n    63→    pub vrf_request_key: Pubkey,\n    64→}\n    65→"}]},"parent_tool_use_id":"toolu_01DfD9Rj3j1sZomWEvmsDpHp","session_id":"cd382642-6e40-406b-af72-e4885c229771","uuid":"0f59ae76-bd5e-4a9a-b9e6-8bc5e19a2af1"}
