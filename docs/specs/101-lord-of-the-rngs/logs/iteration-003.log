{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JGRYQFQEqF5Ph27NETihwp","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { Program } from \"@coral-xyz/anchor\";\n     5→import {\n     6→  Keypair,\n     7→  PublicKey,\n     8→  SystemProgram,\n     9→  LAMPORTS_PER_SOL,\n    10→} from \"@solana/web3.js\";\n    11→import type { Lordofrngs } from \"../target/types/lordofrngs\";\n    12→import { readFileSync } from \"fs\";\n    13→import { dirname, join } from \"path\";\n    14→import { fileURLToPath } from \"url\";\n    15→\n    16→const __filename = fileURLToPath(import.meta.url);\n    17→const __dirname = dirname(__filename);\n    18→\n    19→const IDL = JSON.parse(\n    20→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n    21→);\n    22→const PROGRAM_ID = new PublicKey(IDL.address);\n    23→\n    24→// ---------------------------------------------------------------------------\n    25→// PDA helpers\n    26→// ---------------------------------------------------------------------------\n    27→function getConfigPda(): PublicKey {\n    28→  const [pda] = PublicKey.findProgramAddressSync(\n    29→    [Buffer.from(\"lord_config\")],\n    30→    PROGRAM_ID\n    31→  );\n    32→  return pda;\n    33→}\n    34→\n    35→// ---------------------------------------------------------------------------\n    36→// Test context factory\n    37→// ---------------------------------------------------------------------------\n    38→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n    39→  return {\n    40→    lamports,\n    41→    data: Buffer.alloc(0),\n    42→    owner: SystemProgram.programId,\n    43→    executable: false,\n    44→  };\n    45→}\n    46→\n    47→interface TestContext {\n    48→  context: Awaited<ReturnType<typeof startAnchor>>;\n    49→  creator: PublicKey;\n    50→  treasury: Keypair;\n    51→  creatorProgram: Program<Lordofrngs>;\n    52→  configPda: PublicKey;\n    53→}\n    54→\n    55→async function createTestContext(): Promise<TestContext> {\n    56→  const treasury = Keypair.generate();\n    57→\n    58→  const context = await startAnchor(\"./\", [], [\n    59→    { address: treasury.publicKey, info: fundedAccountData() },\n    60→  ]);\n    61→\n    62→  const creatorProvider = new BankrunProvider(context);\n    63→  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n    64→\n    65→  const creator = creatorProvider.wallet.publicKey;\n    66→  const configPda = getConfigPda();\n    67→\n    68→  return {\n    69→    context,\n    70→    creator,\n    71→    treasury,\n    72→    creatorProgram,\n    73→    configPda,\n    74→  };\n    75→}\n    76→\n    77→// ---------------------------------------------------------------------------\n    78→// Instruction helpers\n    79→// ---------------------------------------------------------------------------\n    80→async function initConfig(t: TestContext) {\n    81→  await t.creatorProgram.methods\n    82→    .initializeConfig(t.treasury.publicKey)\n    83→    .accounts({\n    84→      authority: t.creator,\n    85→      config: t.configPda,\n    86→      systemProgram: SystemProgram.programId,\n    87→    })\n    88→    .rpc();\n    89→}\n    90→\n    91→// ---------------------------------------------------------------------------\n    92→// Tests\n    93→// ---------------------------------------------------------------------------\n    94→describe(\"lordofrngs\", () => {\n    95→  describe(\"initialize_config\", () => {\n    96→    it(\"creates config with treasury and paused=false\", async () => {\n    97→      const t = await createTestContext();\n    98→      await initConfig(t);\n    99→\n   100→      const config = await t.creatorProgram.account.lordConfig.fetch(\n   101→        t.configPda\n   102→      );\n   103→      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n   104→      expect(config.treasury.toBase58()).to.equal(\n   105→        t.treasury.publicKey.toBase58()\n   106→      );\n   107→      expect(config.paused).to.equal(false);\n   108→      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n   109→    });\n   110→  });\n   111→});\n   112→"}]},"parent_tool_use_id":"toolu_013Fbij5mmWtBHgJEXS5c6VB","session_id":"cd382642-6e40-406b-af72-e4885c229771","uuid":"37061630-1814-47e3-ae5d-e279e32cc09d"}
