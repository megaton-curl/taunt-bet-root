e entry amount for the given tier index, or an error if out of range.\npub fn get_tier_amount(tier: u8) -> Result<u64> {\n    TIER_AMOUNTS\n        .get(tier as usize)\n        .copied()\n        .ok_or_else(|| error!(TierError::InvalidTier))\n}\n\n#[error_code]\npub enum TierError {\n    #[msg(\"Invalid tier index\")]\n    InvalidTier,\n}\n","numLines":29,"startLine":1,"totalLines":29}}}
