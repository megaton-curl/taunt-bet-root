{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017g8J1xBhucxyMos6mgx1NK","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→#[error_code]\n     4→pub enum PauseError {\n     5→    #[msg(\"Platform is paused\")]\n     6→    PlatformPaused,\n     7→    #[msg(\"Game is paused\")]\n     8→    GamePaused,\n     9→}\n    10→\n    11→/// Checks that neither the global platform nor the specific game is paused.\n    12→/// Global pause takes precedence over game pause.\n    13→pub fn check_not_paused(global_paused: bool, game_paused: bool) -> Result<()> {\n    14→    if global_paused {\n    15→        return Err(PauseError::PlatformPaused.into());\n    16→    }\n    17→    if game_paused {\n    18→        return Err(PauseError::GamePaused.into());\n    19→    }\n    20→    Ok(())\n    21→}\n    22→\n    23→#[cfg(test)]\n    24→mod tests {\n    25→    use super::*;\n    26→\n    27→    #[test]\n    28→    fn both_unpaused_ok() {\n    29→        assert!(check_not_paused(false, false).is_ok());\n    30→    }\n    31→\n    32→    #[test]\n    33→    fn global_paused_returns_platform_paused() {\n    34→        let err = check_not_paused(true, false).unwrap_err();\n    35→        assert!(err.to_string().contains(\"PlatformPaused\"));\n    36→    }\n    37→\n    38→    #[test]\n    39→    fn game_paused_returns_game_paused() {\n    40→        let err = check_not_paused(false, true).unwrap_err();\n    41→        assert!(err.to_string().contains(\"GamePaused\"));\n    42→    }\n    43→\n    44→    #[test]\n    45→    fn both_paused_returns_platform_paused_precedence() {\n    46→        let err = check_not_paused(true, true).unwrap_err();\n    47→        assert!(err.to_string().contains(\"PlatformPaused\"));\n    48→    }\n    49→}\n    50→"}]},"parent_tool_use_id":null,"session_id":"cd382642-6e40-406b-af72-e4885c229771","uuid":"614b4c41-f2ae-46cd-bd00-1e2703841620","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/pause.rs","content":"use anchor_lang::prelude::*;\n\n#[error_code]\npub enum PauseError {\n    #[msg(\"Platform is paused\")]\n    PlatformPaused,\n    #[msg(\"Game is paused\")]\n    GamePaused,\n}\n\n/// Checks that neither the global platform nor the specific game is paused.\n/// Global pause takes precedence over game pause.\npub fn check_not_paused(global_paused: bool, game_paused: bool) -> Result<()> {\n    if global_paused {\n        return Err(PauseError::PlatformPaused.into());\n    }\n    if game_paused {\n        return Err(PauseError::GamePaused.into());\n    }\n    Ok(())\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn both_unpaused_ok() {\n        assert!(check_not_paused(false, false).is_ok());\n    }\n\n    #[test]\n    fn global_paused_returns_platform_paused() {\n        let err = check_not_paused(true, false).unwrap_err();\n        assert!(err.to_string().contains(\"PlatformPaused\"));\n    }\n\n    #[test]\n    fn game_paused_returns_game_paused() {\n        let err = check_not_paused(false, true).unwrap_err();\n        assert!(err.to_string().contains(\"GamePaused\"));\n    }\n\n    #[test]\n    fn both_paused_returns_platform_paused_precedence() {\n        let err = check_not_paused(true, true).unwrap_err();\n        assert!(err.to_string().contains(\"PlatformPaused\"));\n    }\n}\n","numLines":50,"startLine":1,"totalLines":50}}}
