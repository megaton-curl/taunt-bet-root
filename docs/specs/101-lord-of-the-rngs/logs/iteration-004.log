r(context, new Wallet(player2));\n  const player2Program = new Program<Lordofrngs>(IDL, player2Provider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n\n  return {\n    context,\n    creator,\n    treasury,\n    creatorProgram,\n    configPda,\n    player2,\n    player2Program,\n  };\n}","originalFile":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { AnchorError, Program } from \"@coral-xyz/anchor\";\nimport { Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Lordofrngs } from \"../target/types/lordofrngs\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\nimport BN from \"bn.js\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\n// Tier constants (from shared crate)\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getRoundPda(tier: number, roundNumber: number | bigint): PublicKey {\n  const tierBuf = Buffer.from([tier]);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Test context factory\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  treasury: Keypair;\n  creatorProgram: Program<Lordofrngs>;\n  configPda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const treasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: treasury.publicKey, info: fundedAccountData() },\n  ]);\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n\n  return {\n    context,\n    creator,\n    treasury,\n    creatorProgram,\n    configPda,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Instruction helpers\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createRound(\n  t: TestContext,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n  creator?: PublicKey,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await t.creatorProgram.methods\n    .createRound(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      creator: creator ?? t.creator,\n      config: t.configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\ndescribe(\"lordofrngs\", () => {\n  describe(\"initialize_config\", () => {\n    it(\"creates config with treasury and paused=false\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.lordConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n      expect(config.paused).to.equal(false);\n      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n    });\n  });\n\n  describe(\"create_round\", () => {\n    it(\"creates round with correct PDA data and escrow balance\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Verify round state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.tier).to.equal(TIER_IRON);\n      expect(round.roundNumber.toNumber()).to.equal(0);\n      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n      expect(round.players).to.have.length(1);\n      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.players[0].entries).to.equal(1);\n      expect(round.totalEntries).to.equal(1);\n      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n      expect(round.lockedAt.toNumber()).to.equal(0);\n      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.claimed).to.equal(false);\n\n      // Verify escrow balance: account holds rent + entry amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n\n      // Verify config round counter incremented\n      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n    });\n\n    it(\"creates round with multiple entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const numEntries = 5;\n      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[0].entries).to.equal(numEntries);\n      expect(round.totalEntries).to.equal(numEntries);\n\n      // Escrow should hold numEntries × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n    });\n\n    it(\"increments round counter per tier\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Create first round (round 0)\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Config counter should be 1\n      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n\n      // Create second round (round 1) — need a new PDA\n      await createRound(t, TIER_IRON, 1, 1);\n\n      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n    });\n\n    it(\"rejects invalid tier (tier 6)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const invalidTier = 6;\n      const roundPda = getRoundPda(invalidTier, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(invalidTier, new BN(0), 1)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n        // PDA derivation time, resulting in an Anchor error\n        expect(err).to.be.instanceOf(Error);\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = getRoundPda(TIER_IRON, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(TIER_IRON, new BN(0), 0)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n});\n","structuredPatch":[{"oldStart":67,"oldLines":18,"newStart":67,"newLines":25,"lines":["   treasury: Keypair;","   creatorProgram: Program<Lordofrngs>;","   configPda: PublicKey;","+  player2: Keypair;","+  player2Program: Program<Lordofrngs>;"," }"," "," async function createTestContext(): Promise<TestContext> {","   const treasury = Keypair.generate();","+  const player2 = Keypair.generate();"," ","   const context = await startAnchor(\"./\", [], [","     { address: treasury.publicKey, info: fundedAccountData() },","+    { address: player2.publicKey, info: fundedAccountData() },","   ]);"," ","   const creatorProvider = new BankrunProvider(context);","   const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);"," ","+  const player2Provider = new BankrunProvider(context, new Wallet(player2));","+  const player2Program = new Program<Lordofrngs>(IDL, player2Provider);","+","   const creator = creatorProvider.wallet.publicKey;","   const configPda = getConfigPda();"," "]},{"oldStart":88,"oldLines":6,"newStart":95,"newLines":8,"lines":["     treasury,","     creatorProgram,","     configPda,","+    player2,","+    player2Program,","   };"," }"," "]}],"userModified":false,"replaceAll":false}}
