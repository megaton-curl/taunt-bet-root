{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01V1oVJyX2U8wabGJ8aGXVgy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Gqz9oW8AMw6enmGg1YJfoK","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/lordofrngs/src/instructions/join_round.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_to_pda;\nuse rng_shared::lifecycle::RoundPhase;\nuse rng_shared::pause::check_not_paused;\n\nuse crate::error::LordError;\nuse crate::state::{JackpotRound, LordConfig, PlayerEntry, MAX_PLAYERS};\n\n/// Countdown duration in seconds (60s).\nconst COUNTDOWN_SECONDS: i64 = 60;\n\n/// A new player joins an existing round.\n#[derive(Accounts)]\n#[instruction(tier: u8, round_number: u64)]\npub struct JoinRound<'info> {\n    /// The player joining the round. Signs and pays entry cost.\n    #[account(mut)]\n    pub player: Signer<'info>,\n\n    /// Global config PDA (read-only — we only check paused).\n    #[account(\n        seeds = [b\"lord_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, LordConfig>,\n\n    /// The round PDA to join.\n    #[account(\n        mut,\n        seeds = [\n            b\"jackpot_round\",\n            tier.to_le_bytes().as_ref(),\n            round_number.to_le_bytes().as_ref(),\n        ],\n        bump = round.bump,\n    )]\n    pub round: Account<'info, JackpotRound>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<JoinRound>, _tier: u8, _round_number: u64, num_entries: u32) -> Result<()> {\n    // Pause check\n    check_not_paused(false, ctx.accounts.config.paused)?;\n\n    let round = &ctx.accounts.round;\n\n    // Phase must be Waiting or Active (countdown)\n    require!(\n        round.phase == RoundPhase::Waiting || round.phase == RoundPhase::Active,\n        LordError::InvalidPhase\n    );\n\n    // Must buy at least one entry\n    require!(num_entries > 0, LordError::ZeroEntries);\n\n    // Player must not already be in the round\n    let player_key = ctx.accounts.player.key();\n    let already_in = round.players.iter().any(|p| p.player == player_key);\n    require!(!already_in, LordError::PlayerAlreadyInRound);\n\n    // Max players check\n    require!(round.players.len() < MAX_PLAYERS, LordError::MaxPlayersReached);\n\n    // Calculate cost\n    let entry_amount = round.entry_amount;\n    let total_cost = entry_amount\n        .checked_mul(num_entries as u64)\n        .ok_or(LordError::ArithmeticOverflow)?;\n\n    // Transfer lamports to round PDA (escrow)\n    transfer_lamports_to_pda(\n        &ctx.accounts.player.to_account_info(),\n        &ctx.accounts.round.to_account_info(),\n        total_cost,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    // Update round state\n    let round = &mut ctx.accounts.round;\n\n    round.players.push(PlayerEntry {\n        player: player_key,\n        entries: num_entries,\n    });\n    round.total_entries = round\n        .total_entries\n        .checked_add(num_entries)\n        .ok_or(LordError::ArithmeticOverflow)?;\n\n    // If this is the 2nd unique player, transition Waiting → Active and start countdown\n    if round.phase == RoundPhase::Waiting && round.players.len() == 2 {\n        let now = Clock::get()?.unix_timestamp;\n        round.phase = RoundPhase::Active;\n        round.countdown_ends_at = now + COUNTDOWN_SECONDS;\n    }\n\n    Ok(())\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":12043,"cache_read_input_tokens":45745,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":12043},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eb09418b-9a05-47a7-9018-08de1043e41d","uuid":"5a56fa99-8a9d-4865-9c8b-dd682285f171"}
