ound: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n        // PDA derivation time, resulting in an Anchor error\n        expect(err).to.be.instanceOf(Error);\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = getRoundPda(TIER_IRON, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(TIER_IRON, new BN(0), 0)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n});\n","structuredPatch":[{"oldStart":134,"oldLines":6,"newStart":134,"newLines":27,"lines":["   return roundPda;"," }"," ","+async function joinRound(","+  program: Program<Lordofrngs>,","+  player: PublicKey,","+  configPda: PublicKey,","+  tier = TIER_IRON,","+  roundNumber = 0,","+  numEntries = 1,","+) {","+  const roundPda = getRoundPda(tier, roundNumber);","+  await program.methods","+    .joinRound(tier, new BN(roundNumber), numEntries)","+    .accounts({","+      player,","+      config: configPda,","+      round: roundPda,","+      systemProgram: SystemProgram.programId,","+    })","+    .rpc();","+  return roundPda;","+}","+"," // ---------------------------------------------------------------------------"," // Tests"," // ---------------------------------------------------------------------------"]}],"userModified":false,"replaceAll":false}}
