{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NraoiG7HauKEAxPQB2kPN3","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_to_pda;\n     3→use rng_shared::lifecycle::RoundPhase;\n     4→use rng_shared::pause::check_not_paused;\n     5→use rng_shared::tiers::get_tier_amount;\n     6→\n     7→use crate::error::LordError;\n     8→use crate::state::{JackpotRound, LordConfig, PlayerEntry};\n     9→\n    10→#[derive(Accounts)]\n    11→#[instruction(tier: u8, round_number: u64)]\n    12→pub struct CreateRound<'info> {\n    13→    /// The player creating the round. Signs and pays rent + first entry.\n    14→    #[account(mut)]\n    15→    pub creator: Signer<'info>,\n    16→\n    17→    /// Global config PDA (mutable — we increment the round counter).\n    18→    #[account(\n    19→        mut,\n    20→        seeds = [b\"lord_config\"],\n    21→        bump = config.bump,\n    22→    )]\n    23→    pub config: Account<'info, LordConfig>,\n    24→\n    25→    /// The round PDA. Seeds: [b\"jackpot_round\", tier (1 byte), round_number (8 bytes LE)]\n    26→    #[account(\n    27→        init,\n    28→        payer = creator,\n    29→        space = 8 + JackpotRound::INIT_SPACE,\n    30→        seeds = [\n    31→            b\"jackpot_round\",\n    32→            tier.to_le_bytes().as_ref(),\n    33→            round_number.to_le_bytes().as_ref(),\n    34→        ],\n    35→        bump,\n    36→    )]\n    37→    pub round: Account<'info, JackpotRound>,\n    38→\n    39→    pub system_program: Program<'info, System>,\n    40→}\n    41→\n    42→pub fn handler(ctx: Context<CreateRound>, tier: u8, round_number: u64, num_entries: u32) -> Result<()> {\n    43→    // Pause check\n    44→    check_not_paused(false, ctx.accounts.config.paused)?;\n    45→\n    46→    // Validate tier\n    47→    let entry_amount = get_tier_amount(tier).map_err(|_| LordError::InvalidTier)?;\n    48→\n    49→    // Must buy at least one entry\n    50→    require!(num_entries > 0, LordError::ZeroEntries);\n    51→\n    52→    // Validate round_number matches current counter for this tier\n    53→    let expected_round = ctx.accounts.config.round_counters[tier as usize];\n    54→    require!(round_number == expected_round, LordError::InvalidPhase);\n    55→\n    56→    // Total cost = entry_amount × num_entries\n    57→    let total_cost = entry_amount\n    58→        .checked_mul(num_entries as u64)\n    59→        .ok_or(LordError::ArithmeticOverflow)?;\n    60→\n    61→    // Transfer lamports to round PDA (escrow)\n    62→    transfer_lamports_to_pda(\n    63→        &ctx.accounts.creator.to_account_info(),\n    64→        &ctx.accounts.round.to_account_info(),\n    65→        total_cost,\n    66→        &ctx.accounts.system_program.to_account_info(),\n    67→    )?;\n    68→\n    69→    let now = Clock::get()?.unix_timestamp;\n    70→\n    71→    // Increment the round counter for this tier\n    72→    ctx.accounts.config.round_counters[tier as usize] = round_number\n    73→        .checked_add(1)\n    74→        .ok_or(LordError::ArithmeticOverflow)?;\n    75→\n    76→    // Initialize round state\n    77→    let round = &mut ctx.accounts.round;\n    78→    round.tier = tier;\n    79→    round.round_number = round_number;\n    80→    round.entry_amount = entry_amount;\n    81→    round.phase = RoundPhase::Waiting;\n    82→    round.players = vec![PlayerEntry {\n    83→        player: ctx.accounts.creator.key(),\n    84→        entries: num_entries,\n    85→    }];\n    86→    round.total_entries = num_entries;\n    87→    round.created_at = now;\n    88→    round.countdown_ends_at = 0;\n    89→    round.locked_at = 0;\n    90→    round.resolve_deadline = 0;\n    91→    round.vrf_request_key = Pubkey::default();\n    92→    round.winning_slot = 0;\n    93→    round.winner = Pubkey::default();\n    94→    round.claimed = false;\n    95→    round.creator = ctx.accounts.creator.key();\n    96→    round.bump = ctx.bumps.round;\n    97→\n    98→    Ok(())\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_01YMpfctjCdGaz8ZewoR1JaU","session_id":"eb09418b-9a05-47a7-9018-08de1043e41d","uuid":"9eacbad9-6afe-412a-85f0-a635c7db859c"}
