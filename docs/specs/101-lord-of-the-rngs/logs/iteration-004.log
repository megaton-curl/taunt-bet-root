{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MwL4nKfpmrTXS81Lbp9sLy","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { AnchorError, Program } from \"@coral-xyz/anchor\";\n     5→import {\n     6→  Keypair,\n     7→  PublicKey,\n     8→  SystemProgram,\n     9→  LAMPORTS_PER_SOL,\n    10→} from \"@solana/web3.js\";\n    11→import type { Lordofrngs } from \"../target/types/lordofrngs\";\n    12→import { readFileSync } from \"fs\";\n    13→import { dirname, join } from \"path\";\n    14→import { fileURLToPath } from \"url\";\n    15→import BN from \"bn.js\";\n    16→\n    17→const __filename = fileURLToPath(import.meta.url);\n    18→const __dirname = dirname(__filename);\n    19→\n    20→const IDL = JSON.parse(\n    21→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n    22→);\n    23→const PROGRAM_ID = new PublicKey(IDL.address);\n    24→\n    25→// Tier constants (from shared crate)\n    26→const TIER_IRON = 0;\n    27→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n    28→\n    29→// ---------------------------------------------------------------------------\n    30→// PDA helpers\n    31→// ---------------------------------------------------------------------------\n    32→function getConfigPda(): PublicKey {\n    33→  const [pda] = PublicKey.findProgramAddressSync(\n    34→    [Buffer.from(\"lord_config\")],\n    35→    PROGRAM_ID\n    36→  );\n    37→  return pda;\n    38→}\n    39→\n    40→function getRoundPda(tier: number, roundNumber: number | bigint): PublicKey {\n    41→  const tierBuf = Buffer.from([tier]);\n    42→  const roundBuf = Buffer.alloc(8);\n    43→  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n    44→  const [pda] = PublicKey.findProgramAddressSync(\n    45→    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    46→    PROGRAM_ID\n    47→  );\n    48→  return pda;\n    49→}\n    50→\n    51→// ---------------------------------------------------------------------------\n    52→// Test context factory\n    53→// ---------------------------------------------------------------------------\n    54→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n    55→  return {\n    56→    lamports,\n    57→    data: Buffer.alloc(0),\n    58→    owner: SystemProgram.programId,\n    59→    executable: false,\n    60→  };\n    61→}\n    62→\n    63→interface TestContext {\n    64→  context: Awaited<ReturnType<typeof startAnchor>>;\n    65→  creator: PublicKey;\n    66→  treasury: Keypair;\n    67→  creatorProgram: Program<Lordofrngs>;\n    68→  configPda: PublicKey;\n    69→}\n    70→\n    71→async function createTestContext(): Promise<TestContext> {\n    72→  const treasury = Keypair.generate();\n    73→\n    74→  const context = await startAnchor(\"./\", [], [\n    75→    { address: treasury.publicKey, info: fundedAccountData() },\n    76→  ]);\n    77→\n    78→  const creatorProvider = new BankrunProvider(context);\n    79→  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n    80→\n    81→  const creator = creatorProvider.wallet.publicKey;\n    82→  const configPda = getConfigPda();\n    83→\n    84→  return {\n    85→    context,\n    86→    creator,\n    87→    treasury,\n    88→    creatorProgram,\n    89→    configPda,\n    90→  };\n    91→}\n    92→\n    93→// ---------------------------------------------------------------------------\n    94→// Instruction helpers\n    95→// ---------------------------------------------------------------------------\n    96→async function initConfig(t: TestContext) {\n    97→  await t.creatorProgram.methods\n    98→    .initializeConfig(t.treasury.publicKey)\n    99→    .accounts({\n   100→      authority: t.creator,\n   101→      config: t.configPda,\n   102→      systemProgram: SystemProgram.programId,\n   103→    })\n   104→    .rpc();\n   105→}\n   106→\n   107→async function createRound(\n   108→  t: TestContext,\n   109→  tier = TIER_IRON,\n   110→  roundNumber = 0,\n   111→  numEntries = 1,\n   112→  creator?: PublicKey,\n   113→) {\n   114→  const roundPda = getRoundPda(tier, roundNumber);\n   115→  await t.creatorProgram.methods\n   116→    .createRound(tier, new BN(roundNumber), numEntries)\n   117→    .accounts({\n   118→      creator: creator ?? t.creator,\n   119→      config: t.configPda,\n   120→      round: roundPda,\n   121→      systemProgram: SystemProgram.programId,\n   122→    })\n   123→    .rpc();\n   124→  return roundPda;\n   125→}\n   126→\n   127→// ---------------------------------------------------------------------------\n   128→// Tests\n   129→// ---------------------------------------------------------------------------\n   130→describe(\"lordofrngs\", () => {\n   131→  describe(\"initialize_config\", () => {\n   132→    it(\"creates config with treasury and paused=false\", async () => {\n   133→      const t = await createTestContext();\n   134→      await initConfig(t);\n   135→\n   136→      const config = await t.creatorProgram.account.lordConfig.fetch(\n   137→        t.configPda\n   138→      );\n   139→      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n   140→      expect(config.treasury.toBase58()).to.equal(\n   141→        t.treasury.publicKey.toBase58()\n   142→      );\n   143→      expect(config.paused).to.equal(false);\n   144→      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n   145→    });\n   146→  });\n   147→\n   148→  describe(\"create_round\", () => {\n   149→    it(\"creates round with correct PDA data and escrow balance\", async () => {\n   150→      const t = await createTestContext();\n   151→      await initConfig(t);\n   152→\n   153→      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n   154→\n   155→      // Verify round state\n   156→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   157→      expect(round.tier).to.equal(TIER_IRON);\n   158→      expect(round.roundNumber.toNumber()).to.equal(0);\n   159→      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   160→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n   161→      expect(round.players).to.have.length(1);\n   162→      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n   163→      expect(round.players[0].entries).to.equal(1);\n   164→      expect(round.totalEntries).to.equal(1);\n   165→      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n   166→      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n   167→      expect(round.lockedAt.toNumber()).to.equal(0);\n   168→      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n   169→      expect(round.claimed).to.equal(false);\n   170→\n   171→      // Verify escrow balance: account holds rent + entry amount\n   172→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   173→      const rent = await t.context.banksClient.getRent();\n   174→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   175→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   176→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n   177→\n   178→      // Verify config round counter incremented\n   179→      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   180→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n   181→    });\n   182→\n   183→    it(\"creates round with multiple entries\", async () => {\n   184→      const t = await createTestContext();\n   185→      await initConfig(t);\n   186→\n   187→      const numEntries = 5;\n   188→      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n   189→\n   190→      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n   191→      expect(round.players[0].entries).to.equal(numEntries);\n   192→      expect(round.totalEntries).to.equal(numEntries);\n   193→\n   194→      // Escrow should hold numEntries × entry_amount\n   195→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   196→      const rent = await t.context.banksClient.getRent();\n   197→      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n   198→      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n   199→      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n   200→    });\n   201→\n   202→    it(\"increments round counter per tier\", async () => {\n   203→      const t = await createTestContext();\n   204→      await initConfig(t);\n   205→\n   206→      // Create first round (round 0)\n   207→      await createRound(t, TIER_IRON, 0, 1);\n   208→\n   209→      // Config counter should be 1\n   210→      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   211→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n   212→\n   213→      // Create second round (round 1) — need a new PDA\n   214→      await createRound(t, TIER_IRON, 1, 1);\n   215→\n   216→      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n   217→      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n   218→    });\n   219→\n   220→    it(\"rejects invalid tier (tier 6)\", async () => {\n   221→      const t = await createTestContext();\n   222→      await initConfig(t);\n   223→\n   224→      const invalidTier = 6;\n   225→      const roundPda = getRoundPda(invalidTier, 0);\n   226→\n   227→      try {\n   228→        await t.creatorProgram.methods\n   229→          .createRound(invalidTier, new BN(0), 1)\n   230→          .accounts({\n   231→            creator: t.creator,\n   232→            config: t.configPda,\n   233→            round: roundPda,\n   234→            systemProgram: SystemProgram.programId,\n   235→          })\n   236→          .rpc();\n   237→        expect.fail(\"Expected InvalidTier error\");\n   238→      } catch (err) {\n   239→        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n   240→        // PDA derivation time, resulting in an Anchor error\n   241→        expect(err).to.be.instanceOf(Error);\n   242→      }\n   243→    });\n   244→\n   245→    it(\"rejects zero entries\", async () => {\n   246→      const t = await createTestContext();\n   247→      await initConfig(t);\n   248→\n   249→      const roundPda = getRoundPda(TIER_IRON, 0);\n   250→\n   251→      try {\n   252→        await t.creatorProgram.methods\n   253→          .createRound(TIER_IRON, new BN(0), 0)\n   254→          .accounts({\n   255→            creator: t.creator,\n   256→            config: t.configPda,\n   257→            round: roundPda,\n   258→            systemProgram: SystemProgram.programId,\n   259→          })\n   260→          .rpc();\n   261→        expect.fail(\"Expected ZeroEntries error\");\n   262→      } catch (err) {\n   263→        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n   264→      }\n   265→    });\n   266→  });\n   267→});\n   268→"}]},"parent_tool_use_id":null,"session_id":"eb09418b-9a05-47a7-9018-08de1043e41d","uuid":"0548afca-875e-4cee-bc01-a38dd91deef8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/lordofrngs.ts","content":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { AnchorError, Program } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Lordofrngs } from \"../target/types/lordofrngs\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\nimport BN from \"bn.js\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\n// Tier constants (from shared crate)\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getRoundPda(tier: number, roundNumber: number | bigint): PublicKey {\n  const tierBuf = Buffer.from([tier]);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Test context factory\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  treasury: Keypair;\n  creatorProgram: Program<Lordofrngs>;\n  configPda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const treasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: treasury.publicKey, info: fundedAccountData() },\n  ]);\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Lordofrngs>(IDL, creatorProvider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n\n  return {\n    context,\n    creator,\n    treasury,\n    creatorProgram,\n    configPda,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Instruction helpers\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createRound(\n  t: TestContext,\n  tier = TIER_IRON,\n  roundNumber = 0,\n  numEntries = 1,\n  creator?: PublicKey,\n) {\n  const roundPda = getRoundPda(tier, roundNumber);\n  await t.creatorProgram.methods\n    .createRound(tier, new BN(roundNumber), numEntries)\n    .accounts({\n      creator: creator ?? t.creator,\n      config: t.configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n  return roundPda;\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\ndescribe(\"lordofrngs\", () => {\n  describe(\"initialize_config\", () => {\n    it(\"creates config with treasury and paused=false\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.lordConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n      expect(config.paused).to.equal(false);\n      expect(config.roundCounters.map((n: any) => n.toNumber())).to.deep.equal([0, 0, 0, 0, 0, 0]);\n    });\n  });\n\n  describe(\"create_round\", () => {\n    it(\"creates round with correct PDA data and escrow balance\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = await createRound(t, TIER_IRON, 0, 1);\n\n      // Verify round state\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.tier).to.equal(TIER_IRON);\n      expect(round.roundNumber.toNumber()).to.equal(0);\n      expect(round.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ waiting: {} }));\n      expect(round.players).to.have.length(1);\n      expect(round.players[0].player.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.players[0].entries).to.equal(1);\n      expect(round.totalEntries).to.equal(1);\n      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n      expect(round.countdownEndsAt.toNumber()).to.equal(0);\n      expect(round.lockedAt.toNumber()).to.equal(0);\n      expect(round.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(round.claimed).to.equal(false);\n\n      // Verify escrow balance: account holds rent + entry amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT);\n\n      // Verify config round counter incremented\n      const config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n    });\n\n    it(\"creates round with multiple entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const numEntries = 5;\n      const roundPda = await createRound(t, TIER_IRON, 0, numEntries);\n\n      const round = await t.creatorProgram.account.jackpotRound.fetch(roundPda);\n      expect(round.players[0].entries).to.equal(numEntries);\n      expect(round.totalEntries).to.equal(numEntries);\n\n      // Escrow should hold numEntries × entry_amount\n      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n      const rent = await t.context.banksClient.getRent();\n      const minRent = Number(rent.minimumBalance(BigInt(roundAccount!.data.length)));\n      const escrowBalance = Number(roundAccount!.lamports) - minRent;\n      expect(escrowBalance).to.equal(TIER_IRON_AMOUNT * numEntries);\n    });\n\n    it(\"increments round counter per tier\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      // Create first round (round 0)\n      await createRound(t, TIER_IRON, 0, 1);\n\n      // Config counter should be 1\n      let config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(1);\n\n      // Create second round (round 1) — need a new PDA\n      await createRound(t, TIER_IRON, 1, 1);\n\n      config = await t.creatorProgram.account.lordConfig.fetch(t.configPda);\n      expect(config.roundCounters[TIER_IRON].toNumber()).to.equal(2);\n    });\n\n    it(\"rejects invalid tier (tier 6)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const invalidTier = 6;\n      const roundPda = getRoundPda(invalidTier, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(invalidTier, new BN(0), 1)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        // Tier 6 will cause an out-of-bounds access on round_counters[6] at\n        // PDA derivation time, resulting in an Anchor error\n        expect(err).to.be.instanceOf(Error);\n      }\n    });\n\n    it(\"rejects zero entries\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const roundPda = getRoundPda(TIER_IRON, 0);\n\n      try {\n        await t.creatorProgram.methods\n          .createRound(TIER_IRON, new BN(0), 0)\n          .accounts({\n            creator: t.creator,\n            config: t.configPda,\n            round: roundPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected ZeroEntries error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\"ZeroEntries\");\n      }\n    });\n  });\n});\n","numLines":268,"startLine":1,"totalLines":268}}}
