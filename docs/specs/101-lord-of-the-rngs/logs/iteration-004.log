{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rgqn4vrCXuDLRUnp6fZY49","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use crate::state::LordConfig;\n     3→\n     4→#[derive(Accounts)]\n     5→pub struct InitializeConfig<'info> {\n     6→    #[account(mut)]\n     7→    pub authority: Signer<'info>,\n     8→\n     9→    #[account(\n    10→        init,\n    11→        payer = authority,\n    12→        space = 8 + LordConfig::INIT_SPACE,\n    13→        seeds = [b\"lord_config\"],\n    14→        bump,\n    15→    )]\n    16→    pub config: Account<'info, LordConfig>,\n    17→\n    18→    pub system_program: Program<'info, System>,\n    19→}\n    20→\n    21→pub fn handler(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n    22→    let config = &mut ctx.accounts.config;\n    23→    config.authority = ctx.accounts.authority.key();\n    24→    config.treasury = treasury;\n    25→    config.paused = false;\n    26→    config.round_counters = [0; 6];\n    27→    config.bump = ctx.bumps.config;\n    28→\n    29→    Ok(())\n    30→}\n    31→"}]},"parent_tool_use_id":"toolu_01YMpfctjCdGaz8ZewoR1JaU","session_id":"eb09418b-9a05-47a7-9018-08de1043e41d","uuid":"594bb299-6d10-4f27-8153-0668832a73a2"}
