{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TDc5gwug7Sn5mZBBeqmYiL","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::state::PlayerProfile;\n     4→\n     5→#[derive(Accounts)]\n     6→#[instruction(wager_amount: u64, won_amount: u64, is_winner: bool)]\n     7→pub struct UpdatePlayerProfile<'info> {\n     8→    /// The game program (coinflip) calling via CPI.\n     9→    pub caller: Signer<'info>,\n    10→\n    11→    /// The player profile PDA to update.\n    12→    #[account(\n    13→        mut,\n    14→        seeds = [b\"player_profile\", profile.authority.as_ref()],\n    15→        bump = profile.bump,\n    16→    )]\n    17→    pub profile: Account<'info, PlayerProfile>,\n    18→}\n    19→\n    20→pub fn handler(\n    21→    ctx: Context<UpdatePlayerProfile>,\n    22→    wager_amount: u64,\n    23→    won_amount: u64,\n    24→    is_winner: bool,\n    25→) -> Result<()> {\n    26→    let profile = &mut ctx.accounts.profile;\n    27→    profile.total_games = profile.total_games.checked_add(1).unwrap();\n    28→    profile.total_wagered = profile.total_wagered.checked_add(wager_amount).unwrap();\n    29→    if is_winner {\n    30→        profile.wins = profile.wins.checked_add(1).unwrap();\n    31→        profile.total_won = profile.total_won.checked_add(won_amount).unwrap();\n    32→    }\n    33→    Ok(())\n    34→}\n    35→"}]},"parent_tool_use_id":null,"session_id":"620a91a2-2b9d-4fb9-a12b-278d05c0289f","uuid":"91bf5ef8-6879-4abe-be80-ae9848674fc2","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/platform/src/instructions/update_player_profile.rs","content":"use anchor_lang::prelude::*;\n\nuse crate::state::PlayerProfile;\n\n#[derive(Accounts)]\n#[instruction(wager_amount: u64, won_amount: u64, is_winner: bool)]\npub struct UpdatePlayerProfile<'info> {\n    /// The game program (coinflip) calling via CPI.\n    pub caller: Signer<'info>,\n\n    /// The player profile PDA to update.\n    #[account(\n        mut,\n        seeds = [b\"player_profile\", profile.authority.as_ref()],\n        bump = profile.bump,\n    )]\n    pub profile: Account<'info, PlayerProfile>,\n}\n\npub fn handler(\n    ctx: Context<UpdatePlayerProfile>,\n    wager_amount: u64,\n    won_amount: u64,\n    is_winner: bool,\n) -> Result<()> {\n    let profile = &mut ctx.accounts.profile;\n    profile.total_games = profile.total_games.checked_add(1).unwrap();\n    profile.total_wagered = profile.total_wagered.checked_add(wager_amount).unwrap();\n    if is_winner {\n        profile.wins = profile.wins.checked_add(1).unwrap();\n        profile.total_won = profile.total_won.checked_add(won_amount).unwrap();\n    }\n    Ok(())\n}\n","numLines":35,"startLine":1,"totalLines":35}}}
