{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J5GPxGnspeLHNDRVgkrtcj","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { Program, Wallet } from \"@coral-xyz/anchor\";\n     5→import {\n     6→  Keypair,\n     7→  PublicKey,\n     8→  SystemProgram,\n     9→} from \"@solana/web3.js\";\n    10→import type { Platform } from \"../target/types/platform\";\n    11→import { readFileSync } from \"fs\";\n    12→import { dirname, join } from \"path\";\n    13→import { fileURLToPath } from \"url\";\n    14→\n    15→const __filename = fileURLToPath(import.meta.url);\n    16→const __dirname = dirname(__filename);\n    17→\n    18→const IDL = JSON.parse(\n    19→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    20→);\n    21→const PROGRAM_ID = new PublicKey(IDL.address);\n    22→\n    23→const TOTAL_FEE_BPS = 300;\n    24→\n    25→// ---------------------------------------------------------------------------\n    26→// PDA helpers\n    27→// ---------------------------------------------------------------------------\n    28→function getConfigPda(): PublicKey {\n    29→  const [pda] = PublicKey.findProgramAddressSync(\n    30→    [Buffer.from(\"platform_config\")],\n    31→    PROGRAM_ID\n    32→  );\n    33→  return pda;\n    34→}\n    35→\n    36→function getPlayerProfilePda(wallet: PublicKey): PublicKey {\n    37→  const [pda] = PublicKey.findProgramAddressSync(\n    38→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    39→    PROGRAM_ID\n    40→  );\n    41→  return pda;\n    42→}\n    43→\n    44→// ---------------------------------------------------------------------------\n    45→// Bankrun context factory\n    46→// ---------------------------------------------------------------------------\n    47→interface TestContext {\n    48→  context: Awaited<ReturnType<typeof startAnchor>>;\n    49→  authority: PublicKey;\n    50→  treasury: Keypair;\n    51→  authorityProgram: Program<Platform>;\n    52→  configPda: PublicKey;\n    53→}\n    54→\n    55→async function createTestContext(): Promise<TestContext> {\n    56→  const treasury = Keypair.generate();\n    57→\n    58→  const context = await startAnchor(\"./\", [], []);\n    59→\n    60→  const authorityProvider = new BankrunProvider(context);\n    61→  const authorityProgram = new Program<Platform>(IDL, authorityProvider);\n    62→\n    63→  const authority = authorityProvider.wallet.publicKey;\n    64→  const configPda = getConfigPda();\n    65→\n    66→  return {\n    67→    context,\n    68→    authority,\n    69→    treasury,\n    70→    authorityProgram,\n    71→    configPda,\n    72→  };\n    73→}\n    74→\n    75→// ---------------------------------------------------------------------------\n    76→// Helpers\n    77→// ---------------------------------------------------------------------------\n    78→async function initPlatform(t: TestContext) {\n    79→  await t.authorityProgram.methods\n    80→    .initializePlatform(t.treasury.publicKey)\n    81→    .accounts({\n    82→      authority: t.authority,\n    83→      config: t.configPda,\n    84→      systemProgram: SystemProgram.programId,\n    85→    })\n    86→    .rpc();\n    87→}\n    88→\n    89→// ===========================================================================\n    90→// Tests\n    91→// ===========================================================================\n    92→describe(\"platform\", () => {\n    93→  // -------------------------------------------------------------------------\n    94→  // initialize_platform\n    95→  // -------------------------------------------------------------------------\n    96→  describe(\"initialize_platform\", () => {\n    97→    it(\"creates config with authority, treasury, and fee_bps\", async () => {\n    98→      const t = await createTestContext();\n    99→      await initPlatform(t);\n   100→\n   101→      const config = await t.authorityProgram.account.platformConfig.fetch(\n   102→        t.configPda\n   103→      );\n   104→      expect(config.authority.toBase58()).to.equal(t.authority.toBase58());\n   105→      expect(config.treasury.toBase58()).to.equal(\n   106→        t.treasury.publicKey.toBase58()\n   107→      );\n   108→      expect(config.feeBps).to.equal(TOTAL_FEE_BPS);\n   109→    });\n   110→\n   111→    it(\"rejects double initialization\", async () => {\n   112→      const t = await createTestContext();\n   113→      await initPlatform(t);\n   114→\n   115→      try {\n   116→        await initPlatform(t);\n   117→        expect.fail(\"Expected error on double init\");\n   118→      } catch (err) {\n   119→        // PDA already exists → anchor constraint error\n   120→        expect(err).to.exist;\n   121→      }\n   122→    });\n   123→  });\n   124→\n   125→  // -------------------------------------------------------------------------\n   126→  // create_player_profile\n   127→  // -------------------------------------------------------------------------\n   128→  describe(\"create_player_profile\", () => {\n   129→    it(\"creates a player profile with zeroed stats\", async () => {\n   130→      const t = await createTestContext();\n   131→      const profilePda = getPlayerProfilePda(t.authority);\n   132→\n   133→      await t.authorityProgram.methods\n   134→        .createPlayerProfile()\n   135→        .accounts({\n   136→          player: t.authority,\n   137→          profile: profilePda,\n   138→          systemProgram: SystemProgram.programId,\n   139→        })\n   140→        .rpc();\n   141→\n   142→      const profile = await t.authorityProgram.account.playerProfile.fetch(\n   143→        profilePda\n   144→      );\n   145→      expect(profile.authority.toBase58()).to.equal(t.authority.toBase58());\n   146→      expect(profile.totalGames.toNumber()).to.equal(0);\n   147→      expect(profile.wins.toNumber()).to.equal(0);\n   148→      expect(profile.totalWagered.toNumber()).to.equal(0);\n   149→      expect(profile.totalWon.toNumber()).to.equal(0);\n   150→    });\n   151→\n   152→    it(\"different wallets get different profiles\", async () => {\n   153→      const t = await createTestContext();\n   154→\n   155→      // Authority creates their profile\n   156→      const authorityProfilePda = getPlayerProfilePda(t.authority);\n   157→      await t.authorityProgram.methods\n   158→        .createPlayerProfile()\n   159→        .accounts({\n   160→          player: t.authority,\n   161→          profile: authorityProfilePda,\n   162→          systemProgram: SystemProgram.programId,\n   163→        })\n   164→        .rpc();\n   165→\n   166→      // Second player creates their profile\n   167→      const player2 = Keypair.generate();\n   168→      t.context.setAccount(player2.publicKey, {\n   169→        lamports: 10_000_000_000,\n   170→        data: Buffer.alloc(0),\n   171→        owner: SystemProgram.programId,\n   172→        executable: false,\n   173→      });\n   174→      const player2Provider = new BankrunProvider(\n   175→        t.context,\n   176→        new Wallet(player2)\n   177→      );\n   178→      const player2Program = new Program<Platform>(IDL, player2Provider);\n   179→      const player2ProfilePda = getPlayerProfilePda(player2.publicKey);\n   180→\n   181→      await player2Program.methods\n   182→        .createPlayerProfile()\n   183→        .accounts({\n   184→          player: player2.publicKey,\n   185→          profile: player2ProfilePda,\n   186→          systemProgram: SystemProgram.programId,\n   187→        })\n   188→        .rpc();\n   189→\n   190→      const profile1 = await t.authorityProgram.account.playerProfile.fetch(\n   191→        authorityProfilePda\n   192→      );\n   193→      const profile2 = await t.authorityProgram.account.playerProfile.fetch(\n   194→        player2ProfilePda\n   195→      );\n   196→\n   197→      expect(profile1.authority.toBase58()).to.equal(t.authority.toBase58());\n   198→      expect(profile2.authority.toBase58()).to.equal(\n   199→        player2.publicKey.toBase58()\n   200→      );\n   201→    });\n   202→\n   203→    it(\"rejects double profile creation\", async () => {\n   204→      const t = await createTestContext();\n   205→      const profilePda = getPlayerProfilePda(t.authority);\n   206→\n   207→      await t.authorityProgram.methods\n   208→        .createPlayerProfile()\n   209→        .accounts({\n   210→          player: t.authority,\n   211→          profile: profilePda,\n   212→          systemProgram: SystemProgram.programId,\n   213→        })\n   214→        .rpc();\n   215→\n   216→      try {\n   217→        await t.authorityProgram.methods\n   218→          .createPlayerProfile()\n   219→          .accounts({\n   220→            player: t.authority,\n   221→            profile: profilePda,\n   222→            systemProgram: SystemProgram.programId,\n   223→          })\n   224→          .rpc();\n   225→        expect.fail(\"Expected error on double creation\");\n   226→      } catch (err) {\n   227→        // PDA already exists → anchor constraint error\n   228→        expect(err).to.exist;\n   229→      }\n   230→    });\n   231→  });\n   232→});\n   233→"}]},"parent_tool_use_id":null,"session_id":"620a91a2-2b9d-4fb9-a12b-278d05c0289f","uuid":"95f45bc0-7546-4f91-81be-f32efd9032ab","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/platform.ts","content":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { Program, Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n} from \"@solana/web3.js\";\nimport type { Platform } from \"../target/types/platform\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\nconst TOTAL_FEE_BPS = 300;\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlayerProfilePda(wallet: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Bankrun context factory\n// ---------------------------------------------------------------------------\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  authority: PublicKey;\n  treasury: Keypair;\n  authorityProgram: Program<Platform>;\n  configPda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const treasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], []);\n\n  const authorityProvider = new BankrunProvider(context);\n  const authorityProgram = new Program<Platform>(IDL, authorityProvider);\n\n  const authority = authorityProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n\n  return {\n    context,\n    authority,\n    treasury,\n    authorityProgram,\n    configPda,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\nasync function initPlatform(t: TestContext) {\n  await t.authorityProgram.methods\n    .initializePlatform(t.treasury.publicKey)\n    .accounts({\n      authority: t.authority,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\n// ===========================================================================\n// Tests\n// ===========================================================================\ndescribe(\"platform\", () => {\n  // -------------------------------------------------------------------------\n  // initialize_platform\n  // -------------------------------------------------------------------------\n  describe(\"initialize_platform\", () => {\n    it(\"creates config with authority, treasury, and fee_bps\", async () => {\n      const t = await createTestContext();\n      await initPlatform(t);\n\n      const config = await t.authorityProgram.account.platformConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.authority.toBase58());\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n      expect(config.feeBps).to.equal(TOTAL_FEE_BPS);\n    });\n\n    it(\"rejects double initialization\", async () => {\n      const t = await createTestContext();\n      await initPlatform(t);\n\n      try {\n        await initPlatform(t);\n        expect.fail(\"Expected error on double init\");\n      } catch (err) {\n        // PDA already exists → anchor constraint error\n        expect(err).to.exist;\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // create_player_profile\n  // -------------------------------------------------------------------------\n  describe(\"create_player_profile\", () => {\n    it(\"creates a player profile with zeroed stats\", async () => {\n      const t = await createTestContext();\n      const profilePda = getPlayerProfilePda(t.authority);\n\n      await t.authorityProgram.methods\n        .createPlayerProfile()\n        .accounts({\n          player: t.authority,\n          profile: profilePda,\n          systemProgram: SystemProgram.programId,\n        })\n        .rpc();\n\n      const profile = await t.authorityProgram.account.playerProfile.fetch(\n        profilePda\n      );\n      expect(profile.authority.toBase58()).to.equal(t.authority.toBase58());\n      expect(profile.totalGames.toNumber()).to.equal(0);\n      expect(profile.wins.toNumber()).to.equal(0);\n      expect(profile.totalWagered.toNumber()).to.equal(0);\n      expect(profile.totalWon.toNumber()).to.equal(0);\n    });\n\n    it(\"different wallets get different profiles\", async () => {\n      const t = await createTestContext();\n\n      // Authority creates their profile\n      const authorityProfilePda = getPlayerProfilePda(t.authority);\n      await t.authorityProgram.methods\n        .createPlayerProfile()\n        .accounts({\n          player: t.authority,\n          profile: authorityProfilePda,\n          systemProgram: SystemProgram.programId,\n        })\n        .rpc();\n\n      // Second player creates their profile\n      const player2 = Keypair.generate();\n      t.context.setAccount(player2.publicKey, {\n        lamports: 10_000_000_000,\n        data: Buffer.alloc(0),\n        owner: SystemProgram.programId,\n        executable: false,\n      });\n      const player2Provider = new BankrunProvider(\n        t.context,\n        new Wallet(player2)\n      );\n      const player2Program = new Program<Platform>(IDL, player2Provider);\n      const player2ProfilePda = getPlayerProfilePda(player2.publicKey);\n\n      await player2Program.methods\n        .createPlayerProfile()\n        .accounts({\n          player: player2.publicKey,\n          profile: player2ProfilePda,\n          systemProgram: SystemProgram.programId,\n        })\n        .rpc();\n\n      const profile1 = await t.authorityProgram.account.playerProfile.fetch(\n        authorityProfilePda\n      );\n      const profile2 = await t.authorityProgram.account.playerProfile.fetch(\n        player2ProfilePda\n      );\n\n      expect(profile1.authority.toBase58()).to.equal(t.authority.toBase58());\n      expect(profile2.authority.toBase58()).to.equal(\n        player2.publicKey.toBase58()\n      );\n    });\n\n    it(\"rejects double profile creation\", async () => {\n      const t = await createTestContext();\n      const profilePda = getPlayerProfilePda(t.authority);\n\n      await t.authorityProgram.methods\n        .createPlayerProfile()\n        .accounts({\n          player: t.authority,\n          profile: profilePda,\n          systemProgram: SystemProgram.programId,\n        })\n        .rpc();\n\n      try {\n        await t.authorityProgram.methods\n          .createPlayerProfile()\n          .accounts({\n            player: t.authority,\n            profile: profilePda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected error on double creation\");\n      } catch (err) {\n        // PDA already exists → anchor constraint error\n        expect(err).to.exist;\n      }\n    });\n  });\n});\n","numLines":233,"startLine":1,"totalLines":233}}}
