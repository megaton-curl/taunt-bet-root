{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0119oLUm88sZE4gPPzuMoPzC","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::from_randomness;\n     3→use rng_shared::escrow::transfer_lamports_from_pda;\n     4→use rng_shared::fees::calculate_net_payout;\n     5→use rng_shared::lifecycle::RoundPhase;\n     6→use rng_shared::vrf_orao::read_orao_randomness;\n     7→\n     8→use crate::error::CoinflipError;\n     9→use crate::state::{CoinflipConfig, CoinflipMatch, MatchSettled};\n    10→\n    11→#[derive(Accounts)]\n    12→pub struct ClaimPayout<'info> {\n    13→    /// Either the creator or opponent can trigger the claim.\n    14→    #[account(mut)]\n    15→    pub caller: Signer<'info>,\n    16→\n    17→    /// The match PDA (closed after claim — rent refunded to creator).\n    18→    #[account(\n    19→        mut,\n    20→        close = creator,\n    21→        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    22→        bump = coinflip_match.bump,\n    23→    )]\n    24→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    25→\n    26→    /// The config PDA (for treasury address + CPI signing).\n    27→    #[account(\n    28→        seeds = [b\"coinflip_config\"],\n    29→        bump = config.bump,\n    30→    )]\n    31→    pub config: Account<'info, CoinflipConfig>,\n    32→\n    33→    /// The treasury account to receive fees.\n    34→    /// CHECK: Validated against config.treasury in handler.\n    35→    #[account(mut)]\n    36→    pub treasury: AccountInfo<'info>,\n    37→\n    38→    /// The creator account (receives rent refund on close).\n    39→    /// CHECK: Validated against coinflip_match.creator in handler.\n    40→    #[account(mut)]\n    41→    pub creator: AccountInfo<'info>,\n    42→\n    43→    /// The opponent account.\n    44→    /// CHECK: Validated against coinflip_match.opponent in handler.\n    45→    #[account(mut)]\n    46→    pub opponent: AccountInfo<'info>,\n    47→\n    48→    /// The Orao randomness PDA — must match vrf_request_key stored on match.\n    49→    /// CHECK: Key validated against coinflip_match.vrf_request_key; data read by shared VRF helper.\n    50→    pub randomness_account: AccountInfo<'info>,\n    51→\n    52→    /// Creator's player profile PDA on the platform program.\n    53→    /// CHECK: Validated by platform program via CPI (if account exists).\n    54→    #[account(mut)]\n    55→    pub creator_profile: AccountInfo<'info>,\n    56→\n    57→    /// Opponent's player profile PDA on the platform program.\n    58→    /// CHECK: Validated by platform program via CPI (if account exists).\n    59→    #[account(mut)]\n    60→    pub opponent_profile: AccountInfo<'info>,\n    61→\n    62→    /// The platform program for CPI calls.\n    63→    pub platform_program: Program<'info, platform::program::Platform>,\n    64→\n    65→    pub system_program: Program<'info, System>,\n    66→}\n    67→\n    68→pub fn handler(ctx: Context<ClaimPayout>) -> Result<()> {\n    69→    let coinflip_match = &ctx.accounts.coinflip_match;\n    70→\n    71→    // (1) Must be in LOCKED phase and not already claimed\n    72→    require!(\n    73→        coinflip_match.phase == RoundPhase::Locked,\n    74→        CoinflipError::InvalidPhase\n    75→    );\n    76→    require!(!coinflip_match.claimed, CoinflipError::AlreadyClaimed);\n    77→\n    78→    // Caller must be either creator or opponent\n    79→    let caller = ctx.accounts.caller.key();\n    80→    require!(\n    81→        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n    82→        CoinflipError::UnauthorizedCaller\n    83→    );\n    84→\n    85→    // Validate accounts match stored state\n    86→    require!(\n    87→        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n    88→        CoinflipError::InvalidPhase\n    89→    );\n    90→    require!(\n    91→        ctx.accounts.creator.key() == coinflip_match.creator,\n    92→        CoinflipError::InvalidPhase\n    93→    );\n    94→    require!(\n    95→        ctx.accounts.opponent.key() == coinflip_match.opponent,\n    96→        CoinflipError::InvalidPhase\n    97→    );\n    98→    require!(\n    99→        ctx.accounts.randomness_account.key() == coinflip_match.vrf_request_key,\n   100→        CoinflipError::InvalidPhase\n   101→    );\n   102→\n   103→    // (2) Read Orao randomness — rejects if not fulfilled\n   104→    let randomness = read_orao_randomness(&ctx.accounts.randomness_account)?;\n   105→\n   106→    // (3) Derive winner from randomness\n   107→    let result = from_randomness(randomness[0]);\n   108→    let winner = if result == coinflip_match.creator_side {\n   109→        coinflip_match.creator\n   110→    } else {\n   111→        coinflip_match.opponent\n   112→    };\n   113→\n   114→    // (4) Compute fee/payout\n   115→    let pool = coinflip_match.entry_amount.checked_mul(2).unwrap();\n   116→    let (fee, payout) = calculate_net_payout(pool);\n   117→\n   118→    // (5) Transfer payout to winner + fee to treasury\n   119→    let match_info = ctx.accounts.coinflip_match.to_account_info();\n   120→    let winner_account = if winner == coinflip_match.creator {\n   121→        ctx.accounts.creator.to_account_info()\n   122→    } else {\n   123→        ctx.accounts.opponent.to_account_info()\n   124→    };\n   125→    transfer_lamports_from_pda(&match_info, &winner_account, payout)?;\n   126→    transfer_lamports_from_pda(&match_info, &ctx.accounts.treasury, fee)?;\n   127→\n   128→    // (6) CPI update both player profiles via shared helper\n   129→    let config_bump = ctx.accounts.config.bump;\n   130→    let signer_seeds: &[&[u8]] = &[b\"coinflip_config\", &[config_bump]];\n   131→\n   132→    let creator_is_winner = winner == coinflip_match.creator;\n   133→    rng_shared::cpi::update_player_profile_cpi(\n   134→        &ctx.accounts.platform_program.to_account_info(),\n   135→        &ctx.accounts.creator_profile,\n   136→        &ctx.accounts.config.to_account_info(),\n   137→        signer_seeds,\n   138→        1,\n   139→        if creator_is_winner { 1 } else { 0 },\n   140→        coinflip_match.entry_amount,\n   141→        if creator_is_winner { payout } else { 0 },\n   142→    )?;\n   143→\n   144→    rng_shared::cpi::update_player_profile_cpi(\n   145→        &ctx.accounts.platform_program.to_account_info(),\n   146→        &ctx.accounts.opponent_profile,\n   147→        &ctx.accounts.config.to_account_info(),\n   148→        signer_seeds,\n   149→        1,\n   150→        if creator_is_winner { 0 } else { 1 },\n   151→        coinflip_match.entry_amount,\n   152→        if creator_is_winner { 0 } else { payout },\n   153→    )?;\n   154→\n   155→    // (7) Emit MatchSettled event (audit trail persists in tx logs after PDA closed)\n   156→    emit!(MatchSettled {\n   157→        creator: coinflip_match.creator,\n   158→        opponent: coinflip_match.opponent,\n   159→        winner,\n   160→        randomness,\n   161→        payout_amount: payout,\n   162→        fee_amount: fee,\n   163→        vrf_request_key: coinflip_match.vrf_request_key,\n   164→    });\n   165→\n   166→    // (8) Set phase = Settled, claimed = true, store result + winner\n   167→    // Note: LOCKED → SETTLED is intentionally not in the transition() function;\n   168→    // VRF games handle this phase change directly after reading randomness.\n   169→    let coinflip_match = &mut ctx.accounts.coinflip_match;\n   170→    coinflip_match.phase = RoundPhase::Settled;\n   171→    coinflip_match.claimed = true;\n   172→    coinflip_match.result = result;\n   173→    coinflip_match.winner = winner;\n   174→\n   175→    // Account is closed by Anchor's `close = creator` constraint after handler returns.\n   176→    // Remaining lamports (rent) are sent to creator.\n   177→\n   178→    Ok(())\n   179→}\n   180→"}]},"parent_tool_use_id":null,"session_id":"620a91a2-2b9d-4fb9-a12b-278d05c0289f","uuid":"85445076-47d4-4c62-afa2-13e3c156b974","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/claim_payout.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::constants::from_randomness;\nuse rng_shared::escrow::transfer_lamports_from_pda;\nuse rng_shared::fees::calculate_net_payout;\nuse rng_shared::lifecycle::RoundPhase;\nuse rng_shared::vrf_orao::read_orao_randomness;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch, MatchSettled};\n\n#[derive(Accounts)]\npub struct ClaimPayout<'info> {\n    /// Either the creator or opponent can trigger the claim.\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The match PDA (closed after claim — rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (for treasury address + CPI signing).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// The treasury account to receive fees.\n    /// CHECK: Validated against config.treasury in handler.\n    #[account(mut)]\n    pub treasury: AccountInfo<'info>,\n\n    /// The creator account (receives rent refund on close).\n    /// CHECK: Validated against coinflip_match.creator in handler.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent account.\n    /// CHECK: Validated against coinflip_match.opponent in handler.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The Orao randomness PDA — must match vrf_request_key stored on match.\n    /// CHECK: Key validated against coinflip_match.vrf_request_key; data read by shared VRF helper.\n    pub randomness_account: AccountInfo<'info>,\n\n    /// Creator's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub creator_profile: AccountInfo<'info>,\n\n    /// Opponent's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub opponent_profile: AccountInfo<'info>,\n\n    /// The platform program for CPI calls.\n    pub platform_program: Program<'info, platform::program::Platform>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<ClaimPayout>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // (1) Must be in LOCKED phase and not already claimed\n    require!(\n        coinflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n    require!(!coinflip_match.claimed, CoinflipError::AlreadyClaimed);\n\n    // Caller must be either creator or opponent\n    let caller = ctx.accounts.caller.key();\n    require!(\n        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n        CoinflipError::UnauthorizedCaller\n    );\n\n    // Validate accounts match stored state\n    require!(\n        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.creator.key() == coinflip_match.creator,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.opponent.key() == coinflip_match.opponent,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.randomness_account.key() == coinflip_match.vrf_request_key,\n        CoinflipError::InvalidPhase\n    );\n\n    // (2) Read Orao randomness — rejects if not fulfilled\n    let randomness = read_orao_randomness(&ctx.accounts.randomness_account)?;\n\n    // (3) Derive winner from randomness\n    let result = from_randomness(randomness[0]);\n    let winner = if result == coinflip_match.creator_side {\n        coinflip_match.creator\n    } else {\n        coinflip_match.opponent\n    };\n\n    // (4) Compute fee/payout\n    let pool = coinflip_match.entry_amount.checked_mul(2).unwrap();\n    let (fee, payout) = calculate_net_payout(pool);\n\n    // (5) Transfer payout to winner + fee to treasury\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    let winner_account = if winner == coinflip_match.creator {\n        ctx.accounts.creator.to_account_info()\n    } else {\n        ctx.accounts.opponent.to_account_info()\n    };\n    transfer_lamports_from_pda(&match_info, &winner_account, payout)?;\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.treasury, fee)?;\n\n    // (6) CPI update both player profiles via shared helper\n    let config_bump = ctx.accounts.config.bump;\n    let signer_seeds: &[&[u8]] = &[b\"coinflip_config\", &[config_bump]];\n\n    let creator_is_winner = winner == coinflip_match.creator;\n    rng_shared::cpi::update_player_profile_cpi(\n        &ctx.accounts.platform_program.to_account_info(),\n        &ctx.accounts.creator_profile,\n        &ctx.accounts.config.to_account_info(),\n        signer_seeds,\n        1,\n        if creator_is_winner { 1 } else { 0 },\n        coinflip_match.entry_amount,\n        if creator_is_winner { payout } else { 0 },\n    )?;\n\n    rng_shared::cpi::update_player_profile_cpi(\n        &ctx.accounts.platform_program.to_account_info(),\n        &ctx.accounts.opponent_profile,\n        &ctx.accounts.config.to_account_info(),\n        signer_seeds,\n        1,\n        if creator_is_winner { 0 } else { 1 },\n        coinflip_match.entry_amount,\n        if creator_is_winner { 0 } else { payout },\n    )?;\n\n    // (7) Emit MatchSettled event (audit trail persists in tx logs after PDA closed)\n    emit!(MatchSettled {\n        creator: coinflip_match.creator,\n        opponent: coinflip_match.opponent,\n        winner,\n        randomness,\n        payout_amount: payout,\n        fee_amount: fee,\n        vrf_request_key: coinflip_match.vrf_request_key,\n    });\n\n    // (8) Set phase = Settled, claimed = true, store result + winner\n    // Note: LOCKED → SETTLED is intentionally not in the transition() function;\n    // VRF games handle this phase change directly after reading randomness.\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.phase = RoundPhase::Settled;\n    coinflip_match.claimed = true;\n    coinflip_match.result = result;\n    coinflip_match.winner = winner;\n\n    // Account is closed by Anchor's `close = creator` constraint after handler returns.\n    // Remaining lamports (rent) are sent to creator.\n\n    Ok(())\n}\n","numLines":180,"startLine":1,"totalLines":180}}}
