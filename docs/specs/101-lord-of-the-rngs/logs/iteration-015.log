{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nz8YuBFghuDkFiZLLaLE1D","type":"tool_result","content":"     1→import {\n     2→  ReactNode,\n     3→  createContext,\n     4→  useContext,\n     5→  useState,\n     6→  useCallback,\n     7→} from \"react\";\n     8→import { Transaction } from \"@solana/web3.js\";\n     9→import { useWallet } from \"../useWallet\";\n    10→\n    11→export type TransactionStatus =\n    12→  | \"idle\"\n    13→  | \"building\"\n    14→  | \"signing\"\n    15→  | \"submitting\"\n    16→  | \"confirming\"\n    17→  | \"confirmed\"\n    18→  | \"failed\";\n    19→\n    20→export interface TransactionState {\n    21→  status: TransactionStatus;\n    22→  signature: string | null;\n    23→  error: Error | null;\n    24→}\n    25→\n    26→export interface TransactionContextValue {\n    27→  state: TransactionState;\n    28→  submit: (transaction: Transaction) => Promise<string>;\n    29→  reset: () => void;\n    30→  isProcessing: boolean;\n    31→}\n    32→\n    33→const TransactionContext = createContext<TransactionContextValue | null>(null);\n    34→\n    35→const initialState: TransactionState = {\n    36→  status: \"idle\",\n    37→  signature: null,\n    38→  error: null,\n    39→};\n    40→\n    41→interface TransactionProviderProps {\n    42→  children: ReactNode;\n    43→}\n    44→\n    45→export function TransactionProvider({ children }: TransactionProviderProps) {\n    46→  const { sendTransaction } = useWallet();\n    47→  const [state, setState] = useState<TransactionState>(initialState);\n    48→\n    49→  const submit = useCallback(\n    50→    async (transaction: Transaction): Promise<string> => {\n    51→      setState({ status: \"signing\", signature: null, error: null });\n    52→\n    53→      try {\n    54→        setState((s) => ({ ...s, status: \"submitting\" }));\n    55→        const signature = await sendTransaction(transaction);\n    56→\n    57→        setState((s) => ({ ...s, status: \"confirming\" }));\n    58→        // In real implementation, we'd wait for confirmation here\n    59→\n    60→        setState({ status: \"confirmed\", signature, error: null });\n    61→        return signature;\n    62→      } catch (error) {\n    63→        const err = error instanceof Error ? error : new Error(String(error));\n    64→        setState({ status: \"failed\", signature: null, error: err });\n    65→        throw err;\n    66→      }\n    67→    },\n    68→    [sendTransaction]\n    69→  );\n    70→\n    71→  const reset = useCallback(() => {\n    72→    setState(initialState);\n    73→  }, []);\n    74→\n    75→  const isProcessing =\n    76→    state.status !== \"idle\" &&\n    77→    state.status !== \"confirmed\" &&\n    78→    state.status !== \"failed\";\n    79→\n    80→  const value: TransactionContextValue = {\n    81→    state,\n    82→    submit,\n    83→    reset,\n    84→    isProcessing,\n    85→  };\n    86→\n    87→  return (\n    88→    <TransactionContext.Provider value={value}>\n    89→      {children}\n    90→    </TransactionContext.Provider>\n    91→  );\n    92→}\n    93→\n    94→export function useTransaction(): TransactionContextValue {\n    95→  const context = useContext(TransactionContext);\n    96→  if (!context) {\n    97→    throw new Error(\"useTransaction must be used within TransactionProvider\");\n    98→  }\n    99→  return context;\n   100→}"}]},"parent_tool_use_id":"toolu_01AZyj4jyCw1fFzBnyX8zXaG","session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"322750b0-6458-4f89-9f8e-4ff4dc29f66f"}
