{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QV96DGQmnSuZzyMSBaqeGJ","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { LordofrngsIDL, type Lordofrngs } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  TIER_VALUES,\n    11→  type Tier,\n    12→} from \"@rng-utopia/game-engine/browser\";\n    13→import type { Round, PlayerEntry } from \"../types\";\n    14→import { PLAYER_COLORS } from \"../types\";\n    15→\n    16→// ============ Constants ============\n    17→\n    18→const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n    19→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    20→    .VITE_LORDOFRNGS_PROGRAM_ID ?? LordofrngsIDL.address\n    21→);\n    22→\n    23→const ORAO_VRF_PROGRAM_ID = new PublicKey(\n    24→  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\"\n    25→);\n    26→\n    27→const LAMPORTS_PER_SOL = 1_000_000_000;\n    28→\n    29→// ============ PDA Derivation ============\n    30→\n    31→export function getRoundPda(\n    32→  tier: number,\n    33→  roundNumber: bigint | number\n    34→): [PublicKey, number] {\n    35→  const tierBuf = Buffer.alloc(1);\n    36→  tierBuf.writeUInt8(tier);\n    37→  const roundBuf = Buffer.alloc(8);\n    38→  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n    39→  return PublicKey.findProgramAddressSync(\n    40→    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    41→    LORDOFRNGS_PROGRAM_ID\n    42→  );\n    43→}\n    44→\n    45→export function getConfigPda(): [PublicKey, number] {\n    46→  return PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"lord_config\")],\n    48→    LORDOFRNGS_PROGRAM_ID\n    49→  );\n    50→}\n    51→\n    52→function getOraoNetworkStatePda(): PublicKey {\n    53→  const [pda] = PublicKey.findProgramAddressSync(\n    54→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    55→    ORAO_VRF_PROGRAM_ID\n    56→  );\n    57→  return pda;\n    58→}\n    59→\n    60→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    61→  const [pda] = PublicKey.findProgramAddressSync(\n    62→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    63→    ORAO_VRF_PROGRAM_ID\n    64→  );\n    65→  return pda;\n    66→}\n    67→\n    68→// ============ Program Instance ============\n    69→\n    70→function getLordProgram(connection: Connection): Program<Lordofrngs> {\n    71→  const provider = new AnchorProvider(\n    72→    connection,\n    73→    {} as AnchorProvider[\"wallet\"],\n    74→    { commitment: \"confirmed\" }\n    75→  );\n    76→  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n    77→}\n    78→\n    79→// ============ On-Chain Account Types ============\n    80→\n    81→type RoundPhaseVariant =\n    82→  | { waiting: object }\n    83→  | { active: object }\n    84→  | { locked: object }\n    85→  | { resolving: object }\n    86→  | { settled: object }\n    87→  | { refunded: object };\n    88→\n    89→interface OnChainPlayerEntry {\n    90→  player: PublicKey;\n    91→  entries: number;\n    92→}\n    93→\n    94→interface OnChainRound {\n    95→  tier: number;\n    96→  roundNumber: { toNumber(): number };\n    97→  entryAmount: { toNumber(): number };\n    98→  phase: RoundPhaseVariant;\n    99→  players: OnChainPlayerEntry[];\n   100→  totalEntries: number;\n   101→  createdAt: { toNumber(): number };\n   102→  countdownEndsAt: { toNumber(): number };\n   103→  lockedAt: { toNumber(): number };\n   104→  resolveDeadline: { toNumber(): number };\n   105→  vrfRequestKey: PublicKey;\n   106→  winningSlot: number;\n   107→  winner: PublicKey;\n   108→  claimed: boolean;\n   109→  creator: PublicKey;\n   110→  bump: number;\n   111→}\n   112→\n   113→interface OnChainConfig {\n   114→  authority: PublicKey;\n   115→  treasury: PublicKey;\n   116→  paused: boolean;\n   117→  roundCounters: { toNumber(): number }[];\n   118→  bump: number;\n   119→}\n   120→\n   121→// ============ Converters ============\n   122→\n   123→const TIERS: Tier[] = [\n   124→  \"iron\",\n   125→  \"bronze\",\n   126→  \"silver\",\n   127→  \"gold\",\n   128→  \"platinum\",\n   129→  \"diamond\",\n   130→];\n   131→\n   132→function tierFromIndex(index: number): Tier {\n   133→  return TIERS[index] ?? \"iron\";\n   134→}\n   135→\n   136→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   137→  return name in phase;\n   138→}\n   139→\n   140→function phaseToUI(phase: RoundPhaseVariant): Round[\"phase\"] {\n   141→  if (isPhase(phase, \"waiting\")) return \"waiting\";\n   142→  if (isPhase(phase, \"active\")) return \"countdown\";\n   143→  if (isPhase(phase, \"locked\")) return \"spinning\";\n   144→  if (isPhase(phase, \"settled\")) return \"complete\";\n   145→  // Resolving, Refunded → treat as complete for display\n   146→  return \"complete\";\n   147→}\n   148→\n   149→function getPlayerColor(index: number, isCurrentUser: boolean): string {\n   150→  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\";\n   151→  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n   152→}\n   153→\n   154→function onChainPlayersToUI(\n   155→  players: OnChainPlayerEntry[],\n   156→  currentWallet?: string\n   157→): PlayerEntry[] {\n   158→  return players.map((p, i) => ({\n   159→    address: p.player.toBase58(),\n   160→    entries: p.entries,\n   161→    color: getPlayerColor(i, p.player.toBase58() === currentWallet),\n   162→  }));\n   163→}\n   164→\n   165→export function onChainRoundToUI(\n   166→  roundPda: PublicKey,\n   167→  data: OnChainRound,\n   168→  currentWallet?: string\n   169→): Round {\n   170→  const tier = tierFromIndex(data.tier);\n   171→  const entryAmountLamports = data.entryAmount.toNumber();\n   172→  const entryAmountSol = entryAmountLamports / LAMPORTS_PER_SOL;\n   173→  const totalEntries = data.totalEntries;\n   174→  const poolAmount = entryAmountSol * totalEntries;\n   175→  const phase = phaseToUI(data.phase);\n   176→  const isSettled = isPhase(data.phase, \"settled\");\n   177→  const countdownEndsAt = data.countdownEndsAt.toNumber();\n   178→\n   179→  const winner = isSettled ? data.winner : undefined;\n   180→  const isDefaultWinner =\n   181→    winner && winner.equals(PublicKey.default) ? undefined : winner;\n   182→\n   183→  return {\n   184→    id: roundPda.toBase58(),\n   185→    tier,\n   186→    entryAmount: entryAmountSol,\n   187→    phase,\n   188→    players: onChainPlayersToUI(data.players, currentWallet),\n   189→    totalEntries,\n   190→    poolAmount,\n   191→    createdAt: data.createdAt.toNumber() * 1000,\n   192→    countdownStartedAt:\n   193→      countdownEndsAt > 0 ? (countdownEndsAt - 60) * 1000 : undefined,\n   194→    countdownEndsAt: countdownEndsAt > 0 ? countdownEndsAt * 1000 : undefined,\n   195→    winningSlot: isSettled ? data.winningSlot : undefined,\n   196→    winner: isDefaultWinner?.toBase58(),\n   197→    payoutAmount: isSettled ? poolAmount * 0.97 : undefined,\n   198→    claimed: data.claimed,\n   199→    seedHash: data.vrfRequestKey.equals(PublicKey.default)\n   200→      ? \"\"\n   201→      : data.vrfRequestKey.toBase58(),\n   202→    vrfProof: isSettled\n   203→      ? data.vrfRequestKey.toBase58()\n   204→      : undefined,\n   205→  };\n   206→}\n   207→\n   208→/** Read VRF randomness from an Orao account. Returns 32 bytes or null. */\n   209→async function readVrfRandomness(\n   210→  connection: Connection,\n   211→  vrfRequestKey: PublicKey\n   212→): Promise<Uint8Array | null> {\n   213→  try {\n   214→    if (vrfRequestKey.equals(PublicKey.default)) return null;\n   215→    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n   216→    if (vrfAccount && vrfAccount.data.length > 8) {\n   217→      const randomnessData = vrfAccount.data.subarray(8, 72);\n   218→      if (randomnessData.some((b: number) => b !== 0)) {\n   219→        return randomnessData.subarray(0, 32);\n   220→      }\n   221→    }\n   222→  } catch {\n   223→    // Ignore\n   224→  }\n   225→  return null;\n   226→}\n   227→\n   228→/** Derive winner from VRF randomness for a locked round. */\n   229→function deriveWinnerFromVrf(\n   230→  randomness: Uint8Array,\n   231→  data: OnChainRound\n   232→): { winningSlot: number; winner: PublicKey } {\n   233→  const view = new DataView(\n   234→    randomness.buffer,\n   235→    randomness.byteOffset,\n   236→    8\n   237→  );\n   238→  const raw = view.getBigUint64(0, true);\n   239→  const winningSlot = Number(raw % BigInt(data.totalEntries));\n   240→\n   241→  let cumulative = 0;\n   242→  for (const p of data.players) {\n   243→    cumulative += p.entries;\n   244→    if (winningSlot < cumulative) {\n   245→      return { winningSlot, winner: p.player };\n   246→    }\n   247→  }\n   248→  return { winningSlot, winner: data.players[0]!.player };\n   249→}\n   250→\n   251→// ============ Account Queries ============\n   252→\n   253→/** Fetch a single round by tier and round number. */\n   254→export async function fetchRound(\n   255→  connection: Connection,\n   256→  tier: number,\n   257→  roundNumber: bigint | number,\n   258→  currentWallet?: string\n   259→): Promise<Round | null> {\n   260→  const program = getLordProgram(connection);\n   261→  const [roundPda] = getRoundPda(tier, roundNumber);\n   262→\n   263→  try {\n   264→    const account = await program.account.jackpotRound.fetch(roundPda);\n   265→    const data = account as unknown as OnChainRound;\n   266→    const round = onChainRoundToUI(roundPda, data, currentWallet);\n   267→\n   268→    // If Locked, check if VRF is fulfilled to upgrade to spinning/revealing\n   269→    if (isPhase(data.phase, \"locked\")) {\n   270→      const randomness = await readVrfRandomness(\n   271→        connection,\n   272→        data.vrfRequestKey\n   273→      );\n   274→      if (randomness) {\n   275→        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n   276→        return {\n   277→          ...round,\n   278→          phase: \"revealing\",\n   279→          winningSlot,\n   280→          winner: winner.toBase58(),\n   281→          payoutAmount: round.poolAmount * 0.97,\n   282→        };\n   283→      }\n   284→    }\n   285→\n   286→    return round;\n   287→  } catch {\n   288→    return null;\n   289→  }\n   290→}\n   291→\n   292→/** Fetch the current round for each tier. Returns a map of tier → Round. */\n   293→export async function fetchAllTierRounds(\n   294→  connection: Connection,\n   295→  currentWallet?: string\n   296→): Promise<Map<Tier, Round>> {\n   297→  const program = getLordProgram(connection);\n   298→  const result = new Map<Tier, Round>();\n   299→\n   300→  // Fetch all JackpotRound accounts\n   301→  const accounts = await program.account.jackpotRound.all();\n   302→\n   303→  // Group by tier — pick the latest (highest roundNumber) non-terminal round per tier\n   304→  const byTier = new Map<number, { pda: PublicKey; data: OnChainRound }>();\n   305→\n   306→  for (const acc of accounts) {\n   307→    const data = acc.account as unknown as OnChainRound;\n   308→    // Skip terminal phases\n   309→    if (isPhase(data.phase, \"settled\") || isPhase(data.phase, \"refunded\"))\n   310→      continue;\n   311→\n   312→    const existing = byTier.get(data.tier);\n   313→    if (\n   314→      !existing ||\n   315→      data.roundNumber.toNumber() > existing.data.roundNumber.toNumber()\n   316→    ) {\n   317→      byTier.set(data.tier, { pda: acc.publicKey, data });\n   318→    }\n   319→  }\n   320→\n   321→  for (const [tierIndex, { pda, data }] of byTier) {\n   322→    const round = onChainRoundToUI(pda, data, currentWallet);\n   323→\n   324→    // Check VRF for locked rounds\n   325→    if (isPhase(data.phase, \"locked\")) {\n   326→      const randomness = await readVrfRandomness(\n   327→        connection,\n   328→        data.vrfRequestKey\n   329→      );\n   330→      if (randomness) {\n   331→        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n   332→        result.set(tierFromIndex(tierIndex), {\n   333→          ...round,\n   334→          phase: \"revealing\",\n   335→          winningSlot,\n   336→          winner: winner.toBase58(),\n   337→          payoutAmount: round.poolAmount * 0.97,\n   338→        });\n   339→        continue;\n   340→      }\n   341→    }\n   342→\n   343→    result.set(tierFromIndex(tierIndex), round);\n   344→  }\n   345→\n   346→  return result;\n   347→}\n   348→\n   349→/** Fetch all rounds where the player participated and can still claim. */\n   350→export async function fetchClaimableRounds(\n   351→  connection: Connection,\n   352→  playerPubkey: PublicKey\n   353→): Promise<Round[]> {\n   354→  const program = getLordProgram(connection);\n   355→  const accounts = await program.account.jackpotRound.all();\n   356→  const results: Round[] = [];\n   357→\n   358→  for (const acc of accounts) {\n   359→    const data = acc.account as unknown as OnChainRound;\n   360→\n   361→    // Only interested in Locked (VRF fulfilled) rounds, not yet claimed\n   362→    if (!isPhase(data.phase, \"locked\") || data.claimed) continue;\n   363→\n   364→    // Check if player is in this round\n   365→    const inRound = data.players.some((p) =>\n   366→      p.player.equals(playerPubkey)\n   367→    );\n   368→    if (!inRound) continue;\n   369→\n   370→    // Check if VRF is fulfilled\n   371→    const randomness = await readVrfRandomness(\n   372→      connection,\n   373→      data.vrfRequestKey\n   374→    );\n   375→    if (!randomness) continue;\n   376→\n   377→    const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n   378→    const round = onChainRoundToUI(\n   379→      acc.publicKey,\n   380→      data,\n   381→      playerPubkey.toBase58()\n   382→    );\n   383→    results.push({\n   384→      ...round,\n   385→      phase: \"revealing\",\n   386→      winningSlot,\n   387→      winner: winner.toBase58(),\n   388→      payoutAmount: round.poolAmount * 0.97,\n   389→    });\n   390→  }\n   391→\n   392→  return results;\n   393→}\n   394→\n   395→// ============ Instruction Builders ============\n   396→\n   397→/** Build a transaction to join (or create) a round. */\n   398→export async function buildJoinRoundTx(\n   399→  connection: Connection,\n   400→  player: PublicKey,\n   401→  tier: Tier,\n   402→  numEntries: number,\n   403→  roundNumber: bigint | number\n   404→): Promise<Transaction> {\n   405→  const program = getLordProgram(connection);\n   406→  const tierIndex = TIER_VALUES[tier];\n   407→  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n   408→  const [configPda] = getConfigPda();\n   409→\n   410→  const ix = await program.methods\n   411→    .joinRound(tierIndex, BigInt(roundNumber) as never, numEntries)\n   412→    .accountsStrict({\n   413→      player,\n   414→      config: configPda,\n   415→      round: roundPda,\n   416→      systemProgram: SystemProgram.programId,\n   417→    })\n   418→    .instruction();\n   419→\n   420→  const tx = new Transaction().add(ix);\n   421→  tx.feePayer = player;\n   422→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   423→\n   424→  return tx;\n   425→}\n   426→\n   427→/** Build a transaction to buy more entries in an existing round. */\n   428→export async function buildBuyMoreEntriesTx(\n   429→  connection: Connection,\n   430→  player: PublicKey,\n   431→  tier: Tier,\n   432→  roundNumber: bigint | number,\n   433→  numEntries: number\n   434→): Promise<Transaction> {\n   435→  const program = getLordProgram(connection);\n   436→  const tierIndex = TIER_VALUES[tier];\n   437→  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n   438→  const [configPda] = getConfigPda();\n   439→\n   440→  const ix = await program.methods\n   441→    .buyMoreEntries(tierIndex, BigInt(roundNumber) as never, numEntries)\n   442→    .accountsStrict({\n   443→      player,\n   444→      config: configPda,\n   445→      round: roundPda,\n   446→      systemProgram: SystemProgram.programId,\n   447→    })\n   448→    .instruction();\n   449→\n   450→  const tx = new Transaction().add(ix);\n   451→  tx.feePayer = player;\n   452→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   453→\n   454→  return tx;\n   455→}\n   456→\n   457→/** Build a transaction to trigger the VRF spin. */\n   458→export async function buildStartSpinTx(\n   459→  connection: Connection,\n   460→  caller: PublicKey,\n   461→  tier: Tier,\n   462→  roundNumber: bigint | number\n   463→): Promise<Transaction> {\n   464→  const program = getLordProgram(connection);\n   465→  const tierIndex = TIER_VALUES[tier];\n   466→  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n   467→  const [configPda] = getConfigPda();\n   468→\n   469→  // Orao VRF accounts\n   470→  const oraoNetworkState = getOraoNetworkStatePda();\n   471→  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n   472→  if (!networkInfo)\n   473→    throw new Error(\"Orao VRF network state not found on-chain\");\n   474→  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n   475→  const oraoRandom = getOraoRandomnessPda(roundPda.toBytes());\n   476→\n   477→  const ix = await program.methods\n   478→    .startSpin(tierIndex, BigInt(roundNumber) as never)\n   479→    .accountsStrict({\n   480→      caller,\n   481→      config: configPda,\n   482→      round: roundPda,\n   483→      oraoProgram: ORAO_VRF_PROGRAM_ID,\n   484→      oraoNetworkState,\n   485→      oraoTreasury,\n   486→      oraoRandom,\n   487→      systemProgram: SystemProgram.programId,\n   488→    })\n   489→    .instruction();\n   490→\n   491→  const tx = new Transaction().add(ix);\n   492→  tx.feePayer = caller;\n   493→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   494→\n   495→  return tx;\n   496→}\n   497→\n   498→/** Build a transaction to claim payout as the winner. */\n   499→export async function buildClaimPayoutTx(\n   500→  connection: Connection,\n   501→  caller: PublicKey,\n   502→  tier: Tier,\n   503→  roundNumber: bigint | number\n   504→): Promise<Transaction> {\n   505→  const program = getLordProgram(connection);\n   506→  const tierIndex = TIER_VALUES[tier];\n   507→  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n   508→  const [configPda] = getConfigPda();\n   509→\n   510→  // Fetch config for treasury\n   511→  const config = await program.account.lordConfig.fetch(configPda);\n   512→  const configData = config as unknown as OnChainConfig;\n   513→  const treasury = configData.treasury;\n   514→\n   515→  // Fetch round for creator + VRF key + winner derivation\n   516→  const roundAccount = await program.account.jackpotRound.fetch(roundPda);\n   517→  const roundData = roundAccount as unknown as OnChainRound;\n   518→  const roundCreator = roundData.creator;\n   519→  const randomnessAccount = roundData.vrfRequestKey;\n   520→\n   521→  // Read VRF to derive winner\n   522→  const randomness = await readVrfRandomness(connection, randomnessAccount);\n   523→  if (!randomness) throw new Error(\"VRF randomness not yet fulfilled\");\n   524→  const { winner } = deriveWinnerFromVrf(randomness, roundData);\n   525→\n   526→  const ix = await program.methods\n   527→    .claimPayout(tierIndex, BigInt(roundNumber) as never)\n   528→    .accountsStrict({\n   529→      caller,\n   530→      round: roundPda,\n   531→      config: configPda,\n   532→      treasury,\n   533→      roundCreator,\n   534→      winnerAccount: winner,\n   535→      randomnessAccount,\n   536→      systemProgram: SystemProgram.programId,\n   537→    })\n   538→    .instruction();\n   539→\n   540→  const tx = new Transaction().add(ix);\n   541→  tx.feePayer = caller;\n   542→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   543→\n   544→  return tx;\n   545→}\n   546→\n   547→/** Build a transaction to create a new round (first player). */\n   548→export async function buildCreateRoundTx(\n   549→  connection: Connection,\n   550→  creator: PublicKey,\n   551→  tier: Tier,\n   552→  numEntries: number\n   553→): Promise<{ transaction: Transaction; roundPda: PublicKey; roundNumber: bigint }> {\n   554→  const program = getLordProgram(connection);\n   555→  const tierIndex = TIER_VALUES[tier];\n   556→  const [configPda] = getConfigPda();\n   557→\n   558→  // Fetch config to get current round counter for this tier\n   559→  const config = await program.account.lordConfig.fetch(configPda);\n   560→  const configData = config as unknown as OnChainConfig;\n   561→  const roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber());\n   562→\n   563→  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n   564→\n   565→  const ix = await program.methods\n   566→    .createRound(tierIndex, roundNumber as never, numEntries)\n   567→    .accountsStrict({\n   568→      creator,\n   569→      config: configPda,\n   570→      round: roundPda,\n   571→      systemProgram: SystemProgram.programId,\n   572→    })\n   573→    .instruction();\n   574→\n   575→  const tx = new Transaction().add(ix);\n   576→  tx.feePayer = creator;\n   577→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   578→\n   579→  return { transaction: tx, roundPda, roundNumber };\n   580→}\n   581→"}]},"parent_tool_use_id":null,"session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"907ca6c4-911f-4a5c-80c3-697883733d68","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/chain.ts","content":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport { LordofrngsIDL, type Lordofrngs } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  type Tier,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { Round, PlayerEntry } from \"../types\";\nimport { PLAYER_COLORS } from \"../types\";\n\n// ============ Constants ============\n\nconst LORDOFRNGS_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_LORDOFRNGS_PROGRAM_ID ?? LordofrngsIDL.address\n);\n\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\n  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\"\n);\n\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\n// ============ PDA Derivation ============\n\nexport function getRoundPda(\n  tier: number,\n  roundNumber: bigint | number\n): [PublicKey, number] {\n  const tierBuf = Buffer.alloc(1);\n  tierBuf.writeUInt8(tier);\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), tierBuf, roundBuf],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\nfunction getOraoNetworkStatePda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ============ Program Instance ============\n\nfunction getLordProgram(connection: Connection): Program<Lordofrngs> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n}\n\n// ============ On-Chain Account Types ============\n\ntype RoundPhaseVariant =\n  | { waiting: object }\n  | { active: object }\n  | { locked: object }\n  | { resolving: object }\n  | { settled: object }\n  | { refunded: object };\n\ninterface OnChainPlayerEntry {\n  player: PublicKey;\n  entries: number;\n}\n\ninterface OnChainRound {\n  tier: number;\n  roundNumber: { toNumber(): number };\n  entryAmount: { toNumber(): number };\n  phase: RoundPhaseVariant;\n  players: OnChainPlayerEntry[];\n  totalEntries: number;\n  createdAt: { toNumber(): number };\n  countdownEndsAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  winningSlot: number;\n  winner: PublicKey;\n  claimed: boolean;\n  creator: PublicKey;\n  bump: number;\n}\n\ninterface OnChainConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  paused: boolean;\n  roundCounters: { toNumber(): number }[];\n  bump: number;\n}\n\n// ============ Converters ============\n\nconst TIERS: Tier[] = [\n  \"iron\",\n  \"bronze\",\n  \"silver\",\n  \"gold\",\n  \"platinum\",\n  \"diamond\",\n];\n\nfunction tierFromIndex(index: number): Tier {\n  return TIERS[index] ?? \"iron\";\n}\n\nfunction isPhase(phase: RoundPhaseVariant, name: string): boolean {\n  return name in phase;\n}\n\nfunction phaseToUI(phase: RoundPhaseVariant): Round[\"phase\"] {\n  if (isPhase(phase, \"waiting\")) return \"waiting\";\n  if (isPhase(phase, \"active\")) return \"countdown\";\n  if (isPhase(phase, \"locked\")) return \"spinning\";\n  if (isPhase(phase, \"settled\")) return \"complete\";\n  // Resolving, Refunded → treat as complete for display\n  return \"complete\";\n}\n\nfunction getPlayerColor(index: number, isCurrentUser: boolean): string {\n  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\";\n  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n}\n\nfunction onChainPlayersToUI(\n  players: OnChainPlayerEntry[],\n  currentWallet?: string\n): PlayerEntry[] {\n  return players.map((p, i) => ({\n    address: p.player.toBase58(),\n    entries: p.entries,\n    color: getPlayerColor(i, p.player.toBase58() === currentWallet),\n  }));\n}\n\nexport function onChainRoundToUI(\n  roundPda: PublicKey,\n  data: OnChainRound,\n  currentWallet?: string\n): Round {\n  const tier = tierFromIndex(data.tier);\n  const entryAmountLamports = data.entryAmount.toNumber();\n  const entryAmountSol = entryAmountLamports / LAMPORTS_PER_SOL;\n  const totalEntries = data.totalEntries;\n  const poolAmount = entryAmountSol * totalEntries;\n  const phase = phaseToUI(data.phase);\n  const isSettled = isPhase(data.phase, \"settled\");\n  const countdownEndsAt = data.countdownEndsAt.toNumber();\n\n  const winner = isSettled ? data.winner : undefined;\n  const isDefaultWinner =\n    winner && winner.equals(PublicKey.default) ? undefined : winner;\n\n  return {\n    id: roundPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    phase,\n    players: onChainPlayersToUI(data.players, currentWallet),\n    totalEntries,\n    poolAmount,\n    createdAt: data.createdAt.toNumber() * 1000,\n    countdownStartedAt:\n      countdownEndsAt > 0 ? (countdownEndsAt - 60) * 1000 : undefined,\n    countdownEndsAt: countdownEndsAt > 0 ? countdownEndsAt * 1000 : undefined,\n    winningSlot: isSettled ? data.winningSlot : undefined,\n    winner: isDefaultWinner?.toBase58(),\n    payoutAmount: isSettled ? poolAmount * 0.97 : undefined,\n    claimed: data.claimed,\n    seedHash: data.vrfRequestKey.equals(PublicKey.default)\n      ? \"\"\n      : data.vrfRequestKey.toBase58(),\n    vrfProof: isSettled\n      ? data.vrfRequestKey.toBase58()\n      : undefined,\n  };\n}\n\n/** Read VRF randomness from an Orao account. Returns 32 bytes or null. */\nasync function readVrfRandomness(\n  connection: Connection,\n  vrfRequestKey: PublicKey\n): Promise<Uint8Array | null> {\n  try {\n    if (vrfRequestKey.equals(PublicKey.default)) return null;\n    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      if (randomnessData.some((b: number) => b !== 0)) {\n        return randomnessData.subarray(0, 32);\n      }\n    }\n  } catch {\n    // Ignore\n  }\n  return null;\n}\n\n/** Derive winner from VRF randomness for a locked round. */\nfunction deriveWinnerFromVrf(\n  randomness: Uint8Array,\n  data: OnChainRound\n): { winningSlot: number; winner: PublicKey } {\n  const view = new DataView(\n    randomness.buffer,\n    randomness.byteOffset,\n    8\n  );\n  const raw = view.getBigUint64(0, true);\n  const winningSlot = Number(raw % BigInt(data.totalEntries));\n\n  let cumulative = 0;\n  for (const p of data.players) {\n    cumulative += p.entries;\n    if (winningSlot < cumulative) {\n      return { winningSlot, winner: p.player };\n    }\n  }\n  return { winningSlot, winner: data.players[0]!.player };\n}\n\n// ============ Account Queries ============\n\n/** Fetch a single round by tier and round number. */\nexport async function fetchRound(\n  connection: Connection,\n  tier: number,\n  roundNumber: bigint | number,\n  currentWallet?: string\n): Promise<Round | null> {\n  const program = getLordProgram(connection);\n  const [roundPda] = getRoundPda(tier, roundNumber);\n\n  try {\n    const account = await program.account.jackpotRound.fetch(roundPda);\n    const data = account as unknown as OnChainRound;\n    const round = onChainRoundToUI(roundPda, data, currentWallet);\n\n    // If Locked, check if VRF is fulfilled to upgrade to spinning/revealing\n    if (isPhase(data.phase, \"locked\")) {\n      const randomness = await readVrfRandomness(\n        connection,\n        data.vrfRequestKey\n      );\n      if (randomness) {\n        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n        return {\n          ...round,\n          phase: \"revealing\",\n          winningSlot,\n          winner: winner.toBase58(),\n          payoutAmount: round.poolAmount * 0.97,\n        };\n      }\n    }\n\n    return round;\n  } catch {\n    return null;\n  }\n}\n\n/** Fetch the current round for each tier. Returns a map of tier → Round. */\nexport async function fetchAllTierRounds(\n  connection: Connection,\n  currentWallet?: string\n): Promise<Map<Tier, Round>> {\n  const program = getLordProgram(connection);\n  const result = new Map<Tier, Round>();\n\n  // Fetch all JackpotRound accounts\n  const accounts = await program.account.jackpotRound.all();\n\n  // Group by tier — pick the latest (highest roundNumber) non-terminal round per tier\n  const byTier = new Map<number, { pda: PublicKey; data: OnChainRound }>();\n\n  for (const acc of accounts) {\n    const data = acc.account as unknown as OnChainRound;\n    // Skip terminal phases\n    if (isPhase(data.phase, \"settled\") || isPhase(data.phase, \"refunded\"))\n      continue;\n\n    const existing = byTier.get(data.tier);\n    if (\n      !existing ||\n      data.roundNumber.toNumber() > existing.data.roundNumber.toNumber()\n    ) {\n      byTier.set(data.tier, { pda: acc.publicKey, data });\n    }\n  }\n\n  for (const [tierIndex, { pda, data }] of byTier) {\n    const round = onChainRoundToUI(pda, data, currentWallet);\n\n    // Check VRF for locked rounds\n    if (isPhase(data.phase, \"locked\")) {\n      const randomness = await readVrfRandomness(\n        connection,\n        data.vrfRequestKey\n      );\n      if (randomness) {\n        const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n        result.set(tierFromIndex(tierIndex), {\n          ...round,\n          phase: \"revealing\",\n          winningSlot,\n          winner: winner.toBase58(),\n          payoutAmount: round.poolAmount * 0.97,\n        });\n        continue;\n      }\n    }\n\n    result.set(tierFromIndex(tierIndex), round);\n  }\n\n  return result;\n}\n\n/** Fetch all rounds where the player participated and can still claim. */\nexport async function fetchClaimableRounds(\n  connection: Connection,\n  playerPubkey: PublicKey\n): Promise<Round[]> {\n  const program = getLordProgram(connection);\n  const accounts = await program.account.jackpotRound.all();\n  const results: Round[] = [];\n\n  for (const acc of accounts) {\n    const data = acc.account as unknown as OnChainRound;\n\n    // Only interested in Locked (VRF fulfilled) rounds, not yet claimed\n    if (!isPhase(data.phase, \"locked\") || data.claimed) continue;\n\n    // Check if player is in this round\n    const inRound = data.players.some((p) =>\n      p.player.equals(playerPubkey)\n    );\n    if (!inRound) continue;\n\n    // Check if VRF is fulfilled\n    const randomness = await readVrfRandomness(\n      connection,\n      data.vrfRequestKey\n    );\n    if (!randomness) continue;\n\n    const { winningSlot, winner } = deriveWinnerFromVrf(randomness, data);\n    const round = onChainRoundToUI(\n      acc.publicKey,\n      data,\n      playerPubkey.toBase58()\n    );\n    results.push({\n      ...round,\n      phase: \"revealing\",\n      winningSlot,\n      winner: winner.toBase58(),\n      payoutAmount: round.poolAmount * 0.97,\n    });\n  }\n\n  return results;\n}\n\n// ============ Instruction Builders ============\n\n/** Build a transaction to join (or create) a round. */\nexport async function buildJoinRoundTx(\n  connection: Connection,\n  player: PublicKey,\n  tier: Tier,\n  numEntries: number,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  const ix = await program.methods\n    .joinRound(tierIndex, BigInt(roundNumber) as never, numEntries)\n    .accountsStrict({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = player;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to buy more entries in an existing round. */\nexport async function buildBuyMoreEntriesTx(\n  connection: Connection,\n  player: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number,\n  numEntries: number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  const ix = await program.methods\n    .buyMoreEntries(tierIndex, BigInt(roundNumber) as never, numEntries)\n    .accountsStrict({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = player;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to trigger the VRF spin. */\nexport async function buildStartSpinTx(\n  connection: Connection,\n  caller: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  // Orao VRF accounts\n  const oraoNetworkState = getOraoNetworkStatePda();\n  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n  if (!networkInfo)\n    throw new Error(\"Orao VRF network state not found on-chain\");\n  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n  const oraoRandom = getOraoRandomnessPda(roundPda.toBytes());\n\n  const ix = await program.methods\n    .startSpin(tierIndex, BigInt(roundNumber) as never)\n    .accountsStrict({\n      caller,\n      config: configPda,\n      round: roundPda,\n      oraoProgram: ORAO_VRF_PROGRAM_ID,\n      oraoNetworkState,\n      oraoTreasury,\n      oraoRandom,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to claim payout as the winner. */\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  caller: PublicKey,\n  tier: Tier,\n  roundNumber: bigint | number\n): Promise<Transaction> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n  const [configPda] = getConfigPda();\n\n  // Fetch config for treasury\n  const config = await program.account.lordConfig.fetch(configPda);\n  const configData = config as unknown as OnChainConfig;\n  const treasury = configData.treasury;\n\n  // Fetch round for creator + VRF key + winner derivation\n  const roundAccount = await program.account.jackpotRound.fetch(roundPda);\n  const roundData = roundAccount as unknown as OnChainRound;\n  const roundCreator = roundData.creator;\n  const randomnessAccount = roundData.vrfRequestKey;\n\n  // Read VRF to derive winner\n  const randomness = await readVrfRandomness(connection, randomnessAccount);\n  if (!randomness) throw new Error(\"VRF randomness not yet fulfilled\");\n  const { winner } = deriveWinnerFromVrf(randomness, roundData);\n\n  const ix = await program.methods\n    .claimPayout(tierIndex, BigInt(roundNumber) as never)\n    .accountsStrict({\n      caller,\n      round: roundPda,\n      config: configPda,\n      treasury,\n      roundCreator,\n      winnerAccount: winner,\n      randomnessAccount,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n/** Build a transaction to create a new round (first player). */\nexport async function buildCreateRoundTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  numEntries: number\n): Promise<{ transaction: Transaction; roundPda: PublicKey; roundNumber: bigint }> {\n  const program = getLordProgram(connection);\n  const tierIndex = TIER_VALUES[tier];\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get current round counter for this tier\n  const config = await program.account.lordConfig.fetch(configPda);\n  const configData = config as unknown as OnChainConfig;\n  const roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber());\n\n  const [roundPda] = getRoundPda(tierIndex, roundNumber);\n\n  const ix = await program.methods\n    .createRound(tierIndex, roundNumber as never, numEntries)\n    .accountsStrict({\n      creator,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, roundPda, roundNumber };\n}\n","numLines":581,"startLine":1,"totalLines":581}}}
