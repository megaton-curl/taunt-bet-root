        selectedTier,","+          entryCount,","+          roundNumber,","+        );","+        await sendAndConfirm(tx);","+","+        [roundPda] = getRoundPda(tierIndex, roundNumber);","+      } else {","+        // Create a new round (we are the first player)","+        const result = await buildCreateRoundTx(","+          connection,","+          publicKey,","+          selectedTier,","+          entryCount,","+        );","+        await sendAndConfirm(result.transaction);","+","+        roundPda = result.roundPda;","+        roundNumber = result.roundNumber;","+        tierIndex = TIER_VALUES[selectedTier];","+      }","+","+      // Fetch the round we just joined/created","+      const round = await fetchRound(","+        connection,","+        tierIndex,","+        roundNumber,","+        publicKey.toBase58(),","+      );","+      if (round) {","+        setActiveRound(round);","+        setActiveRoundMeta({ tierIndex, roundNumber });","+        setUserLeftRound(false);","+      }","+","+      void refreshRounds();","+    } catch (err) {","+      setError(parseTransactionError(err));","     } finally {","       setJoining(false);","     }","-  }, [connected, address, selectedTier, entryCount, refreshRounds]);","+  }, [connected, publicKey, selectedTier, entryCount, connection, sendAndConfirm, refreshRounds]);"," ","   // Buy more entries in current round","   const buyMoreEntriesAction = useCallback(","     async (entries: number) => {","-      if (!connected || !address || !activeRound) {","-        throw new Error(\"No active round\");","+      if (!connected || !publicKey || !activeRound || !activeRoundMeta) {","+        setError(\"No active round.\");","+        return;","       }"," ","       setBuyingMore(true);","+      setError(null);","       try {","-        // Simulate transaction delay","-        await new Promise((resolve) => setTimeout(resolve, 500));","+        const tx = await buildBuyMoreEntriesTx(","+          connection,","+          publicKey,","+          activeRound.tier,","+          activeRoundMeta.roundNumber,","+          entries,","+        );","+        await sendAndConfirm(tx);"," ","-        const updated = buyMoreEntries(activeRound.id, address, entries);","-        setActiveRound(updated);","+        // Refresh active round","+        const updated = await fetchRound(","+          connection,","+          activeRoundMeta.tierIndex,","+          activeRoundMeta.roundNumber,","+          publicKey.toBase58(),","+        );","+        if (updated) {","+          setActiveRound(updated);","+        }"," ","-        // Refresh tier statuses","-        refreshRounds();","+        void refreshRounds();","+      } catch (err) {","+        setError(parseTransactionError(err));","       } finally {","         setBuyingMore(false);","       }","     },","-    [connected, address, activeRound, refreshRounds]","+    [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds],","   );"," ","-  // Claim payout for winning round","-  const claimPayout = useCallback(async () => {","-    if (!activeRound || activeRound.phase !== \"complete\") {","-      throw new Error(\"No completed round to claim\");","+  // Start the VRF spin (permissionless — any player can trigger after countdown)","+  const startSpin = useCallback(async () => {","+    if (!connected || !publicKey || !activeRound || !activeRoundMeta) {","+      setError(\"No active round.\");","+      return;","     }","-    if (activeRound.winner !== address) {","-      throw new Error(\"You are not the winner\");","+","+    setSpinning(true);","+    setError(null);","+    try {","+      const tx = await buildStartSpinTx(","+        connection,","+        publicKey,","+        activeRound.tier,","+        activeRoundMeta.roundNumber,","+      );","+      await sendAndConfirm(tx);","+","+      // Refresh active round — should now be in \"spinning\" phase","+      const updated = await fetchRound(","+        connection,","+        activeRoundMeta.tierIndex,","+        activeRoundMeta.roundNumber,","+        publicKey.toBase58(),","+      );","+      if (updated) {","+        setActiveRound(updated);","+      }","+    } catch (err) {","+      setError(parseTransactionError(err));","+    } finally {","+      setSpinning(false);","     }","+  }, [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm]);"," ","+  // Claim payout for winning round (manual trigger)","+  const claimPayout = useCallback(async () => {","+    if (!publicKey || !activeRound || !activeRoundMeta) {","+      setError(\"No active round to claim.\");","+      return;","+    }","+","     setClaiming(true);","+    setError(null);","     try {","-      // Simulate transaction delay","-      await new Promise((resolve) => setTimeout(resolve, 1000));","+      const tx = await buildClaimPayoutTx(","+        connection,","+        publicKey,","+        activeRound.tier,","+        activeRoundMeta.roundNumber,","+      );","+      await sendAndConfirm(tx);"," ","-      // Mark round as claimed","-      setActiveRound((prev) => prev ? { ...prev, claimed: true } : null);","+      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);"," ","-      // After claiming, auto-transition back to lobby","-      setTimeout(() => {","+      // Auto-transition back to lobby","+      completionTimeoutRef.current = setTimeout(() => {","+        completionTimeoutRef.current = null;","         setActiveRound(null);","-        refreshRoundsRef.current();","-      }, 2000);","+        setActiveRoundMeta(null);","+        void refreshRounds();","+      }, 5000);","+    } catch (err) {","+      setError(parseTransactionError(err));","     } finally {","       setClaiming(false);","     }","-  }, [activeRound, address]);","+  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);"," ","-  // Leave round (just clears UI - funds are already committed)","+  // Leave round (just clears UI — funds are committed on-chain)","   const leaveRound = useCallback(() => {","+    if (completionTimeoutRef.current) {","+      clearTimeout(completionTimeoutRef.current);","+      completionTimeoutRef.current = null;","+    }","     setActiveRound(null);","+    setActiveRoundMeta(null);","     setUserLeftRound(true);","-    refreshRounds();","+    void refreshRounds();","   }, [refreshRounds]);"," ","-  // Check for existing active round on wallet connect","+  // Auto-select tier based on active round","   useEffect(() => {","-    if (address && !activeRound && !userLeftRound) {","-      const userRounds = getUserRounds(address);","-      const active = userRounds.find(","-        (r) => r.phase !== \"complete\"","-      );","-      if (active) {","-        const latest = getRound(active.id);","-        if (latest) {","-          setActiveRound(latest);","-        }","-      }","+    if (activeRound && !selectedTier) {","+      setSelectedTier(activeRound.tier);","     }","-  }, [address, activeRound, userLeftRound]);","+  }, [activeRound, selectedTier]);"," ","   // Reset userLeftRound when joining a new round","   useEffect(() => {"]},{"oldStart":269,"oldLines":12,"newStart":510,"newLines":39,"lines":["     }","   }, [activeRound]);"," ","-  // Auto-select tier based on active round","+  // Check for existing active round on wallet connect","+  // (look through tier statuses for a round where user is a participant)","   useEffect(() => {","-    if (activeRound && !selectedTier) {","-      setSelectedTier(activeRound.tier);","+    if (publicKey && !activeRound && !userLeftRound && tierStatuses.length > 0) {","+      const wallet = publicKey.toBase58();","+      for (const status of tierStatuses) {","+        if (","+          status.currentRound &&","+          status.currentRound.phase !== \"complete\" &&","+          status.currentRound.players.some((p) => p.address === wallet)","+        ) {","+          setActiveRound(status.currentRound);","+          // Derive round meta from the round","+          const tierIndex = TIER_VALUES[status.tier];","+          // We need the round number — fetch from config","+          void (async () => {","+            try {","+              const { getLordProgram, getConfigPda } = await import(\"../utils/chain\");","+              const program = getLordProgram(connection);","+              const [configPda] = getConfigPda();","+              const config = await program.account.lordConfig.fetch(configPda);","+              const configData = config as unknown as { roundCounters: { toNumber(): number }[] };","+              const roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber() - 1);","+              setActiveRoundMeta({ tierIndex, roundNumber });","+            } catch {","+              // Ignore — meta will be set on next poll","+            }","+          })();","+          break;","+        }","+      }","     }","-  }, [activeRound, selectedTier]);","+  }, [publicKey, activeRound, userLeftRound, tierStatuses, connection]);"," ","   const value: LordOfRngsContextValue = {","     activeRound,"]},{"oldStart":286,"oldLines":10,"newStart":554,"newLines":14,"lines":["     joining,","     buyingMore,","     claiming,","+    spinning,","+    error,","+    clearError,","     setSelectedTier,","     setEntryCount,","     joinTierRound,","     buyMoreEntriesAction,","+    startSpin,","     claimPayout,","     leaveRound,","     refreshRounds,"]}],"originalFile":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { Round, TierStatus } from \"../types\";\nimport {\n  joinRound,\n  buyMoreEntries,\n  getRound,\n  getAllTierRounds,\n  subscribeToRound,\n  getUserRounds,\n  initializeMockRounds,\n} from \"../utils/mock-simulation\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\ninterface LordOfRngsContextValue {\n  // State\n  activeRound: Round | null;\n  tierStatuses: TierStatus[];\n  userHistory: Round[];\n  selectedTier: Tier | null;\n  entryCount: number;\n\n  // Loading states\n  loading: boolean;\n  joining: boolean;\n  buyingMore: boolean;\n  claiming: boolean;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setEntryCount: (count: number) => void;\n  joinTierRound: () => Promise<void>;\n  buyMoreEntriesAction: (entries: number) => Promise<void>;\n  claimPayout: () => Promise<void>;\n  leaveRound: () => void;\n  refreshRounds: () => void;\n}\n\nconst LordOfRngsContext = createContext<LordOfRngsContextValue | null>(null);\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\nexport function LordOfRngsProvider({ children }: { children: ReactNode }) {\n  const { connected, address } = useWallet();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [entryCount, setEntryCount] = useState(1);\n\n  // Round state\n  const [activeRound, setActiveRound] = useState<Round | null>(null);\n  const [tierStatuses, setTierStatuses] = useState<TierStatus[]>([]);\n  const [userHistory, setUserHistory] = useState<Round[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [joining, setJoining] = useState(false);\n  const [buyingMore, setBuyingMore] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n\n  // Track if user explicitly left the round\n  const [userLeftRound, setUserLeftRound] = useState(false);\n\n  // Ref to prevent multiple completion timeouts\n  const completionTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n  // Ref to access refreshRounds without adding it to effect dependencies\n  const refreshRoundsRef = useRef<() => void>(() => {});\n\n  // Refresh tier statuses\n  const refreshRounds = useCallback(() => {\n    const allRounds = getAllTierRounds();\n    const statuses: TierStatus[] = TIERS.map((tier) => {\n      const round = allRounds.get(tier) ?? null;\n      return {\n        tier,\n        entryAmount: round?.entryAmount ?? 0,\n        currentRound: round,\n      };\n    });\n    setTierStatuses(statuses);\n\n    // Update history\n    if (address) {\n      const history = getUserRounds(address)\n        .filter((r) => r.phase === \"complete\")\n        .sort((a, b) => (b.completedAt ?? b.createdAt) - (a.completedAt ?? a.createdAt));\n      setUserHistory(history);\n    }\n  }, [address]);\n\n  // Keep refreshRoundsRef updated\n  useEffect(() => {\n    refreshRoundsRef.current = refreshRounds;\n  }, [refreshRounds]);\n\n  // Initialize mock rounds\n  useEffect(() => {\n    setLoading(true);\n    initializeMockRounds();\n    refreshRounds();\n    setLoading(false);\n  }, [refreshRounds]);\n\n  // Poll for round updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshRounds();\n    }, 2000);\n    return () => clearInterval(interval);\n  }, [refreshRounds]);\n\n  // Subscribe to active round updates\n  useEffect(() => {\n    if (!activeRound) return;\n\n    // Clear any pending completion timeout when subscribing to a new round\n    if (completionTimeoutRef.current) {\n      clearTimeout(completionTimeoutRef.current);\n      completionTimeoutRef.current = null;\n    }\n\n    const unsubscribe = subscribeToRound(activeRound.id, (updated) => {\n      // If round is complete and user is winner, auto-claim immediately\n      // This eliminates the need for a manual \"Claim Payout\" button\n      if (updated.phase === \"complete\" && updated.winner === address && !updated.claimed) {\n        setActiveRound({ ...updated, claimed: true });\n      } else {\n        setActiveRound(updated);\n      }\n\n      // If round is complete, auto-transition back to lobby after showing the result\n      // Use ref to prevent scheduling multiple timeouts\n      if (updated.phase === \"complete\" && !completionTimeoutRef.current) {\n        const isWinner = updated.winner === address;\n\n        // Auto-transition after a brief delay (winners see result longer)\n        completionTimeoutRef.current = setTimeout(() => {\n          completionTimeoutRef.current = null;\n          setActiveRound(null);\n          refreshRoundsRef.current();\n        }, isWinner ? 3000 : 1500); // Winners see \"You Won!\" for 3s\n      }\n    });\n\n    return () => {\n      unsubscribe();\n      // Clear timeout on cleanup to prevent stale callbacks\n      if (completionTimeoutRef.current) {\n        clearTimeout(completionTimeoutRef.current);\n        completionTimeoutRef.current = null;\n      }\n    };\n  }, [activeRound?.id]);\n\n  // Join a tier's round\n  const joinTierRound = useCallback(async () => {\n    if (!connected || !address) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier) {\n      throw new Error(\"Select a tier first\");\n    }\n    if (entryCount < 1) {\n      throw new Error(\"Select at least 1 entry\");\n    }\n\n    setJoining(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      const round = joinRound(selectedTier, address, entryCount, true);\n      setActiveRound(round);\n      setUserLeftRound(false);\n\n      // Refresh tier statuses\n      refreshRounds();\n    } finally {\n      setJoining(false);\n    }\n  }, [connected, address, selectedTier, entryCount, refreshRounds]);\n\n  // Buy more entries in current round\n  const buyMoreEntriesAction = useCallback(\n    async (entries: number) => {\n      if (!connected || !address || !activeRound) {\n        throw new Error(\"No active round\");\n      }\n\n      setBuyingMore(true);\n      try {\n        // Simulate transaction delay\n        await new Promise((resolve) => setTimeout(resolve, 500));\n\n        const updated = buyMoreEntries(activeRound.id, address, entries);\n        setActiveRound(updated);\n\n        // Refresh tier statuses\n        refreshRounds();\n      } finally {\n        setBuyingMore(false);\n      }\n    },\n    [connected, address, activeRound, refreshRounds]\n  );\n\n  // Claim payout for winning round\n  const claimPayout = useCallback(async () => {\n    if (!activeRound || activeRound.phase !== \"complete\") {\n      throw new Error(\"No completed round to claim\");\n    }\n    if (activeRound.winner !== address) {\n      throw new Error(\"You are not the winner\");\n    }\n\n    setClaiming(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 1000));\n\n      // Mark round as claimed\n      setActiveRound((prev) => prev ? { ...prev, claimed: true } : null);\n\n      // After claiming, auto-transition back to lobby\n      setTimeout(() => {\n        setActiveRound(null);\n        refreshRoundsRef.current();\n      }, 2000);\n    } finally {\n      setClaiming(false);\n    }\n  }, [activeRound, address]);\n\n  // Leave round (just clears UI - funds are already committed)\n  const leaveRound = useCallback(() => {\n    setActiveRound(null);\n    setUserLeftRound(true);\n    refreshRounds();\n  }, [refreshRounds]);\n\n  // Check for existing active round on wallet connect\n  useEffect(() => {\n    if (address && !activeRound && !userLeftRound) {\n      const userRounds = getUserRounds(address);\n      const active = userRounds.find(\n        (r) => r.phase !== \"complete\"\n      );\n      if (active) {\n        const latest = getRound(active.id);\n        if (latest) {\n          setActiveRound(latest);\n        }\n      }\n    }\n  }, [address, activeRound, userLeftRound]);\n\n  // Reset userLeftRound when joining a new round\n  useEffect(() => {\n    if (activeRound) {\n      setUserLeftRound(false);\n    }\n  }, [activeRound]);\n\n  // Auto-select tier based on active round\n  useEffect(() => {\n    if (activeRound && !selectedTier) {\n      setSelectedTier(activeRound.tier);\n    }\n  }, [activeRound, selectedTier]);\n\n  const value: LordOfRngsContextValue = {\n    activeRound,\n    tierStatuses,\n    userHistory,\n    selectedTier,\n    entryCount,\n    loading,\n    joining,\n    buyingMore,\n    claiming,\n    setSelectedTier,\n    setEntryCount,\n    joinTierRound,\n    buyMoreEntriesAction,\n    claimPayout,\n    leaveRound,\n    refreshRounds,\n  };\n\n  return (\n    <LordOfRngsContext.Provider value={value}>\n      {children}\n    </LordOfRngsContext.Provider>\n  );\n}\n\nexport function useLordOfRngs(): LordOfRngsContextValue {\n  const context = useContext(LordOfRngsContext);\n  if (!context) {\n    throw new Error(\"useLordOfRngs must be used within LordOfRngsProvider\");\n  }\n  return context;\n}\n"}}
