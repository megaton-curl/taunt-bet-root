{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J5Uo9CrWb5To6C5KPtosVv","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  TIER_VALUES,\n    11→  COIN_SIDE_VALUES,\n    12→  TIER_AMOUNTS,\n    13→  type Tier,\n    14→  type CoinSide,\n    15→} from \"@rng-utopia/game-engine/browser\";\n    16→import type { UIMatch } from \"../types\";\n    17→\n    18→// ============ Constants ============\n    19→\n    20→const COINFLIP_PROGRAM_ID = new PublicKey(\n    21→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    22→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    23→);\n    24→\n    25→// Orao VRF program (on-chain VRF provider)\n    26→const ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n    27→\n    28→// ============ PDA Derivation ============\n    29→\n    30→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer()],\n    33→    COINFLIP_PROGRAM_ID\n    34→  );\n    35→}\n    36→\n    37→export function getConfigPda(): [PublicKey, number] {\n    38→  return PublicKey.findProgramAddressSync(\n    39→    [Buffer.from(\"coinflip_config\")],\n    40→    COINFLIP_PROGRAM_ID\n    41→  );\n    42→}\n    43→\n    44→/** Orao VRF network state PDA (stores config + treasury). */\n    45→function getOraoNetworkStatePda(): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    48→    ORAO_VRF_PROGRAM_ID\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→/** Orao VRF randomness PDA derived from a 32-byte seed. */\n    54→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    55→  const [pda] = PublicKey.findProgramAddressSync(\n    56→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    57→    ORAO_VRF_PROGRAM_ID\n    58→  );\n    59→  return pda;\n    60→}\n    61→\n    62→// ============ Program Instance ============\n    63→\n    64→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    65→  // Read-only provider (no wallet needed for queries)\n    66→  const provider = new AnchorProvider(\n    67→    connection,\n    68→    {} as AnchorProvider[\"wallet\"],\n    69→    { commitment: \"confirmed\" }\n    70→  );\n    71→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    72→}\n    73→\n    74→// ============ On-Chain Account Types ============\n    75→\n    76→/** Anchor enum variant representation — one key with empty object value. */\n    77→type RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n    78→  | { resolving: object } | { settled: object } | { refunded: object };\n    79→\n    80→interface OnChainMatch {\n    81→  creator: PublicKey;\n    82→  opponent: PublicKey;\n    83→  tier: number;\n    84→  entryAmount: { toNumber(): number };\n    85→  creatorSide: number;\n    86→  phase: RoundPhaseVariant;\n    87→  result: number;\n    88→  winner: PublicKey;\n    89→  claimed: boolean;\n    90→  createdAt: { toNumber(): number };\n    91→  lockedAt: { toNumber(): number };\n    92→  resolveDeadline: { toNumber(): number };\n    93→  vrfRequestKey: PublicKey;\n    94→  bump: number;\n    95→}\n    96→\n    97→// ============ Converters ============\n    98→\n    99→function tierFromIndex(index: number): Tier {\n   100→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   101→  return tiers[index] ?? \"iron\";\n   102→}\n   103→\n   104→function sideFromIndex(index: number): CoinSide {\n   105→  return index === 0 ? \"heads\" : \"tails\";\n   106→}\n   107→\n   108→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   109→  return name in phase;\n   110→}\n   111→\n   112→function phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n   113→  if (isPhase(phase, \"waiting\")) return \"created\";\n   114→  if (isPhase(phase, \"locked\")) return \"ready\";\n   115→  if (isPhase(phase, \"settled\")) return \"complete\";\n   116→  return \"created\";\n   117→}\n   118→\n   119→const DEFAULT_PUBKEY = PublicKey.default;\n   120→\n   121→function isDefaultPubkey(key: PublicKey): boolean {\n   122→  return key.equals(DEFAULT_PUBKEY);\n   123→}\n   124→\n   125→export function onChainMatchToUI(\n   126→  matchPda: PublicKey,\n   127→  data: OnChainMatch\n   128→): UIMatch {\n   129→  const tier = tierFromIndex(data.tier);\n   130→  const creatorSide = sideFromIndex(data.creatorSide);\n   131→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   132→  const phase = phaseToUI(data.phase);\n   133→  const isSettled = isPhase(data.phase, \"settled\");\n   134→\n   135→  const entryAmountSol = TIER_AMOUNTS[tier];\n   136→  const totalPool = entryAmountSol * 2;\n   137→  const payoutAmount = totalPool * 0.97;\n   138→\n   139→  const lockedAt = data.lockedAt.toNumber();\n   140→\n   141→  return {\n   142→    id: matchPda.toBase58(),\n   143→    tier,\n   144→    entryAmount: entryAmountSol,\n   145→    player1: data.creator.toBase58(),\n   146→    player1Side: creatorSide,\n   147→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   148→    player2Side: hasOpponent\n   149→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   150→      : null,\n   151→    phase,\n   152→    createdAt: Date.now(),\n   153→    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n   154→    result: isSettled ? sideFromIndex(data.result) : null,\n   155→    winner: isSettled && !isDefaultPubkey(data.winner)\n   156→      ? data.winner.toBase58()\n   157→      : null,\n   158→    claimed: data.claimed,\n   159→    payoutAmount,\n   160→    seedHash: \"\",\n   161→  };\n   162→}\n   163→\n   164→/** Read fulfilled VRF randomness bytes from an Orao randomness account.\n   165→ *  Returns the first randomness byte (used for coin flip result) or null if not fulfilled. */\n   166→async function readVrfRandomness(\n   167→  connection: Connection,\n   168→  vrfRequestKey: PublicKey\n   169→): Promise<number | null> {\n   170→  try {\n   171→    if (isDefaultPubkey(vrfRequestKey)) return null;\n   172→    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n   173→    if (vrfAccount && vrfAccount.data.length > 8) {\n   174→      // Orao randomness account: 8-byte discriminator then randomness data.\n   175→      const randomnessData = vrfAccount.data.subarray(8, 72);\n   176→      if (randomnessData.some((b: number) => b !== 0)) {\n   177→        return randomnessData[0] ?? null;\n   178→      }\n   179→    }\n   180→  } catch {\n   181→    // Ignore — treat as not fulfilled\n   182→  }\n   183→  return null;\n   184→}\n   185→\n   186→/** Derive client-side winner from VRF randomness for a locked match. */\n   187→function deriveWinnerFromVrf(\n   188→  firstByte: number,\n   189→  data: OnChainMatch\n   190→): { result: CoinSide; winner: string } {\n   191→  const resultSide = firstByte % 2; // 0 = heads, 1 = tails — matches on-chain from_randomness()\n   192→  const creatorWins = resultSide === data.creatorSide;\n   193→  return {\n   194→    result: sideFromIndex(resultSide),\n   195→    winner: creatorWins\n   196→      ? data.creator.toBase58()\n   197→      : data.opponent.toBase58(),\n   198→  };\n   199→}\n   200→\n   201→// ============ Account Queries ============\n   202→\n   203→export async function fetchAllOpenMatches(\n   204→  connection: Connection\n   205→): Promise<UIMatch[]> {\n   206→  const program = getCoinflipProgram(connection);\n   207→  const accounts = await program.account.coinflipMatch.all();\n   208→\n   209→  return accounts\n   210→    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n   211→    .map((acc) =>\n   212→      onChainMatchToUI(\n   213→        acc.publicKey,\n   214→        acc.account as unknown as OnChainMatch\n   215→      )\n   216→    );\n   217→}\n   218→\n   219→/**\n   220→ * Fetch all matches where playerPubkey is creator OR opponent,\n   221→ * claimed == false, and phase is non-terminal (not refunded).\n   222→ * Uses memcmp filters for efficient on-chain filtering.\n   223→ *\n   224→ * Account layout offsets (after 8-byte discriminator):\n   225→ *   creator:  8   (32 bytes)\n   226→ *   opponent: 40  (32 bytes)\n   227→ *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n   228→ */\n   229→export async function fetchClaimableMatches(\n   230→  connection: Connection,\n   231→  playerPubkey: PublicKey\n   232→): Promise<UIMatch[]> {\n   233→  const program = getCoinflipProgram(connection);\n   234→  const playerBase58 = playerPubkey.toBase58();\n   235→\n   236→  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n   237→  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n   238→\n   239→  const [asCreator, asOpponent] = await Promise.all([\n   240→    program.account.coinflipMatch.all([\n   241→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   242→      claimedFalseFilter,\n   243→    ]),\n   244→    program.account.coinflipMatch.all([\n   245→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   246→      claimedFalseFilter,\n   247→    ]),\n   248→  ]);\n   249→\n   250→  // Merge and deduplicate by public key\n   251→  const seen = new Set<string>();\n   252→  const matches: UIMatch[] = [];\n   253→\n   254→  for (const acc of [...asCreator, ...asOpponent]) {\n   255→    const key = acc.publicKey.toBase58();\n   256→    if (seen.has(key)) continue;\n   257→    seen.add(key);\n   258→\n   259→    const data = acc.account as unknown as OnChainMatch;\n   260→    // Skip terminal phase (refunded)\n   261→    if (isPhase(data.phase, \"refunded\")) continue;\n   262→\n   263→    const match = onChainMatchToUI(acc.publicKey, data);\n   264→\n   265→    // Upgrade Locked → complete when VRF has resolved, deriving winner client-side\n   266→    const vrfByte = isPhase(data.phase, \"locked\")\n   267→      ? await readVrfRandomness(connection, data.vrfRequestKey)\n   268→      : null;\n   269→    if (vrfByte !== null) {\n   270→      const derived = deriveWinnerFromVrf(vrfByte, data);\n   271→      matches.push({ ...match, phase: \"complete\", result: derived.result, winner: derived.winner });\n   272→    } else {\n   273→      matches.push(match);\n   274→    }\n   275→  }\n   276→\n   277→  return matches;\n   278→}\n   279→\n   280→export async function fetchMatchByCreator(\n   281→  connection: Connection,\n   282→  creator: PublicKey\n   283→): Promise<UIMatch | null> {\n   284→  const program = getCoinflipProgram(connection);\n   285→  const [matchPda] = getMatchPda(creator);\n   286→\n   287→  try {\n   288→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   289→    const data = account as unknown as OnChainMatch;\n   290→    const match = onChainMatchToUI(matchPda, data);\n   291→\n   292→    const vrfByte = isPhase(data.phase, \"locked\")\n   293→      ? await readVrfRandomness(connection, data.vrfRequestKey)\n   294→      : null;\n   295→    if (vrfByte !== null) {\n   296→      const derived = deriveWinnerFromVrf(vrfByte, data);\n   297→      return { ...match, phase: \"complete\", result: derived.result, winner: derived.winner };\n   298→    }\n   299→\n   300→    return match;\n   301→  } catch {\n   302→    // Account doesn't exist\n   303→    return null;\n   304→  }\n   305→}\n   306→\n   307→export async function fetchMatch(\n   308→  connection: Connection,\n   309→  matchPda: PublicKey\n   310→): Promise<UIMatch | null> {\n   311→  const program = getCoinflipProgram(connection);\n   312→\n   313→  try {\n   314→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   315→    const data = account as unknown as OnChainMatch;\n   316→    const match = onChainMatchToUI(matchPda, data);\n   317→\n   318→    // If on-chain phase is Locked but VRF has resolved, show as \"complete\"\n   319→    // so the Settle button appears instead of Cancel & Refund.\n   320→    const vrfByte = isPhase(data.phase, \"locked\")\n   321→      ? await readVrfRandomness(connection, data.vrfRequestKey)\n   322→      : null;\n   323→    if (vrfByte !== null) {\n   324→      const derived = deriveWinnerFromVrf(vrfByte, data);\n   325→      return { ...match, phase: \"complete\", result: derived.result, winner: derived.winner };\n   326→    }\n   327→\n   328→    return match;\n   329→  } catch {\n   330→    return null;\n   331→  }\n   332→}\n   333→\n   334→// ============ Instruction Builders ============\n   335→\n   336→export async function buildCreateMatchTx(\n   337→  connection: Connection,\n   338→  creator: PublicKey,\n   339→  tier: Tier,\n   340→  side: CoinSide\n   341→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   342→  const program = getCoinflipProgram(connection);\n   343→  const [matchPda] = getMatchPda(creator);\n   344→  const [configPda] = getConfigPda();\n   345→\n   346→  const tierIndex = TIER_VALUES[tier];\n   347→  const sideIndex = COIN_SIDE_VALUES[side];\n   348→\n   349→  const ix = await program.methods\n   350→    .createMatch(tierIndex, sideIndex)\n   351→    .accountsStrict({\n   352→      creator,\n   353→      coinflipMatch: matchPda,\n   354→      config: configPda,\n   355→      systemProgram: SystemProgram.programId,\n   356→    })\n   357→    .instruction();\n   358→\n   359→  const tx = new Transaction().add(ix);\n   360→  tx.feePayer = creator;\n   361→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   362→\n   363→  return { transaction: tx, matchPda };\n   364→}\n   365→\n   366→export async function buildJoinMatchTx(\n   367→  connection: Connection,\n   368→  opponent: PublicKey,\n   369→  matchCreator: PublicKey\n   370→): Promise<Transaction> {\n   371→  const program = getCoinflipProgram(connection);\n   372→  const [matchPda] = getMatchPda(matchCreator);\n   373→  const [configPda] = getConfigPda();\n   374→\n   375→  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n   376→  const oraoNetworkState = getOraoNetworkStatePda();\n   377→  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n   378→  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n   379→  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n   380→  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n   381→  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n   382→\n   383→  const ix = await program.methods\n   384→    .joinMatch()\n   385→    .accountsStrict({\n   386→      opponent,\n   387→      coinflipMatch: matchPda,\n   388→      config: configPda,\n   389→      oraoProgram: ORAO_VRF_PROGRAM_ID,\n   390→      oraoNetworkState,\n   391→      oraoTreasury,\n   392→      oraoRandom,\n   393→      systemProgram: SystemProgram.programId,\n   394→    })\n   395→    .instruction();\n   396→\n   397→  const tx = new Transaction().add(ix);\n   398→  tx.feePayer = opponent;\n   399→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   400→\n   401→  return tx;\n   402→}\n   403→\n   404→export async function buildCancelMatchTx(\n   405→  connection: Connection,\n   406→  creator: PublicKey\n   407→): Promise<Transaction> {\n   408→  const program = getCoinflipProgram(connection);\n   409→  const [matchPda] = getMatchPda(creator);\n   410→\n   411→  const ix = await program.methods\n   412→    .cancelMatch()\n   413→    .accountsStrict({\n   414→      creator,\n   415→      coinflipMatch: matchPda,\n   416→      systemProgram: SystemProgram.programId,\n   417→    })\n   418→    .instruction();\n   419→\n   420→  const tx = new Transaction().add(ix);\n   421→  tx.feePayer = creator;\n   422→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   423→\n   424→  return tx;\n   425→}\n   426→\n   427→export async function buildTimeoutCancelTx(\n   428→  connection: Connection,\n   429→  caller: PublicKey,\n   430→  matchCreator: PublicKey,\n   431→  opponent: PublicKey\n   432→): Promise<Transaction> {\n   433→  const program = getCoinflipProgram(connection);\n   434→  const [matchPda] = getMatchPda(matchCreator);\n   435→\n   436→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   437→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   438→\n   439→  const ix = await program.methods\n   440→    .timeoutCancel()\n   441→    .accountsStrict({\n   442→      caller,\n   443→      creator: matchCreator,\n   444→      opponent,\n   445→      coinflipMatch: matchPda,\n   446→      randomnessAccount,\n   447→    })\n   448→    .instruction();\n   449→\n   450→  const tx = new Transaction().add(ix);\n   451→  tx.feePayer = caller;\n   452→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   453→\n   454→  return tx;\n   455→}\n   456→\n   457→export async function buildClaimPayoutTx(\n   458→  connection: Connection,\n   459→  caller: PublicKey,\n   460→  matchCreator: PublicKey,\n   461→  opponent: PublicKey\n   462→): Promise<Transaction> {\n   463→  const program = getCoinflipProgram(connection);\n   464→  const [matchPda] = getMatchPda(matchCreator);\n   465→  const [configPda] = getConfigPda();\n   466→\n   467→  // Fetch config to get treasury address\n   468→  const config = await program.account.coinflipConfig.fetch(configPda);\n   469→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   470→\n   471→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   472→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   473→\n   474→  // Derive player profile PDAs for CPI\n   475→  const PLATFORM_PROGRAM_ID = new PublicKey(\n   476→    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n   477→      .VITE_PLATFORM_PROGRAM_ID ?? \"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n   478→  );\n   479→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   480→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   481→    PLATFORM_PROGRAM_ID\n   482→  );\n   483→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   484→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   485→    PLATFORM_PROGRAM_ID\n   486→  );\n   487→\n   488→  const ix = await program.methods\n   489→    .claimPayout()\n   490→    .accountsStrict({\n   491→      caller,\n   492→      coinflipMatch: matchPda,\n   493→      config: configPda,\n   494→      treasury,\n   495→      creator: matchCreator,\n   496→      opponent,\n   497→      randomnessAccount,\n   498→      creatorProfile,\n   499→      opponentProfile,\n   500→      platformProgram: PLATFORM_PROGRAM_ID,\n   501→      systemProgram: SystemProgram.programId,\n   502→    })\n   503→    .instruction();\n   504→\n   505→  const tx = new Transaction().add(ix);\n   506→  tx.feePayer = caller;\n   507→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   508→\n   509→  return tx;\n   510→}\n   511→"}]},"parent_tool_use_id":"toolu_01AZyj4jyCw1fFzBnyX8zXaG","session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"a2808b37-0185-4a90-8a96-a2595679690a"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01Rx2i2y4UVGZJK6f4zbEvUS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LnKTNHc36abJhgzRzVMStD","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/mock-simulation.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":1101,"cache_read_input_tokens":30208,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1101},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_011hWagSCWKM3xzAZh1D33d9","session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"20391bf6-b1aa-4cfe-bfb8-b5d15a191d97"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01UYke4WBJwEp1nsHaRDrsVB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01P35iyXDTAYoDEByHXAiPNT","name":"Glob","input":{"pattern":"**/CoinflipContext.tsx","path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":3109,"cache_read_input_tokens":20975,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3109},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01AZyj4jyCw1fFzBnyX8zXaG","session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"2ff815ea-48f0-42c2-b1da-4fc52951b72b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LnKTNHc36abJhgzRzVMStD","type":"tool_result","content":"     1→import { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\n     2→import type { Round, PlayerEntry } from \"../types\";\n     3→import { PLAYER_COLORS } from \"../types\";\n     4→import { emitLordOfRngsComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\n     5→import { emitLordOfRngsResults } from \"../../player-profile/utils/profile-event-bus\";\n     6→\n     7→// ============ Constants ============\n     8→\n     9→const COUNTDOWN_DURATION = 60000; // 60 seconds\n    10→const SPIN_DURATION = 5000; // 5 seconds\n    11→const REVEAL_DURATION = 3000; // 3 seconds to show winner before new round\n    12→const MIN_PLAYERS = 2; // Minimum 2 different players (not just entries)\n    13→\n    14→const TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n    15→\n    16→// ============ Mock Store ============\n    17→\n    18→type TimerId = ReturnType<typeof setTimeout>;\n    19→\n    20→interface MockStore {\n    21→  rounds: Map<string, Round>; // roundId -> Round\n    22→  tierRounds: Map<Tier, string>; // tier -> current round ID\n    23→  listeners: Map<string, Set<(round: Round) => void>>;\n    24→  mockPlayerTimers: Map<string, TimerId[]>;\n    25→}\n    26→\n    27→const store: MockStore = {\n    28→  rounds: new Map(),\n    29→  tierRounds: new Map(),\n    30→  listeners: new Map(),\n    31→  mockPlayerTimers: new Map(),\n    32→};\n    33→\n    34→// ============ Helpers ============\n    35→\n    36→function generateRoundId(): string {\n    37→  return `lotr-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n    38→}\n    39→\n    40→function generateMockAddress(): string {\n    41→  const chars = \"123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz\";\n    42→  let addr = \"\";\n    43→  for (let i = 0; i < 44; i++) {\n    44→    addr += chars[Math.floor(Math.random() * chars.length)];\n    45→  }\n    46→  return addr;\n    47→}\n    48→\n    49→// Generate a mock hex string (simulates SHA-256 hash or seed)\n    50→function generateMockHexString(length: number = 64): string {\n    51→  const chars = \"0123456789abcdef\";\n    52→  let result = \"\";\n    53→  for (let i = 0; i < length; i++) {\n    54→    result += chars[Math.floor(Math.random() * chars.length)];\n    55→  }\n    56→  return result;\n    57→}\n    58→\n    59→// Generate mock provably fair data\n    60→function generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string; vrfProof: string } {\n    61→  const serverSeed = generateMockHexString(64); // 256-bit seed\n    62→  const seedHash = generateMockHexString(64); // SHA-256 hash of server seed\n    63→  const blockHash = generateMockHexString(88); // Solana blockhash format\n    64→  const vrfProof = generateMockHexString(128); // VRF proof\n    65→  return { seedHash, serverSeed, blockHash, vrfProof };\n    66→}\n    67→\n    68→export function truncateAddress(address: string): string {\n    69→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n    70→}\n    71→\n    72→function getPlayerColor(index: number, isCurrentUser: boolean): string {\n    73→  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\"; // Neon green for current user\n    74→  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n    75→}\n    76→\n    77→function calculatePayout(poolAmount: number): number {\n    78→  return poolAmount * 0.97; // 97% after 3% fee\n    79→}\n    80→\n    81→function notifyListeners(roundId: string, round: Round): void {\n    82→  const listeners = store.listeners.get(roundId);\n    83→  if (listeners) {\n    84→    const roundCopy = { ...round, players: [...round.players] };\n    85→    listeners.forEach((cb) => cb(roundCopy));\n    86→  }\n    87→}\n    88→\n    89→// ============ Round Management ============\n    90→\n    91→// Store for server seeds (revealed after settlement)\n    92→const serverSeeds = new Map<string, { serverSeed: string; blockHash: string; vrfProof: string }>();\n    93→\n    94→function createRound(tier: Tier): Round {\n    95→  const id = generateRoundId();\n    96→  const fairnessData = generateFairnessData();\n    97→\n    98→  // Store the secret data to reveal later\n    99→  serverSeeds.set(id, {\n   100→    serverSeed: fairnessData.serverSeed,\n   101→    blockHash: fairnessData.blockHash,\n   102→    vrfProof: fairnessData.vrfProof,\n   103→  });\n   104→\n   105→  const round: Round = {\n   106→    id,\n   107→    tier,\n   108→    entryAmount: TIER_AMOUNTS[tier],\n   109→    phase: \"waiting\",\n   110→    players: [],\n   111→    totalEntries: 0,\n   112→    poolAmount: 0,\n   113→    createdAt: Date.now(),\n   114→    seedHash: fairnessData.seedHash, // Public from the start\n   115→  };\n   116→\n   117→  store.rounds.set(id, round);\n   118→  store.tierRounds.set(tier, id);\n   119→\n   120→  return round;\n   121→}\n   122→\n   123→export function getOrCreateRound(tier: Tier): Round {\n   124→  const existingRoundId = store.tierRounds.get(tier);\n   125→  if (existingRoundId) {\n   126→    const existing = store.rounds.get(existingRoundId);\n   127→    if (existing && existing.phase !== \"complete\") {\n   128→      return existing;\n   129→    }\n   130→  }\n   131→\n   132→  return createRound(tier);\n   133→}\n   134→\n   135→export function getRound(roundId: string): Round | undefined {\n   136→  return store.rounds.get(roundId);\n   137→}\n   138→\n   139→export function getRoundByTier(tier: Tier): Round | undefined {\n   140→  const roundId = store.tierRounds.get(tier);\n   141→  return roundId ? store.rounds.get(roundId) : undefined;\n   142→}\n   143→\n   144→export function getAllTierRounds(): Map<Tier, Round> {\n   145→  const result = new Map<Tier, Round>();\n   146→  for (const tier of TIERS) {\n   147→    const round = getOrCreateRound(tier);\n   148→    result.set(tier, round);\n   149→  }\n   150→  return result;\n   151→}\n   152→\n   153→// ============ Player Actions ============\n   154→\n   155→export function joinRound(\n   156→  tier: Tier,\n   157→  playerAddress: string,\n   158→  entries: number,\n   159→  isCurrentUser: boolean = false\n   160→): Round {\n   161→  const round = getOrCreateRound(tier);\n   162→\n   163→  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n   164→    throw new Error(\"Cannot join round in this phase\");\n   165→  }\n   166→\n   167→  // Check if player already exists\n   168→  const existingPlayer = round.players.find((p) => p.address === playerAddress);\n   169→\n   170→  if (existingPlayer) {\n   171→    // Add more entries\n   172→    existingPlayer.entries += entries;\n   173→  } else {\n   174→    // New player\n   175→    const colorIndex = round.players.length;\n   176→    const player: PlayerEntry = {\n   177→      address: playerAddress,\n   178→      entries,\n   179→      color: getPlayerColor(colorIndex, isCurrentUser),\n   180→    };\n   181→    round.players.push(player);\n   182→  }\n   183→\n   184→  round.totalEntries += entries;\n   185→  round.poolAmount += entries * round.entryAmount;\n   186→\n   187→  // Emit wager placed event (triggers RNG buff chest drop check)\n   188→  const wagerAmount = entries * round.entryAmount;\n   189→  emitWagerPlaced(\"lord-of-rngs\", round.id, playerAddress, wagerAmount);\n   190→\n   191→  store.rounds.set(round.id, round);\n   192→  notifyListeners(round.id, round);\n   193→\n   194→  // Check if we should start countdown (2+ players)\n   195→  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n   196→    startCountdown(round.id);\n   197→  }\n   198→\n   199→  // If in waiting phase and this is a real user, schedule mock players\n   200→  if (round.phase === \"waiting\" && isCurrentUser) {\n   201→    scheduleMockPlayers(round.id);\n   202→  }\n   203→\n   204→  return round;\n   205→}\n   206→\n   207→export function buyMoreEntries(\n   208→  roundId: string,\n   209→  playerAddress: string,\n   210→  entries: number\n   211→): Round {\n   212→  const round = store.rounds.get(roundId);\n   213→  if (!round) throw new Error(\"Round not found\");\n   214→\n   215→  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n   216→    throw new Error(\"Cannot buy entries in this phase\");\n   217→  }\n   218→\n   219→  const player = round.players.find((p) => p.address === playerAddress);\n   220→  if (!player) throw new Error(\"Player not in this round\");\n   221→\n   222→  player.entries += entries;\n   223→  round.totalEntries += entries;\n   224→  round.poolAmount += entries * round.entryAmount;\n   225→\n   226→  // Emit wager placed event (triggers RNG buff chest drop check)\n   227→  const wagerAmount = entries * round.entryAmount;\n   228→  emitWagerPlaced(\"lord-of-rngs\", roundId, playerAddress, wagerAmount);\n   229→\n   230→  store.rounds.set(roundId, round);\n   231→  notifyListeners(roundId, round);\n   232→\n   233→  return round;\n   234→}\n   235→\n   236→// ============ Phase Transitions ============\n   237→\n   238→function startCountdown(roundId: string): void {\n   239→  const round = store.rounds.get(roundId);\n   240→  if (!round || round.phase !== \"waiting\") return;\n   241→\n   242→  round.phase = \"countdown\";\n   243→  round.countdownStartedAt = Date.now();\n   244→  round.countdownEndsAt = Date.now() + COUNTDOWN_DURATION;\n   245→\n   246→  store.rounds.set(roundId, round);\n   247→  notifyListeners(roundId, round);\n   248→\n   249→  // Schedule spin when countdown ends\n   250→  setTimeout(() => startSpinning(roundId), COUNTDOWN_DURATION);\n   251→\n   252→  // Schedule more mock players during countdown\n   253→  scheduleMockPlayersDuringCountdown(roundId);\n   254→}\n   255→\n   256→function startSpinning(roundId: string): void {\n   257→  const round = store.rounds.get(roundId);\n   258→  if (!round || round.phase !== \"countdown\") return;\n   259→\n   260→  // Cancel any pending mock player timers\n   261→  cancelMockPlayerTimers(roundId);\n   262→\n   263→  // Simulate VRF - pick a random winning slot\n   264→  const winningSlot = Math.floor(Math.random() * round.totalEntries);\n   265→\n   266→  round.phase = \"spinning\";\n   267→  round.winningSlot = winningSlot;\n   268→\n   269→  store.rounds.set(roundId, round);\n   270→  notifyListeners(roundId, round);\n   271→\n   272→  // Reveal winner after spin animation\n   273→  setTimeout(() => resolveRound(roundId), SPIN_DURATION);\n   274→}\n   275→\n   276→function resolveRound(roundId: string): void {\n   277→  const round = store.rounds.get(roundId);\n   278→  if (!round || round.phase !== \"spinning\") return;\n   279→\n   280→  // Determine winner based on winning slot\n   281→  let slotCount = 0;\n   282→  let winner: string | undefined;\n   283→\n   284→  for (const player of round.players) {\n   285→    slotCount += player.entries;\n   286→    if (round.winningSlot! < slotCount && !winner) {\n   287→      winner = player.address;\n   288→    }\n   289→  }\n   290→\n   291→  // Reveal the fairness data now that the round is settled\n   292→  const secrets = serverSeeds.get(roundId);\n   293→  if (secrets) {\n   294→    round.serverSeed = secrets.serverSeed;\n   295→    round.blockHash = secrets.blockHash;\n   296→    round.vrfProof = secrets.vrfProof;\n   297→  }\n   298→\n   299→  // First enter revealing phase to show the winner\n   300→  round.phase = \"revealing\";\n   301→  round.winner = winner;\n   302→  round.payoutAmount = calculatePayout(round.poolAmount);\n   303→\n   304→  store.rounds.set(roundId, round);\n   305→  notifyListeners(roundId, round);\n   306→\n   307→  // After reveal duration, complete the round and start new one\n   308→  setTimeout(() => completeRound(roundId), REVEAL_DURATION);\n   309→}\n   310→\n   311→function completeRound(roundId: string): void {\n   312→  const round = store.rounds.get(roundId);\n   313→  if (!round || round.phase !== \"revealing\") return;\n   314→\n   315→  round.phase = \"complete\";\n   316→  round.completedAt = Date.now();\n   317→\n   318→  store.rounds.set(roundId, round);\n   319→  notifyListeners(roundId, round);\n   320→\n   321→  // Emit event for Boss Raid\n   322→  if (round.players.length > 0) {\n   323→    const entries = round.players.map((p) => ({\n   324→      address: p.address,\n   325→      entries: p.entries,\n   326→    }));\n   327→    emitLordOfRngsComplete(roundId, entries, round.entryAmount);\n   328→  }\n   329→\n   330→  // Emit event for Player Profile (XP and stats tracking)\n   331→  if (round.players.length > 0 && round.winner) {\n   332→    const participants = round.players.map((p) => ({\n   333→      address: p.address,\n   334→      totalWager: p.entries * round.entryAmount,\n   335→    }));\n   336→    emitLordOfRngsResults(\n   337→      roundId,\n   338→      round.winner,\n   339→      participants,\n   340→      round.payoutAmount ?? 0,\n   341→      round.tier\n   342→    );\n   343→  }\n   344→\n   345→  // Create a new round for this tier immediately\n   346→  store.tierRounds.delete(round.tier);\n   347→  const newRound = getOrCreateRound(round.tier);\n   348→\n   349→  // Schedule mock players for the new round to keep game alive\n   350→  scheduleMockPlayers(newRound.id);\n   351→}\n   352→\n   353→// ============ Mock Player Simulation ============\n   354→\n   355→function scheduleMockPlayers(roundId: string): void {\n   356→  const round = store.rounds.get(roundId);\n   357→  if (!round) return;\n   358→\n   359→  // Schedule 1-3 mock players to join over next 3-8 seconds\n   360→  const mockCount = 1 + Math.floor(Math.random() * 3);\n   361→  const timers: TimerId[] = [];\n   362→\n   363→  for (let i = 0; i < mockCount; i++) {\n   364→    const delay = 3000 + Math.random() * 5000;\n   365→    const timer = setTimeout(() => addMockPlayer(roundId), delay);\n   366→    timers.push(timer);\n   367→  }\n   368→\n   369→  store.mockPlayerTimers.set(roundId, timers);\n   370→}\n   371→\n   372→function scheduleMockPlayersDuringCountdown(roundId: string): void {\n   373→  const round = store.rounds.get(roundId);\n   374→  if (!round) return;\n   375→\n   376→  // Schedule 2-5 more mock players during countdown\n   377→  const mockCount = 2 + Math.floor(Math.random() * 4);\n   378→  const existingTimers = store.mockPlayerTimers.get(roundId) ?? [];\n   379→\n   380→  for (let i = 0; i < mockCount; i++) {\n   381→    const delay = 5000 + Math.random() * 45000; // Spread over first 50s of countdown\n   382→    const timer = setTimeout(() => {\n   383→      const r = store.rounds.get(roundId);\n   384→      if (r?.phase === \"countdown\") {\n   385→        addMockPlayer(roundId);\n   386→      }\n   387→    }, delay);\n   388→    existingTimers.push(timer);\n   389→  }\n   390→\n   391→  store.mockPlayerTimers.set(roundId, existingTimers);\n   392→}\n   393→\n   394→function addMockPlayer(roundId: string): void {\n   395→  const round = store.rounds.get(roundId);\n   396→  if (!round || (round.phase !== \"waiting\" && round.phase !== \"countdown\")) return;\n   397→\n   398→  const address = generateMockAddress();\n   399→  const entries = 1 + Math.floor(Math.random() * 3); // 1-3 entries\n   400→\n   401→  const colorIndex = round.players.length;\n   402→  const player: PlayerEntry = {\n   403→    address,\n   404→    entries,\n   405→    color: getPlayerColor(colorIndex, false),\n   406→  };\n   407→\n   408→  round.players.push(player);\n   409→  round.totalEntries += entries;\n   410→  round.poolAmount += entries * round.entryAmount;\n   411→\n   412→  store.rounds.set(roundId, round);\n   413→  notifyListeners(roundId, round);\n   414→\n   415→  // Start countdown if we now have enough players\n   416→  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n   417→    startCountdown(roundId);\n   418→  }\n   419→}\n   420→\n   421→function cancelMockPlayerTimers(roundId: string): void {\n   422→  const timers = store.mockPlayerTimers.get(roundId);\n   423→  if (timers) {\n   424→    timers.forEach(clearTimeout);\n   425→    store.mockPlayerTimers.delete(roundId);\n   426→  }\n   427→}\n   428→\n   429→// ============ Subscription ============\n   430→\n   431→export function subscribeToRound(\n   432→  roundId: string,\n   433→  callback: (round: Round) => void\n   434→): () => void {\n   435→  if (!store.listeners.has(roundId)) {\n   436→    store.listeners.set(roundId, new Set());\n   437→  }\n   438→  store.listeners.get(roundId)!.add(callback);\n   439→\n   440→  return () => {\n   441→    store.listeners.get(roundId)?.delete(callback);\n   442→  };\n   443→}\n   444→\n   445→// ============ User History ============\n   446→\n   447→export function getUserRounds(playerAddress: string): Round[] {\n   448→  const rounds: Round[] = [];\n   449→\n   450→  store.rounds.forEach((round) => {\n   451→    if (round.players.some((p) => p.address === playerAddress)) {\n   452→      rounds.push(round);\n   453→    }\n   454→  });\n   455→\n   456→  return rounds.sort((a, b) => b.createdAt - a.createdAt);\n   457→}\n   458→\n   459→// ============ Initialize Mock Rounds ============\n   460→\n   461→export function initializeMockRounds(): void {\n   462→  // Create initial rounds for each tier with some mock players\n   463→  for (const tier of TIERS) {\n   464→    const round = getOrCreateRound(tier);\n   465→\n   466→    // Add 0-3 initial mock players to each tier\n   467→    const initialPlayers = Math.floor(Math.random() * 4);\n   468→    for (let i = 0; i < initialPlayers; i++) {\n   469→      const address = generateMockAddress();\n   470→      const entries = 1 + Math.floor(Math.random() * 2);\n   471→      const player: PlayerEntry = {\n   472→        address,\n   473→        entries,\n   474→        color: getPlayerColor(i, false),\n   475→      };\n   476→      round.players.push(player);\n   477→      round.totalEntries += entries;\n   478→      round.poolAmount += entries * round.entryAmount;\n   479→    }\n   480→\n   481→    store.rounds.set(round.id, round);\n   482→\n   483→    // Start countdown if 2+ players already exist\n   484→    if (round.players.length >= MIN_PLAYERS) {\n   485→      startCountdown(round.id);\n   486→    } else if (round.players.length >= 1) {\n   487→      // Schedule more mock players to eventually start the round\n   488→      scheduleMockPlayers(round.id);\n   489→    }\n   490→  }\n   491→}\n   492→"}]},"parent_tool_use_id":"toolu_011hWagSCWKM3xzAZh1D33d9","session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"c3158614-cb9f-4d0d-a09a-6b2b1deba167"}
