{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rok2RaEw6kFJCaJcQQzZnX","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey, type Transaction } from \"@solana/web3.js\";\n    11→import { TIER_VALUES, type Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { Round, TierStatus } from \"../types\";\n    13→import {\n    14→  fetchAllTierRounds,\n    15→  fetchRound,\n    16→  buildCreateRoundTx,\n    17→  buildJoinRoundTx,\n    18→  buildBuyMoreEntriesTx,\n    19→  buildStartSpinTx,\n    20→  buildClaimPayoutTx,\n    21→  getRoundPda,\n    22→} from \"../utils/chain\";\n    23→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    24→\n    25→/** Parse transaction errors into user-friendly messages */\n    26→function parseTransactionError(err: unknown): string {\n    27→  const msg = err instanceof Error ? err.message : String(err);\n    28→\n    29→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    30→    return \"Wallet not connected. Please connect your wallet first.\";\n    31→  }\n    32→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    33→    return \"Transaction cancelled by user.\";\n    34→  }\n    35→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    36→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    37→  }\n    38→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    39→    return \"Network error. Please check your connection and try again.\";\n    40→  }\n    41→  if (msg.includes(\"InvalidPhase\")) {\n    42→    return \"This round is no longer accepting entries.\";\n    43→  }\n    44→  if (msg.includes(\"MaxPlayersReached\")) {\n    45→    return \"This round is full (max 20 players).\";\n    46→  }\n    47→  if (msg.includes(\"PlayerAlreadyInRound\")) {\n    48→    return \"You are already in this round. Use 'Buy More' to add entries.\";\n    49→  }\n    50→  if (msg.includes(\"CountdownNotExpired\")) {\n    51→    return \"Countdown has not finished yet.\";\n    52→  }\n    53→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    54→    return \"Transaction simulation failed. The round state may have changed.\";\n    55→  }\n    56→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    57→    return \"Transaction expired. Please try again.\";\n    58→  }\n    59→\n    60→  console.error(\"[lord-of-rngs] unhandled transaction error:\", err);\n    61→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    62→}\n    63→\n    64→/** Metadata for the active round needed to build transactions */\n    65→interface RoundMeta {\n    66→  tierIndex: number;\n    67→  roundNumber: bigint;\n    68→}\n    69→\n    70→interface LordOfRngsContextValue {\n    71→  // State\n    72→  activeRound: Round | null;\n    73→  tierStatuses: TierStatus[];\n    74→  userHistory: Round[];\n    75→  selectedTier: Tier | null;\n    76→  entryCount: number;\n    77→\n    78→  // Loading states\n    79→  loading: boolean;\n    80→  joining: boolean;\n    81→  buyingMore: boolean;\n    82→  claiming: boolean;\n    83→  spinning: boolean;\n    84→\n    85→  // Error state\n    86→  error: string | null;\n    87→  clearError: () => void;\n    88→\n    89→  // Actions\n    90→  setSelectedTier: (tier: Tier | null) => void;\n    91→  setEntryCount: (count: number) => void;\n    92→  joinTierRound: () => Promise<void>;\n    93→  buyMoreEntriesAction: (entries: number) => Promise<void>;\n    94→  startSpin: () => Promise<void>;\n    95→  claimPayout: () => Promise<void>;\n    96→  leaveRound: () => void;\n    97→  refreshRounds: () => void;\n    98→}\n    99→\n   100→const LordOfRngsContext = createContext<LordOfRngsContextValue | null>(null);\n   101→\n   102→const TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   103→\n   104→export function LordOfRngsProvider({ children }: { children: ReactNode }) {\n   105→  const { connected, publicKey, sendTransaction } = useWallet();\n   106→  const { connection } = useConnection();\n   107→  const { refresh: refreshBalance } = useBalance();\n   108→\n   109→  // Selection state\n   110→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   111→  const [entryCount, setEntryCount] = useState(1);\n   112→\n   113→  // Round state\n   114→  const [activeRound, setActiveRound] = useState<Round | null>(null);\n   115→  const [activeRoundMeta, setActiveRoundMeta] = useState<RoundMeta | null>(null);\n   116→  const [tierStatuses, setTierStatuses] = useState<TierStatus[]>([]);\n   117→  const [userHistory] = useState<Round[]>([]);\n   118→\n   119→  // Loading states\n   120→  const [loading, setLoading] = useState(true);\n   121→  const [joining, setJoining] = useState(false);\n   122→  const [buyingMore, setBuyingMore] = useState(false);\n   123→  const [claiming, setClaiming] = useState(false);\n   124→  const [spinning, setSpinning] = useState(false);\n   125→\n   126→  // Error state\n   127→  const [error, setError] = useState<string | null>(null);\n   128→  const clearError = useCallback(() => setError(null), []);\n   129→\n   130→  // Track if user explicitly left the round\n   131→  const [userLeftRound, setUserLeftRound] = useState(false);\n   132→\n   133→  // Ref to prevent multiple completion timeouts\n   134→  const completionTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n   135→  const refreshInFlightRef = useRef(false);\n   136→\n   137→  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n   138→  const sendAndConfirm = useCallback(\n   139→    async (transaction: Transaction): Promise<string> => {\n   140→      const { blockhash, lastValidBlockHeight } =\n   141→        await connection.getLatestBlockhash(\"confirmed\");\n   142→      transaction.recentBlockhash = blockhash;\n   143→      const signature = await sendTransaction(transaction);\n   144→      await connection.confirmTransaction(\n   145→        { signature, blockhash, lastValidBlockHeight },\n   146→        \"confirmed\",\n   147→      );\n   148→      await refreshBalance();\n   149→      return signature;\n   150→    },\n   151→    [connection, sendTransaction, refreshBalance],\n   152→  );\n   153→\n   154→  // Refresh tier statuses from on-chain\n   155→  const refreshRounds = useCallback(async () => {\n   156→    if (refreshInFlightRef.current) return;\n   157→    refreshInFlightRef.current = true;\n   158→\n   159→    try {\n   160→      const wallet = publicKey?.toBase58();\n   161→      const allRounds = await fetchAllTierRounds(connection, wallet);\n   162→      const statuses: TierStatus[] = TIERS.map((tier) => {\n   163→        const round = allRounds.get(tier) ?? null;\n   164→        return {\n   165→          tier,\n   166→          entryAmount: round?.entryAmount ?? 0,\n   167→          currentRound: round,\n   168→        };\n   169→      });\n   170→      setTierStatuses(statuses);\n   171→    } catch {\n   172→      // Ignore transient RPC failures; polling will retry\n   173→    } finally {\n   174→      setLoading(false);\n   175→      refreshInFlightRef.current = false;\n   176→    }\n   177→  }, [connection, publicKey]);\n   178→\n   179→  // Initial load\n   180→  useEffect(() => {\n   181→    setLoading(true);\n   182→    void refreshRounds();\n   183→  }, [refreshRounds]);\n   184→\n   185→  // Poll for updates — faster when in active round, slower for lobby\n   186→  const pollInterval = activeRound ? 5000 : 15000;\n   187→\n   188→  useEffect(() => {\n   189→    const interval = setInterval(() => {\n   190→      if (activeRound && activeRoundMeta) {\n   191→        // Poll the active round account\n   192→        fetchRound(\n   193→          connection,\n   194→          activeRoundMeta.tierIndex,\n   195→          activeRoundMeta.roundNumber,\n   196→          publicKey?.toBase58()\n   197→        )\n   198→          .then((updated) => {\n   199→            if (!updated) {\n   200→              // Round account closed (claimed or cancelled) — return to lobby\n   201→              setActiveRound(null);\n   202→              setActiveRoundMeta(null);\n   203→              void refreshRounds();\n   204→              return;\n   205→            }\n   206→\n   207→            setActiveRound(updated);\n   208→\n   209→            // If round is complete (revealing phase from VRF fulfillment),\n   210→            // auto-claim if we're the winner\n   211→            if (\n   212→              updated.phase === \"revealing\" &&\n   213→              updated.winner === publicKey?.toBase58() &&\n   214→              !updated.claimed &&\n   215→              !claiming\n   216→            ) {\n   217→              // Auto-trigger claim\n   218→              void handleAutoClaim();\n   219→            }\n   220→\n   221→            // If round is complete and we're not the winner,\n   222→            // auto-transition back to lobby after showing result\n   223→            if (\n   224→              updated.phase === \"complete\" &&\n   225→              !completionTimeoutRef.current\n   226→            ) {\n   227→              const isWinner = updated.winner === publicKey?.toBase58();\n   228→              completionTimeoutRef.current = setTimeout(() => {\n   229→                completionTimeoutRef.current = null;\n   230→                setActiveRound(null);\n   231→                setActiveRoundMeta(null);\n   232→                void refreshRounds();\n   233→              }, isWinner ? 5000 : 3000);\n   234→            }\n   235→          })\n   236→          .catch(() => {\n   237→            // Ignore polling errors\n   238→          });\n   239→      } else {\n   240→        // Lobby: poll tier statuses\n   241→        void refreshRounds();\n   242→      }\n   243→    }, pollInterval);\n   244→    return () => clearInterval(interval);\n   245→    // eslint-disable-next-line react-hooks/exhaustive-deps\n   246→  }, [refreshRounds, activeRound, activeRoundMeta, connection, pollInterval, publicKey, claiming]);\n   247→\n   248→  // Cleanup completion timeout on unmount\n   249→  useEffect(() => {\n   250→    return () => {\n   251→      if (completionTimeoutRef.current) {\n   252→        clearTimeout(completionTimeoutRef.current);\n   253→      }\n   254→    };\n   255→  }, []);\n   256→\n   257→  /** Auto-claim payout when the player wins */\n   258→  const handleAutoClaim = useCallback(async () => {\n   259→    if (!publicKey || !activeRound || !activeRoundMeta) return;\n   260→\n   261→    setClaiming(true);\n   262→    setError(null);\n   263→    try {\n   264→      const tx = await buildClaimPayoutTx(\n   265→        connection,\n   266→        publicKey,\n   267→        activeRound.tier,\n   268→        activeRoundMeta.roundNumber,\n   269→      );\n   270→      await sendAndConfirm(tx);\n   271→\n   272→      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n   273→\n   274→      // Auto-transition back to lobby after showing win result\n   275→      completionTimeoutRef.current = setTimeout(() => {\n   276→        completionTimeoutRef.current = null;\n   277→        setActiveRound(null);\n   278→        setActiveRoundMeta(null);\n   279→        void refreshRounds();\n   280→      }, 5000);\n   281→    } catch (err) {\n   282→      // If auto-claim fails, user can manually retry\n   283→      setError(parseTransactionError(err));\n   284→    } finally {\n   285→      setClaiming(false);\n   286→    }\n   287→  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n   288→\n   289→  // Join a tier's round\n   290→  const joinTierRound = useCallback(async () => {\n   291→    if (!connected || !publicKey) {\n   292→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   293→      return;\n   294→    }\n   295→    if (!selectedTier) {\n   296→      setError(\"Select a tier first.\");\n   297→      return;\n   298→    }\n   299→    if (entryCount < 1) {\n   300→      setError(\"Select at least 1 entry.\");\n   301→      return;\n   302→    }\n   303→\n   304→    setJoining(true);\n   305→    setError(null);\n   306→    try {\n   307→      // Check if a round exists for this tier\n   308→      const wallet = publicKey.toBase58();\n   309→      const allRounds = await fetchAllTierRounds(connection, wallet);\n   310→      const existingRound = allRounds.get(selectedTier);\n   311→\n   312→      let roundPda: PublicKey;\n   313→      let roundNumber: bigint;\n   314→      let tierIndex: number;\n   315→\n   316→      if (existingRound && existingRound.phase !== \"complete\") {\n   317→        // Join existing round\n   318→        tierIndex = TIER_VALUES[selectedTier];\n   319→        // We need to find the round number — fetch config to derive it\n   320→        // The existing round PDA encodes the round number, but we need to\n   321→        // look it up from the on-chain account. The simplest way: the config\n   322→        // has round counters, and the active round is counter - 1.\n   323→        const { getLordProgram } = await import(\"../utils/chain\");\n   324→        const program = getLordProgram(connection);\n   325→        const [configPda] = (await import(\"../utils/chain\")).getConfigPda();\n   326→        const config = await program.account.lordConfig.fetch(configPda);\n   327→        const configData = config as unknown as { roundCounters: { toNumber(): number }[] };\n   328→        // Active round is the last created = counter - 1\n   329→        roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber() - 1);\n   330→\n   331→        const tx = await buildJoinRoundTx(\n   332→          connection,\n   333→          publicKey,\n   334→          selectedTier,\n   335→          entryCount,\n   336→          roundNumber,\n   337→        );\n   338→        await sendAndConfirm(tx);\n   339→\n   340→        [roundPda] = getRoundPda(tierIndex, roundNumber);\n   341→      } else {\n   342→        // Create a new round (we are the first player)\n   343→        const result = await buildCreateRoundTx(\n   344→          connection,\n   345→          publicKey,\n   346→          selectedTier,\n   347→          entryCount,\n   348→        );\n   349→        await sendAndConfirm(result.transaction);\n   350→\n   351→        roundPda = result.roundPda;\n   352→        roundNumber = result.roundNumber;\n   353→        tierIndex = TIER_VALUES[selectedTier];\n   354→      }\n   355→\n   356→      // Fetch the round we just joined/created\n   357→      const round = await fetchRound(\n   358→        connection,\n   359→        tierIndex,\n   360→        roundNumber,\n   361→        publicKey.toBase58(),\n   362→      );\n   363→      if (round) {\n   364→        setActiveRound(round);\n   365→        setActiveRoundMeta({ tierIndex, roundNumber });\n   366→        setUserLeftRound(false);\n   367→      }\n   368→\n   369→      void refreshRounds();\n   370→    } catch (err) {\n   371→      setError(parseTransactionError(err));\n   372→    } finally {\n   373→      setJoining(false);\n   374→    }\n   375→  }, [connected, publicKey, selectedTier, entryCount, connection, sendAndConfirm, refreshRounds]);\n   376→\n   377→  // Buy more entries in current round\n   378→  const buyMoreEntriesAction = useCallback(\n   379→    async (entries: number) => {\n   380→      if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n   381→        setError(\"No active round.\");\n   382→        return;\n   383→      }\n   384→\n   385→      setBuyingMore(true);\n   386→      setError(null);\n   387→      try {\n   388→        const tx = await buildBuyMoreEntriesTx(\n   389→          connection,\n   390→          publicKey,\n   391→          activeRound.tier,\n   392→          activeRoundMeta.roundNumber,\n   393→          entries,\n   394→        );\n   395→        await sendAndConfirm(tx);\n   396→\n   397→        // Refresh active round\n   398→        const updated = await fetchRound(\n   399→          connection,\n   400→          activeRoundMeta.tierIndex,\n   401→          activeRoundMeta.roundNumber,\n   402→          publicKey.toBase58(),\n   403→        );\n   404→        if (updated) {\n   405→          setActiveRound(updated);\n   406→        }\n   407→\n   408→        void refreshRounds();\n   409→      } catch (err) {\n   410→        setError(parseTransactionError(err));\n   411→      } finally {\n   412→        setBuyingMore(false);\n   413→      }\n   414→    },\n   415→    [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds],\n   416→  );\n   417→\n   418→  // Start the VRF spin (permissionless — any player can trigger after countdown)\n   419→  const startSpin = useCallback(async () => {\n   420→    if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n   421→      setError(\"No active round.\");\n   422→      return;\n   423→    }\n   424→\n   425→    setSpinning(true);\n   426→    setError(null);\n   427→    try {\n   428→      const tx = await buildStartSpinTx(\n   429→        connection,\n   430→        publicKey,\n   431→        activeRound.tier,\n   432→        activeRoundMeta.roundNumber,\n   433→      );\n   434→      await sendAndConfirm(tx);\n   435→\n   436→      // Refresh active round — should now be in \"spinning\" phase\n   437→      const updated = await fetchRound(\n   438→        connection,\n   439→        activeRoundMeta.tierIndex,\n   440→        activeRoundMeta.roundNumber,\n   441→        publicKey.toBase58(),\n   442→      );\n   443→      if (updated) {\n   444→        setActiveRound(updated);\n   445→      }\n   446→    } catch (err) {\n   447→      setError(parseTransactionError(err));\n   448→    } finally {\n   449→      setSpinning(false);\n   450→    }\n   451→  }, [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm]);\n   452→\n   453→  // Claim payout for winning round (manual trigger)\n   454→  const claimPayout = useCallback(async () => {\n   455→    if (!publicKey || !activeRound || !activeRoundMeta) {\n   456→      setError(\"No active round to claim.\");\n   457→      return;\n   458→    }\n   459→\n   460→    setClaiming(true);\n   461→    setError(null);\n   462→    try {\n   463→      const tx = await buildClaimPayoutTx(\n   464→        connection,\n   465→        publicKey,\n   466→        activeRound.tier,\n   467→        activeRoundMeta.roundNumber,\n   468→      );\n   469→      await sendAndConfirm(tx);\n   470→\n   471→      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n   472→\n   473→      // Auto-transition back to lobby\n   474→      completionTimeoutRef.current = setTimeout(() => {\n   475→        completionTimeoutRef.current = null;\n   476→        setActiveRound(null);\n   477→        setActiveRoundMeta(null);\n   478→        void refreshRounds();\n   479→      }, 5000);\n   480→    } catch (err) {\n   481→      setError(parseTransactionError(err));\n   482→    } finally {\n   483→      setClaiming(false);\n   484→    }\n   485→  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n   486→\n   487→  // Leave round (just clears UI — funds are committed on-chain)\n   488→  const leaveRound = useCallback(() => {\n   489→    if (completionTimeoutRef.current) {\n   490→      clearTimeout(completionTimeoutRef.current);\n   491→      completionTimeoutRef.current = null;\n   492→    }\n   493→    setActiveRound(null);\n   494→    setActiveRoundMeta(null);\n   495→    setUserLeftRound(true);\n   496→    void refreshRounds();\n   497→  }, [refreshRounds]);\n   498→\n   499→  // Auto-select tier based on active round\n   500→  useEffect(() => {\n   501→    if (activeRound && !selectedTier) {\n   502→      setSelectedTier(activeRound.tier);\n   503→    }\n   504→  }, [activeRound, selectedTier]);\n   505→\n   506→  // Reset userLeftRound when joining a new round\n   507→  useEffect(() => {\n   508→    if (activeRound) {\n   509→      setUserLeftRound(false);\n   510→    }\n   511→  }, [activeRound]);\n   512→\n   513→  // Check for existing active round on wallet connect\n   514→  // (look through tier statuses for a round where user is a participant)\n   515→  useEffect(() => {\n   516→    if (publicKey && !activeRound && !userLeftRound && tierStatuses.length > 0) {\n   517→      const wallet = publicKey.toBase58();\n   518→      for (const status of tierStatuses) {\n   519→        if (\n   520→          status.currentRound &&\n   521→          status.currentRound.phase !== \"complete\" &&\n   522→          status.currentRound.players.some((p) => p.address === wallet)\n   523→        ) {\n   524→          setActiveRound(status.currentRound);\n   525→          // Derive round meta from the round\n   526→          const tierIndex = TIER_VALUES[status.tier];\n   527→          // We need the round number — fetch from config\n   528→          void (async () => {\n   529→            try {\n   530→              const { getLordProgram, getConfigPda } = await import(\"../utils/chain\");\n   531→              const program = getLordProgram(connection);\n   532→              const [configPda] = getConfigPda();\n   533→              const config = await program.account.lordConfig.fetch(configPda);\n   534→              const configData = config as unknown as { roundCounters: { toNumber(): number }[] };\n   535→              const roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber() - 1);\n   536→              setActiveRoundMeta({ tierIndex, roundNumber });\n   537→            } catch {\n   538→              // Ignore — meta will be set on next poll\n   539→            }\n   540→          })();\n   541→          break;\n   542→        }\n   543→      }\n   544→    }\n   545→  }, [publicKey, activeRound, userLeftRound, tierStatuses, connection]);\n   546→\n   547→  const value: LordOfRngsContextValue = {\n   548→    activeRound,\n   549→    tierStatuses,\n   550→    userHistory,\n   551→    selectedTier,\n   552→    entryCount,\n   553→    loading,\n   554→    joining,\n   555→    buyingMore,\n   556→    claiming,\n   557→    spinning,\n   558→    error,\n   559→    clearError,\n   560→    setSelectedTier,\n   561→    setEntryCount,\n   562→    joinTierRound,\n   563→    buyMoreEntriesAction,\n   564→    startSpin,\n   565→    claimPayout,\n   566→    leaveRound,\n   567→    refreshRounds,\n   568→  };\n   569→\n   570→  return (\n   571→    <LordOfRngsContext.Provider value={value}>\n   572→      {children}\n   573→    </LordOfRngsContext.Provider>\n   574→  );\n   575→}\n   576→\n   577→export function useLordOfRngs(): LordOfRngsContextValue {\n   578→  const context = useContext(LordOfRngsContext);\n   579→  if (!context) {\n   580→    throw new Error(\"useLordOfRngs must be used within LordOfRngsProvider\");\n   581→  }\n   582→  return context;\n   583→}\n   584→"}]},"parent_tool_use_id":null,"session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"99b14cdf-0414-4b57-93a3-8f3e4038b872","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/context/LordOfRngsContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { PublicKey, type Transaction } from \"@solana/web3.js\";\nimport { TIER_VALUES, type Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { Round, TierStatus } from \"../types\";\nimport {\n  fetchAllTierRounds,\n  fetchRound,\n  buildCreateRoundTx,\n  buildJoinRoundTx,\n  buildBuyMoreEntriesTx,\n  buildStartSpinTx,\n  buildClaimPayoutTx,\n  getRoundPda,\n} from \"../utils/chain\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse transaction errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This round is no longer accepting entries.\";\n  }\n  if (msg.includes(\"MaxPlayersReached\")) {\n    return \"This round is full (max 20 players).\";\n  }\n  if (msg.includes(\"PlayerAlreadyInRound\")) {\n    return \"You are already in this round. Use 'Buy More' to add entries.\";\n  }\n  if (msg.includes(\"CountdownNotExpired\")) {\n    return \"Countdown has not finished yet.\";\n  }\n  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    return \"Transaction simulation failed. The round state may have changed.\";\n  }\n  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    return \"Transaction expired. Please try again.\";\n  }\n\n  console.error(\"[lord-of-rngs] unhandled transaction error:\", err);\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\n/** Metadata for the active round needed to build transactions */\ninterface RoundMeta {\n  tierIndex: number;\n  roundNumber: bigint;\n}\n\ninterface LordOfRngsContextValue {\n  // State\n  activeRound: Round | null;\n  tierStatuses: TierStatus[];\n  userHistory: Round[];\n  selectedTier: Tier | null;\n  entryCount: number;\n\n  // Loading states\n  loading: boolean;\n  joining: boolean;\n  buyingMore: boolean;\n  claiming: boolean;\n  spinning: boolean;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setEntryCount: (count: number) => void;\n  joinTierRound: () => Promise<void>;\n  buyMoreEntriesAction: (entries: number) => Promise<void>;\n  startSpin: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  leaveRound: () => void;\n  refreshRounds: () => void;\n}\n\nconst LordOfRngsContext = createContext<LordOfRngsContextValue | null>(null);\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\nexport function LordOfRngsProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [entryCount, setEntryCount] = useState(1);\n\n  // Round state\n  const [activeRound, setActiveRound] = useState<Round | null>(null);\n  const [activeRoundMeta, setActiveRoundMeta] = useState<RoundMeta | null>(null);\n  const [tierStatuses, setTierStatuses] = useState<TierStatus[]>([]);\n  const [userHistory] = useState<Round[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [joining, setJoining] = useState(false);\n  const [buyingMore, setBuyingMore] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [spinning, setSpinning] = useState(false);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Track if user explicitly left the round\n  const [userLeftRound, setUserLeftRound] = useState(false);\n\n  // Ref to prevent multiple completion timeouts\n  const completionTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n  const refreshInFlightRef = useRef(false);\n\n  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n      transaction.recentBlockhash = blockhash;\n      const signature = await sendTransaction(transaction);\n      await connection.confirmTransaction(\n        { signature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      await refreshBalance();\n      return signature;\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // Refresh tier statuses from on-chain\n  const refreshRounds = useCallback(async () => {\n    if (refreshInFlightRef.current) return;\n    refreshInFlightRef.current = true;\n\n    try {\n      const wallet = publicKey?.toBase58();\n      const allRounds = await fetchAllTierRounds(connection, wallet);\n      const statuses: TierStatus[] = TIERS.map((tier) => {\n        const round = allRounds.get(tier) ?? null;\n        return {\n          tier,\n          entryAmount: round?.entryAmount ?? 0,\n          currentRound: round,\n        };\n      });\n      setTierStatuses(statuses);\n    } catch {\n      // Ignore transient RPC failures; polling will retry\n    } finally {\n      setLoading(false);\n      refreshInFlightRef.current = false;\n    }\n  }, [connection, publicKey]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    void refreshRounds();\n  }, [refreshRounds]);\n\n  // Poll for updates — faster when in active round, slower for lobby\n  const pollInterval = activeRound ? 5000 : 15000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      if (activeRound && activeRoundMeta) {\n        // Poll the active round account\n        fetchRound(\n          connection,\n          activeRoundMeta.tierIndex,\n          activeRoundMeta.roundNumber,\n          publicKey?.toBase58()\n        )\n          .then((updated) => {\n            if (!updated) {\n              // Round account closed (claimed or cancelled) — return to lobby\n              setActiveRound(null);\n              setActiveRoundMeta(null);\n              void refreshRounds();\n              return;\n            }\n\n            setActiveRound(updated);\n\n            // If round is complete (revealing phase from VRF fulfillment),\n            // auto-claim if we're the winner\n            if (\n              updated.phase === \"revealing\" &&\n              updated.winner === publicKey?.toBase58() &&\n              !updated.claimed &&\n              !claiming\n            ) {\n              // Auto-trigger claim\n              void handleAutoClaim();\n            }\n\n            // If round is complete and we're not the winner,\n            // auto-transition back to lobby after showing result\n            if (\n              updated.phase === \"complete\" &&\n              !completionTimeoutRef.current\n            ) {\n              const isWinner = updated.winner === publicKey?.toBase58();\n              completionTimeoutRef.current = setTimeout(() => {\n                completionTimeoutRef.current = null;\n                setActiveRound(null);\n                setActiveRoundMeta(null);\n                void refreshRounds();\n              }, isWinner ? 5000 : 3000);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      } else {\n        // Lobby: poll tier statuses\n        void refreshRounds();\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n    // eslint-disable-next-line react-hooks/exhaustive-deps\n  }, [refreshRounds, activeRound, activeRoundMeta, connection, pollInterval, publicKey, claiming]);\n\n  // Cleanup completion timeout on unmount\n  useEffect(() => {\n    return () => {\n      if (completionTimeoutRef.current) {\n        clearTimeout(completionTimeoutRef.current);\n      }\n    };\n  }, []);\n\n  /** Auto-claim payout when the player wins */\n  const handleAutoClaim = useCallback(async () => {\n    if (!publicKey || !activeRound || !activeRoundMeta) return;\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const tx = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n\n      // Auto-transition back to lobby after showing win result\n      completionTimeoutRef.current = setTimeout(() => {\n        completionTimeoutRef.current = null;\n        setActiveRound(null);\n        setActiveRoundMeta(null);\n        void refreshRounds();\n      }, 5000);\n    } catch (err) {\n      // If auto-claim fails, user can manually retry\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n\n  // Join a tier's round\n  const joinTierRound = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier) {\n      setError(\"Select a tier first.\");\n      return;\n    }\n    if (entryCount < 1) {\n      setError(\"Select at least 1 entry.\");\n      return;\n    }\n\n    setJoining(true);\n    setError(null);\n    try {\n      // Check if a round exists for this tier\n      const wallet = publicKey.toBase58();\n      const allRounds = await fetchAllTierRounds(connection, wallet);\n      const existingRound = allRounds.get(selectedTier);\n\n      let roundPda: PublicKey;\n      let roundNumber: bigint;\n      let tierIndex: number;\n\n      if (existingRound && existingRound.phase !== \"complete\") {\n        // Join existing round\n        tierIndex = TIER_VALUES[selectedTier];\n        // We need to find the round number — fetch config to derive it\n        // The existing round PDA encodes the round number, but we need to\n        // look it up from the on-chain account. The simplest way: the config\n        // has round counters, and the active round is counter - 1.\n        const { getLordProgram } = await import(\"../utils/chain\");\n        const program = getLordProgram(connection);\n        const [configPda] = (await import(\"../utils/chain\")).getConfigPda();\n        const config = await program.account.lordConfig.fetch(configPda);\n        const configData = config as unknown as { roundCounters: { toNumber(): number }[] };\n        // Active round is the last created = counter - 1\n        roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber() - 1);\n\n        const tx = await buildJoinRoundTx(\n          connection,\n          publicKey,\n          selectedTier,\n          entryCount,\n          roundNumber,\n        );\n        await sendAndConfirm(tx);\n\n        [roundPda] = getRoundPda(tierIndex, roundNumber);\n      } else {\n        // Create a new round (we are the first player)\n        const result = await buildCreateRoundTx(\n          connection,\n          publicKey,\n          selectedTier,\n          entryCount,\n        );\n        await sendAndConfirm(result.transaction);\n\n        roundPda = result.roundPda;\n        roundNumber = result.roundNumber;\n        tierIndex = TIER_VALUES[selectedTier];\n      }\n\n      // Fetch the round we just joined/created\n      const round = await fetchRound(\n        connection,\n        tierIndex,\n        roundNumber,\n        publicKey.toBase58(),\n      );\n      if (round) {\n        setActiveRound(round);\n        setActiveRoundMeta({ tierIndex, roundNumber });\n        setUserLeftRound(false);\n      }\n\n      void refreshRounds();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setJoining(false);\n    }\n  }, [connected, publicKey, selectedTier, entryCount, connection, sendAndConfirm, refreshRounds]);\n\n  // Buy more entries in current round\n  const buyMoreEntriesAction = useCallback(\n    async (entries: number) => {\n      if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n        setError(\"No active round.\");\n        return;\n      }\n\n      setBuyingMore(true);\n      setError(null);\n      try {\n        const tx = await buildBuyMoreEntriesTx(\n          connection,\n          publicKey,\n          activeRound.tier,\n          activeRoundMeta.roundNumber,\n          entries,\n        );\n        await sendAndConfirm(tx);\n\n        // Refresh active round\n        const updated = await fetchRound(\n          connection,\n          activeRoundMeta.tierIndex,\n          activeRoundMeta.roundNumber,\n          publicKey.toBase58(),\n        );\n        if (updated) {\n          setActiveRound(updated);\n        }\n\n        void refreshRounds();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setBuyingMore(false);\n      }\n    },\n    [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds],\n  );\n\n  // Start the VRF spin (permissionless — any player can trigger after countdown)\n  const startSpin = useCallback(async () => {\n    if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n      setError(\"No active round.\");\n      return;\n    }\n\n    setSpinning(true);\n    setError(null);\n    try {\n      const tx = await buildStartSpinTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      // Refresh active round — should now be in \"spinning\" phase\n      const updated = await fetchRound(\n        connection,\n        activeRoundMeta.tierIndex,\n        activeRoundMeta.roundNumber,\n        publicKey.toBase58(),\n      );\n      if (updated) {\n        setActiveRound(updated);\n      }\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setSpinning(false);\n    }\n  }, [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm]);\n\n  // Claim payout for winning round (manual trigger)\n  const claimPayout = useCallback(async () => {\n    if (!publicKey || !activeRound || !activeRoundMeta) {\n      setError(\"No active round to claim.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const tx = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n\n      // Auto-transition back to lobby\n      completionTimeoutRef.current = setTimeout(() => {\n        completionTimeoutRef.current = null;\n        setActiveRound(null);\n        setActiveRoundMeta(null);\n        void refreshRounds();\n      }, 5000);\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n\n  // Leave round (just clears UI — funds are committed on-chain)\n  const leaveRound = useCallback(() => {\n    if (completionTimeoutRef.current) {\n      clearTimeout(completionTimeoutRef.current);\n      completionTimeoutRef.current = null;\n    }\n    setActiveRound(null);\n    setActiveRoundMeta(null);\n    setUserLeftRound(true);\n    void refreshRounds();\n  }, [refreshRounds]);\n\n  // Auto-select tier based on active round\n  useEffect(() => {\n    if (activeRound && !selectedTier) {\n      setSelectedTier(activeRound.tier);\n    }\n  }, [activeRound, selectedTier]);\n\n  // Reset userLeftRound when joining a new round\n  useEffect(() => {\n    if (activeRound) {\n      setUserLeftRound(false);\n    }\n  }, [activeRound]);\n\n  // Check for existing active round on wallet connect\n  // (look through tier statuses for a round where user is a participant)\n  useEffect(() => {\n    if (publicKey && !activeRound && !userLeftRound && tierStatuses.length > 0) {\n      const wallet = publicKey.toBase58();\n      for (const status of tierStatuses) {\n        if (\n          status.currentRound &&\n          status.currentRound.phase !== \"complete\" &&\n          status.currentRound.players.some((p) => p.address === wallet)\n        ) {\n          setActiveRound(status.currentRound);\n          // Derive round meta from the round\n          const tierIndex = TIER_VALUES[status.tier];\n          // We need the round number — fetch from config\n          void (async () => {\n            try {\n              const { getLordProgram, getConfigPda } = await import(\"../utils/chain\");\n              const program = getLordProgram(connection);\n              const [configPda] = getConfigPda();\n              const config = await program.account.lordConfig.fetch(configPda);\n              const configData = config as unknown as { roundCounters: { toNumber(): number }[] };\n              const roundNumber = BigInt(configData.roundCounters[tierIndex]!.toNumber() - 1);\n              setActiveRoundMeta({ tierIndex, roundNumber });\n            } catch {\n              // Ignore — meta will be set on next poll\n            }\n          })();\n          break;\n        }\n      }\n    }\n  }, [publicKey, activeRound, userLeftRound, tierStatuses, connection]);\n\n  const value: LordOfRngsContextValue = {\n    activeRound,\n    tierStatuses,\n    userHistory,\n    selectedTier,\n    entryCount,\n    loading,\n    joining,\n    buyingMore,\n    claiming,\n    spinning,\n    error,\n    clearError,\n    setSelectedTier,\n    setEntryCount,\n    joinTierRound,\n    buyMoreEntriesAction,\n    startSpin,\n    claimPayout,\n    leaveRound,\n    refreshRounds,\n  };\n\n  return (\n    <LordOfRngsContext.Provider value={value}>\n      {children}\n    </LordOfRngsContext.Provider>\n  );\n}\n\nexport function useLordOfRngs(): LordOfRngsContextValue {\n  const context = useContext(LordOfRngsContext);\n  if (!context) {\n    throw new Error(\"useLordOfRngs must be used within LordOfRngsProvider\");\n  }\n  return context;\n}\n","numLines":584,"startLine":1,"totalLines":584}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01H3ZpgjakxhXAYZgLF9Y6KH","type":"message","role":"assistant","content":[{"type":"text","text":"I see issues: the dynamic imports are messy and the `roundPda` variable at line 312 is declared but never used (only used indirectly through `getRoundPda`). Also, I should use static imports for `getLordProgram` and `getConfigPda`. Let me also deal with a potential issue: the `handleAutoClaim` function is defined after the `useEffect` that references it — that could cause issues. Let me fix these problems."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7342,"cache_read_input_tokens":91943,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7342},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"df6b0bf0-ab73-4d26-9038-ad0d73a11620"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01H3ZpgjakxhXAYZgLF9Y6KH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AJZcV64WUf7FNB3viz6ctT","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/context/LordOfRngsContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { type Transaction } from \"@solana/web3.js\";\nimport { TIER_VALUES, type Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { Round, TierStatus } from \"../types\";\nimport {\n  fetchAllTierRounds,\n  fetchRound,\n  buildCreateRoundTx,\n  buildJoinRoundTx,\n  buildBuyMoreEntriesTx,\n  buildStartSpinTx,\n  buildClaimPayoutTx,\n  getLordProgram,\n  getConfigPda,\n} from \"../utils/chain\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse transaction errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This round is no longer accepting entries.\";\n  }\n  if (msg.includes(\"MaxPlayersReached\")) {\n    return \"This round is full (max 20 players).\";\n  }\n  if (msg.includes(\"PlayerAlreadyInRound\")) {\n    return \"You are already in this round. Use 'Buy More' to add entries.\";\n  }\n  if (msg.includes(\"CountdownNotExpired\")) {\n    return \"Countdown has not finished yet.\";\n  }\n  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    return \"Transaction simulation failed. The round state may have changed.\";\n  }\n  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    return \"Transaction expired. Please try again.\";\n  }\n\n  console.error(\"[lord-of-rngs] unhandled transaction error:\", err);\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\n/** Metadata for the active round needed to build transactions */\ninterface RoundMeta {\n  tierIndex: number;\n  roundNumber: bigint;\n}\n\n/** Fetch the current round number for a tier from the on-chain config */\nasync function fetchRoundNumberForTier(\n  connection: Parameters<typeof getLordProgram>[0],\n  tierIndex: number,\n): Promise<bigint> {\n  const program = getLordProgram(connection);\n  const [configPda] = getConfigPda();\n  const config = await program.account.lordConfig.fetch(configPda);\n  const configData = config as unknown as { roundCounters: { toNumber(): number }[] };\n  // Active round is the last created = counter - 1\n  return BigInt(configData.roundCounters[tierIndex]!.toNumber() - 1);\n}\n\ninterface LordOfRngsContextValue {\n  // State\n  activeRound: Round | null;\n  tierStatuses: TierStatus[];\n  userHistory: Round[];\n  selectedTier: Tier | null;\n  entryCount: number;\n\n  // Loading states\n  loading: boolean;\n  joining: boolean;\n  buyingMore: boolean;\n  claiming: boolean;\n  spinning: boolean;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setEntryCount: (count: number) => void;\n  joinTierRound: () => Promise<void>;\n  buyMoreEntriesAction: (entries: number) => Promise<void>;\n  startSpin: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  leaveRound: () => void;\n  refreshRounds: () => void;\n}\n\nconst LordOfRngsContext = createContext<LordOfRngsContextValue | null>(null);\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\nexport function LordOfRngsProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [entryCount, setEntryCount] = useState(1);\n\n  // Round state\n  const [activeRound, setActiveRound] = useState<Round | null>(null);\n  const [activeRoundMeta, setActiveRoundMeta] = useState<RoundMeta | null>(null);\n  const [tierStatuses, setTierStatuses] = useState<TierStatus[]>([]);\n  const [userHistory] = useState<Round[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [joining, setJoining] = useState(false);\n  const [buyingMore, setBuyingMore] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [spinning, setSpinning] = useState(false);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Track if user explicitly left the round\n  const [userLeftRound, setUserLeftRound] = useState(false);\n\n  // Ref to prevent multiple completion timeouts\n  const completionTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n  const refreshInFlightRef = useRef(false);\n  // Ref to access latest claiming state in polling callback\n  const claimingRef = useRef(false);\n  useEffect(() => { claimingRef.current = claiming; }, [claiming]);\n\n  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n      transaction.recentBlockhash = blockhash;\n      const signature = await sendTransaction(transaction);\n      await connection.confirmTransaction(\n        { signature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      await refreshBalance();\n      return signature;\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // Refresh tier statuses from on-chain\n  const refreshRounds = useCallback(async () => {\n    if (refreshInFlightRef.current) return;\n    refreshInFlightRef.current = true;\n\n    try {\n      const wallet = publicKey?.toBase58();\n      const allRounds = await fetchAllTierRounds(connection, wallet);\n      const statuses: TierStatus[] = TIERS.map((tier) => {\n        const round = allRounds.get(tier) ?? null;\n        return {\n          tier,\n          entryAmount: round?.entryAmount ?? 0,\n          currentRound: round,\n        };\n      });\n      setTierStatuses(statuses);\n    } catch {\n      // Ignore transient RPC failures; polling will retry\n    } finally {\n      setLoading(false);\n      refreshInFlightRef.current = false;\n    }\n  }, [connection, publicKey]);\n\n  /** Auto-claim payout when the player wins */\n  const handleAutoClaim = useCallback(async () => {\n    if (!publicKey || !activeRound || !activeRoundMeta) return;\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const tx = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n\n      // Auto-transition back to lobby after showing win result\n      completionTimeoutRef.current = setTimeout(() => {\n        completionTimeoutRef.current = null;\n        setActiveRound(null);\n        setActiveRoundMeta(null);\n        void refreshRounds();\n      }, 5000);\n    } catch (err) {\n      // If auto-claim fails, user can manually retry via claimPayout\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    void refreshRounds();\n  }, [refreshRounds]);\n\n  // Poll for updates — faster when in active round, slower for lobby\n  const pollInterval = activeRound ? 5000 : 15000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      if (activeRound && activeRoundMeta) {\n        // Poll the active round account\n        fetchRound(\n          connection,\n          activeRoundMeta.tierIndex,\n          activeRoundMeta.roundNumber,\n          publicKey?.toBase58()\n        )\n          .then((updated) => {\n            if (!updated) {\n              // Round account closed (claimed or cancelled) — return to lobby\n              setActiveRound(null);\n              setActiveRoundMeta(null);\n              void refreshRounds();\n              return;\n            }\n\n            setActiveRound(updated);\n\n            // If VRF fulfilled (revealing phase) and we're the winner, auto-claim\n            if (\n              updated.phase === \"revealing\" &&\n              updated.winner === publicKey?.toBase58() &&\n              !updated.claimed &&\n              !claimingRef.current\n            ) {\n              void handleAutoClaim();\n            }\n\n            // If round settled and we're not the winner, auto-return to lobby\n            if (\n              updated.phase === \"complete\" &&\n              !completionTimeoutRef.current\n            ) {\n              const isWinner = updated.winner === publicKey?.toBase58();\n              completionTimeoutRef.current = setTimeout(() => {\n                completionTimeoutRef.current = null;\n                setActiveRound(null);\n                setActiveRoundMeta(null);\n                void refreshRounds();\n              }, isWinner ? 5000 : 3000);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      } else {\n        // Lobby: poll tier statuses\n        void refreshRounds();\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshRounds, activeRound, activeRoundMeta, connection, pollInterval, publicKey, handleAutoClaim]);\n\n  // Cleanup completion timeout on unmount\n  useEffect(() => {\n    return () => {\n      if (completionTimeoutRef.current) {\n        clearTimeout(completionTimeoutRef.current);\n      }\n    };\n  }, []);\n\n  // Join a tier's round\n  const joinTierRound = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier) {\n      setError(\"Select a tier first.\");\n      return;\n    }\n    if (entryCount < 1) {\n      setError(\"Select at least 1 entry.\");\n      return;\n    }\n\n    setJoining(true);\n    setError(null);\n    try {\n      // Check if a round exists for this tier\n      const wallet = publicKey.toBase58();\n      const allRounds = await fetchAllTierRounds(connection, wallet);\n      const existingRound = allRounds.get(selectedTier);\n\n      let roundNumber: bigint;\n      let tierIndex: number;\n\n      if (existingRound && existingRound.phase !== \"complete\") {\n        // Join existing round\n        tierIndex = TIER_VALUES[selectedTier];\n        roundNumber = await fetchRoundNumberForTier(connection, tierIndex);\n\n        const tx = await buildJoinRoundTx(\n          connection,\n          publicKey,\n          selectedTier,\n          entryCount,\n          roundNumber,\n        );\n        await sendAndConfirm(tx);\n      } else {\n        // Create a new round (we are the first player)\n        const result = await buildCreateRoundTx(\n          connection,\n          publicKey,\n          selectedTier,\n          entryCount,\n        );\n        await sendAndConfirm(result.transaction);\n\n        roundNumber = result.roundNumber;\n        tierIndex = TIER_VALUES[selectedTier];\n      }\n\n      // Fetch the round we just joined/created\n      const round = await fetchRound(\n        connection,\n        tierIndex,\n        roundNumber,\n        publicKey.toBase58(),\n      );\n      if (round) {\n        setActiveRound(round);\n        setActiveRoundMeta({ tierIndex, roundNumber });\n        setUserLeftRound(false);\n      }\n\n      void refreshRounds();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setJoining(false);\n    }\n  }, [connected, publicKey, selectedTier, entryCount, connection, sendAndConfirm, refreshRounds]);\n\n  // Buy more entries in current round\n  const buyMoreEntriesAction = useCallback(\n    async (entries: number) => {\n      if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n        setError(\"No active round.\");\n        return;\n      }\n\n      setBuyingMore(true);\n      setError(null);\n      try {\n        const tx = await buildBuyMoreEntriesTx(\n          connection,\n          publicKey,\n          activeRound.tier,\n          activeRoundMeta.roundNumber,\n          entries,\n        );\n        await sendAndConfirm(tx);\n\n        // Refresh active round\n        const updated = await fetchRound(\n          connection,\n          activeRoundMeta.tierIndex,\n          activeRoundMeta.roundNumber,\n          publicKey.toBase58(),\n        );\n        if (updated) {\n          setActiveRound(updated);\n        }\n\n        void refreshRounds();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setBuyingMore(false);\n      }\n    },\n    [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds],\n  );\n\n  // Start the VRF spin (permissionless — any player can trigger after countdown)\n  const startSpin = useCallback(async () => {\n    if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n      setError(\"No active round.\");\n      return;\n    }\n\n    setSpinning(true);\n    setError(null);\n    try {\n      const tx = await buildStartSpinTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      // Refresh active round — should now be in \"spinning\" phase\n      const updated = await fetchRound(\n        connection,\n        activeRoundMeta.tierIndex,\n        activeRoundMeta.roundNumber,\n        publicKey.toBase58(),\n      );\n      if (updated) {\n        setActiveRound(updated);\n      }\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setSpinning(false);\n    }\n  }, [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm]);\n\n  // Claim payout for winning round (manual trigger)\n  const claimPayout = useCallback(async () => {\n    if (!publicKey || !activeRound || !activeRoundMeta) {\n      setError(\"No active round to claim.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const tx = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n\n      // Auto-transition back to lobby\n      completionTimeoutRef.current = setTimeout(() => {\n        completionTimeoutRef.current = null;\n        setActiveRound(null);\n        setActiveRoundMeta(null);\n        void refreshRounds();\n      }, 5000);\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n\n  // Leave round (just clears UI — funds are committed on-chain)\n  const leaveRound = useCallback(() => {\n    if (completionTimeoutRef.current) {\n      clearTimeout(completionTimeoutRef.current);\n      completionTimeoutRef.current = null;\n    }\n    setActiveRound(null);\n    setActiveRoundMeta(null);\n    setUserLeftRound(true);\n    void refreshRounds();\n  }, [refreshRounds]);\n\n  // Auto-select tier based on active round\n  useEffect(() => {\n    if (activeRound && !selectedTier) {\n      setSelectedTier(activeRound.tier);\n    }\n  }, [activeRound, selectedTier]);\n\n  // Reset userLeftRound when joining a new round\n  useEffect(() => {\n    if (activeRound) {\n      setUserLeftRound(false);\n    }\n  }, [activeRound]);\n\n  // Check for existing active round on wallet connect\n  // (look through tier statuses for a round where user is a participant)\n  useEffect(() => {\n    if (publicKey && !activeRound && !userLeftRound && tierStatuses.length > 0) {\n      const wallet = publicKey.toBase58();\n      for (const status of tierStatuses) {\n        if (\n          status.currentRound &&\n          status.currentRound.phase !== \"complete\" &&\n          status.currentRound.players.some((p) => p.address === wallet)\n        ) {\n          setActiveRound(status.currentRound);\n          // Derive round meta\n          const tierIndex = TIER_VALUES[status.tier];\n          void fetchRoundNumberForTier(connection, tierIndex)\n            .then((roundNumber) => {\n              setActiveRoundMeta({ tierIndex, roundNumber });\n            })\n            .catch(() => {\n              // Ignore — meta will be set on next poll\n            });\n          break;\n        }\n      }\n    }\n  }, [publicKey, activeRound, userLeftRound, tierStatuses, connection]);\n\n  const value: LordOfRngsContextValue = {\n    activeRound,\n    tierStatuses,\n    userHistory,\n    selectedTier,\n    entryCount,\n    loading,\n    joining,\n    buyingMore,\n    claiming,\n    spinning,\n    error,\n    clearError,\n    setSelectedTier,\n    setEntryCount,\n    joinTierRound,\n    buyMoreEntriesAction,\n    startSpin,\n    claimPayout,\n    leaveRound,\n    refreshRounds,\n  };\n\n  return (\n    <LordOfRngsContext.Provider value={value}>\n      {children}\n    </LordOfRngsContext.Provider>\n  );\n}\n\nexport function useLordOfRngs(): LordOfRngsContextValue {\n  const context = useContext(LordOfRngsContext);\n  if (!context) {\n    throw new Error(\"useLordOfRngs must be used within LordOfRngsProvider\");\n  }\n  return context;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7342,"cache_read_input_tokens":91943,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7342},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"a9dfefaf-3ec1-4255-83f4-799f41f98f50"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AJZcV64WUf7FNB3viz6ctT","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/context/LordOfRngsContext.tsx has been overwritten successfully."}]},"parent_tool_use_id":null,"session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"a5cd60cd-dc9e-4ed7-9fe9-afb3871bee54","tool_use_result":{"type":"update","filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/context/LordOfRngsContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { type Transaction } from \"@solana/web3.js\";\nimport { TIER_VALUES, type Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { Round, TierStatus } from \"../types\";\nimport {\n  fetchAllTierRounds,\n  fetchRound,\n  buildCreateRoundTx,\n  buildJoinRoundTx,\n  buildBuyMoreEntriesTx,\n  buildStartSpinTx,\n  buildClaimPayoutTx,\n  getLordProgram,\n  getConfigPda,\n} from \"../utils/chain\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse transaction errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This round is no longer accepting entries.\";\n  }\n  if (msg.includes(\"MaxPlayersReached\")) {\n    return \"This round is full (max 20 players).\";\n  }\n  if (msg.includes(\"PlayerAlreadyInRound\")) {\n    return \"You are already in this round. Use 'Buy More' to add entries.\";\n  }\n  if (msg.includes(\"CountdownNotExpired\")) {\n    return \"Countdown has not finished yet.\";\n  }\n  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    return \"Transaction simulation failed. The round state may have changed.\";\n  }\n  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    return \"Transaction expired. Please try again.\";\n  }\n\n  console.error(\"[lord-of-rngs] unhandled transaction error:\", err);\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\n/** Metadata for the active round needed to build transactions */\ninterface RoundMeta {\n  tierIndex: number;\n  roundNumber: bigint;\n}\n\n/** Fetch the current round number for a tier from the on-chain config */\nasync function fetchRoundNumberForTier(\n  connection: Parameters<typeof getLordProgram>[0],\n  tierIndex: number,\n): Promise<bigint> {\n  const program = getLordProgram(connection);\n  const [configPda] = getConfigPda();\n  const config = await program.account.lordConfig.fetch(configPda);\n  const configData = config as unknown as { roundCounters: { toNumber(): number }[] };\n  // Active round is the last created = counter - 1\n  return BigInt(configData.roundCounters[tierIndex]!.toNumber() - 1);\n}\n\ninterface LordOfRngsContextValue {\n  // State\n  activeRound: Round | null;\n  tierStatuses: TierStatus[];\n  userHistory: Round[];\n  selectedTier: Tier | null;\n  entryCount: number;\n\n  // Loading states\n  loading: boolean;\n  joining: boolean;\n  buyingMore: boolean;\n  claiming: boolean;\n  spinning: boolean;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setEntryCount: (count: number) => void;\n  joinTierRound: () => Promise<void>;\n  buyMoreEntriesAction: (entries: number) => Promise<void>;\n  startSpin: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  leaveRound: () => void;\n  refreshRounds: () => void;\n}\n\nconst LordOfRngsContext = createContext<LordOfRngsContextValue | null>(null);\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\nexport function LordOfRngsProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [entryCount, setEntryCount] = useState(1);\n\n  // Round state\n  const [activeRound, setActiveRound] = useState<Round | null>(null);\n  const [activeRoundMeta, setActiveRoundMeta] = useState<RoundMeta | null>(null);\n  const [tierStatuses, setTierStatuses] = useState<TierStatus[]>([]);\n  const [userHistory] = useState<Round[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [joining, setJoining] = useState(false);\n  const [buyingMore, setBuyingMore] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [spinning, setSpinning] = useState(false);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Track if user explicitly left the round\n  const [userLeftRound, setUserLeftRound] = useState(false);\n\n  // Ref to prevent multiple completion timeouts\n  const completionTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n  const refreshInFlightRef = useRef(false);\n  // Ref to access latest claiming state in polling callback\n  const claimingRef = useRef(false);\n  useEffect(() => { claimingRef.current = claiming; }, [claiming]);\n\n  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n      transaction.recentBlockhash = blockhash;\n      const signature = await sendTransaction(transaction);\n      await connection.confirmTransaction(\n        { signature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      await refreshBalance();\n      return signature;\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // Refresh tier statuses from on-chain\n  const refreshRounds = useCallback(async () => {\n    if (refreshInFlightRef.current) return;\n    refreshInFlightRef.current = true;\n\n    try {\n      const wallet = publicKey?.toBase58();\n      const allRounds = await fetchAllTierRounds(connection, wallet);\n      const statuses: TierStatus[] = TIERS.map((tier) => {\n        const round = allRounds.get(tier) ?? null;\n        return {\n          tier,\n          entryAmount: round?.entryAmount ?? 0,\n          currentRound: round,\n        };\n      });\n      setTierStatuses(statuses);\n    } catch {\n      // Ignore transient RPC failures; polling will retry\n    } finally {\n      setLoading(false);\n      refreshInFlightRef.current = false;\n    }\n  }, [connection, publicKey]);\n\n  /** Auto-claim payout when the player wins */\n  const handleAutoClaim = useCallback(async () => {\n    if (!publicKey || !activeRound || !activeRoundMeta) return;\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const tx = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n\n      // Auto-transition back to lobby after showing win result\n      completionTimeoutRef.current = setTimeout(() => {\n        completionTimeoutRef.current = null;\n        setActiveRound(null);\n        setActiveRoundMeta(null);\n        void refreshRounds();\n      }, 5000);\n    } catch (err) {\n      // If auto-claim fails, user can manually retry via claimPayout\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    void refreshRounds();\n  }, [refreshRounds]);\n\n  // Poll for updates — faster when in active round, slower for lobby\n  const pollInterval = activeRound ? 5000 : 15000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      if (activeRound && activeRoundMeta) {\n        // Poll the active round account\n        fetchRound(\n          connection,\n          activeRoundMeta.tierIndex,\n          activeRoundMeta.roundNumber,\n          publicKey?.toBase58()\n        )\n          .then((updated) => {\n            if (!updated) {\n              // Round account closed (claimed or cancelled) — return to lobby\n              setActiveRound(null);\n              setActiveRoundMeta(null);\n              void refreshRounds();\n              return;\n            }\n\n            setActiveRound(updated);\n\n            // If VRF fulfilled (revealing phase) and we're the winner, auto-claim\n            if (\n              updated.phase === \"revealing\" &&\n              updated.winner === publicKey?.toBase58() &&\n              !updated.claimed &&\n              !claimingRef.current\n            ) {\n              void handleAutoClaim();\n            }\n\n            // If round settled and we're not the winner, auto-return to lobby\n            if (\n              updated.phase === \"complete\" &&\n              !completionTimeoutRef.current\n            ) {\n              const isWinner = updated.winner === publicKey?.toBase58();\n              completionTimeoutRef.current = setTimeout(() => {\n                completionTimeoutRef.current = null;\n                setActiveRound(null);\n                setActiveRoundMeta(null);\n                void refreshRounds();\n              }, isWinner ? 5000 : 3000);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      } else {\n        // Lobby: poll tier statuses\n        void refreshRounds();\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshRounds, activeRound, activeRoundMeta, connection, pollInterval, publicKey, handleAutoClaim]);\n\n  // Cleanup completion timeout on unmount\n  useEffect(() => {\n    return () => {\n      if (completionTimeoutRef.current) {\n        clearTimeout(completionTimeoutRef.current);\n      }\n    };\n  }, []);\n\n  // Join a tier's round\n  const joinTierRound = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier) {\n      setError(\"Select a tier first.\");\n      return;\n    }\n    if (entryCount < 1) {\n      setError(\"Select at least 1 entry.\");\n      return;\n    }\n\n    setJoining(true);\n    setError(null);\n    try {\n      // Check if a round exists for this tier\n      const wallet = publicKey.toBase58();\n      const allRounds = await fetchAllTierRounds(connection, wallet);\n      const existingRound = allRounds.get(selectedTier);\n\n      let roundNumber: bigint;\n      let tierIndex: number;\n\n      if (existingRound && existingRound.phase !== \"complete\") {\n        // Join existing round\n        tierIndex = TIER_VALUES[selectedTier];\n        roundNumber = await fetchRoundNumberForTier(connection, tierIndex);\n\n        const tx = await buildJoinRoundTx(\n          connection,\n          publicKey,\n          selectedTier,\n          entryCount,\n          roundNumber,\n        );\n        await sendAndConfirm(tx);\n      } else {\n        // Create a new round (we are the first player)\n        const result = await buildCreateRoundTx(\n          connection,\n          publicKey,\n          selectedTier,\n          entryCount,\n        );\n        await sendAndConfirm(result.transaction);\n\n        roundNumber = result.roundNumber;\n        tierIndex = TIER_VALUES[selectedTier];\n      }\n\n      // Fetch the round we just joined/created\n      const round = await fetchRound(\n        connection,\n        tierIndex,\n        roundNumber,\n        publicKey.toBase58(),\n      );\n      if (round) {\n        setActiveRound(round);\n        setActiveRoundMeta({ tierIndex, roundNumber });\n        setUserLeftRound(false);\n      }\n\n      void refreshRounds();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setJoining(false);\n    }\n  }, [connected, publicKey, selectedTier, entryCount, connection, sendAndConfirm, refreshRounds]);\n\n  // Buy more entries in current round\n  const buyMoreEntriesAction = useCallback(\n    async (entries: number) => {\n      if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n        setError(\"No active round.\");\n        return;\n      }\n\n      setBuyingMore(true);\n      setError(null);\n      try {\n        const tx = await buildBuyMoreEntriesTx(\n          connection,\n          publicKey,\n          activeRound.tier,\n          activeRoundMeta.roundNumber,\n          entries,\n        );\n        await sendAndConfirm(tx);\n\n        // Refresh active round\n        const updated = await fetchRound(\n          connection,\n          activeRoundMeta.tierIndex,\n          activeRoundMeta.roundNumber,\n          publicKey.toBase58(),\n        );\n        if (updated) {\n          setActiveRound(updated);\n        }\n\n        void refreshRounds();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setBuyingMore(false);\n      }\n    },\n    [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds],\n  );\n\n  // Start the VRF spin (permissionless — any player can trigger after countdown)\n  const startSpin = useCallback(async () => {\n    if (!connected || !publicKey || !activeRound || !activeRoundMeta) {\n      setError(\"No active round.\");\n      return;\n    }\n\n    setSpinning(true);\n    setError(null);\n    try {\n      const tx = await buildStartSpinTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      // Refresh active round — should now be in \"spinning\" phase\n      const updated = await fetchRound(\n        connection,\n        activeRoundMeta.tierIndex,\n        activeRoundMeta.roundNumber,\n        publicKey.toBase58(),\n      );\n      if (updated) {\n        setActiveRound(updated);\n      }\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setSpinning(false);\n    }\n  }, [connected, publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm]);\n\n  // Claim payout for winning round (manual trigger)\n  const claimPayout = useCallback(async () => {\n    if (!publicKey || !activeRound || !activeRoundMeta) {\n      setError(\"No active round to claim.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const tx = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        activeRound.tier,\n        activeRoundMeta.roundNumber,\n      );\n      await sendAndConfirm(tx);\n\n      setActiveRound((prev) => prev ? { ...prev, claimed: true, phase: \"complete\" } : null);\n\n      // Auto-transition back to lobby\n      completionTimeoutRef.current = setTimeout(() => {\n        completionTimeoutRef.current = null;\n        setActiveRound(null);\n        setActiveRoundMeta(null);\n        void refreshRounds();\n      }, 5000);\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [publicKey, activeRound, activeRoundMeta, connection, sendAndConfirm, refreshRounds]);\n\n  // Leave round (just clears UI — funds are committed on-chain)\n  const leaveRound = useCallback(() => {\n    if (completionTimeoutRef.current) {\n      clearTimeout(completionTimeoutRef.current);\n      completionTimeoutRef.current = null;\n    }\n    setActiveRound(null);\n    setActiveRoundMeta(null);\n    setUserLeftRound(true);\n    void refreshRounds();\n  }, [refreshRounds]);\n\n  // Auto-select tier based on active round\n  useEffect(() => {\n    if (activeRound && !selectedTier) {\n      setSelectedTier(activeRound.tier);\n    }\n  }, [activeRound, selectedTier]);\n\n  // Reset userLeftRound when joining a new round\n  useEffect(() => {\n    if (activeRound) {\n      setUserLeftRound(false);\n    }\n  }, [activeRound]);\n\n  // Check for existing active round on wallet connect\n  // (look through tier statuses for a round where user is a participant)\n  useEffect(() => {\n    if (publicKey && !activeRound && !userLeftRound && tierStatuses.length > 0) {\n      const wallet = publicKey.toBase58();\n      for (const status of tierStatuses) {\n        if (\n          status.currentRound &&\n          status.currentRound.phase !== \"complete\" &&\n          status.currentRound.players.some((p) => p.address === wallet)\n        ) {\n          setActiveRound(status.currentRound);\n          // Derive round meta\n          const tierIndex = TIER_VALUES[status.tier];\n          void fetchRoundNumberForTier(connection, tierIndex)\n            .then((roundNumber) => {\n              setActiveRoundMeta({ tierIndex, roundNumber });\n            })\n            .catch(() => {\n              // Ignore — meta will be set on next poll\n            });\n          break;\n        }\n      }\n    }\n  }, [publicKey, activeRound, userLeftRound, tierStatuses, connection]);\n\n  const value: LordOfRngsContextValue = {\n    activeRound,\n    tierStatuses,\n    userHistory,\n    selectedTier,\n    entryCount,\n    loading,\n    joining,\n    buyingMore,\n    claiming,\n    spinning,\n    error,\n    clearError,\n    setSelectedTier,\n    setEntryCount,\n    joinTierRound,\n    buyMoreEntriesAction,\n    startSpin,\n    claimPayout,\n    leaveRound,\n    refreshRounds,\n  };\n\n  return (\n    <LordOfRngsContext.Provider value={value}>\n      {children}\n    </LordOfRngsContext.Provider>\n  );\n}\n\nexport function useLordOfRngs(): LordOfRngsContextValue {\n  const context = useContext(LordOfRngsContext);\n  if (!context) {\n    throw new Error(\"useLordOfRngs must be used within LordOfRngsProvider\");\n  }\n  return context;\n}\n","structuredPatch":[{"oldStart":7,"oldLines":7,"newStart":7,"newLines":7,"lines":["   useRef,","   type ReactNode,"," } from \"react\";","-import { PublicKey, type Transaction } from \"@solana/web3.js\";","+import { type Transaction } from \"@solana/web3.js\";"," import { TIER_VALUES, type Tier } from \"@rng-utopia/game-engine/browser\";"," import type { Round, TierStatus } from \"../types\";"," import {"]},{"oldStart":18,"oldLines":7,"newStart":18,"newLines":8,"lines":["   buildBuyMoreEntriesTx,","   buildStartSpinTx,","   buildClaimPayoutTx,","-  getRoundPda,","+  getLordProgram,","+  getConfigPda,"," } from \"../utils/chain\";"," import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";"," "]},{"oldStart":67,"oldLines":6,"newStart":68,"newLines":19,"lines":["   roundNumber: bigint;"," }"," ","+/** Fetch the current roun