{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012wXRD9yxNgDGfHGDf3YUPJ","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    11→import type { Round, TierStatus } from \"../types\";\n    12→import {\n    13→  joinRound,\n    14→  buyMoreEntries,\n    15→  getRound,\n    16→  getAllTierRounds,\n    17→  subscribeToRound,\n    18→  getUserRounds,\n    19→  initializeMockRounds,\n    20→} from \"../utils/mock-simulation\";\n    21→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    22→\n    23→interface LordOfRngsContextValue {\n    24→  // State\n    25→  activeRound: Round | null;\n    26→  tierStatuses: TierStatus[];\n    27→  userHistory: Round[];\n    28→  selectedTier: Tier | null;\n    29→  entryCount: number;\n    30→\n    31→  // Loading states\n    32→  loading: boolean;\n    33→  joining: boolean;\n    34→  buyingMore: boolean;\n    35→  claiming: boolean;\n    36→\n    37→  // Actions\n    38→  setSelectedTier: (tier: Tier | null) => void;\n    39→  setEntryCount: (count: number) => void;\n    40→  joinTierRound: () => Promise<void>;\n    41→  buyMoreEntriesAction: (entries: number) => Promise<void>;\n    42→  claimPayout: () => Promise<void>;\n    43→  leaveRound: () => void;\n    44→  refreshRounds: () => void;\n    45→}\n    46→\n    47→const LordOfRngsContext = createContext<LordOfRngsContextValue | null>(null);\n    48→\n    49→const TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n    50→\n    51→export function LordOfRngsProvider({ children }: { children: ReactNode }) {\n    52→  const { connected, address } = useWallet();\n    53→\n    54→  // Selection state\n    55→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n    56→  const [entryCount, setEntryCount] = useState(1);\n    57→\n    58→  // Round state\n    59→  const [activeRound, setActiveRound] = useState<Round | null>(null);\n    60→  const [tierStatuses, setTierStatuses] = useState<TierStatus[]>([]);\n    61→  const [userHistory, setUserHistory] = useState<Round[]>([]);\n    62→\n    63→  // Loading states\n    64→  const [loading, setLoading] = useState(true);\n    65→  const [joining, setJoining] = useState(false);\n    66→  const [buyingMore, setBuyingMore] = useState(false);\n    67→  const [claiming, setClaiming] = useState(false);\n    68→\n    69→  // Track if user explicitly left the round\n    70→  const [userLeftRound, setUserLeftRound] = useState(false);\n    71→\n    72→  // Ref to prevent multiple completion timeouts\n    73→  const completionTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n    74→  // Ref to access refreshRounds without adding it to effect dependencies\n    75→  const refreshRoundsRef = useRef<() => void>(() => {});\n    76→\n    77→  // Refresh tier statuses\n    78→  const refreshRounds = useCallback(() => {\n    79→    const allRounds = getAllTierRounds();\n    80→    const statuses: TierStatus[] = TIERS.map((tier) => {\n    81→      const round = allRounds.get(tier) ?? null;\n    82→      return {\n    83→        tier,\n    84→        entryAmount: round?.entryAmount ?? 0,\n    85→        currentRound: round,\n    86→      };\n    87→    });\n    88→    setTierStatuses(statuses);\n    89→\n    90→    // Update history\n    91→    if (address) {\n    92→      const history = getUserRounds(address)\n    93→        .filter((r) => r.phase === \"complete\")\n    94→        .sort((a, b) => (b.completedAt ?? b.createdAt) - (a.completedAt ?? a.createdAt));\n    95→      setUserHistory(history);\n    96→    }\n    97→  }, [address]);\n    98→\n    99→  // Keep refreshRoundsRef updated\n   100→  useEffect(() => {\n   101→    refreshRoundsRef.current = refreshRounds;\n   102→  }, [refreshRounds]);\n   103→\n   104→  // Initialize mock rounds\n   105→  useEffect(() => {\n   106→    setLoading(true);\n   107→    initializeMockRounds();\n   108→    refreshRounds();\n   109→    setLoading(false);\n   110→  }, [refreshRounds]);\n   111→\n   112→  // Poll for round updates\n   113→  useEffect(() => {\n   114→    const interval = setInterval(() => {\n   115→      refreshRounds();\n   116→    }, 2000);\n   117→    return () => clearInterval(interval);\n   118→  }, [refreshRounds]);\n   119→\n   120→  // Subscribe to active round updates\n   121→  useEffect(() => {\n   122→    if (!activeRound) return;\n   123→\n   124→    // Clear any pending completion timeout when subscribing to a new round\n   125→    if (completionTimeoutRef.current) {\n   126→      clearTimeout(completionTimeoutRef.current);\n   127→      completionTimeoutRef.current = null;\n   128→    }\n   129→\n   130→    const unsubscribe = subscribeToRound(activeRound.id, (updated) => {\n   131→      // If round is complete and user is winner, auto-claim immediately\n   132→      // This eliminates the need for a manual \"Claim Payout\" button\n   133→      if (updated.phase === \"complete\" && updated.winner === address && !updated.claimed) {\n   134→        setActiveRound({ ...updated, claimed: true });\n   135→      } else {\n   136→        setActiveRound(updated);\n   137→      }\n   138→\n   139→      // If round is complete, auto-transition back to lobby after showing the result\n   140→      // Use ref to prevent scheduling multiple timeouts\n   141→      if (updated.phase === \"complete\" && !completionTimeoutRef.current) {\n   142→        const isWinner = updated.winner === address;\n   143→\n   144→        // Auto-transition after a brief delay (winners see result longer)\n   145→        completionTimeoutRef.current = setTimeout(() => {\n   146→          completionTimeoutRef.current = null;\n   147→          setActiveRound(null);\n   148→          refreshRoundsRef.current();\n   149→        }, isWinner ? 3000 : 1500); // Winners see \"You Won!\" for 3s\n   150→      }\n   151→    });\n   152→\n   153→    return () => {\n   154→      unsubscribe();\n   155→      // Clear timeout on cleanup to prevent stale callbacks\n   156→      if (completionTimeoutRef.current) {\n   157→        clearTimeout(completionTimeoutRef.current);\n   158→        completionTimeoutRef.current = null;\n   159→      }\n   160→    };\n   161→  }, [activeRound?.id]);\n   162→\n   163→  // Join a tier's round\n   164→  const joinTierRound = useCallback(async () => {\n   165→    if (!connected || !address) {\n   166→      throw new Error(\"Wallet not connected\");\n   167→    }\n   168→    if (!selectedTier) {\n   169→      throw new Error(\"Select a tier first\");\n   170→    }\n   171→    if (entryCount < 1) {\n   172→      throw new Error(\"Select at least 1 entry\");\n   173→    }\n   174→\n   175→    setJoining(true);\n   176→    try {\n   177→      // Simulate transaction delay\n   178→      await new Promise((resolve) => setTimeout(resolve, 500));\n   179→\n   180→      const round = joinRound(selectedTier, address, entryCount, true);\n   181→      setActiveRound(round);\n   182→      setUserLeftRound(false);\n   183→\n   184→      // Refresh tier statuses\n   185→      refreshRounds();\n   186→    } finally {\n   187→      setJoining(false);\n   188→    }\n   189→  }, [connected, address, selectedTier, entryCount, refreshRounds]);\n   190→\n   191→  // Buy more entries in current round\n   192→  const buyMoreEntriesAction = useCallback(\n   193→    async (entries: number) => {\n   194→      if (!connected || !address || !activeRound) {\n   195→        throw new Error(\"No active round\");\n   196→      }\n   197→\n   198→      setBuyingMore(true);\n   199→      try {\n   200→        // Simulate transaction delay\n   201→        await new Promise((resolve) => setTimeout(resolve, 500));\n   202→\n   203→        const updated = buyMoreEntries(activeRound.id, address, entries);\n   204→        setActiveRound(updated);\n   205→\n   206→        // Refresh tier statuses\n   207→        refreshRounds();\n   208→      } finally {\n   209→        setBuyingMore(false);\n   210→      }\n   211→    },\n   212→    [connected, address, activeRound, refreshRounds]\n   213→  );\n   214→\n   215→  // Claim payout for winning round\n   216→  const claimPayout = useCallback(async () => {\n   217→    if (!activeRound || activeRound.phase !== \"complete\") {\n   218→      throw new Error(\"No completed round to claim\");\n   219→    }\n   220→    if (activeRound.winner !== address) {\n   221→      throw new Error(\"You are not the winner\");\n   222→    }\n   223→\n   224→    setClaiming(true);\n   225→    try {\n   226→      // Simulate transaction delay\n   227→      await new Promise((resolve) => setTimeout(resolve, 1000));\n   228→\n   229→      // Mark round as claimed\n   230→      setActiveRound((prev) => prev ? { ...prev, claimed: true } : null);\n   231→\n   232→      // After claiming, auto-transition back to lobby\n   233→      setTimeout(() => {\n   234→        setActiveRound(null);\n   235→        refreshRoundsRef.current();\n   236→      }, 2000);\n   237→    } finally {\n   238→      setClaiming(false);\n   239→    }\n   240→  }, [activeRound, address]);\n   241→\n   242→  // Leave round (just clears UI - funds are already committed)\n   243→  const leaveRound = useCallback(() => {\n   244→    setActiveRound(null);\n   245→    setUserLeftRound(true);\n   246→    refreshRounds();\n   247→  }, [refreshRounds]);\n   248→\n   249→  // Check for existing active round on wallet connect\n   250→  useEffect(() => {\n   251→    if (address && !activeRound && !userLeftRound) {\n   252→      const userRounds = getUserRounds(address);\n   253→      const active = userRounds.find(\n   254→        (r) => r.phase !== \"complete\"\n   255→      );\n   256→      if (active) {\n   257→        const latest = getRound(active.id);\n   258→        if (latest) {\n   259→          setActiveRound(latest);\n   260→        }\n   261→      }\n   262→    }\n   263→  }, [address, activeRound, userLeftRound]);\n   264→\n   265→  // Reset userLeftRound when joining a new round\n   266→  useEffect(() => {\n   267→    if (activeRound) {\n   268→      setUserLeftRound(false);\n   269→    }\n   270→  }, [activeRound]);\n   271→\n   272→  // Auto-select tier based on active round\n   273→  useEffect(() => {\n   274→    if (activeRound && !selectedTier) {\n   275→      setSelectedTier(activeRound.tier);\n   276→    }\n   277→  }, [activeRound, selectedTier]);\n   278→\n   279→  const value: LordOfRngsContextValue = {\n   280→    activeRound,\n   281→    tierStatuses,\n   282→    userHistory,\n   283→    selectedTier,\n   284→    entryCount,\n   285→    loading,\n   286→    joining,\n   287→    buyingMore,\n   288→    claiming,\n   289→    setSelectedTier,\n   290→    setEntryCount,\n   291→    joinTierRound,\n   292→    buyMoreEntriesAction,\n   293→    claimPayout,\n   294→    leaveRound,\n   295→    refreshRounds,\n   296→  };\n   297→\n   298→  return (\n   299→    <LordOfRngsContext.Provider value={value}>\n   300→      {children}\n   301→    </LordOfRngsContext.Provider>\n   302→  );\n   303→}\n   304→\n   305→export function useLordOfRngs(): LordOfRngsContextValue {\n   306→  const context = useContext(LordOfRngsContext);\n   307→  if (!context) {\n   308→    throw new Error(\"useLordOfRngs must be used within LordOfRngsProvider\");\n   309→  }\n   310→  return context;\n   311→}\n   312→"}]},"parent_tool_use_id":null,"session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"69f2a1a4-0e47-4052-8fdd-51deb5063f80","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/context/LordOfRngsContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { Round, TierStatus } from \"../types\";\nimport {\n  joinRound,\n  buyMoreEntries,\n  getRound,\n  getAllTierRounds,\n  subscribeToRound,\n  getUserRounds,\n  initializeMockRounds,\n} from \"../utils/mock-simulation\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\ninterface LordOfRngsContextValue {\n  // State\n  activeRound: Round | null;\n  tierStatuses: TierStatus[];\n  userHistory: Round[];\n  selectedTier: Tier | null;\n  entryCount: number;\n\n  // Loading states\n  loading: boolean;\n  joining: boolean;\n  buyingMore: boolean;\n  claiming: boolean;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setEntryCount: (count: number) => void;\n  joinTierRound: () => Promise<void>;\n  buyMoreEntriesAction: (entries: number) => Promise<void>;\n  claimPayout: () => Promise<void>;\n  leaveRound: () => void;\n  refreshRounds: () => void;\n}\n\nconst LordOfRngsContext = createContext<LordOfRngsContextValue | null>(null);\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\nexport function LordOfRngsProvider({ children }: { children: ReactNode }) {\n  const { connected, address } = useWallet();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [entryCount, setEntryCount] = useState(1);\n\n  // Round state\n  const [activeRound, setActiveRound] = useState<Round | null>(null);\n  const [tierStatuses, setTierStatuses] = useState<TierStatus[]>([]);\n  const [userHistory, setUserHistory] = useState<Round[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [joining, setJoining] = useState(false);\n  const [buyingMore, setBuyingMore] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n\n  // Track if user explicitly left the round\n  const [userLeftRound, setUserLeftRound] = useState(false);\n\n  // Ref to prevent multiple completion timeouts\n  const completionTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n  // Ref to access refreshRounds without adding it to effect dependencies\n  const refreshRoundsRef = useRef<() => void>(() => {});\n\n  // Refresh tier statuses\n  const refreshRounds = useCallback(() => {\n    const allRounds = getAllTierRounds();\n    const statuses: TierStatus[] = TIERS.map((tier) => {\n      const round = allRounds.get(tier) ?? null;\n      return {\n        tier,\n        entryAmount: round?.entryAmount ?? 0,\n        currentRound: round,\n      };\n    });\n    setTierStatuses(statuses);\n\n    // Update history\n    if (address) {\n      const history = getUserRounds(address)\n        .filter((r) => r.phase === \"complete\")\n        .sort((a, b) => (b.completedAt ?? b.createdAt) - (a.completedAt ?? a.createdAt));\n      setUserHistory(history);\n    }\n  }, [address]);\n\n  // Keep refreshRoundsRef updated\n  useEffect(() => {\n    refreshRoundsRef.current = refreshRounds;\n  }, [refreshRounds]);\n\n  // Initialize mock rounds\n  useEffect(() => {\n    setLoading(true);\n    initializeMockRounds();\n    refreshRounds();\n    setLoading(false);\n  }, [refreshRounds]);\n\n  // Poll for round updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshRounds();\n    }, 2000);\n    return () => clearInterval(interval);\n  }, [refreshRounds]);\n\n  // Subscribe to active round updates\n  useEffect(() => {\n    if (!activeRound) return;\n\n    // Clear any pending completion timeout when subscribing to a new round\n    if (completionTimeoutRef.current) {\n      clearTimeout(completionTimeoutRef.current);\n      completionTimeoutRef.current = null;\n    }\n\n    const unsubscribe = subscribeToRound(activeRound.id, (updated) => {\n      // If round is complete and user is winner, auto-claim immediately\n      // This eliminates the need for a manual \"Claim Payout\" button\n      if (updated.phase === \"complete\" && updated.winner === address && !updated.claimed) {\n        setActiveRound({ ...updated, claimed: true });\n      } else {\n        setActiveRound(updated);\n      }\n\n      // If round is complete, auto-transition back to lobby after showing the result\n      // Use ref to prevent scheduling multiple timeouts\n      if (updated.phase === \"complete\" && !completionTimeoutRef.current) {\n        const isWinner = updated.winner === address;\n\n        // Auto-transition after a brief delay (winners see result longer)\n        completionTimeoutRef.current = setTimeout(() => {\n          completionTimeoutRef.current = null;\n          setActiveRound(null);\n          refreshRoundsRef.current();\n        }, isWinner ? 3000 : 1500); // Winners see \"You Won!\" for 3s\n      }\n    });\n\n    return () => {\n      unsubscribe();\n      // Clear timeout on cleanup to prevent stale callbacks\n      if (completionTimeoutRef.current) {\n        clearTimeout(completionTimeoutRef.current);\n        completionTimeoutRef.current = null;\n      }\n    };\n  }, [activeRound?.id]);\n\n  // Join a tier's round\n  const joinTierRound = useCallback(async () => {\n    if (!connected || !address) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier) {\n      throw new Error(\"Select a tier first\");\n    }\n    if (entryCount < 1) {\n      throw new Error(\"Select at least 1 entry\");\n    }\n\n    setJoining(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      const round = joinRound(selectedTier, address, entryCount, true);\n      setActiveRound(round);\n      setUserLeftRound(false);\n\n      // Refresh tier statuses\n      refreshRounds();\n    } finally {\n      setJoining(false);\n    }\n  }, [connected, address, selectedTier, entryCount, refreshRounds]);\n\n  // Buy more entries in current round\n  const buyMoreEntriesAction = useCallback(\n    async (entries: number) => {\n      if (!connected || !address || !activeRound) {\n        throw new Error(\"No active round\");\n      }\n\n      setBuyingMore(true);\n      try {\n        // Simulate transaction delay\n        await new Promise((resolve) => setTimeout(resolve, 500));\n\n        const updated = buyMoreEntries(activeRound.id, address, entries);\n        setActiveRound(updated);\n\n        // Refresh tier statuses\n        refreshRounds();\n      } finally {\n        setBuyingMore(false);\n      }\n    },\n    [connected, address, activeRound, refreshRounds]\n  );\n\n  // Claim payout for winning round\n  const claimPayout = useCallback(async () => {\n    if (!activeRound || activeRound.phase !== \"complete\") {\n      throw new Error(\"No completed round to claim\");\n    }\n    if (activeRound.winner !== address) {\n      throw new Error(\"You are not the winner\");\n    }\n\n    setClaiming(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 1000));\n\n      // Mark round as claimed\n      setActiveRound((prev) => prev ? { ...prev, claimed: true } : null);\n\n      // After claiming, auto-transition back to lobby\n      setTimeout(() => {\n        setActiveRound(null);\n        refreshRoundsRef.current();\n      }, 2000);\n    } finally {\n      setClaiming(false);\n    }\n  }, [activeRound, address]);\n\n  // Leave round (just clears UI - funds are already committed)\n  const leaveRound = useCallback(() => {\n    setActiveRound(null);\n    setUserLeftRound(true);\n    refreshRounds();\n  }, [refreshRounds]);\n\n  // Check for existing active round on wallet connect\n  useEffect(() => {\n    if (address && !activeRound && !userLeftRound) {\n      const userRounds = getUserRounds(address);\n      const active = userRounds.find(\n        (r) => r.phase !== \"complete\"\n      );\n      if (active) {\n        const latest = getRound(active.id);\n        if (latest) {\n          setActiveRound(latest);\n        }\n      }\n    }\n  }, [address, activeRound, userLeftRound]);\n\n  // Reset userLeftRound when joining a new round\n  useEffect(() => {\n    if (activeRound) {\n      setUserLeftRound(false);\n    }\n  }, [activeRound]);\n\n  // Auto-select tier based on active round\n  useEffect(() => {\n    if (activeRound && !selectedTier) {\n      setSelectedTier(activeRound.tier);\n    }\n  }, [activeRound, selectedTier]);\n\n  const value: LordOfRngsContextValue = {\n    activeRound,\n    tierStatuses,\n    userHistory,\n    selectedTier,\n    entryCount,\n    loading,\n    joining,\n    buyingMore,\n    claiming,\n    setSelectedTier,\n    setEntryCount,\n    joinTierRound,\n    buyMoreEntriesAction,\n    claimPayout,\n    leaveRound,\n    refreshRounds,\n  };\n\n  return (\n    <LordOfRngsContext.Provider value={value}>\n      {children}\n    </LordOfRngsContext.Provider>\n  );\n}\n\nexport function useLordOfRngs(): LordOfRngsContextValue {\n  const context = useContext(LordOfRngsContext);\n  if (!context) {\n    throw new Error(\"useLordOfRngs must be used within LordOfRngsProvider\");\n  }\n  return context;\n}\n","numLines":312,"startLine":1,"totalLines":312}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_016wGkACr3Zgckp4DKrn5zbN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Rjo8bXsV7kKorYogMFq5jP","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/mock-simulation.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5683,"cache_read_input_tokens":53016,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5683},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"6158f2dd-a30a-4e42-ab80-9c4dad3a7db6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rjo8bXsV7kKorYogMFq5jP","type":"tool_result","content":"     1→import { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\n     2→import type { Round, PlayerEntry } from \"../types\";\n     3→import { PLAYER_COLORS } from \"../types\";\n     4→import { emitLordOfRngsComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\n     5→import { emitLordOfRngsResults } from \"../../player-profile/utils/profile-event-bus\";\n     6→\n     7→// ============ Constants ============\n     8→\n     9→const COUNTDOWN_DURATION = 60000; // 60 seconds\n    10→const SPIN_DURATION = 5000; // 5 seconds\n    11→const REVEAL_DURATION = 3000; // 3 seconds to show winner before new round\n    12→const MIN_PLAYERS = 2; // Minimum 2 different players (not just entries)\n    13→\n    14→const TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n    15→\n    16→// ============ Mock Store ============\n    17→\n    18→type TimerId = ReturnType<typeof setTimeout>;\n    19→\n    20→interface MockStore {\n    21→  rounds: Map<string, Round>; // roundId -> Round\n    22→  tierRounds: Map<Tier, string>; // tier -> current round ID\n    23→  listeners: Map<string, Set<(round: Round) => void>>;\n    24→  mockPlayerTimers: Map<string, TimerId[]>;\n    25→}\n    26→\n    27→const store: MockStore = {\n    28→  rounds: new Map(),\n    29→  tierRounds: new Map(),\n    30→  listeners: new Map(),\n    31→  mockPlayerTimers: new Map(),\n    32→};\n    33→\n    34→// ============ Helpers ============\n    35→\n    36→function generateRoundId(): string {\n    37→  return `lotr-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n    38→}\n    39→\n    40→function generateMockAddress(): string {\n    41→  const chars = \"123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz\";\n    42→  let addr = \"\";\n    43→  for (let i = 0; i < 44; i++) {\n    44→    addr += chars[Math.floor(Math.random() * chars.length)];\n    45→  }\n    46→  return addr;\n    47→}\n    48→\n    49→// Generate a mock hex string (simulates SHA-256 hash or seed)\n    50→function generateMockHexString(length: number = 64): string {\n    51→  const chars = \"0123456789abcdef\";\n    52→  let result = \"\";\n    53→  for (let i = 0; i < length; i++) {\n    54→    result += chars[Math.floor(Math.random() * chars.length)];\n    55→  }\n    56→  return result;\n    57→}\n    58→\n    59→// Generate mock provably fair data\n    60→function generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string; vrfProof: string } {\n    61→  const serverSeed = generateMockHexString(64); // 256-bit seed\n    62→  const seedHash = generateMockHexString(64); // SHA-256 hash of server seed\n    63→  const blockHash = generateMockHexString(88); // Solana blockhash format\n    64→  const vrfProof = generateMockHexString(128); // VRF proof\n    65→  return { seedHash, serverSeed, blockHash, vrfProof };\n    66→}\n    67→\n    68→export function truncateAddress(address: string): string {\n    69→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n    70→}\n    71→\n    72→function getPlayerColor(index: number, isCurrentUser: boolean): string {\n    73→  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\"; // Neon green for current user\n    74→  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n    75→}\n    76→\n    77→function calculatePayout(poolAmount: number): number {\n    78→  return poolAmount * 0.97; // 97% after 3% fee\n    79→}\n    80→\n    81→function notifyListeners(roundId: string, round: Round): void {\n    82→  const listeners = store.listeners.get(roundId);\n    83→  if (listeners) {\n    84→    const roundCopy = { ...round, players: [...round.players] };\n    85→    listeners.forEach((cb) => cb(roundCopy));\n    86→  }\n    87→}\n    88→\n    89→// ============ Round Management ============\n    90→\n    91→// Store for server seeds (revealed after settlement)\n    92→const serverSeeds = new Map<string, { serverSeed: string; blockHash: string; vrfProof: string }>();\n    93→\n    94→function createRound(tier: Tier): Round {\n    95→  const id = generateRoundId();\n    96→  const fairnessData = generateFairnessData();\n    97→\n    98→  // Store the secret data to reveal later\n    99→  serverSeeds.set(id, {\n   100→    serverSeed: fairnessData.serverSeed,\n   101→    blockHash: fairnessData.blockHash,\n   102→    vrfProof: fairnessData.vrfProof,\n   103→  });\n   104→\n   105→  const round: Round = {\n   106→    id,\n   107→    tier,\n   108→    entryAmount: TIER_AMOUNTS[tier],\n   109→    phase: \"waiting\",\n   110→    players: [],\n   111→    totalEntries: 0,\n   112→    poolAmount: 0,\n   113→    createdAt: Date.now(),\n   114→    seedHash: fairnessData.seedHash, // Public from the start\n   115→  };\n   116→\n   117→  store.rounds.set(id, round);\n   118→  store.tierRounds.set(tier, id);\n   119→\n   120→  return round;\n   121→}\n   122→\n   123→export function getOrCreateRound(tier: Tier): Round {\n   124→  const existingRoundId = store.tierRounds.get(tier);\n   125→  if (existingRoundId) {\n   126→    const existing = store.rounds.get(existingRoundId);\n   127→    if (existing && existing.phase !== \"complete\") {\n   128→      return existing;\n   129→    }\n   130→  }\n   131→\n   132→  return createRound(tier);\n   133→}\n   134→\n   135→export function getRound(roundId: string): Round | undefined {\n   136→  return store.rounds.get(roundId);\n   137→}\n   138→\n   139→export function getRoundByTier(tier: Tier): Round | undefined {\n   140→  const roundId = store.tierRounds.get(tier);\n   141→  return roundId ? store.rounds.get(roundId) : undefined;\n   142→}\n   143→\n   144→export function getAllTierRounds(): Map<Tier, Round> {\n   145→  const result = new Map<Tier, Round>();\n   146→  for (const tier of TIERS) {\n   147→    const round = getOrCreateRound(tier);\n   148→    result.set(tier, round);\n   149→  }\n   150→  return result;\n   151→}\n   152→\n   153→// ============ Player Actions ============\n   154→\n   155→export function joinRound(\n   156→  tier: Tier,\n   157→  playerAddress: string,\n   158→  entries: number,\n   159→  isCurrentUser: boolean = false\n   160→): Round {\n   161→  const round = getOrCreateRound(tier);\n   162→\n   163→  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n   164→    throw new Error(\"Cannot join round in this phase\");\n   165→  }\n   166→\n   167→  // Check if player already exists\n   168→  const existingPlayer = round.players.find((p) => p.address === playerAddress);\n   169→\n   170→  if (existingPlayer) {\n   171→    // Add more entries\n   172→    existingPlayer.entries += entries;\n   173→  } else {\n   174→    // New player\n   175→    const colorIndex = round.players.length;\n   176→    const player: PlayerEntry = {\n   177→      address: playerAddress,\n   178→      entries,\n   179→      color: getPlayerColor(colorIndex, isCurrentUser),\n   180→    };\n   181→    round.players.push(player);\n   182→  }\n   183→\n   184→  round.totalEntries += entries;\n   185→  round.poolAmount += entries * round.entryAmount;\n   186→\n   187→  // Emit wager placed event (triggers RNG buff chest drop check)\n   188→  const wagerAmount = entries * round.entryAmount;\n   189→  emitWagerPlaced(\"lord-of-rngs\", round.id, playerAddress, wagerAmount);\n   190→\n   191→  store.rounds.set(round.id, round);\n   192→  notifyListeners(round.id, round);\n   193→\n   194→  // Check if we should start countdown (2+ players)\n   195→  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n   196→    startCountdown(round.id);\n   197→  }\n   198→\n   199→  // If in waiting phase and this is a real user, schedule mock players\n   200→  if (round.phase === \"waiting\" && isCurrentUser) {\n   201→    scheduleMockPlayers(round.id);\n   202→  }\n   203→\n   204→  return round;\n   205→}\n   206→\n   207→export function buyMoreEntries(\n   208→  roundId: string,\n   209→  playerAddress: string,\n   210→  entries: number\n   211→): Round {\n   212→  const round = store.rounds.get(roundId);\n   213→  if (!round) throw new Error(\"Round not found\");\n   214→\n   215→  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n   216→    throw new Error(\"Cannot buy entries in this phase\");\n   217→  }\n   218→\n   219→  const player = round.players.find((p) => p.address === playerAddress);\n   220→  if (!player) throw new Error(\"Player not in this round\");\n   221→\n   222→  player.entries += entries;\n   223→  round.totalEntries += entries;\n   224→  round.poolAmount += entries * round.entryAmount;\n   225→\n   226→  // Emit wager placed event (triggers RNG buff chest drop check)\n   227→  const wagerAmount = entries * round.entryAmount;\n   228→  emitWagerPlaced(\"lord-of-rngs\", roundId, playerAddress, wagerAmount);\n   229→\n   230→  store.rounds.set(roundId, round);\n   231→  notifyListeners(roundId, round);\n   232→\n   233→  return round;\n   234→}\n   235→\n   236→// ============ Phase Transitions ============\n   237→\n   238→function startCountdown(roundId: string): void {\n   239→  const round = store.rounds.get(roundId);\n   240→  if (!round || round.phase !== \"waiting\") return;\n   241→\n   242→  round.phase = \"countdown\";\n   243→  round.countdownStartedAt = Date.now();\n   244→  round.countdownEndsAt = Date.now() + COUNTDOWN_DURATION;\n   245→\n   246→  store.rounds.set(roundId, round);\n   247→  notifyListeners(roundId, round);\n   248→\n   249→  // Schedule spin when countdown ends\n   250→  setTimeout(() => startSpinning(roundId), COUNTDOWN_DURATION);\n   251→\n   252→  // Schedule more mock players during countdown\n   253→  scheduleMockPlayersDuringCountdown(roundId);\n   254→}\n   255→\n   256→function startSpinning(roundId: string): void {\n   257→  const round = store.rounds.get(roundId);\n   258→  if (!round || round.phase !== \"countdown\") return;\n   259→\n   260→  // Cancel any pending mock player timers\n   261→  cancelMockPlayerTimers(roundId);\n   262→\n   263→  // Simulate VRF - pick a random winning slot\n   264→  const winningSlot = Math.floor(Math.random() * round.totalEntries);\n   265→\n   266→  round.phase = \"spinning\";\n   267→  round.winningSlot = winningSlot;\n   268→\n   269→  store.rounds.set(roundId, round);\n   270→  notifyListeners(roundId, round);\n   271→\n   272→  // Reveal winner after spin animation\n   273→  setTimeout(() => resolveRound(roundId), SPIN_DURATION);\n   274→}\n   275→\n   276→function resolveRound(roundId: string): void {\n   277→  const round = store.rounds.get(roundId);\n   278→  if (!round || round.phase !== \"spinning\") return;\n   279→\n   280→  // Determine winner based on winning slot\n   281→  let slotCount = 0;\n   282→  let winner: string | undefined;\n   283→\n   284→  for (const player of round.players) {\n   285→    slotCount += player.entries;\n   286→    if (round.winningSlot! < slotCount && !winner) {\n   287→      winner = player.address;\n   288→    }\n   289→  }\n   290→\n   291→  // Reveal the fairness data now that the round is settled\n   292→  const secrets = serverSeeds.get(roundId);\n   293→  if (secrets) {\n   294→    round.serverSeed = secrets.serverSeed;\n   295→    round.blockHash = secrets.blockHash;\n   296→    round.vrfProof = secrets.vrfProof;\n   297→  }\n   298→\n   299→  // First enter revealing phase to show the winner\n   300→  round.phase = \"revealing\";\n   301→  round.winner = winner;\n   302→  round.payoutAmount = calculatePayout(round.poolAmount);\n   303→\n   304→  store.rounds.set(roundId, round);\n   305→  notifyListeners(roundId, round);\n   306→\n   307→  // After reveal duration, complete the round and start new one\n   308→  setTimeout(() => completeRound(roundId), REVEAL_DURATION);\n   309→}\n   310→\n   311→function completeRound(roundId: string): void {\n   312→  const round = store.rounds.get(roundId);\n   313→  if (!round || round.phase !== \"revealing\") return;\n   314→\n   315→  round.phase = \"complete\";\n   316→  round.completedAt = Date.now();\n   317→\n   318→  store.rounds.set(roundId, round);\n   319→  notifyListeners(roundId, round);\n   320→\n   321→  // Emit event for Boss Raid\n   322→  if (round.players.length > 0) {\n   323→    const entries = round.players.map((p) => ({\n   324→      address: p.address,\n   325→      entries: p.entries,\n   326→    }));\n   327→    emitLordOfRngsComplete(roundId, entries, round.entryAmount);\n   328→  }\n   329→\n   330→  // Emit event for Player Profile (XP and stats tracking)\n   331→  if (round.players.length > 0 && round.winner) {\n   332→    const participants = round.players.map((p) => ({\n   333→      address: p.address,\n   334→      totalWager: p.entries * round.entryAmount,\n   335→    }));\n   336→    emitLordOfRngsResults(\n   337→      roundId,\n   338→      round.winner,\n   339→      participants,\n   340→      round.payoutAmount ?? 0,\n   341→      round.tier\n   342→    );\n   343→  }\n   344→\n   345→  // Create a new round for this tier immediately\n   346→  store.tierRounds.delete(round.tier);\n   347→  const newRound = getOrCreateRound(round.tier);\n   348→\n   349→  // Schedule mock players for the new round to keep game alive\n   350→  scheduleMockPlayers(newRound.id);\n   351→}\n   352→\n   353→// ============ Mock Player Simulation ============\n   354→\n   355→function scheduleMockPlayers(roundId: string): void {\n   356→  const round = store.rounds.get(roundId);\n   357→  if (!round) return;\n   358→\n   359→  // Schedule 1-3 mock players to join over next 3-8 seconds\n   360→  const mockCount = 1 + Math.floor(Math.random() * 3);\n   361→  const timers: TimerId[] = [];\n   362→\n   363→  for (let i = 0; i < mockCount; i++) {\n   364→    const delay = 3000 + Math.random() * 5000;\n   365→    const timer = setTimeout(() => addMockPlayer(roundId), delay);\n   366→    timers.push(timer);\n   367→  }\n   368→\n   369→  store.mockPlayerTimers.set(roundId, timers);\n   370→}\n   371→\n   372→function scheduleMockPlayersDuringCountdown(roundId: string): void {\n   373→  const round = store.rounds.get(roundId);\n   374→  if (!round) return;\n   375→\n   376→  // Schedule 2-5 more mock players during countdown\n   377→  const mockCount = 2 + Math.floor(Math.random() * 4);\n   378→  const existingTimers = store.mockPlayerTimers.get(roundId) ?? [];\n   379→\n   380→  for (let i = 0; i < mockCount; i++) {\n   381→    const delay = 5000 + Math.random() * 45000; // Spread over first 50s of countdown\n   382→    const timer = setTimeout(() => {\n   383→      const r = store.rounds.get(roundId);\n   384→      if (r?.phase === \"countdown\") {\n   385→        addMockPlayer(roundId);\n   386→      }\n   387→    }, delay);\n   388→    existingTimers.push(timer);\n   389→  }\n   390→\n   391→  store.mockPlayerTimers.set(roundId, existingTimers);\n   392→}\n   393→\n   394→function addMockPlayer(roundId: string): void {\n   395→  const round = store.rounds.get(roundId);\n   396→  if (!round || (round.phase !== \"waiting\" && round.phase !== \"countdown\")) return;\n   397→\n   398→  const address = generateMockAddress();\n   399→  const entries = 1 + Math.floor(Math.random() * 3); // 1-3 entries\n   400→\n   401→  const colorIndex = round.players.length;\n   402→  const player: PlayerEntry = {\n   403→    address,\n   404→    entries,\n   405→    color: getPlayerColor(colorIndex, false),\n   406→  };\n   407→\n   408→  round.players.push(player);\n   409→  round.totalEntries += entries;\n   410→  round.poolAmount += entries * round.entryAmount;\n   411→\n   412→  store.rounds.set(roundId, round);\n   413→  notifyListeners(roundId, round);\n   414→\n   415→  // Start countdown if we now have enough players\n   416→  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n   417→    startCountdown(roundId);\n   418→  }\n   419→}\n   420→\n   421→function cancelMockPlayerTimers(roundId: string): void {\n   422→  const timers = store.mockPlayerTimers.get(roundId);\n   423→  if (timers) {\n   424→    timers.forEach(clearTimeout);\n   425→    store.mockPlayerTimers.delete(roundId);\n   426→  }\n   427→}\n   428→\n   429→// ============ Subscription ============\n   430→\n   431→export function subscribeToRound(\n   432→  roundId: string,\n   433→  callback: (round: Round) => void\n   434→): () => void {\n   435→  if (!store.listeners.has(roundId)) {\n   436→    store.listeners.set(roundId, new Set());\n   437→  }\n   438→  store.listeners.get(roundId)!.add(callback);\n   439→\n   440→  return () => {\n   441→    store.listeners.get(roundId)?.delete(callback);\n   442→  };\n   443→}\n   444→\n   445→// ============ User History ============\n   446→\n   447→export function getUserRounds(playerAddress: string): Round[] {\n   448→  const rounds: Round[] = [];\n   449→\n   450→  store.rounds.forEach((round) => {\n   451→    if (round.players.some((p) => p.address === playerAddress)) {\n   452→      rounds.push(round);\n   453→    }\n   454→  });\n   455→\n   456→  return rounds.sort((a, b) => b.createdAt - a.createdAt);\n   457→}\n   458→\n   459→// ============ Initialize Mock Rounds ============\n   460→\n   461→export function initializeMockRounds(): void {\n   462→  // Create initial rounds for each tier with some mock players\n   463→  for (const tier of TIERS) {\n   464→    const round = getOrCreateRound(tier);\n   465→\n   466→    // Add 0-3 initial mock players to each tier\n   467→    const initialPlayers = Math.floor(Math.random() * 4);\n   468→    for (let i = 0; i < initialPlayers; i++) {\n   469→      const address = generateMockAddress();\n   470→      const entries = 1 + Math.floor(Math.random() * 2);\n   471→      const player: PlayerEntry = {\n   472→        address,\n   473→        entries,\n   474→        color: getPlayerColor(i, false),\n   475→      };\n   476→      round.players.push(player);\n   477→      round.totalEntries += entries;\n   478→      round.poolAmount += entries * round.entryAmount;\n   479→    }\n   480→\n   481→    store.rounds.set(round.id, round);\n   482→\n   483→    // Start countdown if 2+ players already exist\n   484→    if (round.players.length >= MIN_PLAYERS) {\n   485→      startCountdown(round.id);\n   486→    } else if (round.players.length >= 1) {\n   487→      // Schedule more mock players to eventually start the round\n   488→      scheduleMockPlayers(round.id);\n   489→    }\n   490→  }\n   491→}\n   492→"}]},"parent_tool_use_id":null,"session_id":"cc54e4bc-17c9-4774-b61a-be37e6291ab9","uuid":"f0ec3722-f90c-4fe4-8d0b-1b91d7000bd5","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/lord-of-rngs/utils/mock-simulation.ts","content":"import { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { Round, PlayerEntry } from \"../types\";\nimport { PLAYER_COLORS } from \"../types\";\nimport { emitLordOfRngsComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\nimport { emitLordOfRngsResults } from \"../../player-profile/utils/profile-event-bus\";\n\n// ============ Constants ============\n\nconst COUNTDOWN_DURATION = 60000; // 60 seconds\nconst SPIN_DURATION = 5000; // 5 seconds\nconst REVEAL_DURATION = 3000; // 3 seconds to show winner before new round\nconst MIN_PLAYERS = 2; // Minimum 2 different players (not just entries)\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\n// ============ Mock Store ============\n\ntype TimerId = ReturnType<typeof setTimeout>;\n\ninterface MockStore {\n  rounds: Map<string, Round>; // roundId -> Round\n  tierRounds: Map<Tier, string>; // tier -> current round ID\n  listeners: Map<string, Set<(round: Round) => void>>;\n  mockPlayerTimers: Map<string, TimerId[]>;\n}\n\nconst store: MockStore = {\n  rounds: new Map(),\n  tierRounds: new Map(),\n  listeners: new Map(),\n  mockPlayerTimers: new Map(),\n};\n\n// ============ Helpers ============\n\nfunction generateRoundId(): string {\n  return `lotr-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n}\n\nfunction generateMockAddress(): string {\n  const chars = \"123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz\";\n  let addr = \"\";\n  for (let i = 0; i < 44; i++) {\n    addr += chars[Math.floor(Math.random() * chars.length)];\n  }\n  return addr;\n}\n\n// Generate a mock hex string (simulates SHA-256 hash or seed)\nfunction generateMockHexString(length: number = 64): string {\n  const chars = \"0123456789abcdef\";\n  let result = \"\";\n  for (let i = 0; i < length; i++) {\n    result += chars[Math.floor(Math.random() * chars.length)];\n  }\n  return result;\n}\n\n// Generate mock provably fair data\nfunction generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string; vrfProof: string } {\n  const serverSeed = generateMockHexString(64); // 256-bit seed\n  const seedHash = generateMockHexString(64); // SHA-256 hash of server seed\n  const blockHash = generateMockHexString(88); // Solana blockhash format\n  const vrfProof = generateMockHexString(128); // VRF proof\n  return { seedHash, serverSeed, blockHash, vrfProof };\n}\n\nexport function truncateAddress(address: string): string {\n  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n}\n\nfunction getPlayerColor(index: number, isCurrentUser: boolean): string {\n  if (isCurrentUser) return PLAYER_COLORS[0] ?? \"#45b058\"; // Neon green for current user\n  return PLAYER_COLORS[(index % (PLAYER_COLORS.length - 1)) + 1] ?? \"#888888\";\n}\n\nfunction calculatePayout(poolAmount: number): number {\n  return poolAmount * 0.97; // 97% after 3% fee\n}\n\nfunction notifyListeners(roundId: string, round: Round): void {\n  const listeners = store.listeners.get(roundId);\n  if (listeners) {\n    const roundCopy = { ...round, players: [...round.players] };\n    listeners.forEach((cb) => cb(roundCopy));\n  }\n}\n\n// ============ Round Management ============\n\n// Store for server seeds (revealed after settlement)\nconst serverSeeds = new Map<string, { serverSeed: string; blockHash: string; vrfProof: string }>();\n\nfunction createRound(tier: Tier): Round {\n  const id = generateRoundId();\n  const fairnessData = generateFairnessData();\n\n  // Store the secret data to reveal later\n  serverSeeds.set(id, {\n    serverSeed: fairnessData.serverSeed,\n    blockHash: fairnessData.blockHash,\n    vrfProof: fairnessData.vrfProof,\n  });\n\n  const round: Round = {\n    id,\n    tier,\n    entryAmount: TIER_AMOUNTS[tier],\n    phase: \"waiting\",\n    players: [],\n    totalEntries: 0,\n    poolAmount: 0,\n    createdAt: Date.now(),\n    seedHash: fairnessData.seedHash, // Public from the start\n  };\n\n  store.rounds.set(id, round);\n  store.tierRounds.set(tier, id);\n\n  return round;\n}\n\nexport function getOrCreateRound(tier: Tier): Round {\n  const existingRoundId = store.tierRounds.get(tier);\n  if (existingRoundId) {\n    const existing = store.rounds.get(existingRoundId);\n    if (existing && existing.phase !== \"complete\") {\n      return existing;\n    }\n  }\n\n  return createRound(tier);\n}\n\nexport function getRound(roundId: string): Round | undefined {\n  return store.rounds.get(roundId);\n}\n\nexport function getRoundByTier(tier: Tier): Round | undefined {\n  const roundId = store.tierRounds.get(tier);\n  return roundId ? store.rounds.get(roundId) : undefined;\n}\n\nexport function getAllTierRounds(): Map<Tier, Round> {\n  const result = new Map<Tier, Round>();\n  for (const tier of TIERS) {\n    const round = getOrCreateRound(tier);\n    result.set(tier, round);\n  }\n  return result;\n}\n\n// ============ Player Actions ============\n\nexport function joinRound(\n  tier: Tier,\n  playerAddress: string,\n  entries: number,\n  isCurrentUser: boolean = false\n): Round {\n  const round = getOrCreateRound(tier);\n\n  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n    throw new Error(\"Cannot join round in this phase\");\n  }\n\n  // Check if player already exists\n  const existingPlayer = round.players.find((p) => p.address === playerAddress);\n\n  if (existingPlayer) {\n    // Add more entries\n    existingPlayer.entries += entries;\n  } else {\n    // New player\n    const colorIndex = round.players.length;\n    const player: PlayerEntry = {\n      address: playerAddress,\n      entries,\n      color: getPlayerColor(colorIndex, isCurrentUser),\n    };\n    round.players.push(player);\n  }\n\n  round.totalEntries += entries;\n  round.poolAmount += entries * round.entryAmount;\n\n  // Emit wager placed event (triggers RNG buff chest drop check)\n  const wagerAmount = entries * round.entryAmount;\n  emitWagerPlaced(\"lord-of-rngs\", round.id, playerAddress, wagerAmount);\n\n  store.rounds.set(round.id, round);\n  notifyListeners(round.id, round);\n\n  // Check if we should start countdown (2+ players)\n  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n    startCountdown(round.id);\n  }\n\n  // If in waiting phase and this is a real user, schedule mock players\n  if (round.phase === \"waiting\" && isCurrentUser) {\n    scheduleMockPlayers(round.id);\n  }\n\n  return round;\n}\n\nexport function buyMoreEntries(\n  roundId: string,\n  playerAddress: string,\n  entries: number\n): Round {\n  const round = store.rounds.get(roundId);\n  if (!round) throw new Error(\"Round not found\");\n\n  if (round.phase === \"spinning\" || round.phase === \"complete\") {\n    throw new Error(\"Cannot buy entries in this phase\");\n  }\n\n  const player = round.players.find((p) => p.address === playerAddress);\n  if (!player) throw new Error(\"Player not in this round\");\n\n  player.entries += entries;\n  round.totalEntries += entries;\n  round.poolAmount += entries * round.entryAmount;\n\n  // Emit wager placed event (triggers RNG buff chest drop check)\n  const wagerAmount = entries * round.entryAmount;\n  emitWagerPlaced(\"lord-of-rngs\", roundId, playerAddress, wagerAmount);\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  return round;\n}\n\n// ============ Phase Transitions ============\n\nfunction startCountdown(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || round.phase !== \"waiting\") return;\n\n  round.phase = \"countdown\";\n  round.countdownStartedAt = Date.now();\n  round.countdownEndsAt = Date.now() + COUNTDOWN_DURATION;\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // Schedule spin when countdown ends\n  setTimeout(() => startSpinning(roundId), COUNTDOWN_DURATION);\n\n  // Schedule more mock players during countdown\n  scheduleMockPlayersDuringCountdown(roundId);\n}\n\nfunction startSpinning(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || round.phase !== \"countdown\") return;\n\n  // Cancel any pending mock player timers\n  cancelMockPlayerTimers(roundId);\n\n  // Simulate VRF - pick a random winning slot\n  const winningSlot = Math.floor(Math.random() * round.totalEntries);\n\n  round.phase = \"spinning\";\n  round.winningSlot = winningSlot;\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // Reveal winner after spin animation\n  setTimeout(() => resolveRound(roundId), SPIN_DURATION);\n}\n\nfunction resolveRound(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || round.phase !== \"spinning\") return;\n\n  // Determine winner based on winning slot\n  let slotCount = 0;\n  let winner: string | undefined;\n\n  for (const player of round.players) {\n    slotCount += player.entries;\n    if (round.winningSlot! < slotCount && !winner) {\n      winner = player.address;\n    }\n  }\n\n  // Reveal the fairness data now that the round is settled\n  const secrets = serverSeeds.get(roundId);\n  if (secrets) {\n    round.serverSeed = secrets.serverSeed;\n    round.blockHash = secrets.blockHash;\n    round.vrfProof = secrets.vrfProof;\n  }\n\n  // First enter revealing phase to show the winner\n  round.phase = \"revealing\";\n  round.winner = winner;\n  round.payoutAmount = calculatePayout(round.poolAmount);\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // After reveal duration, complete the round and start new one\n  setTimeout(() => completeRound(roundId), REVEAL_DURATION);\n}\n\nfunction completeRound(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || round.phase !== \"revealing\") return;\n\n  round.phase = \"complete\";\n  round.completedAt = Date.now();\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // Emit event for Boss Raid\n  if (round.players.length > 0) {\n    const entries = round.players.map((p) => ({\n      address: p.address,\n      entries: p.entries,\n    }));\n    emitLordOfRngsComplete(roundId, entries, round.entryAmount);\n  }\n\n  // Emit event for Player Profile (XP and stats tracking)\n  if (round.players.length > 0 && round.winner) {\n    const participants = round.players.map((p) => ({\n      address: p.address,\n      totalWager: p.entries * round.entryAmount,\n    }));\n    emitLordOfRngsResults(\n      roundId,\n      round.winner,\n      participants,\n      round.payoutAmount ?? 0,\n      round.tier\n    );\n  }\n\n  // Create a new round for this tier immediately\n  store.tierRounds.delete(round.tier);\n  const newRound = getOrCreateRound(round.tier);\n\n  // Schedule mock players for the new round to keep game alive\n  scheduleMockPlayers(newRound.id);\n}\n\n// ============ Mock Player Simulation ============\n\nfunction scheduleMockPlayers(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round) return;\n\n  // Schedule 1-3 mock players to join over next 3-8 seconds\n  const mockCount = 1 + Math.floor(Math.random() * 3);\n  const timers: TimerId[] = [];\n\n  for (let i = 0; i < mockCount; i++) {\n    const delay = 3000 + Math.random() * 5000;\n    const timer = setTimeout(() => addMockPlayer(roundId), delay);\n    timers.push(timer);\n  }\n\n  store.mockPlayerTimers.set(roundId, timers);\n}\n\nfunction scheduleMockPlayersDuringCountdown(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round) return;\n\n  // Schedule 2-5 more mock players during countdown\n  const mockCount = 2 + Math.floor(Math.random() * 4);\n  const existingTimers = store.mockPlayerTimers.get(roundId) ?? [];\n\n  for (let i = 0; i < mockCount; i++) {\n    const delay = 5000 + Math.random() * 45000; // Spread over first 50s of countdown\n    const timer = setTimeout(() => {\n      const r = store.rounds.get(roundId);\n      if (r?.phase === \"countdown\") {\n        addMockPlayer(roundId);\n      }\n    }, delay);\n    existingTimers.push(timer);\n  }\n\n  store.mockPlayerTimers.set(roundId, existingTimers);\n}\n\nfunction addMockPlayer(roundId: string): void {\n  const round = store.rounds.get(roundId);\n  if (!round || (round.phase !== \"waiting\" && round.phase !== \"countdown\")) return;\n\n  const address = generateMockAddress();\n  const entries = 1 + Math.floor(Math.random() * 3); // 1-3 entries\n\n  const colorIndex = round.players.length;\n  const player: PlayerEntry = {\n    address,\n    entries,\n    color: getPlayerColor(colorIndex, false),\n  };\n\n  round.players.push(player);\n  round.totalEntries += entries;\n  round.poolAmount += entries * round.entryAmount;\n\n  store.rounds.set(roundId, round);\n  notifyListeners(roundId, round);\n\n  // Start countdown if we now have enough players\n  if (round.phase === \"waiting\" && round.players.length >= MIN_PLAYERS) {\n    startCountdown(roundId);\n  }\n}\n\nfunction cancelMockPlayerTimers(roundId: string): void {\n  const timers = store.mockPlayerTimers.get(roundId);\n  if (timers) {\n    timers.forEach(clearTimeout);\n    store.mockPlayerTimers.delete(roundId);\n  }\n}\n\n// ============ Subscription ============\n\nexport function subscribeToRound(\n  roundId: string,\n  callback: (round: Round) => void\n): () => void {\n  if (!store.listeners.has(roundId)) {\n    store.listeners.set(roundId, new Set());\n  }\n  store.listeners.get(roundId)!.add(callback);\n\n  return () => {\n    store.listeners.get(roundId)?.delete(callback);\n  };\n}\n\n// ============ User History ============\n\nexport function getUserRounds(playerAddress: string): Round[] {\n  const rounds: Round[] = [];\n\n  store.rounds.forEach((round) => {\n    if (round.players.some((p) => p.address === playerAddress)) {\n      rounds.push(round);\n    }\n  });\n\n  return rounds.sort((a, b) => b.createdAt - a.createdAt);\n}\n\n// ============ Initialize Mock Rounds ============\n\nexport function initializeMockRounds(): void {\n  // Create initial rounds for each tier with some mock players\n  for (const tier of TIERS) {\n    const round = getOrCreateRound(tier);\n\n    // Add 0-3 initial mock players to each tier\n    const initialPlayers = Math.floor(Math.random() * 4);\n    for (let i = 0; i < initialPlayers; i++) {\n      const address = generateMockAddress();\n      const entries = 1 + Math.floor(Math.random() * 2);\n      const player: PlayerEntry = {\n        address,\n        entries,\n        color: getPlayerColor(i, false),\n      };\n      round.players.push(player);\n      round.totalEntries += entries;\n      round.poolAmount += entries * round.entryAmount;\n    }\n\n    store.rounds.set(round.id, round);\n\n    // Start countdown if 2+ players already exist\n    if (round.players.length >= MIN_PLAYERS) {\n      startCountdown(round.id);\n    } else if (round.players.length >= 1) {\n      // Schedule more mock players to eventually start the round\n      scheduleMockPlayers(round.id);\n    }\n  }\n}\n","numLines":492,"startLine":1,"totalLines":492}}}
