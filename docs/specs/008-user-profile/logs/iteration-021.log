{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SbYxAWKpySeKWNZML3aC5o","type":"tool_result","content":"1\t/**\n2\t * Profile routes — transaction history for the authenticated player.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport type { AppEnv } from \"../hono-env.js\";\n7\timport type { Db } from \"../db.js\";\n8\timport { logger } from \"../logger.js\";\n9\t\n10\texport interface ProfileRoutesDeps {\n11\t  db: Db;\n12\t}\n13\t\n14\t/** Map DB game names to frontend game IDs */\n15\tconst GAME_TO_FRONTEND: Record<string, string> = {\n16\t  coinflip: \"coinflip\",\n17\t  lord: \"lord-of-rngs\",\n18\t  closecall: \"close-call\",\n19\t};\n20\t\n21\t/** Map frontend/DB game names to canonical DB names */\n22\tconst TO_DB_GAME: Record<string, string> = {\n23\t  coinflip: \"coinflip\",\n24\t  lord: \"lord\",\n25\t  closecall: \"closecall\",\n26\t  \"lord-of-rngs\": \"lord\",\n27\t  \"close-call\": \"closecall\",\n28\t};\n29\t\n30\texport function createProfileRoutes(deps: ProfileRoutesDeps) {\n31\t  const { db } = deps;\n32\t  const app = new Hono<AppEnv>();\n33\t\n34\t  // GET /me — full profile + stats for authenticated player\n35\t  app.get(\"/me\", async (c) => {\n36\t    const wallet = c.get(\"wallet\");\n37\t    if (!wallet) {\n38\t      return c.json({ error: \"Authentication required\" }, 401);\n39\t    }\n40\t\n41\t    try {\n42\t      const profile = await db.getProfileByWallet(wallet);\n43\t      if (!profile) {\n44\t        return c.json({ error: \"PROFILE_NOT_FOUND\" }, 404);\n45\t      }\n46\t\n47\t      const [stats, streaks, breakdown] = await Promise.all([\n48\t        db.getPlayerStats(wallet),\n49\t        db.getWinStreaks(wallet),\n50\t        db.getGameBreakdown(wallet),\n51\t      ]);\n52\t\n53\t      // Serialize BigInt fields as strings, compute next edit timestamp\n54\t      const usernameNextEditAt = profile.username_updated_at\n55\t        ? new Date(profile.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n56\t        : null;\n57\t\n58\t      // Map breakdown BigInt values to strings\n59\t      const serializedBreakdown: Record<string, object> = {};\n60\t      for (const [game, gs] of Object.entries(breakdown)) {\n61\t        serializedBreakdown[game] = {\n62\t          gamesPlayed: gs.gamesPlayed,\n63\t          totalWagered: String(gs.totalWagered),\n64\t          totalWins: gs.totalWins,\n65\t          winRate: gs.winRate,\n66\t          netPnl: String(gs.netPnl),\n67\t        };\n68\t      }\n69\t\n70\t      return c.json({\n71\t        userId: profile.user_id,\n72\t        username: profile.username,\n73\t        avatarUrl: profile.avatar_url,\n74\t        heatMultiplier: profile.heat_multiplier,\n75\t        pointsBalance: String(profile.points_balance),\n76\t        stats: {\n77\t          gamesPlayed: stats.gamesPlayed,\n78\t          totalWagered: String(stats.totalWagered),\n79\t          totalWins: stats.totalWins,\n80\t          winRate: stats.winRate,\n81\t          winStreakCurrent: streaks.current,\n82\t          winStreakBest: streaks.best,\n83\t          netPnl: String(stats.netPnl),\n84\t          gameBreakdown: serializedBreakdown,\n85\t        },\n86\t        usernameNextEditAt,\n87\t        createdAt: profile.created_at.toISOString(),\n88\t      });\n89\t    } catch (err) {\n90\t      logger.error(\"profile/me failed\", {\n91\t        wallet,\n92\t        error: err instanceof Error ? err.message : \"Unknown error\",\n93\t      });\n94\t      return c.json({ error: \"Failed to fetch profile\" }, 500);\n95\t    }\n96\t  });\n97\t\n98\t  app.get(\"/transactions\", async (c) => {\n99\t    const wallet = c.get(\"wallet\");\n100\t    if (!wallet) {\n101\t      return c.json({ error: \"Authentication required\" }, 401);\n102\t    }\n103\t\n104\t    // Parse query params\n105\t    const cursor = c.req.query(\"cursor\") || undefined;\n106\t    const limitParam = c.req.query(\"limit\");\n107\t    const gameParam = c.req.query(\"game\") || undefined;\n108\t\n109\t    // Validate & clamp limit\n110\t    let limit = 20;\n111\t    if (limitParam) {\n112\t      const parsed = parseInt(limitParam, 10);\n113\t      if (!isNaN(parsed) && parsed > 0) {\n114\t        limit = Math.min(parsed, 50);\n115\t      }\n116\t    }\n117\t\n118\t    // Map game filter to DB name (accept both DB and frontend names)\n119\t    let dbGame: string | undefined;\n120\t    if (gameParam) {\n121\t      dbGame = TO_DB_GAME[gameParam];\n122\t      if (!dbGame) {\n123\t        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n124\t      }\n125\t    }\n126\t\n127\t    try {\n128\t      const rows = await db.getTransactions(wallet, cursor, limit, dbGame);\n129\t\n130\t      const transactions = rows.map((row) => ({\n131\t        id: row.id,\n132\t        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n133\t        matchId: row.match_id,\n134\t        txType: row.tx_type,\n135\t        amountLamports: String(row.amount_lamports),\n136\t        txSig: row.tx_sig,\n137\t        createdAt: row.created_at.toISOString(),\n138\t      }));\n139\t\n140\t      const nextCursor =\n141\t        transactions.length === limit\n142\t          ? String(transactions[transactions.length - 1]!.id)\n143\t          : null;\n144\t\n145\t      return c.json({ transactions, nextCursor });\n146\t    } catch (err) {\n147\t      logger.error(\"profile transactions query failed\", {\n148\t        wallet,\n149\t        error: err instanceof Error ? err.message : \"Unknown error\",\n150\t      });\n151\t      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n152\t    }\n153\t  });\n154\t\n155\t  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n156\t  app.post(\"/confirm-tx\", async (c) => {\n157\t    const wallet = c.get(\"wallet\");\n158\t    if (!wallet) {\n159\t      return c.json({ error: \"Authentication required\" }, 401);\n160\t    }\n161\t\n162\t    const body = await c.req.json<{\n163\t      game?: string;\n164\t      matchId?: string;\n165\t      txType?: string;\n166\t      txSig?: string;\n167\t      amountLamports?: number;\n168\t    }>();\n169\t\n170\t    if (!body.game || !body.matchId || !body.txType || !body.txSig || !body.amountLamports) {\n171\t      return c.json({ error: \"Missing required fields: game, matchId, txType, txSig, amountLamports\" }, 400);\n172\t    }\n173\t\n174\t    const validTypes = [\"deposit\", \"refund\"];\n175\t    if (!validTypes.includes(body.txType)) {\n176\t      return c.json({ error: `Invalid txType: ${body.txType}. Must be one of: ${validTypes.join(\", \")}` }, 400);\n177\t    }\n178\t\n179\t    // Map to DB game name\n180\t    const dbGame = TO_DB_GAME[body.game];\n181\t    if (!dbGame) {\n182\t      return c.json({ error: `Invalid game: ${body.game}` }, 400);\n183\t    }\n184\t\n185\t    try {\n186\t      await db.insertTransaction({\n187\t        wallet,\n188\t        game: dbGame,\n189\t        matchId: body.matchId,\n190\t        txType: body.txType as \"deposit\" | \"refund\",\n191\t        amountLamports: body.amountLamports,\n192\t        txSig: body.txSig,\n193\t      });\n194\t      return c.json({ ok: true });\n195\t    } catch (err) {\n196\t      logger.error(\"confirm-tx failed\", {\n197\t        wallet,\n198\t        txType: body.txType,\n199\t        error: err instanceof Error ? err.message : \"Unknown error\",\n200\t      });\n201\t      return c.json({ error: \"Failed to record transaction\" }, 500);\n202\t    }\n203\t  });\n204\t\n205\t  return app;\n206\t}\n207\t"}]},"parent_tool_use_id":null,"session_id":"3ce9b3ab-0f79-4b2c-b401-722a17ea0805","uuid":"1d0d981f-34fd-41f0-ad60-4739c867fe10","timestamp":"2026-03-31T15:14:59.769Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/routes/profile.ts","content":"/**\n * Profile routes — transaction history for the authenticated player.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ProfileRoutesDeps {\n  db: Db;\n}\n\n/** Map DB game names to frontend game IDs */\nconst GAME_TO_FRONTEND: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord-of-rngs\",\n  closecall: \"close-call\",\n};\n\n/** Map frontend/DB game names to canonical DB names */\nconst TO_DB_GAME: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord\",\n  closecall: \"closecall\",\n  \"lord-of-rngs\": \"lord\",\n  \"close-call\": \"closecall\",\n};\n\nexport function createProfileRoutes(deps: ProfileRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  // GET /me — full profile + stats for authenticated player\n  app.get(\"/me\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const profile = await db.getProfileByWallet(wallet);\n      if (!profile) {\n        return c.json({ error: \"PROFILE_NOT_FOUND\" }, 404);\n      }\n\n      const [stats, streaks, breakdown] = await Promise.all([\n        db.getPlayerStats(wallet),\n        db.getWinStreaks(wallet),\n        db.getGameBreakdown(wallet),\n      ]);\n\n      // Serialize BigInt fields as strings, compute next edit timestamp\n      const usernameNextEditAt = profile.username_updated_at\n        ? new Date(profile.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n        : null;\n\n      // Map breakdown BigInt values to strings\n      const serializedBreakdown: Record<string, object> = {};\n      for (const [game, gs] of Object.entries(breakdown)) {\n        serializedBreakdown[game] = {\n          gamesPlayed: gs.gamesPlayed,\n          totalWagered: String(gs.totalWagered),\n          totalWins: gs.totalWins,\n          winRate: gs.winRate,\n          netPnl: String(gs.netPnl),\n        };\n      }\n\n      return c.json({\n        userId: profile.user_id,\n        username: profile.username,\n        avatarUrl: profile.avatar_url,\n        heatMultiplier: profile.heat_multiplier,\n        pointsBalance: String(profile.points_balance),\n        stats: {\n          gamesPlayed: stats.gamesPlayed,\n          totalWagered: String(stats.totalWagered),\n          totalWins: stats.totalWins,\n          winRate: stats.winRate,\n          winStreakCurrent: streaks.current,\n          winStreakBest: streaks.best,\n          netPnl: String(stats.netPnl),\n          gameBreakdown: serializedBreakdown,\n        },\n        usernameNextEditAt,\n        createdAt: profile.created_at.toISOString(),\n      });\n    } catch (err) {\n      logger.error(\"profile/me failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch profile\" }, 500);\n    }\n  });\n\n  app.get(\"/transactions\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    // Parse query params\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limitParam = c.req.query(\"limit\");\n    const gameParam = c.req.query(\"game\") || undefined;\n\n    // Validate & clamp limit\n    let limit = 20;\n    if (limitParam) {\n      const parsed = parseInt(limitParam, 10);\n      if (!isNaN(parsed) && parsed > 0) {\n        limit = Math.min(parsed, 50);\n      }\n    }\n\n    // Map game filter to DB name (accept both DB and frontend names)\n    let dbGame: string | undefined;\n    if (gameParam) {\n      dbGame = TO_DB_GAME[gameParam];\n      if (!dbGame) {\n        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n      }\n    }\n\n    try {\n      const rows = await db.getTransactions(wallet, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n        matchId: row.match_id,\n        txType: row.tx_type,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return c.json({ transactions, nextCursor });\n    } catch (err) {\n      logger.error(\"profile transactions query failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    }\n  });\n\n  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n  app.post(\"/confirm-tx\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const body = await c.req.json<{\n      game?: string;\n      matchId?: string;\n      txType?: string;\n      txSig?: string;\n      amountLamports?: number;\n    }>();\n\n    if (!body.game || !body.matchId || !body.txType || !body.txSig || !body.amountLamports) {\n      return c.json({ error: \"Missing required fields: game, matchId, txType, txSig, amountLamports\" }, 400);\n    }\n\n    const validTypes = [\"deposit\", \"refund\"];\n    if (!validTypes.includes(body.txType)) {\n      return c.json({ error: `Invalid txType: ${body.txType}. Must be one of: ${validTypes.join(\", \")}` }, 400);\n    }\n\n    // Map to DB game name\n    const dbGame = TO_DB_GAME[body.game];\n    if (!dbGame) {\n      return c.json({ error: `Invalid game: ${body.game}` }, 400);\n    }\n\n    try {\n      await db.insertTransaction({\n        wallet,\n        game: dbGame,\n        matchId: body.matchId,\n        txType: body.txType as \"deposit\" | \"refund\",\n        amountLamports: body.amountLamports,\n        txSig: body.txSig,\n      });\n      return c.json({ ok: true });\n    } catch (err) {\n      logger.error(\"confirm-tx failed\", {\n        wallet,\n        txType: body.txType,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to record transaction\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":207,"startLine":1,"totalLines":207}}}
