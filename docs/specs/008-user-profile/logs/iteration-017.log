{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013vFNah23F2NBjmpFABjtxv","type":"tool_result","content":"/**\n * Database client module — typed query functions for `rounds` and `operator_events`.\n *\n * Phase transitions are unidirectional: created → locked → settling → settled,\n * or created → expired. The application layer rejects backward transitions.\n */\n\nimport postgres from \"postgres\";\nimport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n\nexport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\nexport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n\nexport interface CloseCallRound {\n  round_id: string;\n  pda: string;\n  server_key: string;\n  phase: CloseCallPhase;\n  open_price: number;\n  open_price_expo: number;\n  close_price: number | null;\n  outcome: CloseCallOutcome;\n  green_pool: number;\n  red_pool: number;\n  total_fee: number;\n  green_entries: Array<{ player: string; amountLamports: number }>;\n  red_entries: Array<{ player: string; amountLamports: number }>;\n  settle_tx: string | null;\n  created_at: Date;\n  settled_at: Date | null;\n}\n\nexport interface InsertCloseCallRoundParams {\n  roundId: string;\n  pda: string;\n  serverKey: string;\n  openPrice: number;\n  openPriceExpo: number;\n}\n\nexport type OperatorEventType =\n  | \"secret_generated\"\n  | \"tx_built\"\n  | \"match_detected\"","is_error":false}]},"parent_tool_use_id":"toolu_017Z51pxCDdfae51nki1y7Hu","session_id":"1359e215-dd70-41ad-838f-5fde9a9acf4f","uuid":"4587b840-ddb7-453c-8acd-e42720dc178a","timestamp":"2026-03-31T15:01:18.412Z"}
