{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PUGBihEMtxAc3XRM5TYCSc","type":"tool_result","content":"1\t-- 009_transactions.sql — Replace user_transactions with transactions.\n2\t--\n3\t-- Schema change: event-based (join/win/loss/refund) → transaction-based\n4\t-- (deposit/payout/refund). Every row is a real on-chain SOL movement with\n5\t-- a non-null tx_sig.\n6\t--\n7\t-- Dev phase — drop and recreate, no migration.\n8\t\n9\tDROP TABLE IF EXISTS user_transactions;\n10\t\n11\tCREATE TABLE IF NOT EXISTS transactions (\n12\t  id              BIGSERIAL    PRIMARY KEY,\n13\t  wallet          TEXT         NOT NULL,\n14\t  game            TEXT         NOT NULL,\n15\t  match_id        TEXT         NOT NULL,\n16\t  tx_type         TEXT         NOT NULL,\n17\t  amount_lamports BIGINT       NOT NULL,\n18\t  tx_sig          TEXT         NOT NULL,\n19\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n20\t);\n21\t\n22\t-- Paginated history by wallet (newest first)\n23\tCREATE INDEX IF NOT EXISTS idx_tx_wallet_created\n24\t  ON transactions (wallet, created_at DESC);\n25\t\n26\t-- Lookup by match_id\n27\tCREATE INDEX IF NOT EXISTS idx_tx_match_id\n28\t  ON transactions (match_id);\n29\t\n30\t-- Idempotency guard — same wallet + match + type + sig = duplicate\n31\tCREATE UNIQUE INDEX IF NOT EXISTS uq_tx_wallet_match_type_sig\n32\t  ON transactions (wallet, match_id, tx_type, tx_sig);\n33\t"}]},"parent_tool_use_id":"toolu_01TLmMAPJdMZdf6DxCJNZrwW","session_id":"1359e215-dd70-41ad-838f-5fde9a9acf4f","uuid":"43dcf737-f069-4868-b138-6e0b744876f7","timestamp":"2026-03-31T15:00:51.795Z"}
