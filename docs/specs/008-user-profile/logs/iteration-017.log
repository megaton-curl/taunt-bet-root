{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SzuvwWF9n1pxNQJJchy2oA","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VAteBuYHHq1R6Ho1ACejhC","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/services/backend/src/db.ts","old_string":"    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {","new_string":"    async getPlayerStats(wallet) {\n      const rows = await sql<\n        Array<{\n          games_played: string;\n          total_wagered: string;\n          total_wins: string;\n          net_pnl: string;\n        }>\n      >`\n        SELECT\n          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n          COALESCE(\n            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n                     WHEN tx_type = 'deposit' THEN -amount_lamports\n                     ELSE 0 END),\n            0\n          )::text AS net_pnl\n        FROM transactions\n        WHERE wallet = ${wallet}\n      `;\n      const row = rows[0]!;\n      const gamesPlayed = Number(row.games_played);\n      const totalWins = Number(row.total_wins);\n      return {\n        gamesPlayed,\n        totalWagered: BigInt(row.total_wagered),\n        totalWins,\n        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n        netPnl: BigInt(row.net_pnl),\n      };\n    },\n\n    async getPublicPlayerStats(wallet) {\n      const full = await this.getPlayerStats(wallet);\n      return {\n        gamesPlayed: full.gamesPlayed,\n        totalWins: full.totalWins,\n        winRate: full.winRate,\n      };\n    },\n\n    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":444,"cache_read_input_tokens":48851,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":444},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1359e215-dd70-41ad-838f-5fde9a9acf4f","uuid":"0e262368-9ee8-440a-9dc4-a4b0f2cdacfe"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VAteBuYHHq1R6Ho1ACejhC","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/db.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"1359e215-dd70-41ad-838f-5fde9a9acf4f","uuid":"e695272c-b21f-48f0-8384-15824608331b","timestamp":"2026-03-31T15:02:31.562Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/db.ts","oldString":"    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {","newString":"    async getPlayerStats(wallet) {\n      const rows = await sql<\n        Array<{\n          games_played: string;\n          total_wagered: string;\n          total_wins: string;\n          net_pnl: string;\n        }>\n      >`\n        SELECT\n          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n          COALESCE(\n            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n                     WHEN tx_type = 'deposit' THEN -amount_lamports\n                     ELSE 0 END),\n            0\n          )::text AS net_pnl\n        FROM transactions\n        WHERE wallet = ${wallet}\n      `;\n      const row = rows[0]!;\n      const gamesPlayed = Number(row.games_played);\n      const totalWins = Number(row.total_wins);\n      return {\n        gamesPlayed,\n        totalWagered: BigInt(row.total_wagered),\n        totalWins,\n        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n        netPnl: BigInt(row.net_pnl),\n      };\n    },\n\n    async getPublicPlayerStats(wallet) {\n      const full = await this.getPlayerStats(wallet);\n      return {\n        gamesPlayed: full.gamesPlayed,\n        totalWins: full.totalWins,\n        winRate: full.winRate,\n      };\n    },\n\n    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {","originalFile":"/**\n * Database client module — typed query functions for `rounds` and `operator_events`.\n *\n * Phase transitions are unidirectional: created → locked → settling → settled,\n * or created → expired. The application layer rejects backward transitions.\n */\n\nimport postgres from \"postgres\";\nimport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n\nexport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\nexport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n\nexport interface CloseCallRound {\n  round_id: string;\n  pda: string;\n  server_key: string;\n  phase: CloseCallPhase;\n  open_price: number;\n  open_price_expo: number;\n  close_price: number | null;\n  outcome: CloseCallOutcome;\n  green_pool: number;\n  red_pool: number;\n  total_fee: number;\n  green_entries: Array<{ player: string; amountLamports: number }>;\n  red_entries: Array<{ player: string; amountLamports: number }>;\n  settle_tx: string | null;\n  created_at: Date;\n  settled_at: Date | null;\n}\n\nexport interface InsertCloseCallRoundParams {\n  roundId: string;\n  pda: string;\n  serverKey: string;\n  openPrice: number;\n  openPriceExpo: number;\n}\n\nexport type OperatorEventType =\n  | \"secret_generated\"\n  | \"tx_built\"\n  | \"match_detected\"\n  | \"settle_submitted\"\n  | \"settle_confirmed\"\n  | \"settle_failed\"\n  | \"settle_retried\"\n  | \"timeout_detected\";\n\nexport interface Round {\n  pda: string;\n  game: string;\n  creator: string;\n  server_key: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amount_lamports: number;\n  side: number;\n  match_id: string;\n  phase: RoundPhase;\n  target_slot: string | null;\n  settle_tx: string | null;\n  settle_attempts: number;\n  result_hash: Buffer | null;\n  result_side: number | null;\n  winner: string | null;\n  entries: unknown | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface InsertRoundParams {\n  pda: string;\n  game: string;\n  creator: string;\n  serverKey: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amountLamports: number;\n  side: number;\n  matchId: string;\n  phase: RoundPhase;\n  entries?: Array<{ player: string; amountLamports: number }>;\n}\n\nexport interface OperatorEvent {\n  id: string;\n  pda: string | null;\n  event_type: OperatorEventType;\n  payload: unknown;\n  created_at: Date;\n}\n\n// ---------------------------------------------------------------------------\n// Transaction types\n// ---------------------------------------------------------------------------\n\nexport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n\nexport interface Transaction {\n  id: string;\n  wallet: string;\n  game: string;\n  match_id: string;\n  tx_type: TransactionType;\n  amount_lamports: number;\n  tx_sig: string;\n  created_at: Date;\n}\n\nexport interface InsertTransactionParams {\n  wallet: string;\n  game: string;\n  matchId: string;\n  txType: TransactionType;\n  amountLamports: number;\n  txSig: string;\n}\n\n// ---------------------------------------------------------------------------\n// Referral types\n// ---------------------------------------------------------------------------\n\nexport interface ReferralCode {\n  id: number;\n  wallet: string;\n  code: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface ReferralLink {\n  id: number;\n  referrer_wallet: string;\n  referee_wallet: string;\n  created_at: Date;\n}\n\nexport interface ReferralEarning {\n  id: number;\n  referrer_wallet: string;\n  referee_wallet: string;\n  round_id: string;\n  game_type: string;\n  wager_lamports: number;\n  fee_lamports: number;\n  referrer_earned_lamports: number;\n  referrer_rate_bps: number;\n  referee_rebate_lamports: number;\n  referee_rebate_rate_bps: number;\n  created_at: Date;\n}\n\nexport interface ReferralStats {\n  referred_count: number;\n  active_count: number;\n  total_volume_lamports: string;\n  total_earned_lamports: string;\n  total_rebate_lamports: string;\n  pending_lamports: string;\n}\n\nexport interface ReferralClaim {\n  id: string;\n  wallet: string;\n  amount_lamports: string;\n  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n  retry_count: number;\n  tx_signature: string | null;\n  error: string | null;\n  requested_at: Date;\n  processed_at: Date | null;\n}\n\n// ---------------------------------------------------------------------------\n// Player profile types\n// ---------------------------------------------------------------------------\n\nexport interface PlayerProfile {\n  id: number;\n  user_id: string;\n  wallet: string;\n  username: string;\n  username_updated_at: Date | null;\n  avatar_url: string | null;\n  heat_multiplier: number;\n  points_balance: number;\n  created_at: Date;\n}\n\nexport interface PlayerStats {\n  gamesPlayed: number;\n  totalWagered: bigint;\n  totalWins: number;\n  winRate: number;\n  netPnl: bigint;\n}\n\nexport interface PublicPlayerStats {\n  gamesPlayed: number;\n  totalWins: number;\n  winRate: number;\n}\n\n// ---------------------------------------------------------------------------\n// Phase transition guard\n// ---------------------------------------------------------------------------\n\n/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\nconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n  created: [\"locked\", \"expired\"],\n  locked: [\"settling\"],\n  settling: [\"settled\"],\n  settled: [],\n  expired: [],\n};\n\nfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n  const allowed = VALID_TRANSITIONS[from];\n  if (!allowed.includes(to)) {\n    throw new Error(\n      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    );\n  }\n}\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db {\n  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n  insertRound(params: InsertRoundParams): Promise<Round>;\n\n  /** Delete a round by PDA. Returns true if a row was removed. */\n  deleteRoundByPda(pda: string): Promise<boolean>;\n\n  /** Transition a round's phase. Enforces unidirectional state machine.\n   *  Optional `updates` can set additional columns alongside the phase change. */\n  updateRoundPhase(\n    pda: string,\n    newPhase: RoundPhase,\n    updates?: Partial<\n      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n    >,\n  ): Promise<Round>;\n\n  /** Update the entries JSONB column for a settled round. */\n  updateRoundEntries(\n    pda: string,\n    entries: Array<{ player: string; amountLamports: number }>,\n  ): Promise<Round>;\n\n  /** Get a single round by its PDA. Returns `undefined` if not found. */\n  getRoundByPda(pda: string): Promise<Round | undefined>;\n\n  /** Get all rounds matching a given phase. */\n  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n\n  /** Append an operator event to the audit log. */\n  insertOperatorEvent(\n    pda: string | null,\n    eventType: OperatorEventType,\n    payload?: unknown,\n  ): Promise<OperatorEvent>;\n\n  /** Get the latest operator event for a PDA + type. */\n  getLatestOperatorEvent(\n    pda: string,\n    eventType: OperatorEventType,\n  ): Promise<OperatorEvent | undefined>;\n\n  /** Get a single round by its match_id. Returns `undefined` if not found. */\n  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n\n  /** Batch-fetch the latest operator event per PDA for a given event type. */\n  getLatestOperatorEventsForPdas(\n    pdas: string[],\n    eventType: OperatorEventType,\n  ): Promise<Map<string, OperatorEvent>>;\n\n  /** Get recently settled rounds for a game, ordered newest first. */\n  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n\n  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n\n  // -------------------------------------------------------------------------\n  // Close Call rounds\n  // -------------------------------------------------------------------------\n\n  /** Insert a new Close Call round. */\n  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n\n  /** Get a Close Call round by round_id (16-char hex). */\n  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n\n  /** Get the current active (open) Close Call round. */\n  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n\n  /** Get the most recent settled/refunded Close Call rounds. */\n  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n\n  /** Update a Close Call round after settlement. */\n  settleCloseCallRound(\n    roundId: string,\n    updates: {\n      phase: CloseCallPhase;\n      outcome: CloseCallOutcome;\n      closePrice?: number;\n      greenPool?: number;\n      redPool?: number;\n      totalFee?: number;\n      greenEntries?: Array<{ player: string; amountLamports: number }>;\n      redEntries?: Array<{ player: string; amountLamports: number }>;\n      settleTx?: string;\n    },\n  ): Promise<CloseCallRound>;\n\n  // -------------------------------------------------------------------------\n  // Transactions\n  // -------------------------------------------------------------------------\n\n  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n  insertTransaction(params: InsertTransactionParams): Promise<void>;\n\n  /** Insert multiple transactions in a single batch. */\n  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n\n  /** Get paginated transactions for a wallet, newest first. */\n  getTransactions(\n    wallet: string,\n    cursor?: string,\n    limit?: number,\n    game?: string,\n  ): Promise<Transaction[]>;\n\n  // -------------------------------------------------------------------------\n  // Referral — codes\n  // -------------------------------------------------------------------------\n\n  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n\n  /** Get a wallet's referral code. Returns `undefined` if none set. */\n  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n\n  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n\n  // -------------------------------------------------------------------------\n  // Referral — links\n  // -------------------------------------------------------------------------\n\n  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n\n  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n\n  /** Get all referral links where the given wallet is the referrer. */\n  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n\n  // -------------------------------------------------------------------------\n  // Referral — earnings & stats\n  // -------------------------------------------------------------------------\n\n  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n  insertReferralEarning(params: {\n    referrerWallet: string;\n    refereeWallet: string;\n    roundId: string;\n    gameType: string;\n    wagerLamports: number;\n    feeLamports: number;\n    referrerEarnedLamports: number;\n    referrerRateBps: number;\n    refereeRebateLamports: number;\n    refereeRebateRateBps: number;\n  }): Promise<ReferralEarning>;\n\n  /**\n   * Get the pending (unclaimed) balance for a wallet.\n   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n   * wallet=referee, minus sum of completed claims for the wallet.\n   * Returns a lamport string.\n   */\n  getPendingBalance(wallet: string): Promise<string>;\n\n  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n  getReferralEarnings(\n    wallet: string,\n    page: number,\n    limit: number,\n  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n\n  /** Get referral summary stats for a wallet. */\n  getReferralStats(wallet: string): Promise<ReferralStats>;\n\n  // -------------------------------------------------------------------------\n  // Referral — claims & rates\n  // -------------------------------------------------------------------------\n\n  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n  insertReferralClaim(\n    wallet: string,\n    amountLamports: string,\n  ): Promise<ReferralClaim>;\n\n  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n\n  /**\n   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n   * Returns the updated claim.\n   */\n  updateClaimStatus(\n    claimId: string,\n    status: ReferralClaim[\"status\"],\n    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n  ): Promise<ReferralClaim>;\n\n  /**\n   * Get the effective referrer rate for a wallet in bps.\n   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n   */\n  getReferrerRate(\n    wallet: string,\n    defaultRateBps: number,\n  ): Promise<number>;\n\n  // -------------------------------------------------------------------------\n  // Player profiles\n  // -------------------------------------------------------------------------\n\n  /**\n   * Create a new player profile with auto-generated user_id and username.\n   * Retries up to 5 times on username collision, then falls back to `user-{random8}`.\n   */\n  createPlayerProfile(wallet: string): Promise<PlayerProfile>;\n\n  /** Get a player profile by wallet address. Returns `null` if not found. */\n  getProfileByWallet(wallet: string): Promise<PlayerProfile | null>;\n\n  /**\n   * Get a player profile by public identifier.\n   * If identifier starts with `usr_`, looks up by `user_id`.\n   * Otherwise looks up by username (case-insensitive).\n   */\n  getProfileByIdentifier(identifier: string): Promise<PlayerProfile | null>;\n\n  /**\n   * Update a player's username. Validates 30-day cooldown (first edit is free).\n   * Throws on cooldown violation or UNIQUE conflict.\n   */\n  updateUsername(wallet: string, newUsername: string): Promise<PlayerProfile>;\n\n  /**\n   * Compute aggregate stats from the transactions table for a wallet.\n   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n   */\n  getPlayerStats(wallet: string): Promise<PlayerStats>;\n\n  /**\n   * Get public-safe subset of player stats (no wagered, no PnL).\n   */\n  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n\n  /**\n   * Execute a function within a database transaction.\n   * All db methods called on the transactional Db share the same transaction.\n   * Rolls back on error, commits on success.\n   */\n  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n\n  /** Gracefully close the connection pool. */\n  close(): Promise<void>;\n}\n\nfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n  return {\n    ...row,\n    open_price: Number(row.open_price),\n    open_price_expo: Number(row.open_price_expo),\n    close_price: row.close_price === null ? null : Number(row.close_price),\n    green_pool: Number(row.green_pool),\n    red_pool: Number(row.red_pool),\n    total_fee: Number(row.total_fee),\n    // JSONB comes back as parsed objects from postgres.js\n    green_entries: Array.isArray(row.green_entries)\n      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n      : [],\n    red_entries: Array.isArray(row.red_entries)\n      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n      : [],\n  };\n}\n\nfunction normalizeTransaction(row: Transaction): Transaction {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n  };\n}\n\nfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n  return {\n    ...row,\n    wager_lamports: Number(row.wager_lamports),\n    fee_lamports: Number(row.fee_lamports),\n    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n    referrer_rate_bps: Number(row.referrer_rate_bps),\n    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n  };\n}\n\nfunction normalizePlayerProfile(row: PlayerProfile): PlayerProfile {\n  return {\n    ...row,\n    id: Number(row.id),\n    heat_multiplier: Number(row.heat_multiplier),\n    points_balance: Number(row.points_balance),\n  };\n}\n\nfunction normalizeRound(row: Round): Round {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n    side: Number(row.side),\n    settle_attempts: Number(row.settle_attempts),\n    result_side: row.result_side === null ? null : Number(row.result_side),\n    // JSONB comes back as parsed objects from postgres.js\n    entries: Array.isArray(row.entries)\n      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n          player: e.player,\n          amountLamports: Number(e.amountLamports),\n        }))\n      : null,\n  };\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nexport function createDb(databaseUrl: string, _txSql?: any): Db {\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const sql: any = _txSql ?? postgres(databaseUrl);\n  const _isOwner = !_txSql;\n\n  return {\n    async insertRound(params) {\n      const rows = await sql<Round[]>`\n        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n        VALUES (\n          ${params.pda},\n          ${params.game},\n          ${params.creator},\n          ${params.serverKey},\n          ${params.secret},\n          ${params.commitment},\n          ${params.amountLamports},\n          ${params.side},\n          ${params.matchId},\n          ${params.phase},\n          ${params.entries ? sql.json(params.entries) : null}\n        )\n        RETURNING *\n      `;\n      return normalizeRound(rows[0]!);\n    },\n\n    async deleteRoundByPda(pda) {\n      const rows = await sql<{ pda: string }[]>`\n        DELETE FROM rounds WHERE pda = ${pda}\n        RETURNING pda\n      `;\n      return rows.length > 0;\n    },\n\n    async updateRoundPhase(pda, newPhase, updates) {\n      // Fetch current phase to validate transition\n      const current = await sql<Pick<Round, \"phase\">[]>`\n        SELECT phase FROM rounds WHERE pda = ${pda}\n      `;\n\n      if (current.length === 0) {\n        throw new Error(`Round not found: ${pda}`);\n      }\n\n      const currentPhase = current[0]!.phase as RoundPhase;\n      assertPhaseTransition(currentPhase, newPhase);\n\n      // Build the update — always set phase + updated_at\n      const rows = await sql<Round[]>`\n        UPDATE rounds SET\n          phase = ${newPhase},\n          updated_at = now(),\n          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n          winner = COALESCE(${updates?.winner ?? null}, winner)\n        WHERE pda = ${pda}\n        RETURNING *\n      `;\n\n      return normalizeRound(rows[0]!);\n    },\n\n    async updateRoundEntries(pda, entries) {\n      const rows = await sql<Round[]>`\n        UPDATE rounds SET\n          entries = ${sql.json(entries)},\n          updated_at = now()\n        WHERE pda = ${pda}\n        RETURNING *\n      `;\n      if (rows.length === 0) {\n        throw new Error(`Round not found: ${pda}`);\n      }\n      return normalizeRound(rows[0]!);\n    },\n\n    async getRoundByPda(pda) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE pda = ${pda}\n      `;\n      return rows[0] ? normalizeRound(rows[0]) : undefined;\n    },\n\n    async getRoundByMatchId(matchId) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE match_id = ${matchId}\n      `;\n      return rows[0] ? normalizeRound(rows[0]) : undefined;\n    },\n\n    async getRoundsByPhase(phase) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE phase = ${phase}\n      `;\n      return rows.map(normalizeRound);\n    },\n\n    async insertOperatorEvent(pda, eventType, payload) {\n      const rows = await sql<OperatorEvent[]>`\n        INSERT INTO operator_events (pda, event_type, payload)\n        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getLatestOperatorEvent(pda, eventType) {\n      const rows = await sql<OperatorEvent[]>`\n        SELECT * FROM operator_events\n        WHERE pda = ${pda} AND event_type = ${eventType}\n        ORDER BY id DESC\n        LIMIT 1\n      `;\n      return rows[0];\n    },\n\n    async getLatestOperatorEventsForPdas(pdas, eventType) {\n      if (pdas.length === 0) return new Map();\n      const rows = await sql<OperatorEvent[]>`\n        SELECT DISTINCT ON (pda) *\n        FROM operator_events\n        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n        ORDER BY pda, id DESC\n      `;\n      const map = new Map<string, OperatorEvent>();\n      for (const row of rows) {\n        if (row.pda) map.set(row.pda, row);\n      }\n      return map;\n    },\n\n    async getRecentSettledRounds(game, limit) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds\n        WHERE game = ${game} AND phase = 'settled'\n        ORDER BY updated_at DESC\n        LIMIT ${limit}\n      `;\n      return rows.map(normalizeRound);\n    },\n\n    async getUnsettledStats() {\n      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n        SELECT\n          COUNT(*)::text AS count,\n          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n        FROM rounds\n        WHERE phase NOT IN ('settled', 'expired')\n      `;\n      const row = rows[0]!;\n      return {\n        count: parseInt(row.count, 10),\n        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n      };\n    },\n\n    // -----------------------------------------------------------------------\n    // Close Call rounds\n    // -----------------------------------------------------------------------\n\n    async insertCloseCallRound(params) {\n      const rows = await sql<CloseCallRound[]>`\n        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n        VALUES (\n          ${params.roundId},\n          ${params.pda},\n          ${params.serverKey},\n          ${params.openPrice},\n          ${params.openPriceExpo}\n        )\n        RETURNING *\n      `;\n      return normalizeCloseCallRound(rows[0]!);\n    },\n\n    async getCloseCallRound(roundId) {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n      `;\n      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n    },\n\n    async getCloseCallCurrentRound() {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT * FROM closecall_rounds\n        WHERE phase = 'open'\n        ORDER BY created_at DESC\n        LIMIT 1\n      `;\n      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n    },\n\n    async getCloseCallHistory(limit) {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT * FROM closecall_rounds\n        WHERE phase IN ('settled', 'refunded')\n        ORDER BY settled_at DESC\n        LIMIT ${limit}\n      `;\n      return rows.map(normalizeCloseCallRound);\n    },\n\n    async settleCloseCallRound(roundId, updates) {\n      const rows = await sql<CloseCallRound[]>`\n        UPDATE closecall_rounds SET\n          phase = ${updates.phase},\n          outcome = ${updates.outcome},\n          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n          settled_at = now()\n        WHERE round_id = ${roundId}\n        RETURNING *\n      `;\n      if (rows.length === 0) {\n        throw new Error(`Close Call round not found: ${roundId}`);\n      }\n      return normalizeCloseCallRound(rows[0]!);\n    },\n\n    // -----------------------------------------------------------------------\n    // Transactions\n    // -----------------------------------------------------------------------\n\n    async insertTransaction(params) {\n      await sql`\n        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n        VALUES (\n          ${params.wallet},\n          ${params.game},\n          ${params.matchId},\n          ${params.txType},\n          ${params.amountLamports},\n          ${params.txSig}\n        )\n        ON CONFLICT DO NOTHING\n      `;\n    },\n\n    async insertTransactions(params) {\n      if (params.length === 0) return;\n      const values = params.map((p) => ({\n        wallet: p.wallet,\n        game: p.game,\n        match_id: p.matchId,\n        tx_type: p.txType,\n        amount_lamports: p.amountLamports,\n        tx_sig: p.txSig,\n      }));\n      await sql`\n        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n        ON CONFLICT DO NOTHING\n      `;\n    },\n\n    async getTransactions(wallet, cursor, limit = 20, game) {\n      const effectiveLimit = Math.min(limit, 50);\n      if (cursor && game) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      if (cursor) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND id < ${cursor}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      if (game) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND game = ${game}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      const rows = await sql<Transaction[]>`\n        SELECT * FROM transactions\n        WHERE wallet = ${wallet}\n        ORDER BY id DESC\n        LIMIT ${effectiveLimit}\n      `;\n      return rows.map(normalizeTransaction);\n    },\n\n    // -----------------------------------------------------------------------\n    // Referral — codes\n    // -----------------------------------------------------------------------\n\n    async insertReferralCode(wallet, code) {\n      const rows = await sql<ReferralCode[]>`\n        INSERT INTO referral_codes (wallet, code)\n        VALUES (${wallet}, ${code})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralCodeByWallet(wallet) {\n      const rows = await sql<ReferralCode[]>`\n        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n      `;\n      return rows[0];\n    },\n\n    async getReferralCodeByCode(code) {\n      const rows = await sql<ReferralCode[]>`\n        SELECT * FROM referral_codes WHERE code = ${code}\n      `;\n      return rows[0];\n    },\n\n    // -- Referral links -------------------------------------------------------\n\n    async insertReferralLink(referrerWallet, refereeWallet) {\n      const rows = await sql<ReferralLink[]>`\n        INSERT INTO referral_links (referrer_wallet, referee_wallet)\n        VALUES (${referrerWallet}, ${refereeWallet})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralLinkByReferee(refereeWallet) {\n      const rows = await sql<ReferralLink[]>`\n        SELECT * FROM referral_links WHERE referee_wallet = ${refereeWallet}\n      `;\n      return rows[0];\n    },\n\n    async getReferralLinksByReferrer(referrerWallet) {\n      const rows = await sql<ReferralLink[]>`\n        SELECT * FROM referral_links WHERE referrer_wallet = ${referrerWallet}\n        ORDER BY created_at DESC\n      `;\n      return rows;\n    },\n\n    // -- Referral earnings & stats --------------------------------------------\n\n    async insertReferralEarning(params) {\n      const rows = await sql<ReferralEarning[]>`\n        INSERT INTO referral_earnings (\n          referrer_wallet, referee_wallet, round_id, game_type,\n          wager_lamports, fee_lamports,\n          referrer_earned_lamports, referrer_rate_bps,\n          referee_rebate_lamports, referee_rebate_rate_bps\n        ) VALUES (\n          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n          ${params.wagerLamports}, ${params.feeLamports},\n          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n        )\n        RETURNING *\n      `;\n      return normalizeReferralEarning(rows[0]!);\n    },\n\n    async getPendingBalance(wallet) {\n      const rows = await sql<{ pending: string }[]>`\n        SELECT COALESCE(\n          (\n            SELECT SUM(referrer_earned_lamports)\n            FROM referral_earnings WHERE referrer_wallet = ${wallet}\n          ), 0\n        ) + COALESCE(\n          (\n            SELECT SUM(referee_rebate_lamports)\n            FROM referral_earnings WHERE referee_wallet = ${wallet}\n          ), 0\n        ) - COALESCE(\n          (\n            SELECT SUM(amount_lamports)\n            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'error', 'completed')\n          ), 0\n        ) AS pending\n      `;\n      return rows[0]!.pending;\n    },\n\n    async getReferralEarnings(wallet, page, limit) {\n      const offset = (page - 1) * limit;\n      const [countRows, rows] = await Promise.all([\n        sql<{ count: string }[]>`\n          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n          WHERE referrer_wallet = ${wallet}\n        `,\n        sql<ReferralEarning[]>`\n          SELECT * FROM referral_earnings\n          WHERE referrer_wallet = ${wallet}\n          ORDER BY created_at DESC\n          LIMIT ${limit} OFFSET ${offset}\n        `,\n      ]);\n      const total = Number(countRows[0]!.count);\n      const totalPages = Math.max(1, Math.ceil(total / limit));\n      return { items: rows.map(normalizeReferralEarning), totalPages };\n    },\n\n    async getReferralStats(wallet) {\n      const rows = await sql<ReferralStats[]>`\n        SELECT\n          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n            AS referred_count,\n          (\n            SELECT COUNT(DISTINCT re.referee_wallet)\n            FROM referral_earnings re\n            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n            WHERE re.created_at > now() - INTERVAL '7 days'\n          )::INT AS active_count,\n          COALESCE(\n            (\n              SELECT SUM(re.wager_lamports)::TEXT\n              FROM referral_earnings re\n              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n            ), '0'\n          ) AS total_volume_lamports,\n          COALESCE(\n            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_wallet = ${wallet}),\n            '0'\n          ) AS total_earned_lamports,\n          COALESCE(\n            (SELECT SUM(referee_rebate_lamports)::TEXT FROM referral_earnings WHERE referee_wallet = ${wallet}),\n            '0'\n          ) AS total_rebate_lamports,\n          (\n            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_wallet = ${wallet}), 0)\n            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_wallet = ${wallet}), 0)\n            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending','processing','error','completed')), 0)\n          )::TEXT AS pending_lamports\n      `;\n      return rows[0]!;\n    },\n\n    // -----------------------------------------------------------------------\n    // Referral — claims & rates\n    // -----------------------------------------------------------------------\n\n    async insertReferralClaim(wallet, amountLamports) {\n      const rows = await sql<ReferralClaim[]>`\n        INSERT INTO referral_claims (wallet, amount_lamports, status)\n        VALUES (${wallet}, ${amountLamports}, 'pending')\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralClaim(claimId) {\n      const rows = await sql<ReferralClaim[]>`\n        SELECT * FROM referral_claims WHERE id = ${claimId}\n      `;\n      return rows[0];\n    },\n\n    async updateClaimStatus(claimId, status, meta) {\n      const rows = await sql<ReferralClaim[]>`\n        UPDATE referral_claims\n        SET\n          status = ${status},\n          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n          error = COALESCE(${meta?.error ?? null}, error),\n          retry_count = ${meta?.incrementRetry ? sql`retry_count + 1` : sql`retry_count`},\n          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n        WHERE id = ${claimId}\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferrerRate(wallet, defaultRateBps) {\n      const rows = await sql<{ rate_bps: number }[]>`\n        SELECT rate_bps FROM referral_kol_rates WHERE wallet = ${wallet}\n      `;\n      return rows[0]?.rate_bps ?? defaultRateBps;\n    },\n\n    // -----------------------------------------------------------------------\n    // Player profiles\n    // -----------------------------------------------------------------------\n\n    async createPlayerProfile(wallet) {\n      const userId = generateUserId();\n      const MAX_RETRIES = 5;\n\n      for (let attempt = 0; attempt <= MAX_RETRIES; attempt++) {\n        const username =\n          attempt < MAX_RETRIES\n            ? generateUsername()\n            : `user-${generateUserId().slice(4)}`; // fallback: user-{random8}\n\n        try {\n          const rows = await sql<PlayerProfile[]>`\n            INSERT INTO player_profiles (user_id, wallet, username)\n            VALUES (${userId}, ${wallet}, ${username})\n            RETURNING *\n          `;\n          return normalizePlayerProfile(rows[0]!);\n        } catch (err: unknown) {\n          const pgErr = err as { code?: string; constraint_name?: string };\n          // 23505 = unique_violation — retry only on username collision\n          if (pgErr.code === \"23505\" && attempt < MAX_RETRIES) {\n            continue;\n          }\n          throw err;\n        }\n      }\n\n      // Unreachable — final attempt either succeeds or throws\n      throw new Error(\"createPlayerProfile: exhausted retries\");\n    },\n\n    async getProfileByWallet(wallet) {\n      const rows = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE wallet = ${wallet}\n      `;\n      return rows[0] ? normalizePlayerProfile(rows[0]) : null;\n    },\n\n    async getProfileByIdentifier(identifier) {\n      if (identifier.startsWith(\"usr_\")) {\n        const rows = await sql<PlayerProfile[]>`\n          SELECT * FROM player_profiles WHERE user_id = ${identifier}\n        `;\n        return rows[0] ? normalizePlayerProfile(rows[0]) : null;\n      }\n      const rows = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE LOWER(username) = LOWER(${identifier})\n      `;\n      return rows[0] ? normalizePlayerProfile(rows[0]) : null;\n    },\n\n    async updateUsername(wallet, newUsername) {\n      // Fetch current profile to check cooldown\n      const current = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE wallet = ${wallet}\n      `;\n      if (current.length === 0) {\n        throw new Error(\"Profile not found\");\n      }\n\n      const profile = current[0]!;\n      if (profile.username_updated_at) {\n        const cooldownMs = 30 * 24 * 60 * 60 * 1000; // 30 days\n        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n        if (elapsed < cooldownMs) {\n          const nextEditAt = new Date(\n            new Date(profile.username_updated_at).getTime() + cooldownMs,\n          );\n          const err = new Error(\"Username cooldown active\") as Error & {\n            cooldown: true;\n            nextEditAvailableAt: Date;\n          };\n          err.cooldown = true;\n          err.nextEditAvailableAt = nextEditAt;\n          throw err;\n        }\n      }\n\n      const rows = await sql<PlayerProfile[]>`\n        UPDATE player_profiles\n        SET username = ${newUsername}, username_updated_at = now()\n        WHERE wallet = ${wallet}\n        RETURNING *\n      `;\n      return normalizePlayerProfile(rows[0]!);\n    },\n\n    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n    },\n\n    async close() {\n      if (_isOwner) await sql.end();\n    },\n  };\n}\n","structuredPatch":[{"oldStart":1132,"oldLines":6,"newStart":1132,"newLines":49,"lines":["       return normalizePlayerProfile(rows[0]!);","     },"," ","+    async getPlayerStats(wallet) {","+      const rows = await sql<","+        Array<{","+          games_played: string;","+          total_wagered: string;","+          total_wins: string;","+          net_pnl: string;","+        }>","+      >`","+        SELECT","+          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,","+          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,","+          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,","+          COALESCE(","+            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports","+                     WHEN tx_type = 'deposit' THEN -amount_lamports","+                     ELSE 0 END),","+            0","+          )::text AS net_pnl","+        FROM transactions","+        WHERE wallet = ${wallet}","+      `;","+      const row = rows[0]!;","+      const gamesPlayed = Number(row.games_played);","+      const totalWins = Number(row.total_wins);","+      return {","+        gamesPlayed,","+        totalWagered: BigInt(row.total_wagered),","+        totalWins,","+        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,","+        netPnl: BigInt(row.net_pnl),","+      };","+    },","+","+    async getPublicPlayerStats(wallet) {","+      const full = await this.getPlayerStats(wallet);","+      return {","+        gamesPlayed: full.gamesPlayed,","+        totalWins: full.totalWins,","+        winRate: full.winRate,","+      };","+    },","+","     async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {","       // eslint-disable-next-line @typescript-eslint/no-explicit-any","       return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));"]}],"userModified":false,"replaceAll":false}}
