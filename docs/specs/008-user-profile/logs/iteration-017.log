{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PfRGewjVWS3msjuRGCARxt","type":"tool_result","content":"750\t        throw new Error(`Close Call round not found: ${roundId}`);\n751\t      }\n752\t      return normalizeCloseCallRound(rows[0]!);\n753\t    },\n754\t\n755\t    // -----------------------------------------------------------------------\n756\t    // Transactions\n757\t    // -----------------------------------------------------------------------\n758\t\n759\t    async insertTransaction(params) {\n760\t      await sql`\n761\t        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n762\t        VALUES (\n763\t          ${params.wallet},\n764\t          ${params.game},\n765\t          ${params.matchId},\n766\t          ${params.txType},\n767\t          ${params.amountLamports},\n768\t          ${params.txSig}\n769\t        )\n770\t        ON CONFLICT DO NOTHING\n771\t      `;\n772\t    },\n773\t\n774\t    async insertTransactions(params) {\n775\t      if (params.length === 0) return;\n776\t      const values = params.map((p) => ({\n777\t        wallet: p.wallet,\n778\t        game: p.game,\n779\t        match_id: p.matchId,\n780\t        tx_type: p.txType,\n781\t        amount_lamports: p.amountLamports,\n782\t        tx_sig: p.txSig,\n783\t      }));\n784\t      await sql`\n785\t        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n786\t        ON CONFLICT DO NOTHING\n787\t      `;\n788\t    },\n789\t\n790\t    async getTransactions(wallet, cursor, limit = 20, game) {\n791\t      const effectiveLimit = Math.min(limit, 50);\n792\t      if (cursor && game) {\n793\t        const rows = await sql<Transaction[]>`\n794\t          SELECT * FROM transactions\n795\t          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n796\t          ORDER BY id DESC\n797\t          LIMIT ${effectiveLimit}\n798\t        `;\n799\t        return rows.map(normalizeTransaction);\n800\t      }\n801\t      if (cursor) {\n802\t        const rows = await sql<Transaction[]>`\n803\t          SELECT * FROM transactions\n804\t          WHERE wallet = ${wallet} AND id < ${cursor}\n805\t          ORDER BY id DESC\n806\t          LIMIT ${effectiveLimit}\n807\t        `;\n808\t        return rows.map(normalizeTransaction);\n809\t      }\n810\t      if (game) {\n811\t        const rows = await sql<Transaction[]>`\n812\t          SELECT * FROM transactions\n813\t          WHERE wallet = ${wallet} AND game = ${game}\n814\t          ORDER BY id DESC\n815\t          LIMIT ${effectiveLimit}\n816\t        `;\n817\t        return rows.map(normalizeTransaction);\n818\t      }\n819\t      const rows = await sql<Transaction[]>`\n820\t        SELECT * FROM transactions\n821\t        WHERE wallet = ${wallet}\n822\t        ORDER BY id DESC\n823\t        LIMIT ${effectiveLimit}\n824\t      `;\n825\t      return rows.map(normalizeTransaction);\n826\t    },\n827\t\n828\t    // -----------------------------------------------------------------------\n829\t    // Referral — codes\n830\t    // -----------------------------------------------------------------------\n831\t\n832\t    async insertReferralCode(wallet, code) {\n833\t      const rows = await sql<ReferralCode[]>`\n834\t        INSERT INTO referral_codes (wallet, code)\n835\t        VALUES (${wallet}, ${code})\n836\t        RETURNING *\n837\t      `;\n838\t      return rows[0]!;\n839\t    },\n840\t\n841\t    async getReferralCodeByWallet(wallet) {\n842\t      const rows = await sql<ReferralCode[]>`\n843\t        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n844\t      `;\n845\t      return rows[0];\n846\t    },\n847\t\n848\t    async getReferralCodeByCode(code) {\n849\t      const rows = await sql<ReferralCode[]>`"}]},"parent_tool_use_id":"toolu_01TLmMAPJdMZdf6DxCJNZrwW","session_id":"1359e215-dd70-41ad-838f-5fde9a9acf4f","uuid":"861a9dff-1707-482c-91e3-e835