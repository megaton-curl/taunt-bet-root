{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0117tXA4ZKCPYzP9tS2Yy9HK","type":"tool_result","content":"// ---------------------------------------------------------------------------\n\n/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\nconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n  created: [\"locked\", \"expired\"],\n  locked: [\"settling\"],\n  settling: [\"settled\"],\n  settled: [],\n  expired: [],\n};\n\nfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n  const allowed = VALID_TRANSITIONS[from];\n  if (!allowed.includes(to)) {\n    throw new Error(\n      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    );\n  }\n}\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db {\n  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n  insertRound(params: InsertRoundParams): Promise<Round>;\n\n  /** Delete a round by PDA. Returns true if a row was removed. */\n  deleteRoundByPda(pda: string): Promise<boolean>;\n\n  /** Transition a round's phase. Enforces unidirectional state machine.\n   *  Optional `updates` can set additional columns alongside the phase change. */\n  updateRoundPhase(\n    pda: string,\n    newPhase: RoundPhase,\n    updates?: Partial<\n      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n    >,\n  ): Promise<Round>;\n\n  /** Update the entries JSONB column for a settled round. */\n  updateRoundEntries(\n    pda: string,\n    entries: Array<{ player: string; amountLamports: number }>,\n  ): Promise<Round>;\n\n  /** Get a single round by its PDA. Returns `undefined` if not found. */\n  getRoundByPda(pda: string): Promise<Round | undefined>;\n\n  /** Get all rounds matching a given phase. */","is_error":false}]},"parent_tool_use_id":"toolu_017Z51pxCDdfae51nki1y7Hu","session_id":"1359e215-dd70-41ad-838f-5fde9a9acf4f","uuid":"7eb16b33-06e3-4b20-9d2d-067ec12d1916","timestamp":"2026-03-31T15:01:12.436Z"}
