ret: config.jwtSecret, requireAllMethods: true }),\n    88в†’);\n    89в†’app.route(\"/profile\", createProfileRoutes({ db }));\n    90в†’\n    91в†’// JWT auth middleware for fairness endpoints\n    92в†’app.use(\n    93в†’  \"/fairness/*\",\n    94в†’  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n    95в†’);\n    96в†’\n    97в†’// Rate limiting вЂ” per-wallet and global limits on POST requests\n    98в†’app.use(\n    99в†’  \"/fairness/*\",\n   100в†’  createRateLimitMiddleware({"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"e110bad0-3d32-43a4-9c21-7b29c7b658ce","timestamp":"2026-03-19T19:15:32.879Z"}
