{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EwNCYjnvJsVaRVTQDfYbJE","type":"tool_result","content":"     1в†’/**\n     2в†’ * Thin fetch wrappers for the /auth/* backend endpoints.\n     3в†’ */\n     4в†’\n     5в†’const BACKEND_URL = (\n     6в†’  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n     7в†’    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n     8в†’).replace(/\\/$/, \"\");\n     9в†’\n    10в†’export interface ChallengeResponse {\n    11в†’  nonce: string;\n    12в†’  message: string;\n    13в†’  expiresAt: string;\n    14в†’}\n    15в†’\n    16в†’export interface VerifyResponse {\n    17в†’  accessToken: string;\n    18в†’  accessExpiresAt: string;\n    19в†’  refreshToken: string;\n    20в†’  refreshExpiresAt: string;\n    21в†’}\n    22в†’\n    23в†’export interface RefreshResponse {\n    24в†’  accessToken: string;\n    25в†’  accessExpiresAt: string;\n    26в†’  refreshToken: string;\n    27в†’  refreshExpiresAt: string;\n    28в†’}\n    29в†’\n    30в†’async function parseResponse<T>(res: Response): Promise<T> {\n    31в†’  const json = await res.json();\n    32в†’  if (!res.ok) {\n    33в†’    const msg = typeof json?.error === \"string\" ? json.error : `Auth request failed (${res.status})`;\n    34в†’    throw new Error(msg);\n    35в†’  }\n    36в†’  return json as T;\n    37в†’}\n    38в†’\n    39в†’export async function requestChallenge(wallet: string): Promise<ChallengeResponse> {\n    40в†’  const res = await fetch(`${BACKEND_URL}/auth/challenge`, {\n    41в†’    method: \"POST\",\n    42в†’    headers: { \"Content-Type\": \"application/json\" },\n    43в†’    body: JSON.stringify({ wallet }),\n    44в†’  });\n    45в†’  return parseResponse<ChallengeResponse>(res);\n    46в†’}\n    47в†’\n    48в†’export async function verifyChallenge(\n    49в†’  nonce: string,\n    50в†’  wallet: string,\n    51в†’  signature: string,\n    52в†’): Promise<VerifyResponse> {\n    53в†’  const res = await fetch(`${BACKEND_URL}/auth/verify`, {\n    54в†’    method: \"POST\",\n    55в†’    headers: { \"Content-Type\": \"application/json\" },\n    56в†’    body: JSON.stringify({ nonce, wallet, signature }),\n    57в†’  });\n    58в†’  return parseResponse<VerifyResponse>(res);\n    59в†’}\n    60в†’\n    61в†’export async function refreshSession(refreshToken: string): Promise<RefreshResponse> {\n    62в†’  const res = await fetch(`${BACKEND_URL}/auth/refresh`, {\n    63в†’    method: \"POST\",\n    64в†’    headers: { \"Content-Type\": \"application/json\" },\n    65в†’    body: JSON.stringify({ refreshToken }),\n    66в†’  });\n    67в†’  return parseResponse<RefreshResponse>(res);\n    68в†’}\n    69в†’\n    70в†’export async function logout(refreshToken: string): Promise<void> {\n    71в†’  await fetch(`${BACKEND_URL}/auth/logout`, {\n    72в†’    method: \"POST\",\n    73в†’    headers: { \"Content-Type\": \"application/json\" },\n    74в†’    body: JSON.stringify({ refreshToken }),\n    75в†’  });\n    76в†’}\n    77в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"4ab449ad-f5b6-4fef-9f0c-4c402717d881","timestamp":"2026-03-19T19:14:39.136Z"}
