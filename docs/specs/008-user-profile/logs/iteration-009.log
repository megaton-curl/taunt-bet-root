{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018JE41grPrDV3DD9XJP6JoS","type":"tool_result","content":"     1в†’import { test as base, expect, type Page, type ConsoleMessage } from \"@playwright/test\";\n     2в†’\n     3в†’const FREEZE_CSS = `\n     4в†’  *, *::before, *::after {\n     5в†’    animation-duration: 0s !important;\n     6в†’    animation-delay: 0s !important;\n     7в†’    transition-duration: 0s !important;\n     8в†’    transition-delay: 0s !important;\n     9в†’    scroll-behavior: auto !important;\n    10в†’  }\n    11в†’  /* Pause SVG SMIL animations */\n    12в†’  svg { animation-play-state: paused !important; }\n    13в†’`;\n    14в†’\n    15в†’/**\n    16в†’ * Shared visual-regression fixture.\n    17в†’ *\n    18в†’ * Extends the default Playwright `test` with a `stablePage` fixture that:\n    19в†’ *  (a) Seeds Math.random() and Date.now() for determinism\n    20в†’ *  (b) Injects CSS to disable all CSS + SVG animations/transitions\n    21в†’ *  (c) Pauses SVG SMIL animations via JS\n    22в†’ *  (d) Waits for document.fonts.ready and network idle\n    23в†’ *  (e) Collects console errors and fails the test if any are found\n    24в†’ */\n    25в†’export const test = base.extend<{ stablePage: Page }>({\n    26в†’  stablePage: async ({ page }, use) => {\n    27в†’    // (e) Collect console errors throughout the test (filtering expected noise)\n    28в†’    const NOISE_PATTERNS = [\n    29в†’      \"401\",                 // JWT auth attempts in mock mode (no backend)\n    30в†’      \"403\",                 // Auth rejection in mock mode\n    31в†’      \"429\",                 // Rate limit (multiple visual tests hit same endpoints)\n    32в†’      \"favicon\",             // Missing favicon\n    33в†’      \"ERR_CONNECTION_REFUSED\", // Backend not running in visual test mode\n    34в†’      \"Failed to fetch\",     // Network requests to non-existent backend\n    35в†’      \"Failed to load resource\", // Generic resource loading failures (auth, rate limit)\n    36в†’      \"NetworkError\",        // Same\n    37в†’    ];\n    38в†’    const consoleErrors: string[] = [];\n    39в†’    page.on(\"console\", (msg: ConsoleMessage) => {\n    40в†’      if (msg.type() === \"error\") {\n    41в†’        const text = msg.text();\n    42в†’        if (!NOISE_PATTERNS.some((p) => text.includes(p))) {\n    43в†’          consoleErrors.push(text);\n    44в†’        }\n    45в†’      }\n    46в†’    });\n    47в†’\n    48в†’    // (a) Deterministic Math.random, crypto.getRandomValues, and frozen Date.now\n    49в†’    await page.addInitScript(() => {\n    50в†’      // Mulberry32 seeded PRNG вЂ” deterministic sequence from seed 42\n    51в†’      let seed = 42;\n    52в†’      function mulberry32(): number {\n    53в†’        seed |= 0;\n    54в†’        seed = (seed + 0x6d2b79f5) | 0;\n    55в†’        let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);\n    56в†’        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;\n    57в†’        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n    58в†’      }\n    59в†’\n    60в†’      Math.random = mulberry32;\n    61в†’\n    62в†’      // Also seed crypto.getRandomValues so Keypair.generate() is deterministic\n    63в†’      crypto.getRandomValues = <T extends ArrayBufferView | null>(array: T): T => {\n    64в†’        if (array === null) return array;\n    65в†’        const view = new Uint8Array(\n    66в†’          (array as ArrayBufferView).buffer,\n    67в†’          (array as ArrayBufferView).byteOffset,\n    68в†’          (array as ArrayBufferView).byteLength,\n    69в†’        );\n    70в†’        for (let i = 0; i < view.length; i++) {\n    71в†’          view[i] = Math.floor(mulberry32() * 256);\n    72в†’        }\n    73в†’        return array;\n    74в†’      };\n    75в†’\n    76в†’      // Freeze Date.now to a fixed timestamp (2026-01-01T00:00:00Z)\n    77в†’      const frozen = 1767225600000;\n    78в†’      Date.now = () => frozen;\n    79в†’    });\n    80в†’\n    81в†’    // Store the original goto so we can wrap it\n    82в†’    const originalGoto = page.goto.bind(page);\n    83в†’\n    84в†’    // Override goto to always wait for fonts + network idle after navigation\n    85в†’    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n    86в†’      const response = await originalGoto(url, {\n    87в†’        waitUntil: \"networkidle\",\n    88в†’        ...options,\n    89в†’      });\n    90в†’\n    91в†’      // (b) Inject animation-disabling CSS (navigation clears addStyleTag)\n    92в†’      await page.addStyleTag({ content: FREEZE_CSS });\n    93в†’\n    94в†’      // (c) Pause all SVG SMIL animations\n    95в†’      await page.evaluate(() => {\n    96в†’        document.querySelectorAll(\"svg\").forEach((svg) => {\n    97в†’          if (typeof svg.pauseAnimations === \"function\") {\n    98в†’            svg.pauseAnimations();\n    99в†’          }\n   100в†’        });\n   101в†’      });\n   102в†’\n   103в†’      // (d) Wait for all fonts to finish loading\n   104в†’      await page.evaluate(() => document.fonts.ready);\n   105в†’\n   106в†’      // Settle time for remaining paints\n   107в†’      await page.waitForTimeout(300);\n   108в†’\n   109в†’      return response;\n   110в†’    };\n   111в†’\n   112в†’    await use(page);\n   113в†’\n   114в†’    // (e) Assert no console errors after test completes\n   115в†’    if (consoleErrors.length > 0) {\n   116в†’      throw new Error(\n   117в†’        `Console errors detected during test:\\n${consoleErrors.map((e) => `  - ${e}`).join(\"\\n\")}`\n   118в†’      );\n   119в†’    }\n   120в†’  },\n   121в†’});\n   122в†’\n   123в†’export { expect };\n   124в†’"}]},"parent_tool_use_id":"toolu_01HeJfpFiA1rSVyi58U1gKAc","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"2b740daf-97c3-4d58-847e-25f97320171b","timestamp":"2026-03-19T19:12:32.239Z"}
