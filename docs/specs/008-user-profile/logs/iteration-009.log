{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B6pKDQE1hWvHUczEs2yGqd","type":"tool_result","content":"     1в†’/**\n     2в†’ * Profile Event Bus - Cross-feature event emitter for Player Profiles\n     3в†’ *\n     4в†’ * Games emit game result events here, and the Player Profile\n     5в†’ * system subscribes to track XP, stats, and transaction history.\n     6в†’ *\n     7в†’ * Pattern mirrors raid-event-bus.ts for consistency.\n     8в†’ */\n     9в†’\n    10в†’import type { GameId, GameResultEvent } from \"../types\";\n    11в†’\n    12в†’type GameResultCallback = (event: GameResultEvent) => void;\n    13в†’\n    14в†’class ProfileEventBus {\n    15в†’  private listeners = new Set<GameResultCallback>();\n    16в†’\n    17в†’  /**\n    18в†’   * Emit a game result event from any game\n    19в†’   */\n    20в†’  emit(event: GameResultEvent): void {\n    21в†’    this.listeners.forEach((callback) => {\n    22в†’      try {\n    23в†’        callback(event);\n    24в†’      } catch (error) {\n    25в†’        console.error(\"[ProfileEventBus] Error in listener:\", error);\n    26в†’      }\n    27в†’    });\n    28в†’  }\n    29в†’\n    30в†’  /**\n    31в†’   * Subscribe to game result events\n    32в†’   * Returns an unsubscribe function\n    33в†’   */\n    34в†’  subscribe(callback: GameResultCallback): () => void {\n    35в†’    this.listeners.add(callback);\n    36в†’    return () => {\n    37в†’      this.listeners.delete(callback);\n    38в†’    };\n    39в†’  }\n    40в†’\n    41в†’  /**\n    42в†’   * Get the number of active listeners (for debugging)\n    43в†’   */\n    44в†’  get listenerCount(): number {\n    45в†’    return this.listeners.size;\n    46в†’  }\n    47в†’\n    48в†’  /**\n    49в†’   * Clear all listeners (for testing)\n    50в†’   */\n    51в†’  clear(): void {\n    52в†’    this.listeners.clear();\n    53в†’  }\n    54в†’}\n    55в†’\n    56в†’// Singleton instance for cross-feature communication\n    57в†’export const profileEventBus = new ProfileEventBus();\n    58в†’\n    59в†’// ============ Helper Functions ============\n    60в†’\n    61в†’/**\n    62в†’ * Create a game result event (convenience function for games)\n    63в†’ */\n    64в†’export function createGameResultEvent(\n    65в†’  gameId: GameId,\n    66в†’  matchId: string,\n    67в†’  playerAddress: string,\n    68в†’  wagerAmount: number,\n    69в†’  outcome: \"win\" | \"loss\",\n    70в†’  payoutAmount: number,\n    71в†’): GameResultEvent {\n    72в†’  return {\n    73в†’    gameId,\n    74в†’    matchId,\n    75в†’    playerAddress,\n    76в†’    wagerAmount,\n    77в†’    outcome,\n    78в†’    payoutAmount,\n    79в†’    timestamp: Date.now(),\n    80в†’  };\n    81в†’}\n    82в†’\n    83в†’/**\n    84в†’ * Emit a game result for a single player\n    85в†’ */\n    86в†’export function emitGameResult(\n    87в†’  gameId: GameId,\n    88в†’  matchId: string,\n    89в†’  playerAddress: string,\n    90в†’  wagerAmount: number,\n    91в†’  outcome: \"win\" | \"loss\",\n    92в†’  payoutAmount: number,\n    93в†’): void {\n    94в†’  profileEventBus.emit(\n    95в†’    createGameResultEvent(gameId, matchId, playerAddress, wagerAmount, outcome, payoutAmount)\n    96в†’  );\n    97в†’}\n    98в†’\n    99в†’/**\n   100в†’ * Emit coinflip result for both players\n   101в†’ */\n   102в†’export function emitCoinflipResults(\n   103в†’  matchId: string,\n   104в†’  winner: string,\n   105в†’  loser: string,\n   106в†’  entryAmount: number,\n   107в†’  payoutAmount: number,\n   108в†’): void {\n   109в†’  emitGameResult(\"coinflip\", matchId, winner, entryAmount, \"win\", payoutAmount);\n   110в†’  emitGameResult(\"coinflip\", matchId, loser, entryAmount, \"loss\", 0);\n   111в†’}\n   112в†’\n   113в†’/**\n   114в†’ * Emit lord of rngs result for all players\n   115в†’ */\n   116в†’export function emitLordOfRngsResults(\n   117в†’  roundId: string,\n   118в†’  winner: string,\n   119в†’  participants: Array<{ address: string; totalWager: number }>,\n   120в†’  payoutAmount: number,\n   121в†’): void {\n   122в†’  for (const participant of participants) {\n   123в†’    const isWinner = participant.address === winner;\n   124в†’    emitGameResult(\n   125в†’      \"lord-of-rngs\",\n   126в†’      roundId,\n   127в†’      participant.address,\n   128в†’      participant.totalWager,\n   129в†’      isWinner ? \"win\" : \"loss\",\n   130в†’      isWinner ? payoutAmount : 0,\n   131в†’    );\n   132в†’  }\n   133в†’}\n   134в†’\n   135в†’/**\n   136в†’ * Emit crypto crash results for all players\n   137в†’ */\n   138в†’export function emitCryptoCrashResults(\n   139в†’  roundId: string,\n   140в†’  results: Array<{\n   141в†’    address: string;\n   142в†’    wager: number;\n   143в†’    outcome: \"win\" | \"loss\";\n   144в†’    payout: number;\n   145в†’  }>,\n   146в†’): void {\n   147в†’  for (const result of results) {\n   148в†’    emitGameResult(\n   149в†’      \"crypto-crash\",\n   150в†’      roundId,\n   151в†’      result.address,\n   152в†’      result.wager,\n   153в†’      result.outcome,\n   154в†’      result.payout,\n   155в†’    );\n   156в†’  }\n   157в†’}\n   158в†’\n   159в†’/**\n   160в†’ * Emit close call results for all players\n   161в†’ */\n   162в†’export function emitCloseCallResults(\n   163в†’  roundId: string,\n   164в†’  results: Array<{\n   165в†’    address: string;\n   166в†’    wager: number;\n   167в†’    outcome: \"win\" | \"loss\";\n   168в†’    payout: number;\n   169в†’  }>,\n   170в†’): void {\n   171в†’  for (const result of results) {\n   172в†’    emitGameResult(\n   173в†’      \"close-call\",\n   174в†’      roundId,\n   175в†’      result.address,\n   176в†’      result.wager,\n   177в†’      result.outcome,\n   178в†’      result.payout,\n   179в†’    );\n   180в†’  }\n   181в†’}\n   182в†’\n   183в†’/**\n   184в†’ * Emit game of trades results for all players\n   185в†’ * Winners are the top 3 who receive payouts, everyone else loses\n   186в†’ */\n   187в†’export function emitGameOfTradesResults(\n   188в†’  roundId: string,\n   189в†’  results: Array<{\n   190в†’    address: string;\n   191в†’    entryAmount: number;\n   192в†’    payout: number;\n   193в†’  }>,\n   194в†’): void {\n   195в†’  for (const result of results) {\n   196в†’    const isWinner = result.payout > 0;\n   197в†’    emitGameResult(\n   198в†’      \"game-of-trades\",\n   199в†’      roundId,\n   200в†’      result.address,\n   201в†’      result.entryAmount,\n   202в†’      isWinner ? \"win\" : \"loss\",\n   203в†’      result.payout,\n   204в†’    );\n   205в†’  }\n   206в†’}\n   207в†’"}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"d22f6846-35f8-42cf-81d9-6fed3dbe4c8c","timestamp":"2026-03-19T19:12:43.614Z"}
