{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GRmAMQJSQ97R1H2bcAQZ3G","type":"tool_result","content":"     1в†’#!/usr/bin/env bash\n     2в†’# run-e2e-local.sh вЂ” Single-entrypoint for local E2E tests.\n     3в†’# Runs: validator bootstrap в†’ backend bootstrap в†’ Playwright tests в†’ teardown.\n     4в†’set -euo pipefail\n     5в†’\n     6в†’SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n     7в†’APP_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     8в†’MONOREPO_DIR=\"$(cd \"$APP_DIR/../..\" && pwd)\"\n     9в†’BACKEND_DIR=\"$MONOREPO_DIR/services/backend\"\n    10в†’BACKEND_KEYPAIR_FILE=\"$APP_DIR/.local-backend-keypair.json\"\n    11в†’BACKEND_LOG=\"$APP_DIR/.local-backend.log\"\n    12в†’\n    13в†’RPC_URL=\"${RPC_URL:-http://127.0.0.1:8899}\"\n    14в†’PORT=\"${PORT:-3101}\"\n    15в†’VITE_FAIRNESS_BACKEND_URL=\"${VITE_FAIRNESS_BACKEND_URL:-http://127.0.0.1:${PORT}}\"\n    16в†’DATABASE_URL=\"${DATABASE_URL:-postgres:///postgres}\"\n    17в†’DB_SCHEMA=\"${DB_SCHEMA:-local_e2e}\"\n    18в†’\n    19в†’cleanup() {\n    20в†’  if [ -n \"${BACKEND_PID:-}\" ]; then\n    21в†’    kill \"$BACKEND_PID\" >/dev/null 2>&1 || true\n    22в†’    wait \"$BACKEND_PID\" >/dev/null 2>&1 || true\n    23в†’  fi\n    24в†’  echo \"==> Stopping localnet validatorвЂ¦\"\n    25в†’  bash \"$SCRIPT_DIR/localnet-teardown.sh\" || true\n    26в†’}\n    27в†’\n    28в†’wait_for_health() {\n    29в†’  local url=\"$1\"\n    30в†’  local attempts=30\n    31в†’\n    32в†’  for ((i=1; i<=attempts; i++)); do\n    33в†’    if curl -fsS \"$url\" >/dev/null 2>&1; then\n    34в†’      return 0\n    35в†’    fi\n    36в†’    sleep 2\n    37в†’  done\n    38в†’\n    39в†’  return 1\n    40в†’}\n    41в†’\n    42в†’free_port_if_busy() {\n    43в†’  local port=\"$1\"\n    44в†’  local pids\n    45в†’  pids=\"$(lsof -ti \":$port\" 2>/dev/null || true)\"\n    46в†’  if [ -z \"$pids\" ]; then\n    47в†’    return 0\n    48в†’  fi\n    49в†’\n    50в†’  echo \"==> Reclaiming port $port from stale process(es): $pids\"\n    51в†’  while IFS= read -r pid; do\n    52в†’    [ -z \"$pid\" ] && continue\n    53в†’    kill \"$pid\" >/dev/null 2>&1 || true\n    54в†’  done <<< \"$pids\"\n    55в†’\n    56в†’  sleep 1\n    57в†’}\n    58в†’\n    59в†’trap cleanup EXIT\n    60в†’\n    61в†’# --- Bootstrap ---\n    62в†’echo \"==> Starting localnet validatorвЂ¦\"\n    63в†’if ! bash \"$SCRIPT_DIR/localnet-bootstrap.sh\"; then\n    64в†’  echo \"вќЊ Localnet bootstrap failed\"\n    65в†’  exit 1\n    66в†’fi\n    67в†’\n    68в†’# Source backend .env if present without overriding explicit env vars.\n    69в†’if [ -f \"$BACKEND_DIR/.env\" ]; then\n    70в†’  while IFS='=' read -r key value; do\n    71в†’    [[ \"$key\" =~ ^[[:space:]]*# ]] && continue\n    72в†’    [[ -z \"$key\" ]] && continue\n    73в†’    key=\"$(echo \"$key\" | xargs)\"\n    74в†’    value=\"$(echo \"$value\" | xargs)\"\n    75в†’    if [ -z \"${!key:-}\" ]; then\n    76в†’      export \"$key=$value\"\n    77в†’    fi\n    78в†’  done < \"$BACKEND_DIR/.env\"\n    79в†’fi\n    80в†’\n    81в†’DATABASE_URL=\"${DATABASE_URL:-postgres:///postgres}\"\n    82в†’DB_SCHEMA=\"${DB_SCHEMA:-local_e2e}\"\n    83в†’RPC_URL=\"${RPC_URL:-http://127.0.0.1:8899}\"\n    84в†’\n    85в†’if ! pg_isready -q 2>/dev/null; then\n    86в†’  echo \"==> Starting PostgreSQLвЂ¦\"\n    87в†’  pg_ctlcluster 16 main start 2>/dev/null || sudo pg_ctlcluster 16 main start 2>/dev/null || true\n    88в†’  for i in $(seq 1 10); do\n    89в†’    pg_isready -q 2>/dev/null && break\n    90в†’    sleep 1\n    91в†’  done\n    92в†’  if ! pg_isready -q 2>/dev/null; then\n    93в†’    echo \"вќЊ Could not start PostgreSQL\"\n    94в†’    exit 1\n    95в†’  fi\n    96в†’fi\n    97в†’\n    98в†’if [ ! -f \"$BACKEND_KEYPAIR_FILE\" ]; then\n    99в†’  echo \"==> Generating local backend signerвЂ¦\"\n   100в†’  solana-keygen new --no-bip39-passphrase --silent -o \"$BACKEND_KEYPAIR_FILE\" >/dev/null\n   101в†’fi\n   102в†’\n   103в†’SERVER_KEYPAIR=\"${SERVER_KEYPAIR:-$(tr -d '\\n' < \"$BACKEND_KEYPAIR_FILE\")}\"\n   104в†’BACKEND_PUBKEY=\"$(solana address -k \"$BACKEND_KEYPAIR_FILE\")\"\n   105в†’echo \"==> Funding backend signer $BACKEND_PUBKEYвЂ¦\"\n   106в†’solana airdrop 2 \"$BACKEND_PUBKEY\" --url \"$RPC_URL\" >/dev/null 2>&1 || true\n   107в†’\n   108в†’echo \"==> Running backend migrationsвЂ¦\"\n   109в†’(\n   110в†’  cd \"$MONOREPO_DIR\"\n   111в†’  DATABASE_URL=\"$DATABASE_URL\" \\\n   112в†’  DB_SCHEMA=\"$DB_SCHEMA\" \\\n   113в†’  RPC_URL=\"$RPC_URL\" \\\n   114в†’  SERVER_KEYPAIR=\"$SERVER_KEYPAIR\" \\\n   115в†’  PORT=\"$PORT\" \\\n   116в†’  pnpm --filter @rng-utopia/backend migrate\n   117в†’)\n   118в†’\n   119в†’echo \"==> Starting fairness backendвЂ¦\"\n   120в†’free_port_if_busy \"$PORT\"\n   121в†’(\n   122в†’  cd \"$MONOREPO_DIR\"\n   123в†’  DATABASE_URL=\"$DATABASE_URL\" \\\n   124в†’  DB_SCHEMA=\"$DB_SCHEMA\" \\\n   125в†’  RPC_URL=\"$RPC_URL\" \\\n   126в†’  SERVER_KEYPAIR=\"$SERVER_KEYPAIR\" \\\n   127в†’  PORT=\"$PORT\" \\\n   128в†’  pnpm --filter @rng-utopia/backend dev\n   129в†’) >\"$BACKEND_LOG\" 2>&1 &\n   130в†’BACKEND_PID=$!\n   131в†’\n   132в†’if ! wait_for_health \"${VITE_FAIRNESS_BACKEND_URL}/health\"; then\n   133в†’  echo \"вќЊ Fairness backend failed to become healthy\"\n   134в†’  echo \"   Log: $BACKEND_LOG\"\n   135в†’  exit 1\n   136в†’fi\n   137в†’\n   138в†’# --- Run tests (capture exit code, always teardown after) ---\n   139в†’echo \"==> Running local E2E testsвЂ¦\"\n   140в†’TEST_EXIT=0\n   141в†’(cd \"$APP_DIR\" && VITE_FAIRNESS_BACKEND_URL=\"$VITE_FAIRNESS_BACKEND_URL\" npx playwright test --config playwright.local.config.ts \"$@\") || TEST_EXIT=$?\n   142в†’\n   143в†’# --- Report ---\n   144в†’if [ \"$TEST_EXIT\" -eq 0 ]; then\n   145в†’  echo \"вњ… Local E2E tests passed\"\n   146в†’else\n   147в†’  echo \"вќЊ Local E2E tests failed (exit $TEST_EXIT)\"\n   148в†’fi\n   149в†’\n   150в†’exit \"$TEST_EXIT\"\n   151в†’"}]},"