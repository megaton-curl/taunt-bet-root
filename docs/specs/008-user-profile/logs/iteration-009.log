{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L9USpkQzav2xCubvPDvS8A","type":"tool_result","content":"     1в†’/**\n     2в†’ * Auth-specific database operations for challenge/response and refresh tokens.\n     3в†’ * Shares the postgres connection pool via the sql instance passed in.\n     4в†’ */\n     5в†’\n     6в†’import type postgres from \"postgres\";\n     7в†’\n     8в†’export interface AuthChallenge {\n     9в†’  nonce: string;\n    10в†’  wallet: string;\n    11в†’  cluster: string;\n    12в†’  message: string;\n    13в†’  expires_at: Date;\n    14в†’  used: boolean;\n    15в†’  created_at: Date;\n    16в†’}\n    17в†’\n    18в†’export interface RefreshToken {\n    19в†’  id: string;\n    20в†’  wallet: string;\n    21в†’  token_hash: Buffer;\n    22в†’  family_id: string;\n    23в†’  expires_at: Date;\n    24в†’  revoked: boolean;\n    25в†’  created_at: Date;\n    26в†’}\n    27в†’\n    28в†’export interface AuthDb {\n    29в†’  insertChallenge(\n    30в†’    nonce: string,\n    31в†’    wallet: string,\n    32в†’    cluster: string,\n    33в†’    message: string,\n    34в†’    expiresAt: Date,\n    35в†’  ): Promise<AuthChallenge>;\n    36в†’\n    37в†’  /** Atomically consume a challenge (set used=TRUE). Returns null if already used or not found. */\n    38в†’  consumeChallenge(nonce: string): Promise<AuthChallenge | null>;\n    39в†’\n    40в†’  insertRefreshToken(\n    41в†’    wallet: string,\n    42в†’    tokenHash: Buffer,\n    43в†’    familyId: string,\n    44в†’    expiresAt: Date,\n    45в†’  ): Promise<RefreshToken>;\n    46в†’\n    47в†’  getRefreshTokenByHash(tokenHash: Buffer): Promise<RefreshToken | null>;\n    48в†’\n    49в†’  revokeRefreshToken(id: string): Promise<void>;\n    50в†’\n    51в†’  /** Revoke all tokens in a family (stolen-token detection). */\n    52в†’  revokeTokenFamily(familyId: string): Promise<void>;\n    53в†’\n    54в†’  /** Delete expired challenges and revoked/expired refresh tokens. */\n    55в†’  cleanupExpired(): Promise<void>;\n    56в†’}\n    57в†’\n    58в†’export function createAuthDb(sql: postgres.Sql): AuthDb {\n    59в†’  return {\n    60в†’    async insertChallenge(nonce, wallet, cluster, message, expiresAt) {\n    61в†’      const rows = await sql<AuthChallenge[]>`\n    62в†’        INSERT INTO auth_challenges (nonce, wallet, cluster, message, expires_at)\n    63в†’        VALUES (${nonce}, ${wallet}, ${cluster}, ${message}, ${expiresAt.toISOString()})\n    64в†’        RETURNING *\n    65в†’      `;\n    66в†’      return rows[0]!;\n    67в†’    },\n    68в†’\n    69в†’    async consumeChallenge(nonce) {\n    70в†’      const rows = await sql<AuthChallenge[]>`\n    71в†’        UPDATE auth_challenges\n    72в†’        SET used = TRUE\n    73в†’        WHERE nonce = ${nonce}\n    74в†’          AND used = FALSE\n    75в†’          AND expires_at > now()\n    76в†’        RETURNING *\n    77в†’      `;\n    78в†’      return rows[0] ?? null;\n    79в†’    },\n    80в†’\n    81в†’    async insertRefreshToken(wallet, tokenHash, familyId, expiresAt) {\n    82в†’      const rows = await sql<RefreshToken[]>`\n    83в†’        INSERT INTO refresh_tokens (wallet, token_hash, family_id, expires_at)\n    84в†’        VALUES (${wallet}, ${tokenHash}, ${familyId}, ${expiresAt.toISOString()})\n    85в†’        RETURNING *\n    86в†’      `;\n    87в†’      return rows[0]!;\n    88в†’    },\n    89в†’\n    90в†’    async getRefreshTokenByHash(tokenHash) {\n    91в†’      const rows = await sql<RefreshToken[]>`\n    92в†’        SELECT * FROM refresh_tokens WHERE token_hash = ${tokenHash}\n    93в†’      `;\n    94в†’      return rows[0] ?? null;\n    95в†’    },\n    96в†’\n    97в†’    async revokeRefreshToken(id) {\n    98в†’      await sql`UPDATE refresh_tokens SET revoked = TRUE WHERE id = ${id}`;\n    99в†’    },\n   100в†’\n   101в†’    async revokeTokenFamily(familyId) {\n   102в†’      await sql`UPDATE refresh_tokens SET revoked = TRUE WHERE family_id = ${familyId}`;\n   103в†’    },\n   104в†’\n   105в†’    async cleanupExpired() {\n   106в†’      await sql`DELETE FROM auth_challenges WHERE expires_at < now() OR used = TRUE`;\n   107в†’      await sql`DELETE FROM refresh_tokens WHERE expires_at < now() OR revoked = TRUE`;\n   108в†’    },\n   109в†’  };\n   110в†’}\n   111в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"853b79e3-f273-4a30-8953-bef774d45c03","timestamp":"2026-03-19T19:15:28.846Z"}
