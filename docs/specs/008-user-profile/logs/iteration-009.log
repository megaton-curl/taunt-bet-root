{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BhqZPCPEPh2m3bm4Dwkoba","type":"tool_result","content":"     1в†’/**\n     2в†’ * Dual-browser-context fixture for devnet E2E tests.\n     3в†’ *\n     4в†’ * Same isolated dual-player pattern as local fixtures, but connects\n     5в†’ * to the devnet RPC instead of a local validator. The RPC URL comes\n     6в†’ * from the validated devnet env config.\n     7в†’ *\n     8в†’ * Usage in tests:\n     9в†’ * ```ts\n    10в†’ * import { test, expect } from \"./fixtures\";\n    11в†’ *\n    12в†’ * test(\"devnet lifecycle\", async ({ playerAPage, playerBPage, connection }) => {\n    13в†’ *   // playerAPage and playerBPage target devnet via real RPC\n    14в†’ * });\n    15в†’ * ```\n    16в†’ */\n    17в†’import { test as base, type BrowserContext, type Page } from \"@playwright/test\";\n    18в†’import { Keypair, Connection } from \"@solana/web3.js\";\n    19в†’import { PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    20в†’import { type DevnetConfig, validateDevnetEnv } from \"./helpers/env\";\n    21в†’\n    22в†’export interface DevnetDualPlayerFixtures {\n    23в†’  /** Validated devnet configuration (RPC URL, program IDs). */\n    24в†’  devnetConfig: DevnetConfig;\n    25в†’  /** Isolated browser context for player A (keypair injected). */\n    26в†’  playerAContext: BrowserContext;\n    27в†’  /** Isolated browser context for player B (keypair injected). */\n    28в†’  playerBContext: BrowserContext;\n    29в†’  /** Page within player A's context. */\n    30в†’  playerAPage: Page;\n    31в†’  /** Page within player B's context. */\n    32в†’  playerBPage: Page;\n    33в†’  /** Player A's deterministic keypair. */\n    34в†’  playerAKeypair: Keypair;\n    35в†’  /** Player B's deterministic keypair. */\n    36в†’  playerBKeypair: Keypair;\n    37в†’  /** Shared RPC connection to the devnet cluster. */\n    38в†’  connection: Connection;\n    39в†’}\n    40в†’\n    41в†’/**\n    42в†’ * Inject a 32-byte keypair seed into a new browser context via addInitScript.\n    43в†’ */\n    44в†’async function createPlayerContext(\n    45в†’  browser: BrowserContext[\"browser\"],\n    46в†’  keypair: Keypair,\n    47в†’): Promise<BrowserContext> {\n    48в†’  const context = await browser!.newContext();\n    49в†’  const seedArray = Array.from(keypair.secretKey.slice(0, 32));\n    50в†’  await context.addInitScript((seed: number[]) => {\n    51в†’    (window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ =\n    52в†’      new Uint8Array(seed);\n    53в†’  }, seedArray);\n    54в†’  return context;\n    55в†’}\n    56в†’\n    57в†’export const test = base.extend<DevnetDualPlayerFixtures>({\n    58в†’  // Validate devnet env once per test (sync, cached by Playwright)\n    59в†’  // eslint-disable-next-line no-empty-pattern\n    60в†’  devnetConfig: async ({}, use) => {\n    61в†’    const config = validateDevnetEnv();\n    62в†’    await use(config);\n    63в†’  },\n    64в†’\n    65в†’  // Expose keypairs as fixtures\n    66в†’  playerAKeypair: [PLAYER_A, { option: true }],\n    67в†’  playerBKeypair: [PLAYER_B, { option: true }],\n    68в†’\n    69в†’  // Shared connection to devnet\n    70в†’  connection: async ({ devnetConfig }, use) => {\n    71в†’    const conn = new Connection(devnetConfig.rpcUrl, {\n    72в†’      commitment: \"confirmed\",\n    73в†’      confirmTransactionInitialTimeout: 120_000,\n    74в†’    });\n    75в†’    await use(conn);\n    76в†’  },\n    77в†’\n    78в†’  // --- Player A context + page ---\n    79в†’  playerAContext: async ({ browser, playerAKeypair }, use) => {\n    80в†’    const context = await createPlayerContext(browser, playerAKeypair);\n    81в†’    await use(context);\n    82в†’    await context.close();\n    83в†’  },\n    84в†’\n    85в†’  playerAPage: async ({ playerAContext }, use) => {\n    86в†’    const page = await playerAContext.newPage();\n    87в†’    await use(page);\n    88в†’  },\n    89в†’\n    90в†’  // --- Player B context + page ---\n    91в†’  playerBContext: async ({ browser, playerBKeypair }, use) => {\n    92в†’    const context = await createPlayerContext(browser, playerBKeypair);\n    93в†’    await use(context);\n    94в†’    await context.close();\n    95в†’  },\n    96в†’\n    97в†’  playerBPage: async ({ playerBContext }, use) => {\n    98в†’    const page = await playerBContext.newPage();\n    99в†’    await use(page);\n   100в†’  },\n   101в†’});\n   102в†’\n   103в†’export { expect } from \"@playwright/test\";\n   104в†’"}]},"parent_tool_use_id":"toolu_01HeJfpFiA1rSVyi58U1gKAc","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"c017be14-c424-4dd9-b790-e3adbf3e8ec6","timestamp":"2026-03-19T19:12:58.239Z"}
