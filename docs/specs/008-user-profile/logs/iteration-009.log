{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VnvzeysLcSDRRZ3KLMsNJG","type":"tool_result","content":"     1в†’/**\n     2в†’ * JWT Bearer token authentication middleware.\n     3в†’ *\n     4в†’ * Verifies HS256 JWT access tokens on POST requests.\n     5в†’ * Sets c.set(\"wallet\", payload.sub) for downstream handlers.\n     6в†’ * GET requests pass through without authentication.\n     7в†’ */\n     8в†’\n     9в†’import { createMiddleware } from \"hono/factory\";\n    10в†’import { jwtVerify } from \"jose\";\n    11в†’import { logger } from \"../logger.js\";\n    12в†’import type { AppEnv } from \"../hono-env.js\";\n    13в†’\n    14в†’export interface JwtAuthConfig {\n    15в†’  jwtSecret: Uint8Array;\n    16в†’  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n    17в†’  requireAllMethods?: boolean;\n    18в†’}\n    19в†’\n    20в†’export function createJwtAuthMiddleware(config: JwtAuthConfig) {\n    21в†’  return createMiddleware<AppEnv>(async (c, next) => {\n    22в†’    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n    23в†’    // unless requireAllMethods is set (e.g., profile endpoints)\n    24в†’    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n    25в†’      return next();\n    26в†’    }\n    27в†’\n    28в†’    const authHeader = c.req.header(\"Authorization\");\n    29в†’    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n    30в†’      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n    31в†’        path: c.req.path,\n    32в†’      });\n    33в†’      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n    34в†’    }\n    35в†’\n    36в†’    const token = authHeader.slice(7);\n    37в†’    try {\n    38в†’      const { payload } = await jwtVerify(token, config.jwtSecret, {\n    39в†’        algorithms: [\"HS256\"],\n    40в†’      });\n    41в†’\n    42в†’      if (typeof payload.sub !== \"string\") {\n    43в†’        logger.warn(\"jwt auth rejected: missing sub claim\", {\n    44в†’          path: c.req.path,\n    45в†’        });\n    46в†’        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n    47в†’      }\n    48в†’\n    49в†’      c.set(\"wallet\", payload.sub);\n    50в†’      return next();\n    51в†’    } catch (err) {\n    52в†’      logger.warn(\"jwt auth rejected: token verification failed\", {\n    53в†’        path: c.req.path,\n    54в†’        error: err instanceof Error ? err.message : \"Unknown error\",\n    55в†’      });\n    56в†’      return c.json({ error: \"Invalid or expired token\" }, 401);\n    57в†’    }\n    58в†’  });\n    59в†’}\n    60в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"fd1debca-07b0-46e0-8b5a-9281b8ff1cd9","timestamp":"2026-03-19T19:15:28.701Z"}
