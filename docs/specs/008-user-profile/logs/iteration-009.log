{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01XUKXbuY87eYKiwxAzde8Qk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01E6XomiYyQyi5vt4e3MgAfA","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/20-profile-transactions.spec.ts","content":"/**\n * Local E2E test: profile transactions after coinflip settlement.\n *\n * Plays a coinflip match to completion, then navigates to the profile page\n * and verifies that transaction rows (join + win/loss) appear in the\n * Transactions tab.\n *\n * Prerequisites (handled by run-e2e-local.sh):\n * - solana-test-validator running with deployed programs\n * - Backend running with postgres + migrations applied (including user_transactions)\n * - Test wallets funded\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport { fundTestWallets } from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\n\n// Selectors for profile page elements\nconst profileSel = {\n  header: \".profile-page__header\",\n  tab: (label: string) => `button:has-text(\"${label}\")`,\n  txTable: \".profile-transactions__table\",\n  txRows: \".profile-transactions__table tbody tr\",\n  txEmpty: \".profile-transactions__empty\",\n  txSkeleton: \".profile-transactions__skeleton\",\n  matchLink: \".profile-transactions__match-link\",\n};\n\ntest.describe(\"Profile transactions\", () => {\n  test.describe.configure({ mode: \"serial\" });\n\n  test.beforeAll(async () => {\n    await fundTestWallets();\n    await initializeLocalnet();\n  });\n\n  test(\"shows transaction history after coinflip settlement\", async ({\n    playerAPage,\n    playerBPage,\n  }) => {\n    const consoleA = po.trackConsoleErrors(playerAPage);\n\n    // в”Ђв”Ђ Step 1: Play a coinflip match to generate transaction data в”Ђв”Ђ\n\n    await po.navigateToCoinflip(playerAPage);\n    await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n    await po.navigateToCoinflip(playerBPage);\n    await po.waitForLobbyMatch(playerBPage);\n    await po.joinMatch(playerBPage);\n\n    // Wait for backend settlement\n    await Promise.all([\n      po.waitForResult(playerAPage, 30_000),\n      po.waitForResult(playerBPage, 30_000),\n    ]);\n\n    // в”Ђв”Ђ Step 2: Navigate Player A to profile page в”Ђв”Ђ\n    // After page.goto(), the SPA reloads. SessionContext will restore\n    // the session from the refresh token in localStorage (network call\n    // to /auth/refresh or /auth/verify). We wait for that to complete\n    // before clicking the Transactions tab, so the token is available\n    // when useTransactions mounts.\n\n    const authDone = playerAPage.waitForResponse(\n      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n      { timeout: 15_000 },\n    );\n    await playerAPage.goto(\"/profile\");\n    await authDone;\n\n    // Wait for profile header to confirm page rendered\n    await expect(\n      playerAPage.locator(profileSel.header),\n    ).toBeVisible({ timeout: 10_000 });\n\n    // в”Ђв”Ђ Step 3: Click Transactions tab в”Ђв”Ђ\n    await playerAPage.click(profileSel.tab(\"Transactions\"));\n\n    // в”Ђв”Ђ Step 4: Wait for transaction table to appear в”Ђв”Ђ\n    // (not loading skeleton, not empty state)\n    const table = playerAPage.locator(profileSel.txTable);\n    await expect(table).toBeVisible({ timeout: 10_000 });\n\n    // в”Ђв”Ђ Step 5: Verify Player A has exactly 2 rows: join + win/loss в”Ђв”Ђ\n    const rows = playerAPage.locator(profileSel.txRows);\n    await expect(rows).toHaveCount(2, { timeout: 5_000 });\n\n    // в”Ђв”Ђ Step 6: Verify game name в”Ђв”Ђ\n    // API returns game = \"coinflip\", GAME_NAMES maps it to \"Flip You\"\n    const firstLink = playerAPage.locator(profileSel.matchLink).first();\n    await expect(firstLink).toContainText(\"Flip You\");\n\n    // в”Ђв”Ђ Step 7: Verify event types в”Ђв”Ђ\n    const tableText = await table.textContent();\n    expect(tableText).toContain(\"JOIN\");\n    // Player A is either winner or loser вЂ” check for WIN or LOSS\n    const hasOutcome =\n      tableText?.includes(\"WIN\") || tableText?.includes(\"LOSS\");\n    expect(hasOutcome).toBe(true);\n\n    // в”Ђв”Ђ Step 8: Verify amounts display in SOL в”Ђв”Ђ\n    expect(tableText).toContain(\"SOL\");\n\n    // в”Ђв”Ђ Step 9: Verify match deep-links в”Ђв”Ђ\n    // Each transaction row should link to /coinflip/:matchId\n    const links = playerAPage.locator(profileSel.matchLink);\n    const linkCount = await links.count();\n    for (let i = 0; i < linkCount; i++) {\n      const href = await links.nth(i).getAttribute(\"href\");\n      expect(href).toMatch(/^\\/coinflip\\/.+/);\n    }\n\n    // No unexpected console errors\n    consoleA.assertClean();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":623,"cache_read_input_tokens":79512,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":623},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"b7fc11b9-da52-45b6-a4c1-44488df7a198"}
