{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AnxszkK2S7fb49K6xNJe5P","type":"tool_result","content":"     1в†’/**\n     2в†’ * Localnet setup helper вЂ” initializes coinflip and platform configs.\n     3в†’ *\n     4в†’ * Must be called once before the E2E suite starts, after the test validator\n     5в†’ * is running and wallets are funded. Initializes:\n     6в†’ * - Coinflip config PDA (sets authority + treasury)\n     7в†’ * - Platform config PDA (sets authority + treasury)\n     8в†’ */\n     9в†’import {\n    10в†’  Connection,\n    11в†’  Keypair,\n    12в†’  PublicKey,\n    13в†’  SystemProgram,\n    14в†’  Transaction,\n    15в†’  sendAndConfirmTransaction,\n    16в†’} from \"@solana/web3.js\";\n    17в†’import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n    18в†’import {\n    19в†’  CoinflipIDL,\n    20в†’  PlatformIDL,\n    21в†’  LordofrngsIDL,\n    22в†’  type Coinflip,\n    23в†’  type Platform,\n    24в†’  type Lordofrngs,\n    25в†’} from \"@rng-utopia/anchor-client\";\n    26в†’import { LOCAL_RPC_URL } from \"./wallets\";\n    27в†’\n    28в†’// в”Ђв”Ђ Deterministic admin/treasury keypairs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n    29в†’const SEED_ADMIN = new Uint8Array(32).fill(0xdd);\n    30в†’const SEED_TREASURY = new Uint8Array(32).fill(0xcc);\n    31в†’\n    32в†’export const ADMIN = Keypair.fromSeed(SEED_ADMIN);\n    33в†’export const TREASURY = Keypair.fromSeed(SEED_TREASURY);\n    34в†’\n    35в†’// в”Ђв”Ђ Program IDs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n    36в†’const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    37в†’const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n    38в†’const LORDOFRNGS_PROGRAM_ID = new PublicKey(LordofrngsIDL.address);\n    39в†’\n    40в†’function getConfigPda(): PublicKey {\n    41в†’  const [pda] = PublicKey.findProgramAddressSync(\n    42в†’    [Buffer.from(\"coinflip_config\")],\n    43в†’    COINFLIP_PROGRAM_ID,\n    44в†’  );\n    45в†’  return pda;\n    46в†’}\n    47в†’\n    48в†’function getPlatformConfigPda(): PublicKey {\n    49в†’  const [pda] = PublicKey.findProgramAddressSync(\n    50в†’    [Buffer.from(\"platform_config\")],\n    51в†’    PLATFORM_PROGRAM_ID,\n    52в†’  );\n    53в†’  return pda;\n    54в†’}\n    55в†’\n    56в†’function getLordConfigPda(): PublicKey {\n    57в†’  const [pda] = PublicKey.findProgramAddressSync(\n    58в†’    [Buffer.from(\"lord_config\")],\n    59в†’    LORDOFRNGS_PROGRAM_ID,\n    60в†’  );\n    61в†’  return pda;\n    62в†’}\n    63в†’\n    64в†’function makeProvider(connection: Connection, wallet: Keypair): AnchorProvider {\n    65в†’  return new AnchorProvider(\n    66в†’    connection,\n    67в†’    {\n    68в†’      publicKey: wallet.publicKey,\n    69в†’      signTransaction: async (tx) => {\n    70в†’        tx.partialSign(wallet);\n    71в†’        return tx;\n    72в†’      },\n    73в†’      signAllTransactions: async (txs) => {\n    74в†’        txs.forEach((tx) => tx.partialSign(wallet));\n    75в†’        return txs;\n    76в†’      },\n    77в†’    },\n    78в†’    { commitment: \"confirmed\" },\n    79в†’  );\n    80в†’}\n    81в†’\n    82в†’/**\n    83в†’ * Initialize both program configs and fund the admin/treasury accounts.\n    84в†’ * Idempotent: silently succeeds if configs already exist.\n    85в†’ */\n    86в†’export async function initializeLocalnet(\n    87в†’  rpcUrl = LOCAL_RPC_URL,\n    88в†’): Promise<void> {\n    89в†’  const connection = new Connection(rpcUrl, \"confirmed\");\n    90в†’\n    91в†’  // Fund admin and treasury\n    92в†’  await Promise.all([\n    93в†’    fundIfNeeded(connection, ADMIN.publicKey, 2),\n    94в†’    fundIfNeeded(connection, TREASURY.publicKey, 2),\n    95в†’  ]);\n    96в†’\n    97в†’  const provider = makeProvider(connection, ADMIN);\n    98в†’  const coinflipProgram = new Program(\n    99в†’    CoinflipIDL as Idl as Coinflip,\n   100в†’    provider,\n   101в†’  );\n   102в†’  const platformProgram = new Program(\n   103в†’    PlatformIDL as Idl as Platform,\n   104в†’    provider,\n   105в†’  );\n   106в†’\n   107в†’  // Initialize coinflip config (idempotent)\n   108в†’  const configPda = getConfigPda();\n   109в†’  const configExists = await connection.getAccountInfo(configPda);\n   110в†’  if (!configExists) {\n   111в†’    const ix = await coinflipProgram.methods\n   112в†’      .initializeConfig(TREASURY.publicKey)\n   113в†’      .accountsStrict({\n   114в†’        authority: ADMIN.publicKey,\n   115в†’        config: configPda,\n   116в†’        systemProgram: SystemProgram.programId,\n   117в†’      })\n   118в†’      .instruction();\n   119в†’\n   120в†’    const tx = new Transaction().add(ix);\n   121в†’    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n   122в†’      commitment: \"confirmed\",\n   123в†’    });\n   124в†’  }\n   125в†’\n   126в†’  // Initialize platform config (idempotent)\n   127в†’  const platformConfigPda = getPlatformConfigPda();\n   128в†’  const platformConfigExists =\n   129в†’    await connection.getAccountInfo(platformConfigPda);\n   130в†’  if (!platformConfigExists) {\n   131в†’    const ix = await platformProgram.methods\n   132в†’      .initializePlatform(TREASURY.publicKey)\n   133в†’      .accountsStrict({\n   134в†’        authority: ADMIN.publicKey,\n   135в†’        config: platformConfigPda,\n   136в†’        systemProgram: SystemProgram.programId,\n   137в†’      })\n   138в†’      .instruction();\n   139в†’\n   140в†’    const tx = new Transaction().add(ix);\n   141в†’    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n   142в†’      commitment: \"confirmed\",\n   143в†’    });\n   144в†’  }\n   145в†’\n   146в†’  // Initialize lordofrngs config (idempotent)\n   147в†’  const lordConfigPda = getLordConfigPda();\n   148в†’  const lordConfigExists = await connection.getAccountInfo(lordConfigPda);\n   149в†’  if (!lordConfigExists) {\n   150в†’    const lordProgram = new Program(\n   151в†’      LordofrngsIDL as Idl as Lordofrngs,\n   152в†’      provider,\n   153в†’    );\n   154в†’    const ix = await lordProgram.methods\n   155в†’      .initializeConfig(TREASURY.publicKey)\n   156в†’      .accountsStrict({\n   157в†’        authority: ADMIN.publicKey,\n   158в†’        config: lordConfigPda,\n   159в†’        systemProgram: SystemProgram.programId,\n   160в†’      })\n   161в†’      .instruction();\n   162в†’\n   163в†’    const tx = new Transaction().add(ix);\n   164в†’    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n   165в†’      commitment: \"confirmed\",\n   166в†’    });\n   167в†’  }\n   168в†’\n   169в†’}\n   170в†’\n   171в†’/**\n   172в†’ * Local E2E helper retained for compatibility with Lord tests.\n   173в†’ * Player profiles are optional in localnet right now, so this is a no-op.\n   174в†’ */\n   175в†’export async function ensurePlayerProfiles(): Promise<void> {\n   176в†’  return;\n   177в†’}\n   178в†’\n   179в†’async function fundIfNeeded(\n   180в†’  connection: Connection,\n   181в†’  pubkey: PublicKey,\n   182в†’  solAmount: number,\n   183в†’): Promise<void> {\n   184в†’  const balance = await connection.getBalance(pubkey);\n   185в†’  if (balance >= solAmount * 1_000_000_000) return;\n   186в†’\n   187в†’  const sig = await connection.requestAirdrop(\n   188в†’    pubkey,\n   189в†’    solAmount * 1_000_000_000,\n   190в†’  );\n   191в†’  const { blockhash, lastValidBlockHeight } =\n   192в†’    await connection.getLatestBlockhash();\n   193в†’  await connection.confirmTransaction(\n   194в†’    { signature: sig, blockhash, lastValidBlockHeight },\n   195в†’    \"confirmed\",\n   196в†’  );\n   197в†’}\n   198в†’"}]},"parent_tool_use_id":"toolu_01HeJfpFiA1rSVyi58U1gKAc","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"89f399fb-480d-40cc-9395-b8827e198ce2","timestamp":"2026-03-19T19:13:02.272Z"}
