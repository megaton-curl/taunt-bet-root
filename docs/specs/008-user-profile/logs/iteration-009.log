{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014CbNC6x1kt6w622Ehk8mDf","type":"tool_result","content":"     1в†’import { ReactNode } from \"react\";\n     2в†’import { Keypair } from \"@solana/web3.js\";\n     3в†’import { TestWalletProvider } from \"./TestWalletProvider\";\n     4в†’\n     5в†’interface TestWalletWrapperProps {\n     6в†’  children: ReactNode;\n     7в†’}\n     8в†’\n     9в†’/**\n    10в†’ * Reads a 32-byte seed from `window.__TEST_WALLET_SEED__` (injected by\n    11в†’ * Playwright `addInitScript`) and renders TestWalletProvider with the\n    12в†’ * corresponding Keypair.\n    13в†’ *\n    14в†’ * This component is lazy-loaded by WalletProvider when VITE_TEST_WALLET=\"true\".\n    15в†’ */\n    16в†’export function TestWalletWrapper({ children }: TestWalletWrapperProps) {\n    17в†’  const seed: Uint8Array | undefined =\n    18в†’    typeof window !== \"undefined\"\n    19в†’      ? ((window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ as\n    20в†’          | Uint8Array\n    21в†’          | undefined)\n    22в†’      : undefined;\n    23в†’\n    24в†’  if (!seed) {\n    25в†’    throw new Error(\n    26в†’      \"TestWalletWrapper: window.__TEST_WALLET_SEED__ not found. \" +\n    27в†’        \"Inject it via Playwright addInitScript before loading the app.\",\n    28в†’    );\n    29в†’  }\n    30в†’\n    31в†’  const keypair = Keypair.fromSeed(new Uint8Array(seed));\n    32в†’  const rpcUrl =\n    33в†’    typeof import.meta !== \"undefined\"\n    34в†’      ? (import.meta.env?.VITE_RPC_URL as string | undefined)\n    35в†’      : undefined;\n    36в†’\n    37в†’  return (\n    38в†’    <TestWalletProvider keypair={keypair} rpcUrl={rpcUrl || undefined}>\n    39в†’      {children}\n    40в†’    </TestWalletProvider>\n    41в†’  );\n    42в†’}\n    43в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"468f42c0-6398-408d-bcb5-b22287fa