{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XWS3mKm7Kt3BrNdVdc3XgV","type":"tool_result","content":"     1в†’/**\n     2в†’ * ProfileStats - Statistics tab content\n     3в†’ *\n     4в†’ * Shows aggregate stats and per-game breakdown.\n     5в†’ */\n     6в†’\n     7в†’import type { PlayerProfile, GameId } from \"../types\";\n     8в†’import { GAME_NAMES } from \"../types\";\n     9в†’\n    10в†’interface ProfileStatsProps {\n    11в†’  profile: PlayerProfile;\n    12в†’}\n    13в†’\n    14в†’export function ProfileStats({ profile }: ProfileStatsProps) {\n    15в†’  const { stats } = profile;\n    16в†’\n    17в†’  const formatAmount = (amount: number): string => {\n    18в†’    if (Math.abs(amount) >= 1000) {\n    19в†’      return `${(amount / 1000).toFixed(1)}K`;\n    20в†’    }\n    21в†’    return amount.toFixed(2);\n    22в†’  };\n    23в†’\n    24в†’  const winRate = stats.gamesPlayed > 0\n    25в†’    ? ((stats.wins / stats.gamesPlayed) * 100).toFixed(1)\n    26в†’    : \"0.0\";\n    27в†’\n    28в†’  const gameIds: GameId[] = [\"coinflip\", \"lord-of-rngs\", \"crypto-crash\", \"close-call\", \"game-of-trades\"];\n    29в†’\n    30в†’  return (\n    31в†’    <div className=\"profile-stats\">\n    32в†’      {/* Aggregate Stats Grid */}\n    33в†’      <div className=\"profile-stats__grid\">\n    34в†’        <div className=\"profile-stats__card\">\n    35в†’          <div className=\"profile-stats__card-value\">{stats.gamesPlayed}</div>\n    36в†’          <div className=\"profile-stats__card-label\">Games Played</div>\n    37в†’        </div>\n    38в†’\n    39в†’        <div className=\"profile-stats__card\">\n    40в†’          <div className=\"profile-stats__card-value\">{\"$\" + formatAmount(stats.totalWagered)}</div>\n    41в†’          <div className=\"profile-stats__card-label\">Total Wagered</div>\n    42в†’        </div>\n    43в†’\n    44в†’        <div className=\"profile-stats__card\">\n    45в†’          <div className=\"profile-stats__card-value\">{stats.wins}</div>\n    46в†’          <div className=\"profile-stats__card-label\">Total Wins</div>\n    47в†’        </div>\n    48в†’\n    49в†’        <div className=\"profile-stats__card\">\n    50в†’          <div className={`profile-stats__card-value ${stats.netProfit >= 0 ? \"profile-stats__card-value--positive\" : \"profile-stats__card-value--negative\"}`}>\n    51в†’            {stats.netProfit >= 0 ? \"+$\" : \"-$\"}{formatAmount(Math.abs(stats.netProfit))}\n    52в†’          </div>\n    53в†’          <div className=\"profile-stats__card-label\">Net Profit</div>\n    54в†’        </div>\n    55в†’\n    56в†’        <div className=\"profile-stats__card\">\n    57в†’          <div className=\"profile-stats__card-value\">{winRate}%</div>\n    58в†’          <div className=\"profile-stats__card-label\">Win Rate</div>\n    59в†’        </div>\n    60в†’\n    61в†’        <div className=\"profile-stats__card\">\n    62в†’          <div className=\"profile-stats__card-value\">{stats.bestWinStreak}</div>\n    63в†’          <div className=\"profile-stats__card-label\">Best Streak</div>\n    64в†’        </div>\n    65в†’      </div>\n    66в†’\n    67в†’      {/* Per-Game Breakdown */}\n    68в†’      <div className=\"profile-stats__game-breakdown\">\n    69в†’        <h3 className=\"profile-stats__game-breakdown-title\">Per-Game Breakdown</h3>\n    70в†’        {gameIds.map((gameId) => {\n    71в†’          const gameStats = stats.gameStats[gameId];\n    72в†’          const gameWinRate = gameStats.gamesPlayed > 0\n    73в†’            ? ((gameStats.wins / gameStats.gamesPlayed) * 100).toFixed(0)\n    74в†’            : \"0\";\n    75в†’\n    76в†’          return (\n    77в†’            <div key={gameId} className=\"profile-stats__game-row\">\n    78в†’              <span className=\"profile-stats__game-name\">{GAME_NAMES[gameId]}</span>\n    79в†’              <span className=\"profile-stats__game-stat\">{gameStats.gamesPlayed} games</span>\n    80в†’              <span className=\"profile-stats__game-stat\">{gameStats.wins}W / {gameStats.losses}L</span>"}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"8e055d53-01b0-41fe-b1f5-16485ab222d5","timestamp":"2026-03-19T19:12:36.985Z"}
