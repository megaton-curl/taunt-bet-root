{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JzuuLGcHnXHCu9P9HYcJUW","type":"tool_result","content":"     1в†’/**\n     2в†’ * ProfilePage - Main profile page component\n     3в†’ *\n     4в†’ * Displays the full player profile with tabs:\n     5в†’ * - Statistics (player stats and game performance)\n     6в†’ * - Transactions (game history)\n     7в†’ * - Settings (username, avatar, socials)\n     8в†’ */\n     9в†’\n    10в†’import { useState, useRef, useEffect } from \"react\";\n    11в†’import { usePlayerProfile } from \"../context/PlayerProfileContext\";\n    12в†’import { useBossRaid } from \"../../boss-raid\";\n    13в†’import { PlayerAvatar } from \"./PlayerAvatar\";\n    14в†’import { LevelProgressBar } from \"./LevelProgressBar\";\n    15в†’import { ProfileStats } from \"./ProfileStats\";\n    16в†’import { ProfileTransactions } from \"./ProfileTransactions\";\n    17в†’import { ProfileSettings } from \"./ProfileSettings\";\n    18в†’import { AvatarSelectorModal } from \"./AvatarSelectorModal\";\n    19в†’import { MAX_USERNAME_LENGTH, MIN_USERNAME_LENGTH, USERNAME_REGEX } from \"../types\";\n    20в†’\n    21в†’type ProfileTab = \"stats\" | \"transactions\" | \"settings\";\n    22в†’\n    23в†’// Pencil edit icon\n    24в†’const EditIcon = () => (\n    25в†’  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    26в†’    <path d=\"M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z\"/>\n    27в†’  </svg>\n    28в†’);\n    29в†’\n    30в†’// Check/save icon\n    31в†’const CheckIcon = () => (\n    32в†’  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    33в†’    <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z\"/>\n    34в†’  </svg>\n    35в†’);\n    36в†’\n    37в†’// Cancel icon\n    38в†’const CancelIcon = () => (\n    39в†’  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    40в†’    <path d=\"M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z\"/>\n    41в†’  </svg>\n    42в†’);\n    43в†’\n    44в†’export function ProfilePage() {\n    45в†’  const { myProfile, loading, updateUsername } = usePlayerProfile();\n    46в†’  const { hasRNGBuff, rngBuff } = useBossRaid();\n    47в†’  const [activeTab, setActiveTab] = useState<ProfileTab>(\"stats\");\n    48в†’  const [isEditingName, setIsEditingName] = useState(false);\n    49в†’  const [editedName, setEditedName] = useState(\"\");\n    50в†’  const [savingName, setSavingName] = useState(false);\n    51в†’  const [nameError, setNameError] = useState<string | null>(null);\n    52в†’  const [isAvatarModalOpen, setIsAvatarModalOpen] = useState(false);\n    53в†’  const [buffTimeRemaining, setBuffTimeRemaining] = useState(0);\n    54в†’  const inputRef = useRef<HTMLInputElement>(null);\n    55в†’\n    56в†’  // Update buff timer every second\n    57в†’  useEffect(() => {\n    58в†’    if (!hasRNGBuff || !rngBuff) {\n    59в†’      setBuffTimeRemaining(0);\n    60в†’      return;\n    61в†’    }\n    62в†’\n    63в†’    const updateTimer = () => {\n    64в†’      const remaining = Math.max(0, rngBuff.expiresAt - Date.now());\n    65в†’      setBuffTimeRemaining(remaining);\n    66в†’    };\n    67в†’\n    68в†’    updateTimer();\n    69в†’    const interval = setInterval(updateTimer, 1000);\n    70в†’    return () => clearInterval(interval);\n    71в†’  }, [hasRNGBuff, rngBuff]);\n    72в†’\n    73в†’  useEffect(() => {\n    74в†’    if (isEditingName && inputRef.current) {\n    75в†’      inputRef.current.focus();\n    76в†’      inputRef.current.select();\n    77в†’    }\n    78в†’  }, [isEditingName]);\n    79в†’\n    80в†’  const validateUsername = (value: string): string | null => {\n    81в†’    if (value.length === 0) return null;\n    82в†’    if (value.length < MIN_USERNAME_LENGTH) {\n    83в†’      return `Min ${MIN_USERNAME_LENGTH} characters`;\n    84в†’    }\n    85в†’    if (value.length > MAX_USERNAME_LENGTH) {\n    86в†’      return `Max ${MAX_USERNAME_LENGTH} characters`;\n    87в†’    }\n    88в†’    if (!USERNAME_REGEX.test(value)) {\n    89в†’      return \"Letters, numbers, underscores only\";\n    90в†’    }\n    91в†’    return null;\n    92в†’  };\n    93в†’\n    94в†’  const handleStartEditing = () => {\n    95в†’    setEditedName(myProfile?.username ?? \"\");\n    96в†’    setNameError(null);\n    97в†’    setIsEditingName(true);\n    98в†’  };\n    99в†’\n   100в†’  const handleCancelEditing = () => {\n   101в†’    setIsEditingName(false);\n   102в†’    setEditedName(\"\");\n   103в†’    setNameError(null);\n   104в†’  };\n   105в†’\n   106в†’  const handleSaveName = async () => {\n   107в†’    const error = validateUsername(editedName);\n   108в†’    if (error) {\n   109в†’      setNameError(error);\n   110в†’      return;\n   111в†’    }\n   112в†’\n   113в†’    setSavingName(true);\n   114в†’    try {\n   115в†’      await updateUsername(editedName || \"\");\n   116в†’      setIsEditingName(false);\n   117в†’      setNameError(null);\n   118в†’    } catch (err) {\n   119в†’      console.error(\"Failed to save username:\", err);\n   120в†’    } finally {\n   121в†’      setSavingName(false);\n   122в†’    }\n   123в†’  };\n   124в†’\n   125в†’  const handleKeyDown = (e: React.KeyboardEvent) => {\n   126в†’    if (e.key === \"Enter\") {\n   127в†’      handleSaveName();\n   128в†’    } else if (e.key === \"Escape\") {\n   129в†’      handleCancelEditing();\n   130в†’    }\n   131в†’  };\n   132в†’\n   133в†’  if (loading) {\n   134в†’    return (\n   135в†’      <div className=\"profile-page\">\n   136в†’        <div className=\"profile-page__loading\">Loading profile...</div>\n   137в†’      </div>\n   138в†’    );\n   139в†’  }\n   140в†’\n   141в†’  if (!myProfile) {\n   142в†’    return (\n   143в†’      <div className=\"profile-page\">\n   144в†’        <div className=\"profile-page__connect\">\n   145в†’          <h2>Connect Wallet</h2>\n   146в†’          <p>Connect your wallet to view your profile.</p>\n   147в†’        </div>\n   148в†’      </div>\n   149в†’    );\n   150в†’  }\n   151в†’\n   152в†’  const tabs: { id: ProfileTab; label: string }[] = [\n   153в†’    { id: \"stats\", label: \"Statistics\" },\n   154в†’    { id: \"transactions\", label: \"Transactions\" },\n   155в†’    { id: \"settings\", label: \"Settings\" },\n   156в†’  ];\n   157в†’\n   158в†’  return (\n   159в†’    <div className=\"profile-page\">\n   160в†’      {/* Avatar Selector Modal */}\n   161в†’      <AvatarSelectorModal\n   162в†’        profile={myProfile}\n   163в†’        isOpen={isAvatarModalOpen}\n   164в†’        onClose={() => setIsAvatarModalOpen(false)}\n   165в†’      />\n   166в†’\n   167в†’      {/* Header */}\n   168в†’      <div className=\"profile-page__header\">\n   169в†’        <div\n   170в†’          className=\"profile-page__avatar-section profile-page__avatar-section--clickable\"\n   171в†’          onClick={() => setIsAvatarModalOpen(true)}\n   172в†’          onKeyDown={(e) => e.key === \"Enter\" && setIsAvatarModalOpen(true)}\n   173в†’          role=\"button\"\n   174в†’          tabIndex={0}\n   175в†’          title=\"Click to change avatar\"\n   176в†’        >\n   177в†’          <PlayerAvatar\n   178в†’            address={myProfile.address}\n   179в†’            size=\"xl\"\n   180в†’            showLevel={true}\n   181в†’            enableMiniProfile={false}\n   182в†’          />\n   183в†’          <div className=\"profile-page__avatar-edit-hint\">\n   184в†’            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n   185в†’              <path d=\"M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z\"/>\n   186в†’            </svg>\n   187в†’          </div>\n   188в†’        </div>\n   189в†’\n   190в†’        <div className=\"profile-page__info\">\n   191в†’          <div className=\"profile-page__name-row\">\n   192в†’            {isEditingName ? (\n   193в†’              <div className=\"profile-page__name-edit\">\n   194в†’                <input\n   195в†’                  ref={inputRef}\n   196в†’                  type=\"text\"\n   197в†’                  className={`profile-page__name-input ${nameError ? \"profile-page__name-input--error\" : \"\"}`}\n   198в†’                  value={editedName}\n   199в†’                  onChange={(e) => {\n   200в†’                    setEditedName(e.target.value);\n   201в†’                    setNameError(validateUsername(e.target.value));\n   202в†’                  }}\n   203в†’                  onKeyDown={handleKeyDown}\n   204в†’                  placeholder=\"Enter username\"\n   205в†’                  maxLength={MAX_USERNAME_LENGTH}\n   206в†’                  disabled={savingName}\n   207в†’                />\n   208в†’                <button\n   209в†’                  type=\"button\"\n   210в†’                  className=\"profile-page__name-btn profile-page__name-btn--save\"\n   211в†’                  onClick={handleSaveName}\n   212в†’                  disabled={savingName || !!nameError}\n   213в†’                  title=\"Save\"\n   214в†’                >\n   215в†’                  <CheckIcon />\n   216в†’                </button>\n   217в†’                <button\n   218в†’                  type=\"button\"\n   219в†’                  className=\"profile-page__name-btn profile-page__name-btn--cancel\"\n   220в†’                  onClick={handleCancelEditing}\n   221в†’                  disabled={savingName}\n   222в†’                  title=\"Cancel\"\n   223в†’                >\n   224в†’                  <CancelIcon />\n   225в†’                </button>\n   226в†’                {nameError && (\n   227в†’                  <span className=\"profile-page__name-error\">{nameError}</span>\n   228в†’                )}\n   229в†’              </div>\n   230в†’            ) : (\n   231в†’              <>\n   232в†’                <h1 className=\"profile-page__name\">\n   233в†’                  {myProfile.username ?? \"Anonymous Player\"}\n   234в†’                </h1>\n   235в†’                <button\n   236в†’                  type=\"button\"\n   237в†’                  className=\"profile-page__name-edit-btn\"\n   238в†’                  onClick={handleStartEditing}\n   239в†’                  title=\"Edit username\"\n   240в†’                >\n   241в†’                  <EditIcon />\n   242в†’                </button>\n   243в†’              </>\n   244в†’            )}\n   245в†’          </div>\n   246в†’          <div className=\"profile-page__level-section\">\n   247в†’            <LevelProgressBar totalXP={myProfile.totalXP} size=\"md\" />\n   248в†’\n   249в†’            {/* RNG Buff indicator - compact pill */}\n   250в†’            {hasRNGBuff && rngBuff && (\n   251в†’              <div className=\"profile-page__buff-indicator\" title=\"Heater grants chance for crate drops when wagering\">\n   252в†’                <div className=\"profile-page__buff-icon\">\n   253в†’                  <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n   254в†’                    <path\n   255в†’                      d=\"M12 2L14.4 8.2L21 9.2L16 14L17.6 21L12 17.8L6.4 21L8 14L3 9.2L9.6 8.2L12 2Z\"\n   256в†’                      fill=\"url(#profile-buff-gradient)\"\n   257в†’                      stroke=\"#f0b820\"\n   258в†’                      strokeWidth=\"1.5\"\n   259в†’                      strokeLinejoin=\"round\"\n   260в†’                    />\n   261в†’                    <defs>\n   262в†’                      <linearGradient id=\"profile-buff-gradient\" x1=\"12\" y1=\"2\" x2=\"12\" y2=\"21\" gradientUnits=\"userSpaceOnUse\">\n   263в†’                        <stop stopColor=\"#ffeb3b\" />\n   264в†’                        <stop offset=\"1\" stopColor=\"#ff9800\" />\n   265в†’                      </linearGradient>\n   266в†’                    </defs>\n   267в†’                  </svg>\n   268в†’                </div>\n   269в†’                <div className=\"profile-page__buff-info\">\n   270в†’                  <span className=\"profile-page__buff-label\">Heater</span>\n   271в†’                  <span className=\"profile-page__buff-timer\">\n   272в†’                    {Math.floor(buffTimeRemaining / 60000)}:{Math.floor((buffTimeRemaining % 60000) / 1000).toString().padStart(2, \"0\")}\n   273в†’                  </span>\n   274в†’                </div>\n   275в†’              </div>\n   276в†’            )}\n   277в†’          </div>\n   278в†’        </div>\n   279в†’      </div>\n   280в†’\n   281в†’      {/* Tabs */}\n   282в†’      <div className=\"profile-page__tabs\">\n   283в†’        {tabs.map((tab) => (\n   284в†’          <button\n   285в†’            key={tab.id}\n   286в†’            type=\"button\"\n   287в†’            className={`profile-page__tab ${activeTab === tab.id ? \"profile-page__tab--active\" : \"\"}`}\n   288в†’            onClick={() => setActiveTab(tab.id)}\n   289в†’          >\n   290в†’            {tab.label}\n   291в†’          </button>\n   292в†’        ))}\n   293в†’      </div>\n   294в†’\n   295в†’      {/* Content */}\n   296в†’      <div className=\"profile-page__content\">\n   297в†’        {activeTab === \"stats\" && <ProfileStats profile={myProfile} />}\n   298в†’        {activeTab === \"transactions\" && <ProfileTransactions />}\n   299в†’        {activeTab === \"settings\" && <ProfileSettings profile={myProfile} />}\n   300в†’      </div>\n   301в†’    </div>\n   302в†’  );\n   303в†’}\n   304в†’"}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"e9f1ded2-38ed-4677-9d2b-6a1b4078489d","timestamp":"2026-03-19T19:12:26.615Z"}
