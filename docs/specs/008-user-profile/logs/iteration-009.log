{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01USD1PUavJRLGTbAQMqdNgt","type":"tool_result","content":"     1в†’/**\n     2в†’ * SessionContext вЂ” JWT session management for wallet authentication.\n     3в†’ *\n     4в†’ * Provides sign-once authentication: wallet signs a human-readable challenge\n     5в†’ * on connect, backend issues JWT access + refresh tokens, and all subsequent\n     6в†’ * requests use Bearer tokens.\n     7в†’ */\n     8в†’\n     9в†’import {\n    10в†’  createContext,\n    11в†’  useContext,\n    12в†’  useState,\n    13в†’  useCallback,\n    14в†’  useEffect,\n    15в†’  useRef,\n    16в†’  type ReactNode,\n    17в†’} from \"react\";\n    18в†’import bs58 from \"bs58\";\n    19в†’import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    20в†’import {\n    21в†’  requestChallenge,\n    22в†’  verifyChallenge,\n    23в†’  refreshSession,\n    24в†’  logout,\n    25в†’} from \"../lib/auth-api\";\n    26в†’import {\n    27в†’  getAccessToken,\n    28в†’  setAccessToken,\n    29в†’  getPersistedSession,\n    30в†’  setPersistedSession,\n    31в†’  clearPersistedSession,\n    32в†’  getAccessExpiresAt,\n    33в†’} from \"../lib/auth-store\";\n    34в†’\n    35в†’interface SessionContextValue {\n    36в†’  isAuthenticated: boolean;\n    37в†’  isAuthenticating: boolean;\n    38в†’  accessToken: string | null;\n    39в†’  authenticate: () => Promise<string>;\n    40в†’  clearSession: () => void;\n    41в†’}\n    42в†’\n    43в†’const SessionContext = createContext<SessionContextValue | null>(null);\n    44в†’\n    45в†’export function SessionProvider({ children }: { children: ReactNode }) {\n    46в†’  const { connected, publicKey, signMessage } = useWallet();\n    47в†’\n    48в†’  const [isAuthenticated, setIsAuthenticated] = useState(false);\n    49в†’  const [isAuthenticating, setIsAuthenticating] = useState(false);\n    50в†’\n    51в†’  // Mutex for refresh вЂ” only one in-flight refresh at a time\n    52в†’  const refreshPromiseRef = useRef<Promise<boolean> | null>(null);\n    53в†’  const refreshTimerRef = useRef<number | null>(null);\n    54в†’  const prevWalletRef = useRef<string | null>(null);\n    55в†’\n    56в†’  const clearSession = useCallback(() => {\n    57в†’    const session = getPersistedSession();\n    58в†’    if (session) {\n    59в†’      // Best-effort logout on backend\n    60в†’      logout(session.refreshToken).catch(() => {});\n    61в†’    }\n    62в†’    clearPersistedSession();\n    63в†’    setIsAuthenticated(false);\n    64в†’    if (refreshTimerRef.current !== null) {\n    65в†’      clearTimeout(refreshTimerRef.current);\n    66в†’      refreshTimerRef.current = null;\n    67в†’    }\n    68в†’  }, []);\n    69в†’\n    70в†’  // Schedule proactive refresh ~5 min before access token expiry\n    71в†’  const scheduleRefresh = useCallback(() => {\n    72в†’    if (refreshTimerRef.current !== null) {\n    73в†’      clearTimeout(refreshTimerRef.current);\n    74в†’    }\n    75в†’\n    76в†’    const expiresAt = getAccessExpiresAt();\n    77в†’    if (!expiresAt) return;\n    78в†’\n    79в†’    const msUntilExpiry = new Date(expiresAt).getTime() - Date.now();\n    80в†’    // Refresh 5 minutes before expiry, or immediately if < 5 min remaining\n    81в†’    const refreshIn = Math.max(msUntilExpiry - 5 * 60 * 1000, 0);\n    82в†’\n    83в†’    refreshTimerRef.current = window.setTimeout(() => {\n    84в†’      refreshTimerRef.current = null;\n    85в†’      void tryRefresh();\n    86в†’    }, refreshIn);\n    87в†’  }, []); // eslint-disable-line react-hooks/exhaustive-deps\n    88в†’\n    89в†’  const tryRefresh = useCallback(async (): Promise<boolean> => {\n    90в†’    // Mutex: if a refresh is already in-flight, await the same promise\n    91в†’    if (refreshPromiseRef.current) {\n    92в†’      return refreshPromiseRef.current;\n    93в†’    }\n    94в†’\n    95в†’    const session = getPersistedSession();\n    96в†’    if (!session) return false;\n    97в†’\n    98в†’    const promise = (async () => {\n    99в†’      try {\n   100в†’        const result = await refreshSession(session.refreshToken);\n   101в†’        setAccessToken(result.accessToken, result.accessExpiresAt);\n   102в†’        setPersistedSession({\n   103в†’          wallet: session.wallet,\n   104в†’          cluster: session.cluster,\n   105в†’          refreshToken: result.refreshToken,\n   106в†’          refreshExpiresAt: result.refreshExpiresAt,\n   107в†’        });\n   108в†’        setIsAuthenticated(true);\n   109в†’        scheduleRefresh();\n   110в†’        return true;\n   111в†’      } catch {\n   112в†’        // Refresh failed вЂ” clear session\n   113в†’        clearPersistedSession();\n   114в†’        setIsAuthenticated(false);\n   115в†’        return false;\n   116в†’      } finally {\n   117в†’        refreshPromiseRef.current = null;\n   118в†’      }\n   119в†’    })();\n   120в†’\n   121в†’    refreshPromiseRef.current = promise;\n   122в†’    return promise;\n   123в†’  }, [scheduleRefresh]);\n   124в†’\n   125в†’  const authenticate = useCallback(async () => {\n   126в†’    if (!connected || !publicKey || !signMessage) {\n   127в†’      throw new Error(\"Wallet not connected or does not support message signing\");\n   128в†’    }\n   129в†’\n   130в†’    setIsAuthenticating(true);\n   131в†’    try {\n   132в†’      const wallet = publicKey.toBase58();\n   133в†’\n   134в†’      // 1. Request challenge from backend\n   135в†’      const challenge = await requestChallenge(wallet);\n   136в†’\n   137в†’      // 2. Check challenge hasn't expired\n   138в†’      if (new Date(challenge.expiresAt).getTime() < Date.now()) {\n   139в†’        throw new Error(\"Challenge expired before signing\");\n   140в†’      }\n   141в†’\n   142в†’      // 3. Sign the human-readable message with wallet\n   143в†’      const messageBytes = new TextEncoder().encode(challenge.message);\n   144в†’      const signatureBytes = awai