{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J6S4ZK88Z9CxDoyTu3bCgE","type":"tool_result","content":"     1в†’/**\n     2в†’ * Shared E2E page-object helpers for coinflip tests.\n     3в†’ *\n     4в†’ * CSS-class-based selectors matching the actual component markup.\n     5в†’ * Provides create, join, claim, cancel actions and reusable wait/assert primitives.\n     6в†’ */\n     7в†’import { type Page, type Locator, expect } from \"@playwright/test\";\n     8в†’\n     9в†’// ---------------------------------------------------------------------------\n    10в†’// Selectors (CSS classes from CoinflipPage, ActiveMatchView, OpenMatchesList)\n    11в†’// ---------------------------------------------------------------------------\n    12в†’\n    13в†’export const sel = {\n    14в†’  // Page structure\n    15в†’  lobby: \".coinflip-lobby\",\n    16в†’  sidebar: \".coinflip-sidebar\",\n    17в†’  main: \".coinflip-main\",\n    18в†’\n    19в†’  // Sidebar вЂ” create flow\n    20в†’  sidebarTitle: \".coinflip-sidebar__title\",\n    21в†’  tierSelector: \".rng-tier-selector\",\n    22в†’  tierButton: (tier: string) => `.rng-tier-btn:has(.rng-tier-gem--${tier})`,\n    23в†’  tierButtonSelected: \".rng-tier-btn--selected\",\n    24в†’  sideSelector: \".coinflip-side-selector\",\n    25в†’  sideButtonHeads: \".coinflip-side-btn--heads\",\n    26в†’  sideButtonTails: \".coinflip-side-btn--tails\",\n    27в†’  sideButtonSelected: \".coinflip-side-btn--selected\",\n    28в†’  summary: \".coinflip-sidebar__summary\",\n    29в†’  actionButton: \".coinflip-action-btn\",\n    30в†’  actionButtonSecondary: \".coinflip-action-btn--secondary\",\n    31в†’\n    32в†’  // Lobby вЂ” open matches\n    33в†’  matchesList: \".coinflip-matches__list\",\n    34в†’  matchesCount: \".coinflip-matches__count\",\n    35в†’  matchCard: \".coinflip-match-card\",\n    36в†’  matchCardOwn: \".coinflip-match-card--own\",\n    37в†’  matchCardClaimable: \".coinflip-match-card--claimable\",\n    38в†’  matchCardJoinBtn: \".coinflip-match-card__join-btn\",\n    39в†’  matchCardAmount: \".coinflip-match-card__amount\",\n    40в†’  matchCardAddress: \".coinflip-match-card__address\",\n    41в†’\n    42в†’  // Active match view\n    43в†’  activeMatch: \".coinflip-active-match\",\n    44в†’  activeMatchTitle: \".coinflip-active-match__title\",\n    45в†’  activeMatchTitleWon: \".coinflip-active-match__title--won\",\n    46в†’  activeMatchTitleLost: \".coinflip-active-match__title--lost\",\n    47в†’  activeMatchWaiting: \".coinflip-active-match__waiting\",\n    48в†’  activeMatchPlaying: \".coinflip-active-match__playing\",\n    49в†’\n    50в†’  // Result\n    51в†’  resultOutcome: \".coinflip-result__outcome\",\n    52в†’  resultPayout: \".coinflip-result__payout\",\n    53в†’\n    54в†’  // Post-claim\n    55в†’  postClaim: \".coinflip-active-match__post-claim\",\n    56в†’\n    57в†’  // Error\n    58в†’  errorToast: \".rng-toast--error\",\n    59в†’  toastMessage: \".rng-toast__message\",\n    60в†’\n    61в†’  // Sidebar вЂ” active match info\n    62в†’  sidebarStatus: \".coinflip-sidebar__status\",\n    63в†’  sidebarPot: \".coinflip-sidebar__pot\",\n    64в†’} as const;\n    65в†’\n    66в†’// ---------------------------------------------------------------------------\n    67в†’// Types\n    68в†’// ---------------------------------------------------------------------------\n    69в†’\n    70в†’export type CoinSide = \"heads\" | \"tails\";\n    71в†’\n    72в†’// ---------------------------------------------------------------------------\n    73в†’// Page-object actions\n    74в†’// ---------------------------------------------------------------------------\n    75в†’\n    76в†’/**\n    77в†’ * Navigate to the coinflip page and wait for the lobby to render.\n    78в†’ */\n    79в†’export async function navigateToCoinflip(page: Page): Promise<void> {\n    80в†’  await page.goto(\"/coinflip\", { waitUntil: \"domcontentloaded\" });\n    81в†’  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 15_000 });\n    82в†’}\n    83в†’\n    84в†’/**\n    85в†’ * Enter a wager amount in SOL into the WagerInput.\n    86в†’ */\n    87в†’export async function enterWager(page: Page, amountSol: number): Promise<void> {\n    88в†’  const input = page.locator(\".rng-wager-input__input\").first();\n    89в†’  await expect(input).toBeVisible({ timeout: 15_000 });\n    90в†’  await input.fill(amountSol.toString());\n    91в†’}\n    92в†’\n    93в†’/**\n    94в†’ * @deprecated Use enterWager instead.\n    95в†’ * Legacy tier selection вЂ” clicks a preset amount button that matches the old tier amount.\n    96в†’ */\n    97в†’export async function selectTier(page: Page, _tier: string): Promise<void> {\n    98в†’  // After tierв†’amount migration, select the 0.005 SOL preset (matches old \"iron\" tier)\n    99в†’  await enterWager(page, 0.005);\n   100в†’}\n   101в†’\n   102в†’/**\n   103в†’ * Select a coin side (heads or tails) in the sidebar.\n   104в†’ */\n   105в†’export async function selectSide(page: Page, side: CoinSide): Promise<void> {\n   106в†’  const selector =\n   107в†’    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n   108в†’  await page.click(selector);\n   109в†’  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n   110в†’}\n   111в†’\n   112в†’/**\n   113в†’ * Create a match: enter wager amount, select side, click \"Create Game\".\n   114в†’ * Returns when the active match view (waiting state) is visible.\n   115в†’ */\n   116в†’export async function createMatch(\n   117в†’  page: Page,\n   118в†’  amountOrTier: number | string,\n   119в†’  side: CoinSide,\n   120в†’  options?: { timeout?: number },\n   121в†’): Promise<void> {\n   122в†’  // Support both new amount (number) and legacy tier name (string)\n   123в†’  const amount = typeof amountOrTier === \"number\" ? amountOrTier : 0.005;\n   124в†’  await enterWager(page, amount);\n   125в†’  await selectSide(page, side);\n   126в†’\n   127в†’  // Click create вЂ” button text is \"Create Game\"\n   128в†’  const createBtn = page.locator(sel.actionButton, {\n   129в†’    hasText: \"Create Game\",\n   130в†’  });\n   131в†’  await expect(createBtn).toBeEnabled();\n   132в†’  await createBtn.click();\n   133в†’\n   134в†’  // Wait for transition to active match (waiting for opponent).\n   135в†’  // Default 15s is fine for local; devnet callers should pass a longer timeout.\n   136в†’  await page.waitForSelector(sel.activeMatch, {\n   137в†’    state: \"visible\",\n   138в†’    timeout: options?.timeout ?? 15_000,\n   139в†’  });\n   140в†’}\n   141в†’\n   142в†’/**\n   143в†’ * Join a match visible in the lobby. If `matchIndex` is provided, join that\n   144в†’ * specific card (0-based). Otherwise joins the first joinable match.\n   145в†’ */\n   146в†’export async function joinMatch(\n   147в†’  page: Page,\n   148в†’  matchIndex = 0,\n   149в†’): Promise<void> {\n   150в†’  const cards = page.locator(\n   151в†’    `${sel.matchCard}:not(${sel.matchCardOwn}):not(${sel.matchCardClaimable})`,\n   152в†’  );\n   153в†’  const joinBtn = cards.nth(matchIndex).locator(sel.matchCardJoinBtn);\n   154в†’  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n   155в†’  await joinBtn.click();\n   156в†’\n   157в†’  // Wait for active match view to appear\n   158в†’  await page.waitForSelector(sel.activeMatch, {\n   159в†’    state: \"visible\",\n   160в†’    timeout: 15_000,\n   161в†’  });\n   162в†’}\n   163в†’\n   164в†’/**\n   165в†’ * Join a specific match by exact match PDA id.\n   166в†’ */\n   167в†’export async function joinMatchById(\n   168в†’  page: Page,\n   169в†’  matchId: string,\n   170в†’): Promise<void> {\n   171в†’  const card = page.locator(`[data-match-id=\"${matchId}\"]`).first();\n   172в†’  await expect(card).toBeVisible({ timeout: 15_000 });\n   173в†’  const joinBtn = card.locator(sel.matchCardJoinBtn);\n   174в†’  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n   175в†’  await joinBtn.click();\n   176в†’\n   177в†’  await page.waitForSelector(sel.activeMatch, {\n   178в†’    state: \"visible\",\n   179в†’    timeout: 15_000,\n   180в†’  });\n   181в†’}\n   182в†’\n   183в†’/**\n   184в†’ * Cancel the currently active match (phase = \"created\", waiting for opponent).\n   185в†’ * Clicks \"Cancel Match\" button in the ActiveMatchView.\n   186в†’ */\n   187в†’export async function cancelMatch(page: Page): Promise<void> {\n   188в†’  const cancelBtn = page.locator(\"button\", { hasText: \"Cancel Match\" });\n   189в†’  await expect(cancelBtn).toBeVisible({ timeout: 5_000 });\n   190в†’  await cancelBtn.click();\n   191в†’\n   192в†’  // Wait for lobby to reappear\n   193в†’  await page.waitForSelector(sel.lobby, {\n   194в†’    state: \"visible\",\n   195в†’    timeout: 15_000,\n   196в†’  });\n   197в†’}\n   198в†’\n   199в†’/**\n   200в†’ * Claim payout for the winner, or settle for the loser.\n   201в†’ * Clicks the \"Claim Payout\" or \"Settle & Return\" button in the sidebar.\n   202в†’ */\n   203в†’export async function claimOrSettle(page: Page): Promise<void> {\n   204в†’  // The claim/settle button is inside ActiveMatchView (not the sidebar)\n   205в†’  const claimBtn = page.locator(sel.activeMatch).locator(sel.actionButton).first();\n   206в†’  await expect(claimBtn).toBeEnabled({ timeout: 15_000 });\n   207в†’  await claimBtn.click();\n   208в†’\n   209в†’  // Wait for post-claim section to confirm claim completed\n   210в†’  await expect(\n   211в†’    page.locator(sel.postClaim),\n   212в†’  ).toBeVisible({ timeout: 15_000 });\n   213в†’}\n   214в†’\n   215в†’/**\n   216в†’ * Click \"Back to Lobby\" to return after claiming.\n   217в†’ */\n   218в†’export async function backToLobby(page: Page): Promise<void> {\n   219в†’  // \"Back to Lobby\" may appear in sidebar or post-claim area\n   220в†’  const btn = page.locator(\"button\", { hasText: \"Back to Lobby\" }).first();\n   221в†’  await expect(btn).toBeVisible();\n   222в†’  await btn.click();\n   223в†’  await page.waitForSelector(sel.lobby, {\n   224в†’    state: \"visible\",\n   225в†’    timeout: 10_000,\n   226в†’  });\n   227в†’}\n   228в†’\n   229в†’// ---------------------------------------------------------------------------\n   230в†’// Wait / assert primitives\n   231в†’// ---------------------------------------------------------------------------\n   232в†’\n   233в†’/**\n   234в†’ * Wait until the sidebar status text matches the expected phase label.\n   235в†’ * Phase labels: \"Waiting...\", \"Ready!\", \"Countdown...\", \"Flipping...\", \"Complete\"\n   236в†’ */\n   237в†’export async function waitForPhaseLabel(\n   238в†’  page: Page,\n   239в†’  label: string,\n   240в†’  timeout = 30_000,\n   241в†’): Promise<void> {\n   242в†’  await expect(page.locator(sel.sidebarStatus)).toHaveText(label, {\n   243в†’    timeout,\n   244в†’  });\n   245в†’}\n   246в†’\n   247в†’/**\n   248в†’ * Wait for the active match title to indicate a win or loss.\n   249в†’ */\n   250в†’export async function waitForResult(\n   251в†’  page: Page,\n   252в†’  timeout = 30_000,\n   253в†’): Promise<\"won\" | \"lost\"> {\n   254в†’  // Wait for either won or lost title class to appear\n   255в†’  const wonLocator = page.locator(sel.activeMatchTitleWon);\n   256в†’  const lostLocator = page.locator(sel.activeMatchTitleLost);\n   257в†’\n   258в†’  await expect(wonLocator.or(lostLocator)).toBeVisible({ timeout });\n   259в†’\n   260в†’  if (await wonLocator.isVisible()) return \"won\";\n   261в†’  return \"lost\";\n   262в†’}\n   263в†’\n   264в†’/**\n   265в†’ * Wait until the match either shows a visible result title or has already\n   266в†’ * returned the player to the lobby after settlement.\n   267в†’ */\n   268в†’export async function waitForResultOrLobby(\n   269в†’  page: Page,\n   270в†’  timeout = 30_000,\n   271в†’): Promise<\"won\" | \"lost\" | null> {\n   272в†’  const wonLocator = page.locator(sel.activeMatchTitleWon);\n   273в†’  const lostLocator = page.locator(sel.activeMatchTitleLost);\n   274в†’  const lobbyLocator = page.locator(sel.lobby);\n   275в†’  const backToLobbyBtn = page.locator(\"button\", { hasText: \"Back to Lobby\" });\n   276в†’\n   277в†’  await expect\n   278в†’    .poll(\n   279в†’      async () => {\n   280в†’        const checks = await Promise.all([\n   281в†’          wonLocator.count(),\n   282в†’          lostLocator.count(),\n   283в†’          lobbyLocator.count(),\n   284в†’          backToLobbyBtn.count(),\n   285в†’        ]);\n   286в†’        return checks.some((count) => count > 0);\n   287в†’      },\n   288в†’      { timeout },\n   289в†’    )\n   290в†’    .toBe(true);\n   291в†’\n   292в†’  if (await wonLocator.isVisible()) return \"won\";\n   293в†’  if (await lostLocator.isVisible()) return \"lost\";\n   294в†’  return null;\n   295в†’}\n   296в†’\n   297в†’/**\n   298в†’ * Wait for a match to appear in the lobby's open match list.\n   299в†’ */\n   300в†’export async function waitForLobbyMatch(\n   301в†’  page: Page,\n   302в†’  timeout = 15_000,\n   303в†’): Promise<Locator> {\n   304в†’  const card = page.locator(\n   305в†’    `${sel.matchCard}:not(${sel.matchCardClaimable})`,\n   306в†’  ).first();\n   307в†’  await expect(card).toBeVisible({ timeout });\n   308в†’  return card;\n   309в†’}\n   310в†’\n   311в†’/**\n   312в†’ * Assert the lobby is empty (no open matches).\n   313в†’ */\n   314в†’export async function assertLobbyEmpty(\n   315в†’  page: Page,\n   316в†’  timeout = 10_000,\n   317в†’): Promise<void> {\n   318в†’  // Either the empty state text or zero non-claimable match cards\n   319в†’  await expect(\n   320в†’    page.locator(`${sel.matchCard}:not(${sel.matchCardClaimable})`),\n   321в†’  ).toHaveCount(0, { timeout });\n   322в†’}\n   323в†’\n   324в†’/**\n   325в†’ * Assert that an error toast is visible with the given message substring.\n   326в†’ */\n   327в†’export async function assertErrorToast(\n   328в†’  page: Page,\n   329в†’  messageSubstring: string,\n   330в†’  timeout = 5_000,\n   331в†’): Promise<void> {\n   332в†’  const toast = page.locator(sel.errorToast);\n   333в†’  await expect(toast).toBeVisible({ timeout });\n   334в†’  await expect(toast).toContainText(messageSubstring);\n   335в†’}\n   336в†’\n   337в†’/**\n   338в†’ * Assert that no error toasts are visible.\n   339в†’ */\n   340в†’export async function assertNoErrorToast(page: Page): Promise<void> {\n   341в†’  await expect(page.locator(sel.errorToast)).toHaveCount(0);\n   342в†’}\n   343в†’\n   344в†’/**\n   345в†’ * Get the current balance displayed or fetched from connection for a wallet.\n   346в†’ * This is a convenience wrapper for reading SOL balance via RPC, not UI-based.\n   347в†’ */\n   348в†’export async function getSolBalance(\n   349в†’  page: Page,\n   350в†’  walletAddress: string,\n   351в†’  rpcUrl = \"http://127.0.0.1:8899\",\n   352в†’): Promise<number> {\n   353в†’  return page.evaluate(\n   354в†’    async ({ address, rpc }) => {\n   355в†’      const res = await fetch(rpc, {\n   356в†’        method: \"POST\",\n   357в†’        headers: { \"Content-Type\": \"application/json\" },\n   358в†’        body: JSON.stringify({\n   359в†’          jsonrpc: \"2.0\",\n   360в†’          id: 1,\n   361в†’          method: \"getBalance\",\n   362в†’          params: [address, { commitment: \"confirmed\" }],\n   363в†’        }),\n   364в†’      });\n   365в†’      const json = await res.json();\n   366в†’      return (json.result?.value ?? 0) / 1_000_000_000;\n   367в†’    },\n   368в†’    { address: walletAddress, rpc: rpcUrl },\n   369в†’  );\n   370в†’}\n   371в†’\n   372в†’/**\n   373в†’ * Collect console errors from a page. Returns a cleanup function\n   374в†’ * and an array that accumulates errors.\n   375в†’ */\n   376в†’export function trackConsoleErrors(page: Page): {\n   377в†’  errors: string[];\n   378в†’  assertClean: () => void;\n   379в†’} {\n   380в†’  const errors: string[] = [];\n   381в†’  page.on(\"console\", (msg) => {\n   382в†’    if (msg.type() === \"error\") errors.push(msg.text());\n   383в†’  });\n   384в†’  return {\n   385в†’    errors,\n   386в†’    assertClean: () => {\n   387в†’      // Filter out known non-critical browser noise\n   388в†’      const real = errors.filter(\n   389в†’        (e) =>\n   390в†’          !e.includes(\"favicon.ico\") &&\n   391в†’          !e.includes(\"downloadable font\") &&\n   392в†’          !e.includes(\"third-party cookie\"),\n   393в†’      );\n   394в†’      expect(real).toEqual([]);\n   395в†’    },\n   396в†’  };\n   397в†’}\n   398в†’\n   399в†’/**\n   400в†’ * Wait for a specific text to appear anywhere on the page.\n   401в†’ */\n   402в†’export async function waitForText(\n   403в†’  page: Page,\n   404в†’  text: string,\n   405в†’  timeout = 10_000,\n   406в†’): Promise<void> {\n   407в†’  await expect(page.getByText(text).first()).toBeVisible({ timeout });\n   408в†’}\n   409в†’\n   410в†’/**\n   411в†’ * Wait for the lobby to be visible (no active match).\n   412в†’ */\n   413в†’export async function waitForLobby(\n   414в†’  page: Page,\n   415в†’  timeout = 15_000,\n   416в†’): Promise<void> {\n   417в†’  await page.waitForSelector(sel.lobby, {\n   418в†’    state: \"visible\",\n   419в†’    timeout,\n   420в†’  });\n   421в†’}\n   422в†’"}]},"parent_tool_use_id":null,"session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"2802df39-7e5a-4d36-b07c-b2047276c51b","timestamp":"2026-03-19T19:17:15.124Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/page-objects.ts","content":"/**\n * Shared E2E page-object helpers for coinflip tests.\n *\n * CSS-class-based selectors matching the actual component markup.\n * Provides create, join, claim, cancel actions and reusable wait/assert primitives.\n */\nimport { type Page, type Locator, expect } from \"@playwright/test\";\n\n// ---------------------------------------------------------------------------\n// Selectors (CSS classes from CoinflipPage, ActiveMatchView, OpenMatchesList)\n// ---------------------------------------------------------------------------\n\nexport const sel = {\n  // Page structure\n  lobby: \".coinflip-lobby\",\n  sidebar: \".coinflip-sidebar\",\n  main: \".coinflip-main\",\n\n  // Sidebar вЂ” create flow\n  sidebarTitle: \".coinflip-sidebar__title\",\n  tierSelector: \".rng-tier-selector\",\n  tierButton: (tier: string) => `.rng-tier-btn:has(.rng-tier-gem--${tier})`,\n  tierButtonSelected: \".rng-tier-btn--selected\",\n  sideSelector: \".coinflip-side-selector\",\n  sideButtonHeads: \".coinflip-side-btn--heads\",\n  sideButtonTails: \".coinflip-side-btn--tails\",\n  sideButtonSelected: \".coinflip-side-btn--selected\",\n  summary: \".coinflip-sidebar__summary\",\n  actionButton: \".coinflip-action-btn\",\n  actionButtonSecondary: \".coinflip-action-btn--secondary\",\n\n  // Lobby вЂ” open matches\n  matchesList: \".coinflip-matches__list\",\n  matchesCount: \".coinflip-matches__count\",\n  matchCard: \".coinflip-match-card\",\n  matchCardOwn: \".coinflip-match-card--own\",\n  matchCardClaimable: \".coinflip-match-card--claimable\",\n  matchCardJoinBtn: \".coinflip-match-card__join-btn\",\n  matchCardAmount: \".coinflip-match-card__amount\",\n  matchCardAddress: \".coinflip-match-card__address\",\n\n  // Active match view\n  activeMatch: \".coinflip-active-match\",\n  activeMatchTitle: \".coinflip-active-match__title\",\n  activeMatchTitleWon: \".coinflip-active-match__title--won\",\n  activeMatchTitleLost: \".coinflip-active-match__title--lost\",\n  activeMatchWaiting: \".coinflip-active-match__waiting\",\n  activeMatchPlaying: \".coinflip-active-match__playing\",\n\n  // Result\n  resultOutcome: \".coinflip-result__outcome\",\n  resultPayout: \".coinflip-result__payout\",\n\n  // Post-claim\n  postClaim: \".coinflip-active-match__post-claim\",\n\n  // Error\n  errorToast: \".rng-toast--error\",\n  toastMessage: \".rng-toast__message\",\n\n  // Sidebar вЂ” active match info\n  sidebarStatus: \".coinflip-sidebar__status\",\n  sidebarPot: \".coinflip-sidebar__pot\",\n} as const;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type CoinSide = \"heads\" | \"tails\";\n\n// ---------------------------------------------------------------------------\n// Page-object actions\n// ---------------------------------------------------------------------------\n\n/**\n * Navigate to the coinflip page and wait for the lobby to render.\n */\nexport async function navigateToCoinflip(page: Page): Promise<void> {\n  await page.goto(\"/coinflip\", { waitUntil: \"domcontentloaded\" });\n  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 15_000 });\n}\n\n/**\n * Enter a wager amount in SOL into the WagerInput.\n */\nexport async function enterWager(page: Page, amountSol: number): Promise<void> {\n  const input = page.locator(\".rng-wager-input__input\").first();\n  await expect(input).toBeVisible({ timeout: 15_000 });\n  await input.fill(amountSol.toString());\n}\n\n/**\n * @deprecated Use enterWager instead.\n * Legacy tier selection вЂ” clicks a preset amount button that matches the old tier amount.\n */\nexport async function selectTier(page: Page, _tier: string): Promise<void> {\n  // After tierв†’amount migration, select the 0.005 SOL preset (matches old \"iron\" tier)\n  await enterWager(page, 0.005);\n}\n\n/**\n * Select a coin side (heads or tails) in the sidebar.\n */\nexport async function selectSide(page: Page, side: CoinSide): Promise<void> {\n  const selector =\n    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n  await page.click(selector);\n  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n}\n\n/**\n * Create a match: enter wager amount, select side, click \"Create Game\".\n * Returns when the active match view (waiting state) is visible.\n */\nexport async function createMatch(\n  page: Page,\n  amountOrTier: number | string,\n  side: CoinSide,\n  options?: { timeout?: number },\n): Promise<void> {\n  // Support both new amount (number) and legacy tier name (string)\n  const amount = typeof amountOrTier === \"number\" ? amountOrTier : 0.005;\n  await enterWager(page, amount);\n  await selectSide(page, side);\n\n  // Click create вЂ” button text is \"Create Game\"\n  const createBtn = page.locator(sel.actionButton, {\n    hasText: \"Create Game\",\n  });\n  await expect(createBtn).toBeEnabled();\n  await createBtn.click();\n\n  // Wait for transition to active match (waiting for opponent).\n  // Default 15s is fine for local; devnet callers should pass a longer timeout.\n  await page.waitForSelector(sel.activeMatch, {\n    state: \"visible\",\n    timeout: options?.timeout ?? 15_000,\n  });\n}\n\n/**\n * Join a match visible in the lobby. If `matchIndex` is provided, join that\n * specific card (0-based). Otherwise joins the first joinable match.\n */\nexport async function joinMatch(\n  page: Page,\n  matchIndex = 0,\n): Promise<void> {\n  const cards = page.locator(\n    `${sel.matchCard}:not(${sel.matchCardOwn}):not(${sel.matchCardClaimable})`,\n  );\n  const joinBtn = cards.nth(matchIndex).locator(sel.matchCardJoinBtn);\n  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n  await joinBtn.click();\n\n  // Wait for active match view to appear\n  await page.waitForSelector(sel.activeMatch, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Join a specific match by exact match PDA id.\n */\nexport async function joinMatchById(\n  page: Page,\n  matchId: string,\n): Promise<void> {\n  const card = page.locator(`[data-match-id=\"${matchId}\"]`).first();\n  await expect(card).toBeVisible({ timeout: 15_000 });\n  const joinBtn = card.locator(sel.matchCardJoinBtn);\n  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n  await joinBtn.click();\n\n  await page.waitForSelector(sel.activeMatch, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Cancel the currently active match (phase = \"created\", waiting for opponent).\n * Clicks \"Cancel Match\" button in the ActiveMatchView.\n */\nexport async function cancelMatch(page: Page): Promise<void> {\n  const cancelBtn = page.locator(\"button\", { hasText: \"Cancel Match\" });\n  await expect(cancelBtn).toBeVisible({ timeout: 5_000 });\n  await cancelBtn.click();\n\n  // Wait for lobby to reappear\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Claim payout for the winner, or settle for the loser.\n * Clicks the \"Claim Payout\" or \"Settle & Return\" button in the sidebar.\n */\nexport async function claimOrSettle(page: Page): Promise<void> {\n  // The claim/settle button is inside ActiveMatchView (not the sidebar)\n  const claimBtn = page.locator(sel.activeMatch).locator(sel.actionButton).first();\n  await expect(claimBtn).toBeEnabled({ timeout: 15_000 });\n  await claimBtn.click();\n\n  // Wait for post-claim section to confirm claim completed\n  await expect(\n    page.locator(sel.postClaim),\n  ).toBeVisible({ timeout: 15_000 });\n}\n\n/**\n * Click \"Back to Lobby\" to return after claiming.\n */\nexport async function backToLobby(page: Page): Promise<void> {\n  // \"Back to Lobby\" may appear in sidebar or post-claim area\n  const btn = page.locator(\"button\", { hasText: \"Back to Lobby\" }).first();\n  await expect(btn).toBeVisible();\n  await btn.click();\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout: 10_000,\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Wait / assert primitives\n// ---------------------------------------------------------------------------\n\n/**\n * Wait until the sidebar status text matches the expected phase label.\n * Phase labels: \"Waiting...\", \"Ready!\", \"Countdown...\", \"Flipping...\", \"Complete\"\n */\nexport async function waitForPhaseLabel(\n  page: Page,\n  label: string,\n  timeout = 30_000,\n): Promise<void> {\n  await expect(page.locator(sel.sidebarStatus)).toHaveText(label, {\n    timeout,\n  });\n}\n\n/**\n * Wait for the active match title to indicate a win or loss.\n */\nexport async function waitForResult(\n  page: Page,\n  timeout = 30_000,\n): Promise<\"won\" | \"lost\"> {\n  // Wait for either won or lost title class to appear\n  const wonLocator = page.locator(sel.activeMatchTitleWon);\n  const lostLocator = page.locator(sel.activeMatchTitleLost);\n\n  await expect(wonLocator.or(lostLocator)).toBeVisible({ timeout });\n\n  if (await wonLocator.isVisible()) return \"won\";\n  return \"lost\";\n}\n\n/**\n * Wait until the match either shows a visible result title or has already\n * returned the player to the lobby after settlement.\n */\nexport async function waitForResultOrLobby(\n  page: Page,\n  timeout = 30_000,\n): Promise<\"won\" | \"lost\" | null> {\n  const wonLocator = page.locator(sel.activeMatchTitleWon);\n  const lostLocator = page.locator(sel.activeMatchTitleLost);\n  const lobbyLocator = page.locator(sel.lobby);\n  const backToLobbyBtn = page.locator(\"button\", { hasText: \"Back to Lobby\" });\n\n  await expect\n    .poll(\n      async () => {\n        const checks = await Promise.all([\n          wonLocator.count(),\n          lostLocator.count(),\n          lobbyLocator.count(),\n          backToLobbyBtn.count(),\n        ]);\n        return checks.some((count) => count > 0);\n      },\n      { timeout },\n    )\n    .toBe(true);\n\n  if (await wonLocator.isVisible()) return \"won\";\n  if (await lostLocator.isVisible()) return \"lost\";\n  return null;\n}\n\n/**\n * Wait for a match to appear in the lobby's open match list.\n */\nexport async function waitForLobbyMatch(\n  page: Page,\n  timeout = 15_000,\n): Promise<Locator> {\n  const card = page.locator(\n    `${sel.matchCard}:not(${sel.matchCardClaimable})`,\n  ).first();\n  await expect(card).toBeVisible({ timeout });\n  return card;\n}\n\n/**\n * Assert the lobby is empty (no open matches).\n */\nexport async function assertLobbyEmpty(\n  page: Page,\n  timeout = 10_000,\n): Promise<void> {\n  // Either the empty state text or zero non-claimable match cards\n  await expect(\n    page.locator(`${sel.matchCard}:not(${sel.matchCardClaimable})`),\n  ).toHaveCount(0, { timeout });\n}\n\n/**\n * Assert that an error toast is visible with the given message substring.\n */\nexport async function assertErrorToast(\n  page: Page,\n  messageSubstring: string,\n  timeout = 5_000,\n): Promise<void> {\n  const toast = page.locator(sel.errorToast);\n  await expect(toast).toBeVisible({ timeout });\n  await expect(toast).toContainText(messageSubstring);\n}\n\n/**\n * Assert that no error toasts are visible.\n */\nexport async function assertNoErrorToast(page: Page): Promise<void> {\n  await expect(page.locator(sel.errorToast)).toHaveCount(0);\n}\n\n/**\n * Get the current balance displayed or fetched from connection for a wallet.\n * This is a convenience wrapper for reading SOL balance via RPC, not UI-based.\n */\nexport async function getSolBalance(\n  page: Page,\n  walletAddress: string,\n  rpcUrl = \"http://127.0.0.1:8899\",\n): Promise<number> {\n  return page.evaluate(\n    async ({ address, rpc }) => {\n      const res = await fetch(rpc, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          jsonrpc: \"2.0\",\n          id: 1,\n          method: \"getBalance\",\n          params: [address, { commitment: \"confirmed\" }],\n        }),\n      });\n      const json = await res.json();\n      return (json.result?.value ?? 0) / 1_000_000_000;\n    },\n    { address: walletAddress, rpc: rpcUrl },\n  );\n}\n\n/**\n * Collect console errors from a page. Returns a cleanup function\n * and an array that accumulates errors.\n */\nexport function trackConsoleErrors(page: Page): {\n  errors: string[];\n  assertClean: () => void;\n} {\n  const errors: string[] = [];\n  page.on(\"console\", (msg) => {\n    if (msg.type() === \"error\") errors.push(msg.text());\n  });\n  return {\n    errors,\n    assertClean: () => {\n      // Filter out known non-critical browser noise\n      const real = errors.filter(\n        (e) =>\n          !e.includes(\"favicon.ico\") &&\n          !e.includes(\"downloadable font\") &&\n          !e.includes(\"third-party cookie\"),\n      );\n      expect(real).toEqual([]);\n    },\n  };\n}\n\n/**\n * Wait for a specific text to appear anywhere on the page.\n */\nexport async function waitForText(\n  page: Page,\n  text: string,\n  timeout = 10_000,\n): Promise<void> {\n  await expect(page.getByText(text).first()).toBeVisible({ timeout });\n}\n\n/**\n * Wait for the lobby to be visible (no active match).\n */\nexport async function waitForLobby(\n  page: Page,\n  timeout = 15_000,\n): Promise<void> {\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout,\n  });\n}\n","numLines":422,"startLine":1,"totalLines":422}}}
