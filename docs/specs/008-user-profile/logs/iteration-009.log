{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EzraGjQYGC6D9uqMx28HRf","type":"tool_result","content":"     1в†’/**\n     2в†’ * Local error-flow E2E tests: insufficient balance, join unavailable match,\n     3в†’ * settle already-claimed match.\n     4в†’ *\n     5в†’ * Tests run serially because later tests depend on chain state left by earlier\n     6в†’ * ones (e.g. additional airdrop in test 2).\n     7в†’ *\n     8в†’ * Prerequisites (handled by localnet-bootstrap.sh):\n     9в†’ * - solana-test-validator running with coinflip + platform programs\n    10в†’ * - Orao mock accounts pre-loaded (required for lifecycle in test 3)\n    11в†’ */\n    12в†’import { Connection } from \"@solana/web3.js\";\n    13в†’import { test, expect } from \"./fixtures\";\n    14в†’import * as po from \"./helpers/page-objects\";\n    15в†’import {\n    16в†’  fundWallet,\n    17в†’  PLAYER_A,\n    18в†’  PLAYER_B,\n    19в†’  LOCAL_RPC_URL,\n    20в†’} from \"./helpers/wallets\";\n    21в†’import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    22в†’import { assertMatchClosed, assertMatchCreated, getCoinflipProgram } from \"./helpers/on-chain\";\n    23в†’\n    24в†’// в”Ђв”Ђ Serial execution: skip remaining tests if one fails в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n    25в†’\n    26в†’test.describe(\"Error flow tests\", () => {\n    27в†’  test.describe.configure({ mode: \"serial\" });\n    28в†’\n    29в†’  test.beforeAll(async () => {\n    30в†’    await initializeLocalnet();\n    31в†’    const connection = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    32в†’    // Fund Player A with minimal SOL вЂ” insufficient for iron tier (0.005 SOL)\n    33в†’    await fundWallet(connection, PLAYER_A.publicKey, 0.001);\n    34в†’    // Fund Player B with standard amount\n    35в†’    await fundWallet(connection, PLAYER_B.publicKey, 10);\n    36в†’  });\n    37в†’\n    38в†’  // в”Ђв”Ђ Test 1: Insufficient balance в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n    39в†’\n    40в†’test(\"insufficient balance: creating match is rejected\", async ({\n    41в†’    playerAPage,\n    42в†’    connection,\n    43в†’  }) => {\n    44в†’    await po.navigateToCoinflip(playerAPage);\n    45в†’    await po.selectTier(playerAPage, \"iron\");\n    46в†’    await po.selectSide(playerAPage, \"heads\");\n    47в†’\n    48в†’    // Click \"Create Game\" вЂ” balance (0.001 SOL) < iron entry (0.005 SOL)\n    49в†’    const createBtn = playerAPage.locator(po.sel.actionButton, {\n    50в†’      hasText: \"Create Game\",\n    51в†’    });\n    52в†’    await expect(createBtn).toBeEnabled();\n    53в†’    await createBtn.click();\n    54в†’\n    55в†’    // The current UI keeps the player in the create view when the tx is rejected.\n    56в†’    await expect(playerAPage.locator(po.sel.activeMatch)).toHaveCount(0);\n    57в†’    await expect(createBtn).toBeVisible();\n    58в†’\n    59в†’    // Verify no active match was created on-chain for the player.\n    60в†’    const program = getCoinflipProgram(connection);\n    61в†’    const matches = await program.account.coinflipMatch.all([\n    62в†’      { memcmp: { offset: 8, bytes: PLAYER_A.publicKey.toBase58() } },\n    63в†’      { dataSize: program.account.coinflipMatch.size },\n    64в†’    ]);\n    65в†’    expect(matches).toHaveLength(0);\n    66в†’  });\n    67в†’\n    68в†’  // в”Ђв”Ђ Test 2: Join unavailable (cancelled) match в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n    69в†’\n    70в†’  test(\"joining unavailable match keeps player in the lobby\", async ({\n    71в†’    playerAPage,\n    72в†’    playerBPage,\n    73в†’    connection,\n    74в†’  }) => {\n    75в†’    // Fund A properly for this test (previous test left A with 0.001 SOL)\n    76в†’    await fundWallet(connection, PLAYER_A.publicKey, 10);\n    77в†’\n    78в†’    // A creates a match (iron tier, heads)\n    79в†’    await po.navigateToCoinflip(playerAPage);\n    80в†’    await po.createMatch(playerAPage, \"iron\", \"heads\");\n    81в†’    const { matchPda } = await assertMatchCreated(connection, PLAYER_A.publicKey, 0);\n    82в†’\n    83в†’    // B navigates and sees the match in lobby\n    84в†’    await po.navigateToCoinflip(playerBPage);\n    85в†’    await po.waitForLobbyMatch(playerBPage, 15_000);\n    86в†’\n    87в†’    // A cancels the match вЂ” PDA closes on-chain\n    88в†’    await po.cancelMatch(playerAPage);\n    89в†’    await assertMatchClosed(connection, matchPda);\n    90в†’\n    91в†’    // B tries to join the stale lobby card (lobby hasn't re-polled yet)\n    92в†’    const joinBtn = playerBPage\n    93в†’      .locator(\n    94в†’        `${po.sel.matchCard}:not(${po.sel.matchCardOwn}):not(${po.sel.matchCardClaimable})`,\n    95в†’      )\n    96в†’      .first()\n    97в†’      .locator(po.sel.matchCardJoinBtn);\n    98в†’    await joinBtn.click();\n    99в†’\n   100в†’    // The stale join attempt should not transition B into an active match.\n   101в†’    await expect(playerBPage.locator(po.sel.activeMatch)).toHaveCount(0);\n   102в†’    await expect(playerBPage.locator(po.sel.lobby)).toBeVisible();\n   103в†’  });\n   104в†’\n   105в†’  // в”Ђв”Ђ Test 3: Settle already-claimed match в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n   106в†’\n   107в†’  test(\"settled match does not expose stale settle actions\", async ({\n   108в†’    playerAPage,\n   109в†’    playerBPage,\n   110в†’    connection,\n   111в†’  }) => {\n   112в†’    // A creates a match (iron tier, heads)\n   113в†’    await po.navigateToCoinflip(playerAPage);\n   114в†’    await po.createMatch(playerAPage, \"iron\", \"heads\");\n   115в†’    const { matchPda } = await assertMatchCreated(connection, PLAYER_A.publicKey, 0);\n   116в†’\n   117в†’    // B navigates and joins\n   118в†’    await po.navigateToCoinflip(playerBPage);\n   119в†’    await po.waitForLobbyMatch(playerBPage, 15_000);\n   120в†’    await po.joinMatch(playerBPage);\n   121в†’\n   122в†’    // Both wait for backend settlement and verify the outcomes are complementary.\n   123в†’    const [resultA, resultB] = await Promise.all([\n   124в†’      po.waitForResult(playerAPage, 30_000),\n   125в†’      po.waitForResult(playerBPage, 30_000),\n   126в†’    ]);\n   127в†’    expect(resultA).not.toBe(resultB);\n   128в†’\n   129в†’    await assertMatchClosed(connection, matchPda);\n   130в†’\n   131в†’    // Settled matches now auto-resolve; neither player should see stale claim/settle actions.\n   132в†’    await expect(\n   133в†’      playerAPage.locator(\"button\", { hasText: /Claim|Settle/i }),\n   134в†’    ).toHaveCount(0);\n   135в†’    await expect(\n   136в†’      playerBPage.locator(\"button\", { hasText: /Claim|Settle/i }),\n   137в†’    ).toHaveCount(0);\n   138в†’  });\n   139в†’});\n   140в†’"}]},"parent_tool_use_id":"toolu_01HeJfpFiA1rSVyi58U1gKAc","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"6272abff-2717-462f-b051-8653af06b92f","timestamp":"2026-03-19T19:13:00.193Z"}
