{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A8sV7JZWK4crB6Fv6acAk8","type":"tool_result","content":"     1в†’/**\n     2в†’ * Auth routes: challenge/verify/refresh/logout for JWT session management.\n     3в†’ */\n     4в†’\n     5в†’import { Hono } from \"hono\";\n     6в†’import { randomBytes, createHash } from \"node:crypto\";\n     7в†’import nacl from \"tweetnacl\";\n     8в†’import bs58 from \"bs58\";\n     9в†’import { SignJWT } from \"jose\";\n    10в†’import type { AuthDb } from \"../auth-db.js\";\n    11в†’import { logger } from \"../logger.js\";\n    12в†’\n    13в†’export interface AuthRoutesDeps {\n    14в†’  authDb: AuthDb;\n    15в†’  jwtSecret: Uint8Array;\n    16в†’  cluster: string;\n    17в†’  challengeTtlSeconds: number;\n    18в†’  accessTokenTtlSeconds: number;\n    19в†’  refreshTokenTtlDays: number;\n    20в†’}\n    21в†’\n    22в†’function hashToken(token: string): Buffer {\n    23в†’  return createHash(\"sha256\").update(token).digest();\n    24в†’}\n    25в†’\n    26в†’function buildSignInMessage(\n    27в†’  wallet: string,\n    28в†’  cluster: string,\n    29в†’  nonce: string,\n    30в†’  issuedAt: string,\n    31в†’  expiresAt: string,\n    32в†’): string {\n    33в†’  return [\n    34в†’    \"Sign in to RNG Utopia\",\n    35в†’    `Wallet: ${wallet}`,\n    36в†’    `Cluster: ${cluster}`,\n    37в†’    `Nonce: ${nonce}`,\n    38в†’    `Issued At: ${issuedAt}`,\n    39в†’    `Expires At: ${expiresAt}`,\n    40в†’    \"This signature creates a backend session for gameplay actions.\",\n    41в†’    \"It does not approve a blockchain transaction.\",\n    42в†’  ].join(\"\\n\");\n    43в†’}\n    44в†’\n    45в†’export function createAuthRoutes(deps: AuthRoutesDeps): Hono {\n    46в†’  const {\n    47в†’    authDb,\n    48в†’    jwtSecret,\n    49в†’    cluster,\n    50в†’    challengeTtlSeconds,\n    51в†’    accessTokenTtlSeconds,\n    52в†’    refreshTokenTtlDays,\n    53в†’  } = deps;\n    54в†’\n    55в†’  const app = new Hono();\n    56в†’\n    57в†’  // POST /challenge вЂ” generate nonce + human-readable message\n    58в†’  app.post(\"/challenge\", async (c) => {\n    59в†’    let body: { wallet: string };\n    60в†’    try {\n    61в†’      body = await c.req.json();\n    62в†’      if (typeof body.wallet !== \"string\" || body.wallet.length === 0) {\n    63в†’        return c.json({ error: \"wallet is required\" }, 400);\n    64в†’      }\n    65в†’    } catch {\n    66в†’      return c.json({ error: \"Invalid JSON body\" }, 400);\n    67в†’    }\n    68в†’\n    69в†’    const nonce = randomBytes(32).toString(\"hex\");\n    70в†’    const now = new Date();\n    71в†’    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n    72в†’\n    73в†’    const message = buildSignInMessage(\n    74в†’      body.wallet,\n    75в†’      cluster,\n    76в†’      nonce,\n    77в†’      now.toISOString(),\n    78в†’      expiresAt.toISOString(),\n    79в†’    );\n    80в†’\n    81в†’    await authDb.insertChallenge(nonce, body.wallet, cluster, message, expiresAt);\n    82в†’\n    83в†’    logger.info(\"auth challenge issued\", { wallet: body.wallet, nonce });\n    84в†’\n    85в†’    return c.json({\n    86в†’      nonce,\n    87в†’      message,\n    88в†’      expiresAt: expiresAt.toISOString(),\n    89в†’    });\n    90в†’  });\n    91в†’\n    92в†’  // POST /verify вЂ” consume challenge, verify signature, issue tokens\n    93в†’  app.post(\"/verify\", async (c) => {\n    94в†’    let body: { nonce: string; wallet: string; signature: string };\n    95в†’    try {\n    96в†’      body = await c.req.json();\n    97в†’      if (\n    98в†’        typeof body.nonce !== \"string\" ||\n    99в†’        typeof body.wallet !== \"string\" ||\n   100в†’        typeof body.signature !== \"string\"\n   101в†’      ) {\n   102в†’        return c.json({ error: \"nonce, wallet, and signature are required\" }, 400);\n   103в†’      }\n   104в†’    } catch {\n   105в†’      return c.json({ error: \"Invalid JSON body\" }, 400);\n   106в†’    }\n   107в†’\n   108в†’    // Atomically consume the challenge\n   109в†’    const challenge = await authDb.consumeChallenge(body.nonce);\n   110в†’    if (!challenge) {\n   111в†’      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n   112в†’        nonce: body.nonce,\n   113в†’        wallet: body.wallet,\n   114в†’      });\n   115в†’      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n   116в†’    }\n   117в†’\n   118в†’    // Verify wallet matches challenge\n   119в†’    if (challenge.wallet !== body.wallet) {\n   120в†’      logger.warn(\"auth verify rejected: wallet mismatch\", {\n   121в†’        nonce: body.nonce,\n   122в†’        challengeWallet: challenge.wallet,\n   123в†’        requestWallet: body.wallet,\n   124в†’      });\n   125в†’      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n   126в†’    }\n   127в†’\n   128в†’    // Verify Ed25519 signature over the challenge message\n   129в†’    let sigBytes: Uint8Array;\n   130в†’    let pubkeyBytes: Uint8Array;\n   131в†’    try {\n   132в†’      sigBytes = bs58.decode(body.signature);\n   133в†’      pubkeyBytes = bs58.decode(body.wallet);\n   134в†’    } catch {\n   135в†’      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n   136в†’    }\n   137в†’\n   138в†’    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n   139в†’      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n   140в†’    }\n   141в†’\n   142в†’    const messageBytes = new TextEncoder().encode(challenge.message);\n   143в†’    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n   144в†’    if (!valid) {\n   145в†’      logger.warn(\"auth verify rejected: signature verification failed\", {\n   146в†’        wallet: body.wallet,\n   147в†’      });\n   148в†’      return c.json({ error: \"Invalid signature\" }, 401);\n   149в†’    }\n   150в†’\n   151в†’    // Issue JWT access token\n   152в†’    const now = Math.floor(Date.now() / 1000);\n   153в†’    const accessToken = await new SignJWT({ sub: body.wallet })\n   154в†’      .setProtectedHeader({ alg: \"HS256\" })\n   155в†’      .setIssuedAt(now)\n   156в†’      .setExpirationTime(now + accessTokenTtlSeconds)\n   157в†’      .sign(jwtSecret);\n   158в†’\n   159в†’    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n   160в†’\n   161в†’    // Generate opaque refresh token\n   162в†’    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n   163в†’    const refreshTokenHash = hashToken(refreshTokenRaw);\n   164в†’    const familyId = randomBytes(16).toString(\"hex\");\n   165в†’    const refreshExpiresAt = new Date(\n   166в†’      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n   167в†’    );\n   168в†’\n   169в†’    await authDb.insertRefreshToken(\n   170в†’      body.wallet,\n   171в†’      refreshTokenHash,\n   172в†’      familyId,\n   173в†’      refreshExpiresAt,\n   174в†’    );\n   175в†’\n   176в†’    logger.info(\"auth session created\", { wallet: body.wallet });\n   177в†’\n   178в†’    return c.json({\n   179в†’      accessToken,\n   180в†’      accessExpiresAt,\n   181в†’      refreshToken: refreshTokenRaw,\n   182в†’      refreshExpiresAt: refreshExpiresAt.toISOString(),\n   183в†’    });\n   184в†’  });\n   185в†’\n   186в†’  // POST /refresh вЂ” rotate refresh token, issue new access token\n   187в†’  app.post(\"/refresh\", async (c) => {\n   188в†’    let body: { refreshToken: string };\n   189в†’    try {\n   190в†’      body = await c.req.json();\n   191в†’      if (typeof body.refreshToken !== \"string\") {\n   192в†’        return c.json({ error: \"refreshToken is required\" }, 400);\n   193в†’      }\n   194в†’    } catch {\n   195в†’      return c.json({ error: \"Invalid JSON body\" }, 400);\n   196в†’    }\n   197в†’\n   198в†’    const tokenHash = hashToken(body.refreshToken);\n   199в†’    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n   200в†’\n   201в†’    if (!stored) {\n   202в†’      logger.warn(\"auth refresh rejected: token not found\");\n   203в†’      return c.json({ error: \"Invalid refresh token\" }, 401);\n   204в†’    }\n   205в†’\n   206в†’    // Reuse detection: if the token was already revoked, someone replayed it.\n   207в†’    // Revoke the entire family as a precaution.\n   208в†’    if (stored.revoked) {\n   209в†’      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n   210в†’        wallet: stored.wallet,\n   211в†’        familyId: stored.family_id,\n   212в†’      });\n   213в†’      await authDb.revokeTokenFamily(stored.family_id);\n   214в†’      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n   215в†’    }\n   216в†’\n   217в†’    // Check expiry\n   218в†’    if (new Date() > stored.expires_at) {\n   219в†’      logger.warn(\"auth refresh rejected: token expired\", {\n   220в†’        wallet: stored.wallet,\n   221в†’      });\n   222в†’      await authDb.revokeRefreshToken(stored.id);\n   223в†’      return c.json({ error: \"Refresh token expired\" }, 401);\n   224в†’    }\n   225в†’\n   226в†’    // Revoke old token\n   227в†’    await authDb.revokeRefreshToken(stored.id);\n   228в†’\n   229в†’    // Issue new access token\n   230в†’    const now = Math.floor(Date.now() / 1000);\n   231в†’    const accessToken = await new SignJWT({ sub: stored.wallet })\n   232в†’      .setProtectedHeader({ alg: \"HS256\" })\n   233в†’      .setIssuedAt(now)\n   234в†’      .setExpirationTime(now + accessTokenTtlSeconds)\n   235в†’      .sign(jwtSecret);\n   236в†’\n   237в†’    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n   238в†’\n   239в†’    // Issue new refresh token in the same family\n   240в†’    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n   241в†’    const newRefreshHash = hashToken(newRefreshRaw);\n   242в†’    const newRefreshExpiresAt = new Date(\n   243в†’      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n   244в†’    );\n   245в†’\n   246в†’    await authDb.insertRefreshToken(\n   247в†’      stored.wallet,\n   248в†’      newRefreshHash,\n   249в†’      stored.family_id,\n   250в†’      newRefreshExpiresAt,\n   251в†’    );\n   252в†’\n   253в†’    logger.debug(\"auth token refreshed\", { wallet: stored.wallet });\n   254в†’\n   255в†’    return c.json({\n   256в†’      accessToken,\n   257в†’      accessExpiresAt,\n   258в†’      refreshToken: newRefreshRaw,\n   259в†’      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n   260в†’    });\n   261в†’  });\n   262в†’\n   263в†’  // POST /logout вЂ” revoke refresh token\n   264в†’  app.post(\"/logout\", async (c) => {\n   265в†’    let body: { refreshToken: string };\n   266в†’    try {\n   267в†’      body = await c.req.json();\n   268в†’      if (typeof body.refreshToken !== \"string\") {\n   269в†’        return c.body(null, 204);\n   270в†’      }\n   271в†’    } catch {\n   272в†’      return c.body(null, 204);\n   273в†’    }\n   274в†’\n   275в†’    const tokenHash = hashToken(body.refreshToken);\n   276в†’    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n   277в†’    if (stored) {\n   278в†’      await authDb.revokeRefreshToken(stored.id);\n   279в†’      logger.info(\"auth logout\", { wallet: stored.wallet });\n   280в†’    }\n   281в†’\n   282в†’    return c.body(null, 204);\n   283в†’  });\n   284в†’\n   285в†’  return app;\n   286в†’}\n   287в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"1ebe2f87-8037-405e-bc09-c42a22a998b8","timestamp":"2026-03-19T19:15:28.513Z"}
