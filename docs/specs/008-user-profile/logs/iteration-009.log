{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YKGr8K7rdTPayT3uE4mYZN","type":"tool_result","content":"     1в†’/**\n     2в†’ * Player Profile Feature - Public API\n     3в†’ *\n     4в†’ * Exports the provider, hooks, components, and types needed\n     5в†’ * for integrating player profiles throughout the app.\n     6в†’ */\n     7в†’\n     8в†’// Provider and hook\n     9в†’export { PlayerProfileProvider, usePlayerProfile, truncateAddress } from \"./context/PlayerProfileContext\";\n    10в†’\n    11в†’// Components\n    12в†’export { PlayerAvatar } from \"./components/PlayerAvatar\";\n    13в†’export { PlayerAvatarCompact } from \"./components/PlayerAvatarCompact\";\n    14в†’export { LevelProgressBar } from \"./components/LevelProgressBar\";\n    15в†’export { MiniProfileModal } from \"./components/MiniProfileModal\";\n    16в†’export { ProfilePage } from \"./components/ProfilePage\";\n    17в†’export { AvatarSelector } from \"./components/AvatarSelector\";\n    18в†’\n    19в†’// Types\n    20в†’export type {\n    21в†’  AvatarId,\n    22в†’  AvatarSize,\n    23в†’  AvatarTier,\n    24в†’  AvatarConfig,\n    25в†’  BorderStyle,\n    26в†’  BorderConfig,\n    27в†’  GameId,\n    28в†’  PlayerProfile,\n    29в†’  PlayerStats,\n    30в†’  GameSpecificStats,\n    31в†’  LootItem,\n    32в†’  LootSource,\n    33в†’  ProfileTransaction,\n    34в†’  TransactionEvent,\n    35в†’  GameResultEvent,\n    36в†’  PlayerProfileContextValue,\n    37в†’} from \"./types\";\n    38в†’\n    39в†’export {\n    40в†’  AVATAR_CONFIGS,\n    41в†’  AVATAR_SIZES,\n    42в†’  AVATAR_TIER_COLORS,\n    43в†’  LEVEL_BORDERS,\n    44в†’  GAME_NAMES,\n    45в†’  DEFAULT_AVATAR_ID,\n    46в†’  MAX_USERNAME_LENGTH,\n    47в†’  MIN_USERNAME_LENGTH,\n    48в†’  USERNAME_REGEX,\n    49в†’  createEmptyStats,\n    50в†’  getHighestUnlockedAvatar,\n    51в†’} from \"./types\";\n    52в†’\n    53в†’// XP Calculator utilities\n    54в†’export {\n    55в†’  getXPForLevel,\n    56в†’  getLevelFromXP,\n    57в†’  getXPProgress,\n    58в†’  calculateWagerXP,\n    59в†’  calculateWinBonusXP,\n    60в†’  calculateGameXP,\n    61в†’  getBorderStyleFromLevel,\n    62в†’  getLevelMilestones,\n    63в†’  formatXP,\n    64в†’  formatLevel,\n    65в†’  type XPProgress,\n    66в†’} from \"./utils/xp-calculator\";\n    67в†’\n    68в†’// Event bus for game integrations\n    69в†’export {\n    70в†’  profileEventBus,\n    71в†’  emitGameResult,\n    72в†’  emitCoinflipResults,\n    73в†’  emitLordOfRngsResults,\n    74в†’  emitCryptoCrashResults,\n    75в†’  emitCloseCallResults,\n    76в†’  createGameResultEvent,\n    77в†’} from \"./utils/profile-event-bus\";\n    78в†’\n    79в†’// Mock simulation utilities (for testing/development)\n    80в†’export {\n    81в†’  getProfile,\n    82в†’  getOrCreateProfile,\n    83в†’  getTransactions,\n    84в†’  getDisplayName,\n    85в†’  getAvatarId,\n    86в†’  getLevel,\n    87в†’  addLoot,\n    88в†’} from \"./utils/mock-simulation\";\n    89в†’"}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"410fa70d-9cec-49b3-a4d5-75cff62972d3","timestamp":"2026-03-19T19:12:43.041Z"}
