{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MJUSL6S589iSxj9LaxcGUu","type":"tool_result","content":"     1в†’import { Keypair } from \"@solana/web3.js\";\n     2в†’import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3в†’\n     4в†’export interface Config {\n     5в†’  port: number;\n     6в†’  databaseUrl: string;\n     7в†’  dbSchema: string;\n     8в†’  rpcUrl: string;\n     9в†’  wsRpcUrl: string | undefined;\n    10в†’  serverKeypair: Keypair;\n    11в†’  jwtSecret: Uint8Array;\n    12в†’  cluster: string;\n    13в†’  challengeTtlSeconds: number;\n    14в†’  accessTokenTtlSeconds: number;\n    15в†’  refreshTokenTtlDays: number;\n    16в†’  rateLimitPerWallet: number;\n    17в†’  rateLimitGlobal: number;\n    18в†’  workerPollIntervalMs: number;\n    19в†’  entropyAccount: string;\n    20в†’  pythBtcUsdAccount: string;\n    21в†’  minSolBalance: number;\n    22в†’}\n    23в†’\n    24в†’function requireEnv(name: string): string {\n    25в†’  const value = process.env[name];\n    26в†’  if (!value) {\n    27в†’    throw new Error(`Missing required environment variable: ${name}`);\n    28в†’  }\n    29в†’  return value;\n    30в†’}\n    31в†’\n    32в†’function parseKeypair(raw: string): Keypair {\n    33в†’  try {\n    34в†’    const bytes = JSON.parse(raw) as number[];\n    35в†’    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    36в†’  } catch {\n    37в†’    throw new Error(\n    38в†’      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    39в†’    );\n    40в†’  }\n    41в†’}\n    42в†’\n    43в†’export function loadConfig(): Config {\n    44в†’  const dbSchema = loadDbSchemaFromEnv();\n    45в†’\n    46в†’  return {\n    47в†’    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    48в†’    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    49в†’    dbSchema,\n    50в†’    rpcUrl: requireEnv(\"RPC_URL\"),\n    51в†’    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    52в†’    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    53в†’    jwtSecret: (() => {\n    54в†’      const explicit = process.env.JWT_SECRET;\n    55в†’      if (explicit) return new TextEncoder().encode(explicit);\n    56в†’      // Derive from first 32 bytes of server keypair secret key\n    57в†’      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    58в†’      return kp.secretKey.slice(0, 32);\n    59в†’    })(),\n    60в†’    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    61в†’    challengeTtlSeconds: parseInt(\n    62в†’      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    63в†’      10,\n    64в†’    ),\n    65в†’    accessTokenTtlSeconds: parseInt(\n    66в†’      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    67в†’      10,\n    68в†’    ),\n    69в†’    refreshTokenTtlDays: parseInt(\n    70в†’      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    71в†’      10,\n    72в†’    ),\n    73в†’    rateLimitPerWallet: parseInt(\n    74в†’      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    75в†’      10,\n    76в†’    ),\n    77в†’    rateLimitGlobal: parseInt(\n    78в†’      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    79в†’      10,\n    80в†’    ),\n    81в†’    workerPollIntervalMs: parseInt(\n    82в†’      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    83в†’      10,\n    84в†’    ),\n    85в†’    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    86в†’    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    87в†’    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    88в†’  };\n    89в†’}\n    90в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"a9734812-2dba-4874-b676-f73bb38a1715","timestamp":"2026-03-19T19:15:37.282Z"}
