{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018dPfA9wVt5ENqmxwk4fyRF","type":"tool_result","content":"     1в†’/**\n     2в†’ * ProfileTransactions - Transaction history tab content\n     3в†’ *\n     4в†’ * Fetches real transaction data from the backend API and displays\n     5в†’ * a paginated table with event types, amounts, and match links.\n     6в†’ */\n     7в†’\n     8в†’import { GAME_NAMES } from \"../types\";\n     9в†’import type { GameId } from \"../types\";\n    10в†’import { useTransactions } from \"../hooks/useTransactions\";\n    11в†’import { useSolPrice } from \"../hooks/useSolPrice\";\n    12в†’\n    13в†’/** Format lamports as SOL string with optional USD estimate */\n    14в†’function formatSol(lamports: string, solUsdPrice: number | null): string {\n    15в†’  const sol = Number(lamports) / 1e9;\n    16в†’  const solStr =\n    17в†’    sol.toLocaleString(\"en-US\", {\n    18в†’      minimumFractionDigits: 2,\n    19в†’      maximumFractionDigits: 4,\n    20в†’    }) + \" SOL\";\n    21в†’  if (solUsdPrice == null) return solStr;\n    22в†’  const usd = sol * solUsdPrice;\n    23в†’  return `${solStr} (~$${usd.toLocaleString(\"en-US\", { minimumFractionDigits: 2, maximumFractionDigits: 2 })})`;\n    24в†’}\n    25в†’\n    26в†’/** Format ISO date as relative time */\n    27в†’function formatTime(iso: string): string {\n    28в†’  const date = new Date(iso);\n    29в†’  const diffMs = Date.now() - date.getTime();\n    30в†’  const diffMins = Math.floor(diffMs / 60000);\n    31в†’  const diffHours = Math.floor(diffMs / 3600000);\n    32в†’  const diffDays = Math.floor(diffMs / 86400000);\n    33в†’\n    34в†’  if (diffMins < 1) return \"Just now\";\n    35в†’  if (diffMins < 60) return `${diffMins}m ago`;\n    36в†’  if (diffHours < 24) return `${diffHours}h ago`;\n    37в†’  if (diffDays < 7) return `${diffDays}d ago`;\n    38в†’  return date.toLocaleDateString();\n    39в†’}\n    40в†’\n    41в†’/** Build the deep-link path for a match */\n    42в†’function matchPath(gameId: GameId, matchId: string): string {\n    43в†’  return `/${gameId}/${matchId}`;\n    44в†’}\n    45в†’\n    46в†’/** Event display label */\n    47в†’const EVENT_LABELS: Record<string, string> = {\n    48в†’  join: \"JOIN\",\n    49в†’  win: \"WIN\",\n    50в†’  loss: \"LOSS\",\n    51в†’  refund: \"REFUND\",\n    52в†’};\n    53в†’\n    54в†’export function ProfileTransactions() {\n    55в†’  const { transactions, loading, loadingMore, nextCursor, loadMore } =\n    56в†’    useTransactions();\n    57в†’  const solPrice = useSolPrice();\n    58в†’\n    59в†’  if (loading) {\n    60в†’    return (\n    61в†’      <div className=\"profile-transactions\">\n    62в†’        <div className=\"profile-transactions__skeleton\">\n    63в†’          {Array.from({ length: 5 }, (_, i) => (\n    64в†’            <div key={i} className=\"profile-transactions__skeleton-row\" />\n    65в†’          ))}\n    66в†’        </div>\n    67в†’      </div>\n    68в†’    );\n    69в†’  }\n    70в†’\n    71в†’  if (transactions.length === 0) {\n    72в†’    return (\n    73в†’      <div className=\"profile-transactions\">\n    74в†’        <div className=\"profile-transactions__empty\">\n    75в†’          <p>No transactions yet.</p>\n    76в†’          <p>Start playing to build your history!</p>\n    77в†’        </div>\n    78в†’      </div>\n    79в†’    );\n    80в†’  }\n    81в†’\n    82в†’  return (\n    83в†’    <div className=\"profile-transactions\">\n    84в†’      <table className=\"profile-transactions__table\">\n    85в†’        <thead>\n    86в†’          <tr>\n    87в†’            <th>Time</th>\n    88в†’            <th>Game</th>\n    89в†’            <th>Event</th>\n    90в†’            <th>Amount</th>\n    91в†’          </tr>\n    92в†’        </thead>\n    93в†’        <tbody>\n    94в†’          {transactions.map((tx) => (\n    95в†’            <tr key={tx.id}>\n    96в†’              <td>{formatTime(tx.createdAt)}</td>\n    97в†’              <td>\n    98в†’                <a\n    99в†’                  href={matchPath(tx.gameId, tx.matchId)}\n   100в†’                  className=\"profile-transactions__match-link\"\n   101в†’                >\n   102в†’                  {GAME_NAMES[tx.gameId] ?? tx.gameId}\n   103в†’                </a>\n   104в†’              </td>\n   105в†’              <td\n   106в†’                className={`profile-transactions__event profile-transactions__event--${tx.event}`}\n   107в†’              >\n   108в†’                {EVENT_LABELS[tx.event] ?? tx.event}\n   109в†’              </td>\n   110в†’              <td>{formatSol(tx.amountLamports, solPrice)}</td>\n   111в†’            </tr>\n   112в†’          ))}\n   113в†’        </tbody>\n   114в†’      </table>\n   115в†’\n   116в†’      {nextCursor && (\n   117в†’        <div className=\"profile-transactions__load-more\">\n   118в†’          <button\n   119в†’            type=\"button\"\n   120в†’            className=\"profile-transactions__load-more-btn\"\n   121в†’            onClick={loadMore}\n   122в†’            disabled={loadingMore}\n   123в†’          >\n   124в†’            {loadingMore ? \"Loading...\" : \"Load more\"}\n   125в†’          </button>\n   126в†’        </div>\n   127в†’      )}\n   128в†’    </div>\n   129в†’  );\n   130в†’}\n   131в†’"}]},"parent_tool_use_id":null,"session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"246a9cf2-87f7-43fa-9c60-84b85be38b6d","timestamp":"2026-03-19T19:16:48.076Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/components/ProfileTransactions.tsx","content":"/**\n * ProfileTransactions - Transaction history tab content\n *\n * Fetches real transaction data from the backend API and displays\n * a paginated table with event types, amounts, and match links.\n */\n\nimport { GAME_NAMES } from \"../types\";\nimport type { GameId } from \"../types\";\nimport { useTransactions } from \"../hooks/useTransactions\";\nimport { useSolPrice } from \"../hooks/useSolPrice\";\n\n/** Format lamports as SOL string with optional USD estimate */\nfunction formatSol(lamports: string, solUsdPrice: number | null): string {\n  const sol = Number(lamports) / 1e9;\n  const solStr =\n    sol.toLocaleString(\"en-US\", {\n      minimumFractionDigits: 2,\n      maximumFractionDigits: 4,\n    }) + \" SOL\";\n  if (solUsdPrice == null) return solStr;\n  const usd = sol * solUsdPrice;\n  return `${solStr} (~$${usd.toLocaleString(\"en-US\", { minimumFractionDigits: 2, maximumFractionDigits: 2 })})`;\n}\n\n/** Format ISO date as relative time */\nfunction formatTime(iso: string): string {\n  const date = new Date(iso);\n  const diffMs = Date.now() - date.getTime();\n  const diffMins = Math.floor(diffMs / 60000);\n  const diffHours = Math.floor(diffMs / 3600000);\n  const diffDays = Math.floor(diffMs / 86400000);\n\n  if (diffMins < 1) return \"Just now\";\n  if (diffMins < 60) return `${diffMins}m ago`;\n  if (diffHours < 24) return `${diffHours}h ago`;\n  if (diffDays < 7) return `${diffDays}d ago`;\n  return date.toLocaleDateString();\n}\n\n/** Build the deep-link path for a match */\nfunction matchPath(gameId: GameId, matchId: string): string {\n  return `/${gameId}/${matchId}`;\n}\n\n/** Event display label */\nconst EVENT_LABELS: Record<string, string> = {\n  join: \"JOIN\",\n  win: \"WIN\",\n  loss: \"LOSS\",\n  refund: \"REFUND\",\n};\n\nexport function ProfileTransactions() {\n  const { transactions, loading, loadingMore, nextCursor, loadMore } =\n    useTransactions();\n  const solPrice = useSolPrice();\n\n  if (loading) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__skeleton\">\n          {Array.from({ length: 5 }, (_, i) => (\n            <div key={i} className=\"profile-transactions__skeleton-row\" />\n          ))}\n        </div>\n      </div>\n    );\n  }\n\n  if (transactions.length === 0) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__empty\">\n          <p>No transactions yet.</p>\n          <p>Start playing to build your history!</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"profile-transactions\">\n      <table className=\"profile-transactions__table\">\n        <thead>\n          <tr>\n            <th>Time</th>\n            <th>Game</th>\n            <th>Event</th>\n            <th>Amount</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id}>\n              <td>{formatTime(tx.createdAt)}</td>\n              <td>\n                <a\n                  href={matchPath(tx.gameId, tx.matchId)}\n                  className=\"profile-transactions__match-link\"\n                >\n                  {GAME_NAMES[tx.gameId] ?? tx.gameId}\n                </a>\n              </td>\n              <td\n                className={`profile-transactions__event profile-transactions__event--${tx.event}`}\n              >\n                {EVENT_LABELS[tx.event] ?? tx.event}\n              </td>\n              <td>{formatSol(tx.amountLamports, solPrice)}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n\n      {nextCursor && (\n        <div className=\"profile-transactions__load-more\">\n          <button\n            type=\"button\"\n            className=\"profile-transactions__load-more-btn\"\n            onClick={loadMore}\n            disabled={loadingMore}\n          >\n            {loadingMore ? \"Loading...\" : \"Load more\"}\n          </button>\n        </div>\n      )}\n    </div>\n  );\n}\n","numLines":131,"startLine":1,"totalLines":131}}}
