{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JQDP9QcLdDz6xY1DnNXX98","type":"tool_result","content":"     1в†’import { defineConfig, devices } from \"@playwright/test\";\n     2в†’\n     3в†’/**\n     4в†’ * Playwright config for local E2E integration tests.\n     5в†’ *\n     6в†’ * Runs against a local solana-test-validator with real wallet mode.\n     7в†’ * The validator + program deploy is handled by external bootstrap scripts;\n     8в†’ * this config only starts the Vite dev server.\n     9в†’ */\n    10в†’export default defineConfig({\n    11в†’  testDir: \"./e2e\",\n    12в†’  fullyParallel: false,\n    13в†’  forbidOnly: !!process.env.CI,\n    14в†’  retries: 0,\n    15в†’  workers: 1,\n    16в†’  reporter: \"list\",\n    17в†’  timeout: 60_000,\n    18в†’\n    19в†’  use: {\n    20в†’    baseURL: \"http://localhost:3002\",\n    21в†’    screenshot: \"off\",\n    22в†’    trace: \"retain-on-failure\",\n    23в†’    ...devices[\"Desktop Chrome\"],\n    24в†’    viewport: { width: 1280, height: 1080 },\n    25в†’  },\n    26в†’\n    27в†’  projects: [\n    28в†’    {\n    29в†’      name: \"local-e2e\",\n    30в†’      testMatch: \"local/**/*.spec.ts\",\n    31в†’      use: { ...devices[\"Desktop Chrome\"], viewport: { width: 1280, height: 1080 } },\n    32в†’    },\n    33в†’  ],\n    34в†’\n    35в†’  webServer: {\n    36в†’    command: \"npx vite --port 3002\",\n    37в†’    url: \"http://localhost:3002\",\n    38в†’    reuseExistingServer: !process.env.CI,\n    39в†’    timeout: 90_000,\n    40в†’    env: {\n    41в†’      VITE_MOCK_MODE: \"false\",\n    42в†’      VITE_TEST_WALLET: \"true\",\n    43в†’      VITE_RPC_URL: \"http://127.0.0.1:8899\",\n    44в†’      VITE_SOLANA_NETWORK: \"localnet\",\n    45в†’      VITE_FAIRNESS_BACKEND_URL: process.env.VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\",\n    46в†’    },\n    47в†’  },\n    48в†’});\n    49в†’"}]},"parent_tool_use_id":null,"session_id":"b99e2185-20b1-487e