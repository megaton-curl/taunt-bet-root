{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016zT3xBJakSseWiyn2ZEWt2","type":"tool_result","content":"     1в†’/**\n     2в†’ * ProfileSettings - Settings tab content\n     3в†’ *\n     4в†’ * Shows connected wallet and allows connecting socials.\n     5в†’ * Avatar selection is handled via modal from the profile header.\n     6в†’ * Username editing is handled inline in the profile header.\n     7в†’ */\n     8в†’\n     9в†’import { useState } from \"react\";\n    10в†’import type { PlayerProfile } from \"../types\";\n    11в†’import { usePlayerProfile } from \"../context/PlayerProfileContext\";\n    12в†’import { truncateAddress } from \"../utils/mock-simulation\";\n    13в†’\n    14в†’interface ProfileSettingsProps {\n    15в†’  profile: PlayerProfile;\n    16в†’}\n    17в†’\n    18в†’export function ProfileSettings({ profile }: ProfileSettingsProps) {\n    19в†’  const {\n    20в†’    connectDiscord,\n    21в†’    disconnectDiscord,\n    22в†’    connectTwitter,\n    23в†’    disconnectTwitter,\n    24в†’  } = usePlayerProfile();\n    25в†’\n    26в†’  const [connectingDiscord, setConnectingDiscord] = useState(false);\n    27в†’  const [connectingTwitter, setConnectingTwitter] = useState(false);\n    28в†’\n    29в†’  const handleConnectDiscord = async () => {\n    30в†’    setConnectingDiscord(true);\n    31в†’    try {\n    32в†’      await connectDiscord();\n    33в†’    } catch (error) {\n    34в†’      console.error(\"Failed to connect Discord:\", error);\n    35в†’    } finally {\n    36в†’      setConnectingDiscord(false);\n    37в†’    }\n    38в†’  };\n    39в†’\n    40в†’  const handleDisconnectDiscord = async () => {\n    41в†’    setConnectingDiscord(true);\n    42в†’    try {\n    43в†’      await disconnectDiscord();\n    44в†’    } catch (error) {\n    45в†’      console.error(\"Failed to disconnect Discord:\", error);\n    46в†’    } finally {\n    47в†’      setConnectingDiscord(false);\n    48в†’    }\n    49в†’  };\n    50в†’\n    51в†’  const handleConnectTwitter = async () => {\n    52в†’    setConnectingTwitter(true);\n    53в†’    try {\n    54в†’      await connectTwitter();\n    55в†’    } catch (error) {\n    56в†’      console.error(\"Failed to connect Twitter:\", error);\n    57в†’    } finally {\n    58в†’      setConnectingTwitter(false);\n    59в†’    }\n    60в†’  };\n    61в†’\n    62в†’  const handleDisconnectTwitter = async () => {\n    63в†’    setConnectingTwitter(true);\n    64в†’    try {\n    65в†’      await disconnectTwitter();\n    66в†’    } catch (error) {\n    67в†’      console.error(\"Failed to disconnect Twitter:\", error);\n    68в†’    } finally {\n    69в†’      setConnectingTwitter(false);\n    70в†’    }\n    71в†’  };\n    72в†’\n    73в†’  return (\n    74в†’    <div className=\"profile-settings\">\n    75в†’      {/* Connected Wallet */}\n    76в†’      <div className=\"profile-settings__section\">\n    77в†’        <h3 className=\"profile-settings__section-title\">Connected Wallet</h3>\n    78в†’        <div className=\"profile-settings__wallet\">\n    79в†’          <div className=\"profile-settings__wallet-icon\">\n    80в†’            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">"}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"b42f46db-2dd8-479d-8a06-56610747d7bf","timestamp":"2026-03-19T19:12:37.353Z"}
