{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J2iodZUjdp1quWVYJ7oLVx","type":"tool_result","content":"     1в†’/**\n     2в†’ * useTransactions вЂ” fetches transaction history from the real API.\n     3в†’ *\n     4в†’ * Uses JWT auth (from auth-store) and cursor-based pagination.\n     5в†’ */\n     6в†’\n     7в†’import { useState, useCallback, useEffect, useRef } from \"react\";\n     8в†’import { getAccessToken } from \"../../../lib/auth-store\";\n     9в†’import type { GameId, TransactionEvent } from \"../types\";\n    10в†’\n    11в†’const BACKEND_URL = (\n    12в†’  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    13в†’    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    14в†’).replace(/\\/$/, \"\");\n    15в†’\n    16в†’interface ApiTransaction {\n    17в†’  id: string;\n    18в†’  game: string;\n    19в†’  matchId: string;\n    20в†’  event: TransactionEvent;\n    21в†’  amountLamports: string;\n    22в†’  txSig: string | null;\n    23в†’  createdAt: string;\n    24в†’}\n    25в†’\n    26в†’interface ApiResponse {\n    27в†’  transactions: ApiTransaction[];\n    28в†’  nextCursor: string | null;\n    29в†’}\n    30в†’\n    31в†’export interface Transaction {\n    32в†’  id: string;\n    33в†’  gameId: GameId;\n    34в†’  matchId: string;\n    35в†’  event: TransactionEvent;\n    36в†’  amountLamports: string;\n    37в†’  txSig: string | null;\n    38в†’  createdAt: string;\n    39в†’}\n    40в†’\n    41в†’export function useTransactions(game?: string) {\n    42в†’  const [transactions, setTransactions] = useState<Transaction[]>([]);\n    43в†’  const [nextCursor, setNextCursor] = useState<string | null>(null);\n    44в†’  const [loading, setLoading] = useState(true);\n    45в†’  const [loadingMore, setLoadingMore] = useState(false);\n    46в†’  const [error, setError] = useState<string | null>(null);\n    47в†’  const abortRef = useRef<AbortController | null>(null);\n    48в†’\n    49в†’  const fetchPage = useCallback(\n    50в†’    async (cursor?: string) => {\n    51в†’      const token = getAccessToken();\n    52в†’      if (!token) {\n    53в†’        setTransactions([]);\n    54в†’        setLoading(false);\n    55в†’        return;\n    56в†’      }\n    57в†’\n    58в†’      // Build query string\n    59в†’      const parts = [\"limit=20\"];\n    60в†’      if (cursor) parts.push(`cursor=${encodeURIComponent(cursor)}`);\n    61в†’      if (game) parts.push(`game=${encodeURIComponent(game)}`);\n    62в†’      const qs = parts.join(\"&\");\n    63в†’\n    64в†’      // Abort any in-flight request\n    65в†’      abortRef.current?.abort();\n    66в†’      const controller = new AbortController();\n    67в†’      abortRef.current = controller;\n    68в†’\n    69в†’      try {\n    70в†’        const res = await fetch(\n    71в†’          `${BACKEND_URL}/profile/transactions?${qs}`,\n    72в†’          {\n    73в†’            headers: { Authorization: `Bearer ${token}` },\n    74в†’            signal: controller.signal,\n    75в†’          },\n    76в†’        );\n    77в†’        if (!res.ok) throw new Error(`HTTP ${res.status}`);\n    78в†’        const data: ApiResponse = await res.json();\n    79в†’\n    80в†’        const mapped: Transaction[] = data.transactions.map((tx) => ({\n    81в†’          id: tx.id,\n    82в†’          gameId: tx.game as GameId,\n    83в†’          matchId: tx.matchId,\n    84в†’          event: tx.event,\n    85в†’          amountLamports: tx.amountLamports,\n    86в†’          txSig: tx.txSig,\n    87в†’          createdAt: tx.createdAt,\n    88в†’        }));\n    89в†’\n    90в†’        if (cursor) {\n    91в†’          setTransactions((prev) => [...prev, ...mapped]);\n    92в†’        } else {\n    93в†’          setTransactions(mapped);\n    94в†’        }\n    95в†’        setNextCursor(data.nextCursor);\n    96в†’        setError(null);\n    97в†’      } catch (err) {\n    98в†’        if (err instanceof Error && err.name === \"AbortError\") return;\n    99в†’        setError(err instanceof Error ? err.message : \"Failed to fetch\");\n   100в†’      } finally {\n   101в†’        setLoading(false);\n   102в†’        setLoadingMore(false);\n   103в†’      }\n   104в†’    },\n   105в†’    [game],\n   106в†’  );\n   107в†’\n   108в†’  useEffect(() => {\n   109в†’    setLoading(true);\n   110в†’    setTransactions([]);\n   111в†’    setNextCursor(null);\n   112в†’    fetchPage();\n   113в†’    return () => abortRef.current?.abort();\n   114в†’  }, [fetchPage]);\n   115в†’\n   116в†’  const loadMore = useCallback(() => {\n   117в†’    if (!nextCursor || loadingMore) return;\n   118в†’    setLoadingMore(true);\n   119в†’    fetchPage(nextCursor);\n   120в†’  }, [nextCursor, loadingMore, fetchPage]);\n   121в†’\n   122в†’  return { transactions, loading, loadingMore, error, nextCursor, loadMore };\n   123в†’}\n   124в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"bc2b0b10-063a-4a3f-8671-02ad7bf35727","timestamp":"2026-03-19T19:15:56.803Z"}
