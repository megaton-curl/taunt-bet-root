{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017Lv8xBp2TubPW7ZZJL6CC2","type":"tool_result","content":"     1в†’/**\n     2в†’ * On-chain assertion helpers for local E2E tests.\n     3в†’ *\n     4в†’ * Provides RPC-based helpers to query and assert match PDA state,\n     5в†’ * treasury fee deltas, and player profile stat updates.\n     6в†’ */\n     7в†’import { Connection, PublicKey } from \"@solana/web3.js\";\n     8в†’import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     9в†’import {\n    10в†’  CoinflipIDL,\n    11в†’  LordofrngsIDL,\n    12в†’  type Coinflip,\n    13в†’  type Lordofrngs,\n    14в†’} from \"@rng-utopia/anchor-client\";\n    15в†’\n    16в†’// ============ Program IDs ============\n    17в†’\n    18в†’/** Coinflip program address (from IDL). */\n    19в†’export const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    20в†’\n    21в†’/** Lord of RNGs program address (from IDL). */\n    22в†’export const LORDOFRNGS_PROGRAM_ID = new PublicKey(LordofrngsIDL.address);\n    23в†’\n    24в†’/** Platform fee: 300 basis points = 3%. */\n    25в†’export const FEE_BPS = 300;\n    26в†’\n    27в†’/** Coinflip phase constants matching the on-chain program. */\n    28в†’export const COINFLIP_PHASE_WAITING = 0;\n    29в†’export const COINFLIP_PHASE_LOCKED = 1;\n    30в†’export const COINFLIP_PHASE_SETTLED = 2;\n    31в†’export const COINFLIP_PHASE_REFUNDED = 3;\n    32в†’\n    33в†’// ============ PDA Derivation ============\n    34в†’\n    35в†’/** Derive the match PDA for a creator + matchId. Seeds: [\"match\", creator, matchId]. */\n    36в†’export function getMatchPda(creator: PublicKey, matchId: Buffer | Uint8Array): [PublicKey, number] {\n    37в†’  return PublicKey.findProgramAddressSync(\n    38в†’    [Buffer.from(\"match\"), creator.toBuffer(), Buffer.from(matchId)],\n    39в†’    COINFLIP_PROGRAM_ID,\n    40в†’  );\n    41в†’}\n    42в†’\n    43в†’/** Derive the coinflip config PDA. Seeds: [\"coinflip_config\"]. */\n    44в†’export function getConfigPda(): [PublicKey, number] {\n    45в†’  return PublicKey.findProgramAddressSync(\n    46в†’    [Buffer.from(\"coinflip_config\")],\n    47в†’    COINFLIP_PROGRAM_ID,\n    48в†’  );\n    49в†’}\n    50в†’\n    51в†’// ============ Program Instances ============\n    52в†’\n    53в†’/**\n    54в†’ * Create a read-only Coinflip program instance.\n    55в†’ *\n    56в†’ * @param connection - Solana RPC connection\n    57в†’ */\n    58в†’export function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    59в†’  const provider = new AnchorProvider(\n    60в†’    connection,\n    61в†’    {} as AnchorProvider[\"wallet\"],\n    62в†’    { commitment: \"confirmed\" },\n    63в†’  );\n    64в†’  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    65в†’}\n    66в†’\n    67в†’// ============ Account Types ============\n    68в†’\n    69в†’/** Deserialized match account shape. */\n    70в†’export interface MatchAccount {\n    71в†’  creator: PublicKey;\n    72в†’  opponent: PublicKey;\n    73в†’  server: PublicKey;\n    74в†’  entryAmount: { toNumber(): number };\n    75в†’  creatorSide: number;\n    76в†’  phase: number;\n    77в†’  commitment: Uint8Array;\n    78в†’  algorithmVer: number;\n    79в†’  targetSlot: { toNumber(): number };\n    80в†’  resolveDeadline: { toNumber(): number };\n    81в†’  resultHash: Uint8Array;\n    82в†’  result: number;\n    83в†’  winner: PublicKey;\n    84в†’  createdAt: { toNumber(): number };\n    85в†’  matchId: number[];\n    86в†’  bump: number;\n    87в†’}\n    88в†’\n    89в†’function coinflipPhaseName(phase: number): \"waiting\" | \"locked\" | \"settled\" | \"refunded\" | \"unknown\" {\n    90в†’  switch (phase) {\n    91в†’    case COINFLIP_PHASE_WAITING:\n    92в†’      return \"waiting\";\n    93в†’    case COINFLIP_PHASE_LOCKED:\n    94в†’      return \"locked\";\n    95в†’    case COINFLIP_PHASE_SETTLED:\n    96в†’      return \"settled\";\n    97в†’    case COINFLIP_PHASE_REFUNDED:\n    98в†’      return \"refunded\";\n    99в†’    default:\n   100в†’      return \"unknown\";\n   101в†’  }\n   102в†’}\n   103в†’\n   104в†’// ============ Fetch Helpers ============\n   105в†’\n   106в†’/**\n   107в†’ * Fetch a match PDA account. Returns null if the account is closed.\n   108в†’ *\n   109в†’ * @param connection - Solana RPC connection\n   110в†’ * @param matchPda - The match PDA address\n   111в†’ */\n   112в†’export async function fetchMatch(\n   113в†’  connection: Connection,\n   114в†’  matchPda: PublicKey,\n   115в†’): Promise<MatchAccount | null> {\n   116в†’  const program = getCoinflipProgram(connection);\n   117в†’  try {\n   118в†’    return (await program.account.coinflipMatch.fetch(\n   119в†’      matchPda,\n   120в†’    )) as unknown as MatchAccount;\n   121в†’  } catch {\n   122в†’    // Account not found (closed or never created)\n   123в†’    return null;\n   124в†’  }\n   125в†’}\n   126в†’\n   127в†’/**\n   128в†’ * Get the treasury wallet address from the coinflip config PDA.\n   129в†’ *\n   130в†’ * @param connection - Solana RPC connection\n   131в†’ */\n   132в†’export async function getTreasuryAddress(\n   133в†’  connection: Connection,\n   134в†’): Promise<PublicKey> {\n   135в†’  const program = getCoinflipProgram(connection);\n   136в†’  const [configPda] = getConfigPda();\n   137в†’  const config = await program.account.coinflipConfig.fetch(configPda);\n   138в†’  return (config as unknown as { treasury: PublicKey }).treasury;\n   139в†’}\n   140в†’\n   141в†’// ============ Balance Helpers ============\n   142в†’\n   143в†’/**\n   144в†’ * Get the SOL balance of an address in lamports.\n   145в†’ *\n   146в†’ * @param connection - Solana RPC connection\n   147в†’ * @param address - Public key to check\n   148в†’ */\n   149в†’export async function getBalanceLamports(\n   150в†’  connection: Connection,\n   151в†’  address: PublicKey,\n   152в†’): Promise<number> {\n   153в†’  return connection.getBalance(address);\n   154в†’}\n   155в†’\n   156в†’/**\n   157в†’ * Capture a balance snapshot for later delta comparison.\n   158в†’ *\n   159в†’ * @param connection - Solana RPC connection\n   160в†’ * @param address - Public key to snapshot\n   161в†’ */\n   162в†’export async function snapshotBalance(\n   163в†’  connection: Connection,\n   164в†’  address: PublicKey,\n   165в†’): Promise<number> {\n   166в†’  return connection.getBalance(address);\n   167в†’}\n   168в†’\n   169в†’// ============ Fee Calculation ============\n   170в†’\n   171в†’/**\n   172в†’ * Calculate the expected fee and net payout for a coinflip match.\n   173в†’ * Mirrors on-chain logic: fee = floor(pool * FEE_BPS / 10_000).\n   174в†’ *\n   175в†’ * @param entryAmount - Single player's entry in lamports\n   176в†’ * @returns Object with pool, fee, and payout amounts in lamports\n   177в†’ */\n   178в†’export function calculateExpectedFee(entryAmount: number): {\n   179в†’  pool: number;\n   180в†’  fee: number;\n   181в†’  payout: number;\n   182в†’} {\n   183в†’  const pool = entryAmount * 2;\n   184в†’  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n   185в†’  const payout = pool - fee;\n   186в†’  return { pool, fee, payout };\n   187в†’}\n   188в†’\n   189в†’// ============ Assertion Helpers ============\n   190в†’\n   191в†’/**\n   192в†’ * Assert match PDA state after creation (Waiting phase).\n   193в†’ *\n   194в†’ * Uses memcmp-based search to find the creator's active match,\n   195в†’ * so it works regardless of which nonce was used for PDA derivation.\n   196в†’ *\n   197в†’ * @param connection - Solana RPC connection\n   198в†’ * @param creator - Creator's public key\n   199в†’ * @param expectedSide - Expected creator side (0 = heads, 1 = tails)\n   200в†’ * @param expectedEntryAmount - Expected entry amount in lamports\n   201в†’ */\n   202в†’export async function assertMatchCreated(\n   203в†’  connection: Connection,\n   204в†’  creator: PublicKey,\n   205в†’  expectedSide: number,\n   206в†’  expectedEntryAmount?: number,\n   207в†’): Promise<{ matchPda: PublicKey; match: MatchAccount }> {\n   208в†’  // Use memcmp to find any active match by this creator (works for any nonce).\n   209в†’  const program = getCoinflipProgram(connection);\n   210в†’  const matches = await program.account.coinflipMatch.all([\n   211в†’    { memcmp: { offset: 8, bytes: creator.toBase58() } },\n   212в†’    { dataSize: program.account.coinflipMatch.size },\n   213в†’  ]);\n   214в†’  const activeMatches = matches.filter((m) => {\n   215в†’    const match = m.account as unknown as MatchAccount;\n   216в†’    return (\n   217в†’      match.phase !== COINFLIP_PHASE_SETTLED &&\n   218в†’      match.phase !== COINFLIP_PHASE_REFUNDED\n   219в†’    );\n   220в†’  });\n   221в†’  if (activeMatches.length === 0) {\n   222в†’    throw new Error(`No active match PDA found for creator ${creator}`);\n   223в†’  }\n   224в†’  const matchPda = activeMatches[0].publicKey;\n   225в†’  const match = activeMatches[0].account as unknown as MatchAccount;\n   226в†’\n   227в†’  const phase = coinflipPhaseName(match.phase);\n   228в†’  if (phase !== \"waiting\") {\n   229в†’    throw new Error(`Expected phase 'waiting', got '${phase}'`);\n   230в†’  }\n   231в†’  if (match.creator.toBase58() !== creator.toBase58()) {\n   232в†’    throw new Error(\"Match creator does not match expected creator\");\n   233в†’  }\n   234в†’  if (match.creatorSide !== expectedSide) {\n   235в†’    throw new Error(`Expected side ${expectedSide}, got ${match.creatorSide}`);\n   236в†’  }\n   237в†’  if (match.opponent.toBase58() !== PublicKey.default.toBase58()) {\n   238в†’    throw new Error(\"Expected no opponent in waiting phase\");\n   239в†’  }\n   240в†’  if (expectedEntryAmount !== undefined && match.entryAmount.toNumber() !== expectedEntryAmount) {\n   241в†’    throw new Error(\n   242в†’      `Expected entryAmount ${expectedEntryAmount}, got ${match.entryAmount.toNumber()}`,\n   243в†’    );\n   244в†’  }\n   245в†’\n   246в†’  return { matchPda, match };\n   247в†’}\n   248в†’\n   249в†’/**\n   250в†’ * Assert match PDA is closed (account no longer exists).\n   251в†’ *\n   252в†’ * @param connection - Solana RPC connection\n   253в†’ * @param matchPda - The match PDA address to check\n   254в†’ */\n   255в†’export async function assertMatchClosed(\n   256в†’  connection: Connection,\n   257в†’  matchPda: PublicKey,\n   258в†’): Promise<void> {\n   259в†’  const match = await fetchMatch(connection, matchPda);\n   260в†’  if (match !== null) {\n   261в†’    const phase = coinflipPhaseName(match.phase);\n   262в†’    throw new Error(\n   263в†’      `Expected match PDA to be closed, but it still exists (phase: ${phase})`,\n   264в†’    );\n   265в†’  }\n   266в†’}\n   267в†’\n   268в†’/**\n   269в†’ * Assert that the treasury received the expected fee.\n   270в†’ * Call snapshotBalance before the payout, then call this after.\n   271в†’ *\n   272в†’ * @param connection - Solana RPC connection\n   273в†’ * @param treasury - Treasury public key\n   274в†’ * @param balanceBefore - Treasury balance in lamports before claim\n   275в†’ * @param entryAmount - Single player's entry in lamports\n   276в†’ */\n   277в†’export async function assertTreasuryFee(\n   278в†’  connection: Connection,\n   279в†’  treasury: PublicKey,\n   280в†’  balanceBefore: number,\n   281в†’  entryAmount: number,\n   282в†’): Promise<void> {\n   283в†’  const balanceAfter = await getBalanceLamports(connection, treasury);\n   284в†’  const { fee } = calculateExpectedFee(entryAmount);\n   285в†’  const actualDelta = balanceAfter - balanceBefore;\n   286в†’\n   287в†’  // When treasury == server wallet (devnet), the delta includes rent refund\n   288в†’  // and is reduced by gas costs, so allow approximate match.\n   289в†’  // Exact match for dedicated treasury, В±10% tolerance otherwise.\n   290в†’  const tolerance = Math.max(fee * 0.1, 10_000);\n   291в†’  if (Math.abs(actualDelta - fee) > tolerance) {\n   292в†’    throw new Error(\n   293в†’      `Treasury fee mismatch: expected ~${fee} lamports (В±${tolerance}), got delta ${actualDelta}`,\n   294в†’    );\n   295в†’  }\n   296в†’}\n   297в†’\n   298в†’// ============ Lord of RNGs Helpers ============\n   299в†’\n   300в†’/** Derive a Lord of RNGs round PDA. Seeds: [\"jackpot_round\", matchId]. */\n   301в†’export function getLordRoundPda(matchId: string | Buffer): [PublicKey, number] {\n   302в†’  const matchIdBuf = typeof matchId === \"string\" ? Buffer.from(matchId, \"hex\") : matchId;\n   303в†’  return PublicKey.findProgramAddressSync(\n   304в†’    [Buffer.from(\"jackpot_round\"), matchIdBuf],\n   305в†’    LORDOFRNGS_PROGRAM_ID,\n   306в†’  );\n   307в†’}\n   308в†’\n   309в†’/** Derive the Lord of RNGs config PDA. Seeds: [\"lord_config\"]. */\n   310в†’export function getLordConfigPda(): [PublicKey, number] {\n   311в†’  return PublicKey.findProgramAddressSync(\n   312в†’    [Buffer.from(\"lord_config\")],\n   313в†’    LORDOFRNGS_PROGRAM_ID,\n   314в†’  );\n   315в†’}\n   316в†’\n   317в†’/** Create a read-only Lord of RNGs program instance. */\n   318в†’export function getLordProgram(connection: Connection): Program<Lordofrngs> {\n   319в†’  const provider = new AnchorProvider(\n   320в†’    connection,\n   321в†’    {} as AnchorProvider[\"wallet\"],\n   322в†’    { commitment: \"confirmed\" },\n   323в†’  );\n   324в†’  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n   325в†’}\n   326в†’\n   327в†’/** Deserialized jackpot round account shape. */\n   328в†’export interface JackpotRoundAccount {\n   329в†’  matchId: number[];\n   330в†’  server: PublicKey;\n   331в†’  phase: Record<string, object>;\n   332в†’  commitment: number[];\n   333в†’  algorithmVer: number;\n   334в†’  entries: { player: PublicKey; amountLamports: { toNumber(): number } }[];\n   335в†’  totalAmountLamports: { toNumber(): number };\n   336в†’  distinctPlayers: number;\n   337в†’  creator: PublicKey;\n   338в†’  createdAt: { toNumber(): number };\n   339в†’  countdownStartedAt: { toNumber(): number };\n   340в†’  countdownEndsAt: { toNumber(): number };\n   341в†’  targetEntropySlot: { toNumber(): number };\n   342в†’  resolveDeadline: { toNumber(): number };\n   343в†’  resultHash: number[];\n   344в†’  winningOffset: { toNumber(): number };\n   345в†’  winningEntryIndex: number;\n   346в†’  winner: PublicKey;\n   347в†’  bump: number;\n   348в†’}\n   349в†’\n   350в†’/** Fetch a Lord of RNGs round PDA. Returns null if closed/missing. */\n   351в†’export async function fetchLordRound(\n   352в†’  connection: Connection,\n   353в†’  roundPda: PublicKey,\n   354в†’): Promise<JackpotRoundAccount | null> {\n   355в†’  const program = getLordProgram(connection);\n   356в†’  try {\n   357в†’    return (await program.account.jackpotRound.fetch(\n   358в†’      roundPda,\n   359в†’    )) as unknown as JackpotRoundAccount;\n   360в†’  } catch {\n   361в†’    return null;\n   362в†’  }\n   363в†’}\n   364в†’\n   365в†’/** Assert a Lord of RNGs round PDA is closed. */\n   366в†’export async function assertLordRoundClosed(\n   367в†’  connection: Connection,\n   368в†’  roundPda: PublicKey,\n   369в†’): Promise<void> {\n   370в†’  const round = await fetchLordRound(connection, roundPda);\n   371в†’  if (round !== null) {\n   372в†’    const phase = Object.keys(round.phase)[0];\n   373в†’    throw new Error(\n   374в†’      `Expected round PDA to be closed, but it still exists (phase: ${phase})`,\n   375в†’    );\n   376в†’  }\n   377в†’}\n   378в†’\n   379в†’/**\n   380в†’ * Calculate the expected fee and net payout for a Lord of RNGs jackpot round.\n   381в†’ * pool = totalAmountLamports; fee = floor(pool * 300 / 10_000).\n   382в†’ */\n   383в†’export function calculateLordExpectedFee(\n   384в†’  totalAmountLamports: number,\n   385в†’): { pool: number; fee: number; payout: number } {\n   386в†’  const pool = totalAmountLamports;\n   387в†’  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n   388в†’  const payout = pool - fee;\n   389в†’  return { pool, fee, payout };\n   390в†’}\n   391в†’\n   392в†’/**\n   393в†’ * Assert that the treasury received the expected Lord of RNGs fee.\n   394в†’ * On devnet, treasury == server wallet, so the delta includes both the 3% fee\n   395в†’ * AND the rent refund (server subsidizes rent and gets it back on close).\n   396в†’ * We check that the delta is at least the fee amount.\n   397в†’ */\n   398в†’export async function assertLordTreasuryFee(\n   399в†’  connection: Connection,\n   400в†’  treasury: PublicKey,\n   401в†’  balanceBefore: number,\n   402в†’  totalAmountLamports: number,\n   403в†’): Promise<void> {\n   404в†’  const balanceAfter = await getBalanceLamports(connection, treasury);\n   405в†’  const { fee } = calculateLordExpectedFee(totalAmountLamports);\n   406в†’  const actualDelta = balanceAfter - balanceBefore;\n   407в†’\n   408в†’  // When treasury == server wallet (devnet), the delta includes rent refund.\n   409в†’  // Just verify the fee portion is present (delta >= fee).\n   410в†’  if (actualDelta < fee - 10_000) {\n   411в†’    throw new Error(\n   412в†’      `Lord treasury fee mismatch: expected at least ~${fee} lamports, got delta ${actualDelta}`,\n   413в†’    );\n   414в†’  }\n   415в†’}\n   416в†’"}]},"parent_tool_use_id":"toolu_01HeJfpFiA1rSVyi58U1gKAc","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"ff30f51b-3906-40c6-8636-f69c4910b4f5","timestamp":"2026-03-19T19:12:44.479Z"}
