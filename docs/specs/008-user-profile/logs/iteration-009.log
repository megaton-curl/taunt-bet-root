{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015BdiGMShCMMb7tScgAQ7zG","type":"tool_result","content":"     1в†’import { useState, useEffect, useRef } from \"react\";\n     2в†’import { BrowserRouter, Routes, Route, Link } from \"react-router-dom\";\n     3в†’import { Header } from \"./components/Header\";\n     4в†’import { Sidebar } from \"./components/Sidebar\";\n     5в†’import { Ticker } from \"./components/Ticker\";\n     6в†’import { BackgroundEffects } from \"./components/BackgroundEffects\";\n     7в†’import { CoinflipPage } from \"./pages/CoinflipPage\";\n     8в†’import { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\n     9в†’import { CloseCallPage } from \"./pages/CloseCallPage\";\n    10в†’import { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\n    11в†’import { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\n    12в†’import { BossRaidProvider } from \"./features/boss-raid\";\n    13в†’import { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatarCompact } from \"./features/player-profile\";\n    14в†’import { QuestsProvider, ChestDropNotification } from \"./features/quests\";\n    15в†’import { QuestsPage } from \"./pages/QuestsPage\";\n    16в†’import { LootPage } from \"./pages/LootPage\";\n    17в†’import { CoinflipRoundPage } from \"./pages/CoinflipRoundPage\";\n    18в†’import { LordRoundPage } from \"./pages/LordRoundPage\";\n    19в†’import { CloseCallRoundPage } from \"./pages/CloseCallRoundPage\";\n    20в†’import { FairnessPage } from \"./pages/FairnessPage\";\n    21в†’import { BuildBadge } from \"./components/BuildBadge\";\n    22в†’import { PriceFeedProvider } from \"@rng-utopia/price-feeds\";\n    23в†’\n    24в†’\n    25в†’export function App() {\n    26в†’  return (\n    27в†’    <BrowserRouter>\n    28в†’      <PriceFeedProvider>\n    29в†’        <PlayerProfileProvider>\n    30в†’          <QuestsProvider>\n    31в†’            <BossRaidProvider>\n    32в†’              <AppContent />\n    33в†’            </BossRaidProvider>\n    34в†’          </QuestsProvider>\n    35в†’        </PlayerProfileProvider>\n    36в†’      </PriceFeedProvider>\n    37в†’    </BrowserRouter>\n    38в†’  );\n    39в†’}\n    40в†’\n    41в†’\n    42в†’// Chat icon SVG\n    43в†’const ChatIcon = () => (\n    44в†’  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    45в†’    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    46в†’    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    47в†’    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    48в†’    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n    49в†’  </svg>\n    50в†’);\n    51в†’\n    52в†’// Footer component with terms and FAQ modals\n    53в†’function Footer() {\n    54в†’  const [showTerms, setShowTerms] = useState(false);\n    55в†’  const [showFAQ, setShowFAQ] = useState(false);\n    56в†’  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n    57в†’  const termsModalRef = useRef<HTMLDivElement>(null);\n    58в†’  const faqModalRef = useRef<HTMLDivElement>(null);\n    59в†’\n    60в†’  // Close modal on outside click\n    61в†’  useEffect(() => {\n    62в†’    if (!showTerms && !showFAQ) return;\n    63в†’\n    64в†’    const handleClickOutside = (e: MouseEvent) => {\n    65в†’      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n    66в†’        setShowTerms(false);\n    67в†’      }\n    68в†’      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n    69в†’        setShowFAQ(false);\n    70в†’      }\n    71в†’    };\n    72в†’\n    73в†’    document.addEventListener(\"mousedown\", handleClickOutside);\n    74в†’    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n    75в†’  }, [showTerms, showFAQ]);\n    76в†’\n    77в†’  // Close on escape\n    78в†’  useEffect(() => {\n    79в†’    if (!showTerms && !showFAQ) return;\n    80в†’\n    81в†’    const handleEscape = (e: KeyboardEvent) => {\n    82в†’      if (e.key === \"Escape\") {\n    83в†’        setShowTerms(false);\n    84в†’        setShowFAQ(false);\n    85в†’      }\n    86в†’    };\n    87в†’\n    88в†’    document.addEventListener(\"keydown\", handleEscape);\n    89в†’    return () => document.removeEventListener(\"keydown\", handleEscape);\n    90в†’  }, [showTerms, showFAQ]);\n    91в†’\n    92в†’  const toggleFAQSection = (section: string) => {\n    93в†’    setExpandedFAQ(expandedFAQ === section ? null : section);\n    94в†’  };\n    95в†’\n    96в†’  const faqSections = [\n    97в†’    {\n    98в†’      id: \"fees\",\n    99в†’      title: \"Platform Fees\",\n   100в†’      content: `TAUNT charges a 3% platform fee on all games. This means 97% of all wagered funds go directly to winners."}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"7d64b5c1-835f-4488-a724-83592cec9c55","timestamp":"2026-03-19T19:12:33.018Z"}
