{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U5ipp6LPFCK5cHkvjF7jnm","type":"tool_result","content":"     1в†’/**\n     2в†’ * Profile routes вЂ” transaction history for the authenticated player.\n     3в†’ */\n     4в†’\n     5в†’import { Hono } from \"hono\";\n     6в†’import type { AppEnv } from \"../hono-env.js\";\n     7в†’import type { Db } from \"../db.js\";\n     8в†’import { logger } from \"../logger.js\";\n     9в†’\n    10в†’export interface ProfileRoutesDeps {\n    11в†’  db: Db;\n    12в†’}\n    13в†’\n    14в†’/** Map DB game names to frontend game IDs */\n    15в†’const GAME_TO_FRONTEND: Record<string, string> = {\n    16в†’  coinflip: \"coinflip\",\n    17в†’  lord: \"lord-of-rngs\",\n    18в†’  closecall: \"close-call\",\n    19в†’};\n    20в†’\n    21в†’/** Map frontend/DB game names to canonical DB names */\n    22в†’const TO_DB_GAME: Record<string, string> = {\n    23в†’  coinflip: \"coinflip\",\n    24в†’  lord: \"lord\",\n    25в†’  closecall: \"closecall\",\n    26в†’  \"lord-of-rngs\": \"lord\",\n    27в†’  \"close-call\": \"closecall\",\n    28в†’};\n    29в†’\n    30в†’export function createProfileRoutes(deps: ProfileRoutesDeps) {\n    31в†’  const { db } = deps;\n    32в†’  const app = new Hono<AppEnv>();\n    33в†’\n    34в†’  app.get(\"/transactions\", async (c) => {\n    35в†’    const wallet = c.get(\"wallet\");\n    36в†’    if (!wallet) {\n    37в†’      return c.json({ error: \"Authentication required\" }, 401);\n    38в†’    }\n    39в†’\n    40в†’    // Parse query params\n    41в†’    const cursor = c.req.query(\"cursor\") || undefined;\n    42в†’    const limitParam = c.req.query(\"limit\");\n    43в†’    const gameParam = c.req.query(\"game\") || undefined;\n    44в†’\n    45в†’    // Validate & clamp limit\n    46в†’    let limit = 20;\n    47в†’    if (limitParam) {\n    48в†’      const parsed = parseInt(limitParam, 10);\n    49в†’      if (!isNaN(parsed) && parsed > 0) {\n    50в†’        limit = Math.min(parsed, 50);\n    51в†’      }\n    52в†’    }\n    53в†’\n    54в†’    // Map game filter to DB name (accept both DB and frontend names)\n    55в†’    let dbGame: string | undefined;\n    56в†’    if (gameParam) {\n    57в†’      dbGame = TO_DB_GAME[gameParam];\n    58в†’      if (!dbGame) {\n    59в†’        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n    60в†’      }\n    61в†’    }\n    62в†’\n    63в†’    try {\n    64в†’      const rows = await db.getUserTransactions(wallet, cursor, limit, dbGame);\n    65в†’\n    66в†’      const transactions = rows.map((row) => ({\n    67в†’        id: row.id,\n    68в†’        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n    69в†’        matchId: row.match_id,\n    70в†’        event: row.event,\n    71в†’        amountLamports: String(row.amount_lamports),\n    72в†’        txSig: row.tx_sig,\n    73в†’        createdAt: row.created_at.toISOString(),\n    74в†’      }));\n    75в†’\n    76в†’      const nextCursor =\n    77в†’        transactions.length === limit\n    78в†’          ? String(transactions[transactions.length - 1]!.id)\n    79в†’          : null;\n    80в†’\n    81в†’      return c.json({ transactions, nextCursor });\n    82в†’    } catch (err) {\n    83в†’      logger.error(\"profile transactions query failed\", {\n    84в†’        wallet,\n    85в†’        error: err instanceof Error ? err.message : \"Unknown error\",\n    86в†’      });\n    87в†’      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    88в†’    }\n    89в†’  });\n    90в†’\n    91в†’  return app;\n    92в†’}\n    93в†’"}]},"parent_tool_use_id":null,"session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"ac4ad039-56b4-407a-9900-f25a7e0390a4","timestamp":"2026-03-19T19:19:49.130Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/profile.ts","content":"/**\n * Profile routes вЂ” transaction history for the authenticated player.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ProfileRoutesDeps {\n  db: Db;\n}\n\n/** Map DB game names to frontend game IDs */\nconst GAME_TO_FRONTEND: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord-of-rngs\",\n  closecall: \"close-call\",\n};\n\n/** Map frontend/DB game names to canonical DB names */\nconst TO_DB_GAME: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord\",\n  closecall: \"closecall\",\n  \"lord-of-rngs\": \"lord\",\n  \"close-call\": \"closecall\",\n};\n\nexport function createProfileRoutes(deps: ProfileRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  app.get(\"/transactions\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    // Parse query params\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limitParam = c.req.query(\"limit\");\n    const gameParam = c.req.query(\"game\") || undefined;\n\n    // Validate & clamp limit\n    let limit = 20;\n    if (limitParam) {\n      const parsed = parseInt(limitParam, 10);\n      if (!isNaN(parsed) && parsed > 0) {\n        limit = Math.min(parsed, 50);\n      }\n    }\n\n    // Map game filter to DB name (accept both DB and frontend names)\n    let dbGame: string | undefined;\n    if (gameParam) {\n      dbGame = TO_DB_GAME[gameParam];\n      if (!dbGame) {\n        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n      }\n    }\n\n    try {\n      const rows = await db.getUserTransactions(wallet, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n        matchId: row.match_id,\n        event: row.event,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return c.json({ transactions, nextCursor });\n    } catch (err) {\n      logger.error(\"profile transactions query failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":93,"startLine":1,"totalLines":93}}}
