{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016YkE4tK21ATFmqkf5ocH4v","type":"tool_result","content":"     1в†’/**\n     2в†’ * Player Profile Types\n     3в†’ *\n     4в†’ * Defines all types for the player profile system including\n     5в†’ * XP/levels, avatars, statistics, loot, and transactions.\n     6в†’ */\n     7в†’\n     8в†’\n     9в†’// ============ Level Border System ============\n    10в†’\n    11в†’export type BorderStyle = \"none\" | \"iron\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n    12в†’\n    13в†’export interface BorderConfig {\n    14в†’  minLevel: number;\n    15в†’  color: string;\n    16в†’  glow: string;\n    17в†’}\n    18в†’\n    19в†’export const LEVEL_BORDERS: Record<BorderStyle, BorderConfig> = {\n    20в†’  none: { minLevel: 0, color: \"rgba(255, 255, 255, 0.3)\", glow: \"0 0 6px rgba(255, 255, 255, 0.2)\" },\n    21в†’  iron: { minLevel: 5, color: \"#a8a8a8\", glow: \"0 0 8px #a8a8a8\" },\n    22в†’  silver: { minLevel: 10, color: \"#c0c0c0\", glow: \"0 0 10px #c0c0c0\" },\n    23в†’  gold: { minLevel: 15, color: \"#f0b820\", glow: \"0 0 12px #f0b820\" },\n    24в†’  platinum: { minLevel: 20, color: \"#40c080\", glow: \"0 0 14px #40c080\" },\n    25в†’  diamond: { minLevel: 25, color: \"#b9f2ff\", glow: \"0 0 16px #b9f2ff, 0 0 24px #b9f2ff\" },\n    26в†’};\n    27в†’\n    28в†’// ============ Avatar System ============\n    29в†’\n    30в†’// The Path of the Doge вЂ” progression avatars unlocked at specific levels\n    31в†’export type AvatarId =\n    32в†’  | \"recruit\"        // Lv 1\n    33в†’  | \"mercenary\"      // Lv 5\n    34в†’  | \"cadet\"          // Lv 10\n    35в†’  | \"vanguard\"       // Lv 15\n    36в†’  | \"knight\"         // Lv 20\n    37в†’  | \"champion\"       // Lv 30\n    38в†’  | \"paladin\"        // Lv 40\n    39в†’  | \"grandmaster\"    // Lv 50\n    40в†’  | \"warlord\"        // Lv 60\n    41в†’  | \"sovereign\"      // Lv 70\n    42в†’  | \"archon\"         // Lv 80\n    43в†’  | \"ascendant\"      // Lv 90\n    44в†’  | \"cosmic_deity\";  // Lv 100\n    45в†’\n    46в†’export type AvatarTier = \"starter\" | \"adept\" | \"elite\" | \"legendary\" | \"mythic\";\n    47в†’\n    48в†’export interface AvatarConfig {\n    49в†’  id: AvatarId;\n    50в†’  name: string;\n    51в†’  description: string;\n    52в†’  tier: AvatarTier;\n    53в†’  unlockLevel: number;\n    54в†’}\n    55в†’\n    56в†’export const AVATAR_CONFIGS: AvatarConfig[] = [\n    57в†’  {\n    58в†’    id: \"recruit\",\n    59в†’    name: \"Recruit\",\n    60в†’    description: \"A humble Doge with a curious expression and no gear\",\n    61в†’    tier: \"starter\",\n    62в†’    unlockLevel: 1,\n    63в†’  },\n    64в†’  {\n    65в†’    id: \"mercenary\",\n    66в†’    name: \"Mercenary\",\n    67в†’    description: \"A rugged soldier of fortune with a dark hood and leather eyepatch\",\n    68в†’    tier: \"starter\",\n    69в†’    unlockLevel: 5,\n    70в†’  },\n    71в†’  {\n    72в†’    id: \"cadet\",\n    73в†’    name: \"Cadet\",\n    74в†’    description: \"First step into the military вЂ” a simple iron kettle-hat helmet\",\n    75в†’    tier: \"adept\",\n    76в†’    unlockLevel: 10,\n    77в†’  },\n    78в†’  {\n    79в†’    id: \"vanguard\",\n    80в†’    name: \"Vanguard\",\n    81в†’    description: \"Front-line ready with a thick quilted leather gorget\",\n    82в†’    tier: \"adept\",\n    83в†’    unlockLevel: 15,\n    84в†’  },\n    85в†’  {\n    86в†’    id: \"knight\",\n    87в†’    name: \"Knight\",\n    88в†’    description: \"Fully encased in a polished steel close-helm\",\n    89в†’    tier: \"adept\",\n    90в†’    unlockLevel: 20,\n    91в†’  },\n    92в†’  {\n    93в†’    id: \"champion\",\n    94в†’    name: \"Champion\",\n    95в†’    description: \"Elite knight with a vibrant red feathered plume\",\n    96в†’    tier: \"elite\",\n    97в†’    unlockLevel: 30,\n    98в†’  },\n    99в†’  {\n   100в†’    id: \"paladin\",\n   101в†’    name: \"Paladin\",\n   102в†’    description: \"First hint of divinity вЂ” white-silver chrome with golden holy glow\",\n   103в†’    tier: \"elite\",\n   104в†’    unlockLevel: 40,\n   105в†’  },\n   106в†’  {\n   107в†’    id: \"grandmaster\",\n   108в†’    name: \"Grandmaster\",\n   109в†’    description: \"Visored Great Helm covered in intricate gold-etched filigree\",\n   110в†’    tier: \"legendary\",\n   111в†’    unlockLevel: 50,\n   112в†’  },\n   113в†’  {\n   114в†’    id: \"warlord\",\n   115в†’    name: \"Warlord\",\n   116в†’    description: \"Battle-worn veteran with a wolf-pelt mantle and a glowing red ember eye\",\n   117в†’    tier: \"legendary\",\n   118в†’    unlockLevel: 60,\n   119в†’  },\n   120в†’  {\n   121в†’    id: \"sovereign\",\n   122в†’    name: \"Sovereign\",\n   123в†’    description: \"Jeweled crown welded onto golden plate armor with royal purple cape\",\n   124в†’    tier: \"legendary\",\n   125в†’    unlockLevel: 70,\n   126в†’  },\n   127в†’  {\n   128в†’    id: \"archon\",\n   129в†’    name: \"Archon\",\n   130в†’    description: \"Glowing blue Mithril armor with runic stones orbiting the head\",\n   131в†’    tier: \"mythic\",\n   132в†’    unlockLevel: 80,\n   133в†’  },\n   134в†’  {\n   135в†’    id: \"ascendant\",\n   136в†’    name: \"Ascendant\",\n   137в†’    description: \"Semi-translucent ghostly form in cracked void armor leaking neon energy\",\n   138в†’    tier: \"mythic\",\n   139в†’    unlockLevel: 90,\n   140в†’  },\n   141в†’  {\n   142в†’    id: \"cosmic_deity\",\n   143в†’    name: \"Cosmic Deity\",\n   144в†’    description: \"Body of swirling nebulae, star eyes, galaxy halo, ethereal filament wings\",\n   145в†’    tier: \"mythic\",\n   146в†’    unlockLevel: 100,\n   147в†’  },\n   148в†’];\n   149в†’\n   150в†’export const DEFAULT_AVATAR_ID: AvatarId = \"recruit\";\n   151в†’\n   152в†’// Get the highest unlocked avatar for a given level\n   153в†’export function getHighestUnlockedAvatar(level: number): AvatarId {\n   154в†’  const unlocked = AVATAR_CONFIGS.filter(a => a.unlockLevel <= level);\n   155в†’  if (unlocked.length === 0) return DEFAULT_AVATAR_ID;\n   156в†’  const lastAvatar = unlocked[unlocked.length - 1];\n   157в†’  return lastAvatar ? lastAvatar.id : DEFAULT_AVATAR_ID;\n   158в†’}\n   159в†’\n   160в†’// Avatar tier colors for UI display\n   161в†’export const AVATAR_TIER_COLORS: Record<AvatarTier, string> = {\n   162в†’  starter: \"#a8a8a8\",   // Gray\n   163в†’  adept: \"#4a9eff\",     // Blue\n   164в†’  elite: \"#9d4eff\",     // Purple\n   165в†’  legendary: \"#f0b820\", // Gold\n   166в†’  mythic: \"#f0b820\",    // Pink/Magenta\n   167в†’};\n   168в†’\n   169в†’// ============ Game Types ============\n   170в†’\n   171в†’export type GameId = \"coinflip\" | \"lord-of-rngs\" | \"crypto-crash\" | \"close-call\" | \"game-of-trades\";\n   172в†’\n   173в†’export const GAME_NAMES: Record<GameId, string> = {\n   174в†’  coinflip: \"Flip You\",\n   175в†’  \"lord-of-rngs\": \"Jackpot\",\n   176в†’  \"crypto-crash\": \"Crypto Crash\",\n   177в†’  \"close-call\": \"Close Call\",\n   178в†’  \"game-of-trades\": \"Game of Trades\",\n   179в†’};\n   180в†’\n   181в†’// ============ Player Statistics ============\n   182в†’\n   183в†’export interface GameSpecificStats {\n   184в†’  gamesPlayed: number;\n   185в†’  wagered: number;\n   186в†’  winnings: number;\n   187в†’  wins: number;\n   188в†’  losses: number;\n   189в†’}\n   190в†’\n   191в†’export interface PlayerStats {\n   192в†’  // Aggregate stats\n   193в†’  gamesPlayed: number;\n   194в†’  totalWagered: number;\n   195в†’  totalWins: number;\n   196в†’  netProfit: number;\n   197в†’  wins: number;\n   198в†’  losses: number;\n   199в†’\n   200в†’  // Streak tracking\n   201в†’  currentWinStreak: number;\n   202в†’  bestWinStreak: number;\n   203в†’\n   204в†’  // Per-game breakdown\n   205в†’  gameStats: Record<GameId, GameSpecificStats>;\n   206в†’}\n   207в†’\n   208в†’export function createEmptyStats(): PlayerStats {\n   209в†’  return {\n   210в†’    gamesPlayed: 0,\n   211в†’    totalWagered: 0,\n   212в†’    totalWins: 0,\n   213в†’    netProfit: 0,\n   214в†’    wins: 0,\n   215в†’    losses: 0,\n   216в†’    currentWinStreak: 0,\n   217в†’    bestWinStreak: 0,\n   218в†’    gameStats: {\n   219в†’      coinflip: { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   220в†’      \"lord-of-rngs\": { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   221в†’      \"crypto-crash\": { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   222в†’      \"close-call\": { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   223в†’      \"game-of-trades\": { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   224в†’    },\n   225в†’  };\n   226в†’}\n   227в†’\n   228в†’// ============ Loot System ============\n   229в†’\n   230в†’export type LootSource = \"game_win\" | \"raid_boss\" | \"promo\" | \"achievement\";\n   231в†’\n   232в†’export interface LootItem {\n   233в†’  id: string;\n   234в†’  source: LootSource;\n   235в†’  amount: number; // amount\n   236в†’  description: string;\n   237в†’  earnedAt: number;\n   238в†’  expiresAt?: number;\n   239в†’  gameId?: GameId;\n   240в†’  matchId?: string;\n   241в†’}\n   242в†’\n   243в†’// ============ Transaction History ============\n   244в†’\n   245в†’export type TransactionEvent = \"join\" | \"win\" | \"loss\" | \"refund\";\n   246в†’\n   247в†’export interface ProfileTransaction {\n   248в†’  id: string;\n   249в†’  gameId: GameId;\n   250в†’  matchId: string;\n   251в†’  event: TransactionEvent;\n   252в†’  amountLamports: string;\n   253в†’  txSig: string | null;\n   254в†’  createdAt: string;\n   255в†’}\n   256в†’\n   257в†’// ============ Player Profile ============\n   258в†’\n   259в†’export interface PlayerProfile {\n   260в†’  // Identity\n   261в†’  address: string;\n   262в†’  username: string | null;\n   263в†’  avatarId: AvatarId;\n   264в†’\n   265в†’  // Level system\n   266в†’  level: number;\n   267в†’  currentXP: number; // XP within current level\n   268в†’  totalXP: number; // Lifetime XP\n   269в†’\n   270в†’  // Connected socials\n   271в†’  discordUsername: string | null;\n   272в†’  twitterHandle: string | null;\n   273в†’\n   274в†’  // Statistics\n   275в†’  stats: PlayerStats;\n   276в†’\n   277в†’  // Unclaimed rewards\n   278в†’  unclaimedLoot: LootItem[];\n   279в†’\n   280в†’  // Timestamps\n   281в†’  createdAt: number;\n   282в†’  lastActiveAt: number;\n   283в†’}\n   284в†’\n   285в†’// ============ Event Types ============\n   286в†’\n   287в†’export interface GameResultEvent {\n   288в†’  gameId: GameId;\n   289в†’  matchId: string;\n   290в†’  playerAddress: string;\n   291в†’  wagerAmount: number;\n   292в†’  outcome: \"win\" | \"loss\";\n   293в†’  payoutAmount: number;\n   294в†’  timestamp: number;\n   295в†’}\n   296в†’\n   297в†’// ============ Context Value ============\n   298в†’\n   299в†’export interface PlayerProfileContextValue {\n   300в†’  // Current user's profile\n   301в†’  myProfile: PlayerProfile | null;\n   302в†’  loading: boolean;\n   303в†’\n   304в†’  // Profile lookup (for other users)\n   305в†’  getProfile: (address: string) => PlayerProfile | null;\n   306в†’  loadProfile: (address: string) => Promise<PlayerProfile | null>;\n   307в†’\n   308в†’  // Profile mutations\n   309в†’  updateUsername: (username: string) => Promise<void>;\n   310в†’  updateAvatar: (avatarId: AvatarId) => Promise<void>;\n   311в†’  connectDiscord: () => Promise<void>;\n   312в†’  disconnectDiscord: () => Promise<void>;\n   313в†’  connectTwitter: () => Promise<void>;\n   314в†’  disconnectTwitter: () => Promise<void>;\n   315в†’\n   316в†’  // Loot\n   317в†’  claimLoot: (lootId: string) => Promise<number>; // Returns claimed amount\n   318в†’  claimAllLoot: () => Promise<number>;\n   319в†’\n   320в†’  // Mini profile modal state\n   321в†’  selectedProfileAddress: string | null;\n   322в†’  openMiniProfile: (address: string) => void;\n   323в†’  closeMiniProfile: () => void;\n   324в†’\n   325в†’  // Display helpers\n   326в†’  getDisplayName: (address: string) => string;\n   327в†’  getAvatarId: (address: string) => AvatarId;\n   328в†’  getBorderStyle: (level: number) => BorderStyle;\n   329в†’  isAvatarUnlocked: (avatarId: AvatarId, level: number) => boolean;\n   330в†’}\n   331в†’\n   332в†’// ============ Avatar Sizes ============\n   333в†’\n   334в†’export type AvatarSize = \"xs\" | \"sm\" | \"md\" | \"lg\" | \"xl\";\n   335в†’\n   336в†’export const AVATAR_SIZES: Record<AvatarSize, number> = {\n   337в†’  xs: 56,\n   338в†’  sm: 80,\n   339в†’  md: 104,\n   340в†’  lg: 140,\n   341в†’  xl: 200,\n   342в†’};\n   343в†’\n   344в†’// ============ Constants ============\n   345в†’\n   346в†’export const MAX_USERNAME_LENGTH = 20;\n   347в†’export const MIN_USERNAME_LENGTH = 3;\n   348в†’\n   349в†’// Username validation regex (alphanumeric, underscores, no spaces)\n   350в†’export const USERNAME_REGEX = /^[a-zA-Z0-9_]+$/;\n   351в†’"}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"c883b277-d055-4fd3-b6cd-4026f637e5cf","timestamp":"2026-03-19T19:12:27.144Z"}
