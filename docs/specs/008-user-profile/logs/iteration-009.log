{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WPq3H34xLiQXCeDwoemMTM","type":"tool_result","content":"     1в†’/**\n     2в†’ * Pure storage logic for auth session tokens.\n     3в†’ * No React вЂ” just localStorage + module-level in-memory access token.\n     4в†’ */\n     5в†’\n     6в†’const STORAGE_KEY = \"rng-utopia:session\";\n     7в†’\n     8в†’export interface PersistedWalletSession {\n     9в†’  wallet: string;\n    10в†’  cluster: string;\n    11в†’  refreshToken: string;\n    12в†’  refreshExpiresAt: string;\n    13в†’}\n    14в†’\n    15в†’// In-memory only вЂ” never stored in localStorage\n    16в†’let accessToken: string | null = null;\n    17в†’let accessExpiresAt: string | null = null;\n    18в†’\n    19в†’export function getAccessToken(): string | null {\n    20в†’  if (!accessToken || !accessExpiresAt) return null;\n    21в†’  // Check if expired (with 30s buffer)\n    22в†’  if (new Date(accessExpiresAt).getTime() - 30_000 < Date.now()) return null;\n    23в†’  return accessToken;\n    24в†’}\n    25в†’\n    26в†’export function setAccessToken(token: string, expiresAt: string): void {\n    27в†’  accessToken = token;\n    28в†’  accessExpiresAt = expiresAt;\n    29в†’}\n    30в†’\n    31в†’export function clearAccessToken(): void {\n    32в†’  accessToken = null;\n    33в†’  accessExpiresAt = null;\n    34в†’}\n    35в†’\n    36в†’export function getAccessExpiresAt(): string | null {\n    37в†’  return accessExpiresAt;\n    38в†’}\n    39в†’\n    40в†’export function getPersistedSession(): PersistedWalletSession | null {\n    41в†’  try {\n    42в†’    const raw = localStorage.getItem(STORAGE_KEY);\n    43в†’    if (!raw) return null;\n    44в†’    const parsed = JSON.parse(raw) as PersistedWalletSession;\n    45в†’    // Check refresh token expiry\n    46в†’    if (new Date(parsed.refreshExpiresAt).getTime() < Date.now()) {\n    47в†’      localStorage.removeItem(STORAGE_KEY);\n    48в†’      return null;\n    49в†’    }\n    50в†’    return parsed;\n    51в†’  } catch {\n    52в†’    return null;\n    53в†’  }\n    54в†’}\n    55в†’\n    56в†’export function setPersistedSession(session: PersistedWalletSession): void {\n    57в†’  localStorage.setItem(STORAGE_KEY, JSON.stringify(session));\n    58в†’}\n    59в†’\n    60в†’export function clearPersistedSession(): void {\n    61в†’  localStorage.removeItem(STORAGE_KEY);\n    62в†’  clearAccessToken();\n    63в†’}\n    64в†’"}]},"parent_tool_use_id":null,"session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"81c99353-80bf-421b-a7ec-a5551f73b390","timestamp":"2026-03-19T19:19:59.666Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/auth-store.ts","content":"/**\n * Pure storage logic for auth session tokens.\n * No React вЂ” just localStorage + module-level in-memory access token.\n */\n\nconst STORAGE_KEY = \"rng-utopia:session\";\n\nexport interface PersistedWalletSession {\n  wallet: string;\n  cluster: string;\n  refreshToken: string;\n  refreshExpiresAt: string;\n}\n\n// In-memory only вЂ” never stored in localStorage\nlet accessToken: string | null = null;\nlet accessExpiresAt: string | null = null;\n\nexport function getAccessToken(): string | null {\n  if (!accessToken || !accessExpiresAt) return null;\n  // Check if expired (with 30s buffer)\n  if (new Date(accessExpiresAt).getTime() - 30_000 < Date.now()) return null;\n  return accessToken;\n}\n\nexport function setAccessToken(token: string, expiresAt: string): void {\n  accessToken = token;\n  accessExpiresAt = expiresAt;\n}\n\nexport function clearAccessToken(): void {\n  accessToken = null;\n  accessExpiresAt = null;\n}\n\nexport function getAccessExpiresAt(): string | null {\n  return accessExpiresAt;\n}\n\nexport function getPersistedSession(): PersistedWalletSession | null {\n  try {\n    const raw = localStorage.getItem(STORAGE_KEY);\n    if (!raw) return null;\n    const parsed = JSON.parse(raw) as PersistedWalletSession;\n    // Check refresh token expiry\n    if (new Date(parsed.refreshExpiresAt).getTime() < Date.now()) {\n      localStorage.removeItem(STORAGE_KEY);\n      return null;\n    }\n    return parsed;\n  } catch {\n    return null;\n  }\n}\n\nexport function setPersistedSession(session: PersistedWalletSession): void {\n  localStorage.setItem(STORAGE_KEY, JSON.stringify(session));\n}\n\nexport function clearPersistedSession(): void {\n  localStorage.removeItem(STORAGE_KEY);\n  clearAccessToken();\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
