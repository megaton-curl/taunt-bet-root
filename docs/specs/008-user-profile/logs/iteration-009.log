{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019AULX8RuNSyqHhcxfAyA88","type":"tool_result","content":"     1в†’import { ReactNode, useState, useCallback, useMemo, useEffect } from \"react\";\n     2в†’import {\n     3в†’  Connection,\n     4в†’  Keypair,\n     5в†’  Transaction,\n     6в†’} from \"@solana/web3.js\";\n     7в†’import nacl from \"tweetnacl\";\n     8в†’import { WalletContext } from \"../context\";\n     9в†’import type { WalletContextValue } from \"../types\";\n    10в†’\n    11в†’const DEFAULT_RPC_URL = \"http://127.0.0.1:8899\";\n    12в†’\n    13в†’interface TestWalletProviderProps {\n    14в†’  children: ReactNode;\n    15в†’  /** Keypair to use for signing transactions */\n    16в†’  keypair: Keypair;\n    17в†’  /** RPC URL (defaults to localhost:8899) */\n    18в†’  rpcUrl?: string;\n    19в†’  /** Auto-connect on mount (default: true) */\n    20в†’  autoConnect?: boolean;\n    21в†’}\n    22в†’\n    23в†’/**\n    24в†’ * Test wallet provider that signs real transactions with an injected Keypair.\n    25в†’ * For E2E testing against local test-validator вЂ” no browser extension needed.\n    26в†’ */\n    27в†’export function TestWalletProvider({\n    28в†’  children,\n    29в†’  keypair,\n    30в†’  rpcUrl = DEFAULT_RPC_URL,\n    31в†’  autoConnect = true,\n    32в†’}: TestWalletProviderProps) {\n    33в†’  const [connected, setConnected] = useState(false);\n    34в†’  const [connecting, setConnecting] = useState(false);\n    35в†’\n    36в†’  const connection = useMemo(\n    37в†’    () => new Connection(rpcUrl, \"confirmed\"),\n    38в†’    [rpcUrl],\n    39в†’  );\n    40в†’\n    41в†’  const connect = useCallback(async () => {\n    42в†’    setConnecting(true);\n    43в†’    try {\n    44в†’      // Verify the keypair works by checking if the account exists\n    45в†’      await connection.getBalance(keypair.publicKey);\n    46в†’      setConnected(true);\n    47в†’    } finally {\n    48в†’      setConnecting(false);\n    49в†’    }\n    50в†’  }, [connection, keypair]);\n    51в†’\n    52в†’  const disconnect = useCallback(async () => {\n    53в†’    setConnected(false);\n    54в†’  }, []);\n    55в†’\n    56в†’  const sendTransaction = useCallback(\n    57в†’    async (transaction: Transaction): Promise<string> => {\n    58в†’      if (!connected) {\n    59в†’        throw new Error(\"Wallet not connected\");\n    60в†’      }\n    61в†’\n    62в†’      transaction.feePayer = keypair.publicKey;\n    63в†’\n    64в†’      // Mirror real-wallet behavior: sign and send, return signature.\n    65в†’      // Callers decide when/how to confirm.\n    66в†’      if (!transaction.recentBlockhash) {\n    67в†’        const { blockhash } = await connection.getLatestBlockhash(\"confirmed\");\n    68в†’        transaction.recentBlockhash = blockhash;\n    69в†’      }\n    70в†’\n    71в†’      transaction.partialSign(keypair);\n    72в†’      const signature = await connection.sendRawTransaction(\n    73в†’        transaction.serialize(),\n    74в†’        { preflightCommitment: \"confirmed\" },\n    75в†’      );\n    76в†’      return signature;\n    77в†’    },\n    78в†’    [connected, keypair, connection],\n    79в†’  );\n    80в†’\n    81в†’  const signMessage = useCallback(\n    82в†’    async (message: Uint8Array): Promise<Uint8Array> => {\n    83в†’      if (!connected) {\n    84в†’        throw new Error(\"Wallet not connected\");\n    85в†’      }\n    86в†’      return nacl.sign.detached(message, keypair.secretKey);\n    87в†’    },\n    88в†’    [connected, keypair],\n    89в†’  );\n    90в†’\n    91в†’  // Auto-connect\n    92в†’  useEffect(() => {\n    93в†’    if (autoConnect && !connected && !connecting) {\n    94в†’      connect();\n    95в†’    }\n    96в†’  }, [autoConnect, connected, connecting, connect]);\n    97в†’\n    98в†’  const value: WalletContextValue = useMemo(\n    99в†’    () => ({\n   100в†’      connected,\n   101в†’      connecting,\n   102в†’      address: connected ? keypair.publicKey.toBase58() : null,\n   103в†’      publicKey: connected ? keypair.publicKey : null,\n   104в†’      connect,\n   105в†’      disconnect,\n   106в†’      sendTransaction,\n   107в†’      signMessage,\n   108в†’      isMock: false,\n   109в†’    }),\n   110в†’    [\n   111в†’      connected,\n   112в†’      connecting,\n   113в†’      keypair,\n   114в†’      connect,\n   115в†’      disconnect,\n   116в†’      sendTransaction,\n   117в†’      signMessage,\n   118в†’    ],\n   119в†’  );\n   120в†’\n   121в†’  return (\n   122в†’    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n   123в†’  );\n   124в†’}\n   125в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"929bc1c4-3980-400a-9b3e-ccf51f837155","timestamp":"2026-03-19T19:14:50.660Z"}
