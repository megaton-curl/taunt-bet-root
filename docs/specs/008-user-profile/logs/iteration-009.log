{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AwSpw15fAymdaqCtV6G93C","type":"tool_result","content":"     1в†’/**\n     2в†’ * XP Calculator - Level and XP formulas for the player profile system\n     3в†’ *\n     4в†’ * Uses an exponential curve where higher levels require progressively more XP.\n     5в†’ * XP is earned from wagering in games, with bonuses for winning.\n     6в†’ */\n     7в†’\n     8в†’import type { BorderStyle } from \"../types\";\n     9в†’\n    10в†’// ============ XP Formula ============\n    11в†’\n    12в†’/**\n    13в†’ * Calculate the total XP required to reach a given level.\n    14в†’ * Formula: 50 * level^2 + 50 * level\n    15в†’ *\n    16в†’ * This creates an exponential curve:\n    17в†’ * - Level 5: 1,500 XP\n    18в†’ * - Level 10: 5,500 XP\n    19в†’ * - Level 25: 33,750 XP\n    20в†’ * - Level 50: 127,500 XP\n    21в†’ * - Level 100: 505,000 XP\n    22в†’ */\n    23в†’export function getXPForLevel(level: number): number {\n    24в†’  if (level <= 1) return 0;\n    25в†’  return Math.floor(50 * Math.pow(level, 2) + 50 * level);\n    26в†’}\n    27в†’\n    28в†’/**\n    29в†’ * Calculate level from total XP earned.\n    30в†’ * Solves 50LВІ + 50L = XP directly (no level cap).\n    31в†’ */\n    32в†’export function getLevelFromXP(totalXP: number): number {\n    33в†’  if (totalXP <= 0) return 1;\n    34в†’  // Quadratic formula: L = (-1 + sqrt(1 + XP/12.5)) / 2\n    35в†’  const level = Math.floor((-1 + Math.sqrt(1 + totalXP / 12.5)) / 2);\n    36в†’  return Math.max(1, level);\n    37в†’}\n    38в†’\n    39в†’/**\n    40в†’ * Get detailed XP progress information for a given total XP.\n    41в†’ */\n    42в†’export interface XPProgress {\n    43в†’  level: number;\n    44в†’  currentXP: number; // XP earned since reaching current level\n    45в†’  xpForNextLevel: number; // Total XP needed to reach next level\n    46в†’  xpNeededForNext: number; // Remaining XP needed for next level\n    47в†’  progressPercent: number; // 0-100 progress through current level\n    48в†’  isMaxLevel: boolean;\n    49в†’}\n    50в†’\n    51в†’export function getXPProgress(totalXP: number): XPProgress {\n    52в†’  const level = getLevelFromXP(totalXP);\n    53в†’\n    54в†’  const currentLevelXP = getXPForLevel(level);\n    55в†’  const nextLevelXP = getXPForLevel(level + 1);\n    56в†’\n    57в†’  const currentXP = totalXP - currentLevelXP;\n    58в†’  const xpNeededForNext = nextLevelXP - currentLevelXP;\n    59в†’  const xpNeededRemaining = Math.max(0, nextLevelXP - totalXP);\n    60в†’\n    61в†’  const progressPercent = xpNeededForNext > 0\n    62в†’    ? Math.min(100, (currentXP / xpNeededForNext) * 100)\n    63в†’    : 100;\n    64в†’\n    65в†’  return {\n    66в†’    level,\n    67в†’    currentXP,\n    68в†’    xpForNextLevel: nextLevelXP,\n    69в†’    xpNeededForNext: xpNeededRemaining,\n    70в†’    progressPercent,\n    71в†’    isMaxLevel: false,\n    72в†’  };\n    73в†’}\n    74в†’\n    75в†’// ============ XP Earning ============\n    76в†’\n    77в†’/**\n    78в†’ * Base XP rate: 100 XP per SOL wagered.\n    79в†’ */\n    80в†’const BASE_XP_PER_SOL = 100;"}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"fa0f9c7a-4b68-4fdd-b675-b8de8db7238f","timestamp":"2026-03-19T19:12:43.264Z"}
