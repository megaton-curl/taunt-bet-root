{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DDh7vPJ5kQNtAsuGBUFPKF","type":"tool_result","content":"     1в†’/**\n     2в†’ * Deterministic wallet-funding helper for local E2E tests.\n     3в†’ *\n     4в†’ * Generates fixed keypairs from seed bytes so tests are reproducible,\n     5в†’ * then airdrops SOL and confirms before tests run.\n     6в†’ */\n     7в†’import {\n     8в†’  Connection,\n     9в†’  Keypair,\n    10в†’  LAMPORTS_PER_SOL,\n    11в†’  PublicKey,\n    12в†’} from \"@solana/web3.js\";\n    13в†’\n    14в†’// --- Deterministic keypairs ---\n    15в†’// Fixed 32-byte seeds produce the same keypairs on every run.\n    16в†’const SEED_PLAYER_A = new Uint8Array(32).fill(0xaa);\n    17в†’const SEED_PLAYER_B = new Uint8Array(32).fill(0xbb);\n    18в†’\n    19в†’export const PLAYER_A = Keypair.fromSeed(SEED_PLAYER_A);\n    20в†’export const PLAYER_B = Keypair.fromSeed(SEED_PLAYER_B);\n    21в†’\n    22в†’/** Default RPC URL for local test validator. */\n    23в†’export const LOCAL_RPC_URL = \"http://127.0.0.1:8899\";\n    24в†’\n    25в†’/** Default airdrop amount per wallet (10 SOL). */\n    26в†’const DEFAULT_AIRDROP_SOL = 10;\n    27в†’\n    28в†’/**\n    29в†’ * Airdrop SOL to a single wallet and confirm the transaction.\n    30в†’ *\n    31в†’ * @param connection - Solana RPC connection\n    32в†’ * @param to - Public key to fund\n    33в†’ * @param solAmount - Amount in SOL (default: 10)\n    34в†’ */\n    35в†’export async function fundWallet(\n    36в†’  connection: Connection,\n    37в†’  to: PublicKey,\n    38в†’  solAmount = DEFAULT_AIRDROP_SOL,\n    39в†’): Promise<void> {\n    40в†’  const lamports = solAmount * LAMPORTS_PER_SOL;\n    41в†’  const sig = await connection.requestAirdrop(to, lamports);\n    42в†’  const { blockhash, lastValidBlockHeight } =\n    43в†’    await connection.getLatestBlockhash();\n    44в†’  await connection.confirmTransaction(\n    45в†’    { signature: sig, blockhash, lastValidBlockHeight },\n    46в†’    \"confirmed\",\n    47в†’  );\n    48в†’}\n    49в†’\n    50в†’/**\n    51в†’ * Fund both test players on the local validator.\n    52в†’ * Call this in a `beforeAll` or global setup before the E2E suite starts.\n    53в†’ *\n    54в†’ * @param rpcUrl - RPC endpoint (default: local validator)\n    55в†’ * @param solAmount - SOL to airdrop per player (default: 10)\n    56в†’ */\n    57в†’export async function fundTestWallets(\n    58в†’  rpcUrl = LOCAL_RPC_URL,\n    59в†’  solAmount = DEFAULT_AIRDROP_SOL,\n    60в†’): Promise<{ playerA: Keypair; playerB: Keypair; connection: Connection }> {\n    61в†’  const connection = new Connection(rpcUrl, \"confirmed\");\n    62в†’\n    63в†’  await Promise.all([\n    64в†’    fundWallet(connection, PLAYER_A.publicKey, solAmount),\n    65в†’    fundWallet(connection, PLAYER_B.publicKey, solAmount),\n    66в†’  ]);\n    67в†’\n    68в†’  // Sanity-check: verify balances are present\n    69в†’  const [balA, balB] = await Promise.all([\n    70в†’    connection.getBalance(PLAYER_A.publicKey),\n    71в†’    connection.getBalance(PLAYER_B.publicKey),\n    72в†’  ]);\n    73в†’\n    74в†’  const minExpected = solAmount * LAMPORTS_PER_SOL;\n    75в†’  if (balA < minExpected) {\n    76в†’    throw new Error(\n    77в†’      `Player A funding failed: expected >= ${minExpected} lamports, got ${balA}`,\n    78в†’    );\n    79в†’  }\n    80в†’  if (balB < minExpected) {\n    81в†’    throw new Error(\n    82в†’      `Player B funding failed: expected >= ${minExpected} lamports, got ${balB}`,\n    83в†’    );\n    84в†’  }\n    85в†’\n    86в†’  return { playerA: PLAYER_A, playerB: PLAYER_B, connection };\n    87в†’}\n    88в†’"}]},"parent_tool_use_id":"toolu_01HeJfpFiA1rSVyi58U1gKAc","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"21132432-d0f6-4ba2-8ad0-4f33f664b582","timestamp":"2026-03-19T19:12:36.360Z"}
