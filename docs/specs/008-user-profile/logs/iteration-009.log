{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01LDLimKEmPx9jsQZ8QS8YHV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GkiSztFPJLJBzGHd7H4SB1","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/utils/mock-simulation.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":5,"cache_creation_input_tokens":5721,"cache_read_input_tokens":24758,"cache_creation":{"ephemeral_5m_input_tokens":5721,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"7bb4bcc1-1408-423c-9b46-4729c6b3f789"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GkiSztFPJLJBzGHd7H4SB1","type":"tool_result","content":"     1в†’/**\n     2в†’ * Mock Simulation - In-memory profile store for player profiles\n     3в†’ *\n     4в†’ * Manages player profile data, XP, stats, loot, and transactions.\n     5в†’ * Data is stored in memory and persists for the session.\n     6в†’ */\n     7в†’\n     8в†’import type {\n     9в†’  AvatarId,\n    10в†’  GameId,\n    11в†’  GameResultEvent,\n    12в†’  LootItem,\n    13в†’  LootSource,\n    14в†’  PlayerProfile,\n    15в†’  ProfileTransaction,\n    16в†’} from \"../types\";\n    17в†’import { AVATAR_CONFIGS, createEmptyStats, getHighestUnlockedAvatar } from \"../types\";\n    18в†’import { calculateGameXP, getXPProgress, getXPForLevel } from \"./xp-calculator\";\n    19в†’\n    20в†’// ============ Random Username Generator ============\n    21в†’\n    22в†’const USERNAME_ADJECTIVES = [\n    23в†’  \"Lucky\", \"Swift\", \"Brave\", \"Cosmic\", \"Neon\", \"Cyber\", \"Pixel\", \"Crypto\",\n    24в†’  \"Shadow\", \"Thunder\", \"Golden\", \"Silver\", \"Diamond\", \"Mystic\", \"Turbo\", \"Mega\",\n    25в†’  \"Ultra\", \"Super\", \"Hyper\", \"Epic\", \"Savage\", \"Wild\", \"Blazing\", \"Frozen\",\n    26в†’  \"Phantom\", \"Stellar\", \"Atomic\", \"Quantum\", \"Nova\", \"Solar\", \"Lunar\", \"Astral\",\n    27в†’];\n    28в†’\n    29в†’const USERNAME_NOUNS = [\n    30в†’  \"Player\", \"Gamer\", \"Raider\", \"Trader\", \"Flipper\", \"Whale\", \"Shark\", \"Wolf\",\n    31в†’  \"Dragon\", \"Phoenix\", \"Knight\", \"Wizard\", \"Ninja\", \"Samurai\", \"Viking\", \"Pirate\",\n    32в†’  \"Hunter\", \"Seeker\", \"Runner\", \"Rider\", \"Degen\", \"Ape\", \"Chad\", \"King\",\n    33в†’  \"Queen\", \"Ace\", \"Legend\", \"Hero\", \"Master\", \"Boss\", \"Chief\", \"Captain\",\n    34в†’];\n    35в†’\n    36в†’/**\n    37в†’ * Generate a random username like \"CosmicWhale42\" or \"NeonDragon17\"\n    38в†’ */\n    39в†’function generateRandomUsername(): string {\n    40в†’  const adjective = USERNAME_ADJECTIVES[Math.floor(Math.random() * USERNAME_ADJECTIVES.length)];\n    41в†’  const noun = USERNAME_NOUNS[Math.floor(Math.random() * USERNAME_NOUNS.length)];\n    42в†’  const number = Math.floor(Math.random() * 100);\n    43в†’  return `${adjective}${noun}${number}`;\n    44в†’}\n    45в†’\n    46в†’/**\n    47в†’ * Generate a random level with weighted distribution.\n    48в†’ * Most players are lower level, with fewer high-level players.\n    49в†’ */\n    50в†’function generateRandomLevel(): number {\n    51в†’  const rand = Math.random();\n    52в†’  // Weighted distribution: 50% levels 1-15, 30% levels 16-40, 15% levels 41-70, 5% levels 71-100\n    53в†’  if (rand < 0.5) {\n    54в†’    return Math.floor(Math.random() * 15) + 1; // 1-15\n    55в†’  } else if (rand < 0.8) {\n    56в†’    return Math.floor(Math.random() * 25) + 16; // 16-40\n    57в†’  } else if (rand < 0.95) {\n    58в†’    return Math.floor(Math.random() * 30) + 41; // 41-70\n    59в†’  } else {\n    60в†’    return Math.floor(Math.random() * 30) + 71; // 71-100\n    61в†’  }\n    62в†’}\n    63в†’\n    64в†’/**\n    65в†’ * Get a random unlocked avatar for a given level.\n    66в†’ * Picks randomly from all avatars the player could have unlocked.\n    67в†’ */\n    68в†’function getRandomUnlockedAvatar(level: number): AvatarId {\n    69в†’  const unlockedAvatars = AVATAR_CONFIGS.filter(a => a.unlockLevel <= level);\n    70в†’  if (unlockedAvatars.length === 0) return \"recruit\";\n    71в†’  const randomIndex = Math.floor(Math.random() * unlockedAvatars.length);\n    72в†’  return unlockedAvatars[randomIndex]?.id ?? \"recruit\";\n    73в†’}\n    74в†’\n    75в†’// ============ Store ============\n    76в†’\n    77в†’interface ProfileStore {\n    78в†’  profiles: Map<string, PlayerProfile>;\n    79в†’  transactions: Map<string, ProfileTransaction[]>;\n    80в†’  profileListeners: Set<(address: string, profile: PlayerProfile) => void>;\n    81в†’  isInitialized: boolean;\n    82в†’}\n    83в†’\n    84в†’const store: ProfileStore = {\n    85в†’  profiles: new Map(),\n    86в†’  transactions: new Map(),\n    87в†’  profileListeners: new Set(),\n    88в†’  isInitialized: false,\n    89в†’};\n    90в†’\n    91в†’// ============ Initialization ============\n    92в†’\n    93в†’/**\n    94в†’ * Initialize the profile store. Called once on app start.\n    95в†’ */\n    96в†’export function initializeProfileStore(): void {\n    97в†’  if (store.isInitialized) return;\n    98в†’\n    99в†’  // Generate some mock profiles for other players\n   100в†’  generateMockProfiles();\n   101в†’\n   102в†’  store.isInitialized = true;\n   103в†’}\n   104в†’\n   105в†’/**\n   106в†’ * Generate mock profiles for demonstration purposes.\n   107в†’ */\n   108в†’function generateMockProfiles(): void {\n   109в†’  const mockPlayers = [\n   110в†’    { address: \"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"CryptoKing\", level: 72 },\n   111в†’    { address: \"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"LuckyDice\", level: 15 },\n   112в†’    { address: \"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"WhaleWatch\", level: 45 },\n   113в†’    { address: \"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: null, level: 3 },\n   114в†’    { address: \"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"RNGMaster\", level: 88 },\n   115в†’    { address: \"DemoPlayer6xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"VoidWalker\", level: 25 },\n   116в†’    { address: \"DemoPlayer7xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"ShamanKing\", level: 55 },\n   117в†’    { address: \"DemoPlayer8xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"TheParagon\", level: 35 },\n   118в†’  ];\n   119в†’\n   120в†’  for (const mock of mockPlayers) {\n   121в†’    // Calculate proper XP for the level\n   122в†’    const totalXP = getXPForLevel(mock.level) + Math.floor(Math.random() * 200);\n   123в†’    const xpProgress = getXPProgress(totalXP);\n   124в†’    const profile = createProfile(mock.address);\n   125в†’    profile.username = mock.username;\n   126в†’    profile.level = mock.level;\n   127в†’    profile.totalXP = totalXP;\n   128в†’    profile.currentXP = xpProgress.currentXP;\n   129в†’    // Assign the highest unlocked avatar for their level\n   130в†’    profile.avatarId = getHighestUnlockedAvatar(mock.level);\n   131в†’\n   132в†’    // Add some random stats\n   133в†’    profile.stats.gamesPlayed = Math.floor(Math.random() * 200) + 10;\n   134в†’    profile.stats.totalWagered = Math.random() * 100 + 5;\n   135в†’    profile.stats.wins = Math.floor(profile.stats.gamesPlayed * (0.4 + Math.random() * 0.2));\n   136в†’    profile.stats.losses = profile.stats.gamesPlayed - profile.stats.wins;\n   137в†’    profile.stats.totalWins = profile.stats.totalWagered * (0.8 + Math.random() * 0.4);\n   138в†’    profile.stats.netProfit = profile.stats.totalWins - profile.stats.totalWagered;\n   139в†’    profile.stats.bestWinStreak = Math.floor(Math.random() * 10) + 1;\n   140в†’    profile.stats.currentWinStreak = Math.floor(Math.random() * profile.stats.bestWinStreak);\n   141в†’\n   142в†’    store.profiles.set(mock.address, profile);\n   143в†’  }\n   144в†’}\n   145в†’\n   146в†’// ============ Profile CRUD ============\n   147в†’\n   148в†’/**\n   149в†’ * Create a new profile for an address with random username, level, and avatar.\n   150в†’ * @param forceLevel - Optional level to force (for testing). Defaults to random.\n   151в†’ */\n   152в†’function createProfile(address: string, forceLevel?: number): PlayerProfile {\n   153в†’  // Generate level and calculate XP (use forced level if provided)\n   154в†’  const level = forceLevel ?? generateRandomLevel();\n   155в†’  const totalXP = getXPForLevel(level) + Math.floor(Math.random() * 200);\n   156в†’  const xpProgress = getXPProgress(totalXP);\n   157в†’\n   158в†’  // Pick a random unlocked avatar for this level\n   159в†’  const avatarId = getRandomUnlockedAvatar(level);\n   160в†’\n   161в†’  // Generate random stats based on level\n   162в†’  const gamesPlayed = Math.floor(Math.random() * (level * 5)) + level;\n   163в†’  const wins = Math.floor(gamesPlayed * (0.4 + Math.random() * 0.2));\n   164в†’  const losses = gamesPlayed - wins;\n   165в†’  const totalWagered = Math.random() * (level * 2) + 1;\n   166в†’  const totalWins = totalWagered * (0.8 + Math.random() * 0.4);\n   167в†’  const netProfit = totalWins - totalWagered;\n   168в†’  const bestWinStreak = Math.floor(Math.random() * Math.min(10, level)) + 1;\n   169в†’\n   170в†’  const stats = createEmptyStats();\n   171в†’  stats.gamesPlayed = gamesPlayed;\n   172в†’  stats.totalWagered = totalWagered;\n   173в†’  stats.totalWins = totalWins;\n   174в†’  stats.netProfit = netProfit;\n   175в†’  stats.wins = wins;\n   176в†’  stats.losses = losses;\n   177в†’  stats.bestWinStreak = bestWinStreak;\n   178в†’  stats.currentWinStreak = Math.floor(Math.random() * bestWinStreak);\n   179в†’\n   180в†’  return {\n   181в†’    address,\n   182в†’    username: generateRandomUsername(),\n   183в†’    avatarId,\n   184в†’    level,\n   185в†’    currentXP: xpProgress.currentXP,\n   186в†’    totalXP,\n   187в†’    discordUsername: null,\n   188в†’    twitterHandle: null,\n   189в†’    stats,\n   190в†’    unclaimedLoot: [],\n   191в†’    createdAt: Date.now(),\n   192в†’    lastActiveAt: Date.now(),\n   193в†’  };\n   194в†’}\n   195в†’\n   196в†’/**\n   197в†’ * Get a profile by address. Returns null if not found.\n   198в†’ */\n   199в†’export function getProfile(address: string): PlayerProfile | null {\n   200в†’  return store.profiles.get(address) ?? null;\n   201в†’}\n   202в†’\n   203в†’/**\n   204в†’ * Get or create a profile for an address.\n   205в†’ * @param forceLevel - Optional level to force for new profiles (for testing).\n   206в†’ */\n   207в†’export function getOrCreateProfile(address: string, forceLevel?: number): PlayerProfile {\n   208в†’  let profile = store.profiles.get(address);\n   209в†’  if (!profile) {\n   210в†’    profile = createProfile(address, forceLevel);\n   211в†’    store.profiles.set(address, profile);\n   212в†’    notifyListeners(address, profile);\n   213в†’  } else if (forceLevel !== undefined && profile.level !== forceLevel) {\n   214в†’    // Apply forced level to existing profiles (for testing)\n   215в†’    const totalXP = getXPForLevel(forceLevel) + Math.floor(Math.random() * 200);\n   216в†’    const xpProgress = getXPProgress(totalXP);\n   217в†’    profile.level = forceLevel;\n   218в†’    profile.totalXP = totalXP;\n   219в†’    profile.currentXP = xpProgress.currentXP;\n   220в†’    store.profiles.set(address, profile);\n   221в†’    notifyListeners(address, profile);\n   222в†’  }\n   223в†’  return { ...profile };\n   224в†’}\n   225в†’\n   226в†’/**\n   227в†’ * Update a profile with partial data.\n   228в†’ */\n   229в†’export function updateProfile(\n   230в†’  address: string,\n   231в†’  updates: Partial<Omit<PlayerProfile, \"address\" | \"createdAt\">>\n   232в†’): PlayerProfile {\n   233в†’  const profile = getOrCreateProfile(address);\n   234в†’  const updatedProfile = {\n   235в†’    ...profile,\n   236в†’    ...updates,\n   237в†’    lastActiveAt: Date.now(),\n   238в†’  };\n   239в†’  store.profiles.set(address, updatedProfile);\n   240в†’  notifyListeners(address, updatedProfile);\n   241в†’  return { ...updatedProfile };\n   242в†’}\n   243в†’\n   244в†’// ============ Profile Mutations ============\n   245в†’\n   246в†’/**\n   247в†’ * Update username for a profile.\n   248в†’ */\n   249в†’export function updateUsername(address: string, username: string | null): PlayerProfile {\n   250в†’  return updateProfile(address, { username });\n   251в†’}\n   252в†’\n   253в†’/**\n   254в†’ * Update avatar for a profile.\n   255в†’ */\n   256в†’export function updateAvatar(address: string, avatarId: AvatarId): PlayerProfile {\n   257в†’  return updateProfile(address, { avatarId });\n   258в†’}\n   259в†’\n   260в†’/**\n   261в†’ * Connect Discord to a profile.\n   262в†’ */\n   263в†’export function connectDiscord(address: string, discordUsername: string): PlayerProfile {\n   264в†’  return updateProfile(address, { discordUsername });\n   265в†’}\n   266в†’\n   267в†’/**\n   268в†’ * Disconnect Discord from a profile.\n   269в†’ */\n   270в†’export function disconnectDiscord(address: string): PlayerProfile {\n   271в†’  return updateProfile(address, { discordUsername: null });\n   272в†’}\n   273в†’\n   274в†’/**\n   275в†’ * Connect Twitter to a profile.\n   276в†’ */\n   277в†’export function connectTwitter(address: string, twitterHandle: string): PlayerProfile {\n   278в†’  return updateProfile(address, { twitterHandle });\n   279в†’}\n   280в†’\n   281в†’/**\n   282в†’ * Disconnect Twitter from a profile.\n   283в†’ */\n   284в†’export function disconnectTwitter(address: string): PlayerProfile {\n   285в†’  return updateProfile(address, { twitterHandle: null });\n   286в†’}\n   287в†’\n   288в†’// ============ XP and Stats ============\n   289в†’\n   290в†’/**\n   291в†’ * Award XP to a player and update their level.\n   292в†’ */\n   293в†’export function awardXP(address: string, xp: number): PlayerProfile {\n   294в†’  const profile = getOrCreateProfile(address);\n   295в†’  const newTotalXP = profile.totalXP + xp;\n   296в†’  const xpProgress = getXPProgress(newTotalXP);\n   297в†’\n   298в†’  return updateProfile(address, {\n   299в†’    totalXP: newTotalXP,\n   300в†’    level: xpProgress.level,\n   301в†’    currentXP: xpProgress.currentXP,\n   302в†’  });\n   303в†’}\n   304в†’\n   305в†’/**\n   306в†’ * Record a game result and update stats accordingly.\n   307в†’ */\n   308в†’export function recordGameResult(event: GameResultEvent): void {\n   309в†’  const profile = getOrCreateProfile(event.playerAddress);\n   310в†’  const { gameId, wagerAmount, outcome, payoutAmount } = event;\n   311в†’\n   312в†’  // Calculate XP earned\n   313в†’  const xpEarned = calculateGameXP(wagerAmount, outcome === \"win\");\n   314в†’\n   315в†’  // Update aggregate stats\n   316в†’  const newStats = { ...profile.stats };\n   317в†’  newStats.gamesPlayed += 1;\n   318в†’  newStats.totalWagered += wagerAmount;\n   319в†’\n   320в†’  if (outcome === \"win\") {\n   321в†’    newStats.wins += 1;\n   322в†’    newStats.totalWins += payoutAmount;\n   323в†’    newStats.currentWinStreak += 1;\n   324в†’    if (newStats.currentWinStreak > newStats.bestWinStreak) {\n   325в†’      newStats.bestWinStreak = newStats.currentWinStreak;\n   326в†’    }\n   327в†’  } else {\n   328в†’    newStats.losses += 1;\n   329в†’    newStats.currentWinStreak = 0;\n   330в†’  }\n   331в†’\n   332в†’  newStats.netProfit = newStats.totalWins - newStats.totalWagered;\n   333в†’\n   334в†’  // Update per-game stats\n   335в†’  const gameStats = newStats.gameStats[gameId];\n   336в†’  gameStats.gamesPlayed += 1;\n   337в†’  gameStats.wagered += wagerAmount;\n   338в†’  if (outcome === \"win\") {\n   339в†’    gameStats.wins += 1;\n   340в†’    gameStats.winnings += payoutAmount;\n   341в†’  } else {\n   342в†’    gameStats.losses += 1;\n   343в†’  }\n   344в†’\n   345в†’  // Update profile with new stats\n   346в†’  const newTotalXP = profile.totalXP + xpEarned;\n   347в†’  const xpProgress = getXPProgress(newTotalXP);\n   348в†’\n   349в†’  updateProfile(event.playerAddress, {\n   350в†’    stats: newStats,\n   351в†’    totalXP: newTotalXP,\n   352в†’    level: xpProgress.level,\n   353в†’    currentXP: xpProgress.currentXP,\n   354в†’  });\n   355в†’\n   356в†’  // Record transaction\n   357в†’  recordTransaction(event);\n   358в†’}\n   359в†’\n   360в†’// ============ Transactions ============\n   361в†’\n   362в†’/**\n   363в†’ * Record a transaction for a game result.\n   364в†’ * Creates event-based rows matching the API shape (join + outcome).\n   365в†’ */\n   366в†’function recordTransaction(event: GameResultEvent): void {\n   367в†’  const { gameId, matchId, playerAddress, wagerAmount, outcome, payoutAmount, timestamp } = event;\n   368в†’\n   369в†’  const now = new Date(timestamp).toISOString();\n   370в†’  const wagerLamports = String(Math.round(wagerAmount * 1e9));\n   371в†’  const payoutLamports = String(Math.round(payoutAmount * 1e9));\n   372в†’\n   373в†’  const transactions = store.transactions.get(playerAddress) ?? [];\n   374в†’\n   375в†’  // Outcome event (most recent first)\n   376в†’  transactions.unshift({\n   377в†’    id: `tx-${Date.now()}-${Math.random().toString(36).slice(2, 8)}-out`,\n   378в†’    gameId,\n   379в†’    matchId,\n   380в†’    event: outcome,\n   381в†’    amountLamports: outcome === \"win\" ? payoutLamports : wagerLamports,\n   382в†’    txSig: null,\n   383в†’    createdAt: now,\n   384в†’  });\n   385в†’\n   386в†’  // Join event\n   387в†’  transactions.unshift({\n   388в†’    id: `tx-${Date.now()}-${Math.random().toString(36).slice(2, 8)}-join`,\n   389в†’    gameId,\n   390в†’    matchId,\n   391в†’    event: \"join\",\n   392в†’    amountLamports: wagerLamports,\n   393в†’    txSig: null,\n   394в†’    createdAt: now,\n   395в†’  });\n   396в†’\n   397в†’  // Keep only last 100 transactions per player\n   398в†’  while (transactions.length > 100) transactions.pop();\n   399в†’\n   400в†’  store.transactions.set(playerAddress, transactions);\n   401в†’}\n   402в†’\n   403в†’/**\n   404в†’ * Get transactions for a player.\n   405в†’ */\n   406в†’export function getTransactions(address: string, limit = 50): ProfileTransaction[] {\n   407в†’  const transactions = store.transactions.get(address) ?? [];\n   408в†’  return transactions.slice(0, limit);\n   409в†’}\n   410в†’\n   411в†’// ============ Loot System ============\n   412в†’\n   413в†’/**\n   414в†’ * Generate a unique loot ID.\n   415в†’ */\n   416в†’function generateLootId(): string {\n   417в†’  return `loot-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n   418в†’}\n   419в†’\n   420в†’/**\n   421в†’ * Add loot to a player's unclaimed rewards.\n   422в†’ */\n   423в†’export function addLoot(\n   424в†’  address: string,\n   425в†’  source: LootSource,\n   426в†’  amount: number,\n   427в†’  description: string,\n   428в†’  gameId?: GameId,\n   429в†’  matchId?: string,\n   430в†’  expiresAt?: number\n   431в†’): void {\n   432в†’  const profile = getOrCreateProfile(address);\n   433в†’\n   434в†’  const lootItem: LootItem = {\n   435в†’    id: generateLootId(),\n   436в†’    source,\n   437в†’    amount,\n   438в†’    description,\n   439в†’    earnedAt: Date.now(),\n   440в†’    expiresAt,\n   441в†’    gameId,\n   442в†’    matchId,\n   443в†’  };\n   444в†’\n   445в†’  const newUnclaimedLoot = [...profile.unclaimedLoot, lootItem];\n   446в†’  updateProfile(address, { unclaimedLoot: newUnclaimedLoot });\n   447в†’}\n   448в†’\n   449в†’/**\n   450в†’ * Claim a specific loot item. Returns the claimed amount.\n   451в†’ */\n   452в†’export function claimLoot(address: string, lootId: string): number {\n   453в†’  const profile = getOrCreateProfile(address);\n   454в†’  const lootItem = profile.unclaimedLoot.find((l) => l.id === lootId);\n   455в†’\n   456в†’  if (!lootItem) {\n   457в†’    return 0;\n   458в†’  }\n   459в†’\n   460в†’  const newUnclaimedLoot = profile.unclaimedLoot.filter((l) => l.id !== lootId);\n   461в†’  updateProfile(address, { unclaimedLoot: newUnclaimedLoot });\n   462в†’\n   463в†’  return lootItem.amount;\n   464в†’}\n   465в†’\n   466в†’/**\n   467в†’ * Claim all unclaimed loot. Returns the total claimed amount.\n   468в†’ */\n   469в†’export function claimAllLoot(address: string): number {\n   470в†’  const profile = getOrCreateProfile(address);\n   471в†’  const totalAmount = profile.unclaimedLoot.reduce((sum, loot) => sum + loot.amount, 0);\n   472в†’\n   473в†’  updateProfile(address, { unclaimedLoot: [] });\n   474в†’\n   475в†’  return totalAmount;\n   476в†’}\n   477в†’\n   478в†’/**\n   479в†’ * Get total unclaimed loot amount for a player.\n   480в†’ */\n   481в†’export function getUnclaimedLootTotal(address: string): number {\n   482в†’  const profile = getProfile(address);\n   483в†’  if (!profile) return 0;\n   484в†’  return profile.unclaimedLoot.reduce((sum, loot) => sum + loot.amount, 0);\n   485в†’}\n   486в†’\n   487в†’// ============ Subscriptions ============\n   488в†’\n   489в†’/**\n   490в†’ * Subscribe to profile updates.\n   491в†’ */\n   492в†’export function subscribeToProfiles(\n   493в†’  callback: (address: string, profile: PlayerProfile) => void\n   494в†’): () => void {\n   495в†’  store.profileListeners.add(callback);\n   496в†’  return () => {\n   497в†’    store.profileListeners.delete(callback);\n   498в†’  };\n   499в†’}\n   500в†’\n   501в†’/**\n   502в†’ * Notify all listeners of a profile update.\n   503в†’ */\n   504в†’function notifyListeners(address: string, profile: PlayerProfile): void {\n   505в†’  store.profileListeners.forEach((callback) => {\n   506в†’    try {\n   507в†’      callback(address, { ...profile });\n   508в†’    } catch (error) {\n   509в†’      console.error(\"[ProfileStore] Error in listener:\", error);\n   510в†’    }\n   511в†’  });\n   512в†’}\n   513в†’\n   514в†’// ============ Display Helpers ============\n   515в†’\n   516в†’/**\n   517в†’ * Truncate an address for display.\n   518в†’ */\n   519в†’export function truncateAddress(address: string): string {\n   520в†’  if (address.length <= 10) return address;\n   521в†’  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n   522в†’}\n   523в†’\n   524в†’/**\n   525в†’ * Get display name for an address.\n   526в†’ * Creates a profile with a random username if one doesn't exist.\n   527в†’ */\n   528в†’export function getDisplayName(address: string): string {\n   529в†’  const profile = getOrCreateProfile(address);\n   530в†’  return profile.username ?? truncateAddress(address);\n   531в†’}\n   532в†’\n   533в†’/**\n   534в†’ * Get avatar ID for an address.\n   535в†’ * Creates a profile if one doesn't exist.\n   536в†’ */\n   537в†’export function getAvatarId(address: string): AvatarId {\n   538в†’  const profile = getOrCreateProfile(address);\n   539в†’  return profile.avatarId;\n   540в†’}\n   541в†’\n   542в†’/**\n   543в†’ * Get level for an address.\n   544в†’ * Creates a profile if one doesn't exist.\n   545в†’ */\n   546в†’export function getLevel(address: string): number {\n   547в†’  const profile = getOrCreateProfile(address);\n   548в†’  return profile.level;\n   549в†’}\n   550в†’\n   551в†’// ============ Debug / Testing ============\n   552в†’\n   553в†’/**\n   554в†’ * Clear all profile data (for testing).\n   555в†’ */\n   556в†’export function clearAllProfiles(): void {\n   557в†’  store.profiles.clear();\n   558в†’  store.transactions.clear();\n   559в†’  store.isInitialized = false;\n   560в†’}\n   561в†’\n   562в†’/**\n   563в†’ * Get all profiles (for debugging).\n   564в†’ */\n   565в†’export function getAllProfiles(): PlayerProfile[] {\n   566в†’  return Array.from(store.profiles.values());\n   567в†’}\n   568в†’"}]},"parent_tool_use_id":"toolu_013Pmzpya56sxen9GEbE9TSS","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"872f0d85-7f5b-49fb-8ff0-23bf733e1247","timestamp":"2026-03-19T19:12:27.714Z"}
