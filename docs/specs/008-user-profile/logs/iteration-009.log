{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dp1heVWzNZAV9iyWbxU594","type":"tool_result","content":"     1в†’import { defineConfig, devices } from \"@playwright/test\";\n     2в†’\n     3в†’/**\n     4в†’ * Playwright config for devnet E2E integration tests.\n     5в†’ *\n     6в†’ * Runs against deployed devnet contracts with real VRF fulfillment.\n     7в†’ * Does NOT start a local validator or deploy programs вЂ” requires\n     8в†’ * pre-deployed contracts and env vars (see e2e/devnet/helpers/env.ts).\n     9в†’ *\n    10в†’ * Required env vars (set before running, or in .env.devnet):\n    11в†’ *   VITE_RPC_URL                вЂ” Devnet RPC endpoint\n    12в†’ *   VITE_COINFLIP_PROGRAM_ID   вЂ” Deployed coinflip program address\n    13в†’ *   VITE_PLATFORM_PROGRAM_ID   вЂ” Deployed platform program address\n    14в†’ *\n    15в†’ * Optional:\n    16в†’ *   VITE_SOLANA_NETWORK        вЂ” Cluster name (default: \"devnet\")\n    17в†’ */\n    18в†’export default defineConfig({\n    19в†’  testDir: \"./e2e\",\n    20в†’  fullyParallel: false,\n    21в†’  forbidOnly: !!process.env.CI,\n    22в†’  retries: 2,\n    23в†’  workers: 1,\n    24в†’  reporter: \"list\",\n    25в†’  // Longer timeout: VRF fulfillment can take up to 180s + assertions + cleanup\n    26в†’  timeout: 300_000,\n    27в†’\n    28в†’  use: {\n    29в†’    baseURL: \"http://localhost:3003\",\n    30в†’    screenshot: \"only-on-failure\",\n    31в†’    trace: \"retain-on-failure\",\n    32в†’    video: \"on\",\n    33в†’    ...devices[\"Desktop Chrome\"],\n    34в†’    viewport: { width: 1280, height: 1080 },\n    35в†’  },\n    36в†’\n    37в†’  projects: [\n    38в†’    {\n    39в†’      name: \"devnet-e2e\",\n    40в†’      testMatch: \"devnet/**/*.spec.ts\",\n    41в†’      use: {\n    42в†’        ...devices[\"Desktop Chrome\"],\n    43в†’        viewport: { width: 1280, height: 1080 },\n    44в†’      },\n    45в†’    },\n    46в†’  ],\n    47в†’\n    48в†’  webServer: {\n    49в†’    command: \"npx vite --port 3003\",\n    50в†’    url: \"http://localhost:3003\",\n    51в†’    reuseExistingServer: !process.env.CI,\n    52в†’    timeout: 30_000,\n    53в†’    env: {\n    54в†’      VITE_MOCK_MODE: \"false\",\n    55в†’      VITE_TEST_WALLET: \"true\",\n    56в†’      // RPC URL and program IDs are inherited from the process environment.\n    57в†’      // They must be set before running this config (see env.ts validation).\n    58в†’      // VITE_SOLANA_NETWORK defaults to \"devnet\" in the app if not set.\n    59в†’    },\n    60в†’  },\n    61в†’});\n    62в†’"}]},"parent_tool_use_id":"toolu_01HeJfpFiA1rSVyi58U1gKAc","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"2c9bc7fe-2a75-49df-a40c-c7439598f739","timestamp":"2026-03-19T19:12:54.612Z"}
