{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NDgLMxEawrERJTaYfj4wS5","type":"tool_result","content":"     1в†’/**\n     2в†’ * Player Profile Context - App-level state management for player profiles\n     3в†’ *\n     4в†’ * Provides access to:\n     5в†’ * - Current user's profile (when wallet connected)\n     6в†’ * - Profile lookup for other players\n     7в†’ * - Profile mutations (username, avatar, socials)\n     8в†’ * - Loot claiming\n     9в†’ * - Mini profile modal state\n    10в†’ * - Display helpers\n    11в†’ */\n    12в†’\n    13в†’import {\n    14в†’  createContext,\n    15в†’  useContext,\n    16в†’  useState,\n    17в†’  useEffect,\n    18в†’  useCallback,\n    19в†’  type ReactNode,\n    20в†’} from \"react\";\n    21в†’import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    22в†’import type {\n    23в†’  AvatarId,\n    24в†’  BorderStyle,\n    25в†’  PlayerProfile,\n    26в†’  PlayerProfileContextValue,\n    27в†’} from \"../types\";\n    28в†’import { AVATAR_CONFIGS } from \"../types\";\n    29в†’import { getBorderStyleFromLevel } from \"../utils/xp-calculator\";\n    30в†’import { profileEventBus } from \"../utils/profile-event-bus\";\n    31в†’import {\n    32в†’  initializeProfileStore,\n    33в†’  getProfile as getProfileFromStore,\n    34в†’  getOrCreateProfile,\n    35в†’  updateUsername as updateUsernameInStore,\n    36в†’  updateAvatar as updateAvatarInStore,\n    37в†’  connectDiscord as connectDiscordInStore,\n    38в†’  disconnectDiscord as disconnectDiscordInStore,\n    39в†’  connectTwitter as connectTwitterInStore,\n    40в†’  disconnectTwitter as disconnectTwitterInStore,\n    41в†’  claimLoot as claimLootFromStore,\n    42в†’  claimAllLoot as claimAllLootFromStore,\n    43в†’  recordGameResult,\n    44в†’  subscribeToProfiles,\n    45в†’  getDisplayName as getDisplayNameFromStore,\n    46в†’  getAvatarId as getAvatarIdFromStore,\n    47в†’  truncateAddress,\n    48в†’} from \"../utils/mock-simulation\";\n    49в†’\n    50в†’// ============ Context ============\n    51в†’\n    52в†’const PlayerProfileContext = createContext<PlayerProfileContextValue | null>(null);\n    53в†’\n    54в†’// ============ Provider ============\n    55в†’\n    56в†’interface PlayerProfileProviderProps {\n    57в†’  children: ReactNode;\n    58в†’}\n    59в†’\n    60в†’export function PlayerProfileProvider({ children }: PlayerProfileProviderProps) {\n    61в†’  const { address } = useWallet();\n    62в†’\n    63в†’  // State\n    64в†’  const [myProfile, setMyProfile] = useState<PlayerProfile | null>(null);\n    65в†’  const [loading, setLoading] = useState(true);\n    66в†’  const [selectedProfileAddress, setSelectedProfileAddress] = useState<string | null>(null);\n    67в†’\n    68в†’  // Initialize store on mount\n    69в†’  useEffect(() => {\n    70в†’    initializeProfileStore();\n    71в†’    setLoading(false);\n    72в†’  }, []);\n    73в†’\n    74в†’  // Load/create profile when wallet connects\n    75в†’  // Force level 100 for the connected wallet (testing purposes)\n    76в†’  useEffect(() => {\n    77в†’    if (address) {\n    78в†’      const profile = getOrCreateProfile(address, 100);\n    79в†’      setMyProfile(profile);\n    80в†’    } else {\n    81в†’      setMyProfile(null);\n    82в†’    }\n    83в†’  }, [address]);\n    84в†’\n    85в†’  // Subscribe to profile updates\n    86в†’  useEffect(() => {\n    87в†’    const unsubscribe = subscribeToProfiles((updatedAddress, profile) => {\n    88в†’      if (updatedAddress === address) {\n    89в†’        setMyProfile(profile);\n    90в†’      }\n    91в†’    });\n    92в†’\n    93в†’    return unsubscribe;\n    94в†’  }, [address]);\n    95в†’\n    96в†’  // Subscribe to game result events\n    97в†’  useEffect(() => {\n    98в†’    const unsubscribe = profileEventBus.subscribe((event) => {\n    99в†’      recordGameResult(event);\n   100в†’    });\n   101в†’\n   102в†’    return unsubscribe;\n   103в†’  }, []);\n   104в†’\n   105в†’  // ============ Profile Lookup ============\n   106в†’\n   107в†’  const getProfile = useCallback((targetAddress: string): PlayerProfile | null => {\n   108в†’    return getProfileFromStore(targetAddress);\n   109в†’  }, []);\n   110в†’\n   111в†’  const loadProfile = useCallback(async (targetAddress: string): Promise<PlayerProfile | null> => {\n   112в†’    // In mock mode, just return from store\n   113в†’    // In production, this would fetch from backend\n   114в†’    await new Promise((resolve) => setTimeout(resolve, 100)); // Simulate network delay\n   115в†’    return getOrCreateProfile(targetAddress);\n   116в†’  }, []);\n   117в†’\n   118в†’  // ============ Profile Mutations ============\n   119в†’\n   120в†’  const updateUsername = useCallback(async (username: string): Promise<void> => {\n   121в†’    if (!address) throw new Error(\"Wallet not connected\");\n   122в†’    await new Promise((resolve) => setTimeout(resolve, 300)); // Simulate network delay\n   123в†’    updateUsernameInStore(address, username);\n   124в†’  }, [address]);\n   125в†’\n   126в†’  const updateAvatar = useCallback(async (avatarId: AvatarId): Promise<void> => {\n   127в†’    if (!address) throw new Error(\"Wallet not connected\");\n   128в†’    updateAvatarInStore(address, avatarId);\n   129в†’  }, [address]);\n   130в†’\n   131в†’  const connectDiscord = useCallback(async (): Promise<void> => {\n   132в†’    if (!address) throw new Error(\"Wallet not connected\");\n   133в†’    // In production, this would open OAuth flow\n   134в†’    await new Promise((resolve) => setTimeout(resolve, 500));\n   135в†’    // Mock: generate a fake Discord username\n   136в†’    const mockUsername = `User${Math.floor(Math.random() * 10000)}`;\n   137в†’    connectDiscordInStore(address, mockUsername);\n   138в†’  }, [address]);\n   139в†’\n   140в†’  const disconnectDiscord = useCallback(async (): Promise<void> => {\n   141в†’    if (!address) throw new Error(\"Wallet not connected\");\n   142в†’    await new Promise((resolve) => setTimeout(resolve, 300));\n   143в†’    disconnectDiscordInStore(address);\n   144в†’  }, [address]);\n   145в†’\n   146в†’  const connectTwitter = useCallback(async (): Promise<void> => {\n   147в†’    if (!address) throw new Error(\"Wallet not connected\");\n   148в†’    // In production, this would open OAuth flow\n   149в†’    await new Promise((resolve) => setTimeout(resolve, 500));\n   150в†’    // Mock: generate a fake Twitter handle\n   151в†’    const mockHandle = `@user_${Math.floor(Math.random() * 10000)}`;\n   152в†’    connectTwitterInStore(address, mockHandle);\n   153в†’  }, [address]);\n   154в†’\n   155в†’  const disconnectTwitter = useCallback(async (): Promise<void> => {\n   156в†’    if (!address) throw new Error(\"Wallet not connected\");\n   157в†’    await new Promise((resolve) => setTimeout(resolve, 300));\n   158в†’    disconnectTwitterInStore(address);\n   159в†’  }, [address]);\n   160в†’\n   161в†’  // ============ Loot ============\n   162в†’\n   163в†’  const claimLoot = useCallback(async (lootId: string): Promise<number> => {\n   164в†’    if (!address) throw new Error(\"Wallet not connected\");\n   165в†’    await new Promise((resolve) => setTimeout(resolve, 500)); // Simulate transaction\n   166в†’    return claimLootFromStore(address, lootId);\n   167в†’  }, [address]);\n   168в†’\n   169в†’  const claimAllLoot = useCallback(async (): Promise<number> => {\n   170в†’    if (!address) throw new Error(\"Wallet not connected\");\n   171в†’    await new Promise((resolve) => setTimeout(resolve, 800)); // Simulate transaction\n   172в†’    return claimAllLootFromStore(address);\n   173в†’  }, [address]);\n   174в†’\n   175в†’  // ============ Mini Profile Modal ============\n   176в†’\n   177в†’  const openMiniProfile = useCallback((targetAddress: string) => {\n   178в†’    setSelectedProfileAddress(targetAddress);\n   179в†’  }, []);\n   180в†’\n   181в†’  const closeMiniProfile = useCallback(() => {\n   182в†’    setSelectedProfileAddress(null);\n   183в†’  }, []);\n   184в†’\n   185в†’  // ============ Display Helpers ============\n   186в†’\n   187в†’  const getDisplayName = useCallback((targetAddress: string): string => {\n   188в†’    return getDisplayNameFromStore(targetAddress);\n   189в†’  }, []);\n   190в†’\n   191в†’  const getAvatarId = useCallback((targetAddress: string): AvatarId => {\n   192в†’    return getAvatarIdFromStore(targetAddress);\n   193в†’  }, []);\n   194в†’\n   195в†’  const getBorderStyle = useCallback((level: number): BorderStyle => {\n   196в†’    return getBorderStyleFromLevel(level);\n   197в†’  }, []);\n   198в†’\n   199в†’  const isAvatarUnlocked = useCallback((avatarId: AvatarId, level: number): boolean => {\n   200в†’    const config = AVATAR_CONFIGS.find((a) => a.id === avatarId);\n   201в†’    if (!config) return false;\n   202в†’    return level >= config.unlockLevel;\n   203в†’  }, []);\n   204в†’\n   205в†’  // ============ Context Value ============\n   206в†’\n   207в†’  const value: PlayerProfileContextValue = {\n   208в†’    myProfile,\n   209в†’    loading,\n   210в†’    getProfile,\n   211в†’    loadProfile,\n   212в†’    updateUsername,\n   213в†’    updateAvatar,\n   214в†’    connectDiscord,\n   215в†’    disconnectDiscord,\n   216в†’    connectTwitter,\n   217в†’    disconnectTwitter,\n   218в†’    claimLoot,\n   219в†’    claimAllLoot,\n   220в†’    selectedProfileAddress,\n   221в†’    openMiniProfile,\n   222в†’    closeMiniProfile,\n   223в†’    getDisplayName,\n   224в†’    getAvatarId,\n   225в†’    getBorderStyle,\n   226в†’    isAvatarUnlocked,\n   227в†’  };\n   228в†’\n   229в†’  return (\n   230в†’    <PlayerProfileContext.Provider value={value}>\n   231в†’      {children}\n   232в†’    </PlayerProfileContext.Provider>\n   233в†’  );\n   234в†’}\n   235в†’\n   236в†’// ============ Hook ============\n   237в†’\n   238в†’export function usePlayerProfile(): PlayerProfileContextValue {\n   239в†’  const context = useContext(PlayerProfileContext);\n   240в†’  if (!context) {\n   241в†’    throw new Error(\"usePlayerProfile must be used within a PlayerProfileProvider\");\n   242в†’  }\n   243в†’  return context;\n   244в†’}\n   245в†’\n   246в†’// Re-export truncateAddress for convenience\n   247в†’export { truncateAddress };\n   248в†’"}]},"parent_tool_use_id":null,"session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"4f23d432-37ca-488e-9e10-b7461393b5a4","timestamp":"2026-03-19T19:17:09.639Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/context/PlayerProfileContext.tsx","content":"/**\n * Player Profile Context - App-level state management for player profiles\n *\n * Provides access to:\n * - Current user's profile (when wallet connected)\n * - Profile lookup for other players\n * - Profile mutations (username, avatar, socials)\n * - Loot claiming\n * - Mini profile modal state\n * - Display helpers\n */\n\nimport {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  type ReactNode,\n} from \"react\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport type {\n  AvatarId,\n  BorderStyle,\n  PlayerProfile,\n  PlayerProfileContextValue,\n} from \"../types\";\nimport { AVATAR_CONFIGS } from \"../types\";\nimport { getBorderStyleFromLevel } from \"../utils/xp-calculator\";\nimport { profileEventBus } from \"../utils/profile-event-bus\";\nimport {\n  initializeProfileStore,\n  getProfile as getProfileFromStore,\n  getOrCreateProfile,\n  updateUsername as updateUsernameInStore,\n  updateAvatar as updateAvatarInStore,\n  connectDiscord as connectDiscordInStore,\n  disconnectDiscord as disconnectDiscordInStore,\n  connectTwitter as connectTwitterInStore,\n  disconnectTwitter as disconnectTwitterInStore,\n  claimLoot as claimLootFromStore,\n  claimAllLoot as claimAllLootFromStore,\n  recordGameResult,\n  subscribeToProfiles,\n  getDisplayName as getDisplayNameFromStore,\n  getAvatarId as getAvatarIdFromStore,\n  truncateAddress,\n} from \"../utils/mock-simulation\";\n\n// ============ Context ============\n\nconst PlayerProfileContext = createContext<PlayerProfileContextValue | null>(null);\n\n// ============ Provider ============\n\ninterface PlayerProfileProviderProps {\n  children: ReactNode;\n}\n\nexport function PlayerProfileProvider({ children }: PlayerProfileProviderProps) {\n  const { address } = useWallet();\n\n  // State\n  const [myProfile, setMyProfile] = useState<PlayerProfile | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [selectedProfileAddress, setSelectedProfileAddress] = useState<string | null>(null);\n\n  // Initialize store on mount\n  useEffect(() => {\n    initializeProfileStore();\n    setLoading(false);\n  }, []);\n\n  // Load/create profile when wallet connects\n  // Force level 100 for the connected wallet (testing purposes)\n  useEffect(() => {\n    if (address) {\n      const profile = getOrCreateProfile(address, 100);\n      setMyProfile(profile);\n    } else {\n      setMyProfile(null);\n    }\n  }, [address]);\n\n  // Subscribe to profile updates\n  useEffect(() => {\n    const unsubscribe = subscribeToProfiles((updatedAddress, profile) => {\n      if (updatedAddress === address) {\n        setMyProfile(profile);\n      }\n    });\n\n    return unsubscribe;\n  }, [address]);\n\n  // Subscribe to game result events\n  useEffect(() => {\n    const unsubscribe = profileEventBus.subscribe((event) => {\n      recordGameResult(event);\n    });\n\n    return unsubscribe;\n  }, []);\n\n  // ============ Profile Lookup ============\n\n  const getProfile = useCallback((targetAddress: string): PlayerProfile | null => {\n    return getProfileFromStore(targetAddress);\n  }, []);\n\n  const loadProfile = useCallback(async (targetAddress: string): Promise<PlayerProfile | null> => {\n    // In mock mode, just return from store\n    // In production, this would fetch from backend\n    await new Promise((resolve) => setTimeout(resolve, 100)); // Simulate network delay\n    return getOrCreateProfile(targetAddress);\n  }, []);\n\n  // ============ Profile Mutations ============\n\n  const updateUsername = useCallback(async (username: string): Promise<void> => {\n    if (!address) throw new Error(\"Wallet not connected\");\n    await new Promise((resolve) => setTimeout(resolve, 300)); // Simulate network delay\n    updateUsernameInStore(address, username);\n  }, [address]);\n\n  const updateAvatar = useCallback(async (avatarId: AvatarId): Promise<void> => {\n    if (!address) throw new Error(\"Wallet not connected\");\n    updateAvatarInStore(address, avatarId);\n  }, [address]);\n\n  const connectDiscord = useCallback(async (): Promise<void> => {\n    if (!address) throw new Error(\"Wallet not connected\");\n    // In production, this would open OAuth flow\n    await new Promise((resolve) => setTimeout(resolve, 500));\n    // Mock: generate a fake Discord username\n    const mockUsername = `User${Math.floor(Math.random() * 10000)}`;\n    connectDiscordInStore(address, mockUsername);\n  }, [address]);\n\n  const disconnectDiscord = useCallback(async (): Promise<void> => {\n    if (!address) throw new Error(\"Wallet not connected\");\n    await new Promise((resolve) => setTimeout(resolve, 300));\n    disconnectDiscordInStore(address);\n  }, [address]);\n\n  const connectTwitter = useCallback(async (): Promise<void> => {\n    if (!address) throw new Error(\"Wallet not connected\");\n    // In production, this would open OAuth flow\n    await new Promise((resolve) => setTimeout(resolve, 500));\n    // Mock: generate a fake Twitter handle\n    const mockHandle = `@user_${Math.floor(Math.random() * 10000)}`;\n    connectTwitterInStore(address, mockHandle);\n  }, [address]);\n\n  const disconnectTwitter = useCallback(async (): Promise<void> => {\n    if (!address) throw new Error(\"Wallet not connected\");\n    await new Promise((resolve) => setTimeout(resolve, 300));\n    disconnectTwitterInStore(address);\n  }, [address]);\n\n  // ============ Loot ============\n\n  const claimLoot = useCallback(async (lootId: string): Promise<number> => {\n    if (!address) throw new Error(\"Wallet not connected\");\n    await new Promise((resolve) => setTimeout(resolve, 500)); // Simulate transaction\n    return claimLootFromStore(address, lootId);\n  }, [address]);\n\n  const claimAllLoot = useCallback(async (): Promise<number> => {\n    if (!address) throw new Error(\"Wallet not connected\");\n    await new Promise((resolve) => setTimeout(resolve, 800)); // Simulate transaction\n    return claimAllLootFromStore(address);\n  }, [address]);\n\n  // ============ Mini Profile Modal ============\n\n  const openMiniProfile = useCallback((targetAddress: string) => {\n    setSelectedProfileAddress(targetAddress);\n  }, []);\n\n  const closeMiniProfile = useCallback(() => {\n    setSelectedProfileAddress(null);\n  }, []);\n\n  // ============ Display Helpers ============\n\n  const getDisplayName = useCallback((targetAddress: string): string => {\n    return getDisplayNameFromStore(targetAddress);\n  }, []);\n\n  const getAvatarId = useCallback((targetAddress: string): AvatarId => {\n    return getAvatarIdFromStore(targetAddress);\n  }, []);\n\n  const getBorderStyle = useCallback((level: number): BorderStyle => {\n    return getBorderStyleFromLevel(level);\n  }, []);\n\n  const isAvatarUnlocked = useCallback((avatarId: AvatarId, level: number): boolean => {\n    const config = AVATAR_CONFIGS.find((a) => a.id === avatarId);\n    if (!config) return false;\n    return level >= config.unlockLevel;\n  }, []);\n\n  // ============ Context Value ============\n\n  const value: PlayerProfileContextValue = {\n    myProfile,\n    loading,\n    getProfile,\n    loadProfile,\n    updateUsername,\n    updateAvatar,\n    connectDiscord,\n    disconnectDiscord,\n    connectTwitter,\n    disconnectTwitter,\n    claimLoot,\n    claimAllLoot,\n    selectedProfileAddress,\n    openMiniProfile,\n    closeMiniProfile,\n    getDisplayName,\n    getAvatarId,\n    getBorderStyle,\n    isAvatarUnlocked,\n  };\n\n  return (\n    <PlayerProfileContext.Provider value={value}>\n      {children}\n    </PlayerProfileContext.Provider>\n  );\n}\n\n// ============ Hook ============\n\nexport function usePlayerProfile(): PlayerProfileContextValue {\n  const context = useContext(PlayerProfileContext);\n  if (!context) {\n    throw new Error(\"usePlayerProfile must be used within a PlayerProfileProvider\");\n  }\n  return context;\n}\n\n// Re-export truncateAddress for convenience\nexport { truncateAddress };\n","numLines":248,"startLine":1,"totalLines":248}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RrBo7bVXzi612JkpHznwUY","type":"tool_result","content":"     1в†’/**\n     2в†’ * Dual-browser-context fixture for local E2E tests.\n     3в†’ *\n     4в†’ * Provides two isolated browser contexts (playerA / playerB), each with:\n     5в†’ * - Its own storage and session state (no cross-contamination)\n     6в†’ * - A deterministic keypair seed injected via addInitScript so that\n     7в†’ *   WalletProvider (VITE_TEST_WALLET=true) picks up TestWalletProvider\n     8в†’ * - A ready-to-use Page instance\n     9в†’ *\n    10в†’ * Usage in tests:\n    11в†’ * ```ts\n    12в†’ * import { test, expect } from \"./fixtures\";\n    13в†’ *\n    14в†’ * test(\"lifecycle\", async ({ playerAPage, playerBPage }) => {\n    15в†’ *   // playerAPage and playerBPage are independent browser contexts\n    16в†’ * });\n    17в†’ * ```\n    18в†’ */\n    19в†’import { test as base, type BrowserContext, type Page } from \"@playwright/test\";\n    20в†’import { Keypair, Connection } from \"@solana/web3.js\";\n    21в†’import { PLAYER_A, PLAYER_B, LOCAL_RPC_URL } from \"./helpers/wallets\";\n    22в†’\n    23в†’export interface DualPlayerFixtures {\n    24в†’  /** Isolated browser context for player A (keypair injected). */\n    25в†’  playerAContext: BrowserContext;\n    26в†’  /** Isolated browser context for player B (keypair injected). */\n    27в†’  playerBContext: BrowserContext;\n    28в†’  /** Page within player A's context. */\n    29в†’  playerAPage: Page;\n    30в†’  /** Page within player B's context. */\n    31в†’  playerBPage: Page;\n    32в†’  /** Player A's deterministic keypair (same as PLAYER_A from wallets.ts). */\n    33в†’  playerAKeypair: Keypair;\n    34в†’  /** Player B's deterministic keypair (same as PLAYER_B from wallets.ts). */\n    35в†’  playerBKeypair: Keypair;\n    36в†’  /** Shared RPC connection to the local validator. */\n    37в†’  connection: Connection;\n    38в†’}\n    39в†’\n    40в†’/**\n    41в†’ * Inject a 32-byte keypair seed into a new browser context via addInitScript.\n    42в†’ * The seed is set on `window.__TEST_WALLET_SEED__` before any page script runs,\n    43в†’ * allowing TestWalletWrapper (lazy-loaded by WalletProvider) to construct the\n    44в†’ * correct Keypair at React render time.\n    45в†’ */\n    46в†’async function createPlayerContext(\n    47в†’  browser: BrowserContext[\"browser\"],\n    48в†’  keypair: Keypair,\n    49в†’): Promise<BrowserContext> {\n    50в†’  const context = await browser!.newContext();\n    51в†’  // Pass the 32-byte seed as a plain array (serialisable across the browser boundary)\n    52в†’  const seedArray = Array.from(keypair.secretKey.slice(0, 32));\n    53в†’  await context.addInitScript((seed: number[]) => {\n    54в†’    (window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ =\n    55в†’      new Uint8Array(seed);\n    56в†’  }, seedArray);\n    57в†’  return context;\n    58в†’}\n    59в†’\n    60в†’export const test = base.extend<DualPlayerFixtures>({\n    61в†’  // Expose keypairs as fixtures so tests can reference public keys, sign, etc.\n    62в†’  playerAKeypair: [PLAYER_A, { option: true }],\n    63в†’  playerBKeypair: [PLAYER_B, { option: true }],\n    64в†’\n    65в†’  // Shared connection fixture (created once per test)\n    66в†’  // eslint-disable-next-line no-empty-pattern\n    67в†’  connection: async ({}, use) => {\n    68в†’    const conn = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    69в†’    await use(conn);\n    70в†’  },\n    71в†’\n    72в†’  // --- Player A context + page ---\n    73в†’  playerAContext: async ({ browser, playerAKeypair }, use) => {\n    74в†’    const context = await createPlayerContext(browser, playerAKeypair);\n    75в†’    await use(context);\n    76в†’    await context.close();\n    77в†’  },\n    78в†’\n    79в†’  playerAPage: async ({ playerAContext }, use) => {\n    80в†’    const page = await playerAContext.newPage();\n    81в†’    await use(page);\n    82в†’  },\n    83в†’\n    84в†’  // --- Player B context + page ---\n    85в†’  playerBContext: async ({ browser, playerBKeypair }, use) => {\n    86в†’    const context = await createPlayerContext(browser, playerBKeypair);\n    87в†’    await use(context);\n    88в†’    await context.close();\n    89в†’  },\n    90в†’\n    91в†’  playerBPage: async ({ playerBContext }, use) => {\n    92в†’    const page = await playerBContext.newPage();\n    93в†’    await use(page);\n    94в†’  },\n    95в†’});\n    96в†’\n    97в†’export { expect } from \"@playwright/test\";\n    98в†’"}]},"parent_tool_use_id":null,"session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"9f190568-18e3-4b73-8346-0cbae0cdb02d","timestamp":"2026-03-19T19:17:09.618Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/fixtures.ts","content":"/**\n * Dual-browser-context fixture for local E2E tests.\n *\n * Provides two isolated browser contexts (playerA / playerB), each with:\n * - Its own storage and session state (no cross-contamination)\n * - A deterministic keypair seed injected via addInitScript so that\n *   WalletProvider (VITE_TEST_WALLET=true) picks up TestWalletProvider\n * - A ready-to-use Page instance\n *\n * Usage in tests:\n * ```ts\n * import { test, expect } from \"./fixtures\";\n *\n * test(\"lifecycle\", async ({ playerAPage, playerBPage }) => {\n *   // playerAPage and playerBPage are independent browser contexts\n * });\n * ```\n */\nimport { test as base, type BrowserContext, type Page } from \"@playwright/test\";\nimport { Keypair, Connection } from \"@solana/web3.js\";\nimport { PLAYER_A, PLAYER_B, LOCAL_RPC_URL } from \"./helpers/wallets\";\n\nexport interface DualPlayerFixtures {\n  /** Isolated browser context for player A (keypair injected). */\n  playerAContext: BrowserContext;\n  /** Isolated browser context for player B (keypair injected). */\n  playerBContext: BrowserContext;\n  /** Page within player A's context. */\n  playerAPage: Page;\n  /** Page within player B's context. */\n  playerBPage: Page;\n  /** Player A's deterministic keypair (same as PLAYER_A from wallets.ts). */\n  playerAKeypair: Keypair;\n  /** Player B's deterministic keypair (same as PLAYER_B from wallets.ts). */\n  playerBKeypair: Keypair;\n  /** Shared RPC connection to the local validator. */\n  connection: Connection;\n}\n\n/**\n * Inject a 32-byte keypair seed into a new browser context via addInitScript.\n * The seed is set on `window.__TEST_WALLET_SEED__` before any page script runs,\n * allowing TestWalletWrapper (lazy-loaded by WalletProvider) to construct the\n * correct Keypair at React render time.\n */\nasync function createPlayerContext(\n  browser: BrowserContext[\"browser\"],\n  keypair: Keypair,\n): Promise<BrowserContext> {\n  const context = await browser!.newContext();\n  // Pass the 32-byte seed as a plain array (serialisable across the browser boundary)\n  const seedArray = Array.from(keypair.secretKey.slice(0, 32));\n  await context.addInitScript((seed: number[]) => {\n    (window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ =\n      new Uint8Array(seed);\n  }, seedArray);\n  return context;\n}\n\nexport const test = base.extend<DualPlayerFixtures>({\n  // Expose keypairs as fixtures so tests can reference public keys, sign, etc.\n  playerAKeypair: [PLAYER_A, { option: true }],\n  playerBKeypair: [PLAYER_B, { option: true }],\n\n  // Shared connection fixture (created once per test)\n  // eslint-disable-next-line no-empty-pattern\n  connection: async ({}, use) => {\n    const conn = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    await use(conn);\n  },\n\n  // --- Player A context + page ---\n  playerAContext: async ({ browser, playerAKeypair }, use) => {\n    const context = await createPlayerContext(browser, playerAKeypair);\n    await use(context);\n    await context.close();\n  },\n\n  playerAPage: async ({ playerAContext }, use) => {\n    const page = await playerAContext.newPage();\n    await use(page);\n  },\n\n  // --- Player B context + page ---\n  playerBContext: async ({ browser, playerBKeypair }, use) => {\n    const context = await createPlayerContext(browser, playerBKeypair);\n    await use(context);\n    await context.close();\n  },\n\n  playerBPage: async ({ playerBContext }, use) => {\n    const page = await playerBContext.newPage();\n    await use(page);\n  },\n});\n\nexport { expect } from \"@playwright/test\";\n","numLines":98,"startLine":1,"totalLines":98}}}
