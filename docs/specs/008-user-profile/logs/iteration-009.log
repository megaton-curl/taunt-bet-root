{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Eg5XNHGiKXkG5cBQEaL3sw","type":"tool_result","content":"     1в†’import { ReactNode, lazy, Suspense } from \"react\";\n     2в†’import { ConnectionProvider } from \"@solana/wallet-adapter-react\";\n     3в†’import type { ConnectionConfig } from \"@solana/web3.js\";\n     4в†’import { MockWalletProvider } from \"./mock\";\n     5в†’\n     6в†’// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     7в†’const RealWalletProvider = lazy(() =>\n     8в†’  import(\"./real/RealWalletProvider\").then((m) => ({\n     9в†’    default: m.RealWalletProvider,\n    10в†’  })),\n    11в†’);\n    12в†’\n    13в†’// Lazy-load TestWalletWrapper for E2E tests (reads keypair seed from window)\n    14в†’const TestWalletWrapper = lazy(() =>\n    15в†’  import(\"./test/TestWalletWrapper\").then((m) => ({\n    16в†’    default: m.TestWalletWrapper,\n    17в†’  })),\n    18в†’);\n    19в†’\n    20в†’// Re-export WalletContext from the shared context file\n    21в†’export { WalletContext } from \"./context\";\n    22в†’\n    23в†’const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    24в†’const RPC_MAX_RETRIES = 3;\n    25в†’const RPC_INITIAL_RETRY_DELAY_MS = 1000;\n    26в†’\n    27в†’function getRpcUrl(): string {\n    28в†’  const envUrl =\n    29в†’    typeof import.meta !== \"undefined\"\n    30в†’      ? import.meta.env?.VITE_RPC_URL\n    31в†’      : undefined;\n    32в†’  return envUrl || DEFAULT_RPC_URL;\n    33в†’}\n    34в†’\n    35в†’function getWsRpcUrl(): string | undefined {\n    36в†’  const envUrl =\n    37в†’    typeof import.meta !== \"undefined\"\n    38в†’      ? import.meta.env?.VITE_WS_RPC_URL\n    39в†’      : undefined;\n    40в†’  return envUrl || undefined;\n    41в†’}\n    42в†’\n    43в†’interface WalletProviderProps {\n    44в†’  children: ReactNode;\n    45в†’}\n    46в†’\n    47в†’function delay(ms: number): Promise<void> {\n    48в†’  return new Promise((resolve) => setTimeout(resolve, ms));\n    49в†’}\n    50в†’\n    51в†’const baseFetch = globalThis.fetch?.bind(globalThis);\n    52в†’\n    53в†’const rpcFetch: typeof fetch = async (input, init) => {\n    54в†’  if (!baseFetch) {\n    55в†’    throw new Error(\"Global fetch is not available in this environment.\");\n    56в†’  }\n    57в†’\n    58в†’  let attempt = 0;\n    59в†’  let retryDelayMs = RPC_INITIAL_RETRY_DELAY_MS;\n    60в†’  let response = await baseFetch(input, init);\n    61в†’\n    62в†’  while (response.status === 429 && attempt < RPC_MAX_RETRIES) {\n    63в†’    await delay(retryDelayMs);\n    64в†’    attempt += 1;\n    65в†’    retryDelayMs *= 2;\n    66в†’    response = await baseFetch(input, init);\n    67в†’  }\n    68в†’\n    69в†’  return response;\n    70в†’};\n    71в†’\n    72в†’function buildConnectionConfig(): ConnectionConfig {\n    73в†’  const wsEndpoint = getWsRpcUrl();\n    74в†’  return {\n    75в†’    commitment: \"confirmed\",\n    76в†’    // Disable web3.js internal 429 retries so we can control retry timing.\n    77в†’    disableRetryOnRateLimit: true,\n    78в†’    fetch: rpcFetch,\n    79в†’    // Use a separate WSS endpoint for subscriptions if configured.\n    80в†’    // Load-balanced HTTP RPC providers (dRPC, etc.) often don't relay\n    81в†’    // WebSocket subscription notifications, so a dedicated WSS endpoint\n    82в†’    // (e.g. Helius, public Solana) is needed for onLogs/onAccountChange.\n    83в†’    ...(wsEndpoint ? { wsEndpoint } : {}),\n    84в†’  };\n    85в†’}\n    86в†’\n    87в†’function isMockMode(): boolean {\n    88в†’  const flag =\n    89в†’    typeof import.meta !== \"undefined\"\n    90в†’      ? import.meta.env?.VITE_MOCK_MODE\n    91в†’      : undefined;\n    92в†’  // Default to real mode вЂ” only mock when explicitly set to \"true\"\n    93в†’  return flag === \"true\";\n    94в†’}\n    95в†’\n    96в†’function isTestWalletMode(): boolean {\n    97в†’  const flag =\n    98в†’    typeof import.meta !== \"undefined\"\n    99в†’      ? import.meta.env?.VITE_TEST_WALLET\n   100в†’      : undefined;\n   101в†’  return flag === \"true\";\n   102в†’}\n   103в†’\n   104в†’/**\n   105в†’ * Unified WalletProvider.\n   106в†’ * Wraps both Mock and Real providers with a shared ConnectionProvider.\n   107в†’ */\n   108в†’export function WalletProvider({ children }: WalletProviderProps) {\n   109в†’  const endpoint = getRpcUrl();\n   110в†’\n   111в†’  const inner = isMockMode() ? (\n   112в†’    <MockWalletProvider>{children}</MockWalletProvider>\n   113в†’  ) : isTestWalletMode() ? (\n   114в†’    <Suspense fallback={null}>\n   115в†’      <TestWalletWrapper>{children}</TestWalletWrapper>\n   116в†’    </Suspense>\n   117в†’  ) : (\n   118в†’    <Suspense fallback={null}>\n   119в†’      <RealWalletProvider>{children}</RealWalletProvider>\n   120в†’    </Suspense>\n   121в†’  );\n   122в†’\n   123в†’  return (\n   124в†’    <ConnectionProvider endpoint={endpoint} config={buildConnectionConfig()}>\n   125в†’      {inner}\n   126в†’    </ConnectionProvider>\n   127в†’  );\n   128в†’}\n   129в†’"}]},"parent_tool_use_id":"toolu_01WffBy2rJDSTEwXA4hML3Ae","session_id":"b99e2185-20b1-487e-a0a4-b3fb9a756d45","uuid":"3e3aaa65-8d25-4f98-8952-31a0e678513a","timestamp":"2026-03-19T19:14:50.511Z"}
