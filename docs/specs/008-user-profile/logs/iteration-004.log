{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01XpdJ2NU3aZuHssHNY1jxRg","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014sJg8d6Uu14JM47kD3tETW","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts","old_string":"          WHERE round_id = ${String(Number(minuteTs))}\n        `;\n      } catch (dbErr) {","new_string":"          WHERE round_id = ${String(Number(minuteTs))}\n        `;\n\n        // Write user transaction rows (join + outcome per entry)\n        const roundId = String(Number(minuteTs));\n        const netPool = totalPool - computedFee;\n\n        const doInsert = (\n          wallet: string,\n          event: string,\n          amount: number,\n        ) =>\n          sql`\n            INSERT INTO user_transactions (wallet, game, match_id, event, amount_lamports, tx_sig)\n            VALUES (${wallet}, 'closecall', ${roundId}, ${event}, ${amount}, ${sig})\n            ON CONFLICT DO NOTHING\n          `;\n\n        const userTxInserts: Promise<unknown>[] = [];\n\n        for (const entry of greenEntries) {\n          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n          if (isRefund) {\n            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n          } else if (outcomeStr === \"green\") {\n            const greenPool = Number(round.greenPool);\n            const payout = greenPool > 0\n              ? Math.floor((entry.amountLamports / greenPool) * netPool)\n              : 0;\n            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n          } else {\n            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n          }\n        }\n\n        for (const entry of redEntries) {\n          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n          if (isRefund) {\n            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n          } else if (outcomeStr === \"red\") {\n            const redPool = Number(round.redPool);\n            const payout = redPool > 0\n              ? Math.floor((entry.amountLamports / redPool) * netPool)\n              : 0;\n            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n          } else {\n            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n          }\n        }\n\n        if (userTxInserts.length > 0) {\n          await Promise.all(userTxInserts);\n        }\n      } catch (dbErr) {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1359,"cache_read_input_tokens":41104,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1359},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0ab61bc6-f37e-46f2-adbe-0242ac985946","uuid":"82d6b935-bf41-4846-b497-fda3219348e5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014sJg8d6Uu14JM47kD3tETW","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"0ab61bc6-f37e-46f2-adbe-0242ac985946","uuid":"7a515d4b-8cc5-46bb-87d9-0d5ceb2f5553","timestamp":"2026-03-19T18:52:36.506Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts","oldString":"          WHERE round_id = ${String(Number(minuteTs))}\n        `;\n      } catch (dbErr) {","newString":"          WHERE round_id = ${String(Number(minuteTs))}\n        `;\n\n        // Write user transaction rows (join + outcome per entry)\n        const roundId = String(Number(minuteTs));\n        const netPool = totalPool - computedFee;\n\n        const doInsert = (\n          wallet: string,\n          event: string,\n          amount: number,\n        ) =>\n          sql`\n            INSERT INTO user_transactions (wallet, game, match_id, event, amount_lamports, tx_sig)\n            VALUES (${wallet}, 'closecall', ${roundId}, ${event}, ${amount}, ${sig})\n            ON CONFLICT DO NOTHING\n          `;\n\n        const userTxInserts: Promise<unknown>[] = [];\n\n        for (const entry of greenEntries) {\n          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n          if (isRefund) {\n            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n          } else if (outcomeStr === \"green\") {\n            const greenPool = Number(round.greenPool);\n            const payout = greenPool > 0\n              ? Math.floor((entry.amountLamports / greenPool) * netPool)\n              : 0;\n            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n          } else {\n            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n          }\n        }\n\n        for (const entry of redEntries) {\n          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n          if (isRefund) {\n            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n          } else if (outcomeStr === \"red\") {\n            const redPool = Number(round.redPool);\n            const payout = redPool > 0\n              ? Math.floor((entry.amountLamports / redPool) * netPool)\n              : 0;\n            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n          } else {\n            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n          }\n        }\n\n        if (userTxInserts.length > 0) {\n          await Promise.all(userTxInserts);\n        }\n      } catch (dbErr) {","originalFile":"/**\n * Close Call clock worker — precise minute-boundary price capture + settlement.\n *\n * Scheduling:\n *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n *   - Caches the boundary price (both close of old candle, open of next)\n *   - Settles any open rounds whose candle has closed\n *   - Schedules next tick at (next minute + 1s)\n *\n * Rounds are created on-demand by the first bettor (via /closecall/bet).\n * On start, loads the latest boundary price from DB to seed the cache.\n */\n\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type postgres from \"postgres\";\nimport { logger } from \"../logger.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport {\n  buildCloseCallSettleRoundIx,\n} from \"./settle-tx.js\";\nimport {\n  closeCallRoundDiscriminatorFilter,\n  decodeCloseCallConfig,\n  decodeCloseCallRound,\n} from \"./account-decoder.js\";\nimport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n\n/** Close Call on-chain phase values */\nconst PHASE_OPEN = 0;\n\n/** How long to wait after minute boundary before first Hermes poll (ms). */\nconst BOUNDARY_OFFSET_MS = 1_000;\n\n/** Poll Hermes every 1s when waiting for boundary price. */\nconst HERMES_POLL_INTERVAL_MS = 1_000;\n\n/** Max attempts to fetch a fresh boundary price (10s total). */\nconst HERMES_MAX_RETRIES = 10;\n\n/** Maximum retry attempts for a single tx submission. */\nconst MAX_TX_RETRIES = 3;\nconst TX_RETRY_DELAY_MS = 2_000;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface BoundaryPrice {\n  price: bigint;\n  expo: number;\n  minuteTs: number;\n  priceHuman: number;\n}\n\nexport interface CloseCallClockDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n  /** Postgres `sql` tagged template instance for candle table access. */\n  db: postgres.Sql;\n  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n  hermesEndpoint?: string;\n}\n\nexport interface CloseCallClockWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single tick (exposed for testing). */\n  tick(): Promise<void>;\n  /** Get the most recent minute-boundary price (from cache). */\n  getLatestBoundaryPrice(): BoundaryPrice | null;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createCloseCallClockWorker(\n  deps: CloseCallClockDeps,\n): CloseCallClockWorker {\n  const { connection, serverKeypair, hermesEndpoint, db: sql } = deps;\n\n  const hermes: HermesFetcher = createHermesFetcher(hermesEndpoint);\n\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  /** Cached latest boundary price (in-memory). */\n  let cachedBoundaryPrice: BoundaryPrice | null = null;\n\n  // -----------------------------------------------------------------------\n  // Scheduling\n  // -----------------------------------------------------------------------\n\n  /** Milliseconds until the next minute boundary + offset. */\n  function msUntilNextBoundary(): number {\n    const now = Date.now();\n    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    return nextMinute - now + BOUNDARY_OFFSET_MS;\n  }\n\n  // -----------------------------------------------------------------------\n  // Helpers\n  // -----------------------------------------------------------------------\n\n  /** Send a legacy Transaction with retry. */\n  async function sendAndConfirm(\n    tx: Transaction,\n    label: string,\n  ): Promise<string> {\n    let lastError: unknown;\n\n    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n      try {\n        const sig = await connection.sendRawTransaction(tx.serialize(), {\n          skipPreflight: false,\n        });\n        const { blockhash, lastValidBlockHeight } =\n          await connection.getLatestBlockhash();\n        const confirmation = await connection.confirmTransaction(\n          { signature: sig, blockhash, lastValidBlockHeight },\n          \"confirmed\",\n        );\n        if (confirmation.value.err) {\n          throw new Error(\n            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n          );\n        }\n        return sig;\n      } catch (err) {\n        lastError = err;\n        if (attempt < MAX_TX_RETRIES - 1) {\n          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n        }\n      }\n    }\n\n    throw lastError;\n  }\n\n  /** Read CloseCallConfig for treasury address. */\n  async function readTreasury(): Promise<PublicKey | null> {\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"closecall_config\")],\n      CLOSECALL_PROGRAM_ID,\n    );\n    const info = await connection.getAccountInfo(configPda);\n    if (!info) return null;\n    const config = decodeCloseCallConfig(Buffer.from(info.data));\n    return config.treasury;\n  }\n\n  // -----------------------------------------------------------------------\n  // Candle DB operations\n  // -----------------------------------------------------------------------\n\n  /** Save a boundary price to the closecall_candles table (upsert). */\n  async function saveBoundaryPrice(\n    minuteTs: number,\n    price: bigint,\n    expo: number,\n    priceHuman: number,\n    hermesVaa: string | null,\n  ): Promise<void> {\n    try {\n      await sql`\n        INSERT INTO closecall_candles (minute_ts, price, expo, price_human, hermes_vaa)\n        VALUES (${minuteTs}, ${price.toString()}, ${expo}, ${priceHuman}, ${hermesVaa})\n        ON CONFLICT (minute_ts) DO NOTHING\n      `;\n    } catch (err) {\n      logger.error(\"closecall clock: failed to save boundary price\", {\n        minuteTs,\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  /** Load the latest boundary price from DB (for startup cache seeding). */\n  async function loadLatestBoundaryFromDb(): Promise<void> {\n    try {\n      const rows = await sql<{\n        minute_ts: string;\n        price: string;\n        expo: number;\n        price_human: number;\n      }[]>`\n        SELECT minute_ts, price, expo, price_human\n        FROM closecall_candles\n        ORDER BY minute_ts DESC\n        LIMIT 1\n      `;\n      if (rows.length > 0) {\n        const row = rows[0]!;\n        cachedBoundaryPrice = {\n          price: BigInt(row.price),\n          expo: row.expo,\n          minuteTs: Number(row.minute_ts),\n          priceHuman: row.price_human,\n        };\n        logger.info(\"closecall clock: loaded boundary price from DB\", {\n          minuteTs: cachedBoundaryPrice.minuteTs,\n          priceHuman: cachedBoundaryPrice.priceHuman,\n        });\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: failed to load boundary price from DB\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Boundary price capture — poll Hermes until fresh price arrives\n  // -----------------------------------------------------------------------\n\n  /**\n   * Poll Hermes every 1s until we get a price with publishTime >= boundaryTs.\n   * Returns the captured price or null if max retries exceeded.\n   */\n  async function captureBoundaryPrice(\n    boundaryTs: number,\n  ): Promise<BoundaryPrice | null> {\n    for (let attempt = 0; attempt < HERMES_MAX_RETRIES; attempt++) {\n      try {\n        const result = await hermes.fetchLatestBtcPrice();\n        if (result && result.publishTime >= boundaryTs) {\n          const bp: BoundaryPrice = {\n            price: result.price,\n            expo: result.expo,\n            minuteTs: boundaryTs,\n            priceHuman: result.priceHuman,\n          };\n\n          // Save to DB with VAA proof\n          await saveBoundaryPrice(\n            boundaryTs,\n            result.price,\n            result.expo,\n            result.priceHuman,\n            result.vaaBase64,\n          );\n\n          cachedBoundaryPrice = bp;\n\n          logger.info(\"closecall clock: boundary price captured\", {\n            minuteTs: boundaryTs,\n            priceHuman: result.priceHuman,\n            publishTime: result.publishTime,\n            attempts: attempt + 1,\n          });\n\n          return bp;\n        }\n\n        if (result) {\n          logger.debug(\"closecall clock: Hermes price not yet at boundary\", {\n            publishTime: result.publishTime,\n            boundaryTs,\n            attempt: attempt + 1,\n          });\n        }\n      } catch (err) {\n        logger.warn(\"closecall clock: Hermes poll failed\", {\n          attempt: attempt + 1,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n\n      // Wait 1s before next attempt\n      if (attempt < HERMES_MAX_RETRIES - 1) {\n        await new Promise((r) => setTimeout(r, HERMES_POLL_INTERVAL_MS));\n      }\n    }\n\n    logger.warn(\"closecall clock: failed to capture boundary price after max retries\", {\n      boundaryTs,\n    });\n    return null;\n  }\n\n  // -----------------------------------------------------------------------\n  // Round discovery\n  // -----------------------------------------------------------------------\n\n  /**\n   * Discover ALL existing open rounds owned by this server.\n   */\n  async function discoverOpenRounds(): Promise<\n    Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }>\n  > {\n    const results: Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }> = [];\n    try {\n      const accounts = await connection.getProgramAccounts(\n        CLOSECALL_PROGRAM_ID,\n        { filters: [closeCallRoundDiscriminatorFilter()] },\n      );\n\n      const now = Math.floor(Date.now() / 1000);\n\n      for (const { pubkey, account } of accounts) {\n        try {\n          const round = decodeCloseCallRound(Buffer.from(account.data));\n\n          // Skip rounds with garbage minuteTs (old format / random bytes)\n          const ts = Number(round.minuteTs);\n          if (ts < 1700000000 || ts > now + 120) continue;\n\n          if (\n            round.phase === PHASE_OPEN &&\n            round.server.equals(serverKeypair.publicKey)\n          ) {\n            results.push({ pda: pubkey, minuteTs: round.minuteTs, round });\n          }\n        } catch {\n          // Skip undecodeable accounts\n        }\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: discovery scan failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    return results;\n  }\n\n  // -----------------------------------------------------------------------\n  // Settlement\n  // -----------------------------------------------------------------------\n\n  /**\n   * Settle a single round. Returns true on success.\n   */\n  async function settleRound(\n    roundPda: PublicKey,\n    minuteTs: bigint,\n    round: ReturnType<typeof decodeCloseCallRound>,\n  ): Promise<boolean> {\n    try {\n      const nowSec = Math.floor(Date.now() / 1000);\n      const candleCloseTime = Number(minuteTs) + 60;\n\n      if (nowSec < candleCloseTime) {\n        logger.debug(\"closecall clock: candle not closed yet\", {\n          pda: roundPda.toBase58(),\n          secondsRemaining: candleCloseTime - nowSec,\n        });\n        return false;\n      }\n\n      const greenCount = round.greenEntries.length;\n      const redCount = round.redEntries.length;\n      const totalCount = greenCount + redCount;\n\n      // Fetch treasury + close price\n      const [treasury, hermesPrice] = await Promise.all([\n        readTreasury(),\n        hermes.fetchLatestBtcPrice(),\n      ]);\n\n      if (!treasury) {\n        logger.error(\"closecall clock: cannot read config treasury\");\n        return false;\n      }\n      if (!hermesPrice) {\n        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n        return false;\n      }\n\n      if (totalCount === 0) {\n        logger.info(\"closecall clock: settling empty round\", {\n          pda: roundPda.toBase58(),\n        });\n      }\n\n      // Pre-determine outcome\n      const hasBothSides = greenCount > 0 && redCount > 0;\n      const isRefund =\n        totalCount === 0 ||\n        !hasBothSides ||\n        totalCount === 1 ||\n        hermesPrice.price === round.openPrice;\n\n      let remainingAccounts: PublicKey[];\n      if (isRefund) {\n        remainingAccounts = [\n          ...round.greenEntries.map((e) => e.player),\n          ...round.redEntries.map((e) => e.player),\n        ];\n      } else if (hermesPrice.price > round.openPrice) {\n        remainingAccounts = round.greenEntries.map((e) => e.player);\n      } else {\n        remainingAccounts = round.redEntries.map((e) => e.player);\n      }\n\n      const ix = buildCloseCallSettleRoundIx(\n        serverKeypair.publicKey,\n        minuteTs,\n        hermesPrice.price,\n        hermesPrice.expo,\n        treasury,\n        remainingAccounts,\n      );\n\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      const tx = new Transaction({\n        feePayer: serverKeypair.publicKey,\n        blockhash,\n        lastValidBlockHeight,\n      });\n      tx.add(ix);\n      tx.sign(serverKeypair);\n\n      const sig = await sendAndConfirm(tx, \"settle\");\n\n      const outcomeStr = isRefund\n        ? \"refund\"\n        : hermesPrice.price > round.openPrice\n          ? \"green\"\n          : \"red\";\n\n      logger.info(\"closecall clock: round settled\", {\n        pda: roundPda.toBase58(),\n        tx: sig,\n        totalEntries: totalCount,\n        outcome: outcomeStr,\n      });\n\n      // Persist settlement to DB\n      try {\n        // Ensure round record exists (may not if created before DB persistence was added)\n        await sql`\n          INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo, phase, created_at)\n          VALUES (\n            ${String(Number(minuteTs))},\n            ${roundPda.toBase58()},\n            ${serverKeypair.publicKey.toBase58()},\n            ${Number(round.openPrice)},\n            ${round.openPriceExpo},\n            'open',\n            NOW()\n          )\n          ON CONFLICT (round_id) DO NOTHING\n        `;\n\n        // Format entries for JSONB storage\n        const greenEntries = round.greenEntries.map((e) => ({\n          player: e.player.toBase58(),\n          amountLamports: Number(e.amountLamports),\n        }));\n        const redEntries = round.redEntries.map((e) => ({\n          player: e.player.toBase58(),\n          amountLamports: Number(e.amountLamports),\n        }));\n\n        // Compute fee off-chain (on-chain totalFee is only set after settle,\n        // but we read the account BEFORE settlement, so it's still 0).\n        // Fee = 3% (300 bps) of total pool, truncated. 0 for refund rounds.\n        const totalPool = Number(round.greenPool) + Number(round.redPool);\n        const computedFee = isRefund ? 0 : Math.floor(totalPool * 300 / 10_000);\n\n        // Update with settlement data\n        await sql`\n          UPDATE closecall_rounds SET\n            phase = ${isRefund ? \"refunded\" : \"settled\"},\n            outcome = ${outcomeStr},\n            close_price = ${Number(hermesPrice.price)},\n            green_pool = ${Number(round.greenPool)},\n            red_pool = ${Number(round.redPool)},\n            total_fee = ${computedFee},\n            green_entries = ${sql.json(greenEntries)},\n            red_entries = ${sql.json(redEntries)},\n            settle_tx = ${sig},\n            settled_at = NOW()\n          WHERE round_id = ${String(Number(minuteTs))}\n        `;\n      } catch (dbErr) {\n        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n        });\n      }\n\n      return true;\n    } catch (err) {\n      logger.error(\"closecall clock: settlement failed\", {\n        pda: roundPda.toBase58(),\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return false;\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Tick — fires at minute boundary + 1s\n  // -----------------------------------------------------------------------\n\n  async function tick(): Promise<void> {\n    const t0 = performance.now();\n    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n\n    // Step 1: Capture boundary price (poll Hermes until fresh)\n    await captureBoundaryPrice(boundaryTs);\n\n    // Step 2: Discover + settle all open rounds whose candle has closed\n    const openRounds = await discoverOpenRounds();\n\n    for (const { pda, minuteTs, round } of openRounds) {\n      await settleRound(pda, minuteTs, round);\n    }\n\n    const elapsed = Math.round(performance.now() - t0);\n    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await tick();\n    } catch (err) {\n      logger.error(\"closecall clock loop error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      const delay = msUntilNextBoundary();\n      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n      timeoutId = setTimeout(loop, delay);\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Public interface\n  // -----------------------------------------------------------------------\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n\n      logger.info(\"closecall clock started\", {\n        serverKey: serverKeypair.publicKey.toBase58(),\n        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n      });\n\n      // Load latest boundary price from DB, then schedule first tick\n      loadLatestBoundaryFromDb()\n        .then(() => {\n          if (!running) return;\n          const delay = msUntilNextBoundary();\n          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n          timeoutId = setTimeout(loop, delay);\n        })\n        .catch((err) => {\n          logger.error(\"closecall clock: startup init failed\", {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          if (running) {\n            const delay = msUntilNextBoundary();\n            timeoutId = setTimeout(loop, delay);\n          }\n        });\n    },\n\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"closecall clock stopped\");\n    },\n\n    get isRunning() {\n      return running;\n    },\n\n    tick,\n\n    getLatestBoundaryPrice(): BoundaryPrice | null {\n      return cachedBoundaryPrice;\n    },\n  };\n}\n","structuredPatch":[{"oldStart":485,"oldLines":6,"newStart":485,"newLines":57,"lines":["             settled_at = NOW()","           WHERE round_id = ${String(Number(minuteTs))}","         `;","+","+        // Write user transaction rows (join + outcome per entry)","+        const roundId = String(Number(minuteTs));","+        const netPool = totalPool - computedFee;","+","+        const doInsert = (","+          wallet: string,","+          event: string,","+          amount: number,","+        ) =>","+          sql`","+            INSERT INTO user_transactions (wallet, game, match_id, event, amount_lamports, tx_sig)","+            VALUES (${wallet}, 'closecall', ${roundId}, ${event}, ${amount}, ${sig})","+            ON CONFLICT DO NOTHING","+          `;","+","+        const userTxInserts: Promise<unknown>[] = [];","+","+        for (const entry of greenEntries) {","+          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));","+          if (isRefund) {","+            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));","+          } else if (outcomeStr === \"green\") {","+            const greenPool = Number(round.greenPool);","+            const payout = greenPool > 0","+              ? Math.floor((entry.amountLamports / greenPool) * netPool)","+              : 0;","+            userTxInserts.push(doInsert(entry.player, \"win\", payout));","+          } else {","+            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));","+          }","+        }","+","+        for (const entry of redEntries) {","+          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));","+          if (isRefund) {","+            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));","+          } else if (outcomeStr === \"red\") {","+            const redPool = Number(round.redPool);","+            const payout = redPool > 0","+              ? Math.floor((entry.amountLamports / redPool) * netPool)","+              : 0;","+            userTxInserts.push(doInsert(entry.player, \"win\", payout));","+          } else {","+            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));","+          }","+        }","+","+        if (userTxInserts.length > 0) {","+          await Promise.all(userTxInserts);","+        }","       } catch (dbErr) {","         logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {","           error: dbErr instanceof Error ? dbErr.message : String(dbErr),"]}],"userModified":false,"replaceAll":false}}
