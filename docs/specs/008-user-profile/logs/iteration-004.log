{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016qFUgm9jAH7oGXsxoUrJnE","type":"tool_result","content":"     1→/**\n     2→ * Close Call clock worker — precise minute-boundary price capture + settlement.\n     3→ *\n     4→ * Scheduling:\n     5→ *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n     6→ *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n     7→ *   - Caches the boundary price (both close of old candle, open of next)\n     8→ *   - Settles any open rounds whose candle has closed\n     9→ *   - Schedules next tick at (next minute + 1s)\n    10→ *\n    11→ * Rounds are created on-demand by the first bettor (via /closecall/bet).\n    12→ * On start, loads the latest boundary price from DB to seed the cache.\n    13→ */\n    14→\n    15→import { performance } from \"node:perf_hooks\";\n    16→import {\n    17→  Connection,\n    18→  Keypair,\n    19→  PublicKey,\n    20→  Transaction,\n    21→} from \"@solana/web3.js\";\n    22→import type postgres from \"postgres\";\n    23→import { logger } from \"../logger.js\";\n    24→import { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    25→import {\n    26→  buildCloseCallSettleRoundIx,\n    27→} from \"./settle-tx.js\";\n    28→import {\n    29→  closeCallRoundDiscriminatorFilter,\n    30→  decodeCloseCallConfig,\n    31→  decodeCloseCallRound,\n    32→} from \"./account-decoder.js\";\n    33→import { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n    34→\n    35→/** Close Call on-chain phase values */\n    36→const PHASE_OPEN = 0;\n    37→\n    38→/** How long to wait after minute boundary before first Hermes poll (ms). */\n    39→const BOUNDARY_OFFSET_MS = 1_000;\n    40→\n    41→/** Poll Hermes every 1s when waiting for boundary price. */\n    42→const HERMES_POLL_INTERVAL_MS = 1_000;\n    43→\n    44→/** Max attempts to fetch a fresh boundary price (10s total). */\n    45→const HERMES_MAX_RETRIES = 10;\n    46→\n    47→/** Maximum retry attempts for a single tx submission. */\n    48→const MAX_TX_RETRIES = 3;\n    49→const TX_RETRY_DELAY_MS = 2_000;\n    50→\n    51→// ---------------------------------------------------------------------------\n    52→// Types\n    53→// ---------------------------------------------------------------------------\n    54→\n    55→export interface BoundaryPrice {\n    56→  price: bigint;\n    57→  expo: number;\n    58→  minuteTs: number;\n    59→  priceHuman: number;\n    60→}\n    61→\n    62→export interface CloseCallClockDeps {\n    63→  connection: Connection;\n    64→  serverKeypair: Keypair;\n    65→  /** Postgres `sql` tagged template instance for candle table access. */\n    66→  db: postgres.Sql;\n    67→  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n    68→  hermesEndpoint?: string;\n    69→}\n    70→\n    71→export interface CloseCallClockWorker {\n    72→  start(): void;\n    73→  stop(): void;\n    74→  readonly isRunning: boolean;\n    75→  /** Run a single tick (exposed for testing). */\n    76→  tick(): Promise<void>;\n    77→  /** Get the most recent minute-boundary price (from cache). */\n    78→  getLatestBoundaryPrice(): BoundaryPrice | null;\n    79→}\n    80→\n    81→// ---------------------------------------------------------------------------\n    82→// Factory\n    83→// ---------------------------------------------------------------------------\n    84→\n    85→export function createCloseCallClockWorker(\n    86→  deps: CloseCallClockDeps,\n    87→): CloseCallClockWorker {\n    88→  const { connection, serverKeypair, hermesEndpoint, db: sql } = deps;\n    89→\n    90→  const hermes: HermesFetcher = createHermesFetcher(hermesEndpoint);\n    91→\n    92→  let running = false;\n    93→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    94→\n    95→  /** Cached latest boundary price (in-memory). */\n    96→  let cachedBoundaryPrice: BoundaryPrice | null = null;\n    97→\n    98→  // -----------------------------------------------------------------------\n    99→  // Scheduling\n   100→  // -----------------------------------------------------------------------\n   101→\n   102→  /** Milliseconds until the next minute boundary + offset. */\n   103→  function msUntilNextBoundary(): number {\n   104→    const now = Date.now();\n   105→    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n   106→    return nextMinute - now + BOUNDARY_OFFSET_MS;\n   107→  }\n   108→\n   109→  // -----------------------------------------------------------------------\n   110→  // Helpers\n   111→  // -----------------------------------------------------------------------\n   112→\n   113→  /** Send a legacy Transaction with retry. */\n   114→  async function sendAndConfirm(\n   115→    tx: Transaction,\n   116→    label: string,\n   117→  ): Promise<string> {\n   118→    let lastError: unknown;\n   119→\n   120→    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n   121→      try {\n   122→        const sig = await connection.sendRawTransaction(tx.serialize(), {\n   123→          skipPreflight: false,\n   124→        });\n   125→        const { blockhash, lastValidBlockHeight } =\n   126→          await connection.getLatestBlockhash();\n   127→        const confirmation = await connection.confirmTransaction(\n   128→          { signature: sig, blockhash, lastValidBlockHeight },\n   129→          \"confirmed\",\n   130→        );\n   131→        if (confirmation.value.err) {\n   132→          throw new Error(\n   133→            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   134→          );\n   135→        }\n   136→        return sig;\n   137→      } catch (err) {\n   138→        lastError = err;\n   139→        if (attempt < MAX_TX_RETRIES - 1) {\n   140→          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n   141→            error: err instanceof Error ? err.message : String(err),\n   142→          });\n   143→          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n   144→        }\n   145→      }\n   146→    }\n   147→\n   148→    throw lastError;\n   149→  }\n   150→\n   151→  /** Read CloseCallConfig for treasury address. */\n   152→  async function readTreasury(): Promise<PublicKey | null> {\n   153→    const [configPda] = PublicKey.findProgramAddressSync(\n   154→      [Buffer.from(\"closecall_config\")],\n   155→      CLOSECALL_PROGRAM_ID,\n   156→    );\n   157→    const info = await connection.getAccountInfo(configPda);\n   158→    if (!info) return null;\n   159→    const config = decodeCloseCallConfig(Buffer.from(info.data));\n   160→    return config.treasury;\n   161→  }\n   162→\n   163→  // -----------------------------------------------------------------------\n   164→  // Candle DB operations\n   165→  // -----------------------------------------------------------------------\n   166→\n   167→  /** Save a boundary price to the closecall_candles table (upsert). */\n   168→  async function saveBoundaryPrice(\n   169→    minuteTs: number,\n   170→    price: bigint,\n   171→    expo: number,\n   172→    priceHuman: number,\n   173→    hermesVaa: string | null,\n   174→  ): Promise<void> {\n   175→    try {\n   176→      await sql`\n   177→        INSERT INTO closecall_candles (minute_ts, price, expo, price_human, hermes_vaa)\n   178→        VALUES (${minuteTs}, ${price.toString()}, ${expo}, ${priceHuman}, ${hermesVaa})\n   179→        ON CONFLICT (minute_ts) DO NOTHING\n   180→      `;\n   181→    } catch (err) {\n   182→      logger.error(\"closecall clock: failed to save boundary price\", {\n   183→        minuteTs,\n   184→        error: err instanceof Error ? err.message : String(err),\n   185→      });\n   186→    }\n   187→  }\n   188→\n   189→  /** Load the latest boundary price from DB (for startup cache seeding). */\n   190→  async function loadLatestBoundaryFromDb(): Promise<void> {\n   191→    try {\n   192→      const rows = await sql<{\n   193→        minute_ts: string;\n   194→        price: string;\n   195→        expo: number;\n   196→        price_human: number;\n   197→      }[]>`\n   198→        SELECT minute_ts, price, expo, price_human\n   199→        FROM closecall_candles\n   200→        ORDER BY minute_ts DESC\n   201→        LIMIT 1\n   202→      `;\n   203→      if (rows.length > 0) {\n   204→        const row = rows[0]!;\n   205→        cachedBoundaryPrice = {\n   206→          price: BigInt(row.price),\n   207→          expo: row.expo,\n   208→          minuteTs: Number(row.minute_ts),\n   209→          priceHuman: row.price_human,\n   210→        };\n   211→        logger.info(\"closecall clock: loaded boundary price from DB\", {\n   212→          minuteTs: cachedBoundaryPrice.minuteTs,\n   213→          priceHuman: cachedBoundaryPrice.priceHuman,\n   214→        });\n   215→      }\n   216→    } catch (err) {\n   217→      logger.warn(\"closecall clock: failed to load boundary price from DB\", {\n   218→        error: err instanceof Error ? err.message : String(err),\n   219→      });\n   220→    }\n   221→  }\n   222→\n   223→  // -----------------------------------------------------------------------\n   224→  // Boundary price capture — poll Hermes until fresh price arrives\n   225→  // -----------------------------------------------------------------------\n   226→\n   227→  /**\n   228→   * Poll Hermes every 1s until we get a price with publishTime >= boundaryTs.\n   229→   * Returns the captured price or null if max retries exceeded.\n   230→   */\n   231→  async function captureBoundaryPrice(\n   232→    boundaryTs: number,\n   233→  ): Promise<BoundaryPrice | null> {\n   234→    for (let attempt = 0; attempt < HERMES_MAX_RETRIES; attempt++) {\n   235→      try {\n   236→        const result = await hermes.fetchLatestBtcPrice();\n   237→        if (result && result.publishTime >= boundaryTs) {\n   238→          const bp: BoundaryPrice = {\n   239→            price: result.price,\n   240→            expo: result.expo,\n   241→            minuteTs: boundaryTs,\n   242→            priceHuman: result.priceHuman,\n   243→          };\n   244→\n   245→          // Save to DB with VAA proof\n   246→          await saveBoundaryPrice(\n   247→            boundaryTs,\n   248→            result.price,\n   249→            result.expo,\n   250→            result.priceHuman,\n   251→            result.vaaBase64,\n   252→          );\n   253→\n   254→          cachedBoundaryPrice = bp;\n   255→\n   256→          logger.info(\"closecall clock: boundary price captured\", {\n   257→            minuteTs: boundaryTs,\n   258→            priceHuman: result.priceHuman,\n   259→            publishTime: result.publishTime,\n   260→            attempts: attempt + 1,\n   261→          });\n   262→\n   263→          return bp;\n   264→        }\n   265→\n   266→        if (result) {\n   267→          logger.debug(\"closecall clock: Hermes price not yet at boundary\", {\n   268→            publishTime: result.publishTime,\n   269→            boundaryTs,\n   270→            attempt: attempt + 1,\n   271→          });\n   272→        }\n   273→      } catch (err) {\n   274→        logger.warn(\"closecall clock: Hermes poll failed\", {\n   275→          attempt: attempt + 1,\n   276→          error: err instanceof Error ? err.message : String(err),\n   277→        });\n   278→      }\n   279→\n   280→      // Wait 1s before next attempt\n   281→      if (attempt < HERMES_MAX_RETRIES - 1) {\n   282→        await new Promise((r) => setTimeout(r, HERMES_POLL_INTERVAL_MS));\n   283→      }\n   284→    }\n   285→\n   286→    logger.warn(\"closecall clock: failed to capture boundary price after max retries\", {\n   287→      boundaryTs,\n   288→    });\n   289→    return null;\n   290→  }\n   291→\n   292→  // -----------------------------------------------------------------------\n   293→  // Round discovery\n   294→  // -----------------------------------------------------------------------\n   295→\n   296→  /**\n   297→   * Discover ALL existing open rounds owned by this server.\n   298→   */\n   299→  async function discoverOpenRounds(): Promise<\n   300→    Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }>\n   301→  > {\n   302→    const results: Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }> = [];\n   303→    try {\n   304→      const accounts = await connection.getProgramAccounts(\n   305→        CLOSECALL_PROGRAM_ID,\n   306→        { filters: [closeCallRoundDiscriminatorFilter()] },\n   307→      );\n   308→\n   309→      const now = Math.floor(Date.now() / 1000);\n   310→\n   311→      for (const { pubkey, account } of accounts) {\n   312→        try {\n   313→          const round = decodeCloseCallRound(Buffer.from(account.data));\n   314→\n   315→          // Skip rounds with garbage minuteTs (old format / random bytes)\n   316→          const ts = Number(round.minuteTs);\n   317→          if (ts < 1700000000 || ts > now + 120) continue;\n   318→\n   319→          if (\n   320→            round.phase === PHASE_OPEN &&\n   321→            round.server.equals(serverKeypair.publicKey)\n   322→          ) {\n   323→            results.push({ pda: pubkey, minuteTs: round.minuteTs, round });\n   324→          }\n   325→        } catch {\n   326→          // Skip undecodeable accounts\n   327→        }\n   328→      }\n   329→    } catch (err) {\n   330→      logger.warn(\"closecall clock: discovery scan failed\", {\n   331→        error: err instanceof Error ? err.message : String(err),\n   332→      });\n   333→    }\n   334→    return results;\n   335→  }\n   336→\n   337→  // -----------------------------------------------------------------------\n   338→  // Settlement\n   339→  // -----------------------------------------------------------------------\n   340→\n   341→  /**\n   342→   * Settle a single round. Returns true on success.\n   343→   */\n   344→  async function settleRound(\n   345→    roundPda: PublicKey,\n   346→    minuteTs: bigint,\n   347→    round: ReturnType<typeof decodeCloseCallRound>,\n   348→  ): Promise<boolean> {\n   349→    try {\n   350→      const nowSec = Math.floor(Date.now() / 1000);\n   351→      const candleCloseTime = Number(minuteTs) + 60;\n   352→\n   353→      if (nowSec < candleCloseTime) {\n   354→        logger.debug(\"closecall clock: candle not closed yet\", {\n   355→          pda: roundPda.toBase58(),\n   356→          secondsRemaining: candleCloseTime - nowSec,\n   357→        });\n   358→        return false;\n   359→      }\n   360→\n   361→      const greenCount = round.greenEntries.length;\n   362→      const redCount = round.redEntries.length;\n   363→      const totalCount = greenCount + redCount;\n   364→\n   365→      // Fetch treasury + close price\n   366→      const [treasury, hermesPrice] = await Promise.all([\n   367→        readTreasury(),\n   368→        hermes.fetchLatestBtcPrice(),\n   369→      ]);\n   370→\n   371→      if (!treasury) {\n   372→        logger.error(\"closecall clock: cannot read config treasury\");\n   373→        return false;\n   374→      }\n   375→      if (!hermesPrice) {\n   376→        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n   377→        return false;\n   378→      }\n   379→\n   380→      if (totalCount === 0) {\n   381→        logger.info(\"closecall clock: settling empty round\", {\n   382→          pda: roundPda.toBase58(),\n   383→        });\n   384→      }\n   385→\n   386→      // Pre-determine outcome\n   387→      const hasBothSides = greenCount > 0 && redCount > 0;\n   388→      const isRefund =\n   389→        totalCount === 0 ||\n   390→        !hasBothSides ||\n   391→        totalCount === 1 ||\n   392→        hermesPrice.price === round.openPrice;\n   393→\n   394→      let remainingAccounts: PublicKey[];\n   395→      if (isRefund) {\n   396→        remainingAccounts = [\n   397→          ...round.greenEntries.map((e) => e.player),\n   398→          ...round.redEntries.map((e) => e.player),\n   399→        ];\n   400→      } else if (hermesPrice.price > round.openPrice) {\n   401→        remainingAccounts = round.greenEntries.map((e) => e.player);\n   402→      } else {\n   403→        remainingAccounts = round.redEntries.map((e) => e.player);\n   404→      }\n   405→\n   406→      const ix = buildCloseCallSettleRoundIx(\n   407→        serverKeypair.publicKey,\n   408→        minuteTs,\n   409→        hermesPrice.price,\n   410→        hermesPrice.expo,\n   411→        treasury,\n   412→        remainingAccounts,\n   413→      );\n   414→\n   415→      const { blockhash, lastValidBlockHeight } =\n   416→        await connection.getLatestBlockhash();\n   417→      const tx = new Transaction({\n   418→        feePayer: serverKeypair.publicKey,\n   419→        blockhash,\n   420→        lastValidBlockHeight,\n   421→      });\n   422→      tx.add(ix);\n   423→      tx.sign(serverKeypair);\n   424→\n   425→      const sig = await sendAndConfirm(tx, \"settle\");\n   426→\n   427→      const outcomeStr = isRefund\n   428→        ? \"refund\"\n   429→        : hermesPrice.price > round.openPrice\n   430→          ? \"green\"\n   431→          : \"red\";\n   432→\n   433→      logger.info(\"closecall clock: round settled\", {\n   434→        pda: roundPda.toBase58(),\n   435→        tx: sig,\n   436→        totalEntries: totalCount,\n   437→        outcome: outcomeStr,\n   438→      });\n   439→\n   440→      // Persist settlement to DB\n   441→      try {\n   442→        // Ensure round record exists (may not if created before DB persistence was added)\n   443→        await sql`\n   444→          INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo, phase, created_at)\n   445→          VALUES (\n   446→            ${String(Number(minuteTs))},\n   447→            ${roundPda.toBase58()},\n   448→            ${serverKeypair.publicKey.toBase58()},\n   449→            ${Number(round.openPrice)},\n   450→            ${round.openPriceExpo},\n   451→            'open',\n   452→            NOW()\n   453→          )\n   454→          ON CONFLICT (round_id) DO NOTHING\n   455→        `;\n   456→\n   457→        // Format entries for JSONB storage\n   458→        const greenEntries = round.greenEntries.map((e) => ({\n   459→          player: e.player.toBase58(),\n   460→          amountLamports: Number(e.amountLamports),\n   461→        }));\n   462→        const redEntries = round.redEntries.map((e) => ({\n   463→          player: e.player.toBase58(),\n   464→          amountLamports: Number(e.amountLamports),\n   465→        }));\n   466→\n   467→        // Compute fee off-chain (on-chain totalFee is only set after settle,\n   468→        // but we read the account BEFORE settlement, so it's still 0).\n   469→        // Fee = 3% (300 bps) of total pool, truncated. 0 for refund rounds.\n   470→        const totalPool = Number(round.greenPool) + Number(round.redPool);\n   471→        const computedFee = isRefund ? 0 : Math.floor(totalPool * 300 / 10_000);\n   472→\n   473→        // Update with settlement data\n   474→        await sql`\n   475→          UPDATE closecall_rounds SET\n   476→            phase = ${isRefund ? \"refunded\" : \"settled\"},\n   477→            outcome = ${outcomeStr},\n   478→            close_price = ${Number(hermesPrice.price)},\n   479→            green_pool = ${Number(round.greenPool)},\n   480→            red_pool = ${Number(round.redPool)},\n   481→            total_fee = ${computedFee},\n   482→            green_entries = ${sql.json(greenEntries)},\n   483→            red_entries = ${sql.json(redEntries)},\n   484→            settle_tx = ${sig},\n   485→            settled_at = NOW()\n   486→          WHERE round_id = ${String(Number(minuteTs))}\n   487→        `;\n   488→      } catch (dbErr) {\n   489→        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n   490→          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n   491→        });\n   492→      }\n   493→\n   494→      return true;\n   495→    } catch (err) {\n   496→      logger.error(\"closecall clock: settlement failed\", {\n   497→        pda: roundPda.toBase58(),\n   498→        error: err instanceof Error ? err.message : String(err),\n   499→      });\n   500→      return false;\n   501→    }\n   502→  }\n   503→\n   504→  // -----------------------------------------------------------------------\n   505→  // Tick — fires at minute boundary + 1s\n   506→  // -----------------------------------------------------------------------\n   507→\n   508→  async function tick(): Promise<void> {\n   509→    const t0 = performance.now();\n   510→    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n   511→\n   512→    // Step 1: Capture boundary price (poll Hermes until fresh)\n   513→    await captureBoundaryPrice(boundaryTs);\n   514→\n   515→    // Step 2: Discover + settle all open rounds whose candle has closed\n   516→    const openRounds = await discoverOpenRounds();\n   517→\n   518→    for (const { pda, minuteTs, round } of openRounds) {\n   519→      await settleRound(pda, minuteTs, round);\n   520→    }\n   521→\n   522→    const elapsed = Math.round(performance.now() - t0);\n   523→    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n   524→  }\n   525→\n   526→  async function loop(): Promise<void> {\n   527→    if (!running) return;\n   528→    try {\n   529→      await tick();\n   530→    } catch (err) {\n   531→      logger.error(\"closecall clock loop error\", {\n   532→        error: err instanceof Error ? err.message : String(err),\n   533→      });\n   534→    }\n   535→    if (running) {\n   536→      const delay = msUntilNextBoundary();\n   537→      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n   538→      timeoutId = setTimeout(loop, delay);\n   539→    }\n   540→  }\n   541→\n   542→  // -----------------------------------------------------------------------\n   543→  // Public interface\n   544→  // -----------------------------------------------------------------------\n   545→\n   546→  return {\n   547→    start() {\n   548→      if (running) return;\n   549→      running = true;\n   550→\n   551→      logger.info(\"closecall clock started\", {\n   552→        serverKey: serverKeypair.publicKey.toBase58(),\n   553→        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n   554→      });\n   555→\n   556→      // Load latest boundary price from DB, then schedule first tick\n   557→      loadLatestBoundaryFromDb()\n   558→        .then(() => {\n   559→          if (!running) return;\n   560→          const delay = msUntilNextBoundary();\n   561→          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n   562→          timeoutId = setTimeout(loop, delay);\n   563→        })\n   564→        .catch((err) => {\n   565→          logger.error(\"closecall clock: startup init failed\", {\n   566→            error: err instanceof Error ? err.message : String(err),\n   567→          });\n   568→          if (running) {\n   569→            const delay = msUntilNextBoundary();\n   570→            timeoutId = setTimeout(loop, delay);\n   571→          }\n   572→        });\n   573→    },\n   574→\n   575→    stop() {\n   576→      running = false;\n   577→      if (timeoutId) {\n   578→        clearTimeout(timeoutId);\n   579→        timeoutId = null;\n   580→      }\n   581→      logger.info(\"closecall clock stopped\");\n   582→    },\n   583→\n   584→    get isRunning() {\n   585→      return running;\n   586→    },\n   587→\n   588→    tick,\n   589→\n   590→    getLatestBoundaryPrice(): BoundaryPrice | null {\n   591→      return cachedBoundaryPrice;\n   592→    },\n   593→  };\n   594→}\n   595→"}]},"parent_tool_use_id":"toolu_01KqKLgHFeADqHYqkg5P4qaw","session_id":"0ab61bc6-f37e-46f2-adbe-0242ac985946","uuid":"e4f40444-eb63-4536-929a-5e5b245cef0c","timestamp":"2026-03-19T18:50:58.179Z"}
