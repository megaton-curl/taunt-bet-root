{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ToHHwS7J3Lk4LjFwVQSyQ8","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    23→import {\n    24→  decodeCoinflipMatch,\n    25→  decodeCoinflipConfig,\n    26→  decodeLordRound,\n    27→  decodeLordConfig,\n    28→  type DecodedJackpotRound,\n    29→} from \"./account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→function getInstructionDiscriminator(\n    36→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    37→  instructionName: string,\n    38→): Buffer {\n    39→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    40→  if (!instruction) {\n    41→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    42→  }\n    43→  return Buffer.from(instruction.discriminator);\n    44→}\n    45→\n    46→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    47→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    48→  lordIdl,\n    49→  \"claim_payout\",\n    50→);\n    51→const CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    52→const CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    53→const CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    54→\n    55→// ---------------------------------------------------------------------------\n    56→// Types\n    57→// ---------------------------------------------------------------------------\n    58→\n    59→export interface SettleTxDeps {\n    60→  db: Db;\n    61→  connection: Connection;\n    62→  serverKeypair: Keypair;\n    63→  entropyAccount: PublicKey;\n    64→}\n    65→\n    66→export interface SettleResult {\n    67→  txSignature: string;\n    68→  resultHash: Buffer;\n    69→  resultSide?: number;\n    70→  winningEntryIndex?: number;\n    71→  winner: string;\n    72→}\n    73→\n    74→// ---------------------------------------------------------------------------\n    75→// PDA helpers\n    76→// ---------------------------------------------------------------------------\n    77→\n    78→function deriveConfigPda(): [PublicKey, number] {\n    79→  return PublicKey.findProgramAddressSync(\n    80→    [Buffer.from(\"coinflip_config\")],\n    81→    COINFLIP_PROGRAM_ID,\n    82→  );\n    83→}\n    84→\n    85→function deriveLordConfigPda(): [PublicKey, number] {\n    86→  return PublicKey.findProgramAddressSync(\n    87→    [Buffer.from(\"lord_config\")],\n    88→    LORDOFRNGS_PROGRAM_ID,\n    89→  );\n    90→}\n    91→\n    92→// ---------------------------------------------------------------------------\n    93→// Instruction encoding\n    94→// ---------------------------------------------------------------------------\n    95→\n    96→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    97→function encodeSettleData(secret: Buffer): Buffer {\n    98→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    99→}\n   100→\n   101→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n   102→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n   103→}\n   104→\n   105→// ---------------------------------------------------------------------------\n   106→// Result derivation (mirrors on-chain derive_result)\n   107→// ---------------------------------------------------------------------------\n   108→\n   109→/**\n   110→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n   111→ * Must match shared/src/fairness.rs `derive_result()`.\n   112→ */\n   113→function deriveResult(\n   114→  secret: Buffer,\n   115→  entropy: Buffer,\n   116→  matchPdaBytes: Buffer,\n   117→  algoVer: number,\n   118→): Buffer {\n   119→  return createHash(\"sha256\")\n   120→    .update(secret)\n   121→    .update(entropy)\n   122→    .update(matchPdaBytes)\n   123→    .update(Buffer.from([algoVer]))\n   124→    .digest();\n   125→}\n   126→\n   127→// ---------------------------------------------------------------------------\n   128→// Core settle function\n   129→// ---------------------------------------------------------------------------\n   130→\n   131→/**\n   132→ * Build, submit, and confirm a settle transaction for a locked match.\n   133→ *\n   134→ * Steps:\n   135→ * 1. Retrieve secret from DB\n   136→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   137→ * 3. Fetch config account data (treasury)\n   138→ * 4. Read entropy from the entropy account\n   139→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   140→ * 6. Build + submit settle tx\n   141→ * 7. Update DB on confirmation\n   142→ */\n   143→export async function settleMatch(\n   144→  deps: SettleTxDeps,\n   145→  pda: string,\n   146→): Promise<SettleResult> {\n   147→  const t0 = performance.now();\n   148→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   149→  const matchPubkey = new PublicKey(pda);\n   150→\n   151→  // 1. Retrieve secret from DB\n   152→  const round = await db.getRoundByPda(pda);\n   153→  const tDb = performance.now();\n   154→  if (!round) {\n   155→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   156→  }\n   157→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   158→    throw new PermanentSettleError(\n   159→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   160→    );\n   161→  }\n   162→\n   163→  const secret = Buffer.from(round.secret);\n   164→\n   165→  // Transition to settling (locked → settling)\n   166→  if (round.phase === \"locked\") {\n   167→    await db.updateRoundPhase(pda, \"settling\");\n   168→  }\n   169→\n   170→  // Log settle_submitted\n   171→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   172→    attempt: round.settle_attempts + 1,\n   173→  });\n   174→\n   175→  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n   176→  const [configPda] = deriveConfigPda();\n   177→  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   178→    await Promise.all([\n   179→      connection.getAccountInfo(matchPubkey),\n   180→      connection.getAccountInfo(configPda),\n   181→      connection.getAccountInfo(entropyAccount),\n   182→      connection.getLatestBlockhash(),\n   183→    ]);\n   184→  const tFetch = performance.now();\n   185→\n   186→  if (!matchAccountInfo) {\n   187→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   188→  }\n   189→  if (!configAccountInfo) {\n   190→    throw new PermanentSettleError(\"Coinflip config account not found\");\n   191→  }\n   192→  if (!entropyInfo) {\n   193→    throw new TransientSettleError(\"Entropy account not available yet\");\n   194→  }\n   195→\n   196→  // IDL-driven decode — no manual byte offsets\n   197→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   198→  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n   199→\n   200→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   201→  const { treasury } = config;\n   202→\n   203→  const pool = entryAmount * 2n;\n   204→  const feeAmount = Number((pool * 300n) / 10_000n);\n   205→  const payoutAmount = Number(pool) - feeAmount;\n   206→\n   207→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   208→\n   209→  // 5. Pre-compute result\n   210→  const matchPdaBytes = matchPubkey.toBuffer();\n   211→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   212→  const resultSide = resultHash[0]! % 2;\n   213→  const winner = resultSide === creatorSide ? creator : opponent;\n   214→\n   215→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   216→  const data = encodeSettleData(secret);\n   217→\n   218→  const instruction = new TransactionInstruction({\n   219→    keys: [\n   220→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   221→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   222→      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n   223→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   224→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   225→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   226→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   227→      {\n   228→        pubkey: SystemProgram.programId,\n   229→        isSigner: false,\n   230→        isWritable: false,\n   231→      }, // system_program\n   232→    ],\n   233→    programId: COINFLIP_PROGRAM_ID,\n   234→    data,\n   235→  });\n   236→\n   237→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   238→\n   239→  const tx = new Transaction({\n   240→    feePayer: serverKeypair.publicKey,\n   241→    blockhash,\n   242→    lastValidBlockHeight,\n   243→  });\n   244→  tx.add(instruction);\n   245→  tx.sign(serverKeypair);\n   246→\n   247→  // 7. Submit and confirm\n   248→  const rawTx = tx.serialize();\n   249→  const tBuild = performance.now();\n   250→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   251→    skipPreflight: false,\n   252→  });\n   253→  const tSend = performance.now();\n   254→\n   255→  logger.info(\"settlement transaction submitted\", {\n   256→    pda,\n   257→    txSignature,\n   258→    attempt: round.settle_attempts + 1,\n   259→    dbMs: Math.round(tDb - t0),\n   260→    fetchMs: Math.round(tFetch - tDb),\n   261→    buildMs: Math.round(tBuild - tFetch),\n   262→    sendMs: Math.round(tSend - tBuild),\n   263→  });\n   264→\n   265→  const confirmation = await connection.confirmTransaction(\n   266→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   267→    \"confirmed\",\n   268→  );\n   269→  const tConfirm = performance.now();\n   270→  if (confirmation.value.err) {\n   271→    throw new TransientSettleError(\n   272→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   273→    );\n   274→  }\n   275→\n   276→  // 8. Update DB — phase settling → settled\n   277→  const coinflipEntries = [\n   278→    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n   279→    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n   280→  ];\n   281→\n   282→  await db.updateRoundPhase(pda, \"settled\", {\n   283→    settle_tx: txSignature,\n   284→    result_hash: resultHash,\n   285→    result_side: resultSide,\n   286→    winner: winner.toBase58(),\n   287→    settle_attempts: round.settle_attempts + 1,\n   288→  });\n   289→\n   290→  // Persist entries in dedicated JSONB column for direct access\n   291→  await db.updateRoundEntries(pda, coinflipEntries);\n   292→\n   293→  // Log settle_confirmed\n   294→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   295→    txSignature,\n   296→    resultSide,\n   297→    winner: winner.toBase58(),\n   298→    entropy: entropy.toString(\"hex\"),\n   299→    payoutAmount,\n   300→    feeAmount,\n   301→    entries: coinflipEntries,\n   302→  });\n   303→\n   304→  // Write user transactions — win + loss\n   305→  const loser = winner.equals(creator) ? opponent : creator;\n   306→  await Promise.all([\n   307→    db.insertUserTransaction({\n   308→      wallet: winner.toBase58(),\n   309→      game: \"coinflip\",\n   310→      matchId: round.match_id,\n   311→      event: \"win\",\n   312→      amountLamports: payoutAmount,\n   313→      txSig: txSignature,\n   314→    }),\n   315→    db.insertUserTransaction({\n   316→      wallet: loser.toBase58(),\n   317→      game: \"coinflip\",\n   318→      matchId: round.match_id,\n   319→      event: \"loss\",\n   320→      amountLamports: Number(entryAmount),\n   321→      txSig: txSignature,\n   322→    }),\n   323→  ]);\n   324→\n   325→  const tDone = performance.now();\n   326→  logger.info(\"settlement transaction confirmed\", {\n   327→    pda,\n   328→    txSignature,\n   329→    resultSide,\n   330→    winner: winner.toBase58(),\n   331→    timing: {\n   332→      dbMs: Math.round(tDb - t0),\n   333→      fetchMs: Math.round(tFetch - tDb),\n   334→      buildMs: Math.round(tBuild - tFetch),\n   335→      sendMs: Math.round(tSend - tBuild),\n   336→      confirmMs: Math.round(tConfirm - tSend),\n   337→      dbWriteMs: Math.round(tDone - tConfirm),\n   338→      totalMs: Math.round(tDone - t0),\n   339→    },\n   340→  });\n   341→\n   342→  return {\n   343→    txSignature,\n   344→    resultHash,\n   345→    resultSide,\n   346→    winner: winner.toBase58(),\n   347→  };\n   348→}\n   349→\n   350→export async function settleLordRound(\n   351→  deps: SettleTxDeps,\n   352→  pda: string,\n   353→): Promise<SettleResult> {\n   354→  const t0 = performance.now();\n   355→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   356→  const roundPubkey = new PublicKey(pda);\n   357→\n   358→  const round = await db.getRoundByPda(pda);\n   359→  const tDb = performance.now();\n   360→  if (!round) {\n   361→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   362→  }\n   363→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   364→    throw new PermanentSettleError(\n   365→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   366→    );\n   367→  }\n   368→\n   369→  const secret = Buffer.from(round.secret);\n   370→\n   371→  if (round.phase === \"locked\") {\n   372→    await db.updateRoundPhase(pda, \"settling\");\n   373→  }\n   374→\n   375→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   376→    attempt: round.settle_attempts + 1,\n   377→    game: \"lord\",\n   378→  });\n   379→\n   380→  const [configPda] = deriveLordConfigPda();\n   381→  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   382→    await Promise.all([\n   383→      connection.getAccountInfo(roundPubkey),\n   384→      connection.getAccountInfo(configPda),\n   385→      connection.getAccountInfo(entropyAccount),\n   386→      connection.getLatestBlockhash(),\n   387→    ]);\n   388→\n   389→  const tFetch = performance.now();\n   390→\n   391→  if (!roundAccountInfo) {\n   392→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   393→  }\n   394→  if (!configAccountInfo) {\n   395→    throw new PermanentSettleError(\"Lord config account not found\");\n   396→  }\n   397→  if (!entropyInfo) {\n   398→    throw new TransientSettleError(\"Entropy account not available yet\");\n   399→  }\n   400→\n   401→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   402→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   403→  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n   404→  const { treasury } = lordConfig;\n   405→\n   406→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   407→  const resultHash = deriveResult(\n   408→    secret,\n   409→    entropy,\n   410→    roundPubkey.toBuffer(),\n   411→    roundData.algorithmVer,\n   412→  );\n   413→  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n   414→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   415→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   416→\n   417→  const raw = resultHash.readBigUInt64LE(0);\n   418→  const winningOffset = raw % roundData.totalAmountLamports;\n   419→\n   420→  let cumulative = 0n;\n   421→  let winnerEntryIndex = -1;\n   422→  let winner = roundData.entries[0]?.player;\n   423→  for (const [index, entry] of roundData.entries.entries()) {\n   424→    cumulative += entry.amountLamports;\n   425→    if (winningOffset < cumulative) {\n   426→      winnerEntryIndex = index;\n   427→      winner = entry.player;\n   428→      break;\n   429→    }\n   430→  }\n   431→\n   432→  if (!winner || winnerEntryIndex < 0) {\n   433→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   434→  }\n   435→\n   436→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   437→  const instruction = new TransactionInstruction({\n   438→    keys: [\n   439→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   440→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   441→      { pubkey: configPda, isSigner: false, isWritable: false },\n   442→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   443→      { pubkey: treasury, isSigner: false, isWritable: true },\n   444→      { pubkey: winner, isSigner: false, isWritable: true },\n   445→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   446→    ],\n   447→    programId: LORDOFRNGS_PROGRAM_ID,\n   448→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   449→  });\n   450→\n   451→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   452→  const tx = new Transaction({\n   453→    feePayer: serverKeypair.publicKey,\n   454→    blockhash,\n   455→    lastValidBlockHeight,\n   456→  });\n   457→  tx.add(instruction);\n   458→  tx.sign(serverKeypair);\n   459→\n   460→  const tBuild = performance.now();\n   461→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   462→    skipPreflight: false,\n   463→  });\n   464→  const tSend = performance.now();\n   465→\n   466→  logger.info(\"lord settlement transaction submitted\", {\n   467→    pda,\n   468→    txSignature,\n   469→    attempt: round.settle_attempts + 1,\n   470→    winningEntryIndex: winnerEntryIndex,\n   471→    dbMs: Math.round(tDb - t0),\n   472→    fetchMs: Math.round(tFetch - tDb),\n   473→    buildMs: Math.round(tBuild - tFetch),\n   474→    sendMs: Math.round(tSend - tBuild),\n   475→  });\n   476→\n   477→  const confirmation = await connection.confirmTransaction(\n   478→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   479→    \"confirmed\",\n   480→  );\n   481→  const tConfirm = performance.now();\n   482→  if (confirmation.value.err) {\n   483→    throw new TransientSettleError(\n   484→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   485→    );\n   486→  }\n   487→\n   488→  const serializedEntries = roundData.entries.map((e) => ({\n   489→    player: e.player.toBase58(),\n   490→    amountLamports: Number(e.amountLamports),\n   491→  }));\n   492→\n   493→  await db.updateRoundPhase(pda, \"settled\", {\n   494→    settle_tx: txSignature,\n   495→    result_hash: resultHash,\n   496→    result_side: winnerEntryIndex,\n   497→    winner: winner.toBase58(),\n   498→    settle_attempts: round.settle_attempts + 1,\n   499→  });\n   500→\n   501→  // Persist entries in dedicated JSONB column for direct access\n   502→  await db.updateRoundEntries(pda, serializedEntries);\n   503→\n   504→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   505→    txSignature,\n   506→    winner: winner.toBase58(),\n   507→    winningEntryIndex: winnerEntryIndex,\n   508→    game: \"lord\",\n   509→    entropy: entropy.toString(\"hex\"),\n   510→    winningOffset: winningOffset.toString(),\n   511→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   512→    payoutAmount,\n   513→    feeAmount,\n   514→    rentRefund,\n   515→    entries: serializedEntries,\n   516→  });\n   517→\n   518→  // Write user transactions — win for winner, loss for each losing entry\n   519→  const userTxInserts = [\n   520→    db.insertUserTransaction({\n   521→      wallet: winner.toBase58(),\n   522→      game: \"lord\",\n   523→      matchId: round.match_id,\n   524→      event: \"win\",\n   525→      amountLamports: payoutAmount,\n   526→      txSig: txSignature,\n   527→    }),\n   528→  ];\n   529→  for (const entry of roundData.entries) {\n   530→    if (!entry.player.equals(winner)) {\n   531→      userTxInserts.push(\n   532→        db.insertUserTransaction({\n   533→          wallet: entry.player.toBase58(),\n   534→          game: \"lord\",\n   535→          matchId: round.match_id,\n   536→          event: \"loss\",\n   537→          amountLamports: Number(entry.amountLamports),\n   538→          txSig: txSignature,\n   539→        }),\n   540→      );\n   541→    }\n   542→  }\n   543→  await Promise.all(userTxInserts);\n   544→\n   545→  const tDone = performance.now();\n   546→  logger.info(\"lord settlement transaction confirmed\", {\n   547→    pda,\n   548→    txSignature,\n   549→    winner: winner.toBase58(),\n   550→    winningEntryIndex: winnerEntryIndex,\n   551→    timing: {\n   552→      dbMs: Math.round(tDb - t0),\n   553→      fetchMs: Math.round(tFetch - tDb),\n   554→      buildMs: Math.round(tBuild - tFetch),\n   555→      sendMs: Math.round(tSend - tBuild),\n   556→      confirmMs: Math.round(tConfirm - tSend),\n   557→      dbWriteMs: Math.round(tDone - tConfirm),\n   558→      totalMs: Math.round(tDone - t0),\n   559→    },\n   560→  });\n   561→\n   562→  return {\n   563→    txSignature,\n   564→    resultHash,\n   565→    winningEntryIndex: winnerEntryIndex,\n   566→    winner: winner.toBase58(),\n   567→  };\n   568→}\n   569→\n   570→export async function settleRound(\n   571→  deps: SettleTxDeps,\n   572→  pda: string,\n   573→): Promise<SettleResult> {\n   574→  const round = await deps.db.getRoundByPda(pda);\n   575→  if (!round) {\n   576→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   577→  }\n   578→\n   579→  if (round.game === \"lord\") {\n   580→    return settleLordRound(deps, pda);\n   581→  }\n   582→\n   583→  return settleMatch(deps, pda);\n   584→}\n   585→\n   586→// ---------------------------------------------------------------------------\n   587→// Close Call — transaction builders\n   588→// ---------------------------------------------------------------------------\n   589→\n   590→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   591→  return PublicKey.findProgramAddressSync(\n   592→    [Buffer.from(\"closecall_config\")],\n   593→    CLOSECALL_PROGRAM_ID,\n   594→  );\n   595→}\n   596→\n   597→function minuteTsToBuffer(ts: bigint): Buffer {\n   598→  const buf = Buffer.alloc(8);\n   599→  buf.writeBigInt64LE(ts);\n   600→  return buf;\n   601→}\n   602→\n   603→function deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n   604→  return PublicKey.findProgramAddressSync(\n   605→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n   606→    CLOSECALL_PROGRAM_ID,\n   607→  );\n   608→}\n   609→\n   610→/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n   611→function encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n   612→  const buf = Buffer.alloc(16);\n   613→  discriminator.copy(buf, 0);\n   614→  buf.writeBigInt64LE(minuteTs, 8);\n   615→  return buf;\n   616→}\n   617→\n   618→/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n   619→function encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n   620→  const buf = Buffer.alloc(28);\n   621→  discriminator.copy(buf, 0);\n   622→  buf.writeBigInt64LE(minuteTs, 8);\n   623→  buf.writeBigInt64LE(price, 16);\n   624→  buf.writeInt32LE(expo, 24);\n   625→  return buf;\n   626→}\n   627→\n   628→/**\n   629→ * Encode closecall bet data:\n   630→ * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n   631→ */\n   632→function encodeCcBetData(\n   633→  discriminator: Buffer,\n   634→  minuteTs: bigint,\n   635→  side: number,\n   636→  amount: bigint,\n   637→  openPrice: bigint,\n   638→  openPriceExpo: number,\n   639→): Buffer {\n   640→  const buf = Buffer.alloc(37);\n   641→  discriminator.copy(buf, 0);\n   642→  buf.writeBigInt64LE(minuteTs, 8);\n   643→  buf.writeUInt8(side, 16);\n   644→  buf.writeBigUInt64LE(amount, 17);\n   645→  buf.writeBigInt64LE(openPrice, 25);\n   646→  buf.writeInt32LE(openPriceExpo, 33);\n   647→  return buf;\n   648→}\n   649→\n   650→export interface CloseCallTxDeps {\n   651→  connection: Connection;\n   652→  serverKeypair: Keypair;\n   653→}\n   654→\n   655→/**\n   656→ * Build a `bet` instruction (no transaction wrapping).\n   657→ *\n   658→ * Two signers: player (pays bet) + server (pays rent on first call).\n   659→ * Price + bet info passed as instruction args.\n   660→ * Uses init_if_needed — works for both round creation and joining.\n   661→ */\n   662→export function buildCloseCallBetIx(\n   663→  serverPubkey: PublicKey,\n   664→  playerPubkey: PublicKey,\n   665→  minuteTs: bigint,\n   666→  side: number,\n   667→  amountLamports: bigint,\n   668→  openPrice: bigint,\n   669→  openPriceExpo: number,\n   670→): TransactionInstruction {\n   671→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   672→  const [configPda] = deriveCloseCallConfigPda();\n   673→  const data = encodeCcBetData(\n   674→    CC_BET_DISCRIMINATOR,\n   675→    minuteTs,\n   676→    side,\n   677→    amountLamports,\n   678→    openPrice,\n   679→    openPriceExpo,\n   680→  );\n   681→\n   682→  return new TransactionInstruction({\n   683→    keys: [\n   684→      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n   685→      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n   686→      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n   687→      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n   688→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   689→    ],\n   690→    programId: CLOSECALL_PROGRAM_ID,\n   691→    data,\n   692→  });\n   693→}\n   694→\n   695→/**\n   696→ * Build a `settle_round` instruction (no transaction wrapping).\n   697→ * Price is passed as instruction args (no on-chain Pyth account).\n   698→ */\n   699→export function buildCloseCallSettleRoundIx(\n   700→  serverPubkey: PublicKey,\n   701→  minuteTs: bigint,\n   702→  closePrice: bigint,\n   703→  closePriceExpo: number,\n   704→  treasury: PublicKey,\n   705→  winnerAccounts: PublicKey[],\n   706→): TransactionInstruction {\n   707→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   708→  const [configPda] = deriveCloseCallConfigPda();\n   709→  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n   710→\n   711→  return new TransactionInstruction({\n   712→    keys: [\n   713→      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n   714→      { pubkey: roundPda, isSigner: false, isWritable: true },\n   715→      { pubkey: configPda, isSigner: false, isWritable: false },\n   716→      { pubkey: treasury, isSigner: false, isWritable: true },\n   717→      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n   718→      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   719→    ],\n   720→    programId: CLOSECALL_PROGRAM_ID,\n   721→    data,\n   722→  });\n   723→}\n   724→\n   725→/**\n   726→ * Build a partially-signed `bet` transaction for the Close Call program.\n   727→ *\n   728→ * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n   729→ * Server signs immediately; the frontend must add the player signature before submitting.\n   730→ * Works for both round creation (first bet) and joining (subsequent bets).\n   731→ */\n   732→export async function buildCloseCallBetTx(\n   733→  deps: CloseCallTxDeps,\n   734→  playerPubkey: PublicKey,\n   735→  minuteTs: bigint,\n   736→  side: number,\n   737→  amountLamports: bigint,\n   738→  openPrice: bigint,\n   739→  openPriceExpo: number,\n   740→): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   741→  const { connection, serverKeypair } = deps;\n   742→\n   743→  const instruction = buildCloseCallBetIx(\n   744→    serverKeypair.publicKey,\n   745→    playerPubkey,\n   746→    minuteTs,\n   747→    side,\n   748→    amountLamports,\n   749→    openPrice,\n   750→    openPriceExpo,\n   751→  );\n   752→\n   753→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   754→\n   755→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   756→  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n   757→  tx.add(instruction);\n   758→  tx.partialSign(serverKeypair);\n   759→\n   760→  return { tx, roundPda };\n   761→}\n   762→\n   763→/**\n   764→ * Build a signed `settle_round` transaction for the Close Call program.\n   765→ *\n   766→ * Price is passed as instruction args. Winners (or all players for refund)\n   767→ * are passed as remaining accounts for auto-payout.\n   768→ */\n   769→export async function buildCloseCallSettleRoundTx(\n   770→  deps: CloseCallTxDeps,\n   771→  minuteTs: bigint,\n   772→  closePrice: bigint,\n   773→  closePriceExpo: number,\n   774→  treasury: PublicKey,\n   775→  winnerAccounts: PublicKey[],\n   776→): Promise<Transaction> {\n   777→  const { connection, serverKeypair } = deps;\n   778→\n   779→  const instruction = buildCloseCallSettleRoundIx(\n   780→    serverKeypair.publicKey,\n   781→    minuteTs,\n   782→    closePrice,\n   783→    closePriceExpo,\n   784→    treasury,\n   785→    winnerAccounts,\n   786→  );\n   787→\n   788→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   789→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   790→  tx.add(instruction);\n   791→  tx.sign(serverKeypair);\n   792→\n   793→  return tx;\n   794→}\n   795→\n   796→/**\n   797→ * Build a signed `timeout_refund` transaction for the Close Call program.\n   798→ *\n   799→ * Permissionless after the resolve deadline. Refunds all players their exact\n   800→ * deposit via remaining accounts.\n   801→ */\n   802→export async function buildCloseCallTimeoutRefundTx(\n   803→  deps: CloseCallTxDeps,\n   804→  minuteTs: bigint,\n   805→  playerAccounts: PublicKey[],\n   806→): Promise<Transaction> {\n   807→  const { connection, serverKeypair } = deps;\n   808→\n   809→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   810→  const [configPda] = deriveCloseCallConfigPda();\n   811→  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n   812→\n   813→  const keys = [\n   814→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   815→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   816→    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n   817→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   818→    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   819→  ];\n   820→\n   821→  const instruction = new TransactionInstruction({\n   822→    keys,\n   823→    programId: CLOSECALL_PROGRAM_ID,\n   824→    data,\n   825→  });\n   826→\n   827→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   828→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   829→  tx.add(instruction);\n   830→  tx.sign(serverKeypair);\n   831→\n   832→  return tx;\n   833→}\n   834→\n   835→// ---------------------------------------------------------------------------\n   836→// Error types\n   837→// ---------------------------------------------------------------------------\n   838→\n   839→/** Permanent failure — should not be retried. */\n   840→export class PermanentSettleError extends Error {\n   841→  readonly permanent = true;\n   842→  constructor(message: string) {\n   843→    super(message);\n   844→    this.name = \"PermanentSettleError\";\n   845→  }\n   846→}\n   847→\n   848→/** Transient failure — safe to retry. */\n   849→export class TransientSettleError extends Error {\n   850→  readonly permanent = false;\n   851→  constructor(message: string) {\n   852→    super(message);\n   853→    this.name = \"TransientSettleError\";\n   854→  }\n   855→}\n   856→"}]},"parent_tool_use_id":"toolu_01NNzSvg6Dm9Fg42UNHGx6QU","session_id":"0ab61bc6-f37e-46f2-adbe-0242ac985946","uuid":"d386db36-0ee0-4fae-9a20-7063fbaf0996","timestamp":"2026-03-19T18:51:02.691Z"}
