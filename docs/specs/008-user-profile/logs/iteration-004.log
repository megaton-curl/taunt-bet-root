ice(): BoundaryPrice | null;\n    79→}\n    80→\n    81→// ---------------------------------------------------------------------------\n    82→// Factory\n    83→// ---------------------------------------------------------------------------\n    84→\n    85→export function createCloseCallClockWorker(\n    86→  deps: CloseCallClockDeps,\n    87→): CloseCallClockWorker {\n    88→  const { connection, serverKeypair, hermesEndpoint, db: sql } = deps;\n    89→\n    90→  const hermes: HermesFetcher = createHermesFetcher(hermesEndpoint);\n    91→\n    92→  let running = false;\n    93→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    94→\n    95→  /** Cached latest boundary price (in-memory). */\n    96→  let cachedBoundaryPrice: BoundaryPrice | null = null;\n    97→\n    98→  // -----------------------------------------------------------------------\n    99→  // Scheduling\n   100→  // -----------------------------------------------------------------------\n   101→\n   102→  /** Milliseconds until the next minute boundary + offset. */\n   103→  function msUntilNextBoundary(): number {\n   104→    const now = Date.now();\n   105→    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n   106→    return nextMinute - now + BOUNDARY_OFFSET_MS;\n   107→  }\n   108→\n   109→  // -----------------------------------------------------------------------"}]},"parent_tool_use_id":null,"session_id":"0ab61bc6-f37e-46f2-adbe-0242ac985946","uuid":"efe9e1e1-4f94-45fa-88d3-72e9c9ec59cc","timestamp":"2026-03-19T18:51:37.017Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts","content":"  decodeCloseCallConfig,\n  decodeCloseCallRound,\n} from \"./account-decoder.js\";\nimport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n\n/** Close Call on-chain phase values */\nconst PHASE_OPEN = 0;\n\n/** How long to wait after minute boundary before first Hermes poll (ms). */\nconst BOUNDARY_OFFSET_MS = 1_000;\n\n/** Poll Hermes every 1s when waiting for boundary price. */\nconst HERMES_POLL_INTERVAL_MS = 1_000;\n\n/** Max attempts to fetch a fresh boundary price (10s total). */\nconst HERMES_MAX_RETRIES = 10;\n\n/** Maximum retry attempts for a single tx submission. */\nconst MAX_TX_RETRIES = 3;\nconst TX_RETRY_DELAY_MS = 2_000;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface BoundaryPrice {\n  price: bigint;\n  expo: number;\n  minuteTs: number;\n  priceHuman: number;\n}\n\nexport interface CloseCallClockDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n  /** Postgres `sql` tagged template instance for candle table access. */\n  db: postgres.Sql;\n  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n  hermesEndpoint?: string;\n}\n\nexport interface CloseCallClockWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single tick (exposed for testing). */\n  tick(): Promise<void>;\n  /** Get the most recent minute-boundary price (from cache). */\n  getLatestBoundaryPrice(): BoundaryPrice | null;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createCloseCallClockWorker(\n  deps: CloseCallClockDeps,\n): CloseCallClockWorker {\n  const { connection, serverKeypair, hermesEndpoint, db: sql } = deps;\n\n  const hermes: HermesFetcher = createHermesFetcher(hermesEndpoint);\n\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  /** Cached latest boundary price (in-memory). */\n  let cachedBoundaryPrice: BoundaryPrice | null = null;\n\n  // -----------------------------------------------------------------------\n  // Scheduling\n  // -----------------------------------------------------------------------\n\n  /** Milliseconds until the next minute boundary + offset. */\n  function msUntilNextBoundary(): number {\n    const now = Date.now();\n    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    return nextMinute - now + BOUNDARY_OFFSET_MS;\n  }\n\n  // -----------------------------------------------------------------------","numLines":80,"startLine":30,"totalLines":595}}}
