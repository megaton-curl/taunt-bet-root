 round.match_id,\n          event: \"loss\",\n          amountLamports: Number(entry.amountLamports),\n          txSig: txSignature,\n        }),\n      );\n    }\n  }\n  await Promise.all(userTxInserts);\n\n  const tDone = performance.now();","originalFile":"/**\n * Settle transaction builder + submission.\n *\n * Retrieves the stored secret, reads on-chain match + config data to resolve\n * all accounts, builds the `settle` instruction, submits it, and updates the\n * DB on confirmation.\n */\n\nimport { createHash } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\nimport {\n  decodeCoinflipMatch,\n  decodeCoinflipConfig,\n  decodeLordRound,\n  decodeLordConfig,\n  type DecodedJackpotRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Instruction discriminators (from IDL — no hardcoded byte arrays)\n// ---------------------------------------------------------------------------\n\nfunction getInstructionDiscriminator(\n  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n  instructionName: string,\n): Buffer {\n  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n  if (!instruction) {\n    throw new Error(`Instruction ${instructionName} not found in IDL`);\n  }\n  return Buffer.from(instruction.discriminator);\n}\n\nconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\nconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n  lordIdl,\n  \"claim_payout\",\n);\nconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\nconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\nconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface SettleTxDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  entropyAccount: PublicKey;\n}\n\nexport interface SettleResult {\n  txSignature: string;\n  resultHash: Buffer;\n  resultSide?: number;\n  winningEntryIndex?: number;\n  winner: string;\n}\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\n\nfunction deriveConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n\nfunction deriveLordConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID,\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Instruction encoding\n// ---------------------------------------------------------------------------\n\n/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\nfunction encodeSettleData(secret: Buffer): Buffer {\n  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n}\n\nfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n}\n\n// ---------------------------------------------------------------------------\n// Result derivation (mirrors on-chain derive_result)\n// ---------------------------------------------------------------------------\n\n/**\n * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n * Must match shared/src/fairness.rs `derive_result()`.\n */\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")\n    .update(secret)\n    .update(entropy)\n    .update(matchPdaBytes)\n    .update(Buffer.from([algoVer]))\n    .digest();\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on confirmation\n */\nexport async function settleMatch(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const matchPubkey = new PublicKey(pda);\n\n  // 1. Retrieve secret from DB\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  // Transition to settling (locked → settling)\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  // Log settle_submitted\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n  });\n\n  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n  const [configPda] = deriveConfigPda();\n  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(matchPubkey),\n      connection.getAccountInfo(configPda),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n  const tFetch = performance.now();\n\n  if (!matchAccountInfo) {\n    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n  }\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Coinflip config account not found\");\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets\n  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n\n  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n  const { treasury } = config;\n\n  const pool = entryAmount * 2n;\n  const feeAmount = Number((pool * 300n) / 10_000n);\n  const payoutAmount = Number(pool) - feeAmount;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n\n  // 5. Pre-compute result\n  const matchPdaBytes = matchPubkey.toBuffer();\n  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n  const resultSide = resultHash[0]! % 2;\n  const winner = resultSide === creatorSide ? creator : opponent;\n\n  // 6. Build settle instruction (8 accounts, no profile CPI)\n  const data = encodeSettleData(secret);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      }, // system_program\n    ],\n    programId: COINFLIP_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  // 7. Submit and confirm\n  const rawTx = tx.serialize();\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(rawTx, {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  // 8. Update DB — phase settling → settled\n  const coinflipEntries = [\n    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n  ];\n\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: resultSide,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  // Persist entries in dedicated JSONB column for direct access\n  await db.updateRoundEntries(pda, coinflipEntries);\n\n  // Log settle_confirmed\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    entropy: entropy.toString(\"hex\"),\n    payoutAmount,\n    feeAmount,\n    entries: coinflipEntries,\n  });\n\n  // Write user transactions — win + loss\n  const loser = winner.equals(creator) ? opponent : creator;\n  await Promise.all([\n    db.insertUserTransaction({\n      wallet: winner.toBase58(),\n      game: \"coinflip\",\n      matchId: round.match_id,\n      event: \"win\",\n      amountLamports: payoutAmount,\n      txSig: txSignature,\n    }),\n    db.insertUserTransaction({\n      wallet: loser.toBase58(),\n      game: \"coinflip\",\n      matchId: round.match_id,\n      event: \"loss\",\n      amountLamports: Number(entryAmount),\n      txSig: txSignature,\n    }),\n  ]);\n\n  const tDone = performance.now();\n  logger.info(\"settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    resultSide,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleLordRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const roundPubkey = new PublicKey(pda);\n\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n    game: \"lord\",\n  });\n\n  const [configPda] = deriveLordConfigPda();\n  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(roundPubkey),\n      connection.getAccountInfo(configPda),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n\n  const tFetch = performance.now();\n\n  if (!roundAccountInfo) {\n    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n  }\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Lord config account not found\");\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets or parseLordRound()\n  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n  const { treasury } = lordConfig;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n  const resultHash = deriveResult(\n    secret,\n    entropy,\n    roundPubkey.toBuffer(),\n    roundData.algorithmVer,\n  );\n  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n\n  const raw = resultHash.readBigUInt64LE(0);\n  const winningOffset = raw % roundData.totalAmountLamports;\n\n  let cumulative = 0n;\n  let winnerEntryIndex = -1;\n  let winner = roundData.entries[0]?.player;\n  for (const [index, entry] of roundData.entries.entries()) {\n    cumulative += entry.amountLamports;\n    if (winningOffset < cumulative) {\n      winnerEntryIndex = index;\n      winner = entry.player;\n      break;\n    }\n  }\n\n  if (!winner || winnerEntryIndex < 0) {\n    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n  }\n\n  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n      { pubkey: configPda, isSigner: false, isWritable: false },\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: winner, isSigner: false, isWritable: true },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: LORDOFRNGS_PROGRAM_ID,\n    data: encodeClaimPayoutData(matchIdBuf, secret),\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"lord settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    winningEntryIndex: winnerEntryIndex,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  const serializedEntries = roundData.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: winnerEntryIndex,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  // Persist entries in dedicated JSONB column for direct access\n  await db.updateRoundEntries(pda, serializedEntries);\n\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    game: \"lord\",\n    entropy: entropy.toString(\"hex\"),\n    winningOffset: winningOffset.toString(),\n    totalAmountLamports: Number(roundData.totalAmountLamports),\n    payoutAmount,\n    feeAmount,\n    rentRefund,\n    entries: serializedEntries,\n  });\n\n  const tDone = performance.now();\n  logger.info(\"lord settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    winningEntryIndex: winnerEntryIndex,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const round = await deps.db.getRoundByPda(pda);\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n\n  if (round.game === \"lord\") {\n    return settleLordRound(deps, pda);\n  }\n\n  return settleMatch(deps, pda);\n}\n\n// ---------------------------------------------------------------------------\n// Close Call — transaction builders\n// ---------------------------------------------------------------------------\n\nfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"closecall_config\")],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\nfunction minuteTsToBuffer(ts: bigint): Buffer {\n  const buf = Buffer.alloc(8);\n  buf.writeBigInt64LE(ts);\n  return buf;\n}\n\nfunction deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\n/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\nfunction encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n  const buf = Buffer.alloc(16);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  return buf;\n}\n\n/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\nfunction encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n  const buf = Buffer.alloc(28);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  buf.writeBigInt64LE(price, 16);\n  buf.writeInt32LE(expo, 24);\n  return buf;\n}\n\n/**\n * Encode closecall bet data:\n * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n */\nfunction encodeCcBetData(\n  discriminator: Buffer,\n  minuteTs: bigint,\n  side: number,\n  amount: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): Buffer {\n  const buf = Buffer.alloc(37);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  buf.writeUInt8(side, 16);\n  buf.writeBigUInt64LE(amount, 17);\n  buf.writeBigInt64LE(openPrice, 25);\n  buf.writeInt32LE(openPriceExpo, 33);\n  return buf;\n}\n\nexport interface CloseCallTxDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\n/**\n * Build a `bet` instruction (no transaction wrapping).\n *\n * Two signers: player (pays bet) + server (pays rent on first call).\n * Price + bet info passed as instruction args.\n * Uses init_if_needed — works for both round creation and joining.\n */\nexport function buildCloseCallBetIx(\n  serverPubkey: PublicKey,\n  playerPubkey: PublicKey,\n  minuteTs: bigint,\n  side: number,\n  amountLamports: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): TransactionInstruction {\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcBetData(\n    CC_BET_DISCRIMINATOR,\n    minuteTs,\n    side,\n    amountLamports,\n    openPrice,\n    openPriceExpo,\n  );\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n}\n\n/**\n * Build a `settle_round` instruction (no transaction wrapping).\n * Price is passed as instruction args (no on-chain Pyth account).\n */\nexport function buildCloseCallSettleRoundIx(\n  serverPubkey: PublicKey,\n  minuteTs: bigint,\n  closePrice: bigint,\n  closePriceExpo: number,\n  treasury: PublicKey,\n  winnerAccounts: PublicKey[],\n): TransactionInstruction {\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n      { pubkey: roundPda, isSigner: false, isWritable: true },\n      { pubkey: configPda, isSigner: false, isWritable: false },\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n    ],\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n}\n\n/**\n * Build a partially-signed `bet` transaction for the Close Call program.\n *\n * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n * Server signs immediately; the frontend must add the player signature before submitting.\n * Works for both round creation (first bet) and joining (subsequent bets).\n */\nexport async function buildCloseCallBetTx(\n  deps: CloseCallTxDeps,\n  playerPubkey: PublicKey,\n  minuteTs: bigint,\n  side: number,\n  amountLamports: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n  const { connection, serverKeypair } = deps;\n\n  const instruction = buildCloseCallBetIx(\n    serverKeypair.publicKey,\n    playerPubkey,\n    minuteTs,\n    side,\n    amountLamports,\n    openPrice,\n    openPriceExpo,\n  );\n\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.partialSign(serverKeypair);\n\n  return { tx, roundPda };\n}\n\n/**\n * Build a signed `settle_round` transaction for the Close Call program.\n *\n * Price is passed as instruction args. Winners (or all players for refund)\n * are passed as remaining accounts for auto-payout.\n */\nexport async function buildCloseCallSettleRoundTx(\n  deps: CloseCallTxDeps,\n  minuteTs: bigint,\n  closePrice: bigint,\n  closePriceExpo: number,\n  treasury: PublicKey,\n  winnerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const instruction = buildCloseCallSettleRoundIx(\n    serverKeypair.publicKey,\n    minuteTs,\n    closePrice,\n    closePriceExpo,\n    treasury,\n    winnerAccounts,\n  );\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n/**\n * Build a signed `timeout_refund` transaction for the Close Call program.\n *\n * Permissionless after the resolve deadline. Refunds all players their exact\n * deposit via remaining accounts.\n */\nexport async function buildCloseCallTimeoutRefundTx(\n  deps: CloseCallTxDeps,\n  minuteTs: bigint,\n  playerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n\n  const keys = [\n    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n  ];\n\n  const instruction = new TransactionInstruction({\n    keys,\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------\n\n/** Permanent failure — should not be retried. */\nexport class PermanentSettleError extends Error {\n  readonly permanent = true;\n  constructor(message: string) {\n    super(message);\n    this.name = \"PermanentSettleError\";\n  }\n}\n\n/** Transient failure — safe to retry. */\nexport class TransientSettleError extends Error {\n  readonly permanent = false;\n  constructor(message: string) {\n    super(message);\n    this.name = \"TransientSettleError\";\n  }\n}\n","structuredPatch":[{"oldStart":515,"oldLines":6,"newStart":515,"newLines":33,"lines":["     entries: serializedEntries,","   });"," ","+  // Write user transactions — win for winner, loss for each losing entry","+  const userTxInserts = [","+    db.insertUserTransaction({","+      wallet: winner.toBase58(),","+      game: \"lord\",","+      matchId: round.match_id,","+      event: \"win\",","+      amountLamports: payoutAmount,","+      txSig: txSignature,","+    }),","+  ];","+  for (const entry of roundData.entries) {","+    if (!entry.player.equals(winner)) {","+      userTxInserts.push(","+        db.insertUserTransaction({","+          wallet: entry.player.toBase58(),","+          game: \"lord\",","+          matchId: round.match_id,","+          event: \"loss\",","+          amountLamports: Number(entry.amountLamports),","+          txSig: txSignature,","+        }),","+      );","+    }","+  }","+  await Promise.all(userTxInserts);","+","   const tDone = performance.now();","   logger.info(\"lord settlement transaction confirmed\", {","     pda,"]}],"userModified":false,"replaceAll":false}}
