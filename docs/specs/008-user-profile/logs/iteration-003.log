serts);\n\n  const tDone = performance.now();"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":13398,"cache_read_input_tokens":30340,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":13398},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"46d9d431-715c-4f17-ac5e-f2faa20517a2","uuid":"b5f9f79b-f861-4893-bdd7-e7a19dbcf3c4"}
