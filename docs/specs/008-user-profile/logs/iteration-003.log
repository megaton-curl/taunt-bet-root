{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S8k6iHVva1j87kfoK6cFjy","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    23→import {\n    24→  decodeCoinflipMatch,\n    25→  decodeCoinflipConfig,\n    26→  decodeLordRound,\n    27→  decodeLordConfig,\n    28→  type DecodedJackpotRound,\n    29→} from \"./account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→function getInstructionDiscriminator(\n    36→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    37→  instructionName: string,\n    38→): Buffer {\n    39→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    40→  if (!instruction) {\n    41→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    42→  }\n    43→  return Buffer.from(instruction.discriminator);\n    44→}\n    45→\n    46→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    47→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    48→  lordIdl,\n    49→  \"claim_payout\",\n    50→);\n    51→const CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    52→const CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    53→const CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    54→\n    55→// ---------------------------------------------------------------------------\n    56→// Types\n    57→// ---------------------------------------------------------------------------\n    58→\n    59→export interface SettleTxDeps {\n    60→  db: Db;\n    61→  connection: Connection;\n    62→  serverKeypair: Keypair;\n    63→  entropyAccount: PublicKey;\n    64→}\n    65→\n    66→export interface SettleResult {\n    67→  txSignature: string;\n    68→  resultHash: Buffer;\n    69→  resultSide?: number;\n    70→  winningEntryIndex?: number;\n    71→  winner: string;\n    72→}\n    73→\n    74→// ---------------------------------------------------------------------------\n    75→// PDA helpers\n    76→// ---------------------------------------------------------------------------\n    77→\n    78→function deriveConfigPda(): [PublicKey, number] {\n    79→  return PublicKey.findProgramAddressSync(\n    80→    [Buffer.from(\"coinflip_config\")],\n    81→    COINFLIP_PROGRAM_ID,\n    82→  );\n    83→}\n    84→\n    85→function deriveLordConfigPda(): [PublicKey, number] {\n    86→  return PublicKey.findProgramAddressSync(\n    87→    [Buffer.from(\"lord_config\")],\n    88→    LORDOFRNGS_PROGRAM_ID,\n    89→  );\n    90→}\n    91→\n    92→// ---------------------------------------------------------------------------\n    93→// Instruction encoding\n    94→// ---------------------------------------------------------------------------\n    95→\n    96→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    97→function encodeSettleData(secret: Buffer): Buffer {\n    98→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    99→}\n   100→\n   101→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n   102→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n   103→}\n   104→\n   105→// ---------------------------------------------------------------------------\n   106→// Result derivation (mirrors on-chain derive_result)\n   107→// ---------------------------------------------------------------------------\n   108→\n   109→/**\n   110→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n   111→ * Must match shared/src/fairness.rs `derive_result()`.\n   112→ */\n   113→function deriveResult(\n   114→  secret: Buffer,\n   115→  entropy: Buffer,\n   116→  matchPdaBytes: Buffer,\n   117→  algoVer: number,\n   118→): Buffer {\n   119→  return createHash(\"sha256\")\n   120→    .update(secret)\n   121→    .update(entropy)\n   122→    .update(matchPdaBytes)\n   123→    .update(Buffer.from([algoVer]))\n   124→    .digest();\n   125→}\n   126→\n   127→// ---------------------------------------------------------------------------\n   128→// Core settle function\n   129→// ---------------------------------------------------------------------------\n   130→\n   131→/**\n   132→ * Build, submit, and confirm a settle transaction for a locked match.\n   133→ *\n   134→ * Steps:\n   135→ * 1. Retrieve secret from DB\n   136→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   137→ * 3. Fetch config account data (treasury)\n   138→ * 4. Read entropy from the entropy account\n   139→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   140→ * 6. Build + submit settle tx\n   141→ * 7. Update DB on confirmation\n   142→ */\n   143→export async function settleMatch(\n   144→  deps: SettleTxDeps,\n   145→  pda: string,\n   146→): Promise<SettleResult> {\n   147→  const t0 = performance.now();\n   148→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   149→  const matchPubkey = new PublicKey(pda);\n   150→\n   151→  // 1. Retrieve secret from DB\n   152→  const round = await db.getRoundByPda(pda);\n   153→  const tDb = performance.now();\n   154→  if (!round) {\n   155→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   156→  }\n   157→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   158→    throw new PermanentSettleError(\n   159→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   160→    );\n   161→  }\n   162→\n   163→  const secret = Buffer.from(round.secret);\n   164→\n   165→  // Transition to settling (locked → settling)\n   166→  if (round.phase === \"locked\") {\n   167→    await db.updateRoundPhase(pda, \"settling\");\n   168→  }\n   169→\n   170→  // Log settle_submitted\n   171→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   172→    attempt: round.settle_attempts + 1,\n   173→  });\n   174→\n   175→  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n   176→  const [configPda] = deriveConfigPda();\n   177→  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   178→    await Promise.all([\n   179→      connection.getAccountInfo(matchPubkey),\n   180→      connection.getAccountInfo(configPda),\n   181→      connection.getAccountInfo(entropyAccount),\n   182→      connection.getLatestBlockhash(),\n   183→    ]);\n   184→  const tFetch = performance.now();\n   185→\n   186→  if (!matchAccountInfo) {\n   187→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   188→  }\n   189→  if (!configAccountInfo) {\n   190→    throw new PermanentSettleError(\"Coinflip config account not found\");\n   191→  }\n   192→  if (!entropyInfo) {\n   193→    throw new TransientSettleError(\"Entropy account not available yet\");\n   194→  }\n   195→\n   196→  // IDL-driven decode — no manual byte offsets\n   197→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   198→  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n   199→\n   200→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   201→  const { treasury } = config;\n   202→\n   203→  const pool = entryAmount * 2n;\n   204→  const feeAmount = Number((pool * 300n) / 10_000n);\n   205→  const payoutAmount = Number(pool) - feeAmount;\n   206→\n   207→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   208→\n   209→  // 5. Pre-compute result\n   210→  const matchPdaBytes = matchPubkey.toBuffer();\n   211→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   212→  const resultSide = resultHash[0]! % 2;\n   213→  const winner = resultSide === creatorSide ? creator : opponent;\n   214→\n   215→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   216→  const data = encodeSettleData(secret);\n   217→\n   218→  const instruction = new TransactionInstruction({\n   219→    keys: [\n   220→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   221→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   222→      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n   223→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   224→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   225→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   226→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   227→      {\n   228→        pubkey: SystemProgram.programId,\n   229→        isSigner: false,\n   230→        isWritable: false,\n   231→      }, // system_program\n   232→    ],\n   233→    programId: COINFLIP_PROGRAM_ID,\n   234→    data,\n   235→  });\n   236→\n   237→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   238→\n   239→  const tx = new Transaction({\n   240→    feePayer: serverKeypair.publicKey,\n   241→    blockhash,\n   242→    lastValidBlockHeight,\n   243→  });\n   244→  tx.add(instruction);\n   245→  tx.sign(serverKeypair);\n   246→\n   247→  // 7. Submit and confirm\n   248→  const rawTx = tx.serialize();\n   249→  const tBuild = performance.now();\n   250→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   251→    skipPreflight: false,\n   252→  });\n   253→  const tSend = performance.now();\n   254→\n   255→  logger.info(\"settlement transaction submitted\", {\n   256→    pda,\n   257→    txSignature,\n   258→    attempt: round.settle_attempts + 1,\n   259→    dbMs: Math.round(tDb - t0),\n   260→    fetchMs: Math.round(tFetch - tDb),\n   261→    buildMs: Math.round(tBuild - tFetch),\n   262→    sendMs: Math.round(tSend - tBuild),\n   263→  });\n   264→\n   265→  const confirmation = await connection.confirmTransaction(\n   266→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   267→    \"confirmed\",\n   268→  );\n   269→  const tConfirm = performance.now();\n   270→  if (confirmation.value.err) {\n   271→    throw new TransientSettleError(\n   272→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   273→    );\n   274→  }\n   275→\n   276→  // 8. Update DB — phase settling → settled\n   277→  const coinflipEntries = [\n   278→    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n   279→    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n   280→  ];\n   281→\n   282→  await db.updateRoundPhase(pda, \"settled\", {\n   283→    settle_tx: txSignature,\n   284→    result_hash: resultHash,\n   285→    result_side: resultSide,\n   286→    winner: winner.toBase58(),\n   287→    settle_attempts: round.settle_attempts + 1,\n   288→  });\n   289→\n   290→  // Persist entries in dedicated JSONB column for direct access\n   291→  await db.updateRoundEntries(pda, coinflipEntries);\n   292→\n   293→  // Log settle_confirmed\n   294→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   295→    txSignature,\n   296→    resultSide,\n   297→    winner: winner.toBase58(),\n   298→    entropy: entropy.toString(\"hex\"),\n   299→    payoutAmount,\n   300→    feeAmount,\n   301→    entries: coinflipEntries,\n   302→  });\n   303→\n   304→  // Write user transactions — win + loss\n   305→  const loser = winner.equals(creator) ? opponent : creator;\n   306→  await Promise.all([\n   307→    db.insertUserTransaction({\n   308→      wallet: winner.toBase58(),\n   309→      game: \"coinflip\",\n   310→      matchId: round.match_id,\n   311→      event: \"win\",\n   312→      amountLamports: payoutAmount,\n   313→      txSig: txSignature,\n   314→    }),\n   315→    db.insertUserTransaction({\n   316→      wallet: loser.toBase58(),\n   317→      game: \"coinflip\",\n   318→      matchId: round.match_id,\n   319→      event: \"loss\",\n   320→      amountLamports: Number(entryAmount),\n   321→      txSig: txSignature,\n   322→    }),\n   323→  ]);\n   324→\n   325→  const tDone = performance.now();\n   326→  logger.info(\"settlement transaction confirmed\", {\n   327→    pda,\n   328→    txSignature,\n   329→    resultSide,\n   330→    winner: winner.toBase58(),\n   331→    timing: {\n   332→      dbMs: Math.round(tDb - t0),\n   333→      fetchMs: Math.round(tFetch - tDb),\n   334→      buildMs: Math.round(tBuild - tFetch),\n   335→      sendMs: Math.round(tSend - tBuild),\n   336→      confirmMs: Math.round(tConfirm - tSend),\n   337→      dbWriteMs: Math.round(tDone - tConfirm),\n   338→      totalMs: Math.round(tDone - t0),\n   339→    },\n   340→  });\n   341→\n   342→  return {\n   343→    txSignature,\n   344→    resultHash,\n   345→    resultSide,\n   346→    winner: winner.toBase58(),\n   347→  };\n   348→}\n   349→\n   350→export async function settleLordRound(\n   351→  deps: SettleTxDeps,\n   352→  pda: string,\n   353→): Promise<SettleResult> {\n   354→  const t0 = performance.now();\n   355→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   356→  const roundPubkey = new PublicKey(pda);\n   357→\n   358→  const round = await db.getRoundByPda(pda);\n   359→  const tDb = performance.now();\n   360→  if (!round) {\n   361→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   362→  }\n   363→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   364→    throw new PermanentSettleError(\n   365→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   366→    );\n   367→  }\n   368→\n   369→  const secret = Buffer.from(round.secret);\n   370→\n   371→  if (round.phase === \"locked\") {\n   372→    await db.updateRoundPhase(pda, \"settling\");\n   373→  }\n   374→\n   375→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   376→    attempt: round.settle_attempts + 1,\n   377→    game: \"lord\",\n   378→  });\n   379→\n   380→  const [configPda] = deriveLordConfigPda();\n   381→  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   382→    await Promise.all([\n   383→      connection.getAccountInfo(roundPubkey),\n   384→      connection.getAccountInfo(configPda),\n   385→      connection.getAccountInfo(entropyAccount),\n   386→      connection.getLatestBlockhash(),\n   387→    ]);\n   388→\n   389→  const tFetch = performance.now();\n   390→\n   391→  if (!roundAccountInfo) {\n   392→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   393→  }\n   394→  if (!configAccountInfo) {\n   395→    throw new PermanentSettleError(\"Lord config account not found\");\n   396→  }\n   397→  if (!entropyInfo) {\n   398→    throw new TransientSettleError(\"Entropy account not available yet\");\n   399→  }\n   400→\n   401→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   402→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   403→  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n   404→  const { treasury } = lordConfig;\n   405→\n   406→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   407→  const resultHash = deriveResult(\n   408→    secret,\n   409→    entropy,\n   410→    roundPubkey.toBuffer(),\n   411→    roundData.algorithmVer,\n   412→  );\n   413→  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n   414→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   415→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   416→\n   417→  const raw = resultHash.readBigUInt64LE(0);\n   418→  const winningOffset = raw % roundData.totalAmountLamports;\n   419→\n   420→  let cumulative = 0n;\n   421→  let winnerEntryIndex = -1;\n   422→  let winner = roundData.entries[0]?.player;\n   423→  for (const [index, entry] of roundData.entries.entries()) {\n   424→    cumulative += entry.amountLamports;\n   425→    if (winningOffset < cumulative) {\n   426→      winnerEntryIndex = index;\n   427→      winner = entry.player;\n   428→      break;\n   429→    }\n   430→  }\n   431→\n   432→  if (!winner || winnerEntryIndex < 0) {\n   433→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   434→  }\n   435→\n   436→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   437→  const instruction = new TransactionInstruction({\n   438→    keys: [\n   439→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   440→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   441→      { pubkey: configPda, isSigner: false, isWritable: false },\n   442→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   443→      { pubkey: treasury, isSigner: false, isWritable: true },\n   444→      { pubkey: winner, isSigner: false, isWritable: true },\n   445→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   446→    ],\n   447→    programId: LORDOFRNGS_PROGRAM_ID,\n   448→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   449→  });\n   450→\n   451→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   452→  const tx = new Transaction({\n   453→    feePayer: serverKeypair.publicKey,\n   454→    blockhash,\n   455→    lastValidBlockHeight,\n   456→  });\n   457→  tx.add(instruction);\n   458→  tx.sign(serverKeypair);\n   459→\n   460→  const tBuild = performance.now();\n   461→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   462→    skipPreflight: false,\n   463→  });\n   464→  const tSend = performance.now();\n   465→\n   466→  logger.info(\"lord settlement transaction submitted\", {\n   467→    pda,\n   468→    txSignature,\n   469→    attempt: round.settle_attempts + 1,\n   470→    winningEntryIndex: winnerEntryIndex,\n   471→    dbMs: Math.round(tDb - t0),\n   472→    fetchMs: Math.round(tFetch - tDb),\n   473→    buildMs: Math.round(tBuild - tFetch),\n   474→    sendMs: Math.round(tSend - tBuild),\n   475→  });\n   476→\n   477→  const confirmation = await connection.confirmTransaction(\n   478→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   479→    \"confirmed\",\n   480→  );\n   481→  const tConfirm = performance.now();\n   482→  if (confirmation.value.err) {\n   483→    throw new TransientSettleError(\n   484→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   485→    );\n   486→  }\n   487→\n   488→  const serializedEntries = roundData.entries.map((e) => ({\n   489→    player: e.player.toBase58(),\n   490→    amountLamports: Number(e.amountLamports),\n   491→  }));\n   492→\n   493→  await db.updateRoundPhase(pda, \"settled\", {\n   494→    settle_tx: txSignature,\n   495→    result_hash: resultHash,\n   496→    result_side: winnerEntryIndex,\n   497→    winner: winner.toBase58(),\n   498→    settle_attempts: round.settle_attempts + 1,\n   499→  });\n   500→\n   501→  // Persist entries in dedicated JSONB column for direct access\n   502→  await db.updateRoundEntries(pda, serializedEntries);\n   503→\n   504→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   505→    txSignature,\n   506→    winner: winner.toBase58(),\n   507→    winningEntryIndex: winnerEntryIndex,\n   508→    game: \"lord\",\n   509→    entropy: entropy.toString(\"hex\"),\n   510→    winningOffset: winningOffset.toString(),\n   511→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   512→    payoutAmount,\n   513→    feeAmount,\n   514→    rentRefund,\n   515→    entries: serializedEntries,\n   516→  });\n   517→\n   518→  const tDone = performance.now();\n   519→  logger.info(\"lord settlement transaction confirmed\", {\n   520→    pda,\n   521→    txSignature,\n   522→    winner: winner.toBase58(),\n   523→    winningEntryIndex: winnerEntryIndex,\n   524→    timing: {\n   525→      dbMs: Math.round(tDb - t0),\n   526→      fetchMs: Math.round(tFetch - tDb),\n   527→      buildMs: Math.round(tBuild - tFetch),\n   528→      sendMs: Math.round(tSend - tBuild),\n   529→      confirmMs: Math.round(tConfirm - tSend),\n   530→      dbWriteMs: Math.round(tDone - tConfirm),\n   531→      totalMs: Math.round(tDone - t0),\n   532→    },\n   533→  });\n   534→\n   535→  return {\n   536→    txSignature,\n   537→    resultHash,\n   538→    winningEntryIndex: winnerEntryIndex,\n   539→    winner: winner.toBase58(),\n   540→  };\n   541→}\n   542→\n   543→export async function settleRound(\n   544→  deps: SettleTxDeps,\n   545→  pda: string,\n   546→): Promise<SettleResult> {\n   547→  const round = await deps.db.getRoundByPda(pda);\n   548→  if (!round) {\n   549→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   550→  }\n   551→\n   552→  if (round.game === \"lord\") {\n   553→    return settleLordRound(deps, pda);\n   554→  }\n   555→\n   556→  return settleMatch(deps, pda);\n   557→}\n   558→\n   559→// ---------------------------------------------------------------------------\n   560→// Close Call — transaction builders\n   561→// ---------------------------------------------------------------------------\n   562→\n   563→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   564→  return PublicKey.findProgramAddressSync(\n   565→    [Buffer.from(\"closecall_config\")],\n   566→    CLOSECALL_PROGRAM_ID,\n   567→  );\n   568→}\n   569→\n   570→function minuteTsToBuffer(ts: bigint): Buffer {\n   571→  const buf = Buffer.alloc(8);\n   572→  buf.writeBigInt64LE(ts);\n   573→  return buf;\n   574→}\n   575→\n   576→function deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n   577→  return PublicKey.findProgramAddressSync(\n   578→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n   579→    CLOSECALL_PROGRAM_ID,\n   580→  );\n   581→}\n   582→\n   583→/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n   584→function encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n   585→  const buf = Buffer.alloc(16);\n   586→  discriminator.copy(buf, 0);\n   587→  buf.writeBigInt64LE(minuteTs, 8);\n   588→  return buf;\n   589→}\n   590→\n   591→/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n   592→function encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n   593→  const buf = Buffer.alloc(28);\n   594→  discriminator.copy(buf, 0);\n   595→  buf.writeBigInt64LE(minuteTs, 8);\n   596→  buf.writeBigInt64LE(price, 16);\n   597→  buf.writeInt32LE(expo, 24);\n   598→  return buf;\n   599→}\n   600→\n   601→/**\n   602→ * Encode closecall bet data:\n   603→ * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n   604→ */\n   605→function encodeCcBetData(\n   606→  discriminator: Buffer,\n   607→  minuteTs: bigint,\n   608→  side: number,\n   609→  amount: bigint,\n   610→  openPrice: bigint,\n   611→  openPriceExpo: number,\n   612→): Buffer {\n   613→  const buf = Buffer.alloc(37);\n   614→  discriminator.copy(buf, 0);\n   615→  buf.writeBigInt64LE(minuteTs, 8);\n   616→  buf.writeUInt8(side, 16);\n   617→  buf.writeBigUInt64LE(amount, 17);\n   618→  buf.writeBigInt64LE(openPrice, 25);\n   619→  buf.writeInt32LE(openPriceExpo, 33);\n   620→  return buf;\n   621→}\n   622→\n   623→export interface CloseCallTxDeps {\n   624→  connection: Connection;\n   625→  serverKeypair: Keypair;\n   626→}\n   627→\n   628→/**\n   629→ * Build a `bet` instruction (no transaction wrapping).\n   630→ *\n   631→ * Two signers: player (pays bet) + server (pays rent on first call).\n   632→ * Price + bet info passed as instruction args.\n   633→ * Uses init_if_needed — works for both round creation and joining.\n   634→ */\n   635→export function buildCloseCallBetIx(\n   636→  serverPubkey: PublicKey,\n   637→  playerPubkey: PublicKey,\n   638→  minuteTs: bigint,\n   639→  side: number,\n   640→  amountLamports: bigint,\n   641→  openPrice: bigint,\n   642→  openPriceExpo: number,\n   643→): TransactionInstruction {\n   644→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   645→  const [configPda] = deriveCloseCallConfigPda();\n   646→  const data = encodeCcBetData(\n   647→    CC_BET_DISCRIMINATOR,\n   648→    minuteTs,\n   649→    side,\n   650→    amountLamports,\n   651→    openPrice,\n   652→    openPriceExpo,\n   653→  );\n   654→\n   655→  return new TransactionInstruction({\n   656→    keys: [\n   657→      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n   658→      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n   659→      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n   660→      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n   661→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   662→    ],\n   663→    programId: CLOSECALL_PROGRAM_ID,\n   664→    data,\n   665→  });\n   666→}\n   667→\n   668→/**\n   669→ * Build a `settle_round` instruction (no transaction wrapping).\n   670→ * Price is passed as instruction args (no on-chain Pyth account).\n   671→ */\n   672→export function buildCloseCallSettleRoundIx(\n   673→  serverPubkey: PublicKey,\n   674→  minuteTs: bigint,\n   675→  closePrice: bigint,\n   676→  closePriceExpo: number,\n   677→  treasury: PublicKey,\n   678→  winnerAccounts: PublicKey[],\n   679→): TransactionInstruction {\n   680→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   681→  const [configPda] = deriveCloseCallConfigPda();\n   682→  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n   683→\n   684→  return new TransactionInstruction({\n   685→    keys: [\n   686→      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n   687→      { pubkey: roundPda, isSigner: false, isWritable: true },\n   688→      { pubkey: configPda, isSigner: false, isWritable: false },\n   689→      { pubkey: treasury, isSigner: false, isWritable: true },\n   690→      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n   691→      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   692→    ],\n   693→    programId: CLOSECALL_PROGRAM_ID,\n   694→    data,\n   695→  });\n   696→}\n   697→\n   698→/**\n   699→ * Build a partially-signed `bet` transaction for the Close Call program.\n   700→ *\n   701→ * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n   702→ * Server signs immediately; the frontend must add the player signature before submitting.\n   703→ * Works for both round creation (first bet) and joining (subsequent bets).\n   704→ */\n   705→export async function buildCloseCallBetTx(\n   706→  deps: CloseCallTxDeps,\n   707→  playerPubkey: PublicKey,\n   708→  minuteTs: bigint,\n   709→  side: number,\n   710→  amountLamports: bigint,\n   711→  openPrice: bigint,\n   712→  openPriceExpo: number,\n   713→): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   714→  const { connection, serverKeypair } = deps;\n   715→\n   716→  const instruction = buildCloseCallBetIx(\n   717→    serverKeypair.publicKey,\n   718→    playerPubkey,\n   719→    minuteTs,\n   720→    side,\n   721→    amountLamports,\n   722→    openPrice,\n   723→    openPriceExpo,\n   724→  );\n   725→\n   726→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   727→\n   728→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   729→  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n   730→  tx.add(instruction);\n   731→  tx.partialSign(serverKeypair);\n   732→\n   733→  return { tx, roundPda };\n   734→}\n   735→\n   736→/**\n   737→ * Build a signed `settle_round` transaction for the Close Call program.\n   738→ *\n   739→ * Price is passed as instruction args. Winners (or all players for refund)\n   740→ * are passed as remaining accounts for auto-payout.\n   741→ */\n   742→export async function buildCloseCallSettleRoundTx(\n   743→  deps: CloseCallTxDeps,\n   744→  minuteTs: bigint,\n   745→  closePrice: bigint,\n   746→  closePriceExpo: number,\n   747→  treasury: PublicKey,\n   748→  winnerAccounts: PublicKey[],\n   749→): Promise<Transaction> {\n   750→  const { connection, serverKeypair } = deps;\n   751→\n   752→  const instruction = buildCloseCallSettleRoundIx(\n   753→    serverKeypair.publicKey,\n   754→    minuteTs,\n   755→    closePrice,\n   756→    closePriceExpo,\n   757→    treasury,\n   758→    winnerAccounts,\n   759→  );\n   760→\n   761→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   762→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   763→  tx.add(instruction);\n   764→  tx.sign(serverKeypair);\n   765→\n   766→  return tx;\n   767→}\n   768→\n   769→/**\n   770→ * Build a signed `timeout_refund` transaction for the Close Call program.\n   771→ *\n   772→ * Permissionless after the resolve deadline. Refunds all players their exact\n   773→ * deposit via remaining accounts.\n   774→ */\n   775→export async function buildCloseCallTimeoutRefundTx(\n   776→  deps: CloseCallTxDeps,\n   777→  minuteTs: bigint,\n   778→  playerAccounts: PublicKey[],\n   779→): Promise<Transaction> {\n   780→  const { connection, serverKeypair } = deps;\n   781→\n   782→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   783→  const [configPda] = deriveCloseCallConfigPda();\n   784→  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n   785→\n   786→  const keys = [\n   787→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   788→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   789→    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n   790→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   791→    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   792→  ];\n   793→\n   794→  const instruction = new TransactionInstruction({\n   795→    keys,\n   796→    programId: CLOSECALL_PROGRAM_ID,\n   797→    data,\n   798→  });\n   799→\n   800→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   801→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   802→  tx.add(instruction);\n   803→  tx.sign(serverKeypair);\n   804→\n   805→  return tx;\n   806→}\n   807→\n   808→// ---------------------------------------------------------------------------\n   809→// Error types\n   810→// ---------------------------------------------------------------------------\n   811→\n   812→/** Permanent failure — should not be retried. */\n   813→export class PermanentSettleError extends Error {\n   814→  readonly permanent = true;\n   815→  constructor(message: string) {\n   816→    super(message);\n   817→    this.name = \"PermanentSettleError\";\n   818→  }\n   819→}\n   820→\n   821→/** Transient failure — safe to retry. */\n   822→export class TransientSettleError extends Error {\n   823→  readonly permanent = false;\n   824→  constructor(message: string) {\n   825→    super(message);\n   826→    this.name = \"TransientSettleError\";\n   827→  }\n   828→}\n   829→"}]},"parent_tool_use_id":null,"session_id":"46d9d431-715c-4f17-ac5e-f2faa20517a2","uuid":"71525a70-a2ce-4d38-8e81-34421dee8771","timestamp":"2026-03-19T18:48:41.011Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settle-tx.ts","content":"/**\n * Settle transaction builder + submission.\n *\n * Retrieves the stored secret, reads on-chain match + config data to resolve\n * all accounts, builds the `settle` instruction, submits it, and updates the\n * DB on confirmation.\n */\n\nimport { createHash } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\nimport {\n  decodeCoinflipMatch,\n  decodeCoinflipConfig,\n  decodeLordRound,\n  decodeLordConfig,\n  type DecodedJackpotRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Instruction discriminators (from IDL — no hardcoded byte arrays)\n// ---------------------------------------------------------------------------\n\nfunction getInstructionDiscriminator(\n  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n  instructionName: string,\n): Buffer {\n  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n  if (!instruction) {\n    throw new Error(`Instruction ${instructionName} not found in IDL`);\n  }\n  return Buffer.from(instruction.discriminator);\n}\n\nconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\nconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n  lordIdl,\n  \"claim_payout\",\n);\nconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\nconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\nconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface SettleTxDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  entropyAccount: PublicKey;\n}\n\nexport interface SettleResult {\n  txSignature: string;\n  resultHash: Buffer;\n  resultSide?: number;\n  winningEntryIndex?: number;\n  winner: string;\n}\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\n\nfunction deriveConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n\nfunction deriveLordConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID,\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Instruction encoding\n// ---------------------------------------------------------------------------\n\n/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\nfunction encodeSettleData(secret: Buffer): Buffer {\n  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n}\n\nfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n}\n\n// ---------------------------------------------------------------------------\n// Result derivation (mirrors on-chain derive_result)\n// ---------------------------------------------------------------------------\n\n/**\n * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n * Must match shared/src/fairness.rs `derive_result()`.\n */\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")\n    .update(secret)\n    .update(entropy)\n    .update(matchPdaBytes)\n    .update(Buffer.from([algoVer]))\n    .digest();\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on confirmation\n */\nexport async function settleMatch(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const matchPubkey = new PublicKey(pda);\n\n  // 1. Retrieve secret from DB\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  // Transition to settling (locked → settling)\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  // Log settle_submitted\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n  });\n\n  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n  const [configPda] = deriveConfigPda();\n  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(matchPubkey),\n      connection.getAccountInfo(configPda),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n  const tFetch = performance.now();\n\n  if (!matchAccountInfo) {\n    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n  }\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Coinflip config account not found\");\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets\n  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n\n  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n  const { treasury } = config;\n\n  const pool = entryAmount * 2n;\n  const feeAmount = Number((pool * 300n) / 10_000n);\n  const payoutAmount = Number(pool) - feeAmount;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n\n  // 5. Pre-compute result\n  const matchPdaBytes = matchPubkey.toBuffer();\n  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n  const resultSide = resultHash[0]! % 2;\n  const winner = resultSide === creatorSide ? creator : opponent;\n\n  // 6. Build settle instruction (8 accounts, no profile CPI)\n  const data = encodeSettleData(secret);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      }, // system_program\n    ],\n    programId: COINFLIP_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  // 7. Submit and confirm\n  const rawTx = tx.serialize();\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(rawTx, {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  // 8. Update DB — phase settling → settled\n  const coinflipEntries = [\n    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n  ];\n\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: resultSide,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  // Persist entries in dedicated JSONB column for direct access\n  await db.updateRoundEntries(pda, coinflipEntries);\n\n  // Log settle_confirmed\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    entropy: entropy.toString(\"hex\"),\n    payoutAmount,\n    feeAmount,\n    entries: coinflipEntries,\n  });\n\n  // Write user transactions — win + loss\n  const loser = winner.equals(creator) ? opponent : creator;\n  await Promise.all([\n    db.insertUserTransaction({\n      wallet: winner.toBase58(),\n      game: \"coinflip\",\n      matchId: round.match_id,\n      event: \"win\",\n      amountLamports: payoutAmount,\n      txSig: txSignature,\n    }),\n    db.insertUserTransaction({\n      wallet: loser.toBase58(),\n      game: \"coinflip\",\n      matchId: round.match_id,\n      event: \"loss\",\n      amountLamports: Number(entryAmount),\n      txSig: txSignature,\n    }),\n  ]);\n\n  const tDone = performance.now();\n  logger.info(\"settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    resultSide,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleLordRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const roundPubkey = new PublicKey(pda);\n\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n    game: \"lord\",\n  });\n\n  const [configPda] = deriveLordConfigPda();\n  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(roundPubkey),\n      connection.getAccountInfo(configPda),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n\n  const tFetch = performance.now();\n\n  if (!roundAccountInfo) {\n    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n  }\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Lord config account not found\");\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets or parseLordRound()\n  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n  const { treasury } = lordConfig;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n  const resultHash = deriveResult(\n    secret,\n    entropy,\n    roundPubkey.toBuffer(),\n    roundData.algorithmVer,\n  );\n  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n\n  const raw = resultHash.readBigUInt64LE(0);\n  const winningOffset = raw % roundData.totalAmountLamports;\n\n  let cumulative = 0n;\n  let winnerEntryIndex = -1;\n  let winner = roundData.entries[0]?.player;\n  for (const [index, entry] of roundData.entries.entries()) {\n    cumulative += entry.amountLamports;\n    if (winningOffset < cumulative) {\n      winnerEntryIndex = index;\n      winner = entry.player;\n      break;\n    }\n  }\n\n  if (!winner || winnerEntryIndex < 0) {\n    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n  }\n\n  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n      { pubkey: configPda, isSigner: false, isWritable: false },\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: winner, isSigner: false, isWritable: true },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: LORDOFRNGS_PROGRAM_ID,\n    data: encodeClaimPayoutData(matchIdBuf, secret),\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"lord settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    winningEntryIndex: winnerEntryIndex,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  const serializedEntries = roundData.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: winnerEntryIndex,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  // Persist entries in dedicated JSONB column for direct access\n  await db.updateRoundEntries(pda, serializedEntries);\n\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    game: \"lord\",\n    entropy: entropy.toString(\"hex\"),\n    winningOffset: winningOffset.toString(),\n    totalAmountLamports: Number(roundData.totalAmountLamports),\n    payoutAmount,\n    feeAmount,\n    rentRefund,\n    entries: serializedEntries,\n  });\n\n  const tDone = performance.now();\n  logger.info(\"lord settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    winningEntryIndex: winnerEntryIndex,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const round = await deps.db.getRoundByPda(pda);\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n\n  if (round.game === \"lord\") {\n    return settleLordRound(deps, pda);\n  }\n\n  return settleMatch(deps, pda);\n}\n\n// ---------------------------------------------------------------------------\n// Close Call — transaction builders\n// ---------------------------------------------------------------------------\n\nfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"closecall_config\")],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\nfunction minuteTsToBuffer(ts: bigint): Buffer {\n  const buf = Buffer.alloc(8);\n  buf.writeBigInt64LE(ts);\n  return buf;\n}\n\nfunction deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\n/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\nfunction encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n  const buf = Buffer.alloc(16);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  return buf;\n}\n\n/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\nfunction encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n  const buf = Buffer.alloc(28);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  buf.writeBigInt64LE(price, 16);\n  buf.writeInt32LE(expo, 24);\n  return buf;\n}\n\n/**\n * Encode closecall bet data:\n * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n */\nfunction encodeCcBetData(\n  discriminator: Buffer,\n  minuteTs: bigint,\n  side: number,\n  amount: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): Buffer {\n  const buf = Buffer.alloc(37);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  buf.writeUInt8(side, 16);\n  buf.writeBigUInt64LE(amount, 17);\n  buf.writeBigInt64LE(openPrice, 25);\n  buf.writeInt32LE(openPriceExpo, 33);\n  return buf;\n}\n\nexport interface CloseCallTxDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\n/**\n * Build a `bet` instruction (no transaction wrapping).\n *\n * Two signers: player (pays bet) + server (pays rent on first call).\n * Price + bet info passed as instruction args.\n * Uses init_if_needed — works for both round creation and joining.\n */\nexport function buildCloseCallBetIx(\n  serverPubkey: PublicKey,\n  playerPubkey: PublicKey,\n  minuteTs: bigint,\n  side: number,\n  amountLamports: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): TransactionInstruction {\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcBetData(\n    CC_BET_DISCRIMINATOR,\n    minuteTs,\n    side,\n    amountLamports,\n    openPrice,\n    openPriceExpo,\n  );\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n}\n\n/**\n * Build a `settle_round` instruction (no transaction wrapping).\n * Price is passed as instruction args (no on-chain Pyth account).\n */\nexport function buildCloseCallSettleRoundIx(\n  serverPubkey: PublicKey,\n  minuteTs: bigint,\n  closePrice: bigint,\n  closePriceExpo: number,\n  treasury: PublicKey,\n  winnerAccounts: PublicKey[],\n): TransactionInstruction {\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n      { pubkey: roundPda, isSigner: false, isWritable: true },\n      { pubkey: configPda, isSigner: false, isWritable: false },\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n    ],\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n}\n\n/**\n * Build a partially-signed `bet` transaction for the Close Call program.\n *\n * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n * Server signs immediately; the frontend must add the player signature before submitting.\n * Works for both round creation (first bet) and joining (subsequent bets).\n */\nexport async function buildCloseCallBetTx(\n  deps: CloseCallTxDeps,\n  playerPubkey: PublicKey,\n  minuteTs: bigint,\n  side: number,\n  amountLamports: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n  const { connection, serverKeypair } = deps;\n\n  const instruction = buildCloseCallBetIx(\n    serverKeypair.publicKey,\n    playerPubkey,\n    minuteTs,\n    side,\n    amountLamports,\n    openPrice,\n    openPriceExpo,\n  );\n\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.partialSign(serverKeypair);\n\n  return { tx, roundPda };\n}\n\n/**\n * Build a signed `settle_round` transaction for the Close Call program.\n *\n * Price is passed as instruction args. Winners (or all players for refund)\n * are passed as remaining accounts for auto-payout.\n */\nexport async function buildCloseCallSettleRoundTx(\n  deps: CloseCallTxDeps,\n  minuteTs: bigint,\n  closePrice: bigint,\n  closePriceExpo: number,\n  treasury: PublicKey,\n  winnerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const instruction = buildCloseCallSettleRoundIx(\n    serverKeypair.publicKey,\n    minuteTs,\n    closePrice,\n    closePriceExpo,\n    treasury,\n    winnerAccounts,\n  );\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n/**\n * Build a signed `timeout_refund` transaction for the Close Call program.\n *\n * Permissionless after the resolve deadline. Refunds all players their exact\n * deposit via remaining accounts.\n */\nexport async function buildCloseCallTimeoutRefundTx(\n  deps: CloseCallTxDeps,\n  minuteTs: bigint,\n  playerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n\n  const keys = [\n    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n  ];\n\n  const instruction = new TransactionInstruction({\n    keys,\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------\n\n/** Permanent failure — should not be retried. */\nexport class PermanentSettleError extends Error {\n  readonly permanent = true;\n  constructor(message: string) {\n    super(message);\n    this.name = \"PermanentSettleError\";\n  }\n}\n\n/** Transient failure — safe to retry. */\nexport class TransientSettleError extends Error {\n  readonly permanent = false;\n  constructor(message: string) {\n    super(message);\n    this.name = \"TransientSettleError\";\n  }\n}\n","numLines":829,"startLine":1,"totalLines":829}}}
