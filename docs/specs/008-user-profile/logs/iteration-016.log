{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TZSmXCfAC4jRsR56nbN42s","type":"tool_result","content":"1\t/**\n2\t * Auth routes: challenge/verify/refresh/logout for JWT session management.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport { randomBytes, createHash } from \"node:crypto\";\n7\timport nacl from \"tweetnacl\";\n8\timport bs58 from \"bs58\";\n9\timport { SignJWT } from \"jose\";\n10\timport type { AuthDb } from \"../auth-db.js\";\n11\timport { logger } from \"../logger.js\";\n12\t\n13\texport interface AuthRoutesDeps {\n14\t  authDb: AuthDb;\n15\t  jwtSecret: Uint8Array;\n16\t  cluster: string;\n17\t  challengeTtlSeconds: number;\n18\t  accessTokenTtlSeconds: number;\n19\t  refreshTokenTtlDays: number;\n20\t}\n21\t\n22\tfunction hashToken(token: string): Buffer {\n23\t  return createHash(\"sha256\").update(token).digest();\n24\t}\n25\t\n26\tfunction buildSignInMessage(\n27\t  wallet: string,\n28\t  cluster: string,\n29\t  nonce: string,\n30\t  issuedAt: string,\n31\t  expiresAt: string,\n32\t): string {\n33\t  return [\n34\t    \"Sign in to RNG Utopia\",\n35\t    `Wallet: ${wallet}`,\n36\t    `Cluster: ${cluster}`,\n37\t    `Nonce: ${nonce}`,\n38\t    `Issued At: ${issuedAt}`,\n39\t    `Expires At: ${expiresAt}`,\n40\t    \"This signature creates a backend session for gameplay actions.\",\n41\t    \"It does not approve a blockchain transaction.\",\n42\t  ].join(\"\\n\");\n43\t}\n44\t\n45\texport function createAuthRoutes(deps: AuthRoutesDeps): Hono {\n46\t  const {\n47\t    authDb,\n48\t    jwtSecret,\n49\t    cluster,\n50\t    challengeTtlSeconds,\n51\t    accessTokenTtlSeconds,\n52\t    refreshTokenTtlDays,\n53\t  } = deps;\n54\t\n55\t  const app = new Hono();\n56\t\n57\t  // POST /challenge — generate nonce + human-readable message\n58\t  app.post(\"/challenge\", async (c) => {\n59\t    let body: { wallet: string };\n60\t    try {\n61\t      body = await c.req.json();\n62\t      if (typeof body.wallet !== \"string\" || body.wallet.length === 0) {\n63\t        return c.json({ error: \"wallet is required\" }, 400);\n64\t      }\n65\t    } catch {\n66\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n67\t    }\n68\t\n69\t    const nonce = randomBytes(32).toString(\"hex\");\n70\t    const now = new Date();\n71\t    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n72\t\n73\t    const message = buildSignInMessage(\n74\t      body.wallet,\n75\t      cluster,\n76\t      nonce,\n77\t      now.toISOString(),\n78\t      expiresAt.toISOString(),\n79\t    );\n80\t\n81\t    await authDb.insertChallenge(nonce, body.wallet, cluster, message, expiresAt);\n82\t\n83\t    logger.info(\"auth challenge issued\", { wallet: body.wallet, nonce });\n84\t\n85\t    return c.json({\n86\t      nonce,\n87\t      message,\n88\t      expiresAt: expiresAt.toISOString(),\n89\t    });\n90\t  });\n91\t\n92\t  // POST /verify — consume challenge, verify signature, issue tokens\n93\t  app.post(\"/verify\", async (c) => {\n94\t    let body: { nonce: string; wallet: string; signature: string };\n95\t    try {\n96\t      body = await c.req.json();\n97\t      if (\n98\t        typeof body.nonce !== \"string\" ||\n99\t        typeof body.wallet !== \"string\" ||\n100\t        typeof body.signature !== \"string\"\n101\t      ) {\n102\t        return c.json({ error: \"nonce, wallet, and signature are required\" }, 400);\n103\t      }\n104\t    } catch {\n105\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n106\t    }\n107\t\n108\t    // Atomically consume the challenge\n109\t    const challenge = await authDb.consumeChallenge(body.nonce);\n110\t    if (!challenge) {\n111\t      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n112\t        nonce: body.nonce,\n113\t        wallet: body.wallet,\n114\t      });\n115\t      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n116\t    }\n117\t\n118\t    // Verify wallet matches challenge\n119\t    if (challenge.wallet !== body.wallet) {\n120\t      logger.warn(\"auth verify rejected: wallet mismatch\", {\n121\t        nonce: body.nonce,\n122\t        challengeWallet: challenge.wallet,\n123\t        requestWallet: body.wallet,\n124\t      });\n125\t      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n126\t    }\n127\t\n128\t    // Verify Ed25519 signature over the challenge message\n129\t    let sigBytes: Uint8Array;\n130\t    let pubkeyBytes: Uint8Array;\n131\t    try {\n132\t      sigBytes = bs58.decode(body.signature);\n133\t      pubkeyBytes = bs58.decode(body.wallet);\n134\t    } catch {\n135\t      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n136\t    }\n137\t\n138\t    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n139\t      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n140\t    }\n141\t\n142\t    const messageBytes = new TextEncoder().encode(challenge.message);\n143\t    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n144\t    if (!valid) {\n145\t      logger.warn(\"auth verify rejected: signature verification failed\", {\n146\t        wallet: body.wallet,\n147\t      });\n148\t      return c.json({ error: \"Invalid signature\" }, 401);\n149\t    }\n150\t\n151\t    // Issue JWT access token\n152\t    const now = Math.floor(Date.now() / 1000);\n153\t    const accessToken = await new SignJWT({ sub: body.wallet })\n154\t      .setProtectedHeader({ alg: \"HS256\" })\n155\t      .setIssuedAt(now)\n156\t      .setExpirationTime(now + accessTokenTtlSeconds)\n157\t      .sign(jwtSecret);\n158\t\n159\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n160\t\n161\t    // Generate opaque refresh token\n162\t    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n163\t    const refreshTokenHash = hashToken(refreshTokenRaw);\n164\t    const familyId = randomBytes(16).toString(\"hex\");\n165\t    const refreshExpiresAt = new Date(\n166\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n167\t    );\n168\t\n169\t    await authDb.insertRefreshToken(\n170\t      body.wallet,\n171\t      refreshTokenHash,\n172\t      familyId,\n173\t      refreshExpiresAt,\n174\t    );\n175\t\n176\t    logger.info(\"auth session created\", { wallet: body.wallet });\n177\t\n178\t    return c.json({\n179\t      accessToken,\n180\t      accessExpiresAt,\n181\t      refreshToken: refreshTokenRaw,\n182\t      refreshExpiresAt: refreshExpiresAt.toISOString(),\n183\t    });\n184\t  });\n185\t\n186\t  // POST /refresh — rotate refresh token, issue new access token\n187\t  app.post(\"/refresh\", async (c) => {\n188\t    let body: { refreshToken: string };\n189\t    try {\n190\t      body = await c.req.json();\n191\t      if (typeof body.refreshToken !== \"string\") {\n192\t        return c.json({ error: \"refreshToken is required\" }, 400);\n193\t      }\n194\t    } catch {\n195\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n196\t    }\n197\t\n198\t    const tokenHash = hashToken(body.refreshToken);\n199\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n200\t\n201\t    if (!stored) {\n202\t      logger.warn(\"auth refresh rejected: token not found\");\n203\t      return c.json({ error: \"Invalid refresh token\" }, 401);\n204\t    }\n205\t\n206\t    // Reuse detection: if the token was already revoked, someone replayed it.\n207\t    // Revoke the entire family as a precaution.\n208\t    if (stored.revoked) {\n209\t      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n210\t        wallet: stored.wallet,\n211\t        familyId: stored.family_id,\n212\t      });\n213\t      await authDb.revokeTokenFamily(stored.family_id);\n214\t      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n215\t    }\n216\t\n217\t    // Check expiry\n218\t    if (new Date() > stored.expires_at) {\n219\t      logger.warn(\"auth refresh rejected: token expired\", {\n220\t        wallet: stored.wallet,\n221\t      });\n222\t      await authDb.revokeRefreshToken(stored.id);\n223\t      return c.json({ error: \"Refresh token expired\" }, 401);\n224\t    }\n225\t\n226\t    // Revoke old token\n227\t    await authDb.revokeRefreshToken(stored.id);\n228\t\n229\t    // Issue new access token\n230\t    const now = Math.floor(Date.now() / 1000);\n231\t    const accessToken = await new SignJWT({ sub: stored.wallet })\n232\t      .setProtectedHeader({ alg: \"HS256\" })\n233\t      .setIssuedAt(now)\n234\t      .setExpirationTime(now + accessTokenTtlSeconds)\n235\t      .sign(jwtSecret);\n236\t\n237\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n238\t\n239\t    // Issue new refresh token in the same family\n240\t    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n241\t    const newRefreshHash = hashToken(newRefreshRaw);\n242\t    const newRefreshExpiresAt = new Date(\n243\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n244\t    );\n245\t\n246\t    await authDb.insertRefreshToken(\n247\t      stored.wallet,\n248\t      newRefreshHash,\n249\t      stored.family_id,\n250\t      newRefreshExpiresAt,\n251\t    );\n252\t\n253\t    logger.debug(\"auth token refreshed\", { wallet: stored.wallet });\n254\t\n255\t    return c.json({\n256\t      accessToken,\n257\t      accessExpiresAt,\n258\t      refreshToken: newRefreshRaw,\n259\t      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n260\t    });\n261\t  });\n262\t\n263\t  // POST /logout — revoke refresh token\n264\t  app.post(\"/logout\", async (c) => {\n265\t    let body: { refreshToken: string };\n266\t    try {\n267\t      body = await c.req.json();\n268\t      if (typeof body.refreshToken !== \"string\") {\n269\t        return c.body(null, 204);\n270\t      }\n271\t    } catch {\n272\t      return c.body(null, 204);\n273\t    }\n274\t\n275\t    const tokenHash = hashToken(body.refreshToken);\n276\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n277\t    if (stored) {\n278\t      await authDb.revokeRefreshToken(stored.id);\n279\t      logger.info(\"auth logout\", { wallet: stored.wallet });\n280\t    }\n281\t\n282\t    return c.body(null, 204);\n283\t  });\n284\t\n285\t  return app;\n286\t}\n287\t"}]},"parent_tool_use_id":"toolu_01WGgg9fUhqnqCjdED2b1nUj","session_id":"c90b48a1-f03a-4fbb-962c-9618a8223eda","uuid":"594135a2-7b58-4bf6-8d09-857177b6ee86","timestamp":"2026-03-31T14:55:53.316Z"}
