ostgres>;\n  let authDb: AuthDb;\n  let app: Hono;\n\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = postgres(DATABASE_URL);\n    // Ensure auth tables exist\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    authDb = createAuthDb(rawSql);\n    app = new Hono();\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /auth/challenge\n  // -----------------------------------------------------------------------\n\n  it(\"returns a challenge with nonce and message\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n    expect(json.nonce).toBeDefined();\n    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    expect(json.message).toContain(\"Sign in to RNG Utopia\");\n    expect(json.message).toContain(wallet);\n    expect(json.message).toContain(\"devnet\");\n    expect(json.expiresAt).toBeDefined();\n  });\n\n  it(\"rejects challenge with missing wallet\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  // -----------------------------------------------------------------------\n  // Full flow: challenge → verify → refresh → logout\n  // -----------------------------------------------------------------------\n\n  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // 1. Request challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    expect(challengeRes.status).toBe(200);\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // 2. Sign the message\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // 3. Verify\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(200);\n    const tokens = (await verifyRes.json()) as {\n      accessToken: string;\n      accessExpiresAt: string;\n      refreshToken: string;\n      refreshExpiresAt: string;\n    };\n    expect(tokens.accessToken).toBeDefined();\n    expect(tokens.refreshToken).toBeDefined();\n    expect(tokens.accessExpiresAt).toBeDefined();\n    expect(tokens.refreshExpiresAt).toBeDefined();\n\n    // Verify JWT is valid and contains the correct wallet\n    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n      algorithms: [\"HS256\"],\n    });\n    expect(payload.sub).toBe(wallet);\n\n    // 4. Refresh\n    const refreshRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(refreshRes.status).toBe(200);\n    const newTokens = (await refreshRes.json()) as {\n      accessToken: string;\n      refreshToken: string;\n    };\n    expect(newTokens.accessToken).toBeDefined();\n    expect(newTokens.refreshToken).toBeDefined();\n    // New refresh token should be different from the old one\n    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n\n    // 5. Old refresh token should no longer work (it was rotated)\n    const replayRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(replayRes.status).toBe(401);\n    const replayJson = (await replayRes.json()) as { error: string };\n    expect(replayJson.error).toContain(\"reuse\");\n\n    // 6. Logout with new token\n    const logoutRes = await app.request(\"/auth/logout\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(logoutRes.status).toBe(204);\n\n    // 7. Refresh after logout should fail\n    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(postLogoutRefresh.status).toBe(401);\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge cases\n  // -----------------------------------------------------------------------\n\n  it(\"rejects verify with wrong wallet\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    // Get challenge for the correct wallet\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with the correct keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // But claim to be a different wallet\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        nonce: challenge.nonce,\n        wallet: otherKeypair.publicKey.toBase58(),\n        signature,\n      }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with wrong signature\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with wrong keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with already-used nonce\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // Get and consume a challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // First verify — should succeed\n    const res1 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second verify with same nonce — should fail\n    const res2 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res2.status).toBe(401);\n  });\n\n  it(\"rejects refresh with invalid token\", async () => {\n    const res = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n    });\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[{"oldStart":11,"oldLines":6,"newStart":11,"newLines":7,"lines":[" import postgres from \"postgres\";"," import { createAuthDb, type AuthDb } from \"../auth-db.js\";"," import { createAuthRoutes } from \"../routes/auth.js\";","+import type { Db } from \"../db.js\";"," "," // ---------------------------------------------------------------------------"," // Constants"]}],"userModified":false,"replaceAll":false}}
