{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KaGgYfxd2FwM16gC9vCBd4","type":"tool_result","content":"28\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n29\timport { logger } from \"./logger.js\";\n30\t\n31\tconst config = loadConfig();\n32\t\n33\t// Single postgres pool shared by game DB, auth DB, and all workers\n34\tconst sql = postgres(config.databaseUrl);\n35\tconst db = createDb(config.databaseUrl, sql);\n36\tconst authDb = createAuthDb(sql);\n37\t\n38\tconst connection = new Connection(config.rpcUrl, {\n39\t  commitment: \"confirmed\",\n40\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n41\t});\n42\t\n43\tconst app = new Hono();\n44\t\n45\tapp.use(\n46\t  \"*\",\n47\t  cors({\n48\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n49\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n50\t    allowHeaders: [\"Content-Type\", \"Authorization\"],\n51\t  }),\n52\t);\n53\t\n54\t// Request logging — correlate frontend fetch timing with server-side processing\n55\tapp.use(\"*\", async (c, next) => {\n56\t  const start = Date.now();\n57\t  await next();\n58\t  const ms = Date.now() - start;\n59\t  const method = c.req.method;\n60\t  const path = c.req.path;\n61\t  // Skip noisy health checks and OPTIONS preflight\n62\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n63\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n64\t});\n65\t\n66\t// API docs — Swagger UI + raw OpenAPI spec\n67\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n68\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n69\t\n70\t// Auth routes — no JWT middleware (these are the login endpoints)\n71\t// Lighter rate limiting by IP for auth endpoints\n72\tapp.use(\n73\t  \"/auth/*\",\n74\t  createRateLimitMiddleware({\n75\t    perWallet: 20,\n76\t    global: config.rateLimitGlobal,\n77\t    windowMs: 60_000,\n78\t  }),\n79\t);\n80\t\n81\tapp.route(\n82\t  \"/auth\",\n83\t  createAuthRoutes({\n84\t    authDb,\n85\t    jwtSecret: config.jwtSecret,\n86\t    cluster: config.cluster,\n87\t    challengeTtlSeconds: config.challengeTtlSeconds,\n88\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n89\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n90\t  }),\n91\t);\n92\t\n93\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n94\tapp.use(\n95\t  \"/profile/*\",\n96\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n97\t);"}]},"parent_tool_use_id":null,"session_id":"c90b48a1-f03a-4fbb-962c-9618a8223eda","uuid":"b0929c2a-499c-4d4b-a458-6cbf0b8508e9","timestamp":"2026-03-31T14:56:18.971Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/index.ts","content":"import { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Single postgres pool shared by game DB, auth DB, and all workers\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl, sql);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new Hono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// API docs — Swagger UI + raw OpenAPI spec\napp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\napp.get(\"/openapi.json\", (c) => c.json(spec));\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// Profile routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/profile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);","numLines":70,"startLine":28,"totalLines":263}}}
