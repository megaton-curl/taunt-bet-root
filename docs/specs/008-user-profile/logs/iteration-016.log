nonce: string,\n  issuedAt: string,\n  expiresAt: string,\n): string {\n  return [\n    \"Sign in to RNG Utopia\",\n    `Wallet: ${wallet}`,\n    `Cluster: ${cluster}`,\n    `Nonce: ${nonce}`,\n    `Issued At: ${issuedAt}`,\n    `Expires At: ${expiresAt}`,\n    \"This signature creates a backend session for gameplay actions.\",\n    \"It does not approve a blockchain transaction.\",\n  ].join(\"\\n\");\n}\n\nexport function createAuthRoutes(deps: AuthRoutesDeps): Hono {\n  const {\n    authDb,\n    db,\n    jwtSecret,\n    cluster,\n    challengeTtlSeconds,\n    accessTokenTtlSeconds,\n    refreshTokenTtlDays,\n  } = deps;\n\n  const app = new Hono();\n\n  // POST /challenge — generate nonce + human-readable message\n  app.post(\"/challenge\", async (c) => {\n    let body: { wallet: string };\n    try {\n      body = await c.req.json();\n      if (typeof body.wallet !== \"string\" || body.wallet.length === 0) {\n        return c.json({ error: \"wallet is required\" }, 400);\n      }\n    } catch {\n      return c.json({ error: \"Invalid JSON body\" }, 400);\n    }\n\n    const nonce = randomBytes(32).toString(\"hex\");\n    const now = new Date();\n    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n\n    const message = buildSignInMessage(\n      body.wallet,\n      cluster,\n      nonce,\n      now.toISOString(),\n      expiresAt.toISOString(),\n    );\n\n    await authDb.insertChallenge(nonce, body.wallet, cluster, message, expiresAt);\n\n    logger.info(\"auth challenge issued\", { wallet: body.wallet, nonce });\n\n    return c.json({\n      nonce,\n      message,\n      expiresAt: expiresAt.toISOString(),\n    });\n  });\n\n  // POST /verify — consume challenge, verify signature, issue tokens\n  app.post(\"/verify\", async (c) => {\n    let body: { nonce: string; wallet: string; signature: string };\n    try {\n      body = await c.req.json();\n      if (\n        typeof body.nonce !== \"string\" ||\n        typeof body.wallet !== \"string\" ||\n        typeof body.signature !== \"string\"\n      ) {\n        return c.json({ error: \"nonce, wallet, and signature are required\" }, 400);\n      }\n    } catch {\n      return c.json({ error: \"Invalid JSON body\" }, 400);\n    }\n\n    // Atomically consume the challenge\n    const challenge = await authDb.consumeChallenge(body.nonce);\n    if (!challenge) {\n      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n        nonce: body.nonce,\n        wallet: body.wallet,\n      });\n      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n    }\n\n    // Verify wallet matches challenge\n    if (challenge.wallet !== body.wallet) {\n      logger.warn(\"auth verify rejected: wallet mismatch\", {\n        nonce: body.nonce,\n        challengeWallet: challenge.wallet,\n        requestWallet: body.wallet,\n      });\n      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n    }\n\n    // Verify Ed25519 signature over the challenge message\n    let sigBytes: Uint8Array;\n    let pubkeyBytes: Uint8Array;\n    try {\n      sigBytes = bs58.decode(body.signature);\n      pubkeyBytes = bs58.decode(body.wallet);\n    } catch {\n      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n    }\n\n    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n    }\n\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n    if (!valid) {\n      logger.warn(\"auth verify rejected: signature verification failed\", {\n        wallet: body.wallet,\n      });\n      return c.json({ error: \"Invalid signature\" }, 401);\n    }\n\n    // Issue JWT access token\n    const now = Math.floor(Date.now() / 1000);\n    const accessToken = await new SignJWT({ sub: body.wallet })\n      .setProtectedHeader({ alg: \"HS256\" })\n      .setIssuedAt(now)\n      .setExpirationTime(now + accessTokenTtlSeconds)\n      .sign(jwtSecret);\n\n    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n\n    // Generate opaque refresh token\n    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n    const refreshTokenHash = hashToken(refreshTokenRaw);\n    const familyId = randomBytes(16).toString(\"hex\");\n    const refreshExpiresAt = new Date(\n      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n    );\n\n    await authDb.insertRefreshToken(\n      body.wallet,\n      refreshTokenHash,\n      familyId,\n      refreshExpiresAt,\n    );\n\n    logger.info(\"auth session created\", { wallet: body.wallet });\n\n    return c.json({\n      accessToken,\n      accessExpiresAt,\n      refreshToken: refreshTokenRaw,\n      refreshExpiresAt: refreshExpiresAt.toISOString(),\n    });\n  });\n\n  // POST /refresh — rotate refresh token, issue new access token\n  app.post(\"/refresh\", async (c) => {\n    let body: { refreshToken: string };\n    try {\n      body = await c.req.json();\n      if (typeof body.refreshToken !== \"string\") {\n        return c.json({ error: \"refreshToken is required\" }, 400);\n      }\n    } catch {\n      return c.json({ error: \"Invalid JSON body\" }, 400);\n    }\n\n    const tokenHash = hashToken(body.refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n\n    if (!stored) {\n      logger.warn(\"auth refresh rejected: token not found\");\n      return c.json({ error: \"Invalid refresh token\" }, 401);\n    }\n\n    // Reuse detection: if the token was already revoked, someone replayed it.\n    // Revoke the entire family as a precaution.\n    if (stored.revoked) {\n      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n        wallet: stored.wallet,\n        familyId: stored.family_id,\n      });\n      await authDb.revokeTokenFamily(stored.family_id);\n      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n    }\n\n    // Check expiry\n    if (new Date() > stored.expires_at) {\n      logger.warn(\"auth refresh rejected: token expired\", {\n        wallet: stored.wallet,\n      });\n      await authDb.revokeRefreshToken(stored.id);\n      return c.json({ error: \"Refresh token expired\" }, 401);\n    }\n\n    // Revoke old token\n    await authDb.revokeRefreshToken(stored.id);\n\n    // Issue new access token\n    const now = Math.floor(Date.now() / 1000);\n    const accessToken = await new SignJWT({ sub: stored.wallet })\n      .setProtectedHeader({ alg: \"HS256\" })\n      .setIssuedAt(now)\n      .setExpirationTime(now + accessTokenTtlSeconds)\n      .sign(jwtSecret);\n\n    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n\n    // Issue new refresh token in the same family\n    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n    const newRefreshHash = hashToken(newRefreshRaw);\n    const newRefreshExpiresAt = new Date(\n      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n    );\n\n    await authDb.insertRefreshToken(\n      stored.wallet,\n      newRefreshHash,\n      stored.family_id,\n      newRefreshExpiresAt,\n    );\n\n    logger.debug(\"auth token refreshed\", { wallet: stored.wallet });\n\n    return c.json({\n      accessToken,\n      accessExpiresAt,\n      refreshToken: newRefreshRaw,\n      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n    });\n  });\n\n  // POST /logout — revoke refresh token\n  app.post(\"/logout\", async (c) => {\n    let body: { refreshToken: string };\n    try {\n      body = await c.req.json();\n      if (typeof body.refreshToken !== \"string\") {\n        return c.body(null, 204);\n      }\n    } catch {\n      return c.body(null, 204);\n    }\n\n    const tokenHash = hashToken(body.refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n    if (stored) {\n      await authDb.revokeRefreshToken(stored.id);\n      logger.info(\"auth logout\", { wallet: stored.wallet });\n    }\n\n    return c.body(null, 204);\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":151,"oldLines":6,"newStart":151,"newLines":17,"lines":["       return c.json({ error: \"Invalid signature\" }, 401);","     }"," ","+    // Ensure player profile exists (fire-and-forget — auth must not fail on this)","+    try {","+      const existing = await db.getProfileByWallet(body.wallet);","+      if (!existing) {","+        await db.createPlayerProfile(body.wallet);","+        logger.info(\"player profile auto-created\", { wallet: body.wallet });","+      }","+    } catch (e) {","+      logger.error(\"profile creation failed (non-blocking)\", { wallet: body.wallet, error: e });","+    }","+","     // Issue JWT access token","     const now = Math.floor(Date.now() / 1000);","     const accessToken = await new SignJWT({ sub: body.wallet })"]}],"userModified":false,"replaceAll":false}}
