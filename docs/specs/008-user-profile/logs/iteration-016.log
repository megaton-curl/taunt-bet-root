eshToken }),\n    });\n    expect(logoutRes.status).toBe(204);\n\n    // 7. Refresh after logout should fail\n    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(postLogoutRefresh.status).toBe(401);\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge cases\n  // -----------------------------------------------------------------------\n\n  it(\"rejects verify with wrong wallet\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    // Get challenge for the correct wallet\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with the correct keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // But claim to be a different wallet\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        nonce: challenge.nonce,\n        wallet: otherKeypair.publicKey.toBase58(),\n        signature,\n      }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with wrong signature\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { 