{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UMYsfMfWHnW3tMtBexMc91","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPriceRoutes } from \"./routes/price.js\";\n16\timport { createAuthRoutes } from \"./routes/auth.js\";\n17\timport { createReferralRoutes } from \"./routes/referral.js\";\n18\timport { swaggerUI } from \"@hono/swagger-ui\";\n19\timport { spec } from \"./openapi.js\";\n20\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n21\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n22\timport { createSettlementWorker } from \"./worker/settlement.js\";\n23\timport { settleRound } from \"./worker/settle-tx.js\";\n24\timport { createRetrySettler } from \"./worker/retry.js\";\n25\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n26\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n27\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n28\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n29\timport { logger } from \"./logger.js\";\n30\t\n31\tconst config = loadConfig();\n32\t\n33\t// Single postgres pool shared by game DB, auth DB, and all workers\n34\tconst sql = postgres(config.databaseUrl);\n35\tconst db = createDb(config.databaseUrl, sql);\n36\tconst authDb = createAuthDb(sql);\n37\t\n38\tconst connection = new Connection(config.rpcUrl, {\n39\t  commitment: \"confirmed\",\n40\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n41\t});\n42\t\n43\tconst app = new Hono();\n44\t\n45\tapp.use(\n46\t  \"*\",\n47\t  cors({\n48\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n49\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n50\t    allowHeaders: [\"Content-Type\", \"Authorization\"],\n51\t  }),\n52\t);\n53\t\n54\t// Request logging — correlate frontend fetch timing with server-side processing\n55\tapp.use(\"*\", async (c, next) => {\n56\t  const start = Date.now();\n57\t  await next();\n58\t  const ms = Date.now() - start;\n59\t  const method = c.req.method;\n60\t  const path = c.req.path;\n61\t  // Skip noisy health checks and OPTIONS preflight\n62\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n63\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n64\t});\n65\t\n66\t// API docs — Swagger UI + raw OpenAPI spec\n67\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n68\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n69\t\n70\t// Auth routes — no JWT middleware (these are the login endpoints)\n71\t// Lighter rate limiting by IP for auth endpoints\n72\tapp.use(\n73\t  \"/auth/*\",\n74\t  createRateLimitMiddleware({\n75\t    perWallet: 20,\n76\t    global: config.rateLimitGlobal,\n77\t    windowMs: 60_000,\n78\t  }),\n79\t);\n80\t\n81\tapp.route(\n82\t  \"/auth\",\n83\t  createAuthRoutes({\n84\t    authDb,\n85\t    jwtSecret: config.jwtSecret,\n86\t    cluster: config.cluster,\n87\t    challengeTtlSeconds: config.challengeTtlSeconds,\n88\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n89\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n90\t  }),\n91\t);\n92\t\n93\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n94\tapp.use(\n95\t  \"/profile/*\",\n96\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n97\t);\n98\tapp.route(\"/profile\", createProfileRoutes({ db }));\n99\t\n100\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n101\tapp.use(\n102\t  \"/referral/*\",\n103\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n104\t);\n105\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n106\t\n107\t// JWT auth middleware for fairness endpoints\n108\tapp.use(\n109\t  \"/fairness/*\",\n110\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n111\t);\n112\t\n113\t// Rate limiting — per-wallet and global limits on POST requests\n114\tapp.use(\n115\t  \"/fairness/*\",\n116\t  createRateLimitMiddleware({\n117\t    perWallet: config.rateLimitPerWallet,\n118\t    global: config.rateLimitGlobal,\n119\t    windowMs: 60_000,\n120\t  }),\n121\t);\n122\t\n123\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n124\tconst entropyAccount = new PublicKey(config.entropyAccount);\n125\tconst retrySettler = createRetrySettler({\n126\t  db,\n127\t  connection,\n128\t  settleRound: (pda) =>\n129\t    settleRound(\n130\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n131\t      pda,\n132\t    ),\n133\t});\n134\t\n135\t// PDA watcher — WebSocket-based instant join detection\n136\tconst pdaWatcher = createPdaWatcher({\n137\t  connection,\n138\t  serverKey: config.serverKeypair.publicKey,\n139\t  db,\n140\t  onJoinDetected: async (pda, targetSlot) => {\n141\t    // Update DB phase if still in 'created'\n142\t    const round = await db.getRoundByPda(pda);\n143\t    if (round && round.phase === \"created\") {\n144\t      await db.updateRoundPhase(pda, \"locked\", {\n145\t        target_slot: targetSlot.toString(),\n146\t      });\n147\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n148\t        targetSlot: targetSlot.toString(),\n149\t        source: \"pda-watcher\",\n150\t        game: round.game,\n151\t      });\n152\t    }\n153\t\n154\t    // Check if target slot already passed — settle immediately if so\n155\t    const currentSlot = await connection.getSlot();\n156\t    if (BigInt(currentSlot) >= targetSlot) {\n157\t      await retrySettler.attemptSettle(pda);\n158\t      pdaWatcher.unwatch(pda);\n159\t    }\n160\t    // If target slot not reached yet, poll worker will pick it up next cycle\n161\t  },\n162\t});\n163\t\n164\tconst worker = createSettlementWorker({\n165\t  db,\n166\t  connection,\n167\t  serverKey: config.serverKeypair.publicKey,\n168\t  pollIntervalMs: config.workerPollIntervalMs,\n169\t  onSettleReady: async (pda) => {\n170\t    await retrySettler.attemptSettle(pda);\n171\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n172\t  },\n173\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n174\t});\n175\tworker.start();\n176\t\n177\t// Close Call clock worker — fetches boundary prices + settles open rounds\n178\t// Rounds are created on-demand by players via /closecall/bet\n179\tconst closeCallClock = createCloseCallClockWorker({\n180\t  connection,\n181\t  serverKeypair: config.serverKeypair,\n182\t  db: sql,\n183\t});\n184\tcloseCallClock.start();\n185\t\n186\t// Register event handlers before starting the worker\n187\tregisterHandler(\n188\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n189\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n190\t);\n191\t\n192\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n193\tconst eventWorker = createEventWorker(sql, {\n194\t  pollIntervalMs: config.eventQueuePollMs,\n195\t});\n196\teventWorker.start();\n197\tlogger.info(\"Event queue worker started\", {\n198\t  pollIntervalMs: config.eventQueuePollMs,\n199\t});\n200\t\n201\t// Coinflip fairness routes\n202\tapp.route(\n203\t  \"/fairness/coinflip\",\n204\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n205\t);\n206\tapp.route(\n207\t  \"/fairness/lord\",\n208\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n209\t);\n210\t\n211\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n212\tapp.use(\n213\t  \"/closecall/bet\",\n214\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n215\t);\n216\tapp.use(\n217\t  \"/closecall/bet\",\n218\t  createRateLimitMiddleware({\n219\t    perWallet: config.rateLimitPerWallet,\n220\t    global: config.rateLimitGlobal,\n221\t    windowMs: 60_000,\n222\t  }),\n223\t);\n224\t\n225\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n226\tapp.route(\"/closecall\", createCloseCallRoutes({\n227\t  db,\n228\t  connection,\n229\t  serverKeypair: config.serverKeypair,\n230\t  clockWorker: closeCallClock,\n231\t  sql,\n232\t}));\n233\t\n234\t// Price routes — public, no auth\n235\tapp.route(\"/price\", createPriceRoutes());\n236\t\n237\t// Round verification routes\n238\tapp.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n239\t\n240\t// Health endpoint — wired after worker exists so we can query its status\n241\tapp.route(\n242\t  \"/health\",\n243\t  createHealthRoutes({\n244\t    db,\n245\t    sql,\n246\t    isWorkerRunning: () => worker.isRunning,\n247\t  }),\n248\t);\n249\t\n250\tconst port = config.port;\n251\tlogger.info(\"fairness-backend started\", { port });\n252\t\n253\tserve({\n254\t  fetch: app.fetch,\n255\t  port,\n256\t  hostname: \"0.0.0.0\",\n257\t});\n258\t\n259\texport default {\n260\t  port,\n261\t  fetch: app.fetch,\n262\t};\n263\t"}]},"parent_tool_use_id":"toolu_01WGgg9fUhqnqCjdED2b1nUj","session_id":"c90b48a1-f03a-4fbb-962c-9618a8223eda","uuid":"50ccadf0-3189-4e13-806b-3d99fead493c","timestamp":"2026-03-31T14:55:53.542Z"}
