{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lya6MJpe5vDh7uaKQe5Dk9","type":"tool_result","content":"1\t-- 005_closecall_rounds.sql — Separate table for Close Call pari-mutuel rounds.\n2\t--\n3\t-- Close Call uses oracle-resolved settlement (no secret/commitment), pari-mutuel\n4\t-- pools (multiple players per round), and Pyth price data — a fundamentally\n5\t-- different schema from the commit-reveal `rounds` table.\n6\t\n7\tCREATE TABLE IF NOT EXISTS closecall_rounds (\n8\t  round_id       TEXT PRIMARY KEY,       -- 16-char hex (8-byte random ID)\n9\t  pda            TEXT UNIQUE NOT NULL,    -- Round PDA on-chain\n10\t  server_key     TEXT NOT NULL,           -- Server pubkey that created the round\n11\t  phase          TEXT NOT NULL DEFAULT 'open',  -- open | settled | refunded\n12\t  open_price     BIGINT NOT NULL,        -- Pyth price at round creation\n13\t  open_price_expo INT NOT NULL,          -- Pyth exponent\n14\t  close_price    BIGINT,                 -- Pyth price at settlement (NULL until settled)\n15\t  outcome        TEXT NOT NULL DEFAULT 'pending',  -- pending | green | red | refund\n16\t  green_pool     BIGINT NOT NULL DEFAULT 0,  -- Total lamports on green side\n17\t  red_pool       BIGINT NOT NULL DEFAULT 0,  -- Total lamports on red side\n18\t  total_fee      BIGINT NOT NULL DEFAULT 0,  -- Fee collected (only on decisive rounds)\n19\t  green_entries  JSONB NOT NULL DEFAULT '[]', -- [{player, amountLamports}]\n20\t  red_entries    JSONB NOT NULL DEFAULT '[]', -- [{player, amountLamports}]\n21\t  settle_tx      TEXT,                   -- Settlement transaction signature\n22\t  created_at     TIMESTAMPTZ DEFAULT now(),\n23\t  settled_at     TIMESTAMPTZ             -- NULL until settled/refunded\n24\t);\n25\t\n26\tCREATE INDEX IF NOT EXISTS idx_closecall_rounds_phase ON closecall_rounds(phase);\n27\tCREATE INDEX IF NOT EXISTS idx_closecall_rounds_settled_at ON closecall_rounds(settled_at DESC);\n28\t"}]},"parent_tool_use_id":"toolu_01RoFYvWECRNhCTf6UXtUYrP","session_id":"aa94e491-d3b8-48ec-9244-f434c72362a9","uuid":"fd1c5cea-d956-4135-9087-0d9a71d3ad5b","timestamp":"2026-03-31T14:03:48.391Z"}
