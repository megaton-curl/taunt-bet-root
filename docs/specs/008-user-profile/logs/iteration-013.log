{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WfjxtuEaDx9G6EsdiEEyNq","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPriceRoutes } from \"./routes/price.js\";\n16\timport { createAuthRoutes } from \"./routes/auth.js\";\n17\timport { createReferralRoutes } from \"./routes/referral.js\";\n18\timport { swaggerUI } from \"@hono/swagger-ui\";\n19\timport { spec } from \"./openapi.js\";\n20\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n21\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n22\timport { createSettlementWorker } from \"./worker/settlement.js\";\n23\timport { settleRound } from \"./worker/settle-tx.js\";\n24\timport { createRetrySettler } from \"./worker/retry.js\";\n25\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n26\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n27\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n28\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n29\timport { logger } from \"./logger.js\";\n30\t\n31\tconst config = loadConfig();\n32\t\n33\t// Single postgres pool shared by game DB, auth DB, and all workers\n34\tconst sql = postgres(config.databaseUrl);\n35\tconst db = createDb(config.databaseUrl, sql);\n36\tconst authDb = createAuthDb(sql);\n37\t\n38\tconst connection = new Connection(config.rpcUrl, {\n39\t  commitment: \"confirmed\",\n40\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n41\t});\n42\t\n43\tconst app = new Hono();\n44\t\n45\tapp.use(\n46\t  \"*\",\n47\t  cors({\n48\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n49\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n50\t    allowHeaders: [\"Content-Type\", \"Authorization\"],\n51\t  }),\n52\t);\n53\t\n54\t// Request logging — correlate frontend fetch timing with server-side processing\n55\tapp.use(\"*\", async (c, next) => {\n56\t  const start = Date.now();\n57\t  await next();\n58\t  const ms = Date.now() - start;\n59\t  const method = c.req.method;\n60\t  const path = c.req.path;\n61\t  // Skip noisy health checks and OPTIONS preflight\n62\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n63\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n64\t});\n65\t\n66\t// API docs — Swagger UI + raw OpenAPI spec\n67\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n68\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n69\t\n70\t// Auth routes — no JWT middleware (these are the login endpoints)\n71\t// Lighter rate limiting by IP for auth endpoints\n72\tapp.use(\n73\t  \"/auth/*\",\n74\t  createRateLimitMiddleware({\n75\t    perWallet: 20,\n76\t    global: config.rateLimitGlobal,\n77\t    windowMs: 60_000,\n78\t  }),\n79\t);\n80\t\n81\tapp.route(\n82\t  \"/auth\",\n83\t  createAuthRoutes({\n84\t    authDb,\n85\t    jwtSecret: config.jwtSecret,\n86\t    cluster: config.cluster,\n87\t    challengeTtlSeconds: config.challengeTtlSeconds,\n88\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n89\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n90\t  }),\n91\t);\n92\t\n93\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n94\tapp.use(\n95\t  \"/profile/*\",\n96\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n97\t);\n98\tapp.route(\"/profile\", createProfileRoutes({ db }));\n99\t\n100\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)"}]},"parent_tool_use_id":"toolu_01RoFYvWECRNhCTf6UXtUYrP","session_id":"aa94e491-d3b8-48ec-9244-f434c72362a9","uuid":"aaac7269-274d-445d-954a-e242a68d5405","timestamp":"2026-03-31T14:03:52.981Z"}
