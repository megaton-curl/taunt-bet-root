{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HQHbgkm4Q9DHuPbxSJuvN1","type":"tool_result","content":"1\t-- 011_referral.sql — Referral system tables (spec 300).\n2\t--\n3\t-- Off-chain referral economics: player-chosen codes, referral linking,\n4\t-- per-game earnings tracking, claim payouts, and KOL custom rates.\n5\t-- No on-chain program changes — all tables are backend-only.\n6\t\n7\t-- Referral codes: one active code per wallet\n8\tCREATE TABLE IF NOT EXISTS referral_codes (\n9\t  id              SERIAL       PRIMARY KEY,\n10\t  wallet          TEXT         NOT NULL UNIQUE,\n11\t  code            TEXT         NOT NULL UNIQUE,  -- player-chosen, 3-16 chars [a-z0-9-]\n12\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n13\t  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n14\t);\n15\t\n16\t-- Referral links: immutable referrer→referee binding (one referrer per player)\n17\tCREATE TABLE IF NOT EXISTS referral_links (\n18\t  id              SERIAL       PRIMARY KEY,\n19\t  referrer_wallet TEXT         NOT NULL,\n20\t  referee_wallet  TEXT         NOT NULL UNIQUE,\n21\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n22\t);\n23\t\n24\tCREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n25\t  ON referral_links (referrer_wallet);\n26\t\n27\t-- Referral earnings: one row per referee per round (idempotency guard)\n28\tCREATE TABLE IF NOT EXISTS referral_earnings (\n29\t  id                        SERIAL       PRIMARY KEY,\n30\t  referrer_wallet           TEXT         NOT NULL,\n31\t  referee_wallet            TEXT         NOT NULL,\n32\t  round_id                  TEXT         NOT NULL,\n33\t  game_type                 TEXT         NOT NULL,\n34\t  wager_lamports            BIGINT       NOT NULL,\n35\t  fee_lamports              BIGINT       NOT NULL,\n36\t  referrer_earned_lamports  BIGINT       NOT NULL,\n37\t  referrer_rate_bps         INTEGER      NOT NULL,\n38\t  referee_rebate_lamports   BIGINT       NOT NULL,\n39\t  referee_rebate_rate_bps   INTEGER      NOT NULL,\n40\t  created_at                TIMESTAMPTZ  NOT NULL DEFAULT now(),\n41\t\n42\t  CONSTRAINT uq_referral_earnings_referee_round\n43\t    UNIQUE (referee_wallet, round_id)\n44\t);\n45\t\n46\tCREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n47\t  ON referral_earnings (referrer_wallet, created_at);\n48\t\n49\tCREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n50\t  ON referral_earnings (referee_wallet, created_at);\n51\t\n52\tCREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n53\t  ON referral_earnings (round_id);\n54\t\n55\t-- Referral claims: async SOL payout tracking\n56\tCREATE TABLE IF NOT EXISTS referral_claims (\n57\t  id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),\n58\t  wallet          TEXT         NOT NULL,\n59\t  amount_lamports BIGINT       NOT NULL,\n60\t  status          TEXT         NOT NULL DEFAULT 'pending',\n61\t  tx_signature    TEXT,\n62\t  error           TEXT,\n63\t  requested_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n64\t  processed_at    TIMESTAMPTZ,\n65\t\n66\t  CONSTRAINT chk_referral_claims_status\n67\t    CHECK (status IN ('pending', 'processing', 'completed', 'failed'))\n68\t);\n69\t\n70\tCREATE INDEX IF NOT EXISTS idx_referral_claims_wallet\n71\t  ON referral_claims (wallet, requested_at);\n72\t\n73\tCREATE INDEX IF NOT EXISTS idx_referral_claims_status\n74\t  ON referral_claims (status)\n75\t  WHERE status IN ('pending', 'processing');\n76\t\n77\t-- KOL custom referrer rates (overrides default 1000 bps)\n78\tCREATE TABLE IF NOT EXISTS referral_kol_rates (\n79\t  wallet          TEXT         PRIMARY KEY,\n80\t  rate_bps        INTEGER      NOT NULL,\n81\t  set_by          TEXT         NOT NULL,\n82\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n83\t  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n84\t);\n85\t"}]},"parent_tool_use_id":"toolu_01RoFYvWECRNhCTf6UXtUYrP","session_id":"aa94e491-d3b8-48ec-9244-f434c72362a9","uuid":"059175a7-d288-4ea8-b0d0-95fa9ca67202","timestamp":"2026-03-31T14:03:48.655Z"}
