{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0164rR379roicUptuGQexVbU","type":"tool_result","content":"1\t/**\n2\t * Database client module — typed query functions for `rounds` and `operator_events`.\n3\t *\n4\t * Phase transitions are unidirectional: created → locked → settling → settled,\n5\t * or created → expired. The application layer rejects backward transitions.\n6\t */\n7\t\n8\timport postgres from \"postgres\";\n9\t\n10\t// ---------------------------------------------------------------------------\n11\t// Types\n12\t// ---------------------------------------------------------------------------\n13\t\n14\texport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n15\t\n16\texport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n17\texport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n18\t\n19\texport interface CloseCallRound {\n20\t  round_id: string;\n21\t  pda: string;\n22\t  server_key: string;\n23\t  phase: CloseCallPhase;\n24\t  open_price: number;\n25\t  open_price_expo: number;\n26\t  close_price: number | null;\n27\t  outcome: CloseCallOutcome;\n28\t  green_pool: number;\n29\t  red_pool: number;\n30\t  total_fee: number;\n31\t  green_entries: Array<{ player: string; amountLamports: number }>;\n32\t  red_entries: Array<{ player: string; amountLamports: number }>;\n33\t  settle_tx: string | null;\n34\t  created_at: Date;\n35\t  settled_at: Date | null;\n36\t}\n37\t\n38\texport interface InsertCloseCallRoundParams {\n39\t  roundId: string;\n40\t  pda: string;\n41\t  serverKey: string;\n42\t  openPrice: number;\n43\t  openPriceExpo: number;\n44\t}\n45\t\n46\texport type OperatorEventType =\n47\t  | \"secret_generated\"\n48\t  | \"tx_built\"\n49\t  | \"match_detected\"\n50\t  | \"settle_submitted\"\n51\t  | \"settle_confirmed\"\n52\t  | \"settle_failed\"\n53\t  | \"settle_retried\"\n54\t  | \"timeout_detected\";\n55\t\n56\texport interface Round {\n57\t  pda: string;\n58\t  game: string;\n59\t  creator: string;\n60\t  server_key: string;\n61\t  secret: Buffer;\n62\t  commitment: Buffer;\n63\t  amount_lamports: number;\n64\t  side: number;\n65\t  match_id: string;\n66\t  phase: RoundPhase;\n67\t  target_slot: string | null;\n68\t  settle_tx: string | null;\n69\t  settle_attempts: number;\n70\t  result_hash: Buffer | null;\n71\t  result_side: number | null;\n72\t  winner: string | null;\n73\t  entries: unknown | null;\n74\t  created_at: Date;\n75\t  updated_at: Date;\n76\t}\n77\t\n78\texport interface InsertRoundParams {\n79\t  pda: string;\n80\t  game: string;\n81\t  creator: string;\n82\t  serverKey: string;\n83\t  secret: Buffer;\n84\t  commitment: Buffer;\n85\t  amountLamports: number;\n86\t  side: number;\n87\t  matchId: string;\n88\t  phase: RoundPhase;\n89\t  entries?: Array<{ player: string; amountLamports: number }>;\n90\t}\n91\t\n92\texport interface OperatorEvent {\n93\t  id: string;\n94\t  pda: string | null;\n95\t  event_type: OperatorEventType;\n96\t  payload: unknown;\n97\t  created_at: Date;\n98\t}\n99\t\n100\t// ---------------------------------------------------------------------------\n101\t// Transaction types\n102\t// ---------------------------------------------------------------------------\n103\t\n104\texport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n105\t\n106\texport interface Transaction {\n107\t  id: string;\n108\t  wallet: string;\n109\t  game: string;\n110\t  match_id: string;\n111\t  tx_type: TransactionType;\n112\t  amount_lamports: number;\n113\t  tx_sig: string;\n114\t  created_at: Date;\n115\t}\n116\t\n117\texport interface InsertTransactionParams {\n118\t  wallet: string;\n119\t  game: string;\n120\t  matchId: string;\n121\t  txType: TransactionType;\n122\t  amountLamports: number;\n123\t  txSig: string;\n124\t}\n125\t\n126\t// ---------------------------------------------------------------------------\n127\t// Referral types\n128\t// ---------------------------------------------------------------------------\n129\t\n130\texport interface ReferralCode {\n131\t  id: number;\n132\t  wallet: string;\n133\t  code: string;\n134\t  created_at: Date;\n135\t  updated_at: Date;\n136\t}\n137\t\n138\texport interface ReferralLink {\n139\t  id: number;\n140\t  referrer_wallet: string;\n141\t  referee_wallet: string;\n142\t  created_at: Date;\n143\t}\n144\t\n145\texport interface ReferralEarning {\n146\t  id: number;\n147\t  referrer_wallet: string;\n148\t  referee_wallet: string;\n149\t  round_id: string;\n150\t  game_type: string;\n151\t  wager_lamports: number;\n152\t  fee_lamports: number;\n153\t  referrer_earned_lamports: number;\n154\t  referrer_rate_bps: number;\n155\t  referee_rebate_lamports: number;\n156\t  referee_rebate_rate_bps: number;\n157\t  created_at: Date;\n158\t}\n159\t\n160\texport interface ReferralStats {\n161\t  referred_count: number;\n162\t  active_count: number;\n163\t  total_volume_lamports: string;\n164\t  total_earned_lamports: string;\n165\t  total_rebate_lamports: string;\n166\t  pending_lamports: string;\n167\t}\n168\t\n169\texport interface ReferralClaim {\n170\t  id: string;\n171\t  wallet: string;\n172\t  amount_lamports: string;\n173\t  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n174\t  retry_count: number;\n175\t  tx_signature: string | null;\n176\t  error: string | null;\n177\t  requested_at: Date;\n178\t  processed_at: Date | null;\n179\t}\n180\t\n181\t// ---------------------------------------------------------------------------\n182\t// Phase transition guard\n183\t// ---------------------------------------------------------------------------\n184\t\n185\t/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n186\tconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n187\t  created: [\"locked\", \"expired\"],\n188\t  locked: [\"settling\"],\n189\t  settling: [\"settled\"],\n190\t  settled: [],\n191\t  expired: [],\n192\t};\n193\t\n194\tfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n195\t  const allowed = VALID_TRANSITIONS[from];\n196\t  if (!allowed.includes(to)) {\n197\t    throw new Error(\n198\t      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n199\t    );\n200\t  }\n201\t}\n202\t\n203\t// ---------------------------------------------------------------------------\n204\t// DB client\n205\t// ---------------------------------------------------------------------------\n206\t\n207\texport interface Db {\n208\t  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n209\t  insertRound(params: InsertRoundParams): Promise<Round>;\n210\t\n211\t  /** Delete a round by PDA. Returns true if a row was removed. */\n212\t  deleteRoundByPda(pda: string): Promise<boolean>;\n213\t\n214\t  /** Transition a round's phase. Enforces unidirectional state machine.\n215\t   *  Optional `updates` can set additional columns alongside the phase change. */\n216\t  updateRoundPhase(\n217\t    pda: string,\n218\t    newPhase: RoundPhase,\n219\t    updates?: Partial<\n220\t      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n221\t    >,\n222\t  ): Promise<Round>;\n223\t\n224\t  /** Update the entries JSONB column for a settled round. */\n225\t  updateRoundEntries(\n226\t    pda: string,\n227\t    entries: Array<{ player: string; amountLamports: number }>,\n228\t  ): Promise<Round>;\n229\t\n230\t  /** Get a single round by its PDA. Returns `undefined` if not found. */\n231\t  getRoundByPda(pda: string): Promise<Round | undefined>;\n232\t\n233\t  /** Get all rounds matching a given phase. */\n234\t  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n235\t\n236\t  /** Append an operator event to the audit log. */\n237\t  insertOperatorEvent(\n238\t    pda: string | null,\n239\t    eventType: OperatorEventType,\n240\t    payload?: unknown,\n241\t  ): Promise<OperatorEvent>;\n242\t\n243\t  /** Get the latest operator event for a PDA + type. */\n244\t  getLatestOperatorEvent(\n245\t    pda: string,\n246\t    eventType: OperatorEventType,\n247\t  ): Promise<OperatorEvent | undefined>;\n248\t\n249\t  /** Get a single round by its match_id. Returns `undefined` if not found. */\n250\t  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n251\t\n252\t  /** Batch-fetch the latest operator event per PDA for a given event type. */\n253\t  getLatestOperatorEventsForPdas(\n254\t    pdas: string[],\n255\t    eventType: OperatorEventType,\n256\t  ): Promise<Map<string, OperatorEvent>>;\n257\t\n258\t  /** Get recently settled rounds for a game, ordered newest first. */\n259\t  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n260\t\n261\t  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n262\t  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n263\t\n264\t  // -------------------------------------------------------------------------\n265\t  // Close Call rounds\n266\t  // -------------------------------------------------------------------------\n267\t\n268\t  /** Insert a new Close Call round. */\n269\t  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n270\t\n271\t  /** Get a Close Call round by round_id (16-char hex). */\n272\t  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n273\t\n274\t  /** Get the current active (open) Close Call round. */\n275\t  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n276\t\n277\t  /** Get the most recent settled/refunded Close Call rounds. */\n278\t  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n279\t\n280\t  /** Update a Close Call round after settlement. */\n281\t  settleCloseCallRound(\n282\t    roundId: string,\n283\t    updates: {\n284\t      phase: CloseCallPhase;\n285\t      outcome: CloseCallOutcome;\n286\t      closePrice?: number;\n287\t      greenPool?: number;\n288\t      redPool?: number;\n289\t      totalFee?: number;\n290\t      greenEntries?: Array<{ player: string; amountLamports: number }>;\n291\t      redEntries?: Array<{ player: string; amountLamports: number }>;\n292\t      settleTx?: string;\n293\t    },\n294\t  ): Promise<CloseCallRound>;\n295\t\n296\t  // -------------------------------------------------------------------------\n297\t  // Transactions\n298\t  // -------------------------------------------------------------------------\n299\t\n300\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n301\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n302\t\n303\t  /** Insert multiple transactions in a single batch. */\n304\t  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n305\t\n306\t  /** Get paginated transactions for a wallet, newest first. */\n307\t  getTransactions(\n308\t    wallet: string,\n309\t    cursor?: string,\n310\t    limit?: number,\n311\t    game?: string,\n312\t  ): Promise<Transaction[]>;\n313\t\n314\t  // -------------------------------------------------------------------------\n315\t  // Referral — codes\n316\t  // -------------------------------------------------------------------------\n317\t\n318\t  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n319\t  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n320\t\n321\t  /** Get a wallet's referral code. Returns `undefined` if none set. */\n322\t  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n323\t\n324\t  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n325\t  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n326\t\n327\t  // -------------------------------------------------------------------------\n328\t  // Referral — links\n329\t  // -------------------------------------------------------------------------\n330\t\n331\t  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n332\t  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n333\t\n334\t  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n335\t  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n336\t\n337\t  /** Get all referral links where the given wallet is the referrer. */\n338\t  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n339\t\n340\t  // -------------------------------------------------------------------------\n341\t  // Referral — earnings & stats\n342\t  // -------------------------------------------------------------------------\n343\t\n344\t  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n345\t  insertReferralEarning(params: {\n346\t    referrerWallet: string;\n347\t    refereeWallet: string;\n348\t    roundId: string;\n349\t    gameType: string;\n350\t    wagerLamports: number;\n351\t    feeLamports: number;\n352\t    referrerEarnedLamports: number;\n353\t    referrerRateBps: number;\n354\t    refereeRebateLamports: number;\n355\t    refereeRebateRateBps: number;\n356\t  }): Promise<ReferralEarning>;\n357\t\n358\t  /**\n359\t   * Get the pending (unclaimed) balance for a wallet.\n360\t   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n361\t   * wallet=referee, minus sum of completed claims for the wallet.\n362\t   * Returns a lamport string.\n363\t   */\n364\t  getPendingBalance(wallet: string): Promise<string>;\n365\t\n366\t  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n367\t  getReferralEarnings(\n368\t    wallet: string,\n369\t    page: number,\n370\t    limit: number,\n371\t  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n372\t\n373\t  /** Get referral summary stats for a wallet. */\n374\t  getReferralStats(wallet: string): Promise<ReferralStats>;\n375\t\n376\t  // -------------------------------------------------------------------------\n377\t  // Referral — claims & rates\n378\t  // -------------------------------------------------------------------------\n379\t\n380\t  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n381\t  insertReferralClaim(\n382\t    wallet: string,\n383\t    amountLamports: string,\n384\t  ): Promise<ReferralClaim>;\n385\t\n386\t  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n387\t  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n388\t\n389\t  /**\n390\t   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n391\t   * Returns the updated claim.\n392\t   */\n393\t  updateClaimStatus(\n394\t    claimId: string,\n395\t    status: ReferralClaim[\"status\"],\n396\t    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n397\t  ): Promise<ReferralClaim>;\n398\t\n399\t  /**\n400\t   * Get the effective referrer rate for a wallet in bps.\n401\t   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n402\t   */\n403\t  getReferrerRate(\n404\t    wallet: string,\n405\t    defaultRateBps: number,\n406\t  ): Promise<number>;\n407\t\n408\t  /**\n409\t   * Execute a function within a database transaction.\n410\t   * All db methods called on the transactional Db share the same transaction.\n411\t   * Rolls back on error, commits on success.\n412\t   */\n413\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n414\t\n415\t  /** Gracefully close the connection pool. */\n416\t  close(): Promise<void>;\n417\t}\n418\t\n419\tfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n420\t  return {\n421\t    ...row,\n422\t    open_price: Number(row.open_price),\n423\t    open_price_expo: Number(row.open_price_expo),\n424\t    close_price: row.close_price === null ? null : Number(row.close_price),\n425\t    green_pool: Number(row.green_pool),\n426\t    red_pool: Number(row.red_pool),\n427\t    total_fee: Number(row.total_fee),\n428\t    // JSONB comes back as parsed objects from postgres.js\n429\t    green_entries: Array.isArray(row.green_entries)\n430\t      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n431\t      : [],\n432\t    red_entries: Array.isArray(row.red_entries)\n433\t      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n434\t      : [],\n435\t  };\n436\t}\n437\t\n438\tfunction normalizeTransaction(row: Transaction): Transaction {\n439\t  return {\n440\t    ...row,\n441\t    amount_lamports: Number(row.amount_lamports),\n442\t  };\n443\t}\n444\t\n445\tfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n446\t  return {\n447\t    ...row,\n448\t    wager_lamports: Number(row.wager_lamports),\n449\t    fee_lamports: Number(row.fee_lamports),\n450\t    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n451\t    referrer_rate_bps: Number(row.referrer_rate_bps),\n452\t    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n453\t    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n454\t  };\n455\t}\n456\t\n457\tfunction normalizeRound(row: Round): Round {\n458\t  return {\n459\t    ...row,\n460\t    amount_lamports: Number(row.amount_lamports),\n461\t    side: Number(row.side),\n462\t    settle_attempts: Number(row.settle_attempts),\n463\t    result_side: row.result_side === null ? null : Number(row.result_side),\n464\t    // JSONB comes back as parsed objects from postgres.js\n465\t    entries: Array.isArray(row.entries)\n466\t      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n467\t          player: e.player,\n468\t          amountLamports: Number(e.amountLamports),\n469\t        }))\n470\t      : null,\n471\t  };\n472\t}\n473\t\n474\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n475\texport function createDb(databaseUrl: string, _txSql?: any): Db {\n476\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n477\t  const sql: any = _txSql ?? postgres(databaseUrl);\n478\t  const _isOwner = !_txSql;\n479\t\n480\t  return {\n481\t    async insertRound(params) {\n482\t      const rows = await sql<Round[]>`\n483\t        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n484\t        VALUES (\n485\t          ${params.pda},\n486\t          ${params.game},\n487\t          ${params.creator},\n488\t          ${params.serverKey},\n489\t          ${params.secret},\n490\t          ${params.commitment},\n491\t          ${params.amountLamports},\n492\t          ${params.side},\n493\t          ${params.matchId},\n494\t          ${params.phase},\n495\t          ${params.entries ? sql.json(params.entries) : null}\n496\t        )\n497\t        RETURNING *\n498\t      `;\n499\t      return normalizeRound(rows[0]!);\n500\t    },\n501\t\n502\t    async deleteRoundByPda(pda) {\n503\t      const rows = await sql<{ pda: string }[]>`\n504\t        DELETE FROM rounds WHERE pda = ${pda}\n505\t        RETURNING pda\n506\t      `;\n507\t      return rows.length > 0;\n508\t    },\n509\t\n510\t    async updateRoundPhase(pda, newPhase, updates) {\n511\t      // Fetch current phase to validate transition\n512\t      const current = await sql<Pick<Round, \"phase\">[]>`\n513\t        SELECT phase FROM rounds WHERE pda = ${pda}\n514\t      `;\n515\t\n516\t      if (current.length === 0) {\n517\t        throw new Error(`Round not found: ${pda}`);\n518\t      }\n519\t\n520\t      const currentPhase = current[0]!.phase as RoundPhase;\n521\t      assertPhaseTransition(currentPhase, newPhase);\n522\t\n523\t      // Build the update — always set phase + updated_at\n524\t      const rows = await sql<Round[]>`\n525\t        UPDATE rounds SET\n526\t          phase = ${newPhase},\n527\t          updated_at = now(),\n528\t          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n529\t          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n530\t          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n531\t          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n532\t          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n533\t          winner = COALESCE(${updates?.winner ?? null}, winner)\n534\t        WHERE pda = ${pda}\n535\t        RETURNING *\n536\t      `;\n537\t\n538\t      return normalizeRound(rows[0]!);\n539\t    },\n540\t\n541\t    async updateRoundEntries(pda, entries) {\n542\t      const rows = await sql<Round[]>`\n543\t        UPDATE rounds SET\n544\t          entries = ${sql.json(entries)},\n545\t          updated_at = now()\n546\t        WHERE pda = ${pda}\n547\t        RETURNING *\n548\t      `;\n549\t      if (rows.length === 0) {\n550\t        throw new Error(`Round not found: ${pda}`);\n551\t      }\n552\t      return normalizeRound(rows[0]!);\n553\t    },\n554\t\n555\t    async getRoundByPda(pda) {\n556\t      const rows = await sql<Round[]>`\n557\t        SELECT * FROM rounds WHERE pda = ${pda}\n558\t      `;\n559\t      return rows[0] ? normalizeRound(rows[0]) : undefined;\n560\t    },\n561\t\n562\t    async getRoundByMatchId(matchId) {\n563\t      const rows = await sql<Round[]>`\n564\t        SELECT * FROM rounds WHERE match_id = ${matchId}\n565\t      `;\n566\t      return rows[0] ? normalizeRound(rows[0]) : undefined;\n567\t    },\n568\t\n569\t    async getRoundsByPhase(phase) {\n570\t      const rows = await sql<Round[]>`\n571\t        SELECT * FROM rounds WHERE phase = ${phase}\n572\t      `;\n573\t      return rows.map(normalizeRound);\n574\t    },\n575\t\n576\t    async insertOperatorEvent(pda, eventType, payload) {\n577\t      const rows = await sql<OperatorEvent[]>`\n578\t        INSERT INTO operator_events (pda, event_type, payload)\n579\t        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n580\t        RETURNING *\n581\t      `;\n582\t      return rows[0]!;\n583\t    },\n584\t\n585\t    async getLatestOperatorEvent(pda, eventType) {\n586\t      const rows = await sql<OperatorEvent[]>`\n587\t        SELECT * FROM operator_events\n588\t        WHERE pda = ${pda} AND event_type = ${eventType}\n589\t        ORDER BY id DESC\n590\t        LIMIT 1\n591\t      `;\n592\t      return rows[0];\n593\t    },\n594\t\n595\t    async getLatestOperatorEventsForPdas(pdas, eventType) {\n596\t      if (pdas.length === 0) return new Map();\n597\t      const rows = await sql<OperatorEvent[]>`\n598\t        SELECT DISTINCT ON (pda) *\n599\t        FROM operator_events\n600\t        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n601\t        ORDER BY pda, id DESC\n602\t      `;\n603\t      const map = new Map<string, OperatorEvent>();\n604\t      for (const row of rows) {\n605\t        if (row.pda) map.set(row.pda, row);\n606\t      }\n607\t      return map;\n608\t    },\n609\t\n610\t    async getRecentSettledRounds(game, limit) {\n611\t      const rows = await sql<Round[]>`\n612\t        SELECT * FROM rounds\n613\t        WHERE game = ${game} AND phase = 'settled'\n614\t        ORDER BY updated_at DESC\n615\t        LIMIT ${limit}\n616\t      `;\n617\t      return rows.map(normalizeRound);\n618\t    },\n619\t\n620\t    async getUnsettledStats() {\n621\t      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n622\t        SELECT\n623\t          COUNT(*)::text AS count,\n624\t          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n625\t        FROM rounds\n626\t        WHERE phase NOT IN ('settled', 'expired')\n627\t      `;\n628\t      const row = rows[0]!;\n629\t      return {\n630\t        count: parseInt(row.count, 10),\n631\t        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n632\t      };\n633\t    },\n634\t\n635\t    // -----------------------------------------------------------------------\n636\t    // Close Call rounds\n637\t    // -----------------------------------------------------------------------\n638\t\n639\t    async insertCloseCallRound(params) {\n640\t      const rows = await sql<CloseCallRound[]>`\n641\t        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n642\t        VALUES (\n643\t          ${params.roundId},\n644\t          ${params.pda},\n645\t          ${params.serverKey},\n646\t          ${params.openPrice},\n647\t          ${params.openPriceExpo}\n648\t        )\n649\t        RETURNING *\n650\t      `;\n651\t      return normalizeCloseCallRound(rows[0]!);\n652\t    },\n653\t\n654\t    async getCloseCallRound(roundId) {\n655\t      const rows = await sql<CloseCallRound[]>`\n656\t        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n657\t      `;\n658\t      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n659\t    },\n660\t\n661\t    async getCloseCallCurrentRound() {\n662\t      const rows = await sql<CloseCallRound[]>`\n663\t        SELECT * FROM closecall_rounds\n664\t        WHERE phase = 'open'\n665\t        ORDER BY created_at DESC\n666\t        LIMIT 1\n667\t      `;\n668\t      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n669\t    },\n670\t\n671\t    async getCloseCallHistory(limit) {\n672\t      const rows = await sql<CloseCallRound[]>`\n673\t        SELECT * FROM closecall_rounds\n674\t        WHERE phase IN ('settled', 'refunded')\n675\t        ORDER BY settled_at DESC\n676\t        LIMIT ${limit}\n677\t      `;\n678\t      return rows.map(normalizeCloseCallRound);\n679\t    },\n680\t\n681\t    async settleCloseCallRound(roundId, updates) {\n682\t      const rows = await sql<CloseCallRound[]>`\n683\t        UPDATE closecall_rounds SET\n684\t          phase = ${updates.phase},\n685\t          outcome = ${updates.outcome},\n686\t          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n687\t          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n688\t          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n689\t          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n690\t          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n691\t          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n692\t          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n693\t          settled_at = now()\n694\t        WHERE round_id = ${roundId}\n695\t        RETURNING *\n696\t      `;\n697\t      if (rows.length === 0) {\n698\t        throw new Error(`Close Call round not found: ${roundId}`);\n699\t      }\n700\t      return normalizeCloseCallRound(rows[0]!);\n701\t    },\n702\t\n703\t    // -----------------------------------------------------------------------\n704\t    // Transactions\n705\t    // -----------------------------------------------------------------------\n706\t\n707\t    async insertTransaction(params) {\n708\t      await sql`\n709\t        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n710\t        VALUES (\n711\t          ${params.wallet},\n712\t          ${params.game},\n713\t          ${params.matchId},\n714\t          ${params.txType},\n715\t          ${params.amountLamports},\n716\t          ${params.txSig}\n717\t        )\n718\t        ON CONFLICT DO NOTHING\n719\t      `;\n720\t    },\n721\t\n722\t    async insertTransactions(params) {\n723\t      if (params.length === 0) return;\n724\t      const values = params.map((p) => ({\n725\t        wallet: p.wallet,\n726\t        game: p.game,\n727\t        match_id: p.matchId,\n728\t        tx_type: p.txType,\n729\t        amount_lamports: p.amountLamports,\n730\t        tx_sig: p.txSig,\n731\t      }));\n732\t      await sql`\n733\t        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n734\t        ON CONFLICT DO NOTHING\n735\t      `;\n736\t    },\n737\t\n738\t    async getTransactions(wallet, cursor, limit = 20, game) {\n739\t      const effectiveLimit = Math.min(limit, 50);\n740\t      if (cursor && game) {\n741\t        const rows = await sql<Transaction[]>`\n742\t          SELECT * FROM transactions\n743\t          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n744\t          ORDER BY id DESC\n745\t          LIMIT ${effectiveLimit}\n746\t        `;\n747\t        return rows.map(normalizeTransaction);\n748\t      }\n749\t      if (cursor) {\n750\t        const rows = await sql<Transaction[]>`\n751\t          SELECT * FROM transactions\n752\t          WHERE wallet = ${wallet} AND id < ${cursor}\n753\t          ORDER BY id DESC\n754\t          LIMIT ${effectiveLimit}\n755\t        `;\n756\t        return rows.map(normalizeTransaction);\n757\t      }\n758\t      if (game) {\n759\t        const rows = await sql<Transaction[]>`\n760\t          SELECT * FROM transactions\n761\t          WHERE wallet = ${wallet} AND game = ${game}\n762\t          ORDER BY id DESC\n763\t          LIMIT ${effectiveLimit}\n764\t        `;\n765\t        return rows.map(normalizeTransaction);\n766\t      }\n767\t      const rows = await sql<Transaction[]>`\n768\t        SELECT * FROM transactions\n769\t        WHERE wallet = ${wallet}\n770\t        ORDER BY id DESC\n771\t        LIMIT ${effectiveLimit}\n772\t      `;\n773\t      return rows.map(normalizeTransaction);\n774\t    },\n775\t\n776\t    // -----------------------------------------------------------------------\n777\t    // Referral — codes\n778\t    // -----------------------------------------------------------------------\n779\t\n780\t    async insertReferralCode(wallet, code) {\n781\t      const rows = await sql<ReferralCode[]>`\n782\t        INSERT INTO referral_codes (wallet, code)\n783\t        VALUES (${wallet}, ${code})\n784\t        RETURNING *\n785\t      `;\n786\t      return rows[0]!;\n787\t    },\n788\t\n789\t    async getReferralCodeByWallet(wallet) {\n790\t      const rows = await sql<ReferralCode[]>`\n791\t        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n792\t      `;\n793\t      return rows[0];\n794\t    },\n795\t\n796\t    async getReferralCodeByCode(code) {\n797\t      const rows = await sql<ReferralCode[]>`\n798\t        SELECT * FROM referral_codes WHERE code = ${code}\n799\t      `;\n800\t      return rows[0];\n801\t    },\n802\t\n803\t    // -- Referral links -------------------------------------------------------\n804\t\n805\t    async insertReferralLink(referrerWallet, refereeWallet) {\n806\t      const rows = await sql<ReferralLink[]>`\n807\t        INSERT INTO referral_links (referrer_wallet, referee_wallet)\n808\t        VALUES (${referrerWallet}, ${refereeWallet})\n809\t        RETURNING *\n810\t      `;\n811\t      return rows[0]!;\n812\t    },\n813\t\n814\t    async getReferralLinkByReferee(refereeWallet) {\n815\t      const rows = await sql<ReferralLink[]>`\n816\t        SELECT * FROM referral_links WHERE referee_wallet = ${refereeWallet}\n817\t      `;\n818\t      return rows[0];\n819\t    },\n820\t\n821\t    async getReferralLinksByReferrer(referrerWallet) {\n822\t      const rows = await sql<ReferralLink[]>`\n823\t        SELECT * FROM referral_links WHERE referrer_wallet = ${referrerWallet}\n824\t        ORDER BY created_at DESC\n825\t      `;\n826\t      return rows;\n827\t    },\n828\t\n829\t    // -- Referral earnings & stats --------------------------------------------\n830\t\n831\t    async insertReferralEarning(params) {\n832\t      const rows = await sql<ReferralEarning[]>`\n833\t        INSERT INTO referral_earnings (\n834\t          referrer_wallet, referee_wallet, round_id, game_type,\n835\t          wager_lamports, fee_lamports,\n836\t          referrer_earned_lamports, referrer_rate_bps,\n837\t          referee_rebate_lamports, referee_rebate_rate_bps\n838\t        ) VALUES (\n839\t          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n840\t          ${params.wagerLamports}, ${params.feeLamports},\n841\t          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n842\t          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n843\t        )\n844\t        RETURNING *\n845\t      `;\n846\t      return normalizeReferralEarning(rows[0]!);\n847\t    },\n848\t\n849\t    async getPendingBalance(wallet) {\n850\t      const rows = await sql<{ pending: string }[]>`\n851\t        SELECT COALESCE(\n852\t          (\n853\t            SELECT SUM(referrer_earned_lamports)\n854\t            FROM referral_earnings WHERE referrer_wallet = ${wallet}\n855\t          ), 0\n856\t        ) + COALESCE(\n857\t          (\n858\t            SELECT SUM(referee_rebate_lamports)\n859\t            FROM referral_earnings WHERE referee_wallet = ${wallet}\n860\t          ), 0\n861\t        ) - COALESCE(\n862\t          (\n863\t            SELECT SUM(amount_lamports)\n864\t            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'error', 'completed')\n865\t          ), 0\n866\t        ) AS pending\n867\t      `;\n868\t      return rows[0]!.pending;\n869\t    },\n870\t\n871\t    async getReferralEarnings(wallet, page, limit) {\n872\t      const offset = (page - 1) * limit;\n873\t      const [countRows, rows] = await Promise.all([\n874\t        sql<{ count: string }[]>`\n875\t          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n876\t          WHERE referrer_wallet = ${wallet}\n877\t        `,\n878\t        sql<ReferralEarning[]>`\n879\t          SELECT * FROM referral_earnings\n880\t          WHERE referrer_wallet = ${wallet}\n881\t          ORDER BY created_at DESC\n882\t          LIMIT ${limit} OFFSET ${offset}\n883\t        `,\n884\t      ]);\n885\t      const total = Number(countRows[0]!.count);\n886\t      const totalPages = Math.max(1, Math.ceil(total / limit));\n887\t      return { items: rows.map(normalizeReferralEarning), totalPages };\n888\t    },\n889\t\n890\t    async getReferralStats(wallet) {\n891\t      const rows = await sql<ReferralStats[]>`\n892\t        SELECT\n893\t          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n894\t            AS referred_count,\n895\t          (\n896\t            SELECT COUNT(DISTINCT re.referee_wallet)\n897\t            FROM referral_earnings re\n898\t            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n899\t            WHERE re.created_at > now() - INTERVAL '7 days'\n900\t          )::INT AS active_count,\n901\t          COALESCE(\n902\t            (\n903\t              SELECT SUM(re.wager_lamports)::TEXT\n904\t              FROM referral_earnings re\n905\t              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n906\t            ), '0'\n907\t          ) AS total_volume_lamports,\n908\t          COALESCE(\n909\t            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_wallet = ${wallet}),\n910\t            '0'\n911\t          ) AS total_earned_lamports,\n912\t          COALESCE(\n913\t            (SELECT SUM(referee_rebate_lamports)::TEXT FROM referral_earnings WHERE referee_wallet = ${wallet}),\n914\t            '0'\n915\t          ) AS total_rebate_lamports,\n916\t          (\n917\t            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_wallet = ${wallet}), 0)\n918\t            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_wallet = ${wallet}), 0)\n919\t            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending','processing','error','completed')), 0)\n920\t          )::TEXT AS pending_lamports\n921\t      `;\n922\t      return rows[0]!;\n923\t    },\n924\t\n925\t    // -----------------------------------------------------------------------\n926\t    // Referral — claims & rates\n927\t    // -----------------------------------------------------------------------\n928\t\n929\t    async insertReferralClaim(wallet, amountLamports) {\n930\t      const rows = await sql<ReferralClaim[]>`\n931\t        INSERT INTO referral_claims (wallet, amount_lamports, status)\n932\t        VALUES (${wallet}, ${amountLamports}, 'pending')\n933\t        RETURNING *\n934\t      `;\n935\t      return rows[0]!;\n936\t    },\n937\t\n938\t    async getReferralClaim(claimId) {\n939\t      const rows = await sql<ReferralClaim[]>`\n940\t        SELECT * FROM referral_claims WHERE id = ${claimId}\n941\t      `;\n942\t      return rows[0];\n943\t    },\n944\t\n945\t    async updateClaimStatus(claimId, status, meta) {\n946\t      const rows = await sql<ReferralClaim[]>`\n947\t        UPDATE referral_claims\n948\t        SET\n949\t          status = ${status},\n950\t          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n951\t          error = COALESCE(${meta?.error ?? null}, error),\n952\t          retry_count = ${meta?.incrementRetry ? sql`retry_count + 1` : sql`retry_count`},\n953\t          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n954\t        WHERE id = ${claimId}\n955\t        RETURNING *\n956\t      `;\n957\t      return rows[0]!;\n958\t    },\n959\t\n960\t    async getReferrerRate(wallet, defaultRateBps) {\n961\t      const rows = await sql<{ rate_bps: number }[]>`\n962\t        SELECT rate_bps FROM referral_kol_rates WHERE wallet = ${wallet}\n963\t      `;\n964\t      return rows[0]?.rate_bps ?? defaultRateBps;\n965\t    },\n966\t\n967\t    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n968\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n969\t      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n970\t    },\n971\t\n972\t    async close() {\n973\t      if (_isOwner) await sql.end();\n974\t    },\n975\t  };\n976\t}\n977\t"}]},"parent_tool_use_id":"toolu_01RoFYvWECRNhCTf6UXtUYrP","session_id":"aa94e491-d3b8-48ec-9244-f434c72362a9","uuid":"be00943c-6af2-46a3-9e06-43c4f4998b5d","timestamp":"2026-03-31T14:03:39.345Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YCHUtsnHcogkYKpoBVXpm4","type":"tool_result","content":"1\texport const DEFAULT_DB_SCHEMA = \"public\";\n2\t\n3\tfunction normalizeSchema(schema: string): string {\n4\t  return schema.trim() || DEFAULT_DB_SCHEMA;\n5\t}\n6\t\n7\texport function loadDbSchemaFromEnv(\n8\t  env: Record<string, string | undefined> = process.env,\n9\t): string {\n10\t  return normalizeSchema(env.DB_SCHEMA ?? DEFAULT_DB_SCHEMA);\n11\t}\n12\t\n13\texport function applyDbSchemaToUrl(databaseUrl: string, schema: string): string {\n14\t  const normalizedSchema = normalizeSchema(schema);\n15\t  if (normalizedSchema === DEFAULT_DB_SCHEMA) {\n16\t    return databaseUrl;\n17\t  }\n18\t\n19\t  const url = new URL(databaseUrl);\n20\t  const existingOptions = url.searchParams.get(\"options\");\n21\t  const searchPathOption = `-csearch_path=${normalizedSchema}`;\n22\t\n23\t  if (existingOptions) {\n24\t    const hasSearchPath = existingOptions.includes(\"search_path=\");\n25\t    url.searchParams.set(\n26\t      \"options\",\n27\t      hasSearchPath\n28\t        ? existingOptions.replace(/-csearch_path=[^\\s]+/, searchPathOption)\n29\t        : `${existingOptions} ${searchPathOption}`,\n30\t    );\n31\t  } else {\n32\t    url.searchParams.set(\"options\", searchPathOption);\n33\t  }\n34\t\n35\t  return url.toString();\n36\t}\n37\t"}]},"parent_tool_use_id":"toolu_01RoFYvWECRNhCTf6UXtUYrP","session_id":"aa94e491-d3b8-48ec-9244-f434c72362a9","uuid":"cf522e19-d37d-4a7b-9a5f-8fda7dd8232b","timestamp":"2026-03-31T14:03:39.382Z"}
