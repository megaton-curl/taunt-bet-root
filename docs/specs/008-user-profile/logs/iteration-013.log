{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fbfpb134NV8492Ajrxg4aA","type":"tool_result","content":"1\t-- 012_referral_claim_retry.sql — Referral claim retry support + concurrent claim guard.\n2\t--\n3\t-- Adds retry_count to track transient failures and an 'error' intermediate status.\n4\t-- Adds a partial unique index to prevent concurrent active claims per wallet.\n5\t\n6\t-- 1. Allow 'error' as a valid claim status (retryable transient failure)\n7\tALTER TABLE referral_claims\n8\t  DROP CONSTRAINT IF EXISTS chk_referral_claims_status;\n9\t\n10\tALTER TABLE referral_claims\n11\t  ADD CONSTRAINT chk_referral_claims_status\n12\t  CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed'));\n13\t\n14\t-- 2. Track how many times a claim has been retried\n15\tALTER TABLE referral_claims\n16\t  ADD COLUMN IF NOT EXISTS retry_count INTEGER NOT NULL DEFAULT 0;\n17\t\n18\t-- 3. Prevent concurrent active claims for the same wallet.\n19\t--    Only one claim can be in pending/processing/error at a time.\n20\tCREATE UNIQUE INDEX IF NOT EXISTS idx_referral_claims_wallet_active\n21\t  ON referral_claims (wallet) WHERE status IN ('pending', 'processing', 'error');\n22\t"}]},"parent_tool_use_id":"toolu_019HLGVgiX6XYMADSFy385JM","session_id":"aa94e491-d3b8-48ec-9244-f434c72362a9","uuid":"f5c92266-92d7-416d-86a9-9756093c1544","timestamp":"2026-03-31T14:03:42.015Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AyH7ijwHQrZvqNH13hxxvf","type":"tool_result","content":"1\t-- 008_user_transactions.sql — Player transaction history ledger.\n2\t--\n3\t-- One row per user-visible game event (join, win, loss, refund).\n4\t-- Used by the profile transactions API. Idempotent writes via\n5\t-- UNIQUE constraint on (wallet, match_id, event).\n6\t\n7\tCREATE TABLE IF NOT EXISTS user_transactions (\n8\t  id              BIGSERIAL    PRIMARY KEY,\n9\t  wallet          TEXT         NOT NULL,\n10\t  game            TEXT         NOT NULL,\n11\t  match_id        TEXT         NOT NULL,\n12\t  event           TEXT         NOT NULL,\n13\t  amount_lamports BIGINT       NOT NULL,\n14\t  tx_sig          TEXT,\n15\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n16\t);\n17\t\n18\t-- Paginated history by wallet\n19\tCREATE INDEX IF NOT EXISTS idx_user_tx_wallet_created\n20\t  ON user_transactions (wallet, created_at DESC);\n21\t\n22\t-- Dedup / lookup by match_id\n23\tCREATE INDEX IF NOT EXISTS idx_user_tx_match_id\n24\t  ON user_transactions (match_id);\n25\t\n26\t-- Idempotency guard — ON CONFLICT DO NOTHING target\n27\tALTER TABLE user_transactions\n28\t  ADD CONSTRAINT uq_user_tx_wallet_match_event\n29\t  UNIQUE (wallet, match_id, event);\n30\t"}]},"parent_tool_use_id":"toolu_019HLGVgiX6XYMADSFy385JM","session_id":"aa94e491-d3b8-48ec-9244-f434c72362a9","uuid":"4a802997-3e65-4838-92f7-3a4ae1db27e2","timestamp":"2026-03-31T14:03:42.031Z"}
