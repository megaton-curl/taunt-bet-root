ring;\n  amount_lamports: string;\n  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n  retry_count: number;\n  tx_signature: string | null;\n  error: string | null;\n  requested_at: Date;\n  processed_at: Date | null;\n}\n\n// ---------------------------------------------------------------------------\n// Player profile types\n// ---------------------------------------------------------------------------\n\nexport interface PlayerProfile {\n  id: number;\n  user_id: string;\n  wallet: string;\n  username: string;\n  username_updated_at: Date | null;\n  avatar_url: string | null;\n  heat_multiplier: number;\n  points_balance: number;\n  created_at: Date;\n}\n\nexport interface PlayerStats {\n  gamesPlayed: number;\n  totalWagered: bigint;\n  totalWins: number;\n  winRate: number;\n  netPnl: bigint;\n}\n\nexport interface PublicPlayerStats {\n  gamesPlayed: number;\n  totalWins: number;\n  winRate: number;\n}\n\nexport interface WinStreaks {\n  current: number;\n  best: number;\n}\n\nexport interface GameBreakdownStats {\n  gamesPlayed: number;\n  totalWagered: bigint;\n  totalWins: number;\n  winRate: number;\n  netPnl: bigint;\n}\n\n// ---------------------------------------------------------------------------\n// Phase transition guard\n// ---------------------------------------------------------------------------\n\n/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */","numLines":130,"startLine":100,"totalLines":1309}}}
