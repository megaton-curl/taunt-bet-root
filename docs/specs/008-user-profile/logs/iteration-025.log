{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ge9DEANBjiLLbfFerHD3e","type":"tool_result","content":"1205\t    async getGameBreakdown(wallet) {\n1206\t      const DB_TO_FRONTEND: Record<string, string> = {\n1207\t        coinflip: \"coinflip\",\n1208\t        lord: \"lord-of-rngs\",\n1209\t        closecall: \"close-call\",\n1210\t      };\n1211\t\n1212\t      const rows = await sql<\n1213\t        Array<{\n1214\t          game: string;\n1215\t          games_played: string;\n1216\t          total_wagered: string;\n1217\t          total_wins: string;\n1218\t          net_pnl: string;\n1219\t        }>\n1220\t      >`\n1221\t        SELECT\n1222\t          game,\n1223\t          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n1224\t          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n1225\t          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n1226\t          COALESCE(\n1227\t            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n1228\t                     WHEN tx_type = 'deposit' THEN -amount_lamports\n1229\t                     ELSE 0 END),\n1230\t            0\n1231\t          )::text AS net_pnl\n1232\t        FROM transactions\n1233\t        WHERE wallet = ${wallet}\n1234\t        GROUP BY game\n1235\t      `;\n1236\t\n1237\t      const result: Record<string, GameBreakdownStats> = {};\n1238\t      for (const row of rows) {\n1239\t        const gamesPlayed = Number(row.games_played);\n1240\t        if (gamesPlayed === 0) continue;\n1241\t        const totalWins = Number(row.total_wins);\n1242\t        const frontendName = DB_TO_FRONTEND[row.game] ?? row.game;\n1243\t        result[frontendName] = {\n1244\t          gamesPlayed,\n1245\t          totalWagered: BigInt(row.total_wagered),\n1246\t          totalWins,\n1247\t          winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n1248\t          netPnl: BigInt(row.net_pnl),\n1249\t        };\n1250\t      }\n1251\t      return result;\n1252\t    },\n1253\t\n1254\t    async getWinStreaks(wallet) {"}]},"parent_tool_use_id":"toolu_01PWHsaK556RDDh4b1wd7yam","session_id":"cd479181-9c0f-4c58-8b77-ba63a57dd2e1","uuid":"7fecb2f1-0f55-427b-a85f-eaba70ac5a2d","timestamp":"2026-03-31T15:26:44.133Z"}
