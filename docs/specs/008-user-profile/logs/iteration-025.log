n-- Dev phase — drop and recreate, no migration.\n\nDROP TABLE IF EXISTS user_transactions;\n\nCREATE TABLE IF NOT EXISTS transactions (\n  id              BIGSERIAL    PRIMARY KEY,\n  wallet          TEXT         NOT NULL,\n  game            TEXT         NOT NULL,\n  match_id        TEXT         NOT NULL,\n  tx_type         TEXT         NOT NULL,\n  amount_lamports BIGINT       NOT NULL,\n  tx_sig          TEXT         NOT NULL,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\n-- Paginated history by wallet (newest first)\nCREATE INDEX IF NOT EXISTS idx_tx_wallet_created\n  ON transactions (wallet, created_at DESC);\n\n-- Lookup by match_id\nCREATE INDEX IF NOT EXISTS idx_tx_match_id\n  ON transactions (match_id);\n\n-- Idempotency guard — same wallet + match + type + sig = duplicate\nCREATE UNIQUE INDEX IF NOT EXISTS uq_tx_wallet_match_type_sig\n  ON transactions (wallet, match_id, tx_type, tx_sig);\n","numLines":33,"startLine":1,"totalLines":33}}}
