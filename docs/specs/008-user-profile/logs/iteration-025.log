{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012bo6FMY5ERafLnbSY4hFvL","type":"tool_result","content":"1\t/**\n2\t * Auth routes tests: challenge → verify → refresh → logout flows.\n3\t */\n4\t\n5\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n6\timport { Hono } from \"hono\";\n7\timport { Keypair } from \"@solana/web3.js\";\n8\timport nacl from \"tweetnacl\";\n9\timport bs58 from \"bs58\";\n10\timport { jwtVerify } from \"jose\";\n11\timport postgres from \"postgres\";\n12\timport { createAuthDb, type AuthDb } from \"../auth-db.js\";\n13\timport { createAuthRoutes } from \"../routes/auth.js\";\n14\timport type { Db } from \"../db.js\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// Constants\n18\t// ---------------------------------------------------------------------------\n19\t\n20\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n21\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n22\t\n23\t// ---------------------------------------------------------------------------\n24\t// Test suite\n25\t// ---------------------------------------------------------------------------\n26\t\n27\tdescribe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n28\t  let rawSql: ReturnType<typeof postgres>;\n29\t  let authDb: AuthDb;\n30\t  let app: Hono;\n31\t  const stubDb = {\n32\t    getProfileByWallet: async () => null,\n33\t    createPlayerProfile: async () => ({} as any),\n34\t  } as unknown as Db;\n35\t\n36\t  const creatorKeypair = Keypair.generate();\n37\t\n38\t  beforeAll(async () => {\n39\t    rawSql = postgres(DATABASE_URL);\n40\t    // Ensure auth tables exist\n41\t    await rawSql`\n42\t      CREATE TABLE IF NOT EXISTS auth_challenges (\n43\t        nonce TEXT PRIMARY KEY,\n44\t        wallet TEXT NOT NULL,\n45\t        cluster TEXT NOT NULL DEFAULT 'devnet',\n46\t        message TEXT NOT NULL,\n47\t        expires_at TIMESTAMPTZ NOT NULL,\n48\t        used BOOLEAN DEFAULT FALSE,\n49\t        created_at TIMESTAMPTZ DEFAULT now()\n50\t      )\n51\t    `;\n52\t    await rawSql`\n53\t      CREATE TABLE IF NOT EXISTS refresh_tokens (\n54\t        id BIGSERIAL PRIMARY KEY,\n55\t        wallet TEXT NOT NULL,\n56\t        token_hash BYTEA NOT NULL UNIQUE,\n57\t        family_id TEXT NOT NULL,\n58\t        expires_at TIMESTAMPTZ NOT NULL,\n59\t        revoked BOOLEAN DEFAULT FALSE,\n60\t        created_at TIMESTAMPTZ DEFAULT now()\n61\t      )\n62\t    `;\n63\t  });\n64\t\n65\t  afterAll(async () => {\n66\t    await rawSql.end();\n67\t  });\n68\t\n69\t  beforeEach(async () => {\n70\t    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n71\t    authDb = createAuthDb(rawSql);\n72\t    app = new Hono();\n73\t    app.route(\n74\t      \"/auth\",\n75\t      createAuthRoutes({\n76\t        authDb,\n77\t        db: stubDb,\n78\t        jwtSecret: JWT_SECRET,\n79\t        cluster: \"devnet\",\n80\t        challengeTtlSeconds: 300,\n81\t        accessTokenTtlSeconds: 3600,\n82\t        refreshTokenTtlDays: 14,\n83\t      }),\n84\t    );\n85\t  });\n86\t\n87\t  // -----------------------------------------------------------------------\n88\t  // POST /auth/challenge\n89\t  // -----------------------------------------------------------------------\n90\t"}]},"parent_tool_use_id":null,"session_id":"cd479181-9c0f-4c58-8b77-ba63a57dd2e1","uuid":"5e38fb57-57ec-420c-8187-7d5c65128c7c","timestamp":"2026-03-31T15:27:17.356Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/auth-routes.test.ts","content":"/**\n * Auth routes tests: challenge → verify → refresh → logout flows.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { jwtVerify } from \"jose\";\nimport postgres from \"postgres\";\nimport { createAuthDb, type AuthDb } from \"../auth-db.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport type { Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let authDb: AuthDb;\n  let app: Hono;\n  const stubDb = {\n    getProfileByWallet: async () => null,\n    createPlayerProfile: async () => ({} as any),\n  } as unknown as Db;\n\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = postgres(DATABASE_URL);\n    // Ensure auth tables exist\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    authDb = createAuthDb(rawSql);\n    app = new Hono();\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        db: stubDb,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /auth/challenge\n  // -----------------------------------------------------------------------\n","numLines":90,"startLine":1,"totalLines":304}}}
