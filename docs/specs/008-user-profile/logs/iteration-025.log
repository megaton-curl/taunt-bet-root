{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EMokR384vRmBvxURPYhyQx","type":"tool_result","content":"480\t   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n481\t   */\n482\t  getPlayerStats(wallet: string): Promise<PlayerStats>;\n483\t\n484\t  /**\n485\t   * Get public-safe subset of player stats (no wagered, no PnL).\n486\t   */\n487\t  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n488\t\n489\t  /**\n490\t   * Compute per-game aggregate stats from the transactions table.\n491\t   * Returns a record keyed by frontend game name (coinflip, lord-of-rngs, close-call).\n492\t   * Games with zero activity are omitted.\n493\t   */\n494\t  getGameBreakdown(wallet: string): Promise<Record<string, GameBreakdownStats>>;\n495\t\n496\t  /**\n497\t   * Compute win streaks from the transactions table.\n498\t   * Returns current (consecutive wins from most recent) and best (longest ever).\n499\t   * Refund-only matches are excluded from streak calculation.\n500\t   */\n501\t  getWinStreaks(wallet: string): Promise<WinStreaks>;\n502\t\n503\t  /**\n504\t   * Execute a function within a database transaction.\n505\t   * All db methods called on the transactional Db share the same transaction.\n506\t   * Rolls back on error, commits on success.\n507\t   */\n508\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n509\t"}]},"parent_tool_use_id":"toolu_01PWHsaK556RDDh4b1wd7yam","session_id":"cd479181-9c0f-4c58-8b77-ba63a57dd2e1","uuid":"f694f6d7-7d64-465f-a824-a090d9651f56","timestamp":"2026-03-31T15:26:52.775Z"}
