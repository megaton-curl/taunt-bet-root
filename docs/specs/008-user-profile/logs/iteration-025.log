{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wxhp5n5uDmGvR14rEVMT2x","type":"tool_result","content":"1162\t    async getPlayerStats(wallet) {\n1163\t      const rows = await sql<\n1164\t        Array<{\n1165\t          games_played: string;\n1166\t          total_wagered: string;\n1167\t          total_wins: string;\n1168\t          net_pnl: string;\n1169\t        }>\n1170\t      >`\n1171\t        SELECT\n1172\t          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n1173\t          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n1174\t          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n1175\t          COALESCE(\n1176\t            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n1177\t                     WHEN tx_type = 'deposit' THEN -amount_lamports\n1178\t                     ELSE 0 END),\n1179\t            0\n1180\t          )::text AS net_pnl\n1181\t        FROM transactions\n1182\t        WHERE wallet = ${wallet}\n1183\t      `;\n1184\t      const row = rows[0]!;\n1185\t      const gamesPlayed = Number(row.games_played);\n1186\t      const totalWins = Number(row.total_wins);\n1187\t      return {\n1188\t        gamesPlayed,\n1189\t        totalWagered: BigInt(row.total_wagered),\n1190\t        totalWins,\n1191\t        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n1192\t        netPnl: BigInt(row.net_pnl),\n1193\t      };\n1194\t    },\n1195\t\n1196\t    async getPublicPlayerStats(wallet) {"}]},"parent_tool_use_id":"toolu_01PWHsaK556RDDh4b1wd7yam","session_id":"cd479181-9c0f-4c58-8b77-ba63a57dd2e1","uuid":"6bfebcfc-8e37-4c96-a7f7-f1c6f678a4de","timestamp":"2026-03-31T15:26:43.437Z"}
