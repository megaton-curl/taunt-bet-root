{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cg9wTCKDWwhPc7G9ZsH9Es","type":"tool_result","content":"1\t-- 008_user_transactions.sql — Player transaction history ledger.\n2\t--\n3\t-- One row per user-visible game event (join, win, loss, refund).\n4\t-- Used by the profile transactions API. Idempotent writes via\n5\t-- UNIQUE constraint on (wallet, match_id, event).\n6\t\n7\tCREATE TABLE IF NOT EXISTS user_transactions (\n8\t  id              BIGSERIAL    PRIMARY KEY,\n9\t  wallet          TEXT         NOT NULL,\n10\t  game            TEXT         NOT NULL,\n11\t  match_id        TEXT         NOT NULL,\n12\t  event           TEXT         NOT NULL,\n13\t  amount_lamports BIGINT       NOT NULL,\n14\t  tx_sig          TEXT,\n15\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n16\t);\n17\t\n18\t-- Paginated history by wallet\n19\tCREATE INDEX IF NOT EXISTS idx_user_tx_wallet_created\n20\t  ON user_transactions (wallet, created_at DESC);\n21\t\n22\t-- Dedup / lookup by match_id\n23\tCREATE INDEX IF NOT EXISTS idx_user_tx_match_id\n24\t  ON user_transactions (match_id);\n25\t\n26\t-- Idempotency guard — ON CONFLICT DO NOTHING target\n27\tALTER TABLE user_transactions\n28\t  ADD CONSTRAINT uq_user_tx_wallet_match_event\n29\t  UNIQUE (wallet, match_id, event);\n30\t"}]},"parent_tool_use_id":null,"session_id":"cd479181-9c0f-4c58-8b77-ba63a57dd2e1","uuid":"869efb77-923e-423b-b0d0-b29e3d8417ab","timestamp":"2026-03-31T15:27:26.846Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/migrations/008_user_transactions.sql","content":"-- 008_user_transactions.sql — Player transaction history ledger.\n--\n-- One row per user-visible game event (join, win, loss, refund).\n-- Used by the profile transactions API. Idempotent writes via\n-- UNIQUE constraint on (wallet, match_id, event).\n\nCREATE TABLE IF NOT EXISTS user_transactions (\n  id              BIGSERIAL    PRIMARY KEY,\n  wallet          TEXT         NOT NULL,\n  game            TEXT         NOT NULL,\n  match_id        TEXT         NOT NULL,\n  event           TEXT         NOT NULL,\n  amount_lamports BIGINT       NOT NULL,\n  tx_sig          TEXT,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\n-- Paginated history by wallet\nCREATE INDEX IF NOT EXISTS idx_user_tx_wallet_created\n  ON user_transactions (wallet, created_at DESC);\n\n-- Dedup / lookup by match_id\nCREATE INDEX IF NOT EXISTS idx_user_tx_match_id\n  ON user_transactions (match_id);\n\n-- Idempotency guard — ON CONFLICT DO NOTHING target\nALTER TABLE user_transactions\n  ADD CONSTRAINT uq_user_tx_wallet_match_event\n  UNIQUE (wallet, match_id, event);\n","numLines":30,"startLine":1,"totalLines":30}}}
