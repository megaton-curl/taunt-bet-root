{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cwh9PPgVG1HHVJeUuAKyhx","type":"tool_result","content":"1254\t    async getWinStreaks(wallet) {\n1255\t      // Get outcome per match ordered by most recent first.\n1256\t      // A match with a 'payout' row = win, 'deposit' without 'payout' = loss,\n1257\t      // only 'refund' = skip (excluded).\n1258\t      const rows = await sql<\n1259\t        Array<{ match_id: string; has_payout: boolean; has_deposit: boolean }>\n1260\t      >`\n1261\t        SELECT\n1262\t          match_id,\n1263\t          bool_or(tx_type = 'payout') AS has_payout,\n1264\t          bool_or(tx_type = 'deposit') AS has_deposit\n1265\t        FROM transactions\n1266\t        WHERE wallet = ${wallet}\n1267\t        GROUP BY match_id\n1268\t        HAVING bool_or(tx_type = 'deposit') OR bool_or(tx_type = 'payout')\n1269\t        ORDER BY MAX(created_at) DESC\n1270\t      `;\n1271\t\n1272\t      let current = 0;\n1273\t      let best = 0;\n1274\t      let streak = 0;\n1275\t      let currentSet = false;\n1276\t\n1277\t      for (const row of rows) {\n1278\t        // Skip refund-only matches (no deposit, no payout)\n1279\t        if (!row.has_deposit && !row.has_payout) continue;\n1280\t\n1281\t        const isWin = row.has_payout;\n1282\t        if (isWin) {\n1283\t          streak++;\n1284\t          if (streak > best) best = streak;\n1285\t        } else {\n1286\t          if (!currentSet) {\n1287\t            current = streak;\n1288\t            currentSet = true;\n1289\t          }\n1290\t          streak = 0;\n1291\t        }\n1292\t      }\n1293\t      // If we never hit a loss, current streak = total streak"}]},"parent_tool_use_id":"toolu_01PWHsaK556RDDh4b1wd7yam","session_id":"cd479181-9c0f-4c58-8b77-ba63a57dd2e1","uuid":"014d3535-b2cb-459a-a840-4adaeb959341","timestamp":"2026-03-31T15:26:44.477Z"}
