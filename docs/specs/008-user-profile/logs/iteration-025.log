{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01VhGWzcM72xjVtAQXZrJkyW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CDLTAypz1q2qPZRfvZ7K4Y","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/player-stats.test.ts","content":"/**\n * Unit tests for player stats + streaks DB functions.\n *\n * Requires a running PostgreSQL instance. Seeds the `transactions` table\n * with known rows and verifies getPlayerStats, getWinStreaks,\n * getGameBreakdown, and getPublicPlayerStats.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n\nconst WALLET = \"TestWallet_stats_\" + Date.now();\n\ndescribe(\"Player stats + streaks\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n\n  beforeAll(async () => {\n    rawSql = postgres(DATABASE_URL);\n    // Ensure transactions table exists\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS transactions (\n        id              BIGSERIAL    PRIMARY KEY,\n        wallet          TEXT         NOT NULL,\n        game            TEXT         NOT NULL,\n        match_id        TEXT         NOT NULL,\n        tx_type         TEXT         NOT NULL,\n        amount_lamports BIGINT       NOT NULL,\n        tx_sig          TEXT         NOT NULL,\n        created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX IF NOT EXISTS uq_tx_wallet_match_type_sig\n        ON transactions (wallet, match_id, tx_type, tx_sig)\n    `;\n    db = createDb(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    // Clean up test rows\n    await rawSql`DELETE FROM transactions WHERE wallet LIKE 'TestWallet_stats_%'`;\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean only our test wallet's rows between tests\n    await rawSql`DELETE FROM transactions WHERE wallet LIKE 'TestWallet_stats_%'`;\n  });\n\n  // Helper to insert a transaction row with controlled created_at\n  async function seed(\n    matchId: string,\n    txType: \"deposit\" | \"payout\" | \"refund\",\n    amountLamports: number,\n    game: string,\n    createdAt: Date,\n    wallet = WALLET,\n  ) {\n    const txSig = `sig_${matchId}_${txType}_${Date.now()}_${Math.random()}`;\n    await rawSql`\n      INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig, created_at)\n      VALUES (${wallet}, ${game}, ${matchId}, ${txType}, ${amountLamports}, ${txSig}, ${createdAt})\n    `;\n  }\n\n  // -----------------------------------------------------------------------\n  // (1) Empty history → all zeros\n  // -----------------------------------------------------------------------\n  it(\"returns zero stats for empty history\", async () => {\n    const stats = await db.getPlayerStats(WALLET);\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWagered).toBe(0n);\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n    expect(stats.netPnl).toBe(0n);\n  });\n\n  it(\"returns zero streaks for empty history\", async () => {\n    const streaks = await db.getWinStreaks(WALLET);\n    expect(streaks.current).toBe(0);\n    expect(streaks.best).toBe(0);\n  });\n\n  it(\"returns empty game breakdown for empty history\", async () => {\n    const breakdown = await db.getGameBreakdown(WALLET);\n    expect(Object.keys(breakdown).length).toBe(0);\n  });\n\n  // -----------------------------------------------------------------------\n  // (2) 3 wins in a row → current=3 best=3\n  // -----------------------------------------------------------------------\n  it(\"3 consecutive wins → current=3 best=3\", async () => {\n    const base = new Date(\"2026-01-01T00:00:00Z\");\n    // Match 1: deposit + payout (win)\n    await seed(\"m1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"m1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n    // Match 2: deposit + payout (win)\n    await seed(\"m2\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n    await seed(\"m2\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 4000));\n    // Match 3: deposit + payout (win)\n    await seed(\"m3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n    await seed(\"m3\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 6000));\n\n    const streaks = await db.getWinStreaks(WALLET);\n    expect(streaks.current).toBe(3);\n    expect(streaks.best).toBe(3);\n  });\n\n  // -----------------------------------------------------------------------\n  // (3) win-win-loss-win → current=1 best=2\n  // -----------------------------------------------------------------------\n  it(\"win-win-loss-win → current=1 best=2\", async () => {\n    const base = new Date(\"2026-02-01T00:00:00Z\");\n    // Match 1 (oldest): win\n    await seed(\"a1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"a1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n    // Match 2: win\n    await seed(\"a2\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n    await seed(\"a2\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 4000));\n    // Match 3: loss\n    await seed(\"a3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n    // Match 4 (most recent): win\n    await seed(\"a4\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 7000));\n    await seed(\"a4\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 8000));\n\n    const streaks = await db.getWinStreaks(WALLET);\n    expect(streaks.current).toBe(1);\n    expect(streaks.best).toBe(2);\n  });\n\n  // -----------------------------------------------------------------------\n  // (4) Refund-only match skipped in streak\n  // -----------------------------------------------------------------------\n  it(\"refund-only match is skipped in streak calculation\", async () => {\n    const base = new Date(\"2026-03-01T00:00:00Z\");\n    // Match 1: win\n    await seed(\"r1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"r1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n    // Match 2: refund only (no deposit, no payout)\n    await seed(\"r2\", \"refund\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n    // Match 3 (most recent): win\n    await seed(\"r3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n    await seed(\"r3\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 6000));\n\n    const streaks = await db.getWinStreaks(WALLET);\n    // Refund-only match skipped → current streak is 2 consecutive wins\n    expect(streaks.current).toBe(2);\n    expect(streaks.best).toBe(2);\n  });\n\n  // -----------------------------------------------------------------------\n  // (5) Game breakdown groups correctly\n  // -----------------------------------------------------------------------\n  it(\"game breakdown groups by frontend game name\", async () => {\n    const base = new Date(\"2026-04-01T00:00:00Z\");\n    // Coinflip: 1 win\n    await seed(\"g1\", \"deposit\", 2000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"g1\", \"payout\", 3800, \"coinflip\", new Date(base.getTime() + 2000));\n    // Lord: 1 loss\n    await seed(\"g2\", \"deposit\", 5000, \"lord\", new Date(base.getTime() + 3000));\n    // Close Call: 1 win\n    await seed(\"g3\", \"deposit\", 3000, \"closecall\", new Date(base.getTime() + 5000));\n    await seed(\"g3\", \"payout\", 5500, \"closecall\", new Date(base.getTime() + 6000));\n\n    const breakdown = await db.getGameBreakdown(WALLET);\n\n    // Keys use frontend names\n    expect(breakdown[\"coinflip\"]).toBeDefined();\n    expect(breakdown[\"lord-of-rngs\"]).toBeDefined();\n    expect(breakdown[\"close-call\"]).toBeDefined();\n\n    // Coinflip: 1 game, 1 win, wagered=2000, pnl=3800-2000=1800\n    expect(breakdown[\"coinflip\"].gamesPlayed).toBe(1);\n    expect(breakdown[\"coinflip\"].totalWins).toBe(1);\n    expect(breakdown[\"coinflip\"].totalWagered).toBe(2000n);\n    expect(breakdown[\"coinflip\"].netPnl).toBe(1800n);\n    expect(breakdown[\"coinflip\"].winRate).toBe(1);\n\n    // Lord: 1 game, 0 wins, wagered=5000, pnl=-5000\n    expect(breakdown[\"lord-of-rngs\"].gamesPlayed).toBe(1);\n    expect(breakdown[\"lord-of-rngs\"].totalWins).toBe(0);\n    expect(breakdown[\"lord-of-rngs\"].totalWagered).toBe(5000n);\n    expect(breakdown[\"lord-of-rngs\"].netPnl).toBe(-5000n);\n    expect(breakdown[\"lord-of-rngs\"].winRate).toBe(0);\n\n    // Close Call: 1 game, 1 win, wagered=3000, pnl=5500-3000=2500\n    expect(breakdown[\"close-call\"].gamesPlayed).toBe(1);\n    expect(breakdown[\"close-call\"].totalWins).toBe(1);\n    expect(breakdown[\"close-call\"].totalWagered).toBe(3000n);\n    expect(breakdown[\"close-call\"].netPnl).toBe(2500n);\n    expect(breakdown[\"close-call\"].winRate).toBe(1);\n  });\n\n  // -----------------------------------------------------------------------\n  // (6) Public stats omit wagered/pnl\n  // -----------------------------------------------------------------------\n  it(\"public stats expose only gamesPlayed, totalWins, winRate\", async () => {\n    const base = new Date(\"2026-05-01T00:00:00Z\");\n    await seed(\"p1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"p1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n\n    const pub = await db.getPublicPlayerStats(WALLET);\n    expect(pub.gamesPlayed).toBe(1);\n    expect(pub.totalWins).toBe(1);\n    expect(pub.winRate).toBe(1);\n    // Should not have wagered or pnl fields\n    expect(\"totalWagered\" in pub).toBe(false);\n    expect(\"netPnl\" in pub).toBe(false);\n  });\n\n  // -----------------------------------------------------------------------\n  // Aggregate stats correctness\n  // -----------------------------------------------------------------------\n  it(\"computes aggregate stats correctly\", async () => {\n    const base = new Date(\"2026-06-01T00:00:00Z\");\n    // Match 1: deposit 2000, payout 3800 (win, net +1800)\n    await seed(\"s1\", \"deposit\", 2000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"s1\", \"payout\", 3800, \"coinflip\", new Date(base.getTime() + 2000));\n    // Match 2: deposit 3000 (loss, net -3000)\n    await seed(\"s2\", \"deposit\", 3000, \"lord\", new Date(base.getTime() + 3000));\n    // Match 3: deposit 1000, refund 1000 (refund, net 0)\n    await seed(\"s3\", \"deposit\", 1000, \"closecall\", new Date(base.getTime() + 5000));\n    await seed(\"s3\", \"refund\", 1000, \"closecall\", new Date(base.getTime() + 6000));\n\n    const stats = await db.getPlayerStats(WALLET);\n    expect(stats.gamesPlayed).toBe(3); // 3 distinct match_ids with deposits\n    expect(stats.totalWagered).toBe(6000n); // 2000+3000+1000\n    expect(stats.totalWins).toBe(1); // only match s1 has payout\n    expect(stats.winRate).toBeCloseTo(1 / 3, 5);\n    // netPnl = (3800 payout + 1000 refund) - (2000 + 3000 + 1000 deposits) = 4800 - 6000 = -1200\n    expect(stats.netPnl).toBe(-1200n);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":387,"cache_read_input_tokens":51588,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":387},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cd479181-9c0f-4c58-8b77-ba63a57dd2e1","uuid":"e33b1b47-e160-40be-b2ad-8f9c4a60ba43"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CDLTAypz1q2qPZRfvZ7K4Y","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/backend/services/backend/src/__tests__/player-stats.test.ts"}]},"parent_tool_use_id":null,"session_id":"cd479181-9c0f-4c58-8b77-ba63a57dd2e1","uuid":"eee5f7e4-ac4a-42f2-8aca-c2e57804ce3e","timestamp":"2026-03-31T15:28:37.837Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/player-stats.test.ts","content":"/**\n * Unit tests for player stats + streaks DB functions.\n *\n * Requires a running PostgreSQL instance. Seeds the `transactions` table\n * with known rows and verifies getPlayerStats, getWinStreaks,\n * getGameBreakdown, and getPublicPlayerStats.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n\nconst WALLET = \"TestWallet_stats_\" + Date.now();\n\ndescribe(\"Player stats + streaks\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n\n  beforeAll(async () => {\n    rawSql = postgres(DATABASE_URL);\n    // Ensure transactions table exists\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS transactions (\n        id              BIGSERIAL    PRIMARY KEY,\n        wallet          TEXT         NOT NULL,\n        game            TEXT         NOT NULL,\n        match_id        TEXT         NOT NULL,\n        tx_type         TEXT         NOT NULL,\n        amount_lamports BIGINT       NOT NULL,\n        tx_sig          TEXT         NOT NULL,\n        created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX IF NOT EXISTS uq_tx_wallet_match_type_sig\n        ON transactions (wallet, match_id, tx_type, tx_sig)\n    `;\n    db = createDb(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    // Clean up test rows\n    await rawSql`DELETE FROM transactions WHERE wallet LIKE 'TestWallet_stats_%'`;\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean only our test wallet's rows between tests\n    await rawSql`DELETE FROM transactions WHERE wallet LIKE 'TestWallet_stats_%'`;\n  });\n\n  // Helper to insert a transaction row with controlled created_at\n  async function seed(\n    matchId: string,\n    txType: \"deposit\" | \"payout\" | \"refund\",\n    amountLamports: number,\n    game: string,\n    createdAt: Date,\n    wallet = WALLET,\n  ) {\n    const txSig = `sig_${matchId}_${txType}_${Date.now()}_${Math.random()}`;\n    await rawSql`\n      INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig, created_at)\n      VALUES (${wallet}, ${game}, ${matchId}, ${txType}, ${amountLamports}, ${txSig}, ${createdAt})\n    `;\n  }\n\n  // -----------------------------------------------------------------------\n  // (1) Empty history → all zeros\n  // -----------------------------------------------------------------------\n  it(\"returns zero stats for empty history\", async () => {\n    const stats = await db.getPlayerStats(WALLET);\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWagered).toBe(0n);\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n    expect(stats.netPnl).toBe(0n);\n  });\n\n  it(\"returns zero streaks for empty history\", async () => {\n    const streaks = await db.getWinStreaks(WALLET);\n    expect(streaks.current).toBe(0);\n    expect(streaks.best).toBe(0);\n  });\n\n  it(\"returns empty game breakdown for empty history\", async () => {\n    const breakdown = await db.getGameBreakdown(WALLET);\n    expect(Object.keys(breakdown).length).toBe(0);\n  });\n\n  // -----------------------------------------------------------------------\n  // (2) 3 wins in a row → current=3 best=3\n  // -----------------------------------------------------------------------\n  it(\"3 consecutive wins → current=3 best=3\", async () => {\n    const base = new Date(\"2026-01-01T00:00:00Z\");\n    // Match 1: deposit + payout (win)\n    await seed(\"m1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"m1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n    // Match 2: deposit + payout (win)\n    await seed(\"m2\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n    await seed(\"m2\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 4000));\n    // Match 3: deposit + payout (win)\n    await seed(\"m3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n    await seed(\"m3\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 6000));\n\n    const streaks = await db.getWinStreaks(WALLET);\n    expect(streaks.current).toBe(3);\n    expect(streaks.best).toBe(3);\n  });\n\n  // -----------------------------------------------------------------------\n  // (3) win-win-loss-win → current=1 best=2\n  // -----------------------------------------------------------------------\n  it(\"win-win-loss-win → current=1 best=2\", async () => {\n    const base = new Date(\"2026-02-01T00:00:00Z\");\n    // Match 1 (oldest): win\n    await seed(\"a1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"a1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n    // Match 2: win\n    await seed(\"a2\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n    await seed(\"a2\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 4000));\n    // Match 3: loss\n    await seed(\"a3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n    // Match 4 (most recent): win\n    await seed(\"a4\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 7000));\n    await seed(\"a4\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 8000));\n\n    const streaks = await db.getWinStreaks(WALLET);\n    expect(streaks.current).toBe(1);\n    expect(streaks.best).toBe(2);\n  });\n\n  // -----------------------------------------------------------------------\n  // (4) Refund-only match skipped in streak\n  // -----------------------------------------------------------------------\n  it(\"refund-only match is skipped in streak calculation\", async () => {\n    const base = new Date(\"2026-03-01T00:00:00Z\");\n    // Match 1: win\n    await seed(\"r1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"r1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n    // Match 2: refund only (no deposit, no payout)\n    await seed(\"r2\", \"refund\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n    // Match 3 (most recent): win\n    await seed(\"r3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n    await seed(\"r3\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 6000));\n\n    const streaks = await db.getWinStreaks(WALLET);\n    // Refund-only match skipped → current streak is 2 consecutive wins\n    expect(streaks.current).toBe(2);\n    expect(streaks.best).toBe(2);\n  });\n\n  // -----------------------------------------------------------------------\n  // (5) Game breakdown groups correctly\n  // -----------------------------------------------------------------------\n  it(\"game breakdown groups by frontend game name\", async () => {\n    const base = new Date(\"2026-04-01T00:00:00Z\");\n    // Coinflip: 1 win\n    await seed(\"g1\", \"deposit\", 2000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"g1\", \"payout\", 3800, \"coinflip\", new Date(base.getTime() + 2000));\n    // Lord: 1 loss\n    await seed(\"g2\", \"deposit\", 5000, \"lord\", new Date(base.getTime() + 3000));\n    // Close Call: 1 win\n    await seed(\"g3\", \"deposit\", 3000, \"closecall\", new Date(base.getTime() + 5000));\n    await seed(\"g3\", \"payout\", 5500, \"closecall\", new Date(base.getTime() + 6000));\n\n    const breakdown = await db.getGameBreakdown(WALLET);\n\n    // Keys use frontend names\n    expect(breakdown[\"coinflip\"]).toBeDefined();\n    expect(breakdown[\"lord-of-rngs\"]).toBeDefined();\n    expect(breakdown[\"close-call\"]).toBeDefined();\n\n    // Coinflip: 1 game, 1 win, wagered=2000, pnl=3800-2000=1800\n    expect(breakdown[\"coinflip\"].gamesPlayed).toBe(1);\n    expect(breakdown[\"coinflip\"].totalWins).toBe(1);\n    expect(breakdown[\"coinflip\"].totalWagered).toBe(2000n);\n    expect(breakdown[\"coinflip\"].netPnl).toBe(1800n);\n    expect(breakdown[\"coinflip\"].winRate).toBe(1);\n\n    // Lord: 1 game, 0 wins, wagered=5000, pnl=-5000\n    expect(breakdown[\"lord-of-rngs\"].gamesPlayed).toBe(1);\n    expect(breakdown[\"lord-of-rngs\"].totalWins).toBe(0);\n    expect(breakdown[\"lord-of-rngs\"].totalWagered).toBe(5000n);\n    expect(breakdown[\"lord-of-rngs\"].netPnl).toBe(-5000n);\n    expect(breakdown[\"lord-of-rngs\"].winRate).toBe(0);\n\n    // Close Call: 1 game, 1 win, wagered=3000, pnl=5500-3000=2500\n    expect(breakdown[\"close-call\"].gamesPlayed).toBe(1);\n    expect(breakdown[\"close-call\"].totalWins).toBe(1);\n    expect(breakdown[\"close-call\"].totalWagered).toBe(3000n);\n    expect(breakdown[\"close-call\"].netPnl).toBe(2500n);\n    expect(breakdown[\"close-call\"].winRate).toBe(1);\n  });\n\n  // -----------------------------------------------------------------------\n  // (6) Public stats omit wagered/pnl\n  // -----------------------------------------------------------------------\n  it(\"public stats expose only gamesPlayed, totalWins, winRate\", async () => {\n    const base = new Date(\"2026-05-01T00:00:00Z\");\n    await seed(\"p1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"p1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n\n    const pub = await db.getPublicPlayerStats(WALLET);\n    expect(pub.gamesPlayed).toBe(1);\n    expect(pub.totalWins).toBe(1);\n    expect(pub.winRate).toBe(1);\n    // Should not have wagered or pnl fields\n    expect(\"totalWagered\" in pub).toBe(false);\n    expect(\"netPnl\" in pub).toBe(false);\n  });\n\n  // -----------------------------------------------------------------------\n  // Aggregate stats correctness\n  // -----------------------------------------------------------------------\n  it(\"computes aggregate stats correctly\", async () => {\n    const base = new Date(\"2026-06-01T00:00:00Z\");\n    // Match 1: deposit 2000, payout 3800 (win, net +1800)\n    await seed(\"s1\", \"deposit\", 2000, \"coinflip\", new Date(base.getTime() + 1000));\n    await seed(\"s1\", \"payout\", 3800, \"coinflip\", new Date(base.getTime() + 2000));\n    // Match 2: deposit 3000 (loss, net -3000)\n    await seed(\"s2\", \"deposit\", 3000, \"lord\", new Date(base.getTime() + 3000));\n    // Match 3: deposit 1000, refund 1000 (refund, net 0)\n    await seed(\"s3\", \"deposit\", 1000, \"closecall\", new Date(base.getTime() + 5000));\n    await seed(\"s3\", \"refund\", 1000, \"closecall\", new Date(base.getTime() + 6000));\n\n    const stats = await db.getPlayerStats(WALLET);\n    expect(stats.gamesPlayed).toBe(3); // 3 distinct match_ids with deposits\n    expect(stats.totalWagered).toBe(6000n); // 2000+3000+1000\n    expect(stats.totalWins).toBe(1); // only match s1 has payout\n    expect(stats.winRate).toBeCloseTo(1 / 3, 5);\n    // netPnl = (3800 payout + 1000 refund) - (2000 + 3000 + 1000 deposits) = 4800 - 6000 = -1200\n    expect(stats.netPnl).toBe(-1200n);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
