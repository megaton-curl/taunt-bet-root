xt AS total_wagered,\n      COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n      COALESCE(\n        SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n                 WHEN tx_type = 'deposit' THEN -amount_lamports\n                 ELSE 0 END),\n        0\n      )::text AS net_pnl\n    FROM transactions\n    WHERE wallet = ${wallet}\n    GROUP BY game\n  `;\n\n  const result: Record<string, GameBreakdownStats> = {};\n  for (const row of rows) {\n    const gamesPlayed = Number(row.games_played);\n    if (gamesPlayed === 0) continue;\n    const totalWins = Number(row.total_wins);\n    const frontendName = DB_TO_FRONTEND[row.game] ?? row.game;\n    result[frontendName] = {\n      gamesPlayed,\n      totalWagered: BigInt(row.total_wagered),\n      totalWins,\n      winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n      netPnl: BigInt(row.net_pnl),\n    };\n  }\n  return result;\n}\n```\n\n**Key Logic:**\n- Same aggregation as `getPlayerStats` but grouped by `game`\n- Skips games with zero activity\n- Maps DB game names (`coinflip`, `lord`, `closecall`) to frontend names (`coinflip`, `lord-of-rngs`, `close-call`)\n- Returns Record keyed by frontend game names\n\n---\n\n#### `getWinStreaks(wallet: string): Promise<WinStreaks>` (Lines 1254-1296)\n```typescript\nasync getWinStreaks(wallet) {\n  // Get outcome per match ordered by most recent first.\n  // A match with a 'payout' row = win, 'deposit' without 'payout' = loss,\n  // only 'refund' = skip (excluded).\n  const rows = await sql<\n    Array<{ match_id: string; has_payout: boolean; has_deposit: boolean }>\n  >`\n    SELECT\n      match_id,\n      bool_or(tx_type = 'payout') AS has_payout,\n      bool_or(tx_type = 'deposit') AS has_deposit\n    FROM transactions\n    WHERE wallet = ${wallet}\n    GROUP BY match_id\n    HAVING bool_or(tx_type = 'deposit') OR bool_or(tx_type = 'payout')\n    ORDER BY MAX(created_at) DESC\n  `;\n\n  let current = 0;\n  let best = 0;\n  let streak = 0;\n  let currentSet = false;\n\n  for (const row of rows) {\n    // Skip refund-only matches (no deposit, no payout)\n    if (!row.has_deposit && !row.has_payout) continue;\n\n    const isWin = row.has_payout;\n    if (isWin) {\n      streak++;\n      if (streak > best) best = streak;\n    } else {\n      if (!currentSet) {\n        current = streak;\n        currentSet = true;\n      }\n      streak = 0;\n    }\n  }\n  // If we never hit a loss, current streak = total streak\n  if (!currentSet) current = streak;\n\n  return { current, best };\n}\n```\n\n**Key Logic:**\n- Queries all matches grouped by match_id with booleans for `has_payout` and `has_deposit`\n- Orders by most recent first\n- Iterates through matches (most recent first):\n  - **Win** (has_payout): increment streak, update best if needed\n  - **Loss** (no payout but has deposit): set current streak if not already set, reset streak to 0\n- `current`: current consecutive wins from most recent match\n- `best`: longest winning streak ever\n\n---\n\n#### `insertTransaction(params: InsertTransactionParams): Promise<void>` (Lines 811-824)\n```typescript\nasync insertTransaction(params) {\n  await sql`\n    INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n    VALUES (\n      ${params.wallet},\n      ${params.game},\n      ${params.matchId},\n      ${params.txType},\n      ${params.amountLamports},\n      ${params.txSig}\n    )\n    ON CONFLICT DO NOTHING\n  `;\n}\n```\n\n**Key Details:**\n- `ON CONFLICT DO NOTHING`: Idempotent - ignores duplicate inserts\n\n---\n\n#### `insertTransactions(params: InsertTransactionParams[]): Promise<void>` (Lines 826-840)\n```typescript\nasync insertTransactions(params) {\n  if (params.length === 0) return;\n  const values = params.map((p) => ({\n    wallet: p.wallet,\n    game: p.game,\n    match_id: p.matchId,\n    tx_type: p.txType,\n    amount_lamports: p.amountLamports,\n    tx_sig: p.txSig,\n  }));\n  await sql`\n    INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n    ON CONFLICT DO NOTHING\n  `;\n}\n```\n\n**Key Details:**\n- Bulk insert multiple transactions\n- Handles empty array case early (returns without executing query)\n- Uses parametrized bulk insert with `sql(values, ...columns)` syntax\n- Also uses `ON CONFLICT DO NOTHING` for idempotency"}],"totalDurationMs":41241,"totalTokens":37515,"totalToolUseCount":16,"usage":{"input_tokens":4,"cache_creation_input_tokens":527,"cache_read_input_tokens":34165,"output_tokens":2819,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":527},"inference_geo":"","iterations":[],"speed":"standard"}}}
