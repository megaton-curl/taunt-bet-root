{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BfLZT6aV3UM4w4HSmPZWKy","type":"tool_result","content":"1147\t    async getPlayerStats(wallet) {\n1148\t      const rows = await sql<\n1149\t        Array<{\n1150\t          games_played: string;\n1151\t          total_wagered: string;\n1152\t          total_wins: string;\n1153\t          net_pnl: string;\n1154\t        }>\n1155\t      >`\n1156\t        SELECT\n1157\t          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n1158\t          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n1159\t          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n1160\t          COALESCE(\n1161\t            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n1162\t                     WHEN tx_type = 'deposit' THEN -amount_lamports\n1163\t                     ELSE 0 END),\n1164\t            0\n1165\t          )::text AS net_pnl\n1166\t        FROM transactions\n1167\t        WHERE wallet = ${wallet}\n1168\t      `;\n1169\t      const row = rows[0]!;\n1170\t      const gamesPlayed = Number(row.games_played);\n1171\t      const totalWins = Number(row.total_wins);\n1172\t      return {\n1173\t        gamesPlayed,\n1174\t        totalWagered: BigInt(row.total_wagered),\n1175\t        totalWins,\n1176\t        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n1177\t        netPnl: BigInt(row.net_pnl),\n1178\t      };\n1179\t    },\n1180\t\n1181\t    async getPublicPlayerStats(wallet) {\n1182\t      const full = await this.getPlayerStats(wallet);\n1183\t      return {\n1184\t        gamesPlayed: full.gamesPlayed,\n1185\t        totalWins: full.totalWins,\n1186\t        winRate: full.winRate,\n1187\t      };\n1188\t    },\n1189\t\n1190\t    async getWinStreaks(wallet) {\n1191\t      // Get outcome per match ordered by most recent first.\n1192\t      // A match with a 'payout' row = win, 'deposit' without 'payout' = loss,\n1193\t      // only 'refund' = skip (excluded).\n1194\t      const rows = await sql<\n1195\t        Array<{ match_id: string; has_payout: boolean; has_deposit: boolean }>\n1196\t      >`"}]},"parent_tool_use_id":"toolu_019XK5WeNiSbR3muunoi5YYw","session_id":"b73714c7-2f31-4e13-b447-25e2a49ac6c6","uuid":"235b4400-8840-4f8f-9ac9-22a5ccac02b2","timestamp":"2026-03-31T15:08:28.451Z"}
