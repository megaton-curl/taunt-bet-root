87\t\n288\t  /** Batch-fetch the latest operator event per PDA for a given event type. */\n289\t  getLatestOperatorEventsForPdas(\n290\t    pdas: string[],\n291\t    eventType: OperatorEventType,\n292\t  ): Promise<Map<string, OperatorEvent>>;\n293\t\n294\t  /** Get recently settled rounds for a game, ordered newest first. */\n295\t  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n296\t\n297\t  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n298\t  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n299\t\n300\t  // -------------------------------------------------------------------------\n301\t  // Close Call rounds\n302\t  // -------------------------------------------------------------------------\n303\t\n304\t  /** Insert a new Close Call round. */\n305\t  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n306\t\n307\t  /** Get a Close Call round by round_id (16-char hex). */\n308\t  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n309\t\n310\t  /** Get the current active (open) Close Call round. */\n311\t  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n312\t\n313\t  /** Get the most recent settled/refunded Close Call rounds. */\n314\t  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n315\t\n316\t  /** Update a Close Call round after settlement. */\n317\t  settleCloseCallRound(\n318\t    roundId: string,\n319\t    updates: {\n320\t      phase: CloseCallPhase;\n321\t      outcome: CloseCallOutcome;\n322\t      closePrice?: number;\n323\t      greenPool?: number;\n324\t      redPool?: number;\n325\t      totalFee?: number;\n326\t      greenEntries?: Array<{ player: string; amountLamports: number }>;\n327\t      redEntries?: Array<{ player: string; amountLamports: number }>;\n328\t      settleTx?: string;\n329\t    },\n330\t  ): Promise<CloseCallRound>;\n331\t\n332\t  // -------------------------------------------------------------------------\n333\t  // Transactions\n334\t  // -------------------------------------------------------------------------\n335\t\n336\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n337\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n338\t\n339\t  /** Insert multiple transactions in a single batch. */\n340\t  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n341\t\n342\t  /** Get paginated transactions for a wallet, newest first. */\n343\t  getTransactions(\n344\t    wallet: string,\n345\t    cursor?: string,\n346\t    limit?: number,\n347\t    game?: string,\n348\t  ): Promise<Transaction[]>;\n349\t\n350\t  // -------------------------------------------------------------------------\n351\t  // Referral — codes\n352\t  // -------------------------------------------------------------------------\n353\t\n354\t  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n355\t  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n356\t\n357\t  /** Get a wallet's referral code. Returns `undefined` if none set. */\n358\t  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n359\t\n360\t  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n361\t  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n362\t\n363\t  // -------------------------------------------------------------------------\n364\t  // Referral — links\n365\t  // -------------------------------------------------------------------------\n366\t\n367\t  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n368\t  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n369\t\n370\t  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n371\t  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n372\t\n373\t  /** Get all referral links where the given wallet is the referrer. */\n374\t  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n375\t\n376\t  // -------------------------------------------------------------------------\n377\t  // Referral — earnings & stats\n378\t  // -------------------------------------------------------------------------\n379\t\n380\t  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n381\t  insertReferralEarning(params: {\n382\t    referrerWallet: string;\n383\t    refereeWallet: string;\n384\t    roundId: string;\n385\t    gameType: string;\n386\t    wagerLamports: number;\n387\t    feeLamports: number;\n388\t    referrerEarnedLamports: number;\n389\t    referrerRateBps: number;\n390\t    refereeRebateLamports: number;\n391\t    refereeRebateRateBps: number;\n392\t  }): Promise<ReferralEarning>;\n393\t\n394\t  /**\n395\t   * Get the pending (unclaimed) balance for a wallet.\n396\t   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n397\t   * wallet=referee, minus sum of completed claims for the wallet.\n398\t   * Returns a lamport string.\n399\t   */\n400\t  getPendingBalance(wallet: string): Promise<string>;\n401\t\n402\t  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n403\t  getReferralEarnings(\n404\t    wallet: string,\n405\t    page: number,\n406\t    limit: number,\n407\t  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n408\t\n409\t  /** Get referral summary stats for a wallet. */\n410\t  getReferralStats(wallet: string): Promise<ReferralStats>;\n411\t\n412\t  // -------------------------------------------------------------------------\n413\t  // Referral — claims & rates\n414\t  // -------------------------------------------------------------------------\n415\t\n416\t  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n417\t  insertReferralClaim(\n418\t    wallet: string,\n419\t    amountLamports: string,\n420\t  ): Promise<ReferralClaim>;\n421\t\n422\t  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n423\t  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n424\t\n425\t  /**\n426\t   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n427\t   * Returns the updated claim.\n428\t   */\n429\t  updateClaimStatus(\n430\t    claimId: string,\n431\t    status: ReferralClaim[\"status\"],\n432\t    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n433\t  ): Promise<ReferralClaim>;\n434\t\n435\t  /**\n436\t   * Get the effective referrer rate for a wallet in bps.\n437\t   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n438\t   */\n439\t  getReferrerRate(\n440\t    wallet: string,\n441\t    defaultRateBps: number,\n442\t  ): Promise<number>;\n443\t\n444\t  // -------------------------------------------------------------------------\n445\t  // Player profiles\n446\t  // -------------------------------------------------------------------------\n447\t\n448\t  /**\n449\t   * Create a new player profile with auto-generated user_id and username.\n450\t   * Retries up to 5 times on username collision, then falls back to `user-{random8}`.\n451\t   */\n452\t  createPlayerProfile(wallet: string): Promise<PlayerProfile>;\n453\t\n454\t  /** Get a player profile by wallet address. Returns `null` if not found. */\n455\t  getProfileByWallet(wallet: string): Promise<PlayerProfile | null>;\n456\t\n457\t  /**\n458\t   * Get a player profile by public identifier.\n459\t   * If identifier starts with `usr_`, looks up by `user_id`.\n460\t   * Otherwise looks up by username (case-insensitive).\n461\t   */\n462\t  getProfileByIdentifier(identifier: string): Promise<PlayerProfile | null>;\n463\t\n464\t  /**\n465\t   * Update a player's username. Validates 30-day cooldown (first edit is free).\n466\t   * Throws on cooldown violation or UNIQUE conflict.\n467\t   */\n468\t  updateUsername(wallet: string, newUsername: string): Promise<PlayerProfile>;\n469\t\n470\t  /**\n471\t   * Compute aggregate stats from the transactions table for a wallet.\n472\t   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n473\t   */\n474\t  getPlayerStats(wallet: string): Promise<PlayerStats>;\n475\t\n476\t  /**\n477\t   * Get public-safe subset of player stats (no wagered, no PnL).\n478\t   */\n479\t  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n480\t\n481\t  /**\n482\t   * Compute win streaks from the transactions table.\n483\t   * Returns current (consecutive wins from most recent) and best (longest ever).\n484\t   * Refund-only matches are excluded from streak calculation.\n485\t   */\n486\t  getWinStreaks(wallet: string): Promise<WinStreaks>;\n487\t\n488\t  /**\n489\t   * Execute a function within a database transaction.\n490\t   * All db methods called on the transactional Db share the same transaction.\n491\t   * Rolls back on error, commits on success.\n492\t   */"}]},"parent_tool_use_id":"toolu_019XK5WeNiSbR3muunoi5YYw","session_id":"b73714c7-2f31-4e13-b447-25e2a49ac6c6","uuid":"a9f01f52-60a1-48c3-a9b3-f833c08709f6","timestamp":"2026-03-31T15:08:28.119Z"}
