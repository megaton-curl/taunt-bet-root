{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014j9qv6bNJYfRWWs4Gb5Zxk","type":"tool_result","content":"100\t\n101\t// ---------------------------------------------------------------------------\n102\t// Transaction types\n103\t// ---------------------------------------------------------------------------\n104\t\n105\texport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n106\t\n107\texport interface Transaction {\n108\t  id: string;\n109\t  wallet: string;\n110\t  game: string;\n111\t  match_id: string;\n112\t  tx_type: TransactionType;\n113\t  amount_lamports: number;\n114\t  tx_sig: string;\n115\t  created_at: Date;\n116\t}\n117\t\n118\texport interface InsertTransactionParams {\n119\t  wallet: string;\n120\t  game: string;\n121\t  matchId: string;\n122\t  txType: TransactionType;\n123\t  amountLamports: number;\n124\t  txSig: string;\n125\t}\n126\t\n127\t// ---------------------------------------------------------------------------\n128\t// Referral types\n129\t// ---------------------------------------------------------------------------\n130\t\n131\texport interface ReferralCode {\n132\t  id: number;\n133\t  wallet: string;\n134\t  code: string;\n135\t  created_at: Date;\n136\t  updated_at: Date;\n137\t}\n138\t\n139\texport interface ReferralLink {\n140\t  id: number;\n141\t  referrer_wallet: string;\n142\t  referee_wallet: string;\n143\t  created_at: Date;\n144\t}\n145\t\n146\texport interface ReferralEarning {\n147\t  id: number;\n148\t  referrer_wallet: string;\n149\t  referee_wallet: string;\n150\t  round_id: string;\n151\t  game_type: string;\n152\t  wager_lamports: number;\n153\t  fee_lamports: number;\n154\t  referrer_earned_lamports: number;\n155\t  referrer_rate_bps: number;\n156\t  referee_rebate_lamports: number;\n157\t  referee_rebate_rate_bps: number;\n158\t  created_at: Date;\n159\t}\n160\t\n161\texport interface ReferralStats {\n162\t  referred_count: number;\n163\t  active_count: number;\n164\t  total_volume_lamports: string;\n165\t  total_earned_lamports: string;\n166\t  total_rebate_lamports: string;\n167\t  pending_lamports: string;\n168\t}\n169\t\n170\texport interface ReferralClaim {\n171\t  id: string;\n172\t  wallet: string;\n173\t  amount_lamports: string;\n174\t  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n175\t  retry_count: number;\n176\t  tx_signature: string | null;\n177\t  error: string | null;\n178\t  requested_at: Date;\n179\t  processed_at: Date | null;\n180\t}\n181\t\n182\t// ---------------------------------------------------------------------------\n183\t// Player profile types\n184\t// ---------------------------------------------------------------------------\n185\t\n186\texport interface PlayerProfile {\n187\t  id: number;\n188\t  user_id: string;\n189\t  wallet: string;\n190\t  username: string;\n191\t  username_updated_at: Date | null;\n192\t  avatar_url: string | null;\n193\t  heat_multiplier: number;\n194\t  points_balance: number;\n195\t  created_at: Date;\n196\t}\n197\t\n198\texport interface PlayerStats {\n199\t  gamesPlayed: number;"}]},"parent_tool_use_id":"toolu_019XK5WeNiSbR3muunoi5YYw","session_id":"b73714c7-2f31-4e13-b447-25e2a49ac6c6","uuid":"4f08f665-6045-473b-8f25-86b63f9e96d9","timestamp":"2026-03-31T15:08:37.554Z"}
