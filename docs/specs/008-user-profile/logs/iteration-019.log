{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JfpHtE4f5bxbQW4ubwAefB","type":"tool_result","content":"1\timport { PublicKey } from \"@solana/web3.js\";\n2\t\n3\t// ============ Wager Constants ============\n4\t\n5\t/** Minimum wager in SOL */\n6\texport const MIN_WAGER_SOL = 0.001;\n7\t\n8\t/** Minimum wager in lamports */\n9\texport const MIN_WAGER_LAMPORTS = 1_000_000;\n10\t\n11\t/** Maximum wager in SOL */\n12\texport const MAX_WAGER_SOL = 100;\n13\t\n14\t/** Maximum wager in lamports */\n15\texport const MAX_WAGER_LAMPORTS = 100_000_000_000;\n16\t\n17\t// ============ Pool State ============\n18\t\n19\texport type PoolPhase = \"waiting\" | \"locked\" | \"resolving\" | \"settled\" | \"cancelled\";\n20\t\n21\texport const POOL_PHASE_VALUES: Record<PoolPhase, number> = {\n22\t  waiting: 0,\n23\t  locked: 1,\n24\t  resolving: 2,\n25\t  settled: 3,\n26\t  cancelled: 4,\n27\t};\n28\t\n29\texport interface Pool {\n30\t  poolId: Uint8Array;\n31\t  gameId: string;\n32\t  roundId: number;\n33\t  entryAmount: number;\n34\t  phase: PoolPhase;\n35\t  totalPool: number;\n36\t  playerCount: number;\n37\t  maxPlayers: number;\n38\t  createdAt: Date;\n39\t  lockedAt: Date | null;\n40\t  settledAt: Date | null;\n41\t  feeBps: number;\n42\t  vrfRequest: PublicKey | null;\n43\t  randomness: Uint8Array | null;\n44\t  winner: PublicKey | null;\n45\t  authority: PublicKey;\n46\t  treasury: PublicKey;\n47\t  carryoverAmount: number;\n48\t  carryoverFromRound: number;\n49\t}\n50\t\n51\t// ============ Player Entry ============\n52\t\n53\texport type Side = \"none\" | \"green\" | \"red\";\n54\t\n55\texport const SIDE_VALUES: Record<Side, number> = {\n56\t  none: 0,\n57\t  green: 1,\n58\t  red: 2,\n59\t};\n60\t\n61\texport interface PlayerEntry {\n62\t  pool: PublicKey;\n63\t  player: PublicKey;\n64\t  amount: number;\n65\t  enteredAt: Date;\n66\t  sequence: number;\n67\t  side: Side;\n68\t  cashoutMultiplier: number | null;\n69\t  cashedOutAt: Date | null;\n70\t  claimed: boolean;\n71\t  payout: number;\n72\t  won: boolean;\n73\t  xpParticipation: number;\n74\t  xpWin: number;\n75\t}\n76\t\n77\t// ============ Game Config ============\n78\t\n79\texport interface GameConfig {\n80\t  gameId: string;\n81\t  paused: boolean;\n82\t  minBet: number;\n83\t  maxBet: number;\n84\t  feeBps: number;\n85\t  minPlayers: number;\n86\t  maxPlayers: number;\n87\t  roundDurationSecs: number;\n88\t  bettingWindowSecs: number;\n89\t  vrfQueue: PublicKey;\n90\t  authority: PublicKey;\n91\t  treasury: PublicKey;\n92\t  currentRound: number;\n93\t  totalRounds: number;\n94\t  totalVolume: number;\n95\t  totalFees: number;\n96\t  version: number;\n97\t  createdAt: Date;\n98\t  updatedAt: Date;\n99\t}\n100\t\n101\t// ============ Coinflip ============\n102\t\n103\texport type CoinSide = \"heads\" | \"tails\";\n104\texport type CoinflipPhase = \"created\" | \"ready\" | \"flipping\" | \"complete\";\n105\t\n106\texport const COIN_SIDE_VALUES: Record<CoinSide, number> = {\n107\t  heads: 0,\n108\t  tails: 1,\n109\t};\n110\t\n111\texport const COINFLIP_PHASE_VALUES: Record<CoinflipPhase, number> = {\n112\t  created: 0,\n113\t  ready: 1,\n114\t  flipping: 2,\n115\t  complete: 3,\n116\t};\n117\t\n118\texport interface CoinflipState {\n119\t  pool: PublicKey;\n120\t  player1: PublicKey;\n121\t  player2: PublicKey | null;\n122\t  player1Side: CoinSide;\n123\t  result: CoinSide | null;\n124\t  phase: CoinflipPhase;\n125\t  createdAt: Date;\n126\t  joinedAt: Date | null;\n127\t  flippedAt: Date | null;\n128\t  joinTimeoutSecs: number;\n129\t}\n130\t\n131\texport interface CoinflipMatch {\n132\t  pool: Pool;\n133\t  state: CoinflipState;\n134\t  player1Entry: PlayerEntry;\n135\t  player2Entry: PlayerEntry | null;\n136\t}\n137\t\n138\t// ============ Game IDs ============\n139\t\n140\texport const GAME_IDS = {\n141\t  COINFLIP: \"coinflip\",\n142\t  LORD_OF_RNGS: \"lord-of-rngs\",\n143\t  CRASH: \"crash\",\n144\t  CLOSE_CALL: \"close-call\",\n145\t  SLOTS: \"slots\",\n146\t  GAME_OF_TRADES: \"game-of-trades\",\n147\t  TUG_OF_EARN: \"tug-of-earn\",\n148\t  CHART_COURSE: \"chart-course\",\n149\t} as const;\n150\t\n151\texport type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n152\t\n153\t// ============ Fee Constants ============\n154\t// Must match solana/shared/src/fees.rs DEFAULT_FEE_BPS.\n155\t// On-chain PlatformConfig is the runtime source of truth.\n156\t\n157\texport const FEE_CONSTANTS = {\n158\t  TOTAL_BPS: 500,\n159\t} as const;\n160\t"}]},"parent_tool_use_id":"toolu_019XK5WeNiSbR3muunoi5YYw","session_id":"b73714c7-2f31-4e13-b447-25e2a49ac6c6","uuid":"3e694ca4-829b-4aa4-8a21-c826466d27b9","timestamp":"2026-03-31T15:08:57.294Z"}
