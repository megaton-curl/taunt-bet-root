{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VT53yTvyxcyvJfc86jb7U4","type":"tool_result","content":"1\t/**\n2\t * Profile routes — transaction history for the authenticated player.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport type { AppEnv } from \"../hono-env.js\";\n7\timport type { Db } from \"../db.js\";\n8\timport { logger } from \"../logger.js\";\n9\t\n10\texport interface ProfileRoutesDeps {\n11\t  db: Db;\n12\t}\n13\t\n14\t/** Map DB game names to frontend game IDs */\n15\tconst GAME_TO_FRONTEND: Record<string, string> = {\n16\t  coinflip: \"coinflip\",\n17\t  lord: \"lord-of-rngs\",\n18\t  closecall: \"close-call\",\n19\t};\n20\t\n21\t/** Map frontend/DB game names to canonical DB names */\n22\tconst TO_DB_GAME: Record<string, string> = {\n23\t  coinflip: \"coinflip\",\n24\t  lord: \"lord\",\n25\t  closecall: \"closecall\",\n26\t  \"lord-of-rngs\": \"lord\",\n27\t  \"close-call\": \"closecall\",\n28\t};\n29\t\n30\texport function createProfileRoutes(deps: ProfileRoutesDeps) {\n31\t  const { db } = deps;\n32\t  const app = new Hono<AppEnv>();\n33\t\n34\t  app.get(\"/transactions\", async (c) => {\n35\t    const wallet = c.get(\"wallet\");\n36\t    if (!wallet) {\n37\t      return c.json({ error: \"Authentication required\" }, 401);\n38\t    }\n39\t\n40\t    // Parse query params\n41\t    const cursor = c.req.query(\"cursor\") || undefined;\n42\t    const limitParam = c.req.query(\"limit\");\n43\t    const gameParam = c.req.query(\"game\") || undefined;\n44\t\n45\t    // Validate & clamp limit\n46\t    let limit = 20;\n47\t    if (limitParam) {\n48\t      const parsed = parseInt(limitParam, 10);\n49\t      if (!isNaN(parsed) && parsed > 0) {\n50\t        limit = Math.min(parsed, 50);\n51\t      }\n52\t    }\n53\t\n54\t    // Map game filter to DB name (accept both DB and frontend names)\n55\t    let dbGame: string | undefined;\n56\t    if (gameParam) {\n57\t      dbGame = TO_DB_GAME[gameParam];\n58\t      if (!dbGame) {\n59\t        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n60\t      }\n61\t    }\n62\t\n63\t    try {\n64\t      const rows = await db.getTransactions(wallet, cursor, limit, dbGame);\n65\t\n66\t      const transactions = rows.map((row) => ({\n67\t        id: row.id,\n68\t        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n69\t        matchId: row.match_id,\n70\t        txType: row.tx_type,\n71\t        amountLamports: String(row.amount_lamports),\n72\t        txSig: row.tx_sig,\n73\t        createdAt: row.created_at.toISOString(),\n74\t      }));\n75\t\n76\t      const nextCursor =\n77\t        transactions.length === limit\n78\t          ? String(transactions[transactions.length - 1]!.id)\n79\t          : null;\n80\t\n81\t      return c.json({ transactions, nextCursor });\n82\t    } catch (err) {\n83\t      logger.error(\"profile transactions query failed\", {\n84\t        wallet,\n85\t        error: err instanceof Error ? err.message : \"Unknown error\",\n86\t      });\n87\t      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n88\t    }\n89\t  });\n90\t\n91\t  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n92\t  app.post(\"/confirm-tx\", async (c) => {\n93\t    const wallet = c.get(\"wallet\");\n94\t    if (!wallet) {\n95\t      return c.json({ error: \"Authentication required\" }, 401);\n96\t    }\n97\t\n98\t    const body = await c.req.json<{\n99\t      game?: string;\n100\t      matchId?: string;\n101\t      txType?: string;\n102\t      txSig?: string;\n103\t      amountLamports?: number;\n104\t    }>();\n105\t\n106\t    if (!body.game || !body.matchId || !body.txType || !body.txSig || !body.amountLamports) {\n107\t      return c.json({ error: \"Missing required fields: game, matchId, txType, txSig, amountLamports\" }, 400);\n108\t    }\n109\t\n110\t    const validTypes = [\"deposit\", \"refund\"];\n111\t    if (!validTypes.includes(body.txType)) {\n112\t      return c.json({ error: `Invalid txType: ${body.txType}. Must be one of: ${validTypes.join(\", \")}` }, 400);\n113\t    }\n114\t\n115\t    // Map to DB game name\n116\t    const dbGame = TO_DB_GAME[body.game];\n117\t    if (!dbGame) {\n118\t      return c.json({ error: `Invalid game: ${body.game}` }, 400);\n119\t    }\n120\t\n121\t    try {\n122\t      await db.insertTransaction({\n123\t        wallet,\n124\t        game: dbGame,\n125\t        matchId: body.matchId,\n126\t        txType: body.txType as \"deposit\" | \"refund\",\n127\t        amountLamports: body.amountLamports,\n128\t        txSig: body.txSig,\n129\t      });\n130\t      return c.json({ ok: true });\n131\t    } catch (err) {\n132\t      logger.error(\"confirm-tx failed\", {\n133\t        wallet,\n134\t        txType: body.txType,\n135\t        error: err instanceof Error ? err.message : \"Unknown error\",\n136\t      });\n137\t      return c.json({ error: \"Failed to record transaction\" }, 500);\n138\t    }\n139\t  });\n140\t\n141\t  return app;\n142\t}\n143\t"}]},"parent_tool_use_id":null,"session_id":"b73714c7-2f31-4e13-b447-25e2a49ac6c6","uuid":"01027274-0c2a-4321-a544-3acf52f7cceb","timestamp":"2026-03-31T15:09:22.327Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/routes/profile.ts","content":"/**\n * Profile routes — transaction history for the authenticated player.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ProfileRoutesDeps {\n  db: Db;\n}\n\n/** Map DB game names to frontend game IDs */\nconst GAME_TO_FRONTEND: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord-of-rngs\",\n  closecall: \"close-call\",\n};\n\n/** Map frontend/DB game names to canonical DB names */\nconst TO_DB_GAME: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord\",\n  closecall: \"closecall\",\n  \"lord-of-rngs\": \"lord\",\n  \"close-call\": \"closecall\",\n};\n\nexport function createProfileRoutes(deps: ProfileRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  app.get(\"/transactions\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    // Parse query params\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limitParam = c.req.query(\"limit\");\n    const gameParam = c.req.query(\"game\") || undefined;\n\n    // Validate & clamp limit\n    let limit = 20;\n    if (limitParam) {\n      const parsed = parseInt(limitParam, 10);\n      if (!isNaN(parsed) && parsed > 0) {\n        limit = Math.min(parsed, 50);\n      }\n    }\n\n    // Map game filter to DB name (accept both DB and frontend names)\n    let dbGame: string | undefined;\n    if (gameParam) {\n      dbGame = TO_DB_GAME[gameParam];\n      if (!dbGame) {\n        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n      }\n    }\n\n    try {\n      const rows = await db.getTransactions(wallet, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n        matchId: row.match_id,\n        txType: row.tx_type,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return c.json({ transactions, nextCursor });\n    } catch (err) {\n      logger.error(\"profile transactions query failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    }\n  });\n\n  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n  app.post(\"/confirm-tx\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const body = await c.req.json<{\n      game?: string;\n      matchId?: string;\n      txType?: string;\n      txSig?: string;\n      amountLamports?: number;\n    }>();\n\n    if (!body.game || !body.matchId || !body.txType || !body.txSig || !body.amountLamports) {\n      return c.json({ error: \"Missing required fields: game, matchId, txType, txSig, amountLamports\" }, 400);\n    }\n\n    const validTypes = [\"deposit\", \"refund\"];\n    if (!validTypes.includes(body.txType)) {\n      return c.json({ error: `Invalid txType: ${body.txType}. Must be one of: ${validTypes.join(\", \")}` }, 400);\n    }\n\n    // Map to DB game name\n    const dbGame = TO_DB_GAME[body.game];\n    if (!dbGame) {\n      return c.json({ error: `Invalid game: ${body.game}` }, 400);\n    }\n\n    try {\n      await db.insertTransaction({\n        wallet,\n        game: dbGame,\n        matchId: body.matchId,\n        txType: body.txType as \"deposit\" | \"refund\",\n        amountLamports: body.amountLamports,\n        txSig: body.txSig,\n      });\n      return c.json({ ok: true });\n    } catch (err) {\n      logger.error(\"confirm-tx failed\", {\n        wallet,\n        txType: body.txType,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to record transaction\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":143,"startLine":1,"totalLines":143}}}
