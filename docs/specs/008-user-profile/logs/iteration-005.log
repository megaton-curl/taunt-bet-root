fy(token, config.jwtSecret, {\n        algorithms: [\"HS256\"],\n      });\n\n      if (typeof payload.sub !== \"string\") {\n        logger.warn(\"jwt auth rejected: missing sub claim\", {\n          path: c.req.path,\n        });\n        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n      }\n\n      c.set(\"wallet\", payload.sub);\n      return next();\n    } catch (err) {\n      logger.warn(\"jwt auth rejected: token verification failed\", {\n        path: c.req.path,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Invalid or expired token\" }, 401);\n    }\n  });\n}\n","structuredPatch":[{"oldStart":13,"oldLines":6,"newStart":13,"newLines":8,"lines":[" "," export interface JwtAuthConfig {","   jwtSecret: Uint8Array;","+  /** When true, require JWT for all HTTP methods (not just POST). Default: false */","+  requireAllMethods?: boolean;"," }"," "," export function createJwtAuthMiddleware(config: JwtAuthConfig) {"]}],"userModified":false,"replaceAll":false}}
