{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Btgnh7QcZCn893b52PnqkZ","type":"tool_result","content":"     1→/**\n     2→ * JWT Bearer token authentication middleware.\n     3→ *\n     4→ * Verifies HS256 JWT access tokens on POST requests.\n     5→ * Sets c.set(\"wallet\", payload.sub) for downstream handlers.\n     6→ * GET requests pass through without authentication.\n     7→ */\n     8→\n     9→import { createMiddleware } from \"hono/factory\";\n    10→import { jwtVerify } from \"jose\";\n    11→import { logger } from \"../logger.js\";\n    12→import type { AppEnv } from \"../hono-env.js\";\n    13→\n    14→export interface JwtAuthConfig {\n    15→  jwtSecret: Uint8Array;\n    16→}\n    17→\n    18→export function createJwtAuthMiddleware(config: JwtAuthConfig) {\n    19→  return createMiddleware<AppEnv>(async (c, next) => {\n    20→    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n    21→    if (c.req.method !== \"POST\") {\n    22→      return next();\n    23→    }\n    24→\n    25→    const authHeader = c.req.header(\"Authorization\");\n    26→    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n    27→      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n    28→        path: c.req.path,\n    29→      });\n    30→      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n    31→    }\n    32→\n    33→    const token = authHeader.slice(7);\n    34→    try {\n    35→      const { payload } = await jwtVerify(token, config.jwtSecret, {\n    36→        algorithms: [\"HS256\"],\n    37→      });\n    38→\n    39→      if (typeof payload.sub !== \"string\") {\n    40→        logger.warn(\"jwt auth rejected: missing sub claim\", {\n    41→          path: c.req.path,\n    42→        });\n    43→        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n    44→      }\n    45→\n    46→      c.set(\"wallet\", payload.sub);\n    47→      return next();\n    48→    } catch (err) {\n    49→      logger.warn(\"jwt auth rejected: token verification failed\", {\n    50→        path: c.req.path,\n    51→        error: err instanceof Error ? err.message : \"Unknown error\",\n    52→      });\n    53→      return c.json({ error: \"Invalid or expired token\" }, 401);\n    54→    }\n    55→  });\n    56→}\n    57→"}]},"parent_tool_use_id":null,"session_id":"bdcb16e5-995f-4f3d-baa2-b8a7a74d44d2","uuid":"d99ed942-ee6d-4f1c-9244-f68fb786efb4","timestamp":"2026-03-19T18:55:02.251Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/middleware/jwt-auth.ts","content":"/**\n * JWT Bearer token authentication middleware.\n *\n * Verifies HS256 JWT access tokens on POST requests.\n * Sets c.set(\"wallet\", payload.sub) for downstream handlers.\n * GET requests pass through without authentication.\n */\n\nimport { createMiddleware } from \"hono/factory\";\nimport { jwtVerify } from \"jose\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\n\nexport interface JwtAuthConfig {\n  jwtSecret: Uint8Array;\n}\n\nexport function createJwtAuthMiddleware(config: JwtAuthConfig) {\n  return createMiddleware<AppEnv>(async (c, next) => {\n    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n    if (c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const authHeader = c.req.header(\"Authorization\");\n    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n        path: c.req.path,\n      });\n      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n    }\n\n    const token = authHeader.slice(7);\n    try {\n      const { payload } = await jwtVerify(token, config.jwtSecret, {\n        algorithms: [\"HS256\"],\n      });\n\n      if (typeof payload.sub !== \"string\") {\n        logger.warn(\"jwt auth rejected: missing sub claim\", {\n          path: c.req.path,\n        });\n        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n      }\n\n      c.set(\"wallet\", payload.sub);\n      return next();\n    } catch (err) {\n      logger.warn(\"jwt auth rejected: token verification failed\", {\n        path: c.req.path,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Invalid or expired token\" }, 401);\n    }\n  });\n}\n","numLines":57,"startLine":1,"totalLines":57}}}
