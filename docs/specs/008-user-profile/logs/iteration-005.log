thorization header\", {\n        path: c.req.path,\n      });\n      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n    }\n\n    const token = authHeader.slice(7);\n    try {\n      const { payload } = await jwtVerify(token, config.jwtSecret, {\n        algorithms: [\"HS256\"],\n      });\n\n      if (typeof payload.sub !== \"string\") {\n        logger.warn(\"jwt auth rejected: missing sub claim\", {\n          path: c.req.path,\n        });\n        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n      }\n\n      c.set(\"wallet\", payload.sub);\n      return next();\n    } catch (err) {\n      logger.warn(\"jwt auth rejected: token verification failed\", {\n        path: c.req.path,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Invalid or expired token\" }, 401);\n    }\n  });\n}\n","structuredPatch":[{"oldStart":20,"oldLines":7,"newStart":20,"newLines":8,"lines":[" export function createJwtAuthMiddleware(config: JwtAuthConfig) {","   return createMiddleware<AppEnv>(async (c, next) => {","     // Skip authentication for non-POST requests (GET, OPTIONS, etc.)","-    if (c.req.method !== \"POST\") {","+    // unless requireAllMethods is set (e.g., profile endpoints)","+    if (!config.requireAllMethods && c.req.method !== \"POST\") {","       return next();","     }"," "]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01L782a6L97MsG2sUznUUork","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the profile route:"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1999,"cache_read_input_tokens":45242,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1999},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bdcb16e5-995f-4f3d-baa2-b8a7a74d44d2","uuid":"98bea163-f070-4b9f-9d73-bcfe554560bf"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01L782a6L97MsG2sUznUUork","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015GpKy1YTZXhB8vLL1hRVj1","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/profile.ts","content":"/**\n * Profile routes — transaction history for the authenticated player.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ProfileRoutesDeps {\n  db: Db;\n}\n\n/** Map DB game names to frontend game IDs */\nconst GAME_TO_FRONTEND: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord-of-rngs\",\n  closecall: \"close-call\",\n};\n\n/** Map frontend/DB game names to canonical DB names */\nconst TO_DB_GAME: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord\",\n  closecall: \"closecall\",\n  \"lord-of-rngs\": \"lord\",\n  \"close-call\": \"closecall\",\n};\n\nexport function createProfileRoutes(deps: ProfileRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  app.get(\"/transactions\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    // Parse query params\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limitParam = c.req.query(\"limit\");\n    const gameParam = c.req.query(\"game\") || undefined;\n\n    // Validate & clamp limit\n    let limit = 20;\n    if (limitParam) {\n      const parsed = parseInt(limitParam, 10);\n      if (!isNaN(parsed) && parsed > 0) {\n        limit = Math.min(parsed, 50);\n      }\n    }\n\n    // Map game filter to DB name (accept both DB and frontend names)\n    let dbGame: string | undefined;\n    if (gameParam) {\n      dbGame = TO_DB_GAME[gameParam];\n      if (!dbGame) {\n        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n      }\n    }\n\n    try {\n      const rows = await db.getUserTransactions(wallet, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n        matchId: row.match_id,\n        event: row.event,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return c.json({ transactions, nextCursor });\n    } catch (err) {\n      logger.error(\"profile transactions query failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    }\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1999,"cache_read_input_tokens":45242,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1999},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bdcb16e5-995f-4f3d-baa2-b8a7a74d44d2","uuid":"1b20b2e5-556e-4eac-8e03-5d8cd4d10a1f"}
