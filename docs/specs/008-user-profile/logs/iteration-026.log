{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GPjbJQZ4PJoUSJdK18eYNr","type":"tool_result","content":"1\t/**\n2\t * Public profile routes — unauthenticated lookup by user_id or username.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport type { Db } from \"../db.js\";\n7\timport { logger } from \"../logger.js\";\n8\t\n9\texport interface PublicProfileRoutesDeps {\n10\t  db: Db;\n11\t}\n12\t\n13\texport function createPublicProfileRoutes(deps: PublicProfileRoutesDeps) {\n14\t  const { db } = deps;\n15\t  const app = new Hono();\n16\t\n17\t  // GET /:identifier — public profile lookup (no auth)\n18\t  app.get(\"/:identifier\", async (c) => {\n19\t    const identifier = c.req.param(\"identifier\");\n20\t\n21\t    try {\n22\t      const profile = await db.getProfileByIdentifier(identifier);\n23\t      if (!profile) {\n24\t        return c.json({ error: \"NOT_FOUND\" }, 404);\n25\t      }\n26\t\n27\t      const publicStats = await db.getPublicPlayerStats(profile.wallet);\n28\t\n29\t      return c.json({\n30\t        userId: profile.user_id,\n31\t        username: profile.username,\n32\t        avatarUrl: profile.avatar_url,\n33\t        heatMultiplier: profile.heat_multiplier,\n34\t        stats: {\n35\t          gamesPlayed: publicStats.gamesPlayed,\n36\t          totalWins: publicStats.totalWins,\n37\t          winRate: publicStats.winRate,\n38\t        },\n39\t        createdAt: profile.created_at.toISOString(),\n40\t      });\n41\t    } catch (err) {\n42\t      logger.error(\"public-profile lookup failed\", {\n43\t        identifier,\n44\t        error: err instanceof Error ? err.message : \"Unknown error\",\n45\t      });\n46\t      return c.json({ error: \"Failed to fetch profile\" }, 500);\n47\t    }\n48\t  });\n49\t\n50\t  return app;\n51\t}\n52\t"}]},"parent_tool_use_id":null,"session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"ce50820e-d066-4c86-a2a1-9921b62c7c16","timestamp":"2026-03-31T15:33:32.354Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/routes/public-profile.ts","content":"/**\n * Public profile routes — unauthenticated lookup by user_id or username.\n */\n\nimport { Hono } from \"hono\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface PublicProfileRoutesDeps {\n  db: Db;\n}\n\nexport function createPublicProfileRoutes(deps: PublicProfileRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono();\n\n  // GET /:identifier — public profile lookup (no auth)\n  app.get(\"/:identifier\", async (c) => {\n    const identifier = c.req.param(\"identifier\");\n\n    try {\n      const profile = await db.getProfileByIdentifier(identifier);\n      if (!profile) {\n        return c.json({ error: \"NOT_FOUND\" }, 404);\n      }\n\n      const publicStats = await db.getPublicPlayerStats(profile.wallet);\n\n      return c.json({\n        userId: profile.user_id,\n        username: profile.username,\n        avatarUrl: profile.avatar_url,\n        heatMultiplier: profile.heat_multiplier,\n        stats: {\n          gamesPlayed: publicStats.gamesPlayed,\n          totalWins: publicStats.totalWins,\n          winRate: publicStats.winRate,\n        },\n        createdAt: profile.created_at.toISOString(),\n      });\n    } catch (err) {\n      logger.error(\"public-profile lookup failed\", {\n        identifier,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch profile\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":52,"startLine":1,"totalLines":52}}}
