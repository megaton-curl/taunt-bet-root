{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WirhrtDsN9aY9xQd3dHL9w","type":"tool_result","content":"1\t/**\n2\t * Auth routes: challenge/verify/refresh/logout for JWT session management.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport { randomBytes, createHash } from \"node:crypto\";\n7\timport nacl from \"tweetnacl\";\n8\timport bs58 from \"bs58\";\n9\timport { SignJWT } from \"jose\";\n10\timport type { AuthDb } from \"../auth-db.js\";\n11\timport type { Db } from \"../db.js\";\n12\timport { logger } from \"../logger.js\";\n13\t\n14\texport interface AuthRoutesDeps {\n15\t  authDb: AuthDb;\n16\t  db: Db;\n17\t  jwtSecret: Uint8Array;\n18\t  cluster: string;\n19\t  challengeTtlSeconds: number;\n20\t  accessTokenTtlSeconds: number;\n21\t  refreshTokenTtlDays: number;\n22\t}\n23\t\n24\tfunction hashToken(token: string): Buffer {\n25\t  return createHash(\"sha256\").update(token).digest();\n26\t}\n27\t\n28\tfunction buildSignInMessage(\n29\t  wallet: string,\n30\t  cluster: string,\n31\t  nonce: string,\n32\t  issuedAt: string,\n33\t  expiresAt: string,\n34\t): string {\n35\t  return [\n36\t    \"Sign in to RNG Utopia\",\n37\t    `Wallet: ${wallet}`,\n38\t    `Cluster: ${cluster}`,\n39\t    `Nonce: ${nonce}`,\n40\t    `Issued At: ${issuedAt}`,\n41\t    `Expires At: ${expiresAt}`,\n42\t    \"This signature creates a backend session for gameplay actions.\",\n43\t    \"It does not approve a blockchain transaction.\",\n44\t  ].join(\"\\n\");\n45\t}\n46\t\n47\texport function createAuthRoutes(deps: AuthRoutesDeps): Hono {\n48\t  const {\n49\t    authDb,\n50\t    db,\n51\t    jwtSecret,\n52\t    cluster,\n53\t    challengeTtlSeconds,\n54\t    accessTokenTtlSeconds,\n55\t    refreshTokenTtlDays,\n56\t  } = deps;\n57\t\n58\t  const app = new Hono();\n59\t\n60\t  // POST /challenge — generate nonce + human-readable message\n61\t  app.post(\"/challenge\", async (c) => {\n62\t    let body: { wallet: string };\n63\t    try {\n64\t      body = await c.req.json();\n65\t      if (typeof body.wallet !== \"string\" || body.wallet.length === 0) {\n66\t        return c.json({ error: \"wallet is required\" }, 400);\n67\t      }\n68\t    } catch {\n69\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n70\t    }\n71\t\n72\t    const nonce = randomBytes(32).toString(\"hex\");\n73\t    const now = new Date();\n74\t    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n75\t\n76\t    const message = buildSignInMessage(\n77\t      body.wallet,\n78\t      cluster,\n79\t      nonce,\n80\t      now.toISOString(),\n81\t      expiresAt.toISOString(),\n82\t    );\n83\t\n84\t    await authDb.insertChallenge(nonce, body.wallet, cluster, message, expiresAt);\n85\t\n86\t    logger.info(\"auth challenge issued\", { wallet: body.wallet, nonce });\n87\t\n88\t    return c.json({\n89\t      nonce,\n90\t      message,\n91\t      expiresAt: expiresAt.toISOString(),\n92\t    });\n93\t  });\n94\t\n95\t  // POST /verify — consume challenge, verify signature, issue tokens\n96\t  app.post(\"/verify\", async (c) => {\n97\t    let body: { nonce: string; wallet: string; signature: string };\n98\t    try {\n99\t      body = await c.req.json();\n100\t      if (\n101\t        typeof body.nonce !== \"string\" ||\n102\t        typeof body.wallet !== \"string\" ||\n103\t        typeof body.signature !== \"string\"\n104\t      ) {\n105\t        return c.json({ error: \"nonce, wallet, and signature are required\" }, 400);\n106\t      }\n107\t    } catch {\n108\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n109\t    }\n110\t\n111\t    // Atomically consume the challenge\n112\t    const challenge = await authDb.consumeChallenge(body.nonce);\n113\t    if (!challenge) {\n114\t      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n115\t        nonce: body.nonce,\n116\t        wallet: body.wallet,\n117\t      });\n118\t      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n119\t    }\n120\t\n121\t    // Verify wallet matches challenge\n122\t    if (challenge.wallet !== body.wallet) {\n123\t      logger.warn(\"auth verify rejected: wallet mismatch\", {\n124\t        nonce: body.nonce,\n125\t        challengeWallet: challenge.wallet,\n126\t        requestWallet: body.wallet,\n127\t      });\n128\t      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n129\t    }\n130\t\n131\t    // Verify Ed25519 signature over the challenge message\n132\t    let sigBytes: Uint8Array;\n133\t    let pubkeyBytes: Uint8Array;\n134\t    try {\n135\t      sigBytes = bs58.decode(body.signature);\n136\t      pubkeyBytes = bs58.decode(body.wallet);\n137\t    } catch {\n138\t      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n139\t    }\n140\t\n141\t    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n142\t      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n143\t    }\n144\t\n145\t    const messageBytes = new TextEncoder().encode(challenge.message);\n146\t    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n147\t    if (!valid) {\n148\t      logger.warn(\"auth verify rejected: signature verification failed\", {\n149\t        wallet: body.wallet,\n150\t      });\n151\t      return c.json({ error: \"Invalid signature\" }, 401);\n152\t    }\n153\t\n154\t    // Ensure player profile exists (fire-and-forget — auth must not fail on this)\n155\t    try {\n156\t      const existing = await db.getProfileByWallet(body.wallet);\n157\t      if (!existing) {\n158\t        await db.createPlayerProfile(body.wallet);\n159\t        logger.info(\"player profile auto-created\", { wallet: body.wallet });\n160\t      }\n161\t    } catch (e) {\n162\t      logger.error(\"profile creation failed (non-blocking)\", { wallet: body.wallet, error: e });\n163\t    }\n164\t\n165\t    // Issue JWT access token\n166\t    const now = Math.floor(Date.now() / 1000);\n167\t    const accessToken = await new SignJWT({ sub: body.wallet })\n168\t      .setProtectedHeader({ alg: \"HS256\" })\n169\t      .setIssuedAt(now)\n170\t      .setExpirationTime(now + accessTokenTtlSeconds)\n171\t      .sign(jwtSecret);\n172\t\n173\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n174\t\n175\t    // Generate opaque refresh token\n176\t    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n177\t    const refreshTokenHash = hashToken(refreshTokenRaw);\n178\t    const familyId = randomBytes(16).toString(\"hex\");\n179\t    const refreshExpiresAt = new Date(\n180\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n181\t    );\n182\t\n183\t    await authDb.insertRefreshToken(\n184\t      body.wallet,\n185\t      refreshTokenHash,\n186\t      familyId,\n187\t      refreshExpiresAt,\n188\t    );\n189\t\n190\t    logger.info(\"auth session created\", { wallet: body.wallet });\n191\t\n192\t    return c.json({\n193\t      accessToken,\n194\t      accessExpiresAt,\n195\t      refreshToken: refreshTokenRaw,\n196\t      refreshExpiresAt: refreshExpiresAt.toISOString(),\n197\t    });\n198\t  });\n199\t\n200\t  // POST /refresh — rotate refresh token, issue new access token\n201\t  app.post(\"/refresh\", async (c) => {\n202\t    let body: { refreshToken: string };\n203\t    try {\n204\t      body = await c.req.json();\n205\t      if (typeof body.refreshToken !== \"string\") {\n206\t        return c.json({ error: \"refreshToken is required\" }, 400);\n207\t      }\n208\t    } catch {\n209\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n210\t    }\n211\t\n212\t    const tokenHash = hashToken(body.refreshToken);\n213\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n214\t\n215\t    if (!stored) {\n216\t      logger.warn(\"auth refresh rejected: token not found\");\n217\t      return c.json({ error: \"Invalid refresh token\" }, 401);\n218\t    }\n219\t\n220\t    // Reuse detection: if the token was already revoked, someone replayed it.\n221\t    // Revoke the entire family as a precaution.\n222\t    if (stored.revoked) {\n223\t      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n224\t        wallet: stored.wallet,\n225\t        familyId: stored.family_id,\n226\t      });\n227\t      await authDb.revokeTokenFamily(stored.family_id);\n228\t      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n229\t    }\n230\t\n231\t    // Check expiry\n232\t    if (new Date() > stored.expires_at) {\n233\t      logger.warn(\"auth refresh rejected: token expired\", {\n234\t        wallet: stored.wallet,\n235\t      });\n236\t      await authDb.revokeRefreshToken(stored.id);\n237\t      return c.json({ error: \"Refresh token expired\" }, 401);\n238\t    }\n239\t\n240\t    // Revoke old token\n241\t    await authDb.revokeRefreshToken(stored.id);\n242\t\n243\t    // Issue new access token\n244\t    const now = Math.floor(Date.now() / 1000);\n245\t    const accessToken = await new SignJWT({ sub: stored.wallet })\n246\t      .setProtectedHeader({ alg: \"HS256\" })\n247\t      .setIssuedAt(now)\n248\t      .setExpirationTime(now + accessTokenTtlSeconds)\n249\t      .sign(jwtSecret);\n250\t\n251\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n252\t\n253\t    // Issue new refresh token in the same family\n254\t    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n255\t    const newRefreshHash = hashToken(newRefreshRaw);\n256\t    const newRefreshExpiresAt = new Date(\n257\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n258\t    );\n259\t\n260\t    await authDb.insertRefreshToken(\n261\t      stored.wallet,\n262\t      newRefreshHash,\n263\t      stored.family_id,\n264\t      newRefreshExpiresAt,\n265\t    );\n266\t\n267\t    logger.debug(\"auth token refreshed\", { wallet: stored.wallet });\n268\t\n269\t    return c.json({\n270\t      accessToken,\n271\t      accessExpiresAt,\n272\t      refreshToken: newRefreshRaw,\n273\t      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n274\t    });\n275\t  });\n276\t\n277\t  // POST /logout — revoke refresh token\n278\t  app.post(\"/logout\", async (c) => {\n279\t    let body: { refreshToken: string };\n280\t    try {\n281\t      body = await c.req.json();\n282\t      if (typeof body.refreshToken !== \"string\") {\n283\t        return c.body(null, 204);\n284\t      }\n285\t    } catch {\n286\t      return c.body(null, 204);\n287\t    }\n288\t\n289\t    const tokenHash = hashToken(body.refreshToken);\n290\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n291\t    if (stored) {\n292\t      await authDb.revokeRefreshToken(stored.id);\n293\t      logger.info(\"auth logout\", { wallet: stored.wallet });\n294\t    }\n295\t\n296\t    return c.body(null, 204);\n297\t  });\n298\t\n299\t  return app;\n300\t}\n301\t"}]},"parent_tool_use_id":"toolu_01XTJDDLrAJBf3ugVpnMmc5L","session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"9d5c5b96-4bc1-41f4-9683-d434eb112811","timestamp":"2026-03-31T15:32:45.012Z"}
