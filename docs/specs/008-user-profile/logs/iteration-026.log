  if (!profile) {\n        return c.json({ error: \"PROFILE_NOT_FOUND\" }, 404);\n      }\n\n      const [stats, streaks, breakdown] = await Promise.all([\n        db.getPlayerStats(wallet),\n        db.getWinStreaks(wallet),\n        db.getGameBreakdown(wallet),\n      ]);\n\n      // Serialize BigInt fields as strings, compute next edit timestamp\n      const usernameNextEditAt = profile.username_updated_at\n        ? new Date(profile.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n        : null;\n\n      // Map breakdown BigInt values to strings\n      const serializedBreakdown: Record<string, object> = {};\n      for (const [game, gs] of Object.entries(breakdown)) {\n        serializedBreakdown[game] = {\n          gamesPlayed: gs.gamesPlayed,\n          totalWagered: String(gs.totalWagered),\n          totalWins: gs.totalWins,\n          winRate: gs.winRate,\n          netPnl: String(gs.netPnl),\n        };\n      }\n\n      return c.json({\n        userId: profile.user_id,\n        username: profile.username,\n        avatarUrl: profile.avatar_url,\n        heatMultiplier: profile.heat_multiplier,\n        pointsBalance: String(profile.points_balance),\n        stats: {\n          gamesPlayed: stats.gamesPlayed,\n          totalWagered: String(stats.totalWagered),\n          totalWins: stats.totalWins,\n          winRate: stats.winRate,\n          winStreakCurrent: streaks.current,\n          winStreakBest: streaks.best,\n          netPnl: String(stats.netPnl),\n          gameBreakdown: serializedBreakdown,\n        },\n        usernameNextEditAt,\n        createdAt: profile.created_at.toISOString(),\n      });\n    } catch (err) {\n      logger.error(\"profile/me failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch profile\" }, 500);\n    }\n  });\n\n  // PUT /username — change username for authenticated player\n  app.put(\"/username\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    let body: { username?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"INVALID_FORMAT\" }, 400);\n    }\n\n    const username = body.username;\n    if (!username || !/^[a-zA-Z0-9_-]{3,20}$/.test(username)) {\n      return c.json({ error: \"INVALID_FORMAT\" }, 400);\n    }\n\n    try {\n      const profile = await db.getProfileByWallet(wallet);\n      if (!profile) {\n        return c.json({ error: \"PROFILE_NOT_FOUND\" }, 404);\n      }\n\n      // Check cooldown before calling updateUsername to return proper 429\n      if (profile.username_updated_at) {\n        const cooldownMs = 30 * 24 * 60 * 60 * 1000; // 30 days\n        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n        if (elapsed < cooldownMs) {\n          const nextEditAvailableAt = new Date(\n            new Date(profile.username_updated_at).getTime() + cooldownMs,\n          ).toISOString();\n          return c.json({ error: \"COOLDOWN_ACTIVE\", nextEditAvailableAt }, 429);\n        }\n      }\n\n      const updated = await db.updateUsername(wallet, username);\n\n      const nextEditAvailableAt = updated.username_updated_at\n        ? new Date(updated.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n        : null;\n\n      return c.json({ username: updated.username, nextEditAvailableAt });\n    } catch (err: unknown) {\n      // UNIQUE violation from postgres (case-insensitive index)\n      const errCode = (err as { code?: string })?.code;\n      if (\n        (err instanceof Error && err.message.includes(\"unique\")) || errCode === \"23505\"\n      ) {\n        return c.json({ error: \"USERNAME_TAKEN\" }, 409);\n      }\n      // Cooldown from db.updateUsername (race condition fallback)\n      if (err && typeof err === \"object\" && \"cooldown\" in err) {\n        const cooldownErr = err as unknown as { nextEditAvailableAt: Date };\n        if (cooldownErr.nextEditAvailableAt) {\n          return c.json({ error: \"COOLDOWN_ACTIVE\", nextEditAvailableAt: cooldownErr.nextEditAvailableAt.toISOString() }, 429);\n        }\n      }\n      logger.error(\"profile/username update failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to update username\" }, 500);\n    }\n  });\n\n  app.get(\"/transactions\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    // Parse query params\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limitParam = c.req.query(\"limit\");\n    const gameParam = c.req.query(\"game\") || undefined;\n\n    // Validate & clamp limit\n    let limit = 20;\n    if (limitParam) {\n      const parsed = parseInt(limitParam, 10);\n      if (!isNaN(parsed) && parsed > 0) {\n        limit = Math.min(parsed, 50);\n      }\n    }\n\n    // Map game filter to DB name (accept both DB and frontend names)\n    let dbGame: string | undefined;\n    if (gameParam) {\n      dbGame = TO_DB_GAME[gameParam];\n      if (!dbGame) {\n        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n      }\n    }\n\n    try {\n      const rows = await db.getTransactions(wallet, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n        matchId: row.match_id,\n        txType: row.tx_type,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return c.json({ transactions, nextCursor });\n    } catch (err) {\n      logger.error(\"profile transactions query failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    }\n  });\n\n  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n  app.post(\"/confirm-tx\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const body = await c.req.json<{\n      game?: string;\n      matchId?: string;\n      txType?: string;\n      txSig?: string;\n      amountLamports?: number;\n    }>();\n\n    if (!body.game || !body.matchId || !body.txType || !body.txSig || !body.amountLamports) {\n      return c.json({ error: \"Missing required fields: game, matchId, txType, txSig, amountLamports\" }, 400);\n    }\n\n    const validTypes = [\"deposit\", \"refund\"];\n    if (!validTypes.includes(body.txType)) {\n      return c.json({ error: `Invalid txType: ${body.txType}. Must be one of: ${validTypes.join(\", \")}` }, 400);\n    }\n\n    // Map to DB game name\n    const dbGame = TO_DB_GAME[body.game];\n    if (!dbGame) {\n      return c.json({ error: `Invalid game: ${body.game}` }, 400);\n    }\n\n    try {\n      await db.insertTransaction({\n        wallet,\n        game: dbGame,\n        matchId: body.matchId,\n        txType: body.txType as \"deposit\" | \"refund\",\n        amountLamports: body.amountLamports,\n        txSig: body.txSig,\n      });\n      return c.json({ ok: true });\n    } catch (err) {\n      logger.error(\"confirm-tx failed\", {\n        wallet,\n        txType: body.txType,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to record transaction\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":274,"startLine":1,"totalLines":274}}}
