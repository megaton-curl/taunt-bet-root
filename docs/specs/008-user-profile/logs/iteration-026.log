{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014Fyw1nXAzqpUX9CJSAhSBC","type":"tool_result","content":"1\t/**\n2\t * Profile routes — transaction history for the authenticated player.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport type { AppEnv } from \"../hono-env.js\";\n7\timport type { Db } from \"../db.js\";\n8\timport { logger } from \"../logger.js\";\n9\t\n10\texport interface ProfileRoutesDeps {\n11\t  db: Db;\n12\t}\n13\t\n14\t/** Map DB game names to frontend game IDs */\n15\tconst GAME_TO_FRONTEND: Record<string, string> = {\n16\t  coinflip: \"coinflip\",\n17\t  lord: \"lord-of-rngs\",\n18\t  closecall: \"close-call\",\n19\t};\n20\t\n21\t/** Map frontend/DB game names to canonical DB names */\n22\tconst TO_DB_GAME: Record<string, string> = {\n23\t  coinflip: \"coinflip\",\n24\t  lord: \"lord\",\n25\t  closecall: \"closecall\",\n26\t  \"lord-of-rngs\": \"lord\",\n27\t  \"close-call\": \"closecall\",\n28\t};\n29\t\n30\texport function createProfileRoutes(deps: ProfileRoutesDeps) {\n31\t  const { db } = deps;\n32\t  const app = new Hono<AppEnv>();\n33\t\n34\t  // GET /me — full profile + stats for authenticated player\n35\t  app.get(\"/me\", async (c) => {\n36\t    const wallet = c.get(\"wallet\");\n37\t    if (!wallet) {\n38\t      return c.json({ error: \"Authentication required\" }, 401);\n39\t    }\n40\t\n41\t    try {\n42\t      const profile = await db.getProfileByWallet(wallet);\n43\t      if (!profile) {\n44\t        return c.json({ error: \"PROFILE_NOT_FOUND\" }, 404);\n45\t      }\n46\t\n47\t      const [stats, streaks, breakdown] = await Promise.all([\n48\t        db.getPlayerStats(wallet),\n49\t        db.getWinStreaks(wallet),\n50\t        db.getGameBreakdown(wallet),\n51\t      ]);\n52\t\n53\t      // Serialize BigInt fields as strings, compute next edit timestamp\n54\t      const usernameNextEditAt = profile.username_updated_at\n55\t        ? new Date(profile.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n56\t        : null;\n57\t\n58\t      // Map breakdown BigInt values to strings\n59\t      const serializedBreakdown: Record<string, object> = {};\n60\t      for (const [game, gs] of Object.entries(breakdown)) {\n61\t        serializedBreakdown[game] = {\n62\t          gamesPlayed: gs.gamesPlayed,\n63\t          totalWagered: String(gs.totalWagered),\n64\t          totalWins: gs.totalWins,\n65\t          winRate: gs.winRate,\n66\t          netPnl: String(gs.netPnl),\n67\t        };\n68\t      }\n69\t\n70\t      return c.json({\n71\t        userId: profile.user_id,\n72\t        username: profile.username,\n73\t        avatarUrl: profile.avatar_url,\n74\t        heatMultiplier: profile.heat_multiplier,\n75\t        pointsBalance: String(profile.points_balance),\n76\t        stats: {\n77\t          gamesPlayed: stats.gamesPlayed,\n78\t          totalWagered: String(stats.totalWagered),\n79\t          totalWins: stats.totalWins,\n80\t          winRate: stats.winRate,\n81\t          winStreakCurrent: streaks.current,\n82\t          winStreakBest: streaks.best,\n83\t          netPnl: String(stats.netPnl),\n84\t          gameBreakdown: serializedBreakdown,\n85\t        },\n86\t        usernameNextEditAt,\n87\t        createdAt: profile.created_at.toISOString(),\n88\t      });\n89\t    } catch (err) {\n90\t      logger.error(\"profile/me failed\", {\n91\t        wallet,\n92\t        error: err instanceof Error ? err.message : \"Unknown error\",\n93\t      });\n94\t      return c.json({ error: \"Failed to fetch profile\" }, 500);\n95\t    }\n96\t  });\n97\t\n98\t  // PUT /username — change username for authenticated player\n99\t  app.put(\"/username\", async (c) => {\n100\t    const wallet = c.get(\"wallet\");\n101\t    if (!wallet) {\n102\t      return c.json({ error: \"Authentication required\" }, 401);\n103\t    }\n104\t\n105\t    let body: { username?: string };\n106\t    try {\n107\t      body = await c.req.json();\n108\t    } catch {\n109\t      return c.json({ error: \"INVALID_FORMAT\" }, 400);\n110\t    }\n111\t\n112\t    const username = body.username;\n113\t    if (!username || !/^[a-zA-Z0-9_-]{3,20}$/.test(username)) {\n114\t      return c.json({ error: \"INVALID_FORMAT\" }, 400);\n115\t    }\n116\t\n117\t    try {\n118\t      const profile = await db.getProfileByWallet(wallet);\n119\t      if (!profile) {\n120\t        return c.json({ error: \"PROFILE_NOT_FOUND\" }, 404);\n121\t      }\n122\t\n123\t      // Check cooldown before calling updateUsername to return proper 429\n124\t      if (profile.username_updated_at) {\n125\t        const cooldownMs = 30 * 24 * 60 * 60 * 1000; // 30 days\n126\t        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n127\t        if (elapsed < cooldownMs) {\n128\t          const nextEditAvailableAt = new Date(\n129\t            new Date(profile.username_updated_at).getTime() + cooldownMs,\n130\t          ).toISOString();\n131\t          return c.json({ error: \"COOLDOWN_ACTIVE\", nextEditAvailableAt }, 429);\n132\t        }\n133\t      }\n134\t\n135\t      const updated = await db.updateUsername(wallet, username);\n136\t\n137\t      const nextEditAvailableAt = updated.username_updated_at\n138\t        ? new Date(updated.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n139\t        : null;\n140\t\n141\t      return c.json({ username: updated.username, nextEditAvailableAt });\n142\t    } catch (err: unknown) {\n143\t      // UNIQUE violation from postgres (case-insensitive index)\n144\t      const errCode = (err as { code?: string })?.code;\n145\t      if (\n146\t        (err instanceof Error && err.message.includes(\"unique\")) || errCode === \"23505\"\n147\t      ) {\n148\t        return c.json({ error: \"USERNAME_TAKEN\" }, 409);\n149\t      }\n150\t      // Cooldown from db.updateUsername (race condition fallback)\n151\t      if (err && typeof err === \"object\" && \"cooldown\" in err) {\n152\t        const cooldownErr = err as unknown as { nextEditAvailableAt: Date };\n153\t        if (cooldownErr.nextEditAvailableAt) {\n154\t          return c.json({ error: \"COOLDOWN_ACTIVE\", nextEditAvailableAt: cooldownErr.nextEditAvailableAt.toISOString() }, 429);\n155\t        }\n156\t      }\n157\t      logger.error(\"profile/username update failed\", {\n158\t        wallet,\n159\t        error: err instanceof Error ? err.message : \"Unknown error\",\n160\t      });\n161\t      return c.json({ error: \"Failed to update username\" }, 500);\n162\t    }\n163\t  });\n164\t\n165\t  app.get(\"/transactions\", async (c) => {\n166\t    const wallet = c.get(\"wallet\");\n167\t    if (!wallet) {\n168\t      return c.json({ error: \"Authentication required\" }, 401);\n169\t    }\n170\t\n171\t    // Parse query params\n172\t    const cursor = c.req.query(\"cursor\") || undefined;\n173\t    const limitParam = c.req.query(\"limit\");\n174\t    const gameParam = c.req.query(\"game\") || undefined;\n175\t\n176\t    // Validate & clamp limit\n177\t    let limit = 20;\n178\t    if (limitParam) {\n179\t      const parsed = parseInt(limitParam, 10);\n180\t      if (!isNaN(parsed) && parsed > 0) {\n181\t        limit = Math.min(parsed, 50);\n182\t      }\n183\t    }\n184\t\n185\t    // Map game filter to DB name (accept both DB and frontend names)\n186\t    let dbGame: string | undefined;\n187\t    if (gameParam) {\n188\t      dbGame = TO_DB_GAME[gameParam];\n189\t      if (!dbGame) {\n190\t        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n191\t      }\n192\t    }\n193\t\n194\t    try {\n195\t      const rows = await db.getTransactions(wallet, cursor, limit, dbGame);\n196\t\n197\t      const transactions = rows.map((row) => ({\n198\t        id: row.id,\n199\t        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n200\t        matchId: row.match_id,\n201\t        txType: row.tx_type,\n202\t        amountLamports: String(row.amount_lamports),\n203\t        txSig: row.tx_sig,\n204\t        createdAt: row.created_at.toISOString(),\n205\t      }));\n206\t\n207\t      const nextCursor =\n208\t        transactions.length === limit\n209\t          ? String(transactions[transactions.length - 1]!.id)\n210\t          : null;\n211\t\n212\t      return c.json({ transactions, nextCursor });\n213\t    } catch (err) {\n214\t      logger.error(\"profile transactions query failed\", {\n215\t        wallet,\n216\t        error: err instanceof Error ? err.message : \"Unknown error\",\n217\t      });\n218\t      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n219\t    }\n220\t  });\n221\t\n222\t  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n223\t  app.post(\"/confirm-tx\", async (c) => {\n224\t    const wallet = c.get(\"wallet\");\n225\t    if (!wallet) {\n226\t      return c.json({ error: \"Authentication required\" }, 401);\n227\t    }\n228\t\n229\t    const body = await c.req.json<{\n230\t      game?: string;\n231\t      matchId?: string;\n232\t      txType?: string;\n233\t      txSig?: string;\n234\t      amountLamports?: number;\n235\t    }>();\n236\t\n237\t    if (!body.game || !body.matchId || !body.txType || !body.txSig || !body.amountLamports) {\n238\t      return c.json({ error: \"Missing required fields: game, matchId, txType, txSig, amountLamports\" }, 400);\n239\t    }\n240\t\n241\t    const validTypes = [\"deposit\", \"refund\"];\n242\t    if (!validTypes.includes(body.txType)) {\n243\t      return c.json({ error: `Invalid txType: ${body.txType}. Must be one of: ${validTypes.join(\", \")}` }, 400);\n244\t    }\n245\t\n246\t    // Map to DB game name\n247\t    const dbGame = TO_DB_GAME[body.game];\n248\t    if (!dbGame) {\n249\t      return c.json({ error: `Invalid game: ${body.game}` }, 400);\n250\t    }\n251\t\n252\t    try {\n253\t      await db.insertTransaction({\n254\t        wallet,\n255\t        game: dbGame,\n256\t        matchId: body.matchId,\n257\t        txType: body.txType as \"deposit\" | \"refund\",\n258\t        amountLamports: body.amountLamports,\n259\t        txSig: body.txSig,\n260\t      });\n261\t      return c.json({ ok: true });\n262\t    } catch (err) {\n263\t      logger.error(\"confirm-tx failed\", {\n264\t        wallet,\n265\t        txType: body.txType,\n266\t        error: err instanceof Error ? err.message : \"Unknown error\",\n267\t      });\n268\t      return c.json({ error: \"Failed to record transaction\" }, 500);\n269\t    }\n270\t  });\n271\t\n272\t  return app;\n273\t}\n274\t"}]},"parent_tool_use_id":"toolu_01XTJDDLrAJBf3ugVpnMmc5L","session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"e8aad7b8-2bff-48f0-ad77-02792e8ac7c5","timestamp":"2026-03-31T15:32:44.633Z"}
