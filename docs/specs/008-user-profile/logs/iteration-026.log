{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01831dCUVcVKsNZRV4wFRPzP","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { swaggerUI } from \"@hono/swagger-ui\";\n20\timport { spec } from \"./openapi.js\";\n21\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n22\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n23\timport { createSettlementWorker } from \"./worker/settlement.js\";\n24\timport { settleRound } from \"./worker/settle-tx.js\";\n25\timport { createRetrySettler } from \"./worker/retry.js\";\n26\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n27\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n28\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n29\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n30\timport { logger } from \"./logger.js\";\n31\t\n32\tconst config = loadConfig();\n33\t\n34\t// Single postgres pool shared by game DB, auth DB, and all workers\n35\tconst sql = postgres(config.databaseUrl);\n36\tconst db = createDb(config.databaseUrl, sql);\n37\tconst authDb = createAuthDb(sql);\n38\t\n39\tconst connection = new Connection(config.rpcUrl, {\n40\t  commitment: \"confirmed\",\n41\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n42\t});\n43\t\n44\tconst app = new Hono();\n45\t\n46\tapp.use(\n47\t  \"*\",\n48\t  cors({\n49\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n50\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n51\t    allowHeaders: [\"Content-Type\", \"Authorization\"],\n52\t  }),\n53\t);\n54\t\n55\t// Request logging — correlate frontend fetch timing with server-side processing\n56\tapp.use(\"*\", async (c, next) => {\n57\t  const start = Date.now();\n58\t  await next();\n59\t  const ms = Date.now() - start;\n60\t  const method = c.req.method;\n61\t  const path = c.req.path;\n62\t  // Skip noisy health checks and OPTIONS preflight\n63\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n64\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n65\t});\n66\t\n67\t// API docs — Swagger UI + raw OpenAPI spec\n68\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n69\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n70\t\n71\t// Auth routes — no JWT middleware (these are the login endpoints)\n72\t// Lighter rate limiting by IP for auth endpoints\n73\tapp.use(\n74\t  \"/auth/*\",\n75\t  createRateLimitMiddleware({\n76\t    perWallet: 20,\n77\t    global: config.rateLimitGlobal,\n78\t    windowMs: 60_000,\n79\t  }),\n80\t);\n81\t\n82\tapp.route(\n83\t  \"/auth\",\n84\t  createAuthRoutes({\n85\t    authDb,\n86\t    db,\n87\t    jwtSecret: config.jwtSecret,\n88\t    cluster: config.cluster,\n89\t    challengeTtlSeconds: config.challengeTtlSeconds,\n90\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n91\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n92\t  }),\n93\t);\n94\t\n95\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n96\tapp.use(\n97\t  \"/profile/*\",\n98\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n99\t);\n100\tapp.route(\"/profile\", createProfileRoutes({ db }));\n101\t\n102\t// Public profile routes — no auth required\n103\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n104\t\n105\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n106\tapp.use(\n107\t  \"/referral/*\",\n108\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n109\t);\n110\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n111\t\n112\t// JWT auth middleware for fairness endpoints\n113\tapp.use(\n114\t  \"/fairness/*\",\n115\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n116\t);\n117\t\n118\t// Rate limiting — per-wallet and global limits on POST requests\n119\tapp.use(\n120\t  \"/fairness/*\",\n121\t  createRateLimitMiddleware({\n122\t    perWallet: config.rateLimitPerWallet,\n123\t    global: config.rateLimitGlobal,\n124\t    windowMs: 60_000,\n125\t  }),\n126\t);\n127\t\n128\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n129\tconst entropyAccount = new PublicKey(config.entropyAccount);\n130\tconst retrySettler = createRetrySettler({\n131\t  db,\n132\t  connection,\n133\t  settleRound: (pda) =>\n134\t    settleRound(\n135\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n136\t      pda,\n137\t    ),\n138\t});\n139\t\n140\t// PDA watcher — WebSocket-based instant join detection\n141\tconst pdaWatcher = createPdaWatcher({\n142\t  connection,\n143\t  serverKey: config.serverKeypair.publicKey,\n144\t  db,\n145\t  onJoinDetected: async (pda, targetSlot) => {\n146\t    // Update DB phase if still in 'created'\n147\t    const round = await db.getRoundByPda(pda);\n148\t    if (round && round.phase === \"created\") {\n149\t      await db.updateRoundPhase(pda, \"locked\", {\n150\t        target_slot: targetSlot.toString(),\n151\t      });\n152\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n153\t        targetSlot: targetSlot.toString(),\n154\t        source: \"pda-watcher\",\n155\t        game: round.game,\n156\t      });\n157\t    }\n158\t\n159\t    // Check if target slot already passed — settle immediately if so\n160\t    const currentSlot = await connection.getSlot();\n161\t    if (BigInt(currentSlot) >= targetSlot) {\n162\t      await retrySettler.attemptSettle(pda);\n163\t      pdaWatcher.unwatch(pda);\n164\t    }\n165\t    // If target slot not reached yet, poll worker will pick it up next cycle\n166\t  },\n167\t});\n168\t\n169\tconst worker = createSettlementWorker({\n170\t  db,\n171\t  connection,\n172\t  serverKey: config.serverKeypair.publicKey,\n173\t  pollIntervalMs: config.workerPollIntervalMs,\n174\t  onSettleReady: async (pda) => {\n175\t    await retrySettler.attemptSettle(pda);\n176\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n177\t  },\n178\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n179\t});\n180\tworker.start();\n181\t\n182\t// Close Call clock worker — fetches boundary prices + settles open rounds\n183\t// Rounds are created on-demand by players via /closecall/bet\n184\tconst closeCallClock = createCloseCallClockWorker({\n185\t  connection,\n186\t  serverKeypair: config.serverKeypair,\n187\t  db: sql,\n188\t});\n189\tcloseCallClock.start();\n190\t\n191\t// Register event handlers before starting the worker\n192\tregisterHandler(\n193\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n194\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n195\t);\n196\t\n197\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n198\tconst eventWorker = createEventWorker(sql, {\n199\t  pollIntervalMs: config.eventQueuePollMs,\n200\t});\n201\teventWorker.start();\n202\tlogger.info(\"Event queue worker started\", {\n203\t  pollIntervalMs: config.eventQueuePollMs,\n204\t});\n205\t\n206\t// Coinflip fairness routes\n207\tapp.route(\n208\t  \"/fairness/coinflip\",\n209\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n210\t);\n211\tapp.route(\n212\t  \"/fairness/lord\",\n213\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n214\t);\n215\t\n216\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n217\tapp.use(\n218\t  \"/closecall/bet\",\n219\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n220\t);\n221\tapp.use(\n222\t  \"/closecall/bet\",\n223\t  createRateLimitMiddleware({\n224\t    perWallet: config.rateLimitPerWallet,\n225\t    global: config.rateLimitGlobal,\n226\t    windowMs: 60_000,\n227\t  }),\n228\t);\n229\t\n230\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n231\tapp.route(\"/closecall\", createCloseCallRoutes({\n232\t  db,\n233\t  connection,\n234\t  serverKeypair: config.serverKeypair,\n235\t  clockWorker: closeCallClock,\n236\t  sql,\n237\t}));\n238\t\n239\t// Price routes — public, no auth\n240\tapp.route(\"/price\", createPriceRoutes());\n241\t\n242\t// Round verification routes\n243\tapp.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n244\t\n245\t// Health endpoint — wired after worker exists so we can query its status\n246\tapp.route(\n247\t  \"/health\",\n248\t  createHealthRoutes({\n249\t    db,\n250\t    sql,\n251\t    isWorkerRunning: () => worker.isRunning,\n252\t  }),\n253\t);\n254\t\n255\tconst port = config.port;\n256\tlogger.info(\"fairness-backend started\", { port });\n257\t\n258\tserve({\n259\t  fetch: app.fetch,\n260\t  port,\n261\t  hostname: \"0.0.0.0\",\n262\t});\n263\t\n264\texport default {\n265\t  port,\n266\t  fetch: app.fetch,\n267\t};\n268\t"}]},"parent_tool_use_id":"toolu_016fLr5R1XUSLwEmBUfi2ULE","session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"971b7335-cdf0-48e0-8930-93215c2a4993","timestamp":"2026-03-31T15:32:48.298Z"}
