{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CxTW8gcz1Cys1PsHkdR5Sd","type":"tool_result","content":"1\t/**\n2\t * Unit tests for username + user ID generation utilities.\n3\t */\n4\t\n5\timport { describe, it, expect } from \"vitest\";\n6\timport { generateUserId, generateUsername } from \"../utils/username-gen.js\";\n7\t\n8\tdescribe(\"generateUserId\", () => {\n9\t  it(\"matches format usr_ followed by 8 lowercase alphanumeric chars\", () => {\n10\t    const id = generateUserId();\n11\t    expect(id).toMatch(/^usr_[a-z0-9]{8}$/);\n12\t  });\n13\t\n14\t  it(\"produces different values on successive calls\", () => {\n15\t    const ids = new Set<string>();\n16\t    for (let i = 0; i < 10; i++) {\n17\t      ids.add(generateUserId());\n18\t    }\n19\t    // With 36^8 possible values, 10 calls should never collide\n20\t    expect(ids.size).toBe(10);\n21\t  });\n22\t});\n23\t\n24\tdescribe(\"generateUsername\", () => {\n25\t  it(\"matches format {word}-{word}-{4digits}\", () => {\n26\t    const name = generateUsername();\n27\t    expect(name).toMatch(/^[a-z]+-[a-z]+-\\d{4}$/);\n28\t  });\n29\t\n30\t  it(\"produces different values on successive calls\", () => {\n31\t    const names = new Set<string>();\n32\t    for (let i = 0; i < 10; i++) {\n33\t      names.add(generateUsername());\n34\t    }\n35\t    // With 51*56*10000 combinations, 10 calls should never collide\n36\t    expect(names.size).toBe(10);\n37\t  });\n38\t\n39\t  it(\"words contain no spaces or special characters\", () => {\n40\t    // Generate several usernames and verify each part\n41\t    for (let i = 0; i < 20; i++) {\n42\t      const name = generateUsername();\n43\t      const parts = name.split(\"-\");\n44\t      expect(parts).toHaveLength(3);\n45\t      // adjective: only lowercase letters\n46\t      expect(parts[0]).toMatch(/^[a-z]+$/);\n47\t      // noun: only lowercase letters\n48\t      expect(parts[1]).toMatch(/^[a-z]+$/);\n49\t      // suffix: exactly 4 digits\n50\t      expect(parts[2]).toMatch(/^\\d{4}$/);\n51\t    }\n52\t  });\n53\t});\n54\t"}]},"parent_tool_use_id":"toolu_01FMMzLoBq3fWyHdm67XnMmn","session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"f1c36982-bf1e-4bbe-8f5c-19f4b1e560d1","timestamp":"2026-03-31T15:32:46.454Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019FnUkKtXVLHxEQ9HsfATy3","type":"tool_result","content":"1\t/**\n2\t * Unit tests for player stats + streaks DB functions.\n3\t *\n4\t * Requires a running PostgreSQL instance. Seeds the `transactions` table\n5\t * with known rows and verifies getPlayerStats, getWinStreaks,\n6\t * getGameBreakdown, and getPublicPlayerStats.\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport postgres from \"postgres\";\n11\timport { createDb, type Db } from \"../db.js\";\n12\t\n13\tconst DATABASE_URL =\n14\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n15\t\n16\tconst WALLET = \"TestWallet_stats_\" + Date.now();\n17\t\n18\tdescribe(\"Player stats + streaks\", () => {\n19\t  let rawSql: ReturnType<typeof postgres>;\n20\t  let db: Db;\n21\t\n22\t  beforeAll(async () => {\n23\t    rawSql = postgres(DATABASE_URL);\n24\t    // Ensure transactions table exists\n25\t    await rawSql`\n26\t      CREATE TABLE IF NOT EXISTS transactions (\n27\t        id              BIGSERIAL    PRIMARY KEY,\n28\t        wallet          TEXT         NOT NULL,\n29\t        game            TEXT         NOT NULL,\n30\t        match_id        TEXT         NOT NULL,\n31\t        tx_type         TEXT         NOT NULL,\n32\t        amount_lamports BIGINT       NOT NULL,\n33\t        tx_sig          TEXT         NOT NULL,\n34\t        created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n35\t      )\n36\t    `;\n37\t    await rawSql`\n38\t      CREATE UNIQUE INDEX IF NOT EXISTS uq_tx_wallet_match_type_sig\n39\t        ON transactions (wallet, match_id, tx_type, tx_sig)\n40\t    `;\n41\t    db = createDb(DATABASE_URL);\n42\t  });\n43\t\n44\t  afterAll(async () => {\n45\t    // Clean up test rows\n46\t    await rawSql`DELETE FROM transactions WHERE wallet LIKE 'TestWallet_stats_%'`;\n47\t    await rawSql.end();\n48\t  });\n49\t\n50\t  beforeEach(async () => {\n51\t    // Clean only our test wallet's rows between tests\n52\t    await rawSql`DELETE FROM transactions WHERE wallet LIKE 'TestWallet_stats_%'`;\n53\t  });\n54\t\n55\t  // Helper to insert a transaction row with controlled created_at\n56\t  async function seed(\n57\t    matchId: string,\n58\t    txType: \"deposit\" | \"payout\" | \"refund\",\n59\t    amountLamports: number,\n60\t    game: string,\n61\t    createdAt: Date,\n62\t    wallet = WALLET,\n63\t  ) {\n64\t    const txSig = `sig_${matchId}_${txType}_${Date.now()}_${Math.random()}`;\n65\t    await rawSql`\n66\t      INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig, created_at)\n67\t      VALUES (${wallet}, ${game}, ${matchId}, ${txType}, ${amountLamports}, ${txSig}, ${createdAt})\n68\t    `;\n69\t  }\n70\t\n71\t  // -----------------------------------------------------------------------\n72\t  // (1) Empty history → all zeros\n73\t  // -----------------------------------------------------------------------\n74\t  it(\"returns zero stats for empty history\", async () => {\n75\t    const stats = await db.getPlayerStats(WALLET);\n76\t    expect(stats.gamesPlayed).toBe(0);\n77\t    expect(stats.totalWagered).toBe(0n);\n78\t    expect(stats.totalWins).toBe(0);\n79\t    expect(stats.winRate).toBe(0);\n80\t    expect(stats.netPnl).toBe(0n);\n81\t  });\n82\t\n83\t  it(\"returns zero streaks for empty history\", async () => {\n84\t    const streaks = await db.getWinStreaks(WALLET);\n85\t    expect(streaks.current).toBe(0);\n86\t    expect(streaks.best).toBe(0);\n87\t  });\n88\t\n89\t  it(\"returns empty game breakdown for empty history\", async () => {\n90\t    const breakdown = await db.getGameBreakdown(WALLET);\n91\t    expect(Object.keys(breakdown).length).toBe(0);\n92\t  });\n93\t\n94\t  // -----------------------------------------------------------------------\n95\t  // (2) 3 wins in a row → current=3 best=3\n96\t  // -----------------------------------------------------------------------\n97\t  it(\"3 consecutive wins → current=3 best=3\", async () => {\n98\t    const base = new Date(\"2026-01-01T00:00:00Z\");\n99\t    // Match 1: deposit + payout (win)\n100\t    await seed(\"m1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n101\t    await seed(\"m1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n102\t    // Match 2: deposit + payout (win)\n103\t    await seed(\"m2\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n104\t    await seed(\"m2\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 4000));\n105\t    // Match 3: deposit + payout (win)\n106\t    await seed(\"m3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n107\t    await seed(\"m3\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 6000));\n108\t\n109\t    const streaks = await db.getWinStreaks(WALLET);\n110\t    expect(streaks.current).toBe(3);\n111\t    expect(streaks.best).toBe(3);\n112\t  });\n113\t\n114\t  // -----------------------------------------------------------------------\n115\t  // (3) win-win-loss-win → current=1 best=2\n116\t  // -----------------------------------------------------------------------\n117\t  it(\"win-win-loss-win → current=1 best=2\", async () => {\n118\t    const base = new Date(\"2026-02-01T00:00:00Z\");\n119\t    // Match 1 (oldest): win\n120\t    await seed(\"a1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n121\t    await seed(\"a1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n122\t    // Match 2: win\n123\t    await seed(\"a2\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n124\t    await seed(\"a2\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 4000));\n125\t    // Match 3: loss\n126\t    await seed(\"a3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n127\t    // Match 4 (most recent): win\n128\t    await seed(\"a4\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 7000));\n129\t    await seed(\"a4\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 8000));\n130\t\n131\t    const streaks = await db.getWinStreaks(WALLET);\n132\t    expect(streaks.current).toBe(1);\n133\t    expect(streaks.best).toBe(2);\n134\t  });\n135\t\n136\t  // -----------------------------------------------------------------------\n137\t  // (4) Refund-only match skipped in streak\n138\t  // -----------------------------------------------------------------------\n139\t  it(\"refund-only match is skipped in streak calculation\", async () => {\n140\t    const base = new Date(\"2026-03-01T00:00:00Z\");\n141\t    // Match 1: win\n142\t    await seed(\"r1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n143\t    await seed(\"r1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n144\t    // Match 2: refund only (no deposit, no payout)\n145\t    await seed(\"r2\", \"refund\", 1000, \"coinflip\", new Date(base.getTime() + 3000));\n146\t    // Match 3 (most recent): win\n147\t    await seed(\"r3\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 5000));\n148\t    await seed(\"r3\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 6000));\n149\t\n150\t    const streaks = await db.getWinStreaks(WALLET);\n151\t    // Refund-only match skipped → current streak is 2 consecutive wins\n152\t    expect(streaks.current).toBe(2);\n153\t    expect(streaks.best).toBe(2);\n154\t  });\n155\t\n156\t  // -----------------------------------------------------------------------\n157\t  // (5) Game breakdown groups correctly\n158\t  // -----------------------------------------------------------------------\n159\t  it(\"game breakdown groups by frontend game name\", async () => {\n160\t    const base = new Date(\"2026-04-01T00:00:00Z\");\n161\t    // Coinflip: 1 win\n162\t    await seed(\"g1\", \"deposit\", 2000, \"coinflip\", new Date(base.getTime() + 1000));\n163\t    await seed(\"g1\", \"payout\", 3800, \"coinflip\", new Date(base.getTime() + 2000));\n164\t    // Lord: 1 loss\n165\t    await seed(\"g2\", \"deposit\", 5000, \"lord\", new Date(base.getTime() + 3000));\n166\t    // Close Call: 1 win\n167\t    await seed(\"g3\", \"deposit\", 3000, \"closecall\", new Date(base.getTime() + 5000));\n168\t    await seed(\"g3\", \"payout\", 5500, \"closecall\", new Date(base.getTime() + 6000));\n169\t\n170\t    const breakdown = await db.getGameBreakdown(WALLET);\n171\t\n172\t    // Keys use frontend names\n173\t    expect(breakdown[\"coinflip\"]).toBeDefined();\n174\t    expect(breakdown[\"lord-of-rngs\"]).toBeDefined();\n175\t    expect(breakdown[\"close-call\"]).toBeDefined();\n176\t\n177\t    // Coinflip: 1 game, 1 win, wagered=2000, pnl=3800-2000=1800\n178\t    const cf = breakdown[\"coinflip\"]!;\n179\t    expect(cf.gamesPlayed).toBe(1);\n180\t    expect(cf.totalWins).toBe(1);\n181\t    expect(cf.totalWagered).toBe(2000n);\n182\t    expect(cf.netPnl).toBe(1800n);\n183\t    expect(cf.winRate).toBe(1);\n184\t\n185\t    // Lord: 1 game, 0 wins, wagered=5000, pnl=-5000\n186\t    const lord = breakdown[\"lord-of-rngs\"]!;\n187\t    expect(lord.gamesPlayed).toBe(1);\n188\t    expect(lord.totalWins).toBe(0);\n189\t    expect(lord.totalWagered).toBe(5000n);\n190\t    expect(lord.netPnl).toBe(-5000n);\n191\t    expect(lord.winRate).toBe(0);\n192\t\n193\t    // Close Call: 1 game, 1 win, wagered=3000, pnl=5500-3000=2500\n194\t    const cc = breakdown[\"close-call\"]!;\n195\t    expect(cc.gamesPlayed).toBe(1);\n196\t    expect(cc.totalWins).toBe(1);\n197\t    expect(cc.totalWagered).toBe(3000n);\n198\t    expect(cc.netPnl).toBe(2500n);\n199\t    expect(cc.winRate).toBe(1);\n200\t  });\n201\t\n202\t  // -----------------------------------------------------------------------\n203\t  // (6) Public stats omit wagered/pnl\n204\t  // -----------------------------------------------------------------------\n205\t  it(\"public stats expose only gamesPlayed, totalWins, winRate\", async () => {\n206\t    const base = new Date(\"2026-05-01T00:00:00Z\");\n207\t    await seed(\"p1\", \"deposit\", 1000, \"coinflip\", new Date(base.getTime() + 1000));\n208\t    await seed(\"p1\", \"payout\", 1900, \"coinflip\", new Date(base.getTime() + 2000));\n209\t\n210\t    const pub = await db.getPublicPlayerStats(WALLET);\n211\t    expect(pub.gamesPlayed).toBe(1);\n212\t    expect(pub.totalWins).toBe(1);\n213\t    expect(pub.winRate).toBe(1);\n214\t    // Should not have wagered or pnl fields\n215\t    expect(\"totalWagered\" in pub).toBe(false);\n216\t    expect(\"netPnl\" in pub).toBe(false);\n217\t  });\n218\t\n219\t  // -----------------------------------------------------------------------\n220\t  // Aggregate stats correctness\n221\t  // -----------------------------------------------------------------------\n222\t  it(\"computes aggregate stats correctly\", async () => {\n223\t    const base = new Date(\"2026-06-01T00:00:00Z\");\n224\t    // Match 1: deposit 2000, payout 3800 (win, net +1800)\n225\t    await seed(\"s1\", \"deposit\", 2000, \"coinflip\", new Date(base.getTime() + 1000));\n226\t    await seed(\"s1\", \"payout\", 3800, \"coinflip\", new Date(base.getTime() + 2000));\n227\t    // Match 2: deposit 3000 (loss, net -3000)\n228\t    await seed(\"s2\", \"deposit\", 3000, \"lord\", new Date(base.getTime() + 3000));\n229\t    // Match 3: deposit 1000, refund 1000 (refund, net 0)\n230\t    await seed(\"s3\", \"deposit\", 1000, \"closecall\", new Date(base.getTime() + 5000));\n231\t    await seed(\"s3\", \"refund\", 1000, \"closecall\", new Date(base.getTime() + 6000));\n232\t\n233\t    const stats = await db.getPlayerStats(WALLET);\n234\t    expect(stats.gamesPlayed).toBe(3); // 3 distinct match_ids with deposits\n235\t    expect(stats.totalWagered).toBe(6000n); // 2000+3000+1000\n236\t    expect(stats.totalWins).toBe(1); // only match s1 has payout\n237\t    expect(stats.winRate).toBeCloseTo(1 / 3, 5);\n238\t    // netPnl = (3800 payout + 1000 refund) - (2000 + 3000 + 1000 deposits) = 4800 - 6000 = -1200\n239\t    expect(stats.netPnl).toBe(-1200n);\n240\t  });\n241\t});\n242\t"}]},"parent_tool_use_id":"toolu_01FMMzLoBq3fWyHdm67XnMmn","session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"946b6b72-cee5-4604-b1bf-9ddcda41574b","timestamp":"2026-03-31T15:32:46.709Z"}
