{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BitQVdNcCmPNcpmQ7dfXfY","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/__tests__/profile.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"30647209-7799-4332-9408-067dd61f435a","timestamp":"2026-03-31T15:37:47.142Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/profile.test.ts","oldString":"    const { accessToken, wallet } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });","newString":"    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });","originalFile":"/**\n * Integration test for profile lifecycle:\n * auth → profile auto-created → GET /profile/me → PUT /profile/username →\n * cooldown → taken username → GET /public-profile/:identifier → no wallet leaks\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport { createAuthDb, type AuthDb } from \"../auth-db.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport { createProfileRoutes } from \"../routes/profile.js\";\nimport { createPublicProfileRoutes } from \"../routes/public-profile.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createDb, type Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-profile-tests\");\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\n/** Perform challenge → sign → verify and return access token + wallet. */\nasync function authenticateWallet(\n  app: Hono,\n  keypair: Keypair,\n): Promise<{ accessToken: string; wallet: string }> {\n  const wallet = keypair.publicKey.toBase58();\n\n  // 1. Challenge\n  const challengeRes = await app.request(\"/auth/challenge\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  });\n  expect(challengeRes.status).toBe(200);\n  const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n  // 2. Sign\n  const messageBytes = new TextEncoder().encode(challenge.message);\n  const signatureBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n  const signature = bs58.encode(signatureBytes);\n\n  // 3. Verify\n  const verifyRes = await app.request(\"/auth/verify\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n  });\n  expect(verifyRes.status).toBe(200);\n  const tokens = (await verifyRes.json()) as { accessToken: string };\n  return { accessToken: tokens.accessToken, wallet };\n}\n\n// ---------------------------------------------------------------------------\n// Suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Profile lifecycle integration\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let authDb: AuthDb;\n  let db: Db;\n  let app: Hono;\n\n  const keypairA = Keypair.generate();\n  const keypairB = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = postgres(DATABASE_URL);\n\n    // Ensure required tables exist\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS player_profiles (\n        id BIGSERIAL PRIMARY KEY,\n        user_id TEXT UNIQUE NOT NULL,\n        wallet TEXT UNIQUE NOT NULL,\n        username TEXT UNIQUE NOT NULL,\n        username_updated_at TIMESTAMPTZ,\n        avatar_url TEXT,\n        heat_multiplier NUMERIC DEFAULT 1.0,\n        points_balance BIGINT DEFAULT 0,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    // Case-insensitive uniqueness index\n    await rawSql`\n      CREATE UNIQUE INDEX IF NOT EXISTS idx_player_profiles_username_lower\n      ON player_profiles (LOWER(username))\n    `;\n    // transactions table (needed for stats queries)\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS transactions (\n        id BIGSERIAL PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        game TEXT NOT NULL,\n        match_id TEXT NOT NULL,\n        tx_type TEXT NOT NULL,\n        amount_lamports BIGINT NOT NULL,\n        tx_sig TEXT,\n        created_at TIMESTAMPTZ DEFAULT now(),\n        UNIQUE(wallet, match_id, tx_type, tx_sig)\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    // Clean up test data\n    const walletA = keypairA.publicKey.toBase58();\n    const walletB = keypairB.publicKey.toBase58();\n    await rawSql`DELETE FROM player_profiles WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql`DELETE FROM transactions WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean per-test state\n    const walletA = keypairA.publicKey.toBase58();\n    const walletB = keypairB.publicKey.toBase58();\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    await rawSql`DELETE FROM player_profiles WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql`DELETE FROM transactions WHERE wallet IN (${walletA}, ${walletB})`;\n\n    authDb = createAuthDb(rawSql);\n    db = createDb(DATABASE_URL, rawSql);\n    app = new Hono();\n\n    // Auth routes (no middleware)\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        db,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n\n    // Profile routes (JWT protected)\n    app.use(\n      \"/profile/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    app.route(\"/profile\", createProfileRoutes({ db }));\n\n    // Public profile (no auth)\n    app.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n  });\n\n  // -----------------------------------------------------------------------\n  // (1) Auth creates profile automatically\n  // -----------------------------------------------------------------------\n\n  it(\"POST /auth/verify auto-creates player_profiles row\", async () => {\n    const { wallet } = await authenticateWallet(app, keypairA);\n\n    // Verify profile exists in DB\n    const rows = await rawSql`\n      SELECT user_id, wallet, username FROM player_profiles WHERE wallet = ${wallet}\n    `;\n    expect(rows.length).toBe(1);\n    const row = rows[0]!;\n    expect(row.user_id).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(row.username).toMatch(/^[a-z]+-[a-z]+-\\d{4}$/);\n    expect(row.wallet).toBe(wallet);\n  });\n\n  // -----------------------------------------------------------------------\n  // (2) GET /profile/me returns profile + empty stats\n  // -----------------------------------------------------------------------\n\n  it(\"GET /profile/me returns profile with empty stats\", async () => {\n    const { accessToken, wallet } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, unknown>;\n\n    // Has expected fields\n    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(body.username).toBeDefined();\n    expect(body.createdAt).toBeDefined();\n    expect(body.heatMultiplier).toBe(1);\n    expect(body.pointsBalance).toBe(\"0\");\n    expect(body.usernameNextEditAt).toBeNull(); // first edit free\n\n    // Stats should be empty/zero\n    const stats = body.stats as Record<string, unknown>;\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWagered).toBe(\"0\");\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n    expect(stats.winStreakCurrent).toBe(0);\n    expect(stats.winStreakBest).toBe(0);\n    expect(stats.netPnl).toBe(\"0\");\n\n    // No wallet field\n    expect(body).not.toHaveProperty(\"wallet\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (3) PUT /profile/username succeeds on first edit\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username succeeds with valid name\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"CoolPlayer99\" }),\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as { username: string; nextEditAvailableAt: string };\n    expect(body.username).toBe(\"CoolPlayer99\");\n    expect(body.nextEditAvailableAt).toBeDefined();\n    // nextEditAvailableAt should be ~30 days from now\n    const nextEdit = new Date(body.nextEditAvailableAt).getTime();\n    const thirtyDays = 30 * 24 * 60 * 60 * 1000;\n    expect(nextEdit).toBeGreaterThan(Date.now() + thirtyDays - 60_000);\n  });\n\n  // -----------------------------------------------------------------------\n  // (4) PUT /profile/username again immediately → 429 cooldown\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 429 on cooldown\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    // First edit — succeeds\n    const res1 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"FirstName01\" }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second edit — should be blocked by cooldown\n    const res2 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"SecondName02\" }),\n    });\n    expect(res2.status).toBe(429);\n    const body = (await res2.json()) as { error: string; nextEditAvailableAt: string };\n    expect(body.error).toBe(\"COOLDOWN_ACTIVE\");\n    expect(body.nextEditAvailableAt).toBeDefined();\n  });\n\n  // -----------------------------------------------------------------------\n  // (5) PUT /profile/username with taken name → 409\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 409 for taken username\", async () => {\n    // Authenticate both wallets (creates profiles)\n    const { accessToken: tokenA } = await authenticateWallet(app, keypairA);\n    const { accessToken: tokenB } = await authenticateWallet(app, keypairB);\n\n    // Wallet A takes a name\n    const res1 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${tokenA}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"UniqueName42\" }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Wallet B tries the same name (case-insensitive)\n    const res2 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${tokenB}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"uniquename42\" }),\n    });\n    expect(res2.status).toBe(409);\n    const body = (await res2.json()) as { error: string };\n    expect(body.error).toBe(\"USERNAME_TAKEN\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (6) GET /public-profile/:username returns limited public data\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:username returns public profile\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    // Set a known username\n    await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"PublicUser01\" }),\n    });\n\n    // Fetch public profile (no auth)\n    const res = await app.request(\"/public-profile/PublicUser01\");\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, unknown>;\n\n    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(body.username).toBe(\"PublicUser01\");\n    expect(body.heatMultiplier).toBe(1);\n    expect(body.createdAt).toBeDefined();\n\n    // Public stats — limited fields only\n    const stats = body.stats as Record<string, unknown>;\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n\n    // Must NOT have private fields\n    expect(body).not.toHaveProperty(\"wallet\");\n    expect(body).not.toHaveProperty(\"pointsBalance\");\n    expect(stats).not.toHaveProperty(\"totalWagered\");\n    expect(stats).not.toHaveProperty(\"netPnl\");\n    expect(stats).not.toHaveProperty(\"winStreakCurrent\");\n    expect(stats).not.toHaveProperty(\"winStreakBest\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (7) GET /public-profile/:user_id returns same data\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:user_id resolves by user_id\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    // Get the userId from /profile/me\n    const meRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    const meBody = (await meRes.json()) as { userId: string; username: string };\n    const userId = meBody.userId;\n\n    // Fetch via user_id\n    const res = await app.request(`/public-profile/${userId}`);\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as { userId: string; username: string };\n    expect(body.userId).toBe(userId);\n    expect(body.username).toBe(meBody.username);\n\n    // No wallet\n    expect(body).not.toHaveProperty(\"wallet\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (8) No wallet field in any response (additional checks)\n  // -----------------------------------------------------------------------\n\n  it(\"no wallet field in any response\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    // GET /profile/me\n    const meRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    const meBody = await meRes.text();\n    expect(meBody).not.toContain(keypairA.publicKey.toBase58());\n\n    // PUT /profile/username\n    const putRes = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"NoWalletChk\" }),\n    });\n    const putBody = await putRes.text();\n    expect(putBody).not.toContain(keypairA.publicKey.toBase58());\n\n    // GET /public-profile\n    const pubRes = await app.request(\"/public-profile/NoWalletChk\");\n    const pubBody = await pubRes.text();\n    expect(pubBody).not.toContain(keypairA.publicKey.toBase58());\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge: 404 for unknown identifier\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:identifier returns 404 for unknown\", async () => {\n    const res = await app.request(\"/public-profile/nonexistent_user\");\n    expect(res.status).toBe(404);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"NOT_FOUND\");\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge: invalid username format\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 400 for invalid format\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"ab\" }), // too short\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"INVALID_FORMAT\");\n  });\n});\n","structuredPatch":[{"oldStart":203,"oldLines":7,"newStart":203,"newLines":7,"lines":["   // -----------------------------------------------------------------------"," ","   it(\"GET /profile/me returns profile with empty stats\", async () => {","-    const { accessToken, wallet } = await authenticateWallet(app, keypairA);","+    const { accessToken } = await authenticateWallet(app, keypairA);"," ","     const res = await app.request(\"/profile/me\", {","       method: \"GET\","]}],"userModified":false,"replaceAll":false}}
