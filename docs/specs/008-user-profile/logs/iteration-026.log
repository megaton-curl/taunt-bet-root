{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E3PaRUZ5hnckbgo6hXdeMr","type":"tool_result","content":"1\t/**\n2\t * JWT Bearer token authentication middleware.\n3\t *\n4\t * Verifies HS256 JWT access tokens on POST requests.\n5\t * Sets c.set(\"wallet\", payload.sub) for downstream handlers.\n6\t * GET requests pass through without authentication.\n7\t */\n8\t\n9\timport { createMiddleware } from \"hono/factory\";\n10\timport { jwtVerify } from \"jose\";\n11\timport { logger } from \"../logger.js\";\n12\timport type { AppEnv } from \"../hono-env.js\";\n13\t\n14\texport interface JwtAuthConfig {\n15\t  jwtSecret: Uint8Array;\n16\t  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n17\t  requireAllMethods?: boolean;\n18\t}\n19\t\n20\texport function createJwtAuthMiddleware(config: JwtAuthConfig) {\n21\t  return createMiddleware<AppEnv>(async (c, next) => {\n22\t    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n23\t    // unless requireAllMethods is set (e.g., profile endpoints)\n24\t    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n25\t      return next();\n26\t    }\n27\t\n28\t    const authHeader = c.req.header(\"Authorization\");\n29\t    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n30\t      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n31\t        path: c.req.path,\n32\t      });\n33\t      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n34\t    }\n35\t\n36\t    const token = authHeader.slice(7);\n37\t    try {\n38\t      const { payload } = await jwtVerify(token, config.jwtSecret, {\n39\t        algorithms: [\"HS256\"],\n40\t      });\n41\t\n42\t      if (typeof payload.sub !== \"string\") {\n43\t        logger.warn(\"jwt auth rejected: missing sub claim\", {\n44\t          path: c.req.path,\n45\t        });\n46\t        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n47\t      }\n48\t\n49\t      c.set(\"wallet\", payload.sub);\n50\t      return next();\n51\t    } catch (err) {\n52\t      logger.warn(\"jwt auth rejected: token verification failed\", {\n53\t        path: c.req.path,\n54\t        error: err instanceof Error ? err.message : \"Unknown error\",\n55\t      });\n56\t      return c.json({ error: \"Invalid or expired token\" }, 401);\n57\t    }\n58\t  });\n59\t}\n60\t"}]},"parent_tool_use_id":null,"session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"e8e9d879-2c4d-4474-ae44-ff5665c0d53b","timestamp":"2026-03-31T15:33:15.905Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/middleware/jwt-auth.ts","content":"/**\n * JWT Bearer token authentication middleware.\n *\n * Verifies HS256 JWT access tokens on POST requests.\n * Sets c.set(\"wallet\", payload.sub) for downstream handlers.\n * GET requests pass through without authentication.\n */\n\nimport { createMiddleware } from \"hono/factory\";\nimport { jwtVerify } from \"jose\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\n\nexport interface JwtAuthConfig {\n  jwtSecret: Uint8Array;\n  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n  requireAllMethods?: boolean;\n}\n\nexport function createJwtAuthMiddleware(config: JwtAuthConfig) {\n  return createMiddleware<AppEnv>(async (c, next) => {\n    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n    // unless requireAllMethods is set (e.g., profile endpoints)\n    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const authHeader = c.req.header(\"Authorization\");\n    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n        path: c.req.path,\n      });\n      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n    }\n\n    const token = authHeader.slice(7);\n    try {\n      const { payload } = await jwtVerify(token, config.jwtSecret, {\n        algorithms: [\"HS256\"],\n      });\n\n      if (typeof payload.sub !== \"string\") {\n        logger.warn(\"jwt auth rejected: missing sub claim\", {\n          path: c.req.path,\n        });\n        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n      }\n\n      c.set(\"wallet\", payload.sub);\n      return next();\n    } catch (err) {\n      logger.warn(\"jwt auth rejected: token verification failed\", {\n        path: c.req.path,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Invalid or expired token\" }, 401);\n    }\n  });\n}\n","numLines":60,"startLine":1,"totalLines":60}}}
