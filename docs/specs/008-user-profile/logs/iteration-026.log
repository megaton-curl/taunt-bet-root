{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PpzMzBYtv6PAvuGTsY5Rz8","type":"tool_result","content":"1\t/**\n2\t * Auth routes tests: challenge → verify → refresh → logout flows.\n3\t */\n4\t\n5\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n6\timport { Hono } from \"hono\";\n7\timport { Keypair } from \"@solana/web3.js\";\n8\timport nacl from \"tweetnacl\";\n9\timport bs58 from \"bs58\";\n10\timport { jwtVerify } from \"jose\";\n11\timport postgres from \"postgres\";\n12\timport { createAuthDb, type AuthDb } from \"../auth-db.js\";\n13\timport { createAuthRoutes } from \"../routes/auth.js\";\n14\timport type { Db } from \"../db.js\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// Constants\n18\t// ---------------------------------------------------------------------------\n19\t\n20\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n21\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n22\t\n23\t// ---------------------------------------------------------------------------\n24\t// Test suite\n25\t// ---------------------------------------------------------------------------\n26\t\n27\tdescribe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n28\t  let rawSql: ReturnType<typeof postgres>;\n29\t  let authDb: AuthDb;\n30\t  let app: Hono;\n31\t  const stubDb = {\n32\t    getProfileByWallet: async () => null,\n33\t    createPlayerProfile: async () => ({} as any),\n34\t  } as unknown as Db;\n35\t\n36\t  const creatorKeypair = Keypair.generate();\n37\t\n38\t  beforeAll(async () => {\n39\t    rawSql = postgres(DATABASE_URL);\n40\t    // Ensure auth tables exist\n41\t    await rawSql`\n42\t      CREATE TABLE IF NOT EXISTS auth_challenges (\n43\t        nonce TEXT PRIMARY KEY,\n44\t        wallet TEXT NOT NULL,\n45\t        cluster TEXT NOT NULL DEFAULT 'devnet',\n46\t        message TEXT NOT NULL,\n47\t        expires_at TIMESTAMPTZ NOT NULL,\n48\t        used BOOLEAN DEFAULT FALSE,\n49\t        created_at TIMESTAMPTZ DEFAULT now()\n50\t      )\n51\t    `;\n52\t    await rawSql`\n53\t      CREATE TABLE IF NOT EXISTS refresh_tokens (\n54\t        id BIGSERIAL PRIMARY KEY,\n55\t        wallet TEXT NOT NULL,\n56\t        token_hash BYTEA NOT NULL UNIQUE,\n57\t        family_id TEXT NOT NULL,\n58\t        expires_at TIMESTAMPTZ NOT NULL,\n59\t        revoked BOOLEAN DEFAULT FALSE,\n60\t        created_at TIMESTAMPTZ DEFAULT now()\n61\t      )\n62\t    `;\n63\t  });\n64\t\n65\t  afterAll(async () => {\n66\t    await rawSql.end();\n67\t  });\n68\t\n69\t  beforeEach(async () => {\n70\t    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n71\t    authDb = createAuthDb(rawSql);\n72\t    app = new Hono();\n73\t    app.route(\n74\t      \"/auth\",\n75\t      createAuthRoutes({\n76\t        authDb,\n77\t        db: stubDb,\n78\t        jwtSecret: JWT_SECRET,\n79\t        cluster: \"devnet\",\n80\t        challengeTtlSeconds: 300,\n81\t        accessTokenTtlSeconds: 3600,\n82\t        refreshTokenTtlDays: 14,\n83\t      }),\n84\t    );\n85\t  });\n86\t\n87\t  // -----------------------------------------------------------------------\n88\t  // POST /auth/challenge\n89\t  // -----------------------------------------------------------------------\n90\t\n91\t  it(\"returns a challenge with nonce and message\", async () => {\n92\t    const wallet = creatorKeypair.publicKey.toBase58();\n93\t    const res = await app.request(\"/auth/challenge\", {\n94\t      method: \"POST\",\n95\t      headers: { \"Content-Type\": \"application/json\" },\n96\t      body: JSON.stringify({ wallet }),\n97\t    });\n98\t\n99\t    expect(res.status).toBe(200);\n100\t    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n101\t    expect(json.nonce).toBeDefined();\n102\t    expect(json.nonce.length).toBe(64); // 32 bytes hex\n103\t    expect(json.message).toContain(\"Sign in to RNG Utopia\");\n104\t    expect(json.message).toContain(wallet);\n105\t    expect(json.message).toContain(\"devnet\");\n106\t    expect(json.expiresAt).toBeDefined();\n107\t  });\n108\t\n109\t  it(\"rejects challenge with missing wallet\", async () => {\n110\t    const res = await app.request(\"/auth/challenge\", {\n111\t      method: \"POST\",\n112\t      headers: { \"Content-Type\": \"application/json\" },\n113\t      body: JSON.stringify({}),\n114\t    });\n115\t    expect(res.status).toBe(400);\n116\t  });\n117\t\n118\t  // -----------------------------------------------------------------------\n119\t  // Full flow: challenge → verify → refresh → logout\n120\t  // -----------------------------------------------------------------------\n121\t\n122\t  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n123\t    const wallet = creatorKeypair.publicKey.toBase58();\n124\t\n125\t    // 1. Request challenge\n126\t    const challengeRes = await app.request(\"/auth/challenge\", {\n127\t      method: \"POST\",\n128\t      headers: { \"Content-Type\": \"application/json\" },\n129\t      body: JSON.stringify({ wallet }),\n130\t    });\n131\t    expect(challengeRes.status).toBe(200);\n132\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n133\t\n134\t    // 2. Sign the message\n135\t    const messageBytes = new TextEncoder().encode(challenge.message);\n136\t    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n137\t    const signature = bs58.encode(signatureBytes);\n138\t\n139\t    // 3. Verify\n140\t    const verifyRes = await app.request(\"/auth/verify\", {\n141\t      method: \"POST\",\n142\t      headers: { \"Content-Type\": \"application/json\" },\n143\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n144\t    });\n145\t    expect(verifyRes.status).toBe(200);\n146\t    const tokens = (await verifyRes.json()) as {\n147\t      accessToken: string;\n148\t      accessExpiresAt: string;\n149\t      refreshToken: string;\n150\t      refreshExpiresAt: string;\n151\t    };\n152\t    expect(tokens.accessToken).toBeDefined();\n153\t    expect(tokens.refreshToken).toBeDefined();\n154\t    expect(tokens.accessExpiresAt).toBeDefined();\n155\t    expect(tokens.refreshExpiresAt).toBeDefined();\n156\t\n157\t    // Verify JWT is valid and contains the correct wallet\n158\t    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n159\t      algorithms: [\"HS256\"],\n160\t    });\n161\t    expect(payload.sub).toBe(wallet);\n162\t\n163\t    // 4. Refresh\n164\t    const refreshRes = await app.request(\"/auth/refresh\", {\n165\t      method: \"POST\",\n166\t      headers: { \"Content-Type\": \"application/json\" },\n167\t      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n168\t    });\n169\t    expect(refreshRes.status).toBe(200);\n170\t    const newTokens = (await refreshRes.json()) as {\n171\t      accessToken: string;\n172\t      refreshToken: string;\n173\t    };\n174\t    expect(newTokens.accessToken).toBeDefined();\n175\t    expect(newTokens.refreshToken).toBeDefined();\n176\t    // New refresh token should be different from the old one\n177\t    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n178\t\n179\t    // 5. Old refresh token should no longer work (it was rotated)\n180\t    const replayRes = await app.request(\"/auth/refresh\", {\n181\t      method: \"POST\",\n182\t      headers: { \"Content-Type\": \"application/json\" },\n183\t      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n184\t    });\n185\t    expect(replayRes.status).toBe(401);\n186\t    const replayJson = (await replayRes.json()) as { error: string };\n187\t    expect(replayJson.error).toContain(\"reuse\");\n188\t\n189\t    // 6. Logout with new token\n190\t    const logoutRes = await app.request(\"/auth/logout\", {\n191\t      method: \"POST\",\n192\t      headers: { \"Content-Type\": \"application/json\" },\n193\t      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n194\t    });\n195\t    expect(logoutRes.status).toBe(204);\n196\t\n197\t    // 7. Refresh after logout should fail\n198\t    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n199\t      method: \"POST\",\n200\t      headers: { \"Content-Type\": \"application/json\" },\n201\t      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n202\t    });\n203\t    expect(postLogoutRefresh.status).toBe(401);\n204\t  });\n205\t\n206\t  // -----------------------------------------------------------------------\n207\t  // Edge cases\n208\t  // -----------------------------------------------------------------------\n209\t\n210\t  it(\"rejects verify with wrong wallet\", async () => {\n211\t    const wallet = creatorKeypair.publicKey.toBase58();\n212\t    const otherKeypair = Keypair.generate();\n213\t\n214\t    // Get challenge for the correct wallet\n215\t    const challengeRes = await app.request(\"/auth/challenge\", {\n216\t      method: \"POST\",\n217\t      headers: { \"Content-Type\": \"application/json\" },\n218\t      body: JSON.stringify({ wallet }),\n219\t    });\n220\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n221\t\n222\t    // Sign with the correct keypair\n223\t    const messageBytes = new TextEncoder().encode(challenge.message);\n224\t    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n225\t    const signature = bs58.encode(signatureBytes);\n226\t\n227\t    // But claim to be a different wallet\n228\t    const verifyRes = await app.request(\"/auth/verify\", {\n229\t      method: \"POST\",\n230\t      headers: { \"Content-Type\": \"application/json\" },\n231\t      body: JSON.stringify({\n232\t        nonce: challenge.nonce,\n233\t        wallet: otherKeypair.publicKey.toBase58(),\n234\t        signature,\n235\t      }),\n236\t    });\n237\t    expect(verifyRes.status).toBe(401);\n238\t  });\n239\t\n240\t  it(\"rejects verify with wrong signature\", async () => {\n241\t    const wallet = creatorKeypair.publicKey.toBase58();\n242\t    const otherKeypair = Keypair.generate();\n243\t\n244\t    const challengeRes = await app.request(\"/auth/challenge\", {\n245\t      method: \"POST\",\n246\t      headers: { \"Content-Type\": \"application/json\" },\n247\t      body: JSON.stringify({ wallet }),\n248\t    });\n249\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n250\t\n251\t    // Sign with wrong keypair\n252\t    const messageBytes = new TextEncoder().encode(challenge.message);\n253\t    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n254\t    const signature = bs58.encode(signatureBytes);\n255\t\n256\t    const verifyRes = await app.request(\"/auth/verify\", {\n257\t      method: \"POST\",\n258\t      headers: { \"Content-Type\": \"application/json\" },\n259\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n260\t    });\n261\t    expect(verifyRes.status).toBe(401);\n262\t  });\n263\t\n264\t  it(\"rejects verify with already-used nonce\", async () => {\n265\t    const wallet = creatorKeypair.publicKey.toBase58();\n266\t\n267\t    // Get and consume a challenge\n268\t    const challengeRes = await app.request(\"/auth/challenge\", {\n269\t      method: \"POST\",\n270\t      headers: { \"Content-Type\": \"application/json\" },\n271\t      body: JSON.stringify({ wallet }),\n272\t    });\n273\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n274\t    const messageBytes = new TextEncoder().encode(challenge.message);\n275\t    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n276\t    const signature = bs58.encode(signatureBytes);\n277\t\n278\t    // First verify — should succeed\n279\t    const res1 = await app.request(\"/auth/verify\", {\n280\t      method: \"POST\",\n281\t      headers: { \"Content-Type\": \"application/json\" },\n282\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n283\t    });\n284\t    expect(res1.status).toBe(200);\n285\t\n286\t    // Second verify with same nonce — should fail\n287\t    const res2 = await app.request(\"/auth/verify\", {\n288\t      method: \"POST\",\n289\t      headers: { \"Content-Type\": \"application/json\" },\n290\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n291\t    });\n292\t    expect(res2.status).toBe(401);\n293\t  });\n294\t\n295\t  it(\"rejects refresh with invalid token\", async () => {\n296\t    const res = await app.request(\"/auth/refresh\", {\n297\t      method: \"POST\",\n298\t      headers: { \"Content-Type\": \"application/json\" },\n299\t      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n300\t    });\n301\t    expect(res.status).toBe(401);\n302\t  });\n303\t});\n304\t"}]},"parent_tool_use_id":null,"session_id":"f9901d53-ab05-422c-a65b-76ea18fa6c39","uuid":"9d7fd904-6b7a-45b3-9aa3-d95ff065b3c9","timestamp":"2026-03-31T15:33:05.946Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/auth-routes.test.ts","content":"/**\n * Auth routes tests: challenge → verify → refresh → logout flows.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { jwtVerify } from \"jose\";\nimport postgres from \"postgres\";\nimport { createAuthDb, type AuthDb } from \"../auth-db.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport type { Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let authDb: AuthDb;\n  let app: Hono;\n  const stubDb = {\n    getProfileByWallet: async () => null,\n    createPlayerProfile: async () => ({} as any),\n  } as unknown as Db;\n\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = postgres(DATABASE_URL);\n    // Ensure auth tables exist\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    authDb = createAuthDb(rawSql);\n    app = new Hono();\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        db: stubDb,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /auth/challenge\n  // -----------------------------------------------------------------------\n\n  it(\"returns a challenge with nonce and message\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n    expect(json.nonce).toBeDefined();\n    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    expect(json.message).toContain(\"Sign in to RNG Utopia\");\n    expect(json.message).toContain(wallet);\n    expect(json.message).toContain(\"devnet\");\n    expect(json.expiresAt).toBeDefined();\n  });\n\n  it(\"rejects challenge with missing wallet\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  // -----------------------------------------------------------------------\n  // Full flow: challenge → verify → refresh → logout\n  // -----------------------------------------------------------------------\n\n  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // 1. Request challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    expect(challengeRes.status).toBe(200);\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // 2. Sign the message\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // 3. Verify\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(200);\n    const tokens = (await verifyRes.json()) as {\n      accessToken: string;\n      accessExpiresAt: string;\n      refreshToken: string;\n      refreshExpiresAt: string;\n    };\n    expect(tokens.accessToken).toBeDefined();\n    expect(tokens.refreshToken).toBeDefined();\n    expect(tokens.accessExpiresAt).toBeDefined();\n    expect(tokens.refreshExpiresAt).toBeDefined();\n\n    // Verify JWT is valid and contains the correct wallet\n    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n      algorithms: [\"HS256\"],\n    });\n    expect(payload.sub).toBe(wallet);\n\n    // 4. Refresh\n    const refreshRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(refreshRes.status).toBe(200);\n    const newTokens = (await refreshRes.json()) as {\n      accessToken: string;\n      refreshToken: string;\n    };\n    expect(newTokens.accessToken).toBeDefined();\n    expect(newTokens.refreshToken).toBeDefined();\n    // New refresh token should be different from the old one\n    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n\n    // 5. Old refresh token should no longer work (it was rotated)\n    const replayRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(replayRes.status).toBe(401);\n    const replayJson = (await replayRes.json()) as { error: string };\n    expect(replayJson.error).toContain(\"reuse\");\n\n    // 6. Logout with new token\n    const logoutRes = await app.request(\"/auth/logout\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(logoutRes.status).toBe(204);\n\n    // 7. Refresh after logout should fail\n    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(postLogoutRefresh.status).toBe(401);\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge cases\n  // -----------------------------------------------------------------------\n\n  it(\"rejects verify with wrong wallet\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    // Get challenge for the correct wallet\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with the correct keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // But claim to be a different wallet\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        nonce: challenge.nonce,\n        wallet: otherKeypair.publicKey.toBase58(),\n        signature,\n      }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with wrong signature\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with wrong keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with already-used nonce\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // Get and consume a challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // First verify — should succeed\n    const res1 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second verify with same nonce — should fail\n    const res2 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res2.status).toBe(401);\n  });\n\n  it(\"rejects refresh with invalid token\", async () => {\n    const res = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n    });\n    expect(res.status).toBe(401);\n  });\n});\n","numLines":304,"startLine":1,"totalLines":304}}}
