{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NCZABXRHLFDwC8NThhWDLG","type":"tool_result","content":"     1→/**\n     2→ * ProfileTransactions - Transaction history tab content\n     3→ *\n     4→ * Fetches real transaction data from the backend API and displays\n     5→ * a paginated table with event types, amounts, and match links.\n     6→ */\n     7→\n     8→import { GAME_NAMES } from \"../types\";\n     9→import type { GameId } from \"../types\";\n    10→import { useTransactions } from \"../hooks/useTransactions\";\n    11→import { useSolPrice } from \"../hooks/useSolPrice\";\n    12→\n    13→/** Format lamports as SOL string with optional USD estimate */\n    14→function formatSol(lamports: string, solUsdPrice: number | null): string {\n    15→  const sol = Number(lamports) / 1e9;\n    16→  const solStr =\n    17→    sol.toLocaleString(\"en-US\", {\n    18→      minimumFractionDigits: 2,\n    19→      maximumFractionDigits: 4,\n    20→    }) + \" SOL\";\n    21→  if (solUsdPrice == null) return solStr;\n    22→  const usd = sol * solUsdPrice;\n    23→  return `${solStr} (~$${usd.toLocaleString(\"en-US\", { minimumFractionDigits: 2, maximumFractionDigits: 2 })})`;\n    24→}\n    25→\n    26→/** Format ISO date as relative time */\n    27→function formatTime(iso: string): string {\n    28→  const date = new Date(iso);\n    29→  const diffMs = Date.now() - date.getTime();\n    30→  const diffMins = Math.floor(diffMs / 60000);\n    31→  const diffHours = Math.floor(diffMs / 3600000);\n    32→  const diffDays = Math.floor(diffMs / 86400000);\n    33→\n    34→  if (diffMins < 1) return \"Just now\";\n    35→  if (diffMins < 60) return `${diffMins}m ago`;\n    36→  if (diffHours < 24) return `${diffHours}h ago`;\n    37→  if (diffDays < 7) return `${diffDays}d ago`;\n    38→  return date.toLocaleDateString();\n    39→}\n    40→\n    41→/** Build the deep-link path for a match */\n    42→function matchPath(gameId: GameId, matchId: string): string {\n    43→  return `/${gameId}/${matchId}`;\n    44→}\n    45→\n    46→/** Event display label */\n    47→const EVENT_LABELS: Record<string, string> = {\n    48→  join: \"JOIN\",\n    49→  win: \"WIN\",\n    50→  loss: \"LOSS\",\n    51→  refund: \"REFUND\",\n    52→};\n    53→\n    54→export function ProfileTransactions() {\n    55→  const { transactions, loading, loadingMore, nextCursor, loadMore } =\n    56→    useTransactions();\n    57→  const solPrice = useSolPrice();\n    58→\n    59→  if (loading) {\n    60→    return (\n    61→      <div className=\"profile-transactions\">\n    62→        <div className=\"profile-transactions__skeleton\">\n    63→          {Array.from({ length: 5 }, (_, i) => (\n    64→            <div key={i} className=\"profile-transactions__skeleton-row\" />\n    65→          ))}\n    66→        </div>\n    67→      </div>\n    68→    );\n    69→  }\n    70→\n    71→  if (transactions.length === 0) {\n    72→    return (\n    73→      <div className=\"profile-transactions\">\n    74→        <div className=\"profile-transactions__empty\">\n    75→          <p>No transactions yet.</p>\n    76→          <p>Start playing to build your history!</p>\n    77→        </div>\n    78→      </div>\n    79→    );\n    80→  }\n    81→\n    82→  return (\n    83→    <div className=\"profile-transactions\">\n    84→      <table className=\"profile-transactions__table\">\n    85→        <thead>\n    86→          <tr>\n    87→            <th>Time</th>\n    88→            <th>Game</th>\n    89→            <th>Event</th>\n    90→            <th>Amount</th>\n    91→          </tr>\n    92→        </thead>\n    93→        <tbody>\n    94→          {transactions.map((tx) => (\n    95→            <tr key={tx.id}>\n    96→              <td>{formatTime(tx.createdAt)}</td>\n    97→              <td>\n    98→                <a\n    99→                  href={matchPath(tx.gameId, tx.matchId)}\n   100→                  className=\"profile-transactions__match-link\"\n   101→                >\n   102→                  {GAME_NAMES[tx.gameId] ?? tx.gameId}\n   103→                </a>\n   104→              </td>\n   105→              <td\n   106→                className={`profile-transactions__event profile-transactions__event--${tx.event}`}\n   107→              >\n   108→                {EVENT_LABELS[tx.event] ?? tx.event}\n   109→              </td>\n   110→              <td>{formatSol(tx.amountLamports, solPrice)}</td>\n   111→            </tr>\n   112→          ))}\n   113→        </tbody>\n   114→      </table>\n   115→\n   116→      {nextCursor && (\n   117→        <div className=\"profile-transactions__load-more\">\n   118→          <button\n   119→            type=\"button\"\n   120→            className=\"profile-transactions__load-more-btn\"\n   121→            onClick={loadMore}\n   122→            disabled={loadingMore}\n   123→          >\n   124→            {loadingMore ? \"Loading...\" : \"Load more\"}\n   125→          </button>\n   126→        </div>\n   127→      )}\n   128→    </div>\n   129→  );\n   130→}\n   131→"}]},"parent_tool_use_id":null,"session_id":"2e901ca7-f324-4059-af72-9bf4577c7570","uuid":"5f0b40fa-799b-4b83-8132-ffcca9808ee5","timestamp":"2026-03-19T19:24:16.766Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/components/ProfileTransactions.tsx","content":"/**\n * ProfileTransactions - Transaction history tab content\n *\n * Fetches real transaction data from the backend API and displays\n * a paginated table with event types, amounts, and match links.\n */\n\nimport { GAME_NAMES } from \"../types\";\nimport type { GameId } from \"../types\";\nimport { useTransactions } from \"../hooks/useTransactions\";\nimport { useSolPrice } from \"../hooks/useSolPrice\";\n\n/** Format lamports as SOL string with optional USD estimate */\nfunction formatSol(lamports: string, solUsdPrice: number | null): string {\n  const sol = Number(lamports) / 1e9;\n  const solStr =\n    sol.toLocaleString(\"en-US\", {\n      minimumFractionDigits: 2,\n      maximumFractionDigits: 4,\n    }) + \" SOL\";\n  if (solUsdPrice == null) return solStr;\n  const usd = sol * solUsdPrice;\n  return `${solStr} (~$${usd.toLocaleString(\"en-US\", { minimumFractionDigits: 2, maximumFractionDigits: 2 })})`;\n}\n\n/** Format ISO date as relative time */\nfunction formatTime(iso: string): string {\n  const date = new Date(iso);\n  const diffMs = Date.now() - date.getTime();\n  const diffMins = Math.floor(diffMs / 60000);\n  const diffHours = Math.floor(diffMs / 3600000);\n  const diffDays = Math.floor(diffMs / 86400000);\n\n  if (diffMins < 1) return \"Just now\";\n  if (diffMins < 60) return `${diffMins}m ago`;\n  if (diffHours < 24) return `${diffHours}h ago`;\n  if (diffDays < 7) return `${diffDays}d ago`;\n  return date.toLocaleDateString();\n}\n\n/** Build the deep-link path for a match */\nfunction matchPath(gameId: GameId, matchId: string): string {\n  return `/${gameId}/${matchId}`;\n}\n\n/** Event display label */\nconst EVENT_LABELS: Record<string, string> = {\n  join: \"JOIN\",\n  win: \"WIN\",\n  loss: \"LOSS\",\n  refund: \"REFUND\",\n};\n\nexport function ProfileTransactions() {\n  const { transactions, loading, loadingMore, nextCursor, loadMore } =\n    useTransactions();\n  const solPrice = useSolPrice();\n\n  if (loading) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__skeleton\">\n          {Array.from({ length: 5 }, (_, i) => (\n            <div key={i} className=\"profile-transactions__skeleton-row\" />\n          ))}\n        </div>\n      </div>\n    );\n  }\n\n  if (transactions.length === 0) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__empty\">\n          <p>No transactions yet.</p>\n          <p>Start playing to build your history!</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"profile-transactions\">\n      <table className=\"profile-transactions__table\">\n        <thead>\n          <tr>\n            <th>Time</th>\n            <th>Game</th>\n            <th>Event</th>\n            <th>Amount</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id}>\n              <td>{formatTime(tx.createdAt)}</td>\n              <td>\n                <a\n                  href={matchPath(tx.gameId, tx.matchId)}\n                  className=\"profile-transactions__match-link\"\n                >\n                  {GAME_NAMES[tx.gameId] ?? tx.gameId}\n                </a>\n              </td>\n              <td\n                className={`profile-transactions__event profile-transactions__event--${tx.event}`}\n              >\n                {EVENT_LABELS[tx.event] ?? tx.event}\n              </td>\n              <td>{formatSol(tx.amountLamports, solPrice)}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n\n      {nextCursor && (\n        <div className=\"profile-transactions__load-more\">\n          <button\n            type=\"button\"\n            className=\"profile-transactions__load-more-btn\"\n            onClick={loadMore}\n            disabled={loadingMore}\n          >\n            {loadingMore ? \"Loading...\" : \"Load more\"}\n          </button>\n        </div>\n      )}\n    </div>\n  );\n}\n","numLines":131,"startLine":1,"totalLines":131}}}
