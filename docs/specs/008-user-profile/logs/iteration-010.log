{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018P9Vn7ydzix8KmSg6RUqgw","type":"tool_result","content":"     1→import { defineConfig, devices } from \"@playwright/test\";\n     2→\n     3→/**\n     4→ * Playwright config for devnet E2E integration tests.\n     5→ *\n     6→ * Runs against deployed devnet contracts with real VRF fulfillment.\n     7→ * Does NOT start a local validator or deploy programs — requires\n     8→ * pre-deployed contracts and env vars (see e2e/devnet/helpers/env.ts).\n     9→ *\n    10→ * Required env vars (set before running, or in .env.devnet):\n    11→ *   VITE_RPC_URL                — Devnet RPC endpoint\n    12→ *   VITE_COINFLIP_PROGRAM_ID   — Deployed coinflip program address\n    13→ *   VITE_PLATFORM_PROGRAM_ID   — Deployed platform program address\n    14→ *\n    15→ * Optional:\n    16→ *   VITE_SOLANA_NETWORK        — Cluster name (default: \"devnet\")\n    17→ */\n    18→export default defineConfig({\n    19→  testDir: \"./e2e\",\n    20→  fullyParallel: false,\n    21→  forbidOnly: !!process.env.CI,\n    22→  retries: 2,\n    23→  workers: 1,\n    24→  reporter: \"list\",\n    25→  // Longer timeout: VRF fulfillment can take up to 180s + assertions + cleanup\n    26→  timeout: 300_000,\n    27→\n    28→  use: {\n    29→    baseURL: \"http://localhost:3003\",\n    30→    screenshot: \"only-on-failure\",\n    31→    trace: \"retain-on-failure\",\n    32→    video: \"on\",\n    33→    ...devices[\"Desktop Chrome\"],\n    34→    viewport: { width: 1280, height: 1080 },\n    35→  },\n    36→\n    37→  projects: [\n    38→    {\n    39→      name: \"devnet-e2e\",\n    40→      testMatch: \"devnet/**/*.spec.ts\",\n    41→      use: {\n    42→        ...devices[\"Desktop Chrome\"],\n    43→        viewport: { width: 1280, height: 1080 },\n    44→      },\n    45→    },\n    46→  ],\n    47→\n    48→  webServer: {\n    49→    command: \"npx vite --port 3003\",\n    50→    url: \"http://localhost:3003\",\n    51→    reuseExistingServer: !process.env.CI,\n    52→    timeout: 30_000,\n    53→    env: {\n    54→      VITE_MOCK_MODE: \"false\",\n    55→      VITE_TEST_WALLET: \"true\",\n    56→      // RPC URL and program IDs are inherited from the process environment.\n    57→      // They must be set before running this config (see env.ts validation).\n    58→      // VITE_SOLANA_NETWORK defaults to \"devnet\" in the app if not set.\n    59→    },\n    60→  },\n    61→});\n    62→"}]},"parent_tool_use_id":"toolu_01W3FWnMP3mdkVVwaQnFWHDU","session_id":"2e901ca7-f324-4059-af72-9bf4577c7570","uuid":"036478c4-928f-4476-95f7-c553420b25e9","timestamp":"2026-03-19T19:23:05.704Z"}
