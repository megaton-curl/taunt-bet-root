{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014wEiCWPHxKEbbiZvUJG8Me","type":"tool_result","content":"     1→import { test as base, expect, type Page, type ConsoleMessage } from \"@playwright/test\";\n     2→\n     3→const FREEZE_CSS = `\n     4→  *, *::before, *::after {\n     5→    animation-duration: 0s !important;\n     6→    animation-delay: 0s !important;\n     7→    transition-duration: 0s !important;\n     8→    transition-delay: 0s !important;\n     9→    scroll-behavior: auto !important;\n    10→  }\n    11→  /* Pause SVG SMIL animations */\n    12→  svg { animation-play-state: paused !important; }\n    13→`;\n    14→\n    15→/**\n    16→ * Shared visual-regression fixture.\n    17→ *\n    18→ * Extends the default Playwright `test` with a `stablePage` fixture that:\n    19→ *  (a) Seeds Math.random() and Date.now() for determinism\n    20→ *  (b) Injects CSS to disable all CSS + SVG animations/transitions\n    21→ *  (c) Pauses SVG SMIL animations via JS\n    22→ *  (d) Waits for document.fonts.ready and network idle\n    23→ *  (e) Collects console errors and fails the test if any are found\n    24→ */\n    25→export const test = base.extend<{ stablePage: Page }>({\n    26→  stablePage: async ({ page }, use) => {\n    27→    // (e) Collect console errors throughout the test (filtering expected noise)\n    28→    const NOISE_PATTERNS = [\n    29→      \"401\",                 // JWT auth attempts in mock mode (no backend)\n    30→      \"403\",                 // Auth rejection in mock mode\n    31→      \"429\",                 // Rate limit (multiple visual tests hit same endpoints)\n    32→      \"favicon\",             // Missing favicon\n    33→      \"ERR_CONNECTION_REFUSED\", // Backend not running in visual test mode\n    34→      \"Failed to fetch\",     // Network requests to non-existent backend\n    35→      \"Failed to load resource\", // Generic resource loading failures (auth, rate limit)\n    36→      \"NetworkError\",        // Same\n    37→    ];\n    38→    const consoleErrors: string[] = [];\n    39→    page.on(\"console\", (msg: ConsoleMessage) => {\n    40→      if (msg.type() === \"error\") {\n    41→        const text = msg.text();\n    42→        if (!NOISE_PATTERNS.some((p) => text.includes(p))) {\n    43→          consoleErrors.push(text);\n    44→        }\n    45→      }\n    46→    });\n    47→\n    48→    // (a) Deterministic Math.random, crypto.getRandomValues, and frozen Date.now\n    49→    await page.addInitScript(() => {\n    50→      // Mulberry32 seeded PRNG — deterministic sequence from seed 42\n    51→      let seed = 42;\n    52→      function mulberry32(): number {\n    53→        seed |= 0;\n    54→        seed = (seed + 0x6d2b79f5) | 0;\n    55→        let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);\n    56→        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;\n    57→        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n    58→      }\n    59→\n    60→      Math.random = mulberry32;\n    61→\n    62→      // Also seed crypto.getRandomValues so Keypair.generate() is deterministic\n    63→      crypto.getRandomValues = <T extends ArrayBufferView | null>(array: T): T => {\n    64→        if (array === null) return array;\n    65→        const view = new Uint8Array(\n    66→          (array as ArrayBufferView).buffer,\n    67→          (array as ArrayBufferView).byteOffset,\n    68→          (array as ArrayBufferView).byteLength,\n    69→        );\n    70→        for (let i = 0; i < view.length; i++) {\n    71→          view[i] = Math.floor(mulberry32() * 256);\n    72→        }\n    73→        return array;\n    74→      };\n    75→\n    76→      // Freeze Date.now to a fixed timestamp (2026-01-01T00:00:00Z)\n    77→      const frozen = 1767225600000;\n    78→      Date.now = () => frozen;\n    79→    });\n    80→\n    81→    // Store the original goto so we can wrap it\n    82→    const originalGoto = page.goto.bind(page);\n    83→\n    84→    // Override goto to always wait for fonts + network idle after navigation\n    85→    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n    86→      const response = await originalGoto(url, {\n    87→        waitUntil: \"networkidle\",\n    88→        ...options,\n    89→      });\n    90→\n    91→      // (b) Inject animation-disabling CSS (navigation clears addStyleTag)\n    92→      await page.addStyleTag({ content: FREEZE_CSS });\n    93→\n    94→      // (c) Pause all SVG SMIL animations\n    95→      await page.evaluate(() => {\n    96→        document.querySelectorAll(\"svg\").forEach((svg) => {\n    97→          if (typeof svg.pauseAnimations === \"function\") {\n    98→            svg.pauseAnimations();\n    99→          }\n   100→        });\n   101→      });\n   102→\n   103→      // (d) Wait for all fonts to finish loading\n   104→      await page.evaluate(() => document.fonts.ready);\n   105→\n   106→      // Settle time for remaining paints\n   107→      await page.waitForTimeout(300);\n   108→\n   109→      return response;\n   110→    };\n   111→\n   112→    await use(page);\n   113→\n   114→    // (e) Assert no console errors after test completes\n   115→    if (consoleErrors.length > 0) {\n   116→      throw new Error(\n   117→        `Console errors detected during test:\\n${consoleErrors.map((e) => `  - ${e}`).join(\"\\n\")}`\n   118→      );\n   119→    }\n   120→  },\n   121→});\n   122→\n   123→export { expect };\n   124→"}]},"parent_tool_use_id":"toolu_01UA9aMTi19hVBj2fyombQK6","session_id":"2e901ca7-f324-4059-af72-9bf4577c7570","uuid":"35a51c62-4ba0-454d-9be4-b1bcf7c809f8","timestamp":"2026-03-19T19:23:14.503Z"}
