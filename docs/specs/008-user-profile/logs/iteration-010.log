aitForSelector(\".rng-wallet-button--connected\", {\n   218→        timeout: 5000,\n   219→      });\n   220→\n   221→      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n   222→      await stablePage.addStyleTag({\n   223→        content: `\n   224→          *, *::before, *::after {\n   225→            animation-duration: 0s !important;\n   226→            animation-delay: 0s !important;\n   227→            transition-duration: 0s !important;\n   228→            transition-delay: 0s !important;\n   229→            scroll-behavior: auto !important;\n   230→          }\n   231→          svg { animation-play-state: paused !important; }\n   232→        `,\n   233→      });\n   234→\n   235→      // Settle time for UI to stabilize\n   236→      await stablePage.waitForTimeout(300);\n   237→\n   238→      await expect(stablePage).toHaveScreenshot(\"closecall-connected.png\", { fullPage: true });\n   239→    });\n   240→  });\n   241→\n   242→  test.describe(\"Coinflip page\", () => {\n   243→    test(\"wallet disconnected\", async ({ stablePage }) => {\n   244→      // Clear any persisted wallet state to ensure disconnected\n   245→      await stablePage.addInitScript(() => {\n   246→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   247→      });\n   248→      await stablePage.goto(\"/coinflip\");\n   249→      await expect(stablePage).toHaveScreenshot(\"coinflip-disconnected.png\", { fullPage: true });\n   250→    });\n   251→\n   252→    test(\"wallet connected\", async ({ stablePage }) => {\n   253→      // Clear persisted state first so connect generates fresh from seeded PRNG\n   254→      await stablePage.addInitScript(() => {\n   255→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   256→      });\n   257→      await stablePage.goto(\"/coinflip\");\n   258→\n   259→      // Click the wallet connect button\n   260→      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n   261→\n   262→      // Wait for connected state\n   263→      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n   264→        timeout: 5000,\n   265→      });\n   266→\n   267→      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n   268→      await stablePage.addStyleTag({\n   269→        content: `\n   270→          *, *::before, *::after {\n   271→            animation-duration: 0s !important;\n   272→            animation-delay: 0s !important;\n   273→            transition-duration: 0s !important;\n   274→            transition-delay: 0s !important;\n   275→            scroll-behavior: auto !important;\n   276→          }\n   277→          svg { animation-play-state: paused !important; }\n   278→        `,\n   279→      });\n   280→\n   281→      // Settle time for UI to stabilize\n   282→      await stablePage.waitForTimeout(300);\n   283→\n   284→      await expect(stablePage).toHaveScreenshot(\"coinflip-connected.png\", { fullPage: true });\n   285→    });\n   286→\n   287→    test(\"error toast below middle container\", async ({ stablePage }) => {\n   288→      await stablePage.addInitScript(() => {\n   289→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   290→      });\n   291→      await stablePage.goto(\"/coinflip\");\n   292→\n   293→      // Inject a representative error toast at runtime so placement is snapshot-tested.\n   294→      await stablePage.evaluate(() => {\n   295→        const existing = document.querySelector(\".coinflip-error-toast\");\n   296→        if (existing) existing.remove();\n   297→\n   298→        const wrapper = document.createElement(\"div\");\n   299→        wrapper.className = \"coinflip-error-toast\";\n   300→\n   301→        const toast = document.createElement(\"div\");\n   302→        toast.className = \"rng-toast rng-toast--error\";\n   303→        toast.setAttribute(\"role\", \"alert\");\n   304→\n   305→        const message = document.createElement(\"span\"