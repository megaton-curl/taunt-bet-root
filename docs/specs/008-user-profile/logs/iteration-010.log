{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LJ7Y7d13Y3nf8WCL6M6Hof","type":"tool_result","content":"     1→/**\n     2→ * useTransactions — fetches transaction history from the real API.\n     3→ *\n     4→ * Uses JWT auth (from auth-store) and cursor-based pagination.\n     5→ */\n     6→\n     7→import { useState, useCallback, useEffect, useRef } from \"react\";\n     8→import { getAccessToken } from \"../../../lib/auth-store\";\n     9→import type { GameId, TransactionEvent } from \"../types\";\n    10→\n    11→const BACKEND_URL = (\n    12→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    13→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    14→).replace(/\\/$/, \"\");\n    15→\n    16→interface ApiTransaction {\n    17→  id: string;\n    18→  game: string;\n    19→  matchId: string;\n    20→  event: TransactionEvent;\n    21→  amountLamports: string;\n    22→  txSig: string | null;\n    23→  createdAt: string;\n    24→}\n    25→\n    26→interface ApiResponse {\n    27→  transactions: ApiTransaction[];\n    28→  nextCursor: string | null;\n    29→}\n    30→\n    31→export interface Transaction {\n    32→  id: string;\n    33→  gameId: GameId;\n    34→  matchId: string;\n    35→  event: TransactionEvent;\n    36→  amountLamports: string;\n    37→  txSig: string | null;\n    38→  createdAt: string;\n    39→}\n    40→\n    41→export function useTransactions(game?: string) {\n    42→  const [transactions, setTransactions] = useState<Transaction[]>([]);\n    43→  const [nextCursor, setNextCursor] = useState<string | null>(null);\n    44→  const [loading, setLoading] = useState(true);\n    45→  const [loadingMore, setLoadingMore] = useState(false);\n    46→  const [error, setError] = useState<string | null>(null);\n    47→  const abortRef = useRef<AbortController | null>(null);\n    48→\n    49→  const fetchPage = useCallback(\n    50→    async (cursor?: string) => {\n    51→      const token = getAccessToken();\n    52→      if (!token) {\n    53→        setTransactions([]);\n    54→        setLoading(false);\n    55→        return;\n    56→      }\n    57→\n    58→      // Build query string\n    59→      const parts = [\"limit=20\"];\n    60→      if (cursor) parts.push(`cursor=${encodeURIComponent(cursor)}`);\n    61→      if (game) parts.push(`game=${encodeURIComponent(game)}`);\n    62→      const qs = parts.join(\"&\");\n    63→\n    64→      // Abort any in-flight request\n    65→      abortRef.current?.abort();\n    66→      const controller = new AbortController();\n    67→      abortRef.current = controller;\n    68→\n    69→      try {\n    70→        const res = await fetch(\n    71→          `${BACKEND_URL}/profile/transactions?${qs}`,\n    72→          {\n    73→            headers: { Authorization: `Bearer ${token}` },\n    74→            signal: controller.signal,\n    75→          },\n    76→        );\n    77→        if (!res.ok) throw new Error(`HTTP ${res.status}`);\n    78→        const data: ApiResponse = await res.json();\n    79→\n    80→        const mapped: Transaction[] = data.transactions.map((tx) => ({\n    81→          id: tx.id,\n    82→          gameId: tx.game as GameId,\n    83→          matchId: tx.matchId,\n    84→          event: tx.event,\n    85→          amountLamports: tx.amountLamports,\n    86→          txSig: tx.txSig,\n    87→          createdAt: tx.createdAt,\n    88→        }));\n    89→\n    90→        if (cursor) {\n    91→          setTransactions((prev) => [...prev, ...mapped]);\n    92→        } else {\n    93→          setTransactions(mapped);\n    94→        }\n    95→        setNextCursor(data.nextCursor);\n    96→        setError(null);\n    97→      } catch (err) {\n    98→        if (err instanceof Error && err.name === \"AbortError\") return;\n    99→        setError(err instanceof Error ? err.message : \"Failed to fetch\");\n   100→      } finally {\n   101→        setLoading(false);\n   102→        setLoadingMore(false);\n   103→      }\n   104→    },\n   105→    [game],\n   106→  );\n   107→\n   108→  useEffect(() => {\n   109→    setLoading(true);\n   110→    setTransactions([]);\n   111→    setNextCursor(null);\n   112→    fetchPage();\n   113→    return () => abortRef.current?.abort();\n   114→  }, [fetchPage]);\n   115→\n   116→  const loadMore = useCallback(() => {\n   117→    if (!nextCursor || loadingMore) return;\n   118→    setLoadingMore(true);\n   119→    fetchPage(nextCursor);\n   120→  }, [nextCursor, loadingMore, fetchPage]);\n   121→\n   122→  return { transactions, loading, loadingMore, error, nextCursor, loadMore };\n   123→}\n   124→"}]},"parent_tool_use_id":null,"session_id":"2e901ca7-f324-4059-af72-9bf4577c7570","uuid":"bf29b4e3-7e2a-414e-b46f-204b01480203","timestamp":"2026-03-19T19:24:04.775Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/hooks/useTransactions.ts","content":"/**\n * useTransactions — fetches transaction history from the real API.\n *\n * Uses JWT auth (from auth-store) and cursor-based pagination.\n */\n\nimport { useState, useCallback, useEffect, useRef } from \"react\";\nimport { getAccessToken } from \"../../../lib/auth-store\";\nimport type { GameId, TransactionEvent } from \"../types\";\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\ninterface ApiTransaction {\n  id: string;\n  game: string;\n  matchId: string;\n  event: TransactionEvent;\n  amountLamports: string;\n  txSig: string | null;\n  createdAt: string;\n}\n\ninterface ApiResponse {\n  transactions: ApiTransaction[];\n  nextCursor: string | null;\n}\n\nexport interface Transaction {\n  id: string;\n  gameId: GameId;\n  matchId: string;\n  event: TransactionEvent;\n  amountLamports: string;\n  txSig: string | null;\n  createdAt: string;\n}\n\nexport function useTransactions(game?: string) {\n  const [transactions, setTransactions] = useState<Transaction[]>([]);\n  const [nextCursor, setNextCursor] = useState<string | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [loadingMore, setLoadingMore] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n  const abortRef = useRef<AbortController | null>(null);\n\n  const fetchPage = useCallback(\n    async (cursor?: string) => {\n      const token = getAccessToken();\n      if (!token) {\n        setTransactions([]);\n        setLoading(false);\n        return;\n      }\n\n      // Build query string\n      const parts = [\"limit=20\"];\n      if (cursor) parts.push(`cursor=${encodeURIComponent(cursor)}`);\n      if (game) parts.push(`game=${encodeURIComponent(game)}`);\n      const qs = parts.join(\"&\");\n\n      // Abort any in-flight request\n      abortRef.current?.abort();\n      const controller = new AbortController();\n      abortRef.current = controller;\n\n      try {\n        const res = await fetch(\n          `${BACKEND_URL}/profile/transactions?${qs}`,\n          {\n            headers: { Authorization: `Bearer ${token}` },\n            signal: controller.signal,\n          },\n        );\n        if (!res.ok) throw new Error(`HTTP ${res.status}`);\n        const data: ApiResponse = await res.json();\n\n        const mapped: Transaction[] = data.transactions.map((tx) => ({\n          id: tx.id,\n          gameId: tx.game as GameId,\n          matchId: tx.matchId,\n          event: tx.event,\n          amountLamports: tx.amountLamports,\n          txSig: tx.txSig,\n          createdAt: tx.createdAt,\n        }));\n\n        if (cursor) {\n          setTransactions((prev) => [...prev, ...mapped]);\n        } else {\n          setTransactions(mapped);\n        }\n        setNextCursor(data.nextCursor);\n        setError(null);\n      } catch (err) {\n        if (err instanceof Error && err.name === \"AbortError\") return;\n        setError(err instanceof Error ? err.message : \"Failed to fetch\");\n      } finally {\n        setLoading(false);\n        setLoadingMore(false);\n      }\n    },\n    [game],\n  );\n\n  useEffect(() => {\n    setLoading(true);\n    setTransactions([]);\n    setNextCursor(null);\n    fetchPage();\n    return () => abortRef.current?.abort();\n  }, [fetchPage]);\n\n  const loadMore = useCallback(() => {\n    if (!nextCursor || loadingMore) return;\n    setLoadingMore(true);\n    fetchPage(nextCursor);\n  }, [nextCursor, loadingMore, fetchPage]);\n\n  return { transactions, loading, loadingMore, error, nextCursor, loadMore };\n}\n","numLines":124,"startLine":1,"totalLines":124}}}
