{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D3EezVCmCtwmQTwmvNs8SS","type":"tool_result","content":"     1→/**\n     2→ * Player Profile Types\n     3→ *\n     4→ * Defines all types for the player profile system including\n     5→ * XP/levels, avatars, statistics, loot, and transactions.\n     6→ */\n     7→\n     8→\n     9→// ============ Level Border System ============\n    10→\n    11→export type BorderStyle = \"none\" | \"iron\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n    12→\n    13→export interface BorderConfig {\n    14→  minLevel: number;\n    15→  color: string;\n    16→  glow: string;\n    17→}\n    18→\n    19→export const LEVEL_BORDERS: Record<BorderStyle, BorderConfig> = {\n    20→  none: { minLevel: 0, color: \"rgba(255, 255, 255, 0.3)\", glow: \"0 0 6px rgba(255, 255, 255, 0.2)\" },\n    21→  iron: { minLevel: 5, color: \"#a8a8a8\", glow: \"0 0 8px #a8a8a8\" },\n    22→  silver: { minLevel: 10, color: \"#c0c0c0\", glow: \"0 0 10px #c0c0c0\" },\n    23→  gold: { minLevel: 15, color: \"#f0b820\", glow: \"0 0 12px #f0b820\" },\n    24→  platinum: { minLevel: 20, color: \"#40c080\", glow: \"0 0 14px #40c080\" },\n    25→  diamond: { minLevel: 25, color: \"#b9f2ff\", glow: \"0 0 16px #b9f2ff, 0 0 24px #b9f2ff\" },\n    26→};\n    27→\n    28→// ============ Avatar System ============\n    29→\n    30→// The Path of the Doge — progression avatars unlocked at specific levels\n    31→export type AvatarId =\n    32→  | \"recruit\"        // Lv 1\n    33→  | \"mercenary\"      // Lv 5\n    34→  | \"cadet\"          // Lv 10\n    35→  | \"vanguard\"       // Lv 15\n    36→  | \"knight\"         // Lv 20\n    37→  | \"champion\"       // Lv 30\n    38→  | \"paladin\"        // Lv 40\n    39→  | \"grandmaster\"    // Lv 50\n    40→  | \"warlord\"        // Lv 60\n    41→  | \"sovereign\"      // Lv 70\n    42→  | \"archon\"         // Lv 80\n    43→  | \"ascendant\"      // Lv 90\n    44→  | \"cosmic_deity\";  // Lv 100\n    45→\n    46→export type AvatarTier = \"starter\" | \"adept\" | \"elite\" | \"legendary\" | \"mythic\";\n    47→\n    48→export interface AvatarConfig {\n    49→  id: AvatarId;\n    50→  name: string;\n    51→  description: string;\n    52→  tier: AvatarTier;\n    53→  unlockLevel: number;\n    54→}\n    55→\n    56→export const AVATAR_CONFIGS: AvatarConfig[] = [\n    57→  {\n    58→    id: \"recruit\",\n    59→    name: \"Recruit\",\n    60→    description: \"A humble Doge with a curious expression and no gear\",\n    61→    tier: \"starter\",\n    62→    unlockLevel: 1,\n    63→  },\n    64→  {\n    65→    id: \"mercenary\",\n    66→    name: \"Mercenary\",\n    67→    description: \"A rugged soldier of fortune with a dark hood and leather eyepatch\",\n    68→    tier: \"starter\",\n    69→    unlockLevel: 5,\n    70→  },\n    71→  {\n    72→    id: \"cadet\",\n    73→    name: \"Cadet\",\n    74→    description: \"First step into the military — a simple iron kettle-hat helmet\",\n    75→    tier: \"adept\",\n    76→    unlockLevel: 10,\n    77→  },\n    78→  {\n    79→    id: \"vanguard\",\n    80→    name: \"Vanguard\",\n    81→    description: \"Front-line ready with a thick quilted leather gorget\",\n    82→    tier: \"adept\",\n    83→    unlockLevel: 15,\n    84→  },\n    85→  {\n    86→    id: \"knight\",\n    87→    name: \"Knight\",\n    88→    description: \"Fully encased in a polished steel close-helm\",\n    89→    tier: \"adept\",\n    90→    unlockLevel: 20,\n    91→  },\n    92→  {\n    93→    id: \"champion\",\n    94→    name: \"Champion\",\n    95→    description: \"Elite knight with a vibrant red feathered plume\",\n    96→    tier: \"elite\",\n    97→    unlockLevel: 30,\n    98→  },\n    99→  {\n   100→    id: \"paladin\",\n   101→    name: \"Paladin\",\n   102→    description: \"First hint of divinity — white-silver chrome with golden holy glow\",\n   103→    tier: \"elite\",\n   104→    unlockLevel: 40,\n   105→  },\n   106→  {\n   107→    id: \"grandmaster\",\n   108→    name: \"Grandmaster\",\n   109→    description: \"Visored Great Helm covered in intricate gold-etched filigree\",\n   110→    tier: \"legendary\",\n   111→    unlockLevel: 50,\n   112→  },\n   113→  {\n   114→    id: \"warlord\",\n   115→    name: \"Warlord\",\n   116→    description: \"Battle-worn veteran with a wolf-pelt mantle and a glowing red ember eye\",\n   117→    tier: \"legendary\",\n   118→    unlockLevel: 60,\n   119→  },\n   120→  {\n   121→    id: \"sovereign\",\n   122→    name: \"Sovereign\",\n   123→    description: \"Jeweled crown welded onto golden plate armor with royal purple cape\",\n   124→    tier: \"legendary\",\n   125→    unlockLevel: 70,\n   126→  },\n   127→  {\n   128→    id: \"archon\",\n   129→    name: \"Archon\",\n   130→    description: \"Glowing blue Mithril armor with runic stones orbiting the head\",\n   131→    tier: \"mythic\",\n   132→    unlockLevel: 80,\n   133→  },\n   134→  {\n   135→    id: \"ascendant\",\n   136→    name: \"Ascendant\",\n   137→    description: \"Semi-translucent ghostly form in cracked void armor leaking neon energy\",\n   138→    tier: \"mythic\",\n   139→    unlockLevel: 90,\n   140→  },\n   141→  {\n   142→    id: \"cosmic_deity\",\n   143→    name: \"Cosmic Deity\",\n   144→    description: \"Body of swirling nebulae, star eyes, galaxy halo, ethereal filament wings\",\n   145→    tier: \"mythic\",\n   146→    unlockLevel: 100,\n   147→  },\n   148→];\n   149→\n   150→export const DEFAULT_AVATAR_ID: AvatarId = \"recruit\";\n   151→\n   152→// Get the highest unlocked avatar for a given level\n   153→export function getHighestUnlockedAvatar(level: number): AvatarId {\n   154→  const unlocked = AVATAR_CONFIGS.filter(a => a.unlockLevel <= level);\n   155→  if (unlocked.length === 0) return DEFAULT_AVATAR_ID;\n   156→  const lastAvatar = unlocked[unlocked.length - 1];\n   157→  return lastAvatar ? lastAvatar.id : DEFAULT_AVATAR_ID;\n   158→}\n   159→\n   160→// Avatar tier colors for UI display\n   161→export const AVATAR_TIER_COLORS: Record<AvatarTier, string> = {\n   162→  starter: \"#a8a8a8\",   // Gray\n   163→  adept: \"#4a9eff\",     // Blue\n   164→  elite: \"#9d4eff\",     // Purple\n   165→  legendary: \"#f0b820\", // Gold\n   166→  mythic: \"#f0b820\",    // Pink/Magenta\n   167→};\n   168→\n   169→// ============ Game Types ============\n   170→\n   171→export type GameId = \"coinflip\" | \"lord-of-rngs\" | \"crypto-crash\" | \"close-call\" | \"game-of-trades\";\n   172→\n   173→export const GAME_NAMES: Record<GameId, string> = {\n   174→  coinflip: \"Flip You\",\n   175→  \"lord-of-rngs\": \"Jackpot\",\n   176→  \"crypto-crash\": \"Crypto Crash\",\n   177→  \"close-call\": \"Close Call\",\n   178→  \"game-of-trades\": \"Game of Trades\",\n   179→};\n   180→\n   181→// ============ Player Statistics ============\n   182→\n   183→export interface GameSpecificStats {\n   184→  gamesPlayed: number;\n   185→  wagered: number;\n   186→  winnings: number;\n   187→  wins: number;\n   188→  losses: number;\n   189→}\n   190→\n   191→export interface PlayerStats {\n   192→  // Aggregate stats\n   193→  gamesPlayed: number;\n   194→  totalWagered: number;\n   195→  totalWins: number;\n   196→  netProfit: number;\n   197→  wins: number;\n   198→  losses: number;\n   199→\n   200→  // Streak tracking\n   201→  currentWinStreak: number;\n   202→  bestWinStreak: number;\n   203→\n   204→  // Per-game breakdown\n   205→  gameStats: Record<GameId, GameSpecificStats>;\n   206→}\n   207→\n   208→export function createEmptyStats(): PlayerStats {\n   209→  return {\n   210→    gamesPlayed: 0,\n   211→    totalWagered: 0,\n   212→    totalWins: 0,\n   213→    netProfit: 0,\n   214→    wins: 0,\n   215→    losses: 0,\n   216→    currentWinStreak: 0,\n   217→    bestWinStreak: 0,\n   218→    gameStats: {\n   219→      coinflip: { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   220→      \"lord-of-rngs\": { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   221→      \"crypto-crash\": { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   222→      \"close-call\": { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   223→      \"game-of-trades\": { gamesPlayed: 0, wagered: 0, winnings: 0, wins: 0, losses: 0 },\n   224→    },\n   225→  };\n   226→}\n   227→\n   228→// ============ Loot System ============\n   229→\n   230→export type LootSource = \"game_win\" | \"raid_boss\" | \"promo\" | \"achievement\";\n   231→\n   232→export interface LootItem {\n   233→  id: string;\n   234→  source: LootSource;\n   235→  amount: number; // amount\n   236→  description: string;\n   237→  earnedAt: number;\n   238→  expiresAt?: number;\n   239→  gameId?: GameId;\n   240→  matchId?: string;\n   241→}\n   242→\n   243→// ============ Transaction History ============\n   244→\n   245→export type TransactionEvent = \"join\" | \"win\" | \"loss\" | \"refund\";\n   246→\n   247→export interface ProfileTransaction {\n   248→  id: string;\n   249→  gameId: GameId;\n   250→  matchId: string;\n   251→  event: TransactionEvent;\n   252→  amountLamports: string;\n   253→  txSig: string | null;\n   254→  createdAt: string;\n   255→}\n   256→\n   257→// ============ Player Profile ============\n   258→\n   259→export interface PlayerProfile {\n   260→  // Identity\n   261→  address: string;\n   262→  username: string | null;\n   263→  avatarId: AvatarId;\n   264→\n   265→  // Level system\n   266→  level: number;\n   267→  currentXP: number; // XP within current level\n   268→  totalXP: number; // Lifetime XP\n   269→\n   270→  // Connected socials\n   271→  discordUsername: string | null;\n   272→  twitterHandle: string | null;\n   273→\n   274→  // Statistics\n   275→  stats: PlayerStats;\n   276→\n   277→  // Unclaimed rewards\n   278→  unclaimedLoot: LootItem[];\n   279→\n   280→  // Timestamps\n   281→  createdAt: number;\n   282→  lastActiveAt: number;\n   283→}\n   284→\n   285→// ============ Event Types ============\n   286→\n   287→export interface GameResultEvent {\n   288→  gameId: GameId;\n   289→  matchId: string;\n   290→  playerAddress: string;\n   291→  wagerAmount: number;\n   292→  outcome: \"win\" | \"loss\";\n   293→  payoutAmount: number;\n   294→  timestamp: number;\n   295→}\n   296→\n   297→// ============ Context Value ============\n   298→\n   299→export interface PlayerProfileContextValue {\n   300→  // Current user's profile\n   301→  myProfile: PlayerProfile | null;\n   302→  loading: boolean;\n   303→\n   304→  // Profile lookup (for other users)\n   305→  getProfile: (address: string) => PlayerProfile | null;\n   306→  loadProfile: (address: string) => Promise<PlayerProfile | null>;\n   307→\n   308→  // Profile mutations\n   309→  updateUsername: (username: string) => Promise<void>;\n   310→  updateAvatar: (avatarId: AvatarId) => Promise<void>;\n   311→  connectDiscord: () => Promise<void>;\n   312→  disconnectDiscord: () => Promise<void>;\n   313→  connectTwitter: () => Promise<void>;\n   314→  disconnectTwitter: () => Promise<void>;\n   315→\n   316→  // Loot\n   317→  claimLoot: (lootId: string) => Promise<number>; // Returns claimed amount\n   318→  claimAllLoot: () => Promise<number>;\n   319→\n   320→  // Mini profile modal state\n   321→  selectedProfileAddress: string | null;\n   322→  openMiniProfile: (address: string) => void;\n   323→  closeMiniProfile: () => void;\n   324→\n   325→  // Display helpers\n   326→  getDisplayName: (address: string) => string;\n   327→  getAvatarId: (address: string) => AvatarId;\n   328→  getBorderStyle: (level: number) => BorderStyle;\n   329→  isAvatarUnlocked: (avatarId: AvatarId, level: number) => boolean;\n   330→}\n   331→\n   332→// ============ Avatar Sizes ============\n   333→\n   334→export type AvatarSize = \"xs\" | \"sm\" | \"md\" | \"lg\" | \"xl\";\n   335→\n   336→export const AVATAR_SIZES: Record<AvatarSize, number> = {\n   337→  xs: 56,\n   338→  sm: 80,\n   339→  md: 104,\n   340→  lg: 140,\n   341→  xl: 200,\n   342→};\n   343→\n   344→// ============ Constants ============\n   345→\n   346→export const MAX_USERNAME_LENGTH = 20;\n   347→export const MIN_USERNAME_LENGTH = 3;\n   348→\n   349→// Username validation regex (alphanumeric, underscores, no spaces)\n   350→export const USERNAME_REGEX = /^[a-zA-Z0-9_]+$/;\n   351→"}]},"parent_tool_use_id":"toolu_01UA9aMTi19hVBj2fyombQK6","session_id":"2e901ca7-f324-4059-af72-9bf4577c7570","uuid":"10ef762b-9cf1-420e-8098-5b951ac60e7e","timestamp":"2026-03-19T19:23:28.009Z"}
