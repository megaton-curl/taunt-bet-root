e=\"profile-page__buff-timer\">\n                    {Math.floor(buffTimeRemaining / 60000)}:{Math.floor((buffTimeRemaining % 60000) / 1000).toString().padStart(2, \"0\")}\n                  </span>\n                </div>\n              </div>\n            )}\n          </div>\n        </div>\n      </div>\n\n      {/* Tabs */}\n      <div className=\"profile-page__tabs\">\n        {tabs.map((tab) => (\n          <button\n            key={tab.id}\n            type=\"button\"\n            className={`profile-page__tab ${activeTab === tab.id ? \"profile-page__tab--active\" : \"\"}`}\n            onClick={() => setActiveTab(tab.id)}\n          >\n            {tab.label}\n          </button>\n        ))}\n      </div>\n\n      {/* Content */}\n      <div className=\"profile-page__content\">\n        {activeTab === \"stats\" && <ProfileStats profile={myProfile} />}\n        {activeTab === \"transactions\" && <ProfileTransactions />}\n        {activeTab === \"settings\" && <ProfileSettings profile={myProfile} />}\n      </div>\n    </div>\n  );\n}\n","numLines":35,"startLine":270,"totalLines":304}}}
