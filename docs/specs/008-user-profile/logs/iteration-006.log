{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gme2UB69xfUuYJALA374HL","type":"tool_result","content":"     1→/**\n     2→ * Hermes price fetcher for BTC/USD.\n     3→ *\n     4→ * Fetches the latest price from Pyth Hermes REST API. No on-chain posting —\n     5→ * prices are now passed as instruction arguments to the Close Call program.\n     6→ */\n     7→\n     8→import { HermesClient } from \"@pythnetwork/hermes-client\";\n     9→import { logger } from \"../logger.js\";\n    10→\n    11→// ---------------------------------------------------------------------------\n    12→// BTC/USD Pyth feed ID (same on mainnet + devnet)\n    13→// ---------------------------------------------------------------------------\n    14→export const BTC_USD_FEED_ID =\n    15→  \"0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43\";\n    16→\n    17→// ---------------------------------------------------------------------------\n    18→// Types\n    19→// ---------------------------------------------------------------------------\n    20→\n    21→export interface HermesPrice {\n    22→  price: bigint;\n    23→  expo: number;\n    24→  publishTime: number;\n    25→  priceHuman: number;\n    26→  vaaBase64: string | null;\n    27→}\n    28→\n    29→export interface HermesFetcher {\n    30→  fetchLatestBtcPrice(): Promise<HermesPrice | null>;\n    31→}\n    32→\n    33→// ---------------------------------------------------------------------------\n    34→// Factory\n    35→// ---------------------------------------------------------------------------\n    36→\n    37→export function createHermesFetcher(\n    38→  endpoint = \"https://hermes.pyth.network\",\n    39→): HermesFetcher {\n    40→  const client = new HermesClient(endpoint, {});\n    41→\n    42→  return {\n    43→    async fetchLatestBtcPrice(): Promise<HermesPrice | null> {\n    44→      try {\n    45→        const updates = await client.getLatestPriceUpdates(\n    46→          [BTC_USD_FEED_ID],\n    47→          { encoding: \"base64\", parsed: true },\n    48→        );\n    49→        const feed = updates.parsed?.[0];\n    50→        if (!feed?.price) return null;\n    51→\n    52→        const price = BigInt(feed.price.price);\n    53→        const expo = feed.price.expo;\n    54→        // Compute human-readable price: price * 10^expo\n    55→        const priceHuman = Number(price) * Math.pow(10, expo);\n    56→\n    57→        // Extract VAA from binary data (base64-encoded)\n    58→        const vaaBase64 = updates.binary?.data?.[0] ?? null;\n    59→\n    60→        return {\n    61→          price,\n    62→          expo,\n    63→          publishTime: feed.price.publish_time,\n    64→          priceHuman,\n    65→          vaaBase64,\n    66→        };\n    67→      } catch (err) {\n    68→        logger.warn(\"hermes: fetch failed\", {\n    69→          error: err instanceof Error ? err.message : String(err),\n    70→        });"}]},"parent_tool_use_id":null,"session_id":"abd010b6-9bf8-408c-8fec-8f2eb32c16a2","uuid":"471e8cbb-ea6b-44b0-bd7e-fb7794eac3c3","timestamp":"2026-03-19T18:58:48.045Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/pyth-poster.ts","content":"/**\n * Hermes price fetcher for BTC/USD.\n *\n * Fetches the latest price from Pyth Hermes REST API. No on-chain posting —\n * prices are now passed as instruction arguments to the Close Call program.\n */\n\nimport { HermesClient } from \"@pythnetwork/hermes-client\";\nimport { logger } from \"../logger.js\";\n\n// ---------------------------------------------------------------------------\n// BTC/USD Pyth feed ID (same on mainnet + devnet)\n// ---------------------------------------------------------------------------\nexport const BTC_USD_FEED_ID =\n  \"0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface HermesPrice {\n  price: bigint;\n  expo: number;\n  publishTime: number;\n  priceHuman: number;\n  vaaBase64: string | null;\n}\n\nexport interface HermesFetcher {\n  fetchLatestBtcPrice(): Promise<HermesPrice | null>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createHermesFetcher(\n  endpoint = \"https://hermes.pyth.network\",\n): HermesFetcher {\n  const client = new HermesClient(endpoint, {});\n\n  return {\n    async fetchLatestBtcPrice(): Promise<HermesPrice | null> {\n      try {\n        const updates = await client.getLatestPriceUpdates(\n          [BTC_USD_FEED_ID],\n          { encoding: \"base64\", parsed: true },\n        );\n        const feed = updates.parsed?.[0];\n        if (!feed?.price) return null;\n\n        const price = BigInt(feed.price.price);\n        const expo = feed.price.expo;\n        // Compute human-readable price: price * 10^expo\n        const priceHuman = Number(price) * Math.pow(10, expo);\n\n        // Extract VAA from binary data (base64-encoded)\n        const vaaBase64 = updates.binary?.data?.[0] ?? null;\n\n        return {\n          price,\n          expo,\n          publishTime: feed.price.publish_time,\n          priceHuman,\n          vaaBase64,\n        };\n      } catch (err) {\n        logger.warn(\"hermes: fetch failed\", {\n          error: err instanceof Error ? err.message : String(err),\n        });","numLines":70,"startLine":1,"totalLines":76}}}
