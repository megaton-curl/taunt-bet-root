{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DjaRTESszc9L9Ce2u777Jv","type":"tool_result","content":"     1→/**\n     2→ * Close Call API routes.\n     3→ *\n     4→ * GET  /closecall/current-round — active round + pool state\n     5→ * GET  /closecall/history       — last N settled/refunded rounds\n     6→ * GET  /closecall/candles       — last N minute-boundary candles from DB\n     7→ * POST /closecall/bet           — co-sign a bet tx (creates round or joins)\n     8→ */\n     9→\n    10→import { Hono } from \"hono\";\n    11→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n    12→import type postgres from \"postgres\";\n    13→import type { CloseCallRound, Db } from \"../db.js\";\n    14→import { logger } from \"../logger.js\";\n    15→import { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\n    16→import { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    17→import { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\n    18→import type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\n    19→\n    20→export interface CloseCallRoutesDeps {\n    21→  db: Db;\n    22→  connection: Connection;\n    23→  serverKeypair: Keypair;\n    24→  clockWorker: CloseCallClockWorker;\n    25→  /** Postgres sql instance for candle queries. */\n    26→  sql: postgres.Sql;\n    27→}\n    28→\n    29→/** Minimum wager in lamports: 0.001 SOL */\n    30→const MIN_WAGER_LAMPORTS = 1_000_000;\n    31→const MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n    32→\n    33→function isValidBase58(s: string): boolean {\n    34→  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n    35→}\n    36→\n    37→/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\n    38→function minuteTsToBuffer(ts: bigint): Buffer {\n    39→  const buf = Buffer.alloc(8);\n    40→  buf.writeBigInt64LE(ts);\n    41→  return buf;\n    42→}\n    43→\n    44→/** Derive the CloseCallRound PDA for a given minute timestamp. */\n    45→function deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    48→    CLOSECALL_PROGRAM_ID,\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→const PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\n    54→const OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n    55→\n    56→/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\n    57→function formatOnChainRound(round: DecodedCloseCallRound, pda: PublicKey) {\n    58→  const greenEntries = round.greenEntries.map((e) => ({\n    59→    player: e.player.toBase58(),\n    60→    amountLamports: Number(e.amountLamports),\n    61→  }));\n    62→  const redEntries = round.redEntries.map((e) => ({\n    63→    player: e.player.toBase58(),\n    64→    amountLamports: Number(e.amountLamports),\n    65→  }));\n    66→  const greenPool = Number(round.greenPool);\n    67→  const redPool = Number(round.redPool);\n    68→  const totalPool = greenPool + redPool;\n    69→\n    70→  return {\n    71→    roundId: Number(round.minuteTs).toString(),\n    72→    pda: pda.toBase58(),\n    73→    phase: PHASE_NAMES[round.phase] ?? \"open\",\n    74→    openPrice: Number(round.openPrice),\n    75→    openPriceExpo: round.openPriceExpo,\n    76→    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n    77→    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n    78→    greenPool,\n    79→    redPool,\n    80→    totalPool,\n    81→    totalFee: Number(round.totalFee),\n    82→    greenEntries,\n    83→    redEntries,\n    84→    greenCount: greenEntries.length,\n    85→    redCount: redEntries.length,\n    86→    settleTx: null,\n    87→    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n    88→    settledAt: null,\n    89→  };\n    90→}\n    91→\n    92→function formatCloseCallRound(round: CloseCallRound) {\n    93→  const totalPool = round.green_pool + round.red_pool;\n    94→  return {\n    95→    roundId: round.round_id,\n    96→    pda: round.pda,\n    97→    phase: round.phase,\n    98→    openPrice: round.open_price,\n    99→    openPriceExpo: round.open_price_expo,\n   100→    closePrice: round.close_price,\n   101→    outcome: round.outcome,\n   102→    greenPool: round.green_pool,\n   103→    redPool: round.red_pool,\n   104→    totalPool,\n   105→    totalFee: round.total_fee,\n   106→    greenEntries: round.green_entries,\n   107→    redEntries: round.red_entries,\n   108→    greenCount: round.green_entries.length,\n   109→    redCount: round.red_entries.length,\n   110→    settleTx: round.settle_tx,\n   111→    createdAt: round.created_at.toISOString(),\n   112→    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n   113→  };\n   114→}\n   115→\n   116→export function createCloseCallRoutes(deps: CloseCallRoutesDeps): Hono {\n   117→  const { db, connection, serverKeypair, clockWorker, sql } = deps;\n   118→  const app = new Hono();\n   119→\n   120→  app.get(\"/current-round\", async (c) => {\n   121→    // Derive PDAs for current and previous minute — the round may still be\n   122→    // open from the previous minute if not yet settled.\n   123→    const nowMinuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n   124→    const prevMinuteTs = nowMinuteTs - 60n;\n   125→\n   126→    const currentPda = deriveCloseCallRoundPda(nowMinuteTs);\n   127→    const prevPda = deriveCloseCallRoundPda(prevMinuteTs);\n   128→\n   129→    try {\n   130→      const [currentInfo, prevInfo] = await Promise.all([\n   131→        connection.getAccountInfo(currentPda),\n   132→        connection.getAccountInfo(prevPda),\n   133→      ]);\n   134→\n   135→      // Prefer the current minute's round; fall back to previous if it's still open\n   136→      if (currentInfo) {\n   137→        const round = decodeCloseCallRound(Buffer.from(currentInfo.data));\n   138→        return c.json({ round: formatOnChainRound(round, currentPda) });\n   139→      }\n   140→\n   141→      if (prevInfo) {\n   142→        const round = decodeCloseCallRound(Buffer.from(prevInfo.data));\n   143→        // Only return previous-minute round if it's still open (phase 0)\n   144→        if (round.phase === 0) {\n   145→          return c.json({ round: formatOnChainRound(round, prevPda) });\n   146→        }\n   147→      }\n   148→\n   149→      return c.json({ round: null });\n   150→    } catch (err) {\n   151→      logger.error(\"closecall current-round: on-chain lookup failed\", {\n   152→        error: err instanceof Error ? err.message : String(err),\n   153→      });\n   154→      return c.json({ round: null });\n   155→    }\n   156→  });\n   157→\n   158→  app.get(\"/history\", async (c) => {\n   159→    const limitParam = c.req.query(\"limit\");\n   160→    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n   161→    const rounds = await db.getCloseCallHistory(limit);\n   162→    return c.json({ rounds: rounds.map(formatCloseCallRound) });\n   163→  });\n   164→\n   165→  // -----------------------------------------------------------------------\n   166→  // GET /candles — returns last N minute-boundary candles from DB\n   167→  // -----------------------------------------------------------------------\n   168→\n   169→  app.get(\"/candles\", async (c) => {\n   170→    const limitParam = c.req.query(\"limit\");\n   171→    const limit = Math.min(Math.max(parseInt(limitParam ?? \"5\", 10) || 5, 1), 60);\n   172→\n   173→    try {\n   174→      // We need limit+1 boundary prices to form `limit` candles.\n   175→      // Each candle = two consecutive boundary prices.\n   176→      const rows = await sql<{\n   177→        minute_ts: string;\n   178→        price_human: number;\n   179→      }[]>`\n   180→        SELECT minute_ts, price_human\n   181→        FROM closecall_candles\n   182→        ORDER BY minute_ts DESC\n   183→        LIMIT ${limit + 1}\n   184→      `;\n   185→\n   186→      if (rows.length < 2) {\n   187→        // Not enough data to form even one candle\n   188→        const bp = clockWorker.getLatestBoundaryPrice();\n   189→        return c.json({\n   190→          candles: [],\n   191→          currentOpenPrice: bp ? bp.priceHuman : null,\n   192→          currentMinuteTs: bp ? bp.minuteTs : null,\n   193→        });\n   194→      }\n   195→\n   196→      // Rows come DESC, reverse to ASC for pairing\n   197→      const sorted = rows.reverse();\n   198→\n   199→      // Build candles from consecutive boundary pairs\n   200→      const candles: Array<{\n   201→        openTime: number;\n   202→        closeTime: number;\n   203→        open: number;\n   204→        close: number;\n   205→        high: number;\n   206→        low: number;\n   207→        outcome: string | null;\n   208→      }> = [];\n   209→\n   210→      for (let i = 0; i < sorted.length - 1; i++) {\n   211→        const openBoundary = sorted[i]!;\n   212→        const closeBoundary = sorted[i + 1]!;\n   213→        const openTs = Number(openBoundary.minute_ts);\n   214→        const closeTs = Number(closeBoundary.minute_ts);\n   215→        const open = openBoundary.price_human;\n   216→        const close = closeBoundary.price_human;\n   217→\n   218→        // Only pair consecutive minute boundaries (60s apart)\n   219→        if (closeTs - openTs !== 60) continue;\n   220→\n   221→        const high = Math.max(open, close);\n   222→        const low = Math.min(open, close);\n   223→\n   224→        // Determine outcome: green if close > open, red if close < open, null if equal\n   225→        let outcome: string | null = null;\n   226→        if (close > open) outcome = \"green\";\n   227→        else if (close < open) outcome = \"red\";\n   228→\n   229→        candles.push({\n   230→          openTime: openTs * 1000,\n   231→          closeTime: closeTs * 1000,\n   232→          open,\n   233→          close,\n   234→          high,\n   235→          low,\n   236→          outcome,\n   237→        });\n   238→      }\n   239→\n   240→      // Current open price = latest boundary price\n   241→      const bp = clockWorker.getLatestBoundaryPrice();\n   242→\n   243→      return c.json({\n   244→        candles,\n   245→        currentOpenPrice: bp ? bp.priceHuman : null,\n   246→        currentMinuteTs: bp ? bp.minuteTs : null,\n   247→      });\n   248→    } catch (err) {\n   249→      logger.error(\"closecall candles: query failed\", {\n   250→        error: err instanceof Error ? err.message : String(err),\n   251→      });\n   252→      return c.json({ candles: [], currentOpenPrice: null, currentMinuteTs: null });\n   253→    }\n   254→  });\n   255→\n   256→  /**\n   257→   * POST /bet — co-sign a bet transaction.\n   258→   *\n   259→   * Uses init_if_needed — creates round on first bet, joins on subsequent.\n   260→   * The server partially signs (pays rent on first call), and returns the\n   261→   * serialized tx for the frontend to add the player signature + submit.\n   262→   */\n   263→  app.post(\"/bet\", async (c) => {\n   264→    // 1. Parse + validate request body\n   265→    let body: { playerPubkey: string; side: \"green\" | \"red\"; amountLamports: number };\n   266→    try {\n   267→      const raw = await c.req.json();\n   268→      if (!raw || typeof raw !== \"object\") throw new Error(\"body must be JSON\");\n   269→      const b = raw as Record<string, unknown>;\n   270→\n   271→      if (typeof b.playerPubkey !== \"string\" || !isValidBase58(b.playerPubkey)) {\n   272→        throw new Error(\"playerPubkey must be a valid base58 public key\");\n   273→      }\n   274→      if (b.side !== \"green\" && b.side !== \"red\") {\n   275→        throw new Error('side must be \"green\" or \"red\"');\n   276→      }\n   277→      if (\n   278→        typeof b.amountLamports !== \"number\" ||\n   279→        !Number.isInteger(b.amountLamports) ||\n   280→        b.amountLamports < MIN_WAGER_LAMPORTS ||\n   281→        b.amountLamports > MAX_WAGER_LAMPORTS\n   282→      ) {\n   283→        throw new Error(`amountLamports must be integer between ${MIN_WAGER_LAMPORTS} and ${MAX_WAGER_LAMPORTS}`);\n   284→      }\n   285→\n   286→      body = {\n   287→        playerPubkey: b.playerPubkey as string,\n   288→        side: b.side as \"green\" | \"red\",\n   289→        amountLamports: b.amountLamports as number,\n   290→      };\n   291→    } catch (err) {\n   292→      logger.warn(\"closecall bet rejected: invalid body\", {\n   293→        error: err instanceof Error ? err.message : \"Invalid request body\",\n   294→      });\n   295→      return c.json({ error: err instanceof Error ? err.message : \"Invalid request body\" }, 400);\n   296→    }\n   297→\n   298→    // 2. Validate playerPubkey\n   299→    let playerPubkey: PublicKey;\n   300→    try {\n   301→      playerPubkey = new PublicKey(body.playerPubkey);\n   302→    } catch {\n   303→      return c.json({ error: \"playerPubkey is not a valid public key\" }, 400);\n   304→    }\n   305→\n   306→    // 3. Get the latest boundary price from the clock worker (cached)\n   307→    const boundaryPrice = clockWorker.getLatestBoundaryPrice();\n   308→    if (!boundaryPrice) {\n   309→      logger.warn(\"closecall bet: no cached boundary price\");\n   310→      return c.json(\n   311→        { error: \"No price data available yet. Wait for next minute boundary.\" },\n   312→        503,\n   313→      );\n   314→    }\n   315→\n   316→    // 4. Compute minuteTs + build partially-signed tx\n   317→    const minuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n   318→    const sideNum = body.side === \"green\" ? 0 : 1;\n   319→\n   320→    try {\n   321→      const { tx, roundPda } = await buildCloseCallBetTx(\n   322→        { connection, serverKeypair },\n   323→        playerPubkey,\n   324→        minuteTs,\n   325→        sideNum,\n   326→        BigInt(body.amountLamports),\n   327→        boundaryPrice.price,\n   328→        boundaryPrice.expo,\n   329→      );\n   330→\n   331→      const serialized = tx.serialize({ requireAllSignatures: false }).toString(\"base64\");\n   332→\n   333→      // Persist round to DB (upsert — idempotent if round already exists)\n   334→      try {\n   335→        await sql`\n   336→          INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   337→          VALUES (\n   338→            ${String(Number(minuteTs))},\n   339→            ${roundPda.toBase58()},\n   340→            ${serverKeypair.publicKey.toBase58()},\n   341→            ${Number(boundaryPrice.price)},\n   342→            ${boundaryPrice.expo}\n   343→          )\n   344→          ON CONFLICT (round_id) DO NOTHING\n   345→        `;\n   346→      } catch (dbErr) {\n   347→        logger.warn(\"closecall bet: DB round insert failed (tx still returned)\", {\n   348→          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n   349→        });\n   350→      }\n   351→\n   352→      logger.info(\"closecall bet: tx built\", {\n   353→        minuteTs: Number(minuteTs),\n   354→        roundPda: roundPda.toBase58(),\n   355→        player: body.playerPubkey,\n   356→        side: body.side,\n   357→        amountLamports: body.amountLamports,\n   358→        openPrice: boundaryPrice.priceHuman,\n   359→      });\n   360→\n   361→      return c.json({\n   362→        transaction: serialized,\n   363→        minuteTs: Number(minuteTs),\n   364→        roundPda: roundPda.toBase58(),\n   365→      });\n   366→    } catch (err) {\n   367→      logger.error(\"closecall bet: tx build failed\", {\n   368→        error: err instanceof Error ? err.message : String(err),\n   369→      });\n   370→      return c.json({ error: \"Failed to build transaction\" }, 500);\n   371→    }\n   372→  });\n   373→\n   374→  return app;\n   375→}\n   376→"}]},"parent_tool_use_id":"toolu_018JcFD6c296Bxab8D9hoKMn","session_id":"abd010b6-9bf8-408c-8fec-8f2eb32c16a2","uuid":"9a82e0c3-1d65-4a64-90ee-9682a654b3d6","timestamp":"2026-03-19T18:58:21.260Z"}
