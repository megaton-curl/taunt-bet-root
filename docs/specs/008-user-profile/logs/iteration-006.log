{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kf86VcYWU5AXr9HX6toymD","type":"tool_result","content":"     1→/**\n     2→ * Auth routes: challenge/verify/refresh/logout for JWT session management.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import { randomBytes, createHash } from \"node:crypto\";\n     7→import nacl from \"tweetnacl\";\n     8→import bs58 from \"bs58\";\n     9→import { SignJWT } from \"jose\";\n    10→import type { AuthDb } from \"../auth-db.js\";\n    11→import { logger } from \"../logger.js\";\n    12→\n    13→export interface AuthRoutesDeps {\n    14→  authDb: AuthDb;\n    15→  jwtSecret: Uint8Array;\n    16→  cluster: string;\n    17→  challengeTtlSeconds: number;\n    18→  accessTokenTtlSeconds: number;\n    19→  refreshTokenTtlDays: number;\n    20→}\n    21→\n    22→function hashToken(token: string): Buffer {\n    23→  return createHash(\"sha256\").update(token).digest();\n    24→}\n    25→\n    26→function buildSignInMessage(\n    27→  wallet: string,\n    28→  cluster: string,\n    29→  nonce: string,\n    30→  issuedAt: string,\n    31→  expiresAt: string,\n    32→): string {\n    33→  return [\n    34→    \"Sign in to RNG Utopia\",\n    35→    `Wallet: ${wallet}`,\n    36→    `Cluster: ${cluster}`,\n    37→    `Nonce: ${nonce}`,\n    38→    `Issued At: ${issuedAt}`,\n    39→    `Expires At: ${expiresAt}`,\n    40→    \"This signature creates a backend session for gameplay actions.\",\n    41→    \"It does not approve a blockchain transaction.\",\n    42→  ].join(\"\\n\");\n    43→}\n    44→\n    45→export function createAuthRoutes(deps: AuthRoutesDeps): Hono {\n    46→  const {\n    47→    authDb,\n    48→    jwtSecret,\n    49→    cluster,\n    50→    challengeTtlSeconds,\n    51→    accessTokenTtlSeconds,\n    52→    refreshTokenTtlDays,\n    53→  } = deps;\n    54→\n    55→  const app = new Hono();\n    56→\n    57→  // POST /challenge — generate nonce + human-readable message\n    58→  app.post(\"/challenge\", async (c) => {\n    59→    let body: { wallet: string };\n    60→    try {\n    61→      body = await c.req.json();\n    62→      if (typeof body.wallet !== \"string\" || body.wallet.length === 0) {\n    63→        return c.json({ error: \"wallet is required\" }, 400);\n    64→      }\n    65→    } catch {\n    66→      return c.json({ error: \"Invalid JSON body\" }, 400);\n    67→    }\n    68→\n    69→    const nonce = randomBytes(32).toString(\"hex\");\n    70→    const now = new Date();\n    71→    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n    72→\n    73→    const message = buildSignInMessage(\n    74→      body.wallet,\n    75→      cluster,\n    76→      nonce,\n    77→      now.toISOString(),\n    78→      expiresAt.toISOString(),\n    79→    );\n    80→\n    81→    await authDb.insertChallenge(nonce, body.wallet, cluster, message, expiresAt);\n    82→\n    83→    logger.info(\"auth challenge issued\", { wallet: body.wallet, nonce });\n    84→\n    85→    return c.json({\n    86→      nonce,\n    87→      message,\n    88→      expiresAt: expiresAt.toISOString(),\n    89→    });\n    90→  });\n    91→\n    92→  // POST /verify — consume challenge, verify signature, issue tokens\n    93→  app.post(\"/verify\", async (c) => {\n    94→    let body: { nonce: string; wallet: string; signature: string };\n    95→    try {\n    96→      body = await c.req.json();\n    97→      if (\n    98→        typeof body.nonce !== \"string\" ||\n    99→        typeof body.wallet !== \"string\" ||\n   100→        typeof body.signature !== \"string\""}]},"parent_tool_use_id":"toolu_018JcFD6c296Bxab8D9hoKMn","session_id":"abd010b6-9bf8-408c-8fec-8f2eb32c16a2","uuid":"3bb52bc5-00f7-46e0-94b0-689f9e25c51c","timestamp":"2026-03-19T18:58:24.600Z"}
