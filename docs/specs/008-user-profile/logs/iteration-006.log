{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RNFZ8WGmziebwrTZJjX8a8","type":"tool_result","content":"     1→/**\n     2→ * Close Call clock worker — precise minute-boundary price capture + settlement.\n     3→ *\n     4→ * Scheduling:\n     5→ *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n     6→ *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n     7→ *   - Caches the boundary price (both close of old candle, open of next)\n     8→ *   - Settles any open rounds whose candle has closed\n     9→ *   - Schedules next tick at (next minute + 1s)\n    10→ *\n    11→ * Rounds are created on-demand by the first bettor (via /closecall/bet).\n    12→ * On start, loads the latest boundary price from DB to seed the cache.\n    13→ */\n    14→\n    15→import { performance } from \"node:perf_hooks\";\n    16→import {\n    17→  Connection,\n    18→  Keypair,\n    19→  PublicKey,\n    20→  Transaction,\n    21→} from \"@solana/web3.js\";\n    22→import type postgres from \"postgres\";\n    23→import { logger } from \"../logger.js\";\n    24→import { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    25→import {\n    26→  buildCloseCallSettleRoundIx,\n    27→} from \"./settle-tx.js\";\n    28→import {\n    29→  closeCallRoundDiscriminatorFilter,\n    30→  decodeCloseCallConfig,\n    31→  decodeCloseCallRound,\n    32→} from \"./account-decoder.js\";\n    33→import { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n    34→\n    35→/** Close Call on-chain phase values */\n    36→const PHASE_OPEN = 0;\n    37→\n    38→/** How long to wait after minute boundary before first Hermes poll (ms). */\n    39→const BOUNDARY_OFFSET_MS = 1_000;\n    40→\n    41→/** Poll Hermes every 1s when waiting for boundary price. */\n    42→const HERMES_POLL_INTERVAL_MS = 1_000;\n    43→\n    44→/** Max attempts to fetch a fresh boundary price (10s total). */\n    45→const HERMES_MAX_RETRIES = 10;\n    46→\n    47→/** Maximum retry attempts for a single tx submission. */\n    48→const MAX_TX_RETRIES = 3;\n    49→const TX_RETRY_DELAY_MS = 2_000;\n    50→\n    51→// ---------------------------------------------------------------------------\n    52→// Types\n    53→// ---------------------------------------------------------------------------\n    54→\n    55→export interface BoundaryPrice {\n    56→  price: bigint;\n    57→  expo: number;\n    58→  minuteTs: number;\n    59→  priceHuman: number;\n    60→}\n    61→\n    62→export interface CloseCallClockDeps {\n    63→  connection: Connection;\n    64→  serverKeypair: Keypair;\n    65→  /** Postgres `sql` tagged template instance for candle table access. */\n    66→  db: postgres.Sql;\n    67→  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n    68→  hermesEndpoint?: string;\n    69→}\n    70→\n    71→export interface CloseCallClockWorker {\n    72→  start(): void;\n    73→  stop(): void;\n    74→  readonly isRunning: boolean;\n    75→  /** Run a single tick (exposed for testing). */\n    76→  tick(): Promise<void>;\n    77→  /** Get the most recent minute-boundary price (from cache). */\n    78→  getLatestBoundaryPrice(): BoundaryPrice | null;\n    79→}\n    80→\n    81→// ---------------------------------------------------------------------------\n    82→// Factory\n    83→// ---------------------------------------------------------------------------\n    84→\n    85→export function createCloseCallClockWorker(\n    86→  deps: CloseCallClockDeps,\n    87→): CloseCallClockWorker {\n    88→  const { connection, serverKeypair, hermesEndpoint, db: sql } = deps;\n    89→\n    90→  const hermes: HermesFetcher = createHermesFetcher(hermesEndpoint);\n    91→\n    92→  let running = false;\n    93→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    94→\n    95→  /** Cached latest boundary price (in-memory). */\n    96→  let cachedBoundaryPrice: BoundaryPrice | null = null;\n    97→\n    98→  // -----------------------------------------------------------------------\n    99→  // Scheduling\n   100→  // -----------------------------------------------------------------------\n   101→\n   102→  /** Milliseconds until the next minute boundary + offset. */\n   103→  function msUntilNextBoundary(): number {\n   104→    const now = Date.now();\n   105→    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n   106→    return nextMinute - now + BOUNDARY_OFFSET_MS;\n   107→  }\n   108→\n   109→  // -----------------------------------------------------------------------\n   110→  // Helpers\n   111→  // -----------------------------------------------------------------------\n   112→\n   113→  /** Send a legacy Transaction with retry. */\n   114→  async function sendAndConfirm(\n   115→    tx: Transaction,\n   116→    label: string,\n   117→  ): Promise<string> {\n   118→    let lastError: unknown;\n   119→\n   120→    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n   121→      try {\n   122→        const sig = await connection.sendRawTransaction(tx.serialize(), {\n   123→          skipPreflight: false,\n   124→        });\n   125→        const { blockhash, lastValidBlockHeight } =\n   126→          await connection.getLatestBlockhash();\n   127→        const confirmation = await connection.confirmTransaction(\n   128→          { signature: sig, blockhash, lastValidBlockHeight },\n   129→          \"confirmed\",\n   130→        );\n   131→        if (confirmation.value.err) {\n   132→          throw new Error(\n   133→            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   134→          );\n   135→        }\n   136→        return sig;\n   137→      } catch (err) {\n   138→        lastError = err;\n   139→        if (attempt < MAX_TX_RETRIES - 1) {\n   140→          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n   141→            error: err instanceof Error ? err.message : String(err),\n   142→          });\n   143→          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n   144→        }\n   145→      }\n   146→    }\n   147→\n   148→    throw lastError;\n   149→  }\n   150→\n   151→  /** Read CloseCallConfig for treasury address. */\n   152→  async function readTreasury(): Promise<PublicKey | null> {\n   153→    const [configPda] = PublicKey.findProgramAddressSync(\n   154→      [Buffer.from(\"closecall_config\")],\n   155→      CLOSECALL_PROGRAM_ID,\n   156→    );\n   157→    const info = await connection.getAccountInfo(configPda);\n   158→    if (!info) return null;\n   159→    const config = decodeCloseCallConfig(Buffer.from(info.data));\n   160→    return config.treasury;\n   161→  }\n   162→\n   163→  // -----------------------------------------------------------------------\n   164→  // Candle DB operations\n   165→  // -----------------------------------------------------------------------\n   166→\n   167→  /** Save a boundary price to the closecall_candles table (upsert). */\n   168→  async function saveBoundaryPrice(\n   169→    minuteTs: number,\n   170→    price: bigint,\n   171→    expo: number,\n   172→    priceHuman: number,\n   173→    hermesVaa: string | null,\n   174→  ): Promise<void> {\n   175→    try {\n   176→      await sql`\n   177→        INSERT INTO closecall_candles (minute_ts, price, expo, price_human, hermes_vaa)\n   178→        VALUES (${minuteTs}, ${price.toString()}, ${expo}, ${priceHuman}, ${hermesVaa})\n   179→        ON CONFLICT (minute_ts) DO NOTHING\n   180→      `;\n   181→    } catch (err) {\n   182→      logger.error(\"closecall clock: failed to save boundary price\", {\n   183→        minuteTs,\n   184→        error: err instanceof Error ? err.message : String(err),\n   185→      });\n   186→    }\n   187→  }\n   188→\n   189→  /** Load the latest boundary price from DB (for startup cache seeding). */\n   190→  async function loadLatestBoundaryFromDb(): Promise<void> {\n   191→    try {\n   192→      const rows = await sql<{\n   193→        minute_ts: string;\n   194→        price: string;\n   195→        expo: number;\n   196→        price_human: number;\n   197→      }[]>`\n   198→        SELECT minute_ts, price, expo, price_human\n   199→        FROM closecall_candles\n   200→        ORDER BY minute_ts DESC\n   201→        LIMIT 1\n   202→      `;\n   203→      if (rows.length > 0) {\n   204→        const row = rows[0]!;\n   205→        cachedBoundaryPrice = {\n   206→          price: BigInt(row.price),\n   207→          expo: row.expo,\n   208→          minuteTs: Number(row.minute_ts),\n   209→          priceHuman: row.price_human,\n   210→        };\n   211→        logger.info(\"closecall clock: loaded boundary price from DB\", {\n   212→          minuteTs: cachedBoundaryPrice.minuteTs,\n   213→          priceHuman: cachedBoundaryPrice.priceHuman,\n   214→        });\n   215→      }\n   216→    } catch (err) {\n   217→      logger.warn(\"closecall clock: failed to load boundary price from DB\", {\n   218→        error: err instanceof Error ? err.message : String(err),\n   219→      });\n   220→    }\n   221→  }\n   222→\n   223→  // -----------------------------------------------------------------------\n   224→  // Boundary price capture — poll Hermes until fresh price arrives\n   225→  // -----------------------------------------------------------------------\n   226→\n   227→  /**\n   228→   * Poll Hermes every 1s until we get a price with publishTime >= boundaryTs.\n   229→   * Returns the captured price or null if max retries exceeded.\n   230→   */\n   231→  async function captureBoundaryPrice(\n   232→    boundaryTs: number,\n   233→  ): Promise<BoundaryPrice | null> {\n   234→    for (let attempt = 0; attempt < HERMES_MAX_RETRIES; attempt++) {\n   235→      try {\n   236→        const result = await hermes.fetchLatestBtcPrice();\n   237→        if (result && result.publishTime >= boundaryTs) {\n   238→          const bp: BoundaryPrice = {\n   239→            price: result.price,\n   240→            expo: result.expo,\n   241→            minuteTs: boundaryTs,\n   242→            priceHuman: result.priceHuman,\n   243→          };\n   244→\n   245→          // Save to DB with VAA proof\n   246→          await saveBoundaryPrice(\n   247→            boundaryTs,\n   248→            result.price,\n   249→            result.expo,\n   250→            result.priceHuman,\n   251→            result.vaaBase64,\n   252→          );\n   253→\n   254→          cachedBoundaryPrice = bp;\n   255→\n   256→          logger.info(\"closecall clock: boundary price captured\", {\n   257→            minuteTs: boundaryTs,\n   258→            priceHuman: result.priceHuman,\n   259→            publishTime: result.publishTime,\n   260→            attempts: attempt + 1,\n   261→          });\n   262→\n   263→          return bp;\n   264→        }\n   265→\n   266→        if (result) {\n   267→          logger.debug(\"closecall clock: Hermes price not yet at boundary\", {\n   268→            publishTime: result.publishTime,\n   269→            boundaryTs,\n   270→            attempt: attempt + 1,\n   271→          });\n   272→        }\n   273→      } catch (err) {\n   274→        logger.warn(\"closecall clock: Hermes poll failed\", {\n   275→          attempt: attempt + 1,\n   276→          error: err instanceof Error ? err.message : String(err),\n   277→        });\n   278→      }\n   279→\n   280→      // Wait 1s before next attempt\n   281→      if (attempt < HERMES_MAX_RETRIES - 1) {\n   282→        await new Promise((r) => setTimeout(r, HERMES_POLL_INTERVAL_MS));\n   283→      }\n   284→    }\n   285→\n   286→    logger.warn(\"closecall clock: failed to capture boundary price after max retries\", {\n   287→      boundaryTs,\n   288→    });\n   289→    return null;\n   290→  }\n   291→\n   292→  // -----------------------------------------------------------------------\n   293→  // Round discovery\n   294→  // -----------------------------------------------------------------------\n   295→\n   296→  /**\n   297→   * Discover ALL existing open rounds owned by this server.\n   298→   */\n   299→  async function discoverOpenRounds(): Promise<\n   300→    Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }>\n   301→  > {\n   302→    const results: Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }> = [];\n   303→    try {\n   304→      const accounts = await connection.getProgramAccounts(\n   305→        CLOSECALL_PROGRAM_ID,\n   306→        { filters: [closeCallRoundDiscriminatorFilter()] },\n   307→      );\n   308→\n   309→      const now = Math.floor(Date.now() / 1000);\n   310→\n   311→      for (const { pubkey, account } of accounts) {\n   312→        try {\n   313→          const round = decodeCloseCallRound(Buffer.from(account.data));\n   314→\n   315→          // Skip rounds with garbage minuteTs (old format / random bytes)\n   316→          const ts = Number(round.minuteTs);\n   317→          if (ts < 1700000000 || ts > now + 120) continue;\n   318→\n   319→          if (\n   320→            round.phase === PHASE_OPEN &&\n   321→            round.server.equals(serverKeypair.publicKey)\n   322→          ) {\n   323→            results.push({ pda: pubkey, minuteTs: round.minuteTs, round });\n   324→          }\n   325→        } catch {\n   326→          // Skip undecodeable accounts\n   327→        }\n   328→      }\n   329→    } catch (err) {\n   330→      logger.warn(\"closecall clock: discovery scan failed\", {\n   331→        error: err instanceof Error ? err.message : String(err),\n   332→      });\n   333→    }\n   334→    return results;\n   335→  }\n   336→\n   337→  // -----------------------------------------------------------------------\n   338→  // Settlement\n   339→  // -----------------------------------------------------------------------\n   340→\n   341→  /**\n   342→   * Settle a single round. Returns true on success.\n   343→   */\n   344→  async function settleRound(\n   345→    roundPda: PublicKey,\n   346→    minuteTs: bigint,\n   347→    round: ReturnType<typeof decodeCloseCallRound>,\n   348→  ): Promise<boolean> {\n   349→    try {\n   350→      const nowSec = Math.floor(Date.now() / 1000);\n   351→      const candleCloseTime = Number(minuteTs) + 60;\n   352→\n   353→      if (nowSec < candleCloseTime) {\n   354→        logger.debug(\"closecall clock: candle not closed yet\", {\n   355→          pda: roundPda.toBase58(),\n   356→          secondsRemaining: candleCloseTime - nowSec,\n   357→        });\n   358→        return false;\n   359→      }\n   360→\n   361→      const greenCount = round.greenEntries.length;\n   362→      const redCount = round.redEntries.length;\n   363→      const totalCount = greenCount + redCount;\n   364→\n   365→      // Fetch treasury + close price\n   366→      const [treasury, hermesPrice] = await Promise.all([\n   367→        readTreasury(),\n   368→        hermes.fetchLatestBtcPrice(),\n   369→      ]);\n   370→\n   371→      if (!treasury) {\n   372→        logger.error(\"closecall clock: cannot read config treasury\");\n   373→        return false;\n   374→      }\n   375→      if (!hermesPrice) {\n   376→        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n   377→        return false;\n   378→      }\n   379→\n   380→      if (totalCount === 0) {\n   381→        logger.info(\"closecall clock: settling empty round\", {\n   382→          pda: roundPda.toBase58(),\n   383→        });\n   384→      }\n   385→\n   386→      // Pre-determine outcome\n   387→      const hasBothSides = greenCount > 0 && redCount > 0;\n   388→      const isRefund =\n   389→        totalCount === 0 ||\n   390→        !hasBothSides ||\n   391→        totalCount === 1 ||\n   392→        hermesPrice.price === round.openPrice;\n   393→\n   394→      let remainingAccounts: PublicKey[];\n   395→      if (isRefund) {\n   396→        remainingAccounts = [\n   397→          ...round.greenEntries.map((e) => e.player),\n   398→          ...round.redEntries.map((e) => e.player),\n   399→        ];\n   400→      } else if (hermesPrice.price > round.openPrice) {\n   401→        remainingAccounts = round.greenEntries.map((e) => e.player);\n   402→      } else {\n   403→        remainingAccounts = round.redEntries.map((e) => e.player);\n   404→      }\n   405→\n   406→      const ix = buildCloseCallSettleRoundIx(\n   407→        serverKeypair.publicKey,\n   408→        minuteTs,\n   409→        hermesPrice.price,\n   410→        hermesPrice.expo,\n   411→        treasury,\n   412→        remainingAccounts,\n   413→      );\n   414→\n   415→      const { blockhash, lastValidBlockHeight } =\n   416→        await connection.getLatestBlockhash();\n   417→      const tx = new Transaction({\n   418→        feePayer: serverKeypair.publicKey,\n   419→        blockhash,\n   420→        lastValidBlockHeight,\n   421→      });\n   422→      tx.add(ix);\n   423→      tx.sign(serverKeypair);\n   424→\n   425→      const sig = await sendAndConfirm(tx, \"settle\");\n   426→\n   427→      const outcomeStr = isRefund\n   428→        ? \"refund\"\n   429→        : hermesPrice.price > round.openPrice\n   430→          ? \"green\"\n   431→          : \"red\";\n   432→\n   433→      logger.info(\"closecall clock: round settled\", {\n   434→        pda: roundPda.toBase58(),\n   435→        tx: sig,\n   436→        totalEntries: totalCount,\n   437→        outcome: outcomeStr,\n   438→      });\n   439→\n   440→      // Persist settlement to DB\n   441→      try {\n   442→        // Ensure round record exists (may not if created before DB persistence was added)\n   443→        await sql`\n   444→          INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo, phase, created_at)\n   445→          VALUES (\n   446→            ${String(Number(minuteTs))},\n   447→            ${roundPda.toBase58()},\n   448→            ${serverKeypair.publicKey.toBase58()},\n   449→            ${Number(round.openPrice)},\n   450→            ${round.openPriceExpo},\n   451→            'open',\n   452→            NOW()\n   453→          )\n   454→          ON CONFLICT (round_id) DO NOTHING\n   455→        `;\n   456→\n   457→        // Format entries for JSONB storage\n   458→        const greenEntries = round.greenEntries.map((e) => ({\n   459→          player: e.player.toBase58(),\n   460→          amountLamports: Number(e.amountLamports),\n   461→        }));\n   462→        const redEntries = round.redEntries.map((e) => ({\n   463→          player: e.player.toBase58(),\n   464→          amountLamports: Number(e.amountLamports),\n   465→        }));\n   466→\n   467→        // Compute fee off-chain (on-chain totalFee is only set after settle,\n   468→        // but we read the account BEFORE settlement, so it's still 0).\n   469→        // Fee = 3% (300 bps) of total pool, truncated. 0 for refund rounds.\n   470→        const totalPool = Number(round.greenPool) + Number(round.redPool);\n   471→        const computedFee = isRefund ? 0 : Math.floor(totalPool * 300 / 10_000);\n   472→\n   473→        // Update with settlement data\n   474→        await sql`\n   475→          UPDATE closecall_rounds SET\n   476→            phase = ${isRefund ? \"refunded\" : \"settled\"},\n   477→            outcome = ${outcomeStr},\n   478→            close_price = ${Number(hermesPrice.price)},\n   479→            green_pool = ${Number(round.greenPool)},\n   480→            red_pool = ${Number(round.redPool)},\n   481→            total_fee = ${computedFee},\n   482→            green_entries = ${sql.json(greenEntries)},\n   483→            red_entries = ${sql.json(redEntries)},\n   484→            settle_tx = ${sig},\n   485→            settled_at = NOW()\n   486→          WHERE round_id = ${String(Number(minuteTs))}\n   487→        `;\n   488→\n   489→        // Write user transaction rows (join + outcome per entry)\n   490→        const roundId = String(Number(minuteTs));\n   491→        const netPool = totalPool - computedFee;\n   492→\n   493→        const doInsert = (\n   494→          wallet: string,\n   495→          event: string,\n   496→          amount: number,\n   497→        ) =>\n   498→          sql`\n   499→            INSERT INTO user_transactions (wallet, game, match_id, event, amount_lamports, tx_sig)\n   500→            VALUES (${wallet}, 'closecall', ${roundId}, ${event}, ${amount}, ${sig})\n   501→            ON CONFLICT DO NOTHING\n   502→          `;\n   503→\n   504→        const userTxInserts: Promise<unknown>[] = [];\n   505→\n   506→        for (const entry of greenEntries) {\n   507→          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n   508→          if (isRefund) {\n   509→            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n   510→          } else if (outcomeStr === \"green\") {\n   511→            const greenPool = Number(round.greenPool);\n   512→            const payout = greenPool > 0\n   513→              ? Math.floor((entry.amountLamports / greenPool) * netPool)\n   514→              : 0;\n   515→            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n   516→          } else {\n   517→            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n   518→          }\n   519→        }\n   520→\n   521→        for (const entry of redEntries) {\n   522→          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n   523→          if (isRefund) {\n   524→            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n   525→          } else if (outcomeStr === \"red\") {\n   526→            const redPool = Number(round.redPool);\n   527→            const payout = redPool > 0\n   528→              ? Math.floor((entry.amountLamports / redPool) * netPool)\n   529→              : 0;\n   530→            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n   531→          } else {\n   532→            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n   533→          }\n   534→        }\n   535→\n   536→        if (userTxInserts.length > 0) {\n   537→          await Promise.all(userTxInserts);\n   538→        }\n   539→      } catch (dbErr) {\n   540→        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n   541→          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n   542→        });\n   543→      }\n   544→\n   545→      return true;\n   546→    } catch (err) {\n   547→      logger.error(\"closecall clock: settlement failed\", {\n   548→        pda: roundPda.toBase58(),\n   549→        error: err instanceof Error ? err.message : String(err),\n   550→      });\n   551→      return false;\n   552→    }\n   553→  }\n   554→\n   555→  // -----------------------------------------------------------------------\n   556→  // Tick — fires at minute boundary + 1s\n   557→  // -----------------------------------------------------------------------\n   558→\n   559→  async function tick(): Promise<void> {\n   560→    const t0 = performance.now();\n   561→    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n   562→\n   563→    // Step 1: Capture boundary price (poll Hermes until fresh)\n   564→    await captureBoundaryPrice(boundaryTs);\n   565→\n   566→    // Step 2: Discover + settle all open rounds whose candle has closed\n   567→    const openRounds = await discoverOpenRounds();\n   568→\n   569→    for (const { pda, minuteTs, round } of openRounds) {\n   570→      await settleRound(pda, minuteTs, round);\n   571→    }\n   572→\n   573→    const elapsed = Math.round(performance.now() - t0);\n   574→    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n   575→  }\n   576→\n   577→  async function loop(): Promise<void> {\n   578→    if (!running) return;\n   579→    try {\n   580→      await tick();\n   581→    } catch (err) {\n   582→      logger.error(\"closecall clock loop error\", {\n   583→        error: err instanceof Error ? err.message : String(err),\n   584→      });\n   585→    }\n   586→    if (running) {\n   587→      const delay = msUntilNextBoundary();\n   588→      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n   589→      timeoutId = setTimeout(loop, delay);\n   590→    }\n   591→  }\n   592→\n   593→  // -----------------------------------------------------------------------\n   594→  // Public interface\n   595→  // -----------------------------------------------------------------------\n   596→\n   597→  return {\n   598→    start() {\n   599→      if (running) return;\n   600→      running = true;\n   601→\n   602→      logger.info(\"closecall clock started\", {\n   603→        serverKey: serverKeypair.publicKey.toBase58(),\n   604→        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n   605→      });\n   606→\n   607→      // Load latest boundary price from DB, then schedule first tick\n   608→      loadLatestBoundaryFromDb()\n   609→        .then(() => {\n   610→          if (!running) return;\n   611→          const delay = msUntilNextBoundary();\n   612→          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n   613→          timeoutId = setTimeout(loop, delay);\n   614→        })\n   615→        .catch((err) => {\n   616→          logger.error(\"closecall clock: startup init failed\", {\n   617→            error: err instanceof Error ? err.message : String(err),\n   618→          });\n   619→          if (running) {\n   620→            const delay = msUntilNextBoundary();\n   621→            timeoutId = setTimeout(loop, delay);\n   622→          }\n   623→        });\n   624→    },\n   625→\n   626→    stop() {\n   627→      running = false;\n   628→      if (timeoutId) {\n   629→        clearTimeout(timeoutId);\n   630→        timeoutId = null;\n   631→      }\n   632→      logger.info(\"closecall clock stopped\");\n   633→    },\n   634→\n   635→    get isRunning() {\n   636→      return running;\n   637→    },\n   638→\n   639→    tick,\n   640→\n   641→    getLatestBoundaryPrice(): BoundaryPrice | null {\n   642→      return cachedBoundaryPrice;\n   643→    },\n   644→  };\n   645→}\n   646→"}]},"parent_tool_use_id":"toolu_018JcFD6c296Bxab8D9hoKMn","session_id":"abd010b6-9bf8-408c-8fec-8f2eb32c16a2","uuid":"be01f3ee-5fac-496a-a9ed-a484086014b0","timestamp":"2026-03-19T18:58:16.076Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RQs3LCQkQXVtvsmCdF1vvF","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createProfileRoutes } from \"./routes/profile.js\";\n    15→import { createAuthRoutes } from \"./routes/auth.js\";\n    16→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    17→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    18→import { createSettlementWorker } from \"./worker/settlement.js\";\n    19→import { settleRound } from \"./worker/settle-tx.js\";\n    20→import { createRetrySettler } from \"./worker/retry.js\";\n    21→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    22→import { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    23→import { logger } from \"./logger.js\";\n    24→\n    25→const config = loadConfig();\n    26→\n    27→// Shared postgres connection for both game DB and auth DB\n    28→const sql = postgres(config.databaseUrl);\n    29→const db = createDb(config.databaseUrl);\n    30→const authDb = createAuthDb(sql);\n    31→\n    32→const connection = new Connection(config.rpcUrl, {\n    33→  commitment: \"confirmed\",\n    34→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    35→});\n    36→\n    37→const app = new Hono();\n    38→\n    39→app.use(\n    40→  \"*\",\n    41→  cors({\n    42→    origin: \"*\",\n    43→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    44→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    45→  }),\n    46→);\n    47→\n    48→// Request logging — correlate frontend fetch timing with server-side processing\n    49→app.use(\"*\", async (c, next) => {\n    50→  const start = Date.now();\n    51→  await next();\n    52→  const ms = Date.now() - start;\n    53→  const method = c.req.method;\n    54→  const path = c.req.path;\n    55→  // Skip noisy health checks and OPTIONS preflight\n    56→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    57→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    58→});\n    59→\n    60→// Auth routes — no JWT middleware (these are the login endpoints)\n    61→// Lighter rate limiting by IP for auth endpoints\n    62→app.use(\n    63→  \"/auth/*\",\n    64→  createRateLimitMiddleware({\n    65→    perWallet: 20,\n    66→    global: config.rateLimitGlobal,\n    67→    windowMs: 60_000,\n    68→  }),\n    69→);\n    70→\n    71→app.route(\n    72→  \"/auth\",\n    73→  createAuthRoutes({\n    74→    authDb,\n    75→    jwtSecret: config.jwtSecret,\n    76→    cluster: config.cluster,\n    77→    challengeTtlSeconds: config.challengeTtlSeconds,\n    78→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    79→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    80→  }),\n    81→);\n    82→\n    83→// Profile routes — authenticated GET endpoints (require JWT on all methods)\n    84→app.use(\n    85→  \"/profile/*\",\n    86→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    87→);\n    88→app.route(\"/profile\", createProfileRoutes({ db }));\n    89→\n    90→// JWT auth middleware for fairness endpoints\n    91→app.use(\n    92→  \"/fairness/*\",\n    93→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n    94→);\n    95→\n    96→// Rate limiting — per-wallet and global limits on POST requests\n    97→app.use(\n    98→  \"/fairness/*\",\n    99→  createRateLimitMiddleware({\n   100→    perWallet: config.rateLimitPerWallet,\n   101→    global: config.rateLimitGlobal,\n   102→    windowMs: 60_000,\n   103→  }),\n   104→);\n   105→\n   106→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n   107→const entropyAccount = new PublicKey(config.entropyAccount);\n   108→const retrySettler = createRetrySettler({\n   109→  db,\n   110→  connection,\n   111→  settleRound: (pda) =>\n   112→    settleRound(\n   113→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n   114→      pda,\n   115→    ),\n   116→});\n   117→\n   118→// PDA watcher — WebSocket-based instant join detection\n   119→const pdaWatcher = createPdaWatcher({\n   120→  connection,\n   121→  serverKey: config.serverKeypair.publicKey,\n   122→  db,\n   123→  onJoinDetected: async (pda, targetSlot) => {\n   124→    // Update DB phase if still in 'created'\n   125→    const round = await db.getRoundByPda(pda);\n   126→    if (round && round.phase === \"created\") {\n   127→      await db.updateRoundPhase(pda, \"locked\", {\n   128→        target_slot: targetSlot.toString(),\n   129→      });\n   130→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   131→        targetSlot: targetSlot.toString(),\n   132→        source: \"pda-watcher\",\n   133→        game: round.game,\n   134→      });\n   135→    }\n   136→\n   137→    // Check if target slot already passed — settle immediately if so\n   138→    const currentSlot = await connection.getSlot();\n   139→    if (BigInt(currentSlot) >= targetSlot) {\n   140→      await retrySettler.attemptSettle(pda);\n   141→      pdaWatcher.unwatch(pda);\n   142→    }\n   143→    // If target slot not reached yet, poll worker will pick it up next cycle\n   144→  },\n   145→});\n   146→\n   147→const worker = createSettlementWorker({\n   148→  db,\n   149→  connection,\n   150→  serverKey: config.serverKeypair.publicKey,\n   151→  pollIntervalMs: config.workerPollIntervalMs,\n   152→  onSettleReady: async (pda) => {\n   153→    await retrySettler.attemptSettle(pda);\n   154→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   155→  },\n   156→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   157→});\n   158→worker.start();\n   159→\n   160→// Close Call clock worker — fetches boundary prices + settles open rounds\n   161→// Rounds are created on-demand by players via /closecall/bet\n   162→const closeCallClock = createCloseCallClockWorker({\n   163→  connection,\n   164→  serverKeypair: config.serverKeypair,\n   165→  db: sql,\n   166→});\n   167→closeCallClock.start();\n   168→\n   169→// Coinflip fairness routes\n   170→app.route(\n   171→  \"/fairness/coinflip\",\n   172→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   173→);\n   174→app.route(\n   175→  \"/fairness/lord\",\n   176→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   177→);\n   178→\n   179→// Close Call routes (create-round co-signing + candle history + read queries)\n   180→app.route(\"/closecall\", createCloseCallRoutes({\n   181→  db,\n   182→  connection,\n   183→  serverKeypair: config.serverKeypair,\n   184→  clockWorker: closeCallClock,\n   185→  sql,\n   186→}));\n   187→\n   188→// Round verification routes\n   189→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   190→\n   191→// Health endpoint — wired after worker exists so we can query its status\n   192→app.route(\n   193→  \"/health\",\n   194→  createHealthRoutes({\n   195→    db,\n   196→    connection,\n   197→    serverKey: config.serverKeypair.publicKey,\n   198→    isWorkerRunning: () => worker.isRunning,\n   199→    minSolBalance: config.minSolBalance,\n   200→  }),\n   201→);\n   202→\n   203→const port = config.port;\n   204→logger.info(\"fairness-backend started\", { port });\n   205→\n   206→serve({\n   207→  fetch: app.fetch,\n   208→  port,\n   209→});\n   210→\n   211→export default {\n   212→  port,\n   213→  fetch: app.fetch,\n   214→};\n   215→"}]},"parent_tool_use_id":"toolu_018JcFD6c296Bxab8D9hoKMn","session_id":"abd010b6-9bf8-408c-8fec-8f2eb32c16a2","uuid":"656f0a7e-9367-404f-8669-27a0492a925e","timestamp":"2026-03-19T18:58:16.114Z"}
