esponses: {\n826\t          \"200\": {\n827\t            description: \"Code set\",\n828\t            content: {\n829\t              \"application/json\": {\n830\t                schema: {\n831\t                  type: \"object\",\n832\t                  properties: { code: { type: \"string\" } },\n833\t                },\n834\t              },\n835\t            },\n836\t          },\n837\t          \"400\": { description: \"Invalid code format\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/StructuredError\" } } } },\n838\t          \"409\": { description: \"Code already set or taken\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/StructuredError\" } } } },\n839\t        },\n840\t      },\n841\t      get: {\n842\t        tags: [\"Referral\"],\n843\t        summary: \"Get own referral code\",\n844\t        security: [{ bearerAuth: [] }],\n845\t        responses: {\n846\t          \"200\": {\n847\t            description: \"Code found\",\n848\t            content: {\n849\t              \"application/json\": {\n850\t                schema: {\n851\t                  type: \"object\",\n852\t                  properties: { code: { type: \"string\" } },\n853\t                },\n854\t              },\n855\t            },\n856\t          },\n857\t          \"404\": { description: \"No code set\" },\n858\t        },\n859\t      },\n860\t    },\n861\t    \"/referral/apply\": {\n862\t      post: {\n863\t        tags: [\"Referral\"],\n864\t        summary: \"Apply a referral code (link to referrer)\",\n865\t        security: [{ bearerAuth: [] }],\n866\t        requestBody: {\n867\t          required: true,\n868\t          content: {\n869\t            \"application/json\": {\n870\t              schema: {\n871\t                type: \"object\",\n872\t                required: [\"code\"],\n873\t                properties: {\n874\t                  code: { type: \"string\" },\n875\t                },\n876\t              },\n877\t            },\n878\t          },\n879\t        },\n880\t        responses: {\n881\t          \"200\": {\n882\t            description: \"Linked to referrer\",\n883\t            content: {\n884\t              \"application/json\": {\n885\t                schema: {\n886\t                  type: \"object\",\n887\t                  properties: {\n888\t                    referrer: { type: \"string\" },\n889\t                    benefit: { type: \"string\" },\n890\t                  },\n891\t                },\n892\t              },\n893\t            },\n894\t          },\n895\t          \"400\": { description: \"Invalid code or self-referral\" },\n896\t          \"404\": { description: \"Code not found\" },\n897\t          \"409\": { description: \"Already linked to a referrer\" },\n898\t        },\n899\t      },\n900\t    },\n901\t    \"/referral/referrer\": {\n902\t      get: {\n903\t        tags: [\"Referral\"],\n904\t        summary: \"Get own referrer info\",\n905\t        security: [{ bearerAuth: [] }],\n906\t        responses: {\n907\t          \"200\": {\n908\t            description: \"Referrer found\",\n909\t            content: {\n910\t              \"application/json\": {\n911\t                schema: {\n912\t                  type: \"object\",\n913\t                  properties: {\n914\t                    referrerWallet: { type: \"string\" },\n915\t                    referrerCode: { type: \"string\", nullable: true },\n916\t                    linkedAt: { type: \"string\", format: \"date-time\" },\n917\t                  },\n918\t                },\n919\t              },\n920\t            },\n921\t          },\n922\t          \"404\": { description: \"Not linked to a referrer\" },\n923\t        },\n924\t      },\n925\t    },\n926\t    \"/referral/stats\": {\n927\t      get: {\n928\t        tags: [\"Referral\"],\n929\t        summary: \"Get referral stats\",\n930\t        security: [{ bearerAuth: [] }],\n931\t        responses: {\n932\t          \"200\": {\n933\t            description: \"Referral statistics\",\n934\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/ReferralStats\" } } },\n935\t          },\n936\t        },\n937\t      },\n938\t    },\n939\t    \"/referral/referrals\": {\n940\t      get: {\n941\t        tags: [\"Referral\"],\n942\t        summary: \"List referred users (last 10)\",\n943\t        security: [{ bearerAuth: [] }],\n944\t        responses: {\n945\t          \"200\": {\n946\t            description: \"Referred users\",\n947\t            content: {\n948\t              \"application/json\": {\n949\t                schema: {\n950\t                  type: \"object\",\n951\t                  properties: {\n952\t                    items: {\n953\t                      type: \"array\",\n954\t                      items: {\n955\t                        type: \"object\",\n956\t                        properties: {\n957\t                          refereeWallet: { type: \"string\" },\n958\t                          createdAt: { type: \"string\", format: \"date-time\" },\n959\t                        },\n960\t                      },\n961\t                    },\n962\t                  },\n963\t                },\n964\t              },\n965\t            },\n966\t          },\n967\t        },\n968\t      },\n969\t    },\n970\t    \"/referral/earnings\": {\n971\t      get: {\n972\t        tags: [\"Referral\"],\n973\t        summary: \"Get paginated referral earnings\",\n974\t        security: [{ bearerAuth: [] }],\n975\t        parameters: [\n976\t          { name: \"page\", in: \"query\", schema: { type: \"integer\", default: 1 } },\n977\t          {\n978\t            name: \"limit\",\n979\t            in: \"query\",\n980\t            schema: { type: \"integer\", minimum: 1, maximum: 100, default: 20 },\n981\t          },\n982\t        ],\n983\t        responses: {\n984\t          \"200\": {\n985\t            description: \"Earnings list\",\n986\t            content: {\n987\t              \"application/json\": {\n988\t                schema: {\n989\t                  type: \"object\",\n990\t                  properties: {\n991\t                    items: {\n992\t                      type: \"array\",\n993\t                      items: { $ref: \"#/components/schemas/ReferralEarning\" },\n994\t                    },\n995\t                    pagination: {\n996\t                      type: \"object\",\n997\t                      properties: {\n998\t                        page: { type: \"integer\" },\n999\t                        totalPages: { type: \"integer\" },\n1000\t                      },\n1001\t                    },\n1002\t                  },\n1003\t                },\n1004\t              },\n1005\t            },\n1006\t          },\n1007\t        },\n1008\t      },\n1009\t    },\n1010\t    \"/referral/claim\": {\n1011\t      post: {\n1012\t        tags: [\"Referral\"],\n1013\t        summary: \"Request payout of pending referral earnings\",\n1014\t        security: [{ bearerAuth: [] }],\n1015\t        responses: {\n1016\t          \"202\": {\n1017\t            description: \"Claim queued\",\n1018\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/ClaimResponse\" } } },\n1019\t          },\n1020\t          \"400\": { description: \"Zero balance or below threshold\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/StructuredError\" } } } },\n1021\t        },\n1022\t      },\n1023\t    },\n1024\t    \"/referral/claim/{claimId}\": {\n1025\t      get: {\n1026\t        tags: [\"Referral\"],\n1027\t        summary: \"Poll claim status\",\n1028\t        security: [{ bearerAuth: [] }],\n1029\t        parameters: [\n1030\t          {\n1031\t            name: \"claimId\",\n1032\t            in: \"path\",\n1033\t            required: true,\n1034\t            schema: { type: \"string\" },\n1035\t          },\n1036\t        ],\n1037\t        responses: {\n1038\t          \"200\": {\n1039\t            description: \"Claim status\",\n1040\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/ClaimResponse\" } } },\n1041\t          },\n1042\t          \"404\": { description: \"Claim not found\" },\n1043\t        },\n1044\t      },\n1045\t    },\n1046\t\n1047\t    // ── Price ─────────────────────────────────────────────────────\n1048\t    \"/price/sol-usd\": {\n1049\t      get: {\n1050\t        tags: [\"Price\"],\n1051\t        summary: \"Get cached SOL/USD price\",\n1052\t        responses: {\n1053\t          \"200\": {\n1054\t            description: \"Price data\",\n1055\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/PriceResponse\" } } },\n1056\t          },\n1057\t          \"503\": { description: \"Price unavailable\" },\n1058\t        },\n1059\t      },\n1060\t    },\n1061\t\n1062\t    // ── Health ────────────────────────────────────────────────────\n1063\t    \"/health\": {\n1064\t      get: {\n1065\t        tags: [\"Health\"],\n1066\t        summary: \"Service health check\",\n1067\t        parameters: [\n1068\t          {\n1069\t            name: \"verbose\",\n1070\t            in: \"query\",\n1071\t            schema: { type: \"string\", enum: [\"1\"] },\n1072\t            description: \"Include event queue stats\",\n1073\t          },\n1074\t        ],\n1075\t        responses: {\n1076\t          \"200\": {\n1077\t            description: \"Health status\",\n1078\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/HealthResponse\" } } },\n1079\t          },\n1080\t        },\n1081\t      },\n1082\t    },\n1083\t  },\n1084\t} as const;\n1085\t"}]},"parent_tool_use_id":null,"session_id":"e44550f8-11fe-49dd-bb57-a4d026a1433a","uuid":"5a49f44b-9bc1-4bd1-a7f4-4a422c132fc8","timestamp":"2026-03-31T15:20:12.639Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/openapi.ts","content":"/**\n * OpenAPI 3.0 specification for the Taunt Bet API.\n */\n\nexport const spec = {\n  openapi: \"3.0.3\",\n  info: {\n    title: \"Taunt Bet API\",\n    description:\n      \"Backend API for Taunt Bet — handles game round creation, \" +\n      \"settlement verification, player profiles, referrals, and price feeds.\",\n    version: \"0.1.0\",\n  },\n  servers: [\n    { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n    { url: \"http://localhost:3100\", description: \"Local\" },\n    { url: \"https://api.taunt.bet\", description: \"Production\" },\n  ],\n  tags: [\n    { name: \"Auth\", description: \"JWT session management via Ed25519 challenge-response\" },\n    { name: \"Coinflip\", description: \"1v1 coinflip match creation\" },\n    { name: \"Lord of RNGs\", description: \"Winner-takes-all jackpot round creation\" },\n    { name: \"Close Call\", description: \"Pari-mutuel BTC candle prediction\" },\n    { name: \"Rounds\", description: \"Round history and fairness verification\" },\n    { name: \"Profile\", description: \"Player transaction history\" },\n    { name: \"Referral\", description: \"Referral code management, linking, and earnings\" },\n    { name: \"Price\", description: \"Cached SOL/USD price from Pyth\" },\n    { name: \"Health\", description: \"Operational health check\" },\n  ],\n  components: {\n    securitySchemes: {\n      bearerAuth: {\n        type: \"http\",\n        scheme: \"bearer\",\n        bearerFormat: \"JWT\",\n        description: \"JWT obtained via /auth/verify\",\n      },\n    },\n    schemas: {\n      Error: {\n        type: \"object\",\n        properties: {\n          error: { type: \"string\" },\n        },\n      },\n      StructuredError: {\n        type: \"object\",\n        properties: {\n          error: {\n            type: \"object\",\n            properties: {\n              code: { type: \"string\" },\n              message: { type: \"string\" },\n              retryable: { type: \"boolean\" },\n            },\n            required: [\"code\", \"message\"],\n          },\n        },\n      },\n      ChallengeResponse: {\n        type: \"object\",\n        properties: {\n          nonce: { type: \"string\", description: \"64-char hex nonce\" },\n          message: { type: \"string\", description: \"Human-readable sign-in message\" },\n          expiresAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      TokenResponse: {\n        type: \"object\",\n        properties: {\n          accessToken: { type: \"string\", description: \"HS256 JWT\" },\n          accessExpiresAt: { type: \"string\", format: \"date-time\" },\n          refreshToken: { type: \"string\", description: \"Opaque 96-char hex token\" },\n          refreshExpiresAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      CoinflipCreateResponse: {\n        type: \"object\",\n        properties: {\n          transaction: { type: \"string\", description: \"Base64-encoded partially-signed transaction\" },\n          matchPda: { type: \"string\", description: \"Base58 match PDA address\" },\n          matchId: { type: \"string\", description: \"16-char hex match ID\" },\n          commitment: { type: \"string\", description: \"SHA256 hex commitment\" },\n          lastValidBlockHeight: { type: \"integer\" },\n        },\n      },\n      LordCreateResponse: {\n        type: \"object\",\n        properties: {\n          transaction: { type: \"string\", description: \"Base64-encoded partially-signed transaction\" },\n          roundPda: { type: \"string\", description: \"Base58 round PDA address\" },\n          matchId: { type: \"string\", description: \"16-char hex match ID\" },\n          commitment: { type: \"string\", description: \"SHA256 hex commitment\" },\n          lastValidBlockHeight: { type: \"integer\" },\n        },\n      },\n      LordEntry: {\n        type: \"object\",\n        properties: {\n          player: { type: \"string\", description: \"Base58 wallet address\" },\n          amountLamports: { type: \"integer\" },\n        },\n      },\n      LordRound: {\n        type: \"object\",\n        properties: {\n          matchId: { type: \"string\" },\n          pda: { type: \"string\" },\n          phase: {\n            type: \"string\",\n            enum: [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"],\n          },\n          creator: { type: \"string\" },\n          commitment: { type: \"string\" },\n          entries: {\n            type: \"array\",\n            items: { $ref: \"#/components/schemas/LordEntry\" },\n          },\n          totalAmountLamports: { type: \"integer\" },\n          distinctPlayers: { type: \"integer\" },\n          countdownStartedAt: { type: \"integer\", nullable: true },\n          countdownEndsAt: { type: \"integer\", nullable: true },\n          createdAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      CloseCallEntry: {\n        type: \"object\",\n        properties: {\n          player: { type: \"string\" },\n          amountLamports: { type: \"integer\" },\n        },\n      },\n      CloseCallRound: {\n        type: \"object\",\n        properties: {\n          roundId: { type: \"string\" },\n          pda: { type: \"string\" },\n          phase: { type: \"string\", enum: [\"open\", \"settled\", \"refunded\"] },\n          openPrice: { type: \"number\" },\n          openPriceExpo: { type: \"integer\" },\n          closePrice: { type: \"number\", nullable: true },\n          outcome: { type: \"string\", enum: [\"pending\", \"green\", \"red\", \"refund\"] },\n          greenPool: { type: \"integer\" },\n          redPool: { type: \"integer\" },\n          totalPool: { type: \"integer\" },\n          totalFee: { type: \"integer\" },\n          greenEntries: {\n            type: \"array\",\n            items: { $ref: \"#/components/schemas/CloseCallEntry\" },\n          },\n          redEntries: {\n            type: \"array\",\n            items: { $ref: \"#/components/schemas/CloseCallEntry\" },\n          },\n          greenCount: { type: \"integer\" },\n          redCount: { type: \"integer\" },\n          settleTx: { type: \"string\", nullable: true },\n          createdAt: { type: \"string\", format: \"date-time\" },\n          settledAt: { type: \"string\", format: \"date-time\", nullable: true },\n        },\n      },\n      Candle: {\n        type: \"object\",\n        properties: {\n          openTime: { type: \"integer\", description: \"Millisecond timestamp\" },\n          closeTime: { type: \"integer\", description: \"Millisecond timestamp\" },\n          open: { type: \"number\" },\n          close: { type: \"number\" },\n          high: { type: \"number\" },\n          low: { type: \"number\" },\n          outcome: { type: \"string\", nullable: true, enum: [\"green\", \"red\", null] },\n        },\n      },\n      CloseCallBetResponse: {\n        type: \"object\",\n        properties: {\n          transaction: { type: \"string\", description: \"Base64-encoded partially-signed transaction\" },\n          minuteTs: { type: \"integer\", description: \"Unix timestamp (seconds) of the minute boundary\" },\n          roundPda: { type: \"string\" },\n        },\n      },\n      RoundResponse: {\n        type: \"object\",\n        properties: {\n          pda: { type: \"string\" },\n          game: { type: \"string\", enum: [\"coinflip\", \"lord\"] },\n          phase: { type: \"string\" },\n          creator: { type: \"string\" },\n          commitment: { type: \"string\" },\n          amountLamports: { type: \"integer\" },\n          side: { type: \"integer\" },\n          matchId: { type: \"string\" },\n          createdAt: { type: \"string\", format: \"date-time\" },\n          updatedAt: { type: \"string\", format: \"date-time\" },\n          targetSlot: { type: \"integer\" },\n          secret: { type: \"string\", description: \"Only present when settled\" },\n          resultHash: { type: \"string\", nullable: true },\n          resultSide: { type: \"integer\", description: \"Coinflip only\" },\n          winningEntryIndex: { type: \"integer\", description: \"Lord only\" },\n          winner: { type: \"string\" },\n          settleTx: { type: \"string\" },\n          entropy: { type: \"string\", nullable: true },\n          payoutAmount: { type: \"integer\", nullable: true },\n          feeAmount: { type: \"integer\", nullable: true },\n          entries: { type: \"array\", items: { type: \"object\" } },\n          verification: {\n            type: \"object\",\n            properties: {\n              commitmentCheck: { type: \"string\" },\n              resultFormula: { type: \"string\" },\n              entropySource: { type: \"string\" },\n            },\n          },\n        },\n      },\n      Transaction: {\n        type: \"object\",\n        properties: {\n          id: { type: \"string\" },\n          game: { type: \"string\" },\n          matchId: { type: \"string\" },\n          txType: { type: \"string\", enum: [\"deposit\", \"refund\"] },\n          amountLamports: { type: \"string\" },\n          txSig: { type: \"string\" },\n          createdAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      ReferralStats: {\n        type: \"object\",\n        properties: {\n          referredCount: { type: \"integer\" },\n          activeCount: { type: \"integer\" },\n          totalVolumeLamports: { type: \"string\" },\n          totalEarnedLamports: { type: \"string\" },\n          totalRebateLamports: { type: \"string\" },\n          pendingLamports: { type: \"string\" },\n        },\n      },\n      ReferralEarning: {\n        type: \"object\",\n        properties: {\n          roundId: { type: \"string\" },\n          gameType: { type: \"string\" },\n          refereeWallet: { type: \"string\" },\n          wagerLamports: { type: \"string\" },\n          earnedLamports: { type: \"string\" },\n          createdAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      ClaimResponse: {\n        type: \"object\",\n        properties: {\n          claimId: { type: \"string\" },\n          amountLamports: { type: \"string\" },\n          status: { type: \"string\" },\n          txSignature: { type: \"string\" },\n        },\n      },\n      PriceResponse: {\n        type: \"object\",\n        properties: {\n          price: { type: \"number\", description: \"SOL/USD price\" },\n          updatedAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      HealthResponse: {\n        type: \"object\",\n        properties: {\n          status: { type: \"string\" },\n          version: { type: \"string\" },\n          dbConnected: { type: \"boolean\" },\n          workerRunning: { type: \"boolean\" },\n          unsettledCount: { type: \"integer\" },\n          oldestUnsettledAge: { type: \"integer\", description: \"Seconds\" },\n          eventQueue: {\n            type: \"object\",\n            description: \"Only present when verbose=1\",\n            properties: {\n              pending: { type: \"integer\" },\n              processing: { type: \"integer\" },\n              dead: { type: \"integer\" },\n              completed: { type: \"integer\" },\n            },\n          },\n        },\n      },\n    },\n  },\n  paths: {\n    // ── Auth ───────────────────────────────────────────────────────\n    \"/auth/challenge\": {\n      post: {\n        tags: [\"Auth\"],\n        summary: \"Request sign-in challenge\",\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"wallet\"],\n                properties: {\n                  wallet: { type: \"string\", description: \"Base58 wallet address\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Challenge issued\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/ChallengeResponse\" } } },\n          },\n          \"400\": { description: \"Invalid request\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n        },\n      },\n    },\n    \"/auth/verify\": {\n      post: {\n        tags: [\"Auth\"],\n        summary: \"Verify signature and issue tokens\",\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"nonce\", \"wallet\", \"signature\"],\n                properties: {\n                  nonce: { type: \"string\" },\n                  wallet: { type: \"string\" },\n                  signature: { type: \"string\", description: \"Base58-encoded Ed25519 signature\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Tokens issued\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/TokenResponse\" } } },\n          },\n          \"400\": { description: \"Missing fields\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"401\": { description: \"Invalid signature or challenge\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n        },\n      },\n    },\n    \"/auth/refresh\": {\n      post: {\n        tags: [\"Auth\"],\n        summary: \"Rotate refresh token and issue new access token\",\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"refreshToken\"],\n                properties: {\n                  refreshToken: { type: \"string\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"New tokens issued\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/TokenResponse\" } } },\n          },\n          \"401\": { description: \"Invalid or expired token\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n        },\n      },\n    },\n    \"/auth/logout\": {\n      post: {\n        tags: [\"Auth\"],\n        summary: \"Revoke refresh token\",\n        requestBody: {\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                properties: {\n                  refreshToken: { type: \"string\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"204\": { description: \"Logged out\" },\n        },\n      },\n    },\n\n    // ── Coinflip ──────────────────────────────────────────────────\n    \"/fairness/coinflip/create\": {\n      post: {\n        tags: [\"Coinflip\"],\n        summary: \"Create a coinflip match\",\n        security: [{ bearerAuth: [] }],\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"wallet\", \"amountLamports\", \"side\"],\n                properties: {\n                  wallet: { type: \"string\", description: \"Base58 wallet address\" },\n                  amountLamports: {\n                    type: \"integer\",\n                    minimum: 1000000,\n                    maximum: 100000000000,\n                    description: \"Wager in lamports (0.001 - 100 SOL)\",\n                  },\n                  side: { type: \"integer\", enum: [0, 1], description: \"0 = Heads, 1 = Tails\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Match created, transaction ready for signing\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/CoinflipCreateResponse\" } } },\n          },\n          \"400\": { description: \"Validation error\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"403\": { description: \"Wallet mismatch with JWT\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"409\": { description: \"Match ID collision\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"429\": { description: \"Rate limited\" },\n          \"500\": { description: \"Transaction build failed\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n        },\n      },\n    },\n\n    // ── Lord of RNGs ──────────────────────────────────────────────\n    \"/fairness/lord/current\": {\n      get: {\n        tags: [\"Lord of RNGs\"],\n        summary: \"Get the current active Lord round\",\n        security: [{ bearerAuth: [] }],\n        responses: {\n          \"200\": {\n            description: \"Active round or null\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    round: {\n                      nullable: true,\n                      allOf: [{ $ref: \"#/components/schemas/LordRound\" }],\n                    },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/fairness/lord/create\": {\n      post: {\n        tags: [\"Lord of RNGs\"],\n        summary: \"Create a Lord of RNGs round\",\n        security: [{ bearerAuth: [] }],\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"wallet\", \"amountLamports\"],\n                properties: {\n                  wallet: { type: \"string\" },\n                  amountLamports: {\n                    type: \"integer\",\n                    minimum: 1000000,\n                    description: \"Wager in lamports (min 0.001 SOL)\",\n                  },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Round created\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/LordCreateResponse\" } } },\n          },\n          \"400\": { description: \"Validation error\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"403\": { description: \"Wallet mismatch\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"409\": { description: \"Round already active or ID collision\" },\n          \"429\": { description: \"Rate limited\" },\n          \"500\": { description: \"Transaction build failed\" },\n        },\n      },\n    },\n\n    // ── Close Call ─────────────────────────────────────────────────\n    \"/closecall/current-round\": {\n      get: {\n        tags: [\"Close Call\"],\n        summary: \"Get the current open round\",\n        responses: {\n          \"200\": {\n            description: \"Current round or null\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    round: {\n                      nullable: true,\n                      allOf: [{ $ref: \"#/components/schemas/CloseCallRound\" }],\n                    },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/closecall/history\": {\n      get: {\n        tags: [\"Close Call\"],\n        summary: \"Get recent settled rounds\",\n        parameters: [\n          {\n            name: \"limit\",\n            in: \"query\",\n            schema: { type: \"integer\", minimum: 1, maximum: 100, default: 20 },\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"List of rounds\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    rounds: {\n                      type: \"array\",\n                      items: { $ref: \"#/components/schemas/CloseCallRound\" },\n                    },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/closecall/candles\": {\n      get: {\n        tags: [\"Close Call\"],\n        summary: \"Get BTC/USD minute candles\",\n        parameters: [\n          {\n            name: \"limit\",\n            in: \"query\",\n            schema: { type: \"integer\", minimum: 1, maximum: 60, default: 5 },\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"Candle data\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    candles: {\n                      type: \"array\",\n                      items: { $ref: \"#/components/schemas/Candle\" },\n                    },\n                    currentOpenPrice: { type: \"number\", nullable: true },\n                    currentMinuteTs: { type: \"integer\", nullable: true },\n                  },\n                },\n              