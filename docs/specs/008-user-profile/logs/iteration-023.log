rs: [\n563\t          {\n564\t            name: \"limit\",\n565\t            in: \"query\",\n566\t            schema: { type: \"integer\", minimum: 1, maximum: 60, default: 5 },\n567\t          },\n568\t        ],\n569\t        responses: {\n570\t          \"200\": {\n571\t            description: \"Candle data\",\n572\t            content: {\n573\t              \"application/json\": {\n574\t                schema: {\n575\t                  type: \"object\",\n576\t                  properties: {\n577\t                    candles: {\n578\t                      type: \"array\",\n579\t                      items: { $ref: \"#/components/schemas/Candle\" },\n580\t                    },\n581\t                    currentOpenPrice: { type: \"number\", nullable: true },\n582\t                    currentMinuteTs: { type: \"integer\", nullable: true },\n583\t                  },\n584\t                },\n585\t              },\n586\t            },\n587\t          },\n588\t        },\n589\t      },\n590\t    },\n591\t    \"/closecall/bet\": {\n592\t      post: {\n593\t        tags: [\"Close Call\"],\n594\t        summary: \"Co-sign a bet transaction\",\n595\t        security: [{ bearerAuth: [] }],\n596\t        requestBody: {\n597\t          required: true,\n598\t          content: {\n599\t            \"application/json\": {\n600\t              schema: {\n601\t                type: \"object\",\n602\t                required: [\"playerPubkey\", \"side\", \"amountLamports\"],\n603\t                properties: {\n604\t                  playerPubkey: { type: \"string\", description: \"Base58 wallet address\" },\n605\t                  side: { type: \"string\", enum: [\"green\", \"red\"] },\n606\t                  amountLamports: {\n607\t                    type: \"integer\",\n608\t                    minimum: 1000000,\n609\t                    maximum: 100000000000,\n610\t                  },\n611\t                },\n612\t              },\n613\t            },\n614\t          },\n615\t        },\n616\t        responses: {\n617\t          \"200\": {\n618\t            description: \"Transaction ready for signing\",\n619\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/CloseCallBetResponse\" } } },\n620\t          },\n621\t          \"400\": { description: \"Validation error\" },\n622\t          \"401\": { description: \"Authentication required\" },\n623\t          \"429\": { description: \"Rate limited\" },\n624\t          \"500\": { description: \"Transaction build failed\" },\n625\t          \"503\": { description: \"No price data available\" },\n626\t        },\n627\t      },\n628\t    },\n629\t\n630\t    // ── Rounds ────────────────────────────────────────────────────\n631\t    \"/fairness/rounds/history\": {\n632\t      get: {\n633\t        tags: [\"Rounds\"],\n634\t        summary: \"Get settled round history\",\n635\t        security: [{ bearerAuth: [] }],\n636\t        parameters: [\n637\t          {\n638\t            name: \"game\",\n639\t            in: \"query\",\n640\t            required: true,\n641\t            schema: { type: \"string\", enum: [\"coinflip\", \"lord\"] },\n642\t          },\n643\t          {\n644\t            name: \"limit\",\n645\t            in: \"query\",\n646\t            schema: { type: \"integer\", minimum: 1, maximum: 50, default: 20 },\n647\t          },\n648\t        ],\n649\t        responses: {\n650\t          \"200\": {\n651\t            description: \"List of rounds\",\n652\t            content: {\n653\t              \"application/json\": {\n654\t                schema: {\n655\t                  type: \"object\",\n656\t                  properties: {\n657\t                    rounds: {\n658\t                      type: \"array\",\n659\t                      items: { $ref: \"#/components/schemas/RoundResponse\" },\n660\t                    },\n661\t                  },\n662\t                },\n663\t              },\n664\t            },\n665\t          },\n666\t          \"400\": { description: \"Invalid game parameter\" },\n667\t        },\n668\t      },\n669\t    },\n670\t    \"/fairness/rounds/by-id/{matchId}\": {\n671\t      get: {\n672\t        tags: [\"Rounds\"],\n673\t        summary: \"Get round by match ID\",\n674\t        security: [{ bearerAuth: [] }],\n675\t        parameters: [\n676\t          {\n677\t            name: \"matchId\",\n678\t            in: \"path\",\n679\t            required: true,\n680\t            schema: { type: \"string\" },\n681\t            description: \"16-char hex (coinflip/lord) or numeric timestamp (closecall)\",\n682\t          },\n683\t        ],\n684\t        responses: {\n685\t          \"200\": {\n686\t            description: \"Round data\",\n687\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/RoundResponse\" } } },\n688\t          },\n689\t          \"400\": { description: \"Invalid matchId format\" },\n690\t          \"404\": { description: \"Round not found\" },\n691\t        },\n692\t      },\n693\t    },\n694\t    \"/fairness/rounds/{pda}\": {\n695\t      get: {\n696\t        tags: [\"Rounds\"],\n697\t        summary: \"Get round by PDA address\",\n698\t        security: [{ bearerAuth: [] }],\n699\t        parameters: [\n700\t          {\n701\t            name: \"pda\",\n702\t            in: \"path\",\n703\t            required: true,\n704\t            schema: { type: \"string\" },\n705\t            description: \"Base58 PDA address\",\n706\t          },\n707\t        ],\n708\t        responses: {\n709\t          \"200\": {\n710\t            description: \"Round data\",\n711\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/RoundResponse\" } } },\n712\t          },\n713\t          \"404\": { description: \"Round not found\" },\n714\t        },\n715\t      },\n716\t    },\n717\t\n718\t    // ── Profile ───────────────────────────────────────────────────\n719\t    \"/profile/transactions\": {\n720\t     