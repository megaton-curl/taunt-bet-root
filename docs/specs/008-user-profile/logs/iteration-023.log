rties: {\n          userId: { type: \"string\", description: \"Short user ID (usr_xxxxxxxx)\" },\n          username: { type: \"string\" },\n          avatarUrl: { type: \"string\", nullable: true },\n          heatMultiplier: { type: \"number\" },\n          pointsBalance: { type: \"string\", description: \"BigInt as string\" },\n          stats: { $ref: \"#/components/schemas/PlayerStats\" },\n          usernameNextEditAt: { type: \"string\", format: \"date-time\", nullable: true },\n          createdAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      PublicPlayerProfile: {\n        type: \"object\",\n        properties: {\n          userId: { type: \"string\", description: \"Short user ID (usr_xxxxxxxx)\" },\n          username: { type: \"string\" },\n          avatarUrl: { type: \"string\", nullable: true },\n          heatMultiplier: { type: \"number\" },\n          stats: { $ref: \"#/components/schemas/PublicStats\" },\n          createdAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      PriceResponse: {","originalFile":"/**\n * OpenAPI 3.0 specification for the Taunt Bet API.\n */\n\nexport const spec = {\n  openapi: \"3.0.3\",\n  info: {\n    title: \"Taunt Bet API\",\n    description:\n      \"Backend API for Taunt Bet — handles game round creation, \" +\n      \"settlement verification, player profiles, referrals, and price feeds.\",\n    version: \"0.1.0\",\n  },\n  servers: [\n    { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n    { url: \"http://localhost:3100\", description: \"Local\" },\n    { url: \"https://api.taunt.bet\", description: \"Production\" },\n  ],\n  tags: [\n    { name: \"Auth\", description: \"JWT session management via Ed25519 challenge-response\" },\n    { name: \"Coinflip\", description: \"1v1 coinflip match creation\" },\n    { name: \"Lord of RNGs\", description: \"Winner-takes-all jackpot round creation\" },\n    { name: \"Close Call\", description: \"Pari-mutuel BTC candle prediction\" },\n    { name: \"Rounds\", description: \"Round history and fairness verification\" },\n    { name: \"Profile\", description: \"Player identity, stats, and transaction history\" },\n    { name: \"Referral\", description: \"Referral code management, linking, and earnings\" },\n    { name: \"Price\", description: \"Cached SOL/USD price from Pyth\" },\n    { name: \"Health\", description: \"Operational health check\" },\n  ],\n  components: {\n    securitySchemes: {\n      bearerAuth: {\n        type: \"http\",\n        scheme: \"bearer\",\n        bearerFormat: \"JWT\",\n        description: \"JWT obtained via /auth/verify\",\n      },\n    },\n    schemas: {\n      Error: {\n        type: \"object\",\n        properties: {\n          error: { type: \"string\" },\n        },\n      },\n      StructuredError: {\n        type: \"object\",\n        properties: {\n          error: {\n            type: \"object\",\n            properties: {\n              code: { type: \"string\" },\n              message: { type: \"string\" },\n              retryable: { type: \"boolean\" },\n            },\n            required: [\"code\", \"message\"],\n          },\n        },\n      },\n      ChallengeResponse: {\n        type: \"object\",\n        properties: {\n          nonce: { type: \"string\", description: \"64-char hex nonce\" },\n          message: { type: \"string\", description: \"Human-readable sign-in message\" },\n          expiresAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      TokenResponse: {\n        type: \"object\",\n        properties: {\n          accessToken: { type: \"string\", description: \"HS256 JWT\" },\n          accessExpiresAt: { type: \"string\", format: \"date-time\" },\n          refreshToken: { type: \"string\", description: \"Opaque 96-char hex token\" },\n          refreshExpiresAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      CoinflipCreateResponse: {\n        type: \"object\",\n        properties: {\n          transaction: { type: \"string\", description: \"Base64-encoded partially-signed transaction\" },\n          matchPda: { type: \"string\", description: \"Base58 match PDA address\" },\n          matchId: { type: \"string\", description: \"16-char hex match ID\" },\n          commitment: { type: \"string\", description: \"SHA256 hex commitment\" },\n          lastValidBlockHeight: { type: \"integer\" },\n        },\n      },\n      LordCreateResponse: {\n        type: \"object\",\n        properties: {\n          transaction: { type: \"string\", description: \"Base64-encoded partially-signed transaction\" },\n          roundPda: { type: \"string\", description: \"Base58 round PDA address\" },\n          matchId: { type: \"string\", description: \"16-char hex match ID\" },\n          commitment: { type: \"string\", description: \"SHA256 hex commitment\" },\n          lastValidBlockHeight: { type: \"integer\" },\n        },\n      },\n      LordEntry: {\n        type: \"object\",\n        properties: {\n          player: { type: \"string\", description: \"Base58 wallet address\" },\n          amountLamports: { type: \"integer\" },\n        },\n      },\n      LordRound: {\n        type: \"object\",\n        properties: {\n          matchId: { type: \"string\" },\n          pda: { type: \"string\" },\n          phase: {\n            type: \"string\",\n            enum: [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"],\n          },\n          creator: { type: \"string\" },\n          commitment: { type: \"string\" },\n          entries: {\n            type: \"array\",\n            items: { $ref: \"#/components/schemas/LordEntry\" },\n          },\n          totalAmountLamports: { type: \"integer\" },\n          distinctPlayers: { type: \"integer\" },\n          countdownStartedAt: { type: \"integer\", nullable: true },\n          countdownEndsAt: { type: \"integer\", nullable: true },\n          createdAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      CloseCallEntry: {\n        type: \"object\",\n        properties: {\n          player: { type: \"string\" },\n          amountLamports: { type: \"integer\" },\n        },\n      },\n      CloseCallRound: {\n        type: \"object\",\n        properties: {\n          roundId: { type: \"string\" },\n          pda: { type: \"string\" },\n          phase: { type: \"string\", enum: [\"open\", \"settled\", \"refunded\"] },\n          openPrice: { type: \"number\" },\n          openPriceExpo: { type: \"integer\" },\n          closePrice: { type: \"number\", nullable: true },\n          outcome: { type: \"string\", enum: [\"pending\", \"green\", \"red\", \"refund\"] },\n          greenPool: { type: \"integer\" },\n          redPool: { type: \"integer\" },\n          totalPool: { type: \"integer\" },\n          totalFee: { type: \"integer\" },\n          greenEntries: {\n            type: \"array\",\n            items: { $ref: \"#/components/schemas/CloseCallEntry\" },\n          },\n          redEntries: {\n            type: \"array\",\n            items: { $ref: \"#/components/schemas/CloseCallEntry\" },\n          },\n          greenCount: { type: \"integer\" },\n          redCount: { type: \"integer\" },\n          settleTx: { type: \"string\", nullable: true },\n          createdAt: { type: \"string\", format: \"date-time\" },\n          settledAt: { type: \"string\", format: \"date-time\", nullable: true },\n        },\n      },\n      Candle: {\n        type: \"object\",\n        properties: {\n          openTime: { type: \"integer\", description: \"Millisecond timestamp\" },\n          closeTime: { type: \"integer\", description: \"Millisecond timestamp\" },\n          open: { type: \"number\" },\n          close: { type: \"number\" },\n          high: { type: \"number\" },\n          low: { type: \"number\" },\n          outcome: { type: \"string\", nullable: true, enum: [\"green\", \"red\", null] },\n        },\n      },\n      CloseCallBetResponse: {\n        type: \"object\",\n        properties: {\n          transaction: { type: \"string\", description: \"Base64-encoded partially-signed transaction\" },\n          minuteTs: { type: \"integer\", description: \"Unix timestamp (seconds) of the minute boundary\" },\n          roundPda: { type: \"string\" },\n        },\n      },\n      RoundResponse: {\n        type: \"object\",\n        properties: {\n          pda: { type: \"string\" },\n          game: { type: \"string\", enum: [\"coinflip\", \"lord\"] },\n          phase: { type: \"string\" },\n          creator: { type: \"string\" },\n          commitment: { type: \"string\" },\n          amountLamports: { type: \"integer\" },\n          side: { type: \"integer\" },\n          matchId: { type: \"string\" },\n          createdAt: { type: \"string\", format: \"date-time\" },\n          updatedAt: { type: \"string\", format: \"date-time\" },\n          targetSlot: { type: \"integer\" },\n          secret: { type: \"string\", description: \"Only present when settled\" },\n          resultHash: { type: \"string\", nullable: true },\n          resultSide: { type: \"integer\", description: \"Coinflip only\" },\n          winningEntryIndex: { type: \"integer\", description: \"Lord only\" },\n          winner: { type: \"string\" },\n          settleTx: { type: \"string\" },\n          entropy: { type: \"string\", nullable: true },\n          payoutAmount: { type: \"integer\", nullable: true },\n          feeAmount: { type: \"integer\", nullable: true },\n          entries: { type: \"array\", items: { type: \"object\" } },\n          verification: {\n            type: \"object\",\n            properties: {\n              commitmentCheck: { type: \"string\" },\n              resultFormula: { type: \"string\" },\n              entropySource: { type: \"string\" },\n            },\n          },\n        },\n      },\n      Transaction: {\n        type: \"object\",\n        properties: {\n          id: { type: \"string\" },\n          game: { type: \"string\" },\n          matchId: { type: \"string\" },\n          txType: { type: \"string\", enum: [\"deposit\", \"refund\"] },\n          amountLamports: { type: \"string\" },\n          txSig: { type: \"string\" },\n          createdAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      ReferralStats: {\n        type: \"object\",\n        properties: {\n          referredCount: { type: \"integer\" },\n          activeCount: { type: \"integer\" },\n          totalVolumeLamports: { type: \"string\" },\n          totalEarnedLamports: { type: \"string\" },\n          totalRebateLamports: { type: \"string\" },\n          pendingLamports: { type: \"string\" },\n        },\n      },\n      ReferralEarning: {\n        type: \"object\",\n        properties: {\n          roundId: { type: \"string\" },\n          gameType: { type: \"string\" },\n          refereeWallet: { type: \"string\" },\n          wagerLamports: { type: \"string\" },\n          earnedLamports: { type: \"string\" },\n          createdAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      ClaimResponse: {\n        type: \"object\",\n        properties: {\n          claimId: { type: \"string\" },\n          amountLamports: { type: \"string\" },\n          status: { type: \"string\" },\n          txSignature: { type: \"string\" },\n        },\n      },\n      PriceResponse: {\n        type: \"object\",\n        properties: {\n          price: { type: \"number\", description: \"SOL/USD price\" },\n          updatedAt: { type: \"string\", format: \"date-time\" },\n        },\n      },\n      HealthResponse: {\n        type: \"object\",\n        properties: {\n          status: { type: \"string\" },\n          version: { type: \"string\" },\n          dbConnected: { type: \"boolean\" },\n          workerRunning: { type: \"boolean\" },\n          unsettledCount: { type: \"integer\" },\n          oldestUnsettledAge: { type: \"integer\", description: \"Seconds\" },\n          eventQueue: {\n            type: \"object\",\n            description: \"Only present when verbose=1\",\n            properties: {\n              pending: { type: \"integer\" },\n              processing: { type: \"integer\" },\n              dead: { type: \"integer\" },\n              completed: { type: \"integer\" },\n            },\n          },\n        },\n      },\n    },\n  },\n  paths: {\n    // ── Auth ───────────────────────────────────────────────────────\n    \"/auth/challenge\": {\n      post: {\n        tags: [\"Auth\"],\n        summary: \"Request sign-in challenge\",\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"wallet\"],\n                properties: {\n                  wallet: { type: \"string\", description: \"Base58 wallet address\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Challenge issued\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/ChallengeResponse\" } } },\n          },\n          \"400\": { description: \"Invalid request\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n        },\n      },\n    },\n    \"/auth/verify\": {\n      post: {\n        tags: [\"Auth\"],\n        summary: \"Verify signature and issue tokens\",\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"nonce\", \"wallet\", \"signature\"],\n                properties: {\n                  nonce: { type: \"string\" },\n                  wallet: { type: \"string\" },\n                  signature: { type: \"string\", description: \"Base58-encoded Ed25519 signature\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Tokens issued\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/TokenResponse\" } } },\n          },\n          \"400\": { description: \"Missing fields\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"401\": { description: \"Invalid signature or challenge\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n        },\n      },\n    },\n    \"/auth/refresh\": {\n      post: {\n        tags: [\"Auth\"],\n        summary: \"Rotate refresh token and issue new access token\",\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"refreshToken\"],\n                properties: {\n                  refreshToken: { type: \"string\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"New tokens issued\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/TokenResponse\" } } },\n          },\n          \"401\": { description: \"Invalid or expired token\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n        },\n      },\n    },\n    \"/auth/logout\": {\n      post: {\n        tags: [\"Auth\"],\n        summary: \"Revoke refresh token\",\n        requestBody: {\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                properties: {\n                  refreshToken: { type: \"string\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"204\": { description: \"Logged out\" },\n        },\n      },\n    },\n\n    // ── Coinflip ──────────────────────────────────────────────────\n    \"/fairness/coinflip/create\": {\n      post: {\n        tags: [\"Coinflip\"],\n        summary: \"Create a coinflip match\",\n        security: [{ bearerAuth: [] }],\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"wallet\", \"amountLamports\", \"side\"],\n                properties: {\n                  wallet: { type: \"string\", description: \"Base58 wallet address\" },\n                  amountLamports: {\n                    type: \"integer\",\n                    minimum: 1000000,\n                    maximum: 100000000000,\n                    description: \"Wager in lamports (0.001 - 100 SOL)\",\n                  },\n                  side: { type: \"integer\", enum: [0, 1], description: \"0 = Heads, 1 = Tails\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Match created, transaction ready for signing\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/CoinflipCreateResponse\" } } },\n          },\n          \"400\": { description: \"Validation error\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"403\": { description: \"Wallet mismatch with JWT\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"409\": { description: \"Match ID collision\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"429\": { description: \"Rate limited\" },\n          \"500\": { description: \"Transaction build failed\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n        },\n      },\n    },\n\n    // ── Lord of RNGs ──────────────────────────────────────────────\n    \"/fairness/lord/current\": {\n      get: {\n        tags: [\"Lord of RNGs\"],\n        summary: \"Get the current active Lord round\",\n        security: [{ bearerAuth: [] }],\n        responses: {\n          \"200\": {\n            description: \"Active round or null\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    round: {\n                      nullable: true,\n                      allOf: [{ $ref: \"#/components/schemas/LordRound\" }],\n                    },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/fairness/lord/create\": {\n      post: {\n        tags: [\"Lord of RNGs\"],\n        summary: \"Create a Lord of RNGs round\",\n        security: [{ bearerAuth: [] }],\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"wallet\", \"amountLamports\"],\n                properties: {\n                  wallet: { type: \"string\" },\n                  amountLamports: {\n                    type: \"integer\",\n                    minimum: 1000000,\n                    description: \"Wager in lamports (min 0.001 SOL)\",\n                  },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Round created\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/LordCreateResponse\" } } },\n          },\n          \"400\": { description: \"Validation error\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"403\": { description: \"Wallet mismatch\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n          \"409\": { description: \"Round already active or ID collision\" },\n          \"429\": { description: \"Rate limited\" },\n          \"500\": { description: \"Transaction build failed\" },\n        },\n      },\n    },\n\n    // ── Close Call ─────────────────────────────────────────────────\n    \"/closecall/current-round\": {\n      get: {\n        tags: [\"Close Call\"],\n        summary: \"Get the current open round\",\n        responses: {\n          \"200\": {\n            description: \"Current round or null\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    round: {\n                      nullable: true,\n                      allOf: [{ $ref: \"#/components/schemas/CloseCallRound\" }],\n                    },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/closecall/history\": {\n      get: {\n        tags: [\"Close Call\"],\n        summary: \"Get recent settled rounds\",\n        parameters: [\n          {\n            name: \"limit\",\n            in: \"query\",\n            schema: { type: \"integer\", minimum: 1, maximum: 100, default: 20 },\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"List of rounds\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    rounds: {\n                      type: \"array\",\n                      items: { $ref: \"#/components/schemas/CloseCallRound\" },\n                    },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/closecall/candles\": {\n      get: {\n        tags: [\"Close Call\"],\n        summary: \"Get BTC/USD minute candles\",\n        parameters: [\n          {\n            name: \"limit\",\n            in: \"query\",\n            schema: { type: \"integer\", minimum: 1, maximum: 60, default: 5 },\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"Candle data\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    candles: {\n                      type: \"array\",\n                      items: { $ref: \"#/components/schemas/Candle\" },\n                    },\n                    currentOpenPrice: { type: \"number\", nullable: true },\n                    currentMinuteTs: { type: \"integer\", nullable: true },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/closecall/bet\": {\n      post: {\n        tags: [\"Close Call\"],\n        summary: \"Co-sign a bet transaction\",\n        security: [{ bearerAuth: [] }],\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"playerPubkey\", \"side\", \"amountLamports\"],\n                properties: {\n                  playerPubkey: { type: \"string\", description: \"Base58 wallet address\" },\n                  side: { type: \"string\", enum: [\"green\", \"red\"] },\n                  amountLamports: {\n                    type: \"integer\",\n                    minimum: 1000000,\n                    maximum: 100000000000,\n                  },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Transaction ready for signing\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/CloseCallBetResponse\" } } },\n          },\n          \"400\": { description: \"Validation error\" },\n          \"401\": { description: \"Authentication required\" },\n          \"429\": { description: \"Rate limited\" },\n          \"500\": { description: \"Transaction build failed\" },\n          \"503\": { description: \"No price data available\" },\n        },\n      },\n    },\n\n    // ── Rounds ────────────────────────────────────────────────────\n    \"/fairness/rounds/history\": {\n      get: {\n        tags: [\"Rounds\"],\n        summary: \"Get settled round history\",\n        security: [{ bearerAuth: [] }],\n        parameters: [\n          {\n            name: \"game\",\n            in: \"query\",\n            required: true,\n            schema: { type: \"string\", enum: [\"coinflip\", \"lord\"] },\n          },\n          {\n            name: \"limit\",\n            in: \"query\",\n            schema: { type: \"integer\", minimum: 1, maximum: 50, default: 20 },\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"List of rounds\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    rounds: {\n                      type: \"array\",\n                      items: { $ref: \"#/components/schemas/RoundResponse\" },\n                    },\n                  },\n                },\n              },\n            },\n          },\n          \"400\": { description: \"Invalid game parameter\" },\n        },\n      },\n    },\n    \"/fairness/rounds/by-id/{matchId}\": {\n      get: {\n        tags: [\"Rounds\"],\n        summary: \"Get round by match ID\",\n        security: [{ bearerAuth: [] }],\n        parameters: [\n          {\n            name: \"matchId\",\n            in: \"path\",\n            required: true,\n            schema: { type: \"string\" },\n            description: \"16-char hex (coinflip/lord) or numeric timestamp (closecall)\",\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"Round data\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/RoundResponse\" } } },\n          },\n          \"400\": { description: \"Invalid matchId format\" },\n          \"404\": { description: \"Round not found\" },\n        },\n      },\n    },\n    \"/fairness/rounds/{pda}\": {\n      get: {\n        tags: [\"Rounds\"],\n        summary: \"Get round by PDA address\",\n        security: [{ bearerAuth: [] }],\n        parameters: [\n          {\n            name: \"pda\",\n            in: \"path\",\n            required: true,\n            schema: { type: \"string\" },\n            description: \"Base58 PDA address\",\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"Round data\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/RoundResponse\" } } },\n          },\n          \"404\": { description: \"Round not found\" },\n        },\n      },\n    },\n\n    // ── Profile ───────────────────────────────────────────────────\n    \"/profile/transactions\": {\n      get: {\n        tags: [\"Profile\"],\n        summary: \"Get player transaction history\",\n        security: [{ bearerAuth: [] }],\n        parameters: [\n          { name: \"cursor\", in: \"query\", schema: { type: \"string\" } },\n          {\n            name: \"limit\",\n            in: \"query\",\n            schema: { type: \"integer\", minimum: 1, maximum: 50, default: 20 },\n          },\n          {\n            name: \"game\",\n            in: \"query\",\n            schema: { type: \"string\" },\n            description: \"Filter by game (coinflip, lord-of-rngs, close-call)\",\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"Paginated transaction list\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    transactions: {\n                      type: \"array\",\n                      items: { $ref: \"#/components/schemas/Transaction\" },\n                    },\n                    nextCursor: { type: \"string\", nullable: true },\n                  },\n                },\n              },\n            },\n          },\n          \"401\": { description: \"Authentication required\" },\n        },\n      },\n    },\n    \"/profile/confirm-tx\": {\n      post: {\n        tags: [\"Profile\"],\n        summary: \"Report a confirmed on-chain transaction\",\n        security: [{ bearerAuth: [] }],\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"game\", \"matchId\", \"txType\", \"txSig\", \"amountLamports\"],\n                properties: {\n                  game: { type: \"string\" },\n                  matchId: { type: \"string\" },\n                  txType: { type: \"string\", enum: [\"deposit\", \"refund\"] },\n                  txSig: { type: \"string\" },\n                  amountLamports: { type: \"integer\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Transaction recorded\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: { ok: { type: \"boolean\" } },\n                },\n              },\n            },\n          },\n          \"400\": { description: \"Missing or invalid fields\" },\n          \"401\": { description: \"Authentication required\" },\n        },\n      },\n    },\n\n    // ── Referral ──────────────────────────────────────────────────\n    \"/referral/code\": {\n      post: {\n        tags: [\"Referral\"],\n        summary: \"Set referral code (permanent)\",\n        security: [{ bearerAuth: [] }],\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"code\"],\n                properties: {\n                  code: {\n                    type: \"string\",\n                    pattern: \"^[a-z0-9-]{3,16}$\",\n                    description: \"3-16 chars, lowercase alphanumeric + hyphens\",\n                  },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Code set\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: { code: { type: \"string\" } },\n                },\n              },\n            },\n          },\n          \"400\": { description: \"Invalid code format\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/StructuredError\" } } } },\n          \"409\": { description: \"Code already set or taken\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/StructuredError\" } } } },\n        },\n      },\n      get: {\n        tags: [\"Referral\"],\n        summary: \"Get own referral code\",\n        security: [{ bearerAuth: [] }],\n        responses: {\n          \"200\": {\n            description: \"Code found\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: { code: { type: \"string\" } },\n                },\n              },\n            },\n          },\n          \"404\": { description: \"No code set\" },\n        },\n      },\n    },\n    \"/referral/apply\": {\n      post: {\n        tags: [\"Referral\"],\n        summary: \"Apply a referral code (link to referrer)\",\n        security: [{ bearerAuth: [] }],\n        requestBody: {\n          required: true,\n          content: {\n            \"application/json\": {\n              schema: {\n                type: \"object\",\n                required: [\"code\"],\n                properties: {\n                  code: { type: \"string\" },\n                },\n              },\n            },\n          },\n        },\n        responses: {\n          \"200\": {\n            description: \"Linked to referrer\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    referrer: { type: \"string\" },\n                    benefit: { type: \"string\" },\n                  },\n                },\n              },\n            },\n          },\n          \"400\": { description: \"Invalid code or self-referral\" },\n          \"404\": { description: \"Code not found\" },\n          \"409\": { description: \"Already linked to a referrer\" },\n        },\n      },\n    },\n    \"/referral/referrer\": {\n      get: {\n        tags: [\"Referral\"],\n        summary: \"Get own referrer info\",\n        security: [{ bearerAuth: [] }],\n        responses: {\n          \"200\": {\n            description: \"Referrer found\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    referrerWallet: { type: \"string\" },\n                    referrerCode: { type: \"string\", nullable: true },\n                    linkedAt: { type: \"string\", format: \"date-time\" },\n                  },\n                },\n              },\n            },\n          },\n          \"404\": { description: \"Not linked to a referrer\" },\n        },\n      },\n    },\n    \"/referral/stats\": {\n      get: {\n        tags: [\"Referral\"],\n        summary: \"Get referral stats\",\n        security: [{ bearerAuth: [] }],\n        responses: {\n          \"200\": {\n            description: \"Referral statistics\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/ReferralStats\" } } },\n          },\n        },\n      },\n    },\n    \"/referral/referrals\": {\n      get: {\n        tags: [\"Referral\"],\n        summary: \"List referred users (last 10)\",\n        security: [{ bearerAuth: [] }],\n        responses: {\n          \"200\": {\n            description: \"Referred users\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    items: {\n                      type: \"array\",\n                      items: {\n                        type: \"object\",\n                        properties: {\n                          refereeWallet: { type: \"string\" },\n                          createdAt: { type: \"string\", format: \"date-time\" },\n                        },\n                      },\n                    },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/referral/earnings\": {\n      get: {\n        tags: [\"Referral\"],\n        summary: \"Get paginated referral earnings\",\n        security: [{ bearerAuth: [] }],\n        parameters: [\n          { name: \"page\", in: \"query\", schema: { type: \"integer\", default: 1 } },\n          {\n            name: \"limit\",\n            in: \"query\",\n            schema: { type: \"integer\", minimum: 1, maximum: 100, default: 20 },\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"Earnings list\",\n            content: {\n              \"application/json\": {\n                schema: {\n                  type: \"object\",\n                  properties: {\n                    items: {\n                      type: \"array\",\n                      items: { $ref: \"#/components/schemas/ReferralEarning\" },\n                    },\n                    pagination: {\n                      type: \"object\",\n                      properties: {\n                        page: { type: \"integer\" },\n                        totalPages: { type: \"integer\" },\n                      },\n                    },\n                  },\n                },\n              },\n            },\n          },\n        },\n      },\n    },\n    \"/referral/claim\": {\n      post: {\n        tags: [\"Referral\"],\n        summary: \"Request payout of pending referral earnings\",\n        security: [{ bearerAuth: [] }],\n        responses: {\n          \"202\": {\n            description: \"Claim queued\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/ClaimResponse\" } } },\n          },\n          \"400\": { description: \"Zero balance or below threshold\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/StructuredError\" } } } },\n        },\n      },\n    },\n    \"/referral/claim/{claimId}\": {\n      get: {\n        tags: [\"Referral\"],\n        summary: \"Poll claim status\",\n        security: [{ bearerAuth: [] }],\n        parameters: [\n          {\n            name: \"claimId\",\n            in: \"path\",\n            required: true,\n            schema: { type: \"string\" },\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"Claim status\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/ClaimResponse\" } } },\n          },\n          \"404\": { description: \"Claim not found\" },\n        },\n      },\n    },\n\n    // ── Price ─────────────────────────────────────────────────────\n    \"/price/sol-usd\": {\n      get: {\n        tags: [\"Price\"],\n        summary: \"Get cached SOL/USD price\",\n        responses: {\n          \"200\": {\n            description: \"Price data\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/PriceResponse\" } } },\n          },\n          \"503\": { description: \"Price unavailable\" },\n        },\n      },\n    },\n\n    // ── Health ────────────────────────────────────────────────────\n    \"/health\": {\n      get: {\n        tags: [\"Health\"],\n        summary: \"Service health check\",\n        parameters: [\n          {\n            name: \"verbose\",\n            in: \"query\",\n            schema: { type: \"string\", enum: [\"1\"] },\n            description: \"Include event queue stats\",\n          },\n        ],\n        responses: {\n          \"200\": {\n            description: \"Health status\",\n            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/HealthResponse\" } } },\n          },\n        },\n      },\n    },\n  },\n} as const;\n","structuredPatch":[{"oldStart":256,"oldLines":6,"newStart":256,"newLines":65,"lines":["           txSignature: { type: \"string\" },","         },","       },","+      GameBreakdownStats: {","+        type: \"object\",","+        properties: {","+          gamesPlayed: { type: \"integer\" },","+          totalWagered: { type: \"string\", description: \"Lamports as string\" },","+          totalWins: { type: \"integer\" },","+          winRate: { type: \"number\" },","+          netPnl: { type: \"string\", description: \"Lamports as string\" },","+        },","+      },","+      PlayerStats: {","+        type: \"object\",","+        properties: {","+          gamesPlayed: { type: \"