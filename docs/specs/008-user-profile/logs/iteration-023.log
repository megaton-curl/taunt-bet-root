 100 SOL)\",\n417\t                  },\n418\t                  side: { type: \"integer\", enum: [0, 1], description: \"0 = Heads, 1 = Tails\" },\n419\t                },\n420\t              },\n421\t            },\n422\t          },\n423\t        },\n424\t        responses: {\n425\t          \"200\": {\n426\t            description: \"Match created, transaction ready for signing\",\n427\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/CoinflipCreateResponse\" } } },\n428\t          },\n429\t          \"400\": { description: \"Validation error\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n430\t          \"403\": { description: \"Wallet mismatch with JWT\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n431\t          \"409\": { description: \"Match ID collision\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n432\t          \"429\": { description: \"Rate limited\" },\n433\t          \"500\": { description: \"Transaction build failed\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n434\t        },\n435\t      },\n436\t    },\n437\t\n438\t    // ── Lord of RNGs ──────────────────────────────────────────────\n439\t    \"/fairness/lord/current\": {\n440\t      get: {\n441\t        tags: [\"Lord of RNGs\"],\n442\t        summary: \"Get the current active Lord round\",\n443\t        security: [{ bearerAuth: [] }],\n444\t        responses: {\n445\t          \"200\": {\n446\t            description: \"Active round or null\",\n447\t            content: {\n448\t              \"application/json\": {\n449\t                schema: {\n450\t                  type: \"object\",\n451\t                  properties: {\n452\t                    round: {\n453\t                      nullable: true,\n454\t                      allOf: [{ $ref: \"#/components/schemas/LordRound\" }],\n455\t                    },\n456\t                  },\n457\t                },\n458\t              },\n459\t            },\n460\t          },\n461\t        },\n462\t      },\n463\t    },\n464\t    \"/fairness/lord/create\": {\n465\t      post: {\n466\t        tags: [\"Lord of RNGs\"],\n467\t        summary: \"Create a Lord of RNGs round\",\n468\t        security: [{ bearerAuth: [] }],\n469\t        requestBody: {\n470\t          required: true,\n471\t          content: {\n472\t            \"application/json\": {\n473\t              schema: {\n474\t                type: \"object\",\n475\t                required: [\"wallet\", \"amountLamports\"],\n476\t                properties: {\n477\t                  wallet: { type: \"string\" },\n478\t                  amountLamports: {\n479\t                    type: \"integer\",\n480\t                    minimum: 1000000,\n481\t                    description: \"Wager in lamports (min 0.001 SOL)\",\n482\t                  },\n483\t                },\n484\t              },\n485\t            },\n486\t          },\n487\t        },\n488\t        responses: {\n489\t          \"200\": {\n490\t            description: \"Round created\",\n491\t            content: { \"application/json\": { schema: { $ref: \"#/components/schemas/LordCreateResponse\" } } },\n492\t          },\n493\t          \"400\": { description: \"Validation error\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n494\t          \"403\": { description: \"Wallet mismatch\", content: { \"application/json\": { schema: { $ref: \"#/components/schemas/Error\" } } } },\n495\t          \"409\": { description: \"Round already active or ID collision\" },\n496\t          \"429\": { description: \"Rate limited\" },\n497\t          \"500\": { description: \"Transaction build failed\" },\n498\t        },\n499\t      },\n500\t    },\n501\t\n502\t    // ── Close Call ─────────────────────────────────────────────────\n503\t  