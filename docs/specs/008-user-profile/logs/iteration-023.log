ly-signed transaction\" },\n178\t          minuteTs: { type: \"integer\", description: \"Unix timestamp (seconds) of the minute boundary\" },\n179\t          roundPda: { type: \"string\" },\n180\t        },\n181\t      },\n182\t      RoundResponse: {\n183\t        type: \"object\",\n184\t        properties: {\n185\t          pda: { type: \"string\" },\n186\t          game: { type: \"string\", enum: [\"coinflip\", \"lord\"] },\n187\t          phase: { type: \"string\" },\n188\t          creator: { type: \"string\" },\n189\t          commitment: { type: \"string\" },\n190\t          amountLamports: { type: \"integer\" },\n191\t          side: { type: \"integer\" },\n192\t          matchId: { type: \"string\" },\n193\t          createdAt: { type: \"string\", format: \"date-time\" },\n194\t          updatedAt: { type: \"string\", format: \"date-time\" },\n195\t          targetSlot: { type: \"integer\" },\n196\t          secret: { type: \"string\", description: \"Only present when settled\" },\n197\t          resultHash: { type: \"string\", nullable: true },\n198\t          resultSide: { type: \"integer\", description: \"Coinflip only\" },\n199\t          winningEntryIndex: { type: \"integer\", description: \"Lord only\" },\n200\t          winner: { type: \"string\" },\n201\t          settleTx: { type: \"string\" },\n202\t          entropy: { type: \"string\", nullable: true },\n203\t          payoutAmount: { type: \"integer\", nullable: true },\n204\t          feeAmount: { type: \"integer\", nullable: true },\n205\t          entries: { type: \"array\", items: { type: \"object\" } },\n206\t          verification: {\n207\t            type: \"object\",\n208\t            properties: {\n209\t              commitmentCheck: { type: \"string\" },\n210\t              resultFormula: { type: \"string\" },\n211\t              entropySource: { type: \"string\" },\n212\t            },\n213\t          },\n214\t        },\n215\t      },\n216\t      Transaction: {\n217\t        type: \"object\",\n218\t        properties: {\n219\t          id: { type: \"string\" },\n220\t          game: { type: \"string\" },\n221\t          matchId: { type: \"string\" },\n222\t          txType: { type: \"string\", enum: [\"deposit\", \"refund\"] },\n223\t          amountLamports: { type: \"string\" },\n224\t          txSig: { type: \"string\" },\n225\t          createdAt: { type: \"string\", format: \"date-time\" },\n226\t        },\n227\t      },\n228\t      ReferralStats: {\n229\t        type: \"object\",\n230\t        properties: {\n231\t          referredCount: { type: \"integer\" },\n232\t          activeCount: { type: \"integer\" },\n233\t          totalVolumeLamports: { type: \"string\" },\n234\t          totalEarnedLamports: { type: \"string\" },\n235\t          totalRebateLamports: { type: \"string\" },\n236\t          pendingLamports: { type: \"string\" },\n237\t        },\n238\t      },\n239\t      ReferralEarning: {\n240\t        type: \"object\",\n241\t        properties: {\n242\t          roundId: { type: \"string\" },\n243\t          gameType: { type: \"string\" },\n244\t          refereeWallet: { type: \"string\" },\n245\t          wagerLamports: { type: \"string\" },\n246\t          earnedLamports: { type: \"string\" },\n247\t          createdAt: { type: \"string\", format: \"date-time\" },\n248\t        },\n249\t      },\n250\t      ClaimResponse: {\n251\t        type: \"object\",\n252\t        properties: {\n253\t          claimId: { type: \"string\" },\n254\t          amountLamports: { type: \"string\" },\n255\t          status: { type: \"string\" },\n256\t          txSignature: { type: \"string\" },\n257\t        },\n258\t      },\n259\t      PriceResponse: {\n260\t        type: \"object\",\n261\t        properties: {\n262\t          price: { type: \"number\", description: \"SOL/USD price\" },\n263\t          updatedAt: { type: \"string\", format: \"date-time\" },\n264\t        },\n265\t      },\n266\t      HealthResponse: {\n267\t        type: