{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FDb2gUAsJG463erMrCL66P","type":"tool_result","content":"1\t/**\n2\t * Public profile routes — unauthenticated lookup by user_id or username.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport type { Db } from \"../db.js\";\n7\timport { logger } from \"../logger.js\";\n8\t\n9\texport interface PublicProfileRoutesDeps {\n10\t  db: Db;\n11\t}\n12\t\n13\texport function createPublicProfileRoutes(deps: PublicProfileRoutesDeps) {\n14\t  const { db } = deps;\n15\t  const app = new Hono();\n16\t\n17\t  // GET /:identifier — public profile lookup (no auth)\n18\t  app.get(\"/:identifier\", async (c) => {\n19\t    const identifier = c.req.param(\"identifier\");\n20\t\n21\t    try {\n22\t      const profile = await db.getProfileByIdentifier(identifier);\n23\t      if (!profile) {\n24\t        return c.json({ error: \"NOT_FOUND\" }, 404);\n25\t      }\n26\t\n27\t      const publicStats = await db.getPublicPlayerStats(profile.wallet);\n28\t\n29\t      return c.json({\n30\t        userId: profile.user_id,\n31\t        username: profile.username,\n32\t        avatarUrl: profile.avatar_url,\n33\t        heatMultiplier: profile.heat_multiplier,\n34\t        stats: {\n35\t          gamesPlayed: publicStats.gamesPlayed,\n36\t          totalWins: publicStats.totalWins,\n37\t          winRate: publicStats.winRate,\n38\t        },\n39\t        createdAt: profile.created_at.toISOString(),\n40\t      });\n41\t    } catch (err) {\n42\t      logger.error(\"public-profile lookup failed\", {\n43\t        identifier,\n44\t        error: err instanceof Error ? err.message : \"Unknown error\",\n45\t      });\n46\t      return c.json({ error: \"Failed to fetch profile\" }, 500);\n47\t    }\n48\t  });\n49\t\n50\t  return app;\n51\t}\n52\t"}]},"parent_tool_use_id":"toolu_01Lou6iaykHjWxYZz86gQiVx","session_id":"e44550f8-11fe-49dd-bb57-a4d026a1433a","uuid":"4ddb77d7-1fc9-4dac-a3b9-1714de1c8725","timestamp":"2026-03-31T15:20:30.793Z"}
