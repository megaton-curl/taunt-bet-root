      },\n46\t      StructuredError: {\n47\t        type: \"object\",\n48\t        properties: {\n49\t          error: {\n50\t            type: \"object\",\n51\t            properties: {\n52\t              code: { type: \"string\" },\n53\t              message: { type: \"string\" },\n54\t              retryable: { type: \"boolean\" },\n55\t            },\n56\t            required: [\"code\", \"message\"],\n57\t          },\n58\t        },\n59\t      },\n60\t      ChallengeResponse: {\n61\t        type: \"object\",\n62\t        properties: {\n63\t          nonce: { type: \"string\", description: \"64-char hex nonce\" },\n64\t          message: { type: \"string\", description: \"Human-readable sign-in message\" },\n65\t          expiresAt: { type: \"string\", format: \"date-time\" },\n66\t        },\n67\t      },\n68\t      TokenResponse: {\n69\t        type: \"object\",\n70\t        properties: {\n71\t          accessToken: { type: \"string\", description: \"HS256 JWT\" },\n72\t          accessExpiresAt: { type: \"string\", format: \"date-time\" },\n73\t          refreshToken: { type: \"string\", description: \"Opaque 96-char hex token\" },\n74\t          refreshExpiresAt: { type: \"string\", format: \"date-time\" },\n75\t        },\n76\t      },\n77\t      CoinflipCreateResponse: {\n78\t        type: \"object\",\n79\t        properties: {\n80\t          transaction: { type: \"string\", description: \"Base64-encoded partially-signed transaction\" },\n81\t          matchPda: { type: \"string\", description: \"Base58 match PDA address\" },\n82\t          matchId: { type: \"string\", description: \"16-char hex match ID\" },\n83\t          commitment: { type: \"string\", description: \"SHA256 hex commitment\" },\n84\t          lastValidBlockHeight: { type: \"integer\" },\n85\t        },\n86\t      },\n87\t      LordCreateResponse: {\n88\t        type: \"object\",\n89\t        properties: {\n90\t          transaction: { type: \"string\", description: \"Base64-encoded part