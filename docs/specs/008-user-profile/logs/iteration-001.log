{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01He4Wi2V5ztApBf6jXMtywo","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// Phase transition guard\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   105→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   106→  created: [\"locked\", \"expired\"],\n   107→  locked: [\"settling\"],\n   108→  settling: [\"settled\"],\n   109→  settled: [],\n   110→  expired: [],\n   111→};\n   112→\n   113→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   114→  const allowed = VALID_TRANSITIONS[from];\n   115→  if (!allowed.includes(to)) {\n   116→    throw new Error(\n   117→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   118→    );\n   119→  }\n   120→}\n   121→\n   122→// ---------------------------------------------------------------------------\n   123→// DB client\n   124→// ---------------------------------------------------------------------------\n   125→\n   126→export interface Db {\n   127→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   128→  insertRound(params: InsertRoundParams): Promise<Round>;\n   129→\n   130→  /** Delete a round by PDA. Returns true if a row was removed. */\n   131→  deleteRoundByPda(pda: string): Promise<boolean>;\n   132→\n   133→  /** Transition a round's phase. Enforces unidirectional state machine.\n   134→   *  Optional `updates` can set additional columns alongside the phase change. */\n   135→  updateRoundPhase(\n   136→    pda: string,\n   137→    newPhase: RoundPhase,\n   138→    updates?: Partial<\n   139→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   140→    >,\n   141→  ): Promise<Round>;\n   142→\n   143→  /** Update the entries JSONB column for a settled round. */\n   144→  updateRoundEntries(\n   145→    pda: string,\n   146→    entries: Array<{ player: string; amountLamports: number }>,\n   147→  ): Promise<Round>;\n   148→\n   149→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   150→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   151→\n   152→  /** Get all rounds matching a given phase. */\n   153→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   154→\n   155→  /** Append an operator event to the audit log. */\n   156→  insertOperatorEvent(\n   157→    pda: string | null,\n   158→    eventType: OperatorEventType,\n   159→    payload?: unknown,\n   160→  ): Promise<OperatorEvent>;\n   161→\n   162→  /** Get the latest operator event for a PDA + type. */\n   163→  getLatestOperatorEvent(\n   164→    pda: string,\n   165→    eventType: OperatorEventType,\n   166→  ): Promise<OperatorEvent | undefined>;\n   167→\n   168→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   169→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   170→\n   171→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   172→  getLatestOperatorEventsForPdas(\n   173→    pdas: string[],\n   174→    eventType: OperatorEventType,\n   175→  ): Promise<Map<string, OperatorEvent>>;\n   176→\n   177→  /** Get recently settled rounds for a game, ordered newest first. */\n   178→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   179→\n   180→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   181→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   182→\n   183→  // -------------------------------------------------------------------------\n   184→  // Close Call rounds\n   185→  // -------------------------------------------------------------------------\n   186→\n   187→  /** Insert a new Close Call round. */\n   188→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   189→\n   190→  /** Get a Close Call round by round_id (16-char hex). */\n   191→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   192→\n   193→  /** Get the current active (open) Close Call round. */\n   194→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   195→\n   196→  /** Get the most recent settled/refunded Close Call rounds. */\n   197→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   198→\n   199→  /** Update a Close Call round after settlement. */\n   200→  settleCloseCallRound(\n   201→    roundId: string,\n   202→    updates: {\n   203→      phase: CloseCallPhase;\n   204→      outcome: CloseCallOutcome;\n   205→      closePrice?: number;\n   206→      greenPool?: number;\n   207→      redPool?: number;\n   208→      totalFee?: number;\n   209→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   210→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   211→      settleTx?: string;\n   212→    },\n   213→  ): Promise<CloseCallRound>;\n   214→\n   215→  /** Gracefully close the connection pool. */\n   216→  close(): Promise<void>;\n   217→}\n   218→\n   219→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   220→  return {\n   221→    ...row,\n   222→    open_price: Number(row.open_price),\n   223→    open_price_expo: Number(row.open_price_expo),\n   224→    close_price: row.close_price === null ? null : Number(row.close_price),\n   225→    green_pool: Number(row.green_pool),\n   226→    red_pool: Number(row.red_pool),\n   227→    total_fee: Number(row.total_fee),\n   228→    // JSONB comes back as parsed objects from postgres.js\n   229→    green_entries: Array.isArray(row.green_entries)\n   230→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   231→      : [],\n   232→    red_entries: Array.isArray(row.red_entries)\n   233→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   234→      : [],\n   235→  };\n   236→}\n   237→\n   238→function normalizeRound(row: Round): Round {\n   239→  return {\n   240→    ...row,\n   241→    amount_lamports: Number(row.amount_lamports),\n   242→    side: Number(row.side),\n   243→    settle_attempts: Number(row.settle_attempts),\n   244→    result_side: row.result_side === null ? null : Number(row.result_side),\n   245→    // JSONB comes back as parsed objects from postgres.js\n   246→    entries: Array.isArray(row.entries)\n   247→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   248→          player: e.player,\n   249→          amountLamports: Number(e.amountLamports),\n   250→        }))\n   251→      : null,\n   252→  };\n   253→}\n   254→\n   255→export function createDb(databaseUrl: string): Db {\n   256→  const sql = postgres(databaseUrl);\n   257→\n   258→  return {\n   259→    async insertRound(params) {\n   260→      const rows = await sql<Round[]>`\n   261→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   262→        VALUES (\n   263→          ${params.pda},\n   264→          ${params.game},\n   265→          ${params.creator},\n   266→          ${params.serverKey},\n   267→          ${params.secret},\n   268→          ${params.commitment},\n   269→          ${params.amountLamports},\n   270→          ${params.side},\n   271→          ${params.matchId},\n   272→          ${params.phase},\n   273→          ${params.entries ? sql.json(params.entries) : null}\n   274→        )\n   275→        RETURNING *\n   276→      `;\n   277→      return normalizeRound(rows[0]!);\n   278→    },\n   279→\n   280→    async deleteRoundByPda(pda) {\n   281→      const rows = await sql<{ pda: string }[]>`\n   282→        DELETE FROM rounds WHERE pda = ${pda}\n   283→        RETURNING pda\n   284→      `;\n   285→      return rows.length > 0;\n   286→    },\n   287→\n   288→    async updateRoundPhase(pda, newPhase, updates) {\n   289→      // Fetch current phase to validate transition\n   290→      const current = await sql<Pick<Round, \"phase\">[]>`\n   291→        SELECT phase FROM rounds WHERE pda = ${pda}\n   292→      `;\n   293→\n   294→      if (current.length === 0) {\n   295→        throw new Error(`Round not found: ${pda}`);\n   296→      }\n   297→\n   298→      const currentPhase = current[0]!.phase as RoundPhase;\n   299→      assertPhaseTransition(currentPhase, newPhase);\n   300→\n   301→      // Build the update — always set phase + updated_at\n   302→      const rows = await sql<Round[]>`\n   303→        UPDATE rounds SET\n   304→          phase = ${newPhase},\n   305→          updated_at = now(),\n   306→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   307→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   308→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   309→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   310→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   311→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   312→        WHERE pda = ${pda}\n   313→        RETURNING *\n   314→      `;\n   315→\n   316→      return normalizeRound(rows[0]!);\n   317→    },\n   318→\n   319→    async updateRoundEntries(pda, entries) {\n   320→      const rows = await sql<Round[]>`\n   321→        UPDATE rounds SET\n   322→          entries = ${sql.json(entries)},\n   323→          updated_at = now()\n   324→        WHERE pda = ${pda}\n   325→        RETURNING *\n   326→      `;\n   327→      if (rows.length === 0) {\n   328→        throw new Error(`Round not found: ${pda}`);\n   329→      }\n   330→      return normalizeRound(rows[0]!);\n   331→    },\n   332→\n   333→    async getRoundByPda(pda) {\n   334→      const rows = await sql<Round[]>`\n   335→        SELECT * FROM rounds WHERE pda = ${pda}\n   336→      `;\n   337→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   338→    },\n   339→\n   340→    async getRoundByMatchId(matchId) {\n   341→      const rows = await sql<Round[]>`\n   342→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   343→      `;\n   344→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   345→    },\n   346→\n   347→    async getRoundsByPhase(phase) {\n   348→      const rows = await sql<Round[]>`\n   349→        SELECT * FROM rounds WHERE phase = ${phase}\n   350→      `;\n   351→      return rows.map(normalizeRound);\n   352→    },\n   353→\n   354→    async insertOperatorEvent(pda, eventType, payload) {\n   355→      const rows = await sql<OperatorEvent[]>`\n   356→        INSERT INTO operator_events (pda, event_type, payload)\n   357→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   358→        RETURNING *\n   359→      `;\n   360→      return rows[0]!;\n   361→    },\n   362→\n   363→    async getLatestOperatorEvent(pda, eventType) {\n   364→      const rows = await sql<OperatorEvent[]>`\n   365→        SELECT * FROM operator_events\n   366→        WHERE pda = ${pda} AND event_type = ${eventType}\n   367→        ORDER BY id DESC\n   368→        LIMIT 1\n   369→      `;\n   370→      return rows[0];\n   371→    },\n   372→\n   373→    async getLatestOperatorEventsForPdas(pdas, eventType) {\n   374→      if (pdas.length === 0) return new Map();\n   375→      const rows = await sql<OperatorEvent[]>`\n   376→        SELECT DISTINCT ON (pda) *\n   377→        FROM operator_events\n   378→        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n   379→        ORDER BY pda, id DESC\n   380→      `;\n   381→      const map = new Map<string, OperatorEvent>();\n   382→      for (const row of rows) {\n   383→        if (row.pda) map.set(row.pda, row);\n   384→      }\n   385→      return map;\n   386→    },\n   387→\n   388→    async getRecentSettledRounds(game, limit) {\n   389→      const rows = await sql<Round[]>`\n   390→        SELECT * FROM rounds\n   391→        WHERE game = ${game} AND phase = 'settled'\n   392→        ORDER BY updated_at DESC\n   393→        LIMIT ${limit}\n   394→      `;\n   395→      return rows.map(normalizeRound);\n   396→    },\n   397→\n   398→    async getUnsettledStats() {\n   399→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   400→        SELECT\n   401→          COUNT(*)::text AS count,\n   402→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   403→        FROM rounds\n   404→        WHERE phase NOT IN ('settled', 'expired')\n   405→      `;\n   406→      const row = rows[0]!;\n   407→      return {\n   408→        count: parseInt(row.count, 10),\n   409→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   410→      };\n   411→    },\n   412→\n   413→    // -----------------------------------------------------------------------\n   414→    // Close Call rounds\n   415→    // -----------------------------------------------------------------------\n   416→\n   417→    async insertCloseCallRound(params) {\n   418→      const rows = await sql<CloseCallRound[]>`\n   419→        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   420→        VALUES (\n   421→          ${params.roundId},\n   422→          ${params.pda},\n   423→          ${params.serverKey},\n   424→          ${params.openPrice},\n   425→          ${params.openPriceExpo}\n   426→        )\n   427→        RETURNING *\n   428→      `;\n   429→      return normalizeCloseCallRound(rows[0]!);\n   430→    },\n   431→\n   432→    async getCloseCallRound(roundId) {\n   433→      const rows = await sql<CloseCallRound[]>`\n   434→        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   435→      `;\n   436→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   437→    },\n   438→\n   439→    async getCloseCallCurrentRound() {\n   440→      const rows = await sql<CloseCallRound[]>`\n   441→        SELECT * FROM closecall_rounds\n   442→        WHERE phase = 'open'\n   443→        ORDER BY created_at DESC\n   444→        LIMIT 1\n   445→      `;\n   446→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   447→    },\n   448→\n   449→    async getCloseCallHistory(limit) {\n   450→      const rows = await sql<CloseCallRound[]>`\n   451→        SELECT * FROM closecall_rounds\n   452→        WHERE phase IN ('settled', 'refunded')\n   453→        ORDER BY settled_at DESC\n   454→        LIMIT ${limit}\n   455→      `;\n   456→      return rows.map(normalizeCloseCallRound);\n   457→    },\n   458→\n   459→    async settleCloseCallRound(roundId, updates) {\n   460→      const rows = await sql<CloseCallRound[]>`\n   461→        UPDATE closecall_rounds SET\n   462→          phase = ${updates.phase},\n   463→          outcome = ${updates.outcome},\n   464→          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   465→          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   466→          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   467→          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   468→          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   469→          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   470→          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   471→          settled_at = now()\n   472→        WHERE round_id = ${roundId}\n   473→        RETURNING *\n   474→      `;\n   475→      if (rows.length === 0) {\n   476→        throw new Error(`Close Call round not found: ${roundId}`);\n   477→      }\n   478→      return normalizeCloseCallRound(rows[0]!);\n   479→    },\n   480→\n   481→    async close() {\n   482→      await sql.end();\n   483→    },\n   484→  };\n   485→}\n   486→"}]},"parent_tool_use_id":"toolu_01S1wbL63U6v6kHW8Fb5sfmB","session_id":"4555428c-1a06-457a-b5b1-590225853d9d","uuid":"b3f4b1f2-f7b8-431c-a1e1-1feb23f0ee14","timestamp":"2026-03-19T18:41:02.446Z"}
