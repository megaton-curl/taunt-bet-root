{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MpWevtzyJv4E62QpBNyL78","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    23→import {\n    24→  decodeCoinflipMatch,\n    25→  decodeCoinflipConfig,\n    26→  decodeLordRound,\n    27→  decodeLordConfig,\n    28→  type DecodedJackpotRound,\n    29→} from \"./account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→function getInstructionDiscriminator(\n    36→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    37→  instructionName: string,\n    38→): Buffer {\n    39→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    40→  if (!instruction) {\n    41→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    42→  }\n    43→  return Buffer.from(instruction.discriminator);\n    44→}\n    45→\n    46→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    47→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    48→  lordIdl,\n    49→  \"claim_payout\",\n    50→);\n    51→const CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    52→const CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    53→const CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    54→\n    55→// ---------------------------------------------------------------------------\n    56→// Types\n    57→// ---------------------------------------------------------------------------\n    58→\n    59→export interface SettleTxDeps {\n    60→  db: Db;\n    61→  connection: Connection;\n    62→  serverKeypair: Keypair;\n    63→  entropyAccount: PublicKey;\n    64→}\n    65→\n    66→export interface SettleResult {\n    67→  txSignature: string;\n    68→  resultHash: Buffer;\n    69→  resultSide?: number;\n    70→  winningEntryIndex?: number;\n    71→  winner: string;\n    72→}\n    73→\n    74→// ---------------------------------------------------------------------------\n    75→// PDA helpers\n    76→// ---------------------------------------------------------------------------\n    77→\n    78→function deriveConfigPda(): [PublicKey, number] {\n    79→  return PublicKey.findProgramAddressSync(\n    80→    [Buffer.from(\"coinflip_config\")],\n    81→    COINFLIP_PROGRAM_ID,\n    82→  );\n    83→}\n    84→\n    85→function deriveLordConfigPda(): [PublicKey, number] {\n    86→  return PublicKey.findProgramAddressSync(\n    87→    [Buffer.from(\"lord_config\")],\n    88→    LORDOFRNGS_PROGRAM_ID,\n    89→  );\n    90→}\n    91→\n    92→// ---------------------------------------------------------------------------\n    93→// Instruction encoding\n    94→// ---------------------------------------------------------------------------\n    95→\n    96→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    97→function encodeSettleData(secret: Buffer): Buffer {\n    98→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    99→}\n   100→\n   101→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n   102→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n   103→}\n   104→\n   105→// ---------------------------------------------------------------------------\n   106→// Result derivation (mirrors on-chain derive_result)\n   107→// ---------------------------------------------------------------------------\n   108→\n   109→/**\n   110→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n   111→ * Must match shared/src/fairness.rs `derive_result()`.\n   112→ */\n   113→function deriveResult(\n   114→  secret: Buffer,\n   115→  entropy: Buffer,\n   116→  matchPdaBytes: Buffer,\n   117→  algoVer: number,\n   118→): Buffer {\n   119→  return createHash(\"sha256\")\n   120→    .update(secret)\n   121→    .update(entropy)\n   122→    .update(matchPdaBytes)\n   123→    .update(Buffer.from([algoVer]))\n   124→    .digest();\n   125→}\n   126→\n   127→// ---------------------------------------------------------------------------\n   128→// Core settle function\n   129→// ---------------------------------------------------------------------------\n   130→\n   131→/**\n   132→ * Build, submit, and confirm a settle transaction for a locked match.\n   133→ *\n   134→ * Steps:\n   135→ * 1. Retrieve secret from DB\n   136→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   137→ * 3. Fetch config account data (treasury)\n   138→ * 4. Read entropy from the entropy account\n   139→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   140→ * 6. Build + submit settle tx\n   141→ * 7. Update DB on confirmation\n   142→ */\n   143→export async function settleMatch(\n   144→  deps: SettleTxDeps,\n   145→  pda: string,\n   146→): Promise<SettleResult> {\n   147→  const t0 = performance.now();\n   148→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   149→  const matchPubkey = new PublicKey(pda);\n   150→\n   151→  // 1. Retrieve secret from DB\n   152→  const round = await db.getRoundByPda(pda);\n   153→  const tDb = performance.now();\n   154→  if (!round) {\n   155→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   156→  }\n   157→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   158→    throw new PermanentSettleError(\n   159→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   160→    );\n   161→  }\n   162→\n   163→  const secret = Buffer.from(round.secret);\n   164→\n   165→  // Transition to settling (locked → settling)\n   166→  if (round.phase === \"locked\") {\n   167→    await db.updateRoundPhase(pda, \"settling\");\n   168→  }\n   169→\n   170→  // Log settle_submitted\n   171→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   172→    attempt: round.settle_attempts + 1,\n   173→  });\n   174→\n   175→  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n   176→  const [configPda] = deriveConfigPda();\n   177→  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   178→    await Promise.all([\n   179→      connection.getAccountInfo(matchPubkey),\n   180→      connection.getAccountInfo(configPda),\n   181→      connection.getAccountInfo(entropyAccount),\n   182→      connection.getLatestBlockhash(),\n   183→    ]);\n   184→  const tFetch = performance.now();\n   185→\n   186→  if (!matchAccountInfo) {\n   187→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   188→  }\n   189→  if (!configAccountInfo) {\n   190→    throw new PermanentSettleError(\"Coinflip config account not found\");\n   191→  }\n   192→  if (!entropyInfo) {\n   193→    throw new TransientSettleError(\"Entropy account not available yet\");\n   194→  }\n   195→\n   196→  // IDL-driven decode — no manual byte offsets\n   197→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   198→  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n   199→\n   200→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   201→  const { treasury } = config;\n   202→\n   203→  const pool = entryAmount * 2n;\n   204→  const feeAmount = Number((pool * 300n) / 10_000n);\n   205→  const payoutAmount = Number(pool) - feeAmount;\n   206→\n   207→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   208→\n   209→  // 5. Pre-compute result\n   210→  const matchPdaBytes = matchPubkey.toBuffer();\n   211→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   212→  const resultSide = resultHash[0]! % 2;\n   213→  const winner = resultSide === creatorSide ? creator : opponent;\n   214→\n   215→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   216→  const data = encodeSettleData(secret);\n   217→\n   218→  const instruction = new TransactionInstruction({\n   219→    keys: [\n   220→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   221→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   222→      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n   223→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   224→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   225→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   226→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   227→      {\n   228→        pubkey: SystemProgram.programId,\n   229→        isSigner: false,\n   230→        isWritable: false,\n   231→      }, // system_program\n   232→    ],\n   233→    programId: COINFLIP_PROGRAM_ID,\n   234→    data,\n   235→  });\n   236→\n   237→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   238→\n   239→  const tx = new Transaction({\n   240→    feePayer: serverKeypair.publicKey,\n   241→    blockhash,\n   242→    lastValidBlockHeight,\n   243→  });\n   244→  tx.add(instruction);\n   245→  tx.sign(serverKeypair);\n   246→\n   247→  // 7. Submit and confirm\n   248→  const rawTx = tx.serialize();\n   249→  const tBuild = performance.now();\n   250→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   251→    skipPreflight: false,\n   252→  });\n   253→  const tSend = performance.now();\n   254→\n   255→  logger.info(\"settlement transaction submitted\", {\n   256→    pda,\n   257→    txSignature,\n   258→    attempt: round.settle_attempts + 1,\n   259→    dbMs: Math.round(tDb - t0),\n   260→    fetchMs: Math.round(tFetch - tDb),\n   261→    buildMs: Math.round(tBuild - tFetch),\n   262→    sendMs: Math.round(tSend - tBuild),\n   263→  });\n   264→\n   265→  const confirmation = await connection.confirmTransaction(\n   266→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   267→    \"confirmed\",\n   268→  );\n   269→  const tConfirm = performance.now();\n   270→  if (confirmation.value.err) {\n   271→    throw new TransientSettleError(\n   272→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   273→    );\n   274→  }\n   275→\n   276→  // 8. Update DB — phase settling → settled\n   277→  const coinflipEntries = [\n   278→    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n   279→    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n   280→  ];\n   281→\n   282→  await db.updateRoundPhase(pda, \"settled\", {\n   283→    settle_tx: txSignature,\n   284→    result_hash: resultHash,\n   285→    result_side: resultSide,\n   286→    winner: winner.toBase58(),\n   287→    settle_attempts: round.settle_attempts + 1,\n   288→  });\n   289→\n   290→  // Persist entries in dedicated JSONB column for direct access\n   291→  await db.updateRoundEntries(pda, coinflipEntries);\n   292→\n   293→  // Log settle_confirmed\n   294→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   295→    txSignature,\n   296→    resultSide,\n   297→    winner: winner.toBase58(),\n   298→    entropy: entropy.toString(\"hex\"),\n   299→    payoutAmount,\n   300→    feeAmount,\n   301→    entries: coinflipEntries,\n   302→  });\n   303→\n   304→  const tDone = performance.now();\n   305→  logger.info(\"settlement transaction confirmed\", {\n   306→    pda,\n   307→    txSignature,\n   308→    resultSide,\n   309→    winner: winner.toBase58(),\n   310→    timing: {\n   311→      dbMs: Math.round(tDb - t0),\n   312→      fetchMs: Math.round(tFetch - tDb),\n   313→      buildMs: Math.round(tBuild - tFetch),\n   314→      sendMs: Math.round(tSend - tBuild),\n   315→      confirmMs: Math.round(tConfirm - tSend),\n   316→      dbWriteMs: Math.round(tDone - tConfirm),\n   317→      totalMs: Math.round(tDone - t0),\n   318→    },\n   319→  });\n   320→\n   321→  return {\n   322→    txSignature,\n   323→    resultHash,\n   324→    resultSide,\n   325→    winner: winner.toBase58(),\n   326→  };\n   327→}\n   328→\n   329→export async function settleLordRound(\n   330→  deps: SettleTxDeps,\n   331→  pda: string,\n   332→): Promise<SettleResult> {\n   333→  const t0 = performance.now();\n   334→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   335→  const roundPubkey = new PublicKey(pda);\n   336→\n   337→  const round = await db.getRoundByPda(pda);\n   338→  const tDb = performance.now();\n   339→  if (!round) {\n   340→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   341→  }\n   342→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   343→    throw new PermanentSettleError(\n   344→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   345→    );\n   346→  }\n   347→\n   348→  const secret = Buffer.from(round.secret);\n   349→\n   350→  if (round.phase === \"locked\") {\n   351→    await db.updateRoundPhase(pda, \"settling\");\n   352→  }\n   353→\n   354→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   355→    attempt: round.settle_attempts + 1,\n   356→    game: \"lord\",\n   357→  });\n   358→\n   359→  const [configPda] = deriveLordConfigPda();\n   360→  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   361→    await Promise.all([\n   362→      connection.getAccountInfo(roundPubkey),\n   363→      connection.getAccountInfo(configPda),\n   364→      connection.getAccountInfo(entropyAccount),\n   365→      connection.getLatestBlockhash(),\n   366→    ]);\n   367→\n   368→  const tFetch = performance.now();\n   369→\n   370→  if (!roundAccountInfo) {\n   371→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   372→  }\n   373→  if (!configAccountInfo) {\n   374→    throw new PermanentSettleError(\"Lord config account not found\");\n   375→  }\n   376→  if (!entropyInfo) {\n   377→    throw new TransientSettleError(\"Entropy account not available yet\");\n   378→  }\n   379→\n   380→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   381→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   382→  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n   383→  const { treasury } = lordConfig;\n   384→\n   385→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   386→  const resultHash = deriveResult(\n   387→    secret,\n   388→    entropy,\n   389→    roundPubkey.toBuffer(),\n   390→    roundData.algorithmVer,\n   391→  );\n   392→  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n   393→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   394→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   395→\n   396→  const raw = resultHash.readBigUInt64LE(0);\n   397→  const winningOffset = raw % roundData.totalAmountLamports;\n   398→\n   399→  let cumulative = 0n;\n   400→  let winnerEntryIndex = -1;\n   401→  let winner = roundData.entries[0]?.player;\n   402→  for (const [index, entry] of roundData.entries.entries()) {\n   403→    cumulative += entry.amountLamports;\n   404→    if (winningOffset < cumulative) {\n   405→      winnerEntryIndex = index;\n   406→      winner = entry.player;\n   407→      break;\n   408→    }\n   409→  }\n   410→\n   411→  if (!winner || winnerEntryIndex < 0) {\n   412→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   413→  }\n   414→\n   415→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   416→  const instruction = new TransactionInstruction({\n   417→    keys: [\n   418→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   419→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   420→      { pubkey: configPda, isSigner: false, isWritable: false },\n   421→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   422→      { pubkey: treasury, isSigner: false, isWritable: true },\n   423→      { pubkey: winner, isSigner: false, isWritable: true },\n   424→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   425→    ],\n   426→    programId: LORDOFRNGS_PROGRAM_ID,\n   427→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   428→  });\n   429→\n   430→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   431→  const tx = new Transaction({\n   432→    feePayer: serverKeypair.publicKey,\n   433→    blockhash,\n   434→    lastValidBlockHeight,\n   435→  });\n   436→  tx.add(instruction);\n   437→  tx.sign(serverKeypair);\n   438→\n   439→  const tBuild = performance.now();\n   440→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   441→    skipPreflight: false,\n   442→  });\n   443→  const tSend = performance.now();\n   444→\n   445→  logger.info(\"lord settlement transaction submitted\", {\n   446→    pda,\n   447→    txSignature,\n   448→    attempt: round.settle_attempts + 1,\n   449→    winningEntryIndex: winnerEntryIndex,\n   450→    dbMs: Math.round(tDb - t0),\n   451→    fetchMs: Math.round(tFetch - tDb),\n   452→    buildMs: Math.round(tBuild - tFetch),\n   453→    sendMs: Math.round(tSend - tBuild),\n   454→  });\n   455→\n   456→  const confirmation = await connection.confirmTransaction(\n   457→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   458→    \"confirmed\",\n   459→  );\n   460→  const tConfirm = performance.now();\n   461→  if (confirmation.value.err) {\n   462→    throw new TransientSettleError(\n   463→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   464→    );\n   465→  }\n   466→\n   467→  const serializedEntries = roundData.entries.map((e) => ({\n   468→    player: e.player.toBase58(),\n   469→    amountLamports: Number(e.amountLamports),\n   470→  }));\n   471→\n   472→  await db.updateRoundPhase(pda, \"settled\", {\n   473→    settle_tx: txSignature,\n   474→    result_hash: resultHash,\n   475→    result_side: winnerEntryIndex,\n   476→    winner: winner.toBase58(),\n   477→    settle_attempts: round.settle_attempts + 1,\n   478→  });\n   479→\n   480→  // Persist entries in dedicated JSONB column for direct access\n   481→  await db.updateRoundEntries(pda, serializedEntries);\n   482→\n   483→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   484→    txSignature,\n   485→    winner: winner.toBase58(),\n   486→    winningEntryIndex: winnerEntryIndex,\n   487→    game: \"lord\",\n   488→    entropy: entropy.toString(\"hex\"),\n   489→    winningOffset: winningOffset.toString(),\n   490→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   491→    payoutAmount,\n   492→    feeAmount,\n   493→    rentRefund,\n   494→    entries: serializedEntries,\n   495→  });\n   496→\n   497→  const tDone = performance.now();\n   498→  logger.info(\"lord settlement transaction confirmed\", {\n   499→    pda,\n   500→    txSignature,\n   501→    winner: winner.toBase58(),\n   502→    winningEntryIndex: winnerEntryIndex,\n   503→    timing: {\n   504→      dbMs: Math.round(tDb - t0),\n   505→      fetchMs: Math.round(tFetch - tDb),\n   506→      buildMs: Math.round(tBuild - tFetch),\n   507→      sendMs: Math.round(tSend - tBuild),\n   508→      confirmMs: Math.round(tConfirm - tSend),\n   509→      dbWriteMs: Math.round(tDone - tConfirm),\n   510→      totalMs: Math.round(tDone - t0),\n   511→    },\n   512→  });\n   513→\n   514→  return {\n   515→    txSignature,\n   516→    resultHash,\n   517→    winningEntryIndex: winnerEntryIndex,\n   518→    winner: winner.toBase58(),\n   519→  };\n   520→}\n   521→\n   522→export async function settleRound(\n   523→  deps: SettleTxDeps,\n   524→  pda: string,\n   525→): Promise<SettleResult> {\n   526→  const round = await deps.db.getRoundByPda(pda);\n   527→  if (!round) {\n   528→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   529→  }\n   530→\n   531→  if (round.game === \"lord\") {\n   532→    return settleLordRound(deps, pda);\n   533→  }\n   534→\n   535→  return settleMatch(deps, pda);\n   536→}\n   537→\n   538→// ---------------------------------------------------------------------------\n   539→// Close Call — transaction builders\n   540→// ---------------------------------------------------------------------------\n   541→\n   542→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   543→  return PublicKey.findProgramAddressSync(\n   544→    [Buffer.from(\"closecall_config\")],\n   545→    CLOSECALL_PROGRAM_ID,\n   546→  );\n   547→}\n   548→\n   549→function minuteTsToBuffer(ts: bigint): Buffer {\n   550→  const buf = Buffer.alloc(8);\n   551→  buf.writeBigInt64LE(ts);\n   552→  return buf;\n   553→}\n   554→\n   555→function deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n   556→  return PublicKey.findProgramAddressSync(\n   557→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n   558→    CLOSECALL_PROGRAM_ID,\n   559→  );\n   560→}\n   561→\n   562→/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n   563→function encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n   564→  const buf = Buffer.alloc(16);\n   565→  discriminator.copy(buf, 0);\n   566→  buf.writeBigInt64LE(minuteTs, 8);\n   567→  return buf;\n   568→}\n   569→\n   570→/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n   571→function encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n   572→  const buf = Buffer.alloc(28);\n   573→  discriminator.copy(buf, 0);\n   574→  buf.writeBigInt64LE(minuteTs, 8);\n   575→  buf.writeBigInt64LE(price, 16);\n   576→  buf.writeInt32LE(expo, 24);\n   577→  return buf;\n   578→}\n   579→\n   580→/**\n   581→ * Encode closecall bet data:\n   582→ * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n   583→ */\n   584→function encodeCcBetData(\n   585→  discriminator: Buffer,\n   586→  minuteTs: bigint,\n   587→  side: number,\n   588→  amount: bigint,\n   589→  openPrice: bigint,\n   590→  openPriceExpo: number,\n   591→): Buffer {\n   592→  const buf = Buffer.alloc(37);\n   593→  discriminator.copy(buf, 0);\n   594→  buf.writeBigInt64LE(minuteTs, 8);\n   595→  buf.writeUInt8(side, 16);\n   596→  buf.writeBigUInt64LE(amount, 17);\n   597→  buf.writeBigInt64LE(openPrice, 25);\n   598→  buf.writeInt32LE(openPriceExpo, 33);\n   599→  return buf;\n   600→}\n   601→\n   602→export interface CloseCallTxDeps {\n   603→  connection: Connection;\n   604→  serverKeypair: Keypair;\n   605→}\n   606→\n   607→/**\n   608→ * Build a `bet` instruction (no transaction wrapping).\n   609→ *\n   610→ * Two signers: player (pays bet) + server (pays rent on first call).\n   611→ * Price + bet info passed as instruction args.\n   612→ * Uses init_if_needed — works for both round creation and joining.\n   613→ */\n   614→export function buildCloseCallBetIx(\n   615→  serverPubkey: PublicKey,\n   616→  playerPubkey: PublicKey,\n   617→  minuteTs: bigint,\n   618→  side: number,\n   619→  amountLamports: bigint,\n   620→  openPrice: bigint,\n   621→  openPriceExpo: number,\n   622→): TransactionInstruction {\n   623→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   624→  const [configPda] = deriveCloseCallConfigPda();\n   625→  const data = encodeCcBetData(\n   626→    CC_BET_DISCRIMINATOR,\n   627→    minuteTs,\n   628→    side,\n   629→    amountLamports,\n   630→    openPrice,\n   631→    openPriceExpo,\n   632→  );\n   633→\n   634→  return new TransactionInstruction({\n   635→    keys: [\n   636→      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n   637→      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n   638→      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n   639→      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n   640→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   641→    ],\n   642→    programId: CLOSECALL_PROGRAM_ID,\n   643→    data,\n   644→  });\n   645→}\n   646→\n   647→/**\n   648→ * Build a `settle_round` instruction (no transaction wrapping).\n   649→ * Price is passed as instruction args (no on-chain Pyth account).\n   650→ */\n   651→export function buildCloseCallSettleRoundIx(\n   652→  serverPubkey: PublicKey,\n   653→  minuteTs: bigint,\n   654→  closePrice: bigint,\n   655→  closePriceExpo: number,\n   656→  treasury: PublicKey,\n   657→  winnerAccounts: PublicKey[],\n   658→): TransactionInstruction {\n   659→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   660→  const [configPda] = deriveCloseCallConfigPda();\n   661→  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n   662→\n   663→  return new TransactionInstruction({\n   664→    keys: [\n   665→      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n   666→      { pubkey: roundPda, isSigner: false, isWritable: true },\n   667→      { pubkey: configPda, isSigner: false, isWritable: false },\n   668→      { pubkey: treasury, isSigner: false, isWritable: true },\n   669→      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n   670→      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   671→    ],\n   672→    programId: CLOSECALL_PROGRAM_ID,\n   673→    data,\n   674→  });\n   675→}\n   676→\n   677→/**\n   678→ * Build a partially-signed `bet` transaction for the Close Call program.\n   679→ *\n   680→ * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n   681→ * Server signs immediately; the frontend must add the player signature before submitting.\n   682→ * Works for both round creation (first bet) and joining (subsequent bets).\n   683→ */\n   684→export async function buildCloseCallBetTx(\n   685→  deps: CloseCallTxDeps,\n   686→  playerPubkey: PublicKey,\n   687→  minuteTs: bigint,\n   688→  side: number,\n   689→  amountLamports: bigint,\n   690→  openPrice: bigint,\n   691→  openPriceExpo: number,\n   692→): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   693→  const { connection, serverKeypair } = deps;\n   694→\n   695→  const instruction = buildCloseCallBetIx(\n   696→    serverKeypair.publicKey,\n   697→    playerPubkey,\n   698→    minuteTs,\n   699→    side,\n   700→    amountLamports,\n   701→    openPrice,\n   702→    openPriceExpo,\n   703→  );\n   704→\n   705→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   706→\n   707→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   708→  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n   709→  tx.add(instruction);\n   710→  tx.partialSign(serverKeypair);\n   711→\n   712→  return { tx, roundPda };\n   713→}\n   714→\n   715→/**\n   716→ * Build a signed `settle_round` transaction for the Close Call program.\n   717→ *\n   718→ * Price is passed as instruction args. Winners (or all players for refund)\n   719→ * are passed as remaining accounts for auto-payout.\n   720→ */\n   721→export async function buildCloseCallSettleRoundTx(\n   722→  deps: CloseCallTxDeps,\n   723→  minuteTs: bigint,\n   724→  closePrice: bigint,\n   725→  closePriceExpo: number,\n   726→  treasury: PublicKey,\n   727→  winnerAccounts: PublicKey[],\n   728→): Promise<Transaction> {\n   729→  const { connection, serverKeypair } = deps;\n   730→\n   731→  const instruction = buildCloseCallSettleRoundIx(\n   732→    serverKeypair.publicKey,\n   733→    minuteTs,\n   734→    closePrice,\n   735→    closePriceExpo,\n   736→    treasury,\n   737→    winnerAccounts,\n   738→  );\n   739→\n   740→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   741→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   742→  tx.add(instruction);\n   743→  tx.sign(serverKeypair);\n   744→\n   745→  return tx;\n   746→}\n   747→\n   748→/**\n   749→ * Build a signed `timeout_refund` transaction for the Close Call program.\n   750→ *\n   751→ * Permissionless after the resolve deadline. Refunds all players their exact\n   752→ * deposit via remaining accounts.\n   753→ */\n   754→export async function buildCloseCallTimeoutRefundTx(\n   755→  deps: CloseCallTxDeps,\n   756→  minuteTs: bigint,\n   757→  playerAccounts: PublicKey[],\n   758→): Promise<Transaction> {\n   759→  const { connection, serverKeypair } = deps;\n   760→\n   761→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   762→  const [configPda] = deriveCloseCallConfigPda();\n   763→  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n   764→\n   765→  const keys = [\n   766→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   767→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   768→    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n   769→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   770→    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   771→  ];\n   772→\n   773→  const instruction = new TransactionInstruction({\n   774→    keys,\n   775→    programId: CLOSECALL_PROGRAM_ID,\n   776→    data,\n   777→  });\n   778→\n   779→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   780→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   781→  tx.add(instruction);\n   782→  tx.sign(serverKeypair);\n   783→\n   784→  return tx;\n   785→}\n   786→\n   787→// ---------------------------------------------------------------------------\n   788→// Error types\n   789→// ---------------------------------------------------------------------------\n   790→\n   791→/** Permanent failure — should not be retried. */\n   792→export class PermanentSettleError extends Error {\n   793→  readonly permanent = true;\n   794→  constructor(message: string) {\n   795→    super(message);\n   796→    this.name = \"PermanentSettleError\";\n   797→  }\n   798→}\n   799→\n   800→/** Transient failure — safe to retry. */\n   801→export class TransientSettleError extends Error {\n   802→  readonly permanent = false;\n   803→  constructor(message: string) {\n   804→    super(message);\n   805→    this.name = \"TransientSettleError\";\n   806→  }\n   807→}\n   808→"}]},"parent_tool_use_id":"toolu_01PFNMRbpbgUyxXZhws5Ty3J","session_id":"ab81b221-6f6d-4c3b-b1b4-ab27917ca48e","uuid":"9ac16cc9-e10c-4f2f-95a7-24bcfe5eccb3","timestamp":"2026-03-19T18:43:55.174Z"}
