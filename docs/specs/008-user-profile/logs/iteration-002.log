med\",\n    95→    );\n    96→\n    97→    subscriptions.set(pda, subId);\n    98→    logger.debug(\"[pda-watcher] watching\", { pda: pda.slice(0, 12) });\n    99→  }\n   100→\n   101→  function handleCoinflipChange(pda: string, data: Buffer): void {\n   102→    let match;\n   103→    try {\n   104→      match = decodeCoinflipMatch(data);"}]},"parent_tool_use_id":null,"session_id":"ab81b221-6f6d-4c3b-b1b4-ab27917ca48e","uuid":"6325ffbc-c360-4772-9dc8-fd6bcd31bdce","timestamp":"2026-03-19T18:45:01.428Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/pda-watcher.ts","content":"// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createPdaWatcher(deps: PdaWatcherDeps): PdaWatcher {\n  const { connection, serverKey, onJoinDetected } = deps;\n\n  /** Map from PDA base58 → WebSocket subscription ID. */\n  const subscriptions = new Map<string, number>();\n\n  function watch(pda: string): void {\n    if (subscriptions.has(pda)) return; // already watching\n\n    const pubkey = new PublicKey(pda);\n\n    const subId = connection.onAccountChange(\n      pubkey,\n      async (accountInfo) => {\n        try {\n          // Account closed (settled or cancelled) — just unwatch\n          if (accountInfo.lamports === 0) {\n            logger.debug(\"[pda-watcher] account closed, unwatching\", {\n              pda: pda.slice(0, 12),\n            });\n            unwatch(pda);\n            return;\n          }\n\n          const data = Buffer.from(accountInfo.data);\n\n          // Determine game type by account size\n          if (data.length === COINFLIP_MATCH_SIZE) {\n            handleCoinflipChange(pda, data);\n          } else {\n            // Try lord decode — variable-size accounts\n            handleLordChange(pda, data);\n          }\n        } catch (err) {\n   