{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Leo7h2cF299irjhYv772TH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01M6uTgbt1MkaJzj2SogKoK8","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/pda-watcher.ts","old_string":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  coinflipMatchSize,\n  decodeCoinflipMatch,\n  decodeLordRound,\n} from \"./account-decoder.js\";","new_string":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport type { Db } from \"../db.js\";\nimport {\n  coinflipMatchSize,\n  decodeCoinflipMatch,\n  decodeLordRound,\n} from \"./account-decoder.js\";"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":840,"cache_read_input_tokens":45775,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":840},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ab81b221-6f6d-4c3b-b1b4-ab27917ca48e","uuid":"dadef909-1e72-4f0e-9c01-ba36b5fe770e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M6uTgbt1MkaJzj2SogKoK8","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/pda-watcher.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"ab81b221-6f6d-4c3b-b1b4-ab27917ca48e","uuid":"b48a6cae-b303-4c6b-aded-573fd5f012ea","timestamp":"2026-03-19T18:45:23.494Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/pda-watcher.ts","oldString":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  coinflipMatchSize,\n  decodeCoinflipMatch,\n  decodeLordRound,\n} from \"./account-decoder.js\";","newString":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport type { Db } from \"../db.js\";\nimport {\n  coinflipMatchSize,\n  decodeCoinflipMatch,\n  decodeLordRound,\n} from \"./account-decoder.js\";","originalFile":"/**\n * PDA watcher — subscribes to match/round PDAs via WebSocket to detect\n * phase changes (join, countdown start) instantly instead of waiting for\n * the next getProgramAccounts poll cycle.\n *\n * This dramatically reduces settlement latency: from ~13s (stale poll) to\n * ~1-3s (WebSocket delivery + settlement).\n *\n * The poll-based settlement worker remains as a fallback for server\n * restarts, missed subscriptions, and edge cases.\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  coinflipMatchSize,\n  decodeCoinflipMatch,\n  decodeLordRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface PdaWatcherDeps {\n  connection: Connection;\n  serverKey: PublicKey;\n  onJoinDetected: (pda: string, targetSlot: bigint) => Promise<void>;\n}\n\nexport interface PdaWatcher {\n  /** Register a PDA for watching. Called after match/round creation. */\n  watch(pda: string): void;\n  /** Stop watching a PDA. Called after settlement or cleanup. */\n  unwatch(pda: string): void;\n  /** Stop all subscriptions. */\n  stopAll(): void;\n  /** Number of active subscriptions (for health/debugging). */\n  readonly size: number;\n}\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst COINFLIP_MATCH_SIZE = coinflipMatchSize();\nconst PHASE_LOCKED = 1;\nconst LORD_PHASE_ACTIVE = 1;\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createPdaWatcher(deps: PdaWatcherDeps): PdaWatcher {\n  const { connection, serverKey, onJoinDetected } = deps;\n\n  /** Map from PDA base58 → WebSocket subscription ID. */\n  const subscriptions = new Map<string, number>();\n\n  function watch(pda: string): void {\n    if (subscriptions.has(pda)) return; // already watching\n\n    const pubkey = new PublicKey(pda);\n\n    const subId = connection.onAccountChange(\n      pubkey,\n      async (accountInfo) => {\n        try {\n          // Account closed (settled or cancelled) — just unwatch\n          if (accountInfo.lamports === 0) {\n            logger.debug(\"[pda-watcher] account closed, unwatching\", {\n              pda: pda.slice(0, 12),\n            });\n            unwatch(pda);\n            return;\n          }\n\n          const data = Buffer.from(accountInfo.data);\n\n          // Determine game type by account size\n          if (data.length === COINFLIP_MATCH_SIZE) {\n            handleCoinflipChange(pda, data);\n          } else {\n            // Try lord decode — variable-size accounts\n            handleLordChange(pda, data);\n          }\n        } catch (err) {\n          logger.warn(\"[pda-watcher] callback error\", {\n            pda: pda.slice(0, 12),\n            error: err instanceof Error ? err.message : String(err),\n          });\n        }\n      },\n      \"confirmed\",\n    );\n\n    subscriptions.set(pda, subId);\n    logger.debug(\"[pda-watcher] watching\", { pda: pda.slice(0, 12) });\n  }\n\n  function handleCoinflipChange(pda: string, data: Buffer): void {\n    let match;\n    try {\n      match = decodeCoinflipMatch(data);\n    } catch {\n      return; // undecodeable — ignore, poll worker will log it\n    }\n\n    // Only care about our server's matches that are now locked\n    if (match.phase !== PHASE_LOCKED || !match.server.equals(serverKey)) return;\n    if (match.targetSlot <= 0n) return;\n\n    logger.info(\"[pda-watcher] coinflip phase changed to locked\", {\n      pda: pda.slice(0, 12),\n      targetSlot: match.targetSlot.toString(),\n    });\n\n    onJoinDetected(pda, match.targetSlot).catch((err) => {\n      logger.error(\"[pda-watcher] onJoinDetected error\", {\n        pda: pda.slice(0, 12),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    });\n  }\n\n  function handleLordChange(pda: string, data: Buffer): void {\n    let round;\n    try {\n      round = decodeLordRound(data);\n    } catch {\n      return; // undecodeable — ignore\n    }\n\n    // Only care about our server's rounds that are active with a target slot\n    if (round.phase !== LORD_PHASE_ACTIVE || !round.server.equals(serverKey)) return;\n    if (round.targetEntropySlot <= 0n) return;\n\n    logger.info(\"[pda-watcher] lord round countdown started\", {\n      pda: pda.slice(0, 12),\n      targetEntropySlot: round.targetEntropySlot.toString(),\n    });\n\n    onJoinDetected(pda, round.targetEntropySlot).catch((err) => {\n      logger.error(\"[pda-watcher] onJoinDetected error\", {\n        pda: pda.slice(0, 12),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    });\n  }\n\n  function unwatch(pda: string): void {\n    const subId = subscriptions.get(pda);\n    if (subId === undefined) return;\n\n    connection.removeAccountChangeListener(subId).catch((err) => {\n      logger.warn(\"[pda-watcher] removeAccountChangeListener error\", {\n        pda: pda.slice(0, 12),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    });\n\n    subscriptions.delete(pda);\n    logger.debug(\"[pda-watcher] unwatching\", { pda: pda.slice(0, 12) });\n  }\n\n  function stopAll(): void {\n    for (const pda of subscriptions.keys()) {\n      unwatch(pda);\n    }\n    logger.info(\"[pda-watcher] stopped all subscriptions\");\n  }\n\n  return {\n    watch,\n    unwatch,\n    stopAll,\n    get size() {\n      return subscriptions.size;\n    },\n  };\n}\n","structuredPatch":[{"oldStart":12,"oldLines":6,"newStart":12,"newLines":7,"lines":[" "," import { Connection, PublicKey } from \"@solana/web3.js\";"," import { logger } from \"../logger.js\";","+import type { Db } from \"../db.js\";"," import {","   coinflipMatchSize,","   decodeCoinflipMatch,"]}],"userModified":false,"replaceAll":false}}
