{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HJuMnaXVH7A4U3s3TRf5UN","type":"tool_result","content":"     1→/**\n     2→ * PDA watcher — subscribes to match/round PDAs via WebSocket to detect\n     3→ * phase changes (join, countdown start) instantly instead of waiting for\n     4→ * the next getProgramAccounts poll cycle.\n     5→ *\n     6→ * This dramatically reduces settlement latency: from ~13s (stale poll) to\n     7→ * ~1-3s (WebSocket delivery + settlement).\n     8→ *\n     9→ * The poll-based settlement worker remains as a fallback for server\n    10→ * restarts, missed subscriptions, and edge cases.\n    11→ */\n    12→\n    13→import { Connection, PublicKey } from \"@solana/web3.js\";\n    14→import { logger } from \"../logger.js\";\n    15→import {\n    16→  coinflipMatchSize,\n    17→  decodeCoinflipMatch,\n    18→  decodeLordRound,\n    19→} from \"./account-decoder.js\";\n    20→\n    21→// ---------------------------------------------------------------------------\n    22→// Types\n    23→// ---------------------------------------------------------------------------\n    24→\n    25→export interface PdaWatcherDeps {\n    26→  connection: Connection;\n    27→  serverKey: PublicKey;\n    28→  onJoinDetected: (pda: string, targetSlot: bigint) => Promise<void>;\n    29→}\n    30→\n    31→export interface PdaWatcher {\n    32→  /** Register a PDA for watching. Called after match/round creation. */\n    33→  watch(pda: string): void;\n    34→  /** Stop watching a PDA. Called after settlement or cleanup. */\n    35→  unwatch(pda: string): void;\n    36→  /** Stop all subscriptions. */\n    37→  stopAll(): void;\n    38→  /** Number of active subscriptions (for health/debugging). */\n    39→  readonly size: number;\n    40→}\n    41→\n    42→// ---------------------------------------------------------------------------\n    43→// Constants\n    44→// ---------------------------------------------------------------------------\n    45→\n    46→const COINFLIP_MATCH_SIZE = coinflipMatchSize();\n    47→const PHASE_LOCKED = 1;\n    48→const LORD_PHASE_ACTIVE = 1;\n    49→\n    50→// ---------------------------------------------------------------------------"}]},"parent_tool_use_id":null,"session_id":"ab81b221-6f6d-4c3b-b1b4-ab27917ca48e","uuid":"80358625-0098-4f3e-aec8-c6dfdcb1cba1","timestamp":"2026-03-19T18:44:22.758Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/pda-watcher.ts","content":"/**\n * PDA watcher — subscribes to match/round PDAs via WebSocket to detect\n * phase changes (join, countdown start) instantly instead of waiting for\n * the next getProgramAccounts poll cycle.\n *\n * This dramatically reduces settlement latency: from ~13s (stale poll) to\n * ~1-3s (WebSocket delivery + settlement).\n *\n * The poll-based settlement worker remains as a fallback for server\n * restarts, missed subscriptions, and edge cases.\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  coinflipMatchSize,\n  decodeCoinflipMatch,\n  decodeLordRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface PdaWatcherDeps {\n  connection: Connection;\n  serverKey: PublicKey;\n  onJoinDetected: (pda: string, targetSlot: bigint) => Promise<void>;\n}\n\nexport interface PdaWatcher {\n  /** Register a PDA for watching. Called after match/round creation. */\n  watch(pda: string): void;\n  /** Stop watching a PDA. Called after settlement or cleanup. */\n  unwatch(pda: string): void;\n  /** Stop all subscriptions. */\n  stopAll(): void;\n  /** Number of active subscriptions (for health/debugging). */\n  readonly size: number;\n}\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst COINFLIP_MATCH_SIZE = coinflipMatchSize();\nconst PHASE_LOCKED = 1;\nconst LORD_PHASE_ACTIVE = 1;\n\n// ---------------------------------------------------------------------------","numLines":50,"startLine":1,"totalLines":182}}}
