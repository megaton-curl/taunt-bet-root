ter a PDA for watching. Called after match/round creation. */\n  watch(pda: string): void;\n  /** Stop watching a PDA. Called after settlement or cleanup. */\n  unwatch(pda: string): void;\n  /** Stop all subscriptions. */\n  stopAll(): void;\n  /** Number of active subscriptions (for health/debugging). */\n  readonly size: number;\n}\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst COINFLIP_MATCH_SIZE = coinflipMatchSize();\nconst PHASE_LOCKED = 1;\nconst LORD_PHASE_ACTIVE = 1;\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createPdaWatcher(deps: PdaWatcherDeps): PdaWatcher {\n  const { connection, serverKey, onJoinDetected } = deps;\n\n  /** Map from PDA base58 → WebSocket subscription ID. */\n  const subscriptions = new Map<string, number>();\n\n  function watch(pda: string): void {\n    if (subscriptions.has(pda)) return; // already watching\n\n    const pubkey = new PublicKey(pda);\n\n    const subId = connection.onAccountChange(\n      pubkey,\n      async (accountInfo) => {\n        try {\n          // Account closed (settled or cancelled) — just unwatch\n          if (accountInfo.lamports === 0) {\n            logger.debug(\"[pda-watcher] account closed, unwatching\", {\n              pda: pda.slice(0, 12),\n            });\n            unwatch(pda);\n            return;\n          }\n\n          const data = Buffer.from(accountInfo.data);\n\n          // Determine game type by account size\n          if (data.length === COINFLIP_MATCH_SIZE) {\n            handleCoinflipChange(pda, data);\n          } else {\n            // Try lord decode — variable-size accounts\n            handleLordChange(pda, data);\n          }\n        } catch (err) {\n          logger.warn(\"[pda-watcher] callback error\", {\n            pda: pda.slice(0, 12),\n            error: err instanceof Error ? err.message : String(err),\n          });\n        }\n      },\n      \"confirmed\",\n    );\n\n    subscriptions.set(pda, subId);\n    logger.debug(\"[pda-watcher] watching\", { pda: pda.slice(0, 12) });\n  }\n\n  function handleCoinflipChange(pda: string, data: Buffer): void {\n    let match;\n    try {\n      match = decodeCoinflipMatch(data);\n    } catch {\n      return; // undecodeable — ignore, poll worker will log it\n    }\n\n    // Only care about our server's matches that are now locked\n    if (match.phase !== PHASE_LOCKED || !match.server.equals(serverKey)) return;\n    if (match.targetSlot <= 0n) return;\n\n    logger.info(\"[pda-watcher] coinflip phase changed to locked\", {\n      pda: pda.slice(0, 12),\n      targetSlot: match.targetSlot.toString(),\n    });\n\n    onJoinDetected(pda, match.targetSlot).catch((err) => {\n      logger.error(\"[pda-watcher] onJoinDetected error\", {\n        pda: pda.slice(0, 12),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    });\n  }\n\n  function handleLordChange(pda: string, data: Buffer): void {\n    let round;\n    try {\n      round = decodeLordRound(data);\n    } catch {\n      return; // undecodeable — ignore\n    }\n\n    // Only care about our server's rounds that are active with a target slot\n    if (round.phase !== LORD_PHASE_ACTIVE || !round.server.equals(serverKey)) return;\n    if (round.targetEntropySlot <= 0n) return;\n\n    logger.info(\"[pda-watcher] lord round countdown started\", {\n      pda: pda.slice(0, 12),\n      targetEntropySlot: round.targetEntropySlot.toString(),\n    });\n\n    onJoinDetected(pda, round.targetEntropySlot).catch((err) => {\n      logger.error(\"[pda-watcher] onJoinDetected error\", {\n        pda: pda.slice(0, 12),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    });\n  }\n\n  function unwatch(pda: string): void {\n    const subId = subscriptions.get(pda);\n    if (subId === undefined) return;\n\n    connection.removeAccountChangeListener(subId).catch((err) => {\n      logger.warn(\"[pda-watcher] removeAccountChangeListener error\", {\n        pda: pda.slice(0, 12),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    });\n\n    subscriptions.delete(pda);\n    logger.debug(\"[pda-watcher] unwatching\", { pda: pda.slice(0, 12) });\n  }\n\n  function stopAll(): void {\n    for (const pda of subscriptions.keys()) {\n      unwatch(pda);\n    }\n    logger.info(\"[pda-watcher] stopped all subscriptions\");\n  }\n\n  return {\n    watch,\n    unwatch,\n    stopAll,\n    get size() {\n      return subscriptions.size;\n    },\n  };\n}\n","structuredPatch":[{"oldStart":26,"oldLines":6,"newStart":26,"newLines":7,"lines":[" export interface PdaWatcherDeps {","   connection: Connection;","   serverKey: PublicKey;","+  db: Db;","   onJoinDetected: (pda: string, targetSlot: bigint) => Promise<void>;"," }"," "]}],"userModified":false,"replaceAll":false}}
