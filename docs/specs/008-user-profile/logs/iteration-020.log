{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y67cTuYvjzc1YSHJZ6FGZs","type":"tool_result","content":"186\texport interface PlayerProfile {\n187\t  id: number;\n188\t  user_id: string;\n189\t  wallet: string;\n190\t  username: string;\n191\t  username_updated_at: Date | null;\n192\t  avatar_url: string | null;\n193\t  heat_multiplier: number;\n194\t  points_balance: number;\n195\t  created_at: Date;\n196\t}\n197\t\n198\texport interface PlayerStats {\n199\t  gamesPlayed: number;\n200\t  totalWagered: bigint;\n201\t  totalWins: number;\n202\t  winRate: number;\n203\t  netPnl: bigint;\n204\t}\n205\t\n206\texport interface PublicPlayerStats {\n207\t  gamesPlayed: number;\n208\t  totalWins: number;\n209\t  winRate: number;\n210\t}\n211\t\n212\texport interface WinStreaks {\n213\t  current: number;\n214\t  best: number;\n215\t}\n216\t\n217\texport interface GameBreakdownStats {\n218\t  gamesPlayed: number;\n219\t  totalWagered: bigint;\n220\t  totalWins: number;\n221\t  winRate: number;\n222\t  netPnl: bigint;\n223\t}\n224\t\n225\t// ---------------------------------------------------------------------------\n226\t// Phase transition guard\n227\t// ---------------------------------------------------------------------------\n228\t\n229\t/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n230\tconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n231\t  created: [\"locked\", \"expired\"],\n232\t  locked: [\"settling\"],\n233\t  settling: [\"settled\"],\n234\t  settled: [],\n235\t  expired: [],\n236\t};\n237\t\n238\tfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n239\t  const allowed = VALID_TRANSITIONS[from];\n240\t  if (!allowed.includes(to)) {\n241\t    throw new Error(\n242\t      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n243\t    );\n244\t  }\n245\t}\n246\t\n247\t// ---------------------------------------------------------------------------\n248\t// DB client\n249\t// ---------------------------------------------------------------------------\n250\t\n251\texport interface Db {\n252\t  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n253\t  insertRound(params: InsertRoundParams): Promise<Round>;\n254\t\n255\t  /** Delete a round by PDA. Returns true if a row was removed. */\n256\t  deleteRoundByPda(pda: string): Promise<boolean>;\n257\t\n258\t  /** Transition a round's phase. Enforces unidirectional state machine.\n259\t   *  Optional `updates` can set additional columns alongside the phase change. */\n260\t  updateRoundPhase(\n261\t    pda: string,\n262\t    newPhase: RoundPhase,\n263\t    updates?: Partial<\n264\t      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n265\t    >,\n266\t  ): Promise<Round>;\n267\t\n268\t  /** Update the entries JSONB column for a settled round. */\n269\t  updateRoundEntries(\n270\t    pda: string,\n271\t    entries: Array<{ player: string; amountLamports: number }>,\n272\t  ): Promise<Round>;\n273\t\n274\t  /** Get a single round by its PDA. Returns `undefined` if not found. */\n275\t  getRoundByPda(pda: string): Promise<Round | undefined>;\n276\t\n277\t  /** Get all rounds matching a given phase. */\n278\t  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n279\t\n280\t  /** Append an operator event to the audit log. */\n281\t  insertOperatorEvent(\n282\t    pda: string | null,\n283\t    eventType: OperatorEventType,\n284\t    payload?: unknown,\n285\t  ): Promise<OperatorEvent>;\n286\t\n287\t  /** Get the latest operator event for a PDA + type. */\n288\t  getLatestOperatorEvent(\n289\t    pda: string,\n290\t    eventType: OperatorEventType,\n291\t  ): Promise<OperatorEvent | undefined>;\n292\t\n293\t  /** Get a single round by its match_id. Returns `undefined` if not found. */\n294\t  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n295\t\n296\t  /** Batch-fetch the latest operator event per PDA for a given event type. */\n297\t  getLatestOperatorEventsForPdas(\n298\t    pdas: string[],\n299\t    eventType: OperatorEventType,\n300\t  ): Promise<Map<string, OperatorEvent>>;\n301\t\n302\t  /** Get recently settled rounds for a game, ordered newest first. */\n303\t  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n304\t\n305\t  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n306\t  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n307\t\n308\t  // -------------------------------------------------------------------------\n309\t  // Close Call rounds\n310\t  // -------------------------------------------------------------------------\n311\t\n312\t  /** Insert a new Close Call round. */\n313\t  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n314\t\n315\t  /** Get a Close Call round by round_id (16-char hex). */\n316\t  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n317\t\n318\t  /** Get the current active (open) Close Call round. */\n319\t  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n320\t\n321\t  /** Get the most recent settled/refunded Close Call rounds. */\n322\t  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n323\t\n324\t  /** Update a Close Call round after settlement. */\n325\t  settleCloseCallRound(\n326\t    roundId: string,\n327\t    updates: {\n328\t      phase: CloseCallPhase;\n329\t      outcome: CloseCallOutcome;\n330\t      closePrice?: number;\n331\t      greenPool?: number;\n332\t      redPool?: number;\n333\t      totalFee?: number;\n334\t      greenEntries?: Array<{ player: string; amountLamports: number }>;\n335\t      redEntries?: Array<{ player: string; amountLamports: number }>;\n336\t      settleTx?: string;\n337\t    },\n338\t  ): Promise<CloseCallRound>;\n339\t\n340\t  // -------------------------------------------------------------------------\n341\t  // Transactions\n342\t  // -------------------------------------------------------------------------\n343\t\n344\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n345\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n346\t\n347\t  /** Insert multiple transactions in a single batch. */\n348\t  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n349\t\n350\t  /** Get paginated transactions for a wallet, newest first. */\n351\t  getTransactions(\n352\t    wallet: string,\n353\t    cursor?: string,\n354\t    limit?: number,\n355\t    game?: string,\n356\t  ): Promise<Transaction[]>;\n357\t\n358\t  // -------------------------------------------------------------------------\n359\t  // Referral — codes\n360\t  // -------------------------------------------------------------------------\n361\t\n362\t  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n363\t  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n364\t\n365\t  /** Get a wallet's referral code. Returns `undefined` if none set. */\n366\t  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n367\t\n368\t  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n369\t  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n370\t\n371\t  // -------------------------------------------------------------------------\n372\t  // Referral — links\n373\t  // -------------------------------------------------------------------------\n374\t\n375\t  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n376\t  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n377\t\n378\t  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n379\t  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n380\t\n381\t  /** Get all referral links where the given wallet is the referrer. */\n382\t  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n383\t\n384\t  // -------------------------------------------------------------------------\n385\t  // Referral — earnings & stats\n386\t  // -------------------------------------------------------------------------\n387\t\n388\t  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n389\t  insertReferralEarning(params: {\n390\t    referrerWallet: string;\n391\t    refereeWallet: string;\n392\t    roundId: string;\n393\t    gameType: string;\n394\t    wagerLamports: number;\n395\t    feeLamports: number;\n396\t    referrerEarnedLamports: number;\n397\t    referrerRateBps: number;\n398\t    refereeRebateLamports: number;\n399\t    refereeRebateRateBps: number;\n400\t  }): Promise<ReferralEarning>;\n401\t\n402\t  /**\n403\t   * Get the pending (unclaimed) balance for a wallet.\n404\t   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n405\t   * wallet=referee, minus sum of completed claims for the wallet.\n406\t   * Returns a lamport string.\n407\t   */\n408\t  getPendingBalance(wallet: string): Promise<string>;\n409\t\n410\t  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n411\t  getReferralEarnings(\n412\t    wallet: string,\n413\t    page: number,\n414\t    limit: number,\n415\t  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n416\t\n417\t  /** Get referral summary stats for a wallet. */\n418\t  getReferralStats(wallet: string): Promise<ReferralStats>;\n419\t\n420\t  // -------------------------------------------------------------------------\n421\t  // Referral — claims & rates\n422\t  // -------------------------------------------------------------------------\n423\t\n424\t  /** Insert a new referral claim row (status defaults to 'pending'