 green_pool: Number(row.green_pool),\n521\t    red_pool: Number(row.red_pool),\n522\t    total_fee: Number(row.total_fee),\n523\t    // JSONB comes back as parsed objects from postgres.js\n524\t    green_entries: Array.isArray(row.green_entries)"}]},"parent_tool_use_id":"toolu_01GeJimhuQgTGsiYns1Mb4UZ","session_id":"b10d11a6-64a8-4246-9053-4c7d6bdc5315","uuid":"2c68a933-5d9d-4cbb-8201-71b6e729a885","timestamp":"2026-03-31T15:12:26.199Z"}
