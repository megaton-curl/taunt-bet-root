alWins,\n          winRate: gs.winRate,\n          netPnl: String(gs.netPnl),\n        };\n      }\n\n      return c.json({\n        userId: profile.user_id,\n        username: profile.username,\n        avatarUrl: profile.avatar_url,\n        heatMultiplier: profile.heat_multiplier,\n        pointsBalance: String(profile.points_balance),\n        stats: {\n          gamesPlayed: stats.gamesPlayed,\n          totalWagered: String(stats.totalWagered),\n          totalWins: stats.totalWins,\n          winRate: stats.winRate,\n          winStreakCurrent: streaks.current,\n          winStreakBest: streaks.best,\n          netPnl: String(stats.netPnl),\n          gameBreakdown: serializedBreakdown,\n        },\n        usernameNextEditAt,\n        createdAt: profile.created_at.toISOString(),\n      });\n    } catch (err) {\n      logger.error(\"profile/me failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch profile\" }, 500);\n    }\n  });\n\n  app.get(\"/transactions\", async (c) => {","originalFile":"/**\n * Profile routes — transaction history for the authenticated player.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ProfileRoutesDeps {\n  db: Db;\n}\n\n/** Map DB game names to frontend game IDs */\nconst GAME_TO_FRONTEND: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord-of-rngs\",\n  closecall: \"close-call\",\n};\n\n/** Map frontend/DB game names to canonical DB names */\nconst TO_DB_GAME: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord\",\n  closecall: \"closecall\",\n  \"lord-of-rngs\": \"lord\",\n  \"close-call\": \"closecall\",\n};\n\nexport function createProfileRoutes(deps: ProfileRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  app.get(\"/transactions\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    // Parse query params\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limitParam = c.req.query(\"limit\");\n    const gameParam = c.req.query(\"game\") || undefined;\n\n    // Validate & clamp limit\n    let limit = 20;\n    if (limitParam) {\n      const parsed = parseInt(limitParam, 10);\n      if (!isNaN(parsed) && parsed > 0) {\n        limit = Math.min(parsed, 50);\n      }\n    }\n\n    // Map game filter to DB name (accept both DB and frontend names)\n    let dbGame: string | undefined;\n    if (gameParam) {\n      dbGame = TO_DB_GAME[gameParam];\n      if (!dbGame) {\n        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n      }\n    }\n\n    try {\n      const rows = await db.getTransactions(wallet, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n        matchId: row.match_id,\n        txType: row.tx_type,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return c.json({ transactions, nextCursor });\n    } catch (err) {\n      logger.error(\"profile transactions query failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    }\n  });\n\n  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n  app.post(\"/confirm-tx\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const body = await c.req.json<{\n      game?: string;\n      matchId?: string;\n      txType?: string;\n      txSig?: string;\n      amountLamports?: number;\n    }>();\n\n    if (!body.game || !body.matchId || !body.txType || !body.txSig || !body.amountLamports) {\n      return c.json({ error: \"Missing required fields: game, matchId, txType, txSig, amountLamports\" }, 400);\n    }\n\n    const validTypes = [\"deposit\", \"refund\"];\n    if (!validTypes.includes(body.txType)) {\n      return c.json({ error: `Invalid txType: ${body.txType}. Must be one of: ${validTypes.join(\", \")}` }, 400);\n    }\n\n    // Map to DB game name\n    const dbGame = TO_DB_GAME[body.game];\n    if (!dbGame) {\n      return c.json({ error: `Invalid game: ${body.game}` }, 400);\n    }\n\n    try {\n      await db.insertTransaction({\n        wallet,\n        game: dbGame,\n        matchId: body.matchId,\n        txType: body.txType as \"deposit\" | \"refund\",\n        amountLamports: body.amountLamports,\n        txSig: body.txSig,\n      });\n      return c.json({ ok: true });\n    } catch (err) {\n      logger.error(\"confirm-tx failed\", {\n        wallet,\n        txType: body.txType,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to record transaction\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":31,"oldLines":6,"newStart":31,"newLines":70,"lines":["   const { db } = deps;","   const app = new Hono<AppEnv>();"," ","+  // GET /me — full profile + stats for authenticated player","+  app.get(\"/me\", async (c) => {","+    const wallet = c.get(\"wallet\");","+    if (!wallet) {","+      return c.json({ error: \"Authentication required\" }, 401);","+    }","+","+    try {","+      const profile = await db.getProfileByWallet(wallet);","+      if (!profile) {","+        return c.json({ error: \"PROFILE_NOT_FOUND\" }, 404);","+      }","+","+      const [stats, streaks, breakdown] = await Promise.all([","+        db.getPlayerStats(wallet),","+        db.getWinStreaks(wallet),","+        db.getGameBreakdown(wallet),","+      ]);","+","+      // Serialize BigInt fields as strings, compute next edit timestamp","+      const usernameNextEditAt = profile.username_updated_at","+        ? new Date(profile.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()","+        : null;","+","+      // Map breakdown BigInt values to strings","+      const serializedBreakdown: Record<string, object> = {};","+      for (const [game, gs] of Object.entries(breakdown)) {","+        serializedBreakdown[game] = {","+          gamesPlayed: gs.gamesPlayed,","+          totalWagered: String(gs.totalWagered),","+          totalWins: gs.totalWins,","+          winRate: gs.winRate,","+          netPnl: String(gs.netPnl),","+        };","+      }","+","+      return c.json({","+        userId: profile.user_id,","+        username: profile.username,","+        avatarUrl: profile.avatar_url,","+        heatMultiplier: profile.heat_multiplier,","+        pointsBalance: String(profile.points_balance),","+        stats: {","+          gamesPlayed: stats.gamesPlayed,","+          totalWagered: String(stats.totalWagered),","+          totalWins: stats.totalWins,","+          winRate: stats.winRate,","+          winStreakCurrent: streaks.current,","+          winStreakBest: streaks.best,","+          netPnl: String(stats.netPnl),","+          gameBreakdown: serializedBreakdown,","+        },","+        usernameNextEditAt,","+        createdAt: profile.created_at.toISOString(),","+      });","+    } catch (err) {","+      logger.error(\"profile/me failed\", {","+        wallet,","+        error: err instanceof Error ? err.message : \"Unknown error\",","+      });","+      return c.json({ error: \"Failed to fetch profile\" }, 500);","+    }","+  });","+","   app.get(\"/transactions\", async (c) => {","     const wallet = c.get(\"wallet\");","     if (!wallet) {"]}],"userModified":false,"replaceAll":false}}
