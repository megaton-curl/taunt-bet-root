{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MBor6jZBayDYq5rFL8QGYH","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPriceRoutes } from \"./routes/price.js\";\n16\timport { createAuthRoutes } from \"./routes/auth.js\";\n17\timport { createReferralRoutes } from \"./routes/referral.js\";\n18\timport { swaggerUI } from \"@hono/swagger-ui\";\n19\timport { spec } from \"./openapi.js\";\n20\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n21\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n22\timport { createSettlementWorker } from \"./worker/settlement.js\";\n23\timport { settleRound } from \"./worker/settle-tx.js\";\n24\timport { createRetrySettler } from \"./worker/retry.js\";\n25\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n26\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n27\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n28\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n29\timport { logger } from \"./logger.js\";\n30\t\n31\tconst config = loadConfig();\n32\t\n33\t// Single postgres pool shared by game DB, auth DB, and all workers\n34\tconst sql = postgres(config.databaseUrl);\n35\tconst db = createDb(config.databaseUrl, sql);\n36\tconst authDb = createAuthDb(sql);\n37\t\n38\tconst connection = new Connection(config.rpcUrl, {\n39\t  commitment: \"confirmed\",\n40\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n41\t});\n42\t\n43\tconst app = new Hono();\n44\t\n45\tapp.use(\n46\t  \"*\",\n47\t  cors({\n48\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n49\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n50\t    allowHeaders: [\"Content-Type\", \"Authorization\"],\n51\t  }),\n52\t);\n53\t\n54\t// Request logging — correlate frontend fetch timing with server-side processing\n55\tapp.use(\"*\", async (c, next) => {\n56\t  const start = Date.now();\n57\t  await next();\n58\t  const ms = Date.now() - start;\n59\t  const method = c.req.method;\n60\t  const path = c.req.path;\n61\t  // Skip noisy health checks and OPTIONS preflight\n62\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n63\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n64\t});\n65\t\n66\t// API docs — Swagger UI + raw OpenAPI spec\n67\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n68\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n69\t\n70\t// Auth routes — no JWT middleware (these are the login endpoints)\n71\t// Lighter rate limiting by IP for auth endpoints\n72\tapp.use(\n73\t  \"/auth/*\",\n74\t  createRateLimitMiddleware({\n75\t    perWallet: 20,\n76\t    global: config.rateLimitGlobal,\n77\t    windowMs: 60_000,\n78\t  }),\n79\t);\n80\t\n81\tapp.route(\n82\t  \"/auth\",\n83\t  createAuthRoutes({\n84\t    authDb,\n85\t    db,\n86\t    jwtSecret: config.jwtSecret,\n87\t    cluster: config.cluster,\n88\t    challengeTtlSeconds: config.challengeTtlSeconds,\n89\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n90\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n91\t  }),\n92\t);\n93\t\n94\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n95\tapp.use(\n96\t  \"/profile/*\",\n97\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n98\t);\n99\tapp.route(\"/profile\", createProfileRoutes({ db }));\n100\t\n101\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n102\tapp.use(\n103\t  \"/referral/*\",\n104\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n105\t);\n106\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n107\t\n108\t// JWT auth middleware for fairness endpoints\n109\tapp.use(\n110\t  \"/fairness/*\",\n111\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n112\t);\n113\t\n114\t// Rate limiting — per-wallet and global limits on POST requests\n115\tapp.use(\n116\t  \"/fairness/*\",\n117\t  createRateLimitMiddleware({\n118\t    perWallet: config.rateLimitPerWallet,\n119\t    global: config.rateLimitGlobal,\n120\t    windowMs: 60_000,\n121\t  }),\n122\t);\n123\t\n124\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n125\tconst entropyAccount = new PublicKey(config.entropyAccount);\n126\tconst retrySettler = createRetrySettler({\n127\t  db,\n128\t  connection,\n129\t  settleRound: (pda) =>\n130\t    settleRound(\n131\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n132\t      pda,\n133\t    ),\n134\t});\n135\t\n136\t// PDA watcher — WebSocket-based instant join detection\n137\tconst pdaWatcher = createPdaWatcher({\n138\t  connection,\n139\t  serverKey: config.serverKeypair.publicKey,\n140\t  db,\n141\t  onJoinDetected: async (pda, targetSlot) => {\n142\t    // Update DB phase if still in 'created'\n143\t    const round = await db.getRoundByPda(pda);\n144\t    if (round && round.phase === \"created\") {\n145\t      await db.updateRoundPhase(pda, \"locked\", {\n146\t        target_slot: targetSlot.toString(),\n147\t      });\n148\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n149\t        targetSlot: targetSlot.toString(),\n150\t        source: \"pda-watcher\",\n151\t        game: round.game,\n152\t      });\n153\t    }\n154\t\n155\t    // Check if target slot already passed — settle immediately if so\n156\t    const currentSlot = await connection.getSlot();\n157\t    if (BigInt(currentSlot) >= targetSlot) {\n158\t      await retrySettler.attemptSettle(pda);\n159\t      pdaWatcher.unwatch(pda);\n160\t    }\n161\t    // If target slot not reached yet, poll worker will pick it up next cycle\n162\t  },\n163\t});\n164\t\n165\tconst worker = createSettlementWorker({\n166\t  db,\n167\t  connection,\n168\t  serverKey: config.serverKeypair.publicKey,\n169\t  pollIntervalMs: config.workerPollIntervalMs,\n170\t  onSettleReady: async (pda) => {\n171\t    await retrySettler.attemptSettle(pda);\n172\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n173\t  },\n174\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n175\t});\n176\tworker.start();\n177\t\n178\t// Close Call clock worker — fetches boundary prices + settles open rounds\n179\t// Rounds are created on-demand by players via /closecall/bet\n180\tconst closeCallClock = createCloseCallClockWorker({\n181\t  connection,\n182\t  serverKeypair: config.serverKeypair,\n183\t  db: sql,\n184\t});\n185\tcloseCallClock.start();\n186\t\n187\t// Register event handlers before starting the worker\n188\tregisterHandler(\n189\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n190\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n191\t);\n192\t\n193\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n194\tconst eventWorker = createEventWorker(sql, {\n195\t  pollIntervalMs: config.eventQueuePollMs,\n196\t});\n197\teventWorker.start();\n198\tlogger.info(\"Event queue worker started\", {\n199\t  pollIntervalMs: config.eventQueuePollMs,\n200\t});\n201\t\n202\t// Coinflip fairness routes\n203\tapp.route(\n204\t  \"/fairness/coinflip\",\n205\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n206\t);\n207\tapp.route(\n208\t  \"/fairness/lord\",\n209\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n210\t);\n211\t\n212\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n213\tapp.use(\n214\t  \"/closecall/bet\",\n215\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n216\t);\n217\tapp.use(\n218\t  \"/closecall/bet\",\n219\t  createRateLimitMiddleware({\n220\t    perWallet: config.rateLimitPerWallet,\n221\t    global: config.rateLimitGlobal,\n222\t    windowMs: 60_000,\n223\t  }),\n224\t);\n225\t\n226\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n227\tapp.route(\"/closecall\", createCloseCallRoutes({\n228\t  db,\n229\t  connection,\n230\t  serverKeypair: config.serverKeypair,\n231\t  clockWorker: closeCallClock,\n232\t  sql,\n233\t}));\n234\t\n235\t// Price routes — public, no auth\n236\tapp.route(\"/price\", createPriceRoutes());\n237\t\n238\t// Round verification routes\n239\tapp.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n240\t\n241\t// Health endpoint — wired after worker exists so we can query its status\n242\tapp.route(\n243\t  \"/health\",\n244\t  createHealthRoutes({\n245\t    db,\n246\t    sql,\n247\t    isWorkerRunning: () => worker.isRunning,\n248\t  }),\n249\t);\n250\t\n251\tconst port = config.port;\n252\tlogger.info(\"fairness-backend started\", { port });\n253\t\n254\tserve({\n255\t  fetch: app.fetch,\n256\t  port,\n257\t  hostname: \"0.0.0.0\",\n258\t});\n259\t\n260\texport default {\n261\t  port,\n262\t  fetch: app.fetch,\n263\t};\n264\t"}]},"parent_tool_use_id":"toolu_01GeJimhuQgTGsiYns1Mb4UZ","session_id":"b10d11a6-64a8-4246-9053-4c7d6bdc5315","uuid":"847806c6-60f8-4d0e-9