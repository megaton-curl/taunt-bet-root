tes 30-day cooldown (first edit is free).\n474\t   * Throws on cooldown violation or UNIQUE conflict.\n475\t   */\n476\t  updateUsername(wallet: string, newUsername: string): Promise<PlayerProfile>;\n477\t\n478\t  /**\n479\t   * Compute aggregate stats from the transactions table for a wallet.\n480\t   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n481\t   */\n482\t  getPlayerStats(wallet: string): Promise<PlayerStats>;\n483\t\n484\t  /**\n485\t   * Get public-safe subset of player stats (no wagered, no PnL).\n486\t   */\n487\t  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n488\t\n489\t  /**\n490\t   * Compute per-game aggregate stats from the transactions table.\n491\t   * Returns a record keyed by frontend game name (coinflip, lord-of-rngs, close-call).\n492\t   * Games with zero activity are omitted.\n493\t   */\n494\t  getGameBreakdown(wallet: string): Promise<Record<string, GameBreakdownStats>>;\n495\t\n496\t  /**\n497\t   * Compute win streaks from the transactions table.\n498\t   * Returns current (consecutive wins from most recent) and best (longest ever).\n499\t   * Refund-only matches are excluded from streak calculation.\n500\t   */\n501\t  getWinStreaks(wallet: string): Promise<WinStreaks>;\n502\t\n503\t  /**\n504\t   * Execute a function within a database transaction.\n505\t   * All db methods called on the transactional Db share the same transaction.\n506\t   * Rolls back on error, commits on success.\n507\t   */\n508\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n509\t\n510\t  /** Gracefully close the connection pool. */\n511\t  close(): Promise<void>;\n512\t}\n513\t\n514\tfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n515\t  return {\n516\t    ...row,\n517\t    open_price: Number(row.open_price),\n518\t    open_price_expo: Number(row.open_price_expo),\n519\t    close_price: row.close_price === null ? null : Number(row.close_price),\n520\t    green_pool: Number(row.green_pool),\n521\t    red_pool: Number(row.red_pool),\n522\t    total_fee: Number(row.total_fee),\n523\t    // JSONB comes back as parsed objects from postgres.js\n524\t    green_entries: Array.isArray(row.green_entries)\n525\t      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n526\t      : [],\n527\t    red_entries: Array.isArray(row.red_entries)\n528\t      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n529\t      : [],\n530\t  };\n531\t}\n532\t\n533\tfunction normalizeTransaction(row: Transaction): Transaction {\n534\t  return {\n535\t    ...row,\n536\t    amount_lamports: Number(row.amount_lamports),\n537\t  };\n538\t}\n539\t\n540\tfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n541\t  return {\n542\t    ...row,\n543\t    wager_lamports: Number(row.wager_lamports),\n544\t    fee_lamports: Number(row.fee_lamports),\n545\t    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n546\t    referrer_rate_bps: Number(row.referrer_rate_bps),\n547\t    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n548\t    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n549\t  };\n550\t}\n551\t\n552\tfunction normalizePlayerProfile(row: PlayerProfile): PlayerProfile {\n553\t  return {\n554\t    ...row,\n555\t    id: Number(row.id),\n556\t    heat_multiplier: Number(row.heat_multiplier),\n557\t    points_balance: Number(row.points_balance),\n558\t  };\n559\t}\n560\t\n561\tfunction normalizeRound(row: Round): Round {\n562\t  return {\n563\t    ...row,\n564\t    amount_lamports: Number(row.amount_lamports),\n565\t    side: Number(row.side),\n566\t    settle_attempts: Number(row.settle_attempts),\n567\t    result_side: row.result_side === null ? null : Number(row.result_side),\n568\t    // JSONB comes back as parsed objects from postgres.js\n569\t    entries: Array.isArray(row.entries)\n570\t      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n571\t          player: e.player,\n572\t          amountLamports: Number(e.amountLamports),\n573\t        }))\n574\t      : null,\n575\t  };\n576\t}\n577\t\n578\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n579\texport function createDb(databaseUrl: string, _txSql?: any): Db {\n580\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n581\t  const sql: any = _txSql ?? postgres(databaseUrl);\n582\t  const _isOwner = !_txSql;\n583\t\n584\t  return {\n585\t    async insertRound(params) {"}]},"parent_tool_use_id":"toolu_01GeJimhuQgTGsiYns1Mb4UZ","session_id":"b10d11a6-64a8-4246-9053-4c7d6bdc5315","uuid":"f27c7b23-1ce4-49b9-b177-d38b7cda6771","timestamp":"2026-03-31T15:12:26.064Z"}
