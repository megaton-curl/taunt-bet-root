{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016VnJr9XXXd2DJEKEF9NMF4","type":"tool_result","content":"1155\t        SET username = ${newUsername}, username_updated_at = now()\n1156\t        WHERE wallet = ${wallet}\n1157\t        RETURNING *\n1158\t      `;\n1159\t      return normalizePlayerProfile(rows[0]!);\n1160\t    },\n1161\t\n1162\t    async getPlayerStats(wallet) {\n1163\t      const rows = await sql<\n1164\t        Array<{\n1165\t          games_played: string;\n1166\t          total_wagered: string;\n1167\t          total_wins: string;\n1168\t          net_pnl: string;\n1169\t        }>\n1170\t      >`\n1171\t        SELECT\n1172\t          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n1173\t          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n1174\t          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n1175\t          COALESCE(\n1176\t            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n1177\t                     WHEN tx_type = 'deposit' THEN -amount_lamports\n1178\t                     ELSE 0 END),\n1179\t            0\n1180\t          )::text AS net_pnl\n1181\t        FROM transactions\n1182\t        WHERE wallet = ${wallet}\n1183\t      `;\n1184\t      const row = rows[0]!;\n1185\t      const gamesPlayed = Number(row.games_played);\n1186\t      const totalWins = Number(row.total_wins);\n1187\t      return {\n1188\t        gamesPlayed,\n1189\t        totalWagered: BigInt(row.total_wagered),\n1190\t        totalWins,\n1191\t        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n1192\t        netPnl: BigInt(row.net_pnl),\n1193\t      };\n1194\t    },\n1195\t\n1196\t    async getPublicPlayerStats(wallet) {\n1197\t      const full = await this.getPlayerStats(wallet);\n1198\t      return {\n1199\t        gamesPlayed: full.gamesPlayed,\n1200\t        totalWins: full.totalWins,\n1201\t        winRate: full.winRate,\n1202\t      };\n1203\t    },\n1204\t\n1205\t    async getGameBreakdown(wallet) {\n1206\t      const DB_TO_FRONTEND: Record<string, string> = {\n1207\t        coinflip: \"coinflip\",\n1208\t        lord: \"lord-of-rngs\",\n1209\t        closecall: \"close-call\",\n1210\t      };\n1211\t\n1212\t      const rows = await sql<\n1213\t        Array<{\n1214\t          game: string;\n1215\t          games_played: string;\n1216\t          total_wagered: string;\n1217\t          total_wins: string;\n1218\t          net_pnl: string;\n1219\t        }>\n1220\t      >`\n1221\t        SELECT\n1222\t          game,\n1223\t          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n1224\t          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n1225\t          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n1226\t          COALESCE(\n1227\t            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n1228\t                     WHEN tx_type = 'deposit' THEN -amount_lamports\n1229\t                     ELSE 0 END),\n1230\t            0\n1231\t          )::text AS net_pnl\n1232\t        FROM transactions\n1233\t        WHERE wallet = ${wallet}\n1234\t        GROUP BY game\n1235\t      `;\n1236\t\n1237\t      const result: Record<string, GameBreakdownStats> = {};\n1238\t      for (const row of rows) {\n1239\t        const gamesPlayed = Number(row.games_played);\n1240\t        if (gamesPlayed === 0) continue;\n1241\t        const totalWins = Number(row.total_wins);\n1242\t        const frontendName = DB_TO_FRONTEND[row.game] ?? row.game;\n1243\t        result[frontendName] = {\n1244\t          gamesPlayed,\n1245\t          totalWagered: BigInt(row.total_wagered),\n1246\t          totalWins,\n1247\t          winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n1248\t          netPnl: BigInt(row.net_pnl),\n1249\t        };\n1250\t      }\n1251\t      return result;\n1252\t    },\n1253\t\n1254\t    async getWinStreaks(wallet) {\n1255\t      // Get outcome per match ordered by most recent first.\n1256\t      // A match with a 'payout' row = win, 'deposit' without 'payout' = loss,\n1257\t      // only 'refund' = skip (excluded).\n1258\t      const rows = await sql<\n1259\t        Array<{ match_id: string; has_payout: boolean; has_deposit: boolean }>\n1260\t      >`\n1261\t        SELECT\n1262\t          match_id,\n1263\t          bool_or(tx_type = 'payout') AS has_payout,\n1264\t          bool_or(tx_type = 'deposit') AS has_deposit\n1265\t        FROM transactions\n1266\t        WHERE wallet = ${wallet}\n1267\t        GROUP BY match_id\n1268\t        HAVING bool_or(tx_type = 'deposit') OR bool_or(tx_type = 'payout')\n1269\t        ORDER BY MAX(created_at) DESC\n1270\t      `;\n1271\t\n1272\t      let current = 0;\n1273\t      let best = 0;\n1274\t      let streak = 0;\n1275\t      let currentSet = false;\n1276\t\n1277\t      for (const row of rows) {\n1278\t        // Skip refund-only matches (no deposit, no payout)\n1279\t        if (!row.has_deposit && !row.has_payout) continue;\n1280\t\n1281\t        const isWin = row.has_payout;\n1282\t        if (isWin) {\n1283\t          streak++;\n1284\t          if (streak > best) best = streak;\n1285\t        } else {\n1286\t          if (!currentSet) {\n1287\t            current = streak;\n1288\t            currentSet = true;\n1289\t          }\n1290\t          streak = 0;\n1291\t        }\n1292\t      }\n1293\t      // If we never hit a loss, current streak = total streak\n1294\t      if (!currentSet) current = streak;\n1295\t\n1296\t      return { current, best };\n1297\t    },\n1298\t\n1299\t    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n1300\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1301\t      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n1302\t    },\n1303\t\n1304\t    async close() {"}]},"parent_tool_use_id":"toolu_01GeJimhuQgTGsiYns1Mb4UZ","session_id":"b10d11a6-64a8-4246-9053-4c7d6bdc5315","uuid":"09fd4341-09f6-4bcc-b1ef-ac30c7c75e90","timestamp":"2026-03-31T15:12:26.433Z"}
