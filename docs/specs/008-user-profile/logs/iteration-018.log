{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018Agf7bDaAJ5oMqrxvw6AdE","type":"tool_result","content":"780\t    // -----------------------------------------------------------------------\n781\t    // Transactions\n782\t    // -----------------------------------------------------------------------\n783\t\n784\t    async insertTransaction(params) {\n785\t      await sql`\n786\t        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n787\t        VALUES (\n788\t          ${params.wallet},\n789\t          ${params.game},\n790\t          ${params.matchId},\n791\t          ${params.txType},\n792\t          ${params.amountLamports},\n793\t          ${params.txSig}\n794\t        )\n795\t        ON CONFLICT DO NOTHING\n796\t      `;\n797\t    },\n798\t\n799\t    async insertTransactions(params) {\n800\t      if (params.length === 0) return;\n801\t      const values = params.map((p) => ({\n802\t        wallet: p.wallet,\n803\t        game: p.game,\n804\t        match_id: p.matchId,\n805\t        tx_type: p.txType,\n806\t        amount_lamports: p.amountLamports,\n807\t        tx_sig: p.txSig,\n808\t      }));\n809\t      await sql`\n810\t        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n811\t        ON CONFLICT DO NOTHING\n812\t      `;\n813\t    },\n814\t\n815\t    async getTransactions(wallet, cursor, limit = 20, game) {\n816\t      const effectiveLimit = Math.min(limit, 50);\n817\t      if (cursor && game) {\n818\t        const rows = await sql<Transaction[]>`\n819\t          SELECT * FROM transactions\n820\t          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n821\t          ORDER BY id DESC\n822\t          LIMIT ${effectiveLimit}\n823\t        `;\n824\t        return rows.map(normalizeTransaction);\n825\t      }\n826\t      if (cursor) {\n827\t        const rows = await sql<Transaction[]>`\n828\t          SELECT * FROM transactions\n829\t          WHERE wallet = ${wallet} AND id < ${cursor}"}]},"parent_tool_use_id":"toolu_01Qne3pCaV5dTuUee5XP3YXa","session_id":"0ca033a0-a8fc-41b6-94ce-75284f4db80b","uuid":"892b091d-e0e2-4d30-a4b2-50ae9fb7e199","timestamp":"2026-03-31T15:05:14.585Z"}
