{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ewh4bHxfFrxNEW89JEmnxD","type":"tool_result","content":"460\t   * Update a player's username. Validates 30-day cooldown (first edit is free).\n461\t   * Throws on cooldown violation or UNIQUE conflict.\n462\t   */\n463\t  updateUsername(wallet: string, newUsername: string): Promise<PlayerProfile>;\n464\t\n465\t  /**\n466\t   * Compute aggregate stats from the transactions table for a wallet.\n467\t   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n468\t   */\n469\t  getPlayerStats(wallet: string): Promise<PlayerStats>;\n470\t\n471\t  /**\n472\t   * Get public-safe subset of player stats (no wagered, no PnL).\n473\t   */\n474\t  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n475\t\n476\t  /**\n477\t   * Execute a function within a database transaction.\n478\t   * All db methods called on the transactional Db share the same transaction.\n479\t   * Rolls back on error, commits on success.\n480\t   */\n481\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n482\t\n483\t  /** Gracefully close the connection pool. */\n484\t  close(): Promise<void>;\n485\t}\n486\t\n487\tfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n488\t  return {\n489\t    ...row,\n490\t    open_price: Number(row.open_price),\n491\t    open_price_expo: Number(row.open_price_expo),\n492\t    close_price: row.close_price === null ? null : Number(row.close_price),\n493\t    green_pool: Number(row.green_pool),\n494\t    red_pool: Number(row.red_pool),\n495\t    total_fee: Number(row.total_fee),\n496\t    // JSONB comes back as parsed objects from postgres.js\n497\t    green_entries: Array.isArray(row.green_entries)\n498\t      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n499\t      : [],\n500\t    red_entries: Array.isArray(row.red_entries)\n501\t      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n502\t      : [],\n503\t  };\n504\t}\n505\t\n506\tfunction normalizeTransaction(row: Transaction): Transaction {\n507\t  return {\n508\t    ...row,\n509\t    amount_lamports: Number(row.amount_lamports),"}]},"parent_tool_use_id":"toolu_01Qne3pCaV5dTuUee5XP3YXa","session_id":"0ca033a0-a8fc-41b6-94ce-75284f4db80b","uuid":"0d6e8ceb-da29-4f06-8f58-555104db19ab","timestamp":"2026-03-31T15:05:08.438Z"}
