{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ECoGyxp4pFcW1jdVTtJ7nf","type":"tool_result","content":"235\t// DB client\n236\t// ---------------------------------------------------------------------------\n237\t\n238\texport interface Db {\n239\t  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n240\t  insertRound(params: InsertRoundParams): Promise<Round>;\n241\t\n242\t  /** Delete a round by PDA. Returns true if a row was removed. */\n243\t  deleteRoundByPda(pda: string): Promise<boolean>;\n244\t\n245\t  /** Transition a round's phase. Enforces unidirectional state machine.\n246\t   *  Optional `updates` can set additional columns alongside the phase change. */\n247\t  updateRoundPhase(\n248\t    pda: string,\n249\t    newPhase: RoundPhase,\n250\t    updates?: Partial<\n251\t      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n252\t    >,\n253\t  ): Promise<Round>;\n254\t\n255\t  /** Update the entries JSONB column for a settled round. */\n256\t  updateRoundEntries(\n257\t    pda: string,\n258\t    entries: Array<{ player: string; amountLamports: number }>,\n259\t  ): Promise<Round>;\n260\t\n261\t  /** Get a single round by its PDA. Returns `undefined` if not found. */\n262\t  getRoundByPda(pda: string): Promise<Round | undefined>;\n263\t\n264\t  /** Get all rounds matching a given phase. */\n265\t  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n266\t\n267\t  /** Append an operator event to the audit log. */\n268\t  insertOperatorEvent(\n269\t    pda: string | null,\n270\t    eventType: OperatorEventType,\n271\t    payload?: unknown,\n272\t  ): Promise<OperatorEvent>;\n273\t\n274\t  /** Get the latest operator event for a PDA + type. */\n275\t  getLatestOperatorEvent(\n276\t    pda: string,\n277\t    eventType: OperatorEventType,\n278\t  ): Promise<OperatorEvent | undefined>;\n279\t\n280\t  /** Get a single round by its match_id. Returns `undefined` if not found. */\n281\t  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n282\t\n283\t  /** Batch-fetch the latest operator event per PDA for a given event type. */\n284\t  getLatestOperatorEventsForPdas(\n285\t    pdas: string[],\n286\t    eventType: OperatorEventType,\n287\t  ): Promise<Map<string, OperatorEvent>>;\n288\t\n289\t  /** Get recently settled rounds for a game, ordered newest first. */\n290\t  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n291\t\n292\t  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n293\t  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n294\t\n295\t  // -------------------------------------------------------------------------\n296\t  // Close Call rounds\n297\t  // -------------------------------------------------------------------------\n298\t\n299\t  /** Insert a new Close Call round. */\n300\t  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n301\t\n302\t  /** Get a Close Call round by round_id (16-char hex). */\n303\t  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n304\t\n305\t  /** Get the current active (open) Close Call round. */\n306\t  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n307\t\n308\t  /** Get the most recent settled/refunded Close Call rounds. */\n309\t  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n310\t\n311\t  /** Update a Close Call round after settlement. */\n312\t  settleCloseCallRound(\n313\t    roundId: string,\n314\t    updates: {\n315\t      phase: CloseCallPhase;\n316\t      outcome: CloseCallOutcome;\n317\t      closePrice?: number;\n318\t      greenPool?: number;\n319\t      redPool?: number;\n320\t      totalFee?: number;\n321\t      greenEntries?: Array<{ player: string; amountLamports: number }>;\n322\t      redEntries?: Array<{ player: string; amountLamports: number }>;\n323\t      settleTx?: string;\n324\t    },\n325\t  ): Promise<CloseCallRound>;\n326\t\n327\t  // -------------------------------------------------------------------------\n328\t  // Transactions\n329\t  // -------------------------------------------------------------------------\n330\t\n331\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n332\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n333\t\n334\t  /** Insert multiple transactions in a single batch. */\n335\t  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n336\t\n337\t  /** Get paginated transactions for a wallet, newest first. */\n338\t  getTransactions(\n339\t    wallet: string,\n340\t    cursor?: string,\n341\t    limit?: number,\n342\t    game?: string,\n343\t  ): Promise<Transaction[]>;\n344\t\n345\t  // -------------------------------------------------------------------------\n346\t  // Referral — codes\n347\t  // -------------------------------------------------------------------------\n348\t\n349\t  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n350\t  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n351\t\n352\t  /** Get a wallet's referral code. Returns `undefined` if none set. */\n353\t  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n354\t\n355\t  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n356\t  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n357\t\n358\t  // -------------------------------------------------------------------------\n359\t  // Referral — links\n360\t  // -------------------------------------------------------------------------\n361\t\n362\t  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n363\t  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n364\t\n365\t  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n366\t  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n367\t\n368\t  /** Get all referral links where the given wallet is the referrer. */\n369\t  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n370\t\n371\t  // -------------------------------------------------------------------------\n372\t  // Referral — earnings & stats\n373\t  // -------------------------------------------------------------------------\n374\t\n375\t  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n376\t  insertReferralEarning(params: {\n377\t    referrerWallet: string;\n378\t    refereeWallet: string;\n379\t    roundId: string;\n380\t    gameType: string;\n381\t    wagerLamports: number;\n382\t    feeLamports: number;\n383\t    referrerEarnedLamports: number;\n384\t    referrerRateBps: number;"}]},"parent_tool_use_id":"toolu_01Qne3pCaV5dTuUee5XP3YXa","session_id":"0ca033a0-a8fc-41b6-94ce-75284f4db80b","uuid":"df0a5b11-8cf8-4a5f-8c59-529d1e331c19","timestamp":"2026-03-31T15:05:05.539Z"}
