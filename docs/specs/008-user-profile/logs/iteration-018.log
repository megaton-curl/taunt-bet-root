{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016n8GGrHae5pfMzBzy7Woi9","type":"tool_result","content":"100\t\n101\t// ---------------------------------------------------------------------------\n102\t// Transaction types\n103\t// ---------------------------------------------------------------------------\n104\t\n105\texport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n106\t\n107\texport interface Transaction {\n108\t  id: string;\n109\t  wallet: string;\n110\t  game: string;\n111\t  match_id: string;\n112\t  tx_type: TransactionType;\n113\t  amount_lamports: number;\n114\t  tx_sig: string;\n115\t  created_at: Date;\n116\t}\n117\t\n118\texport interface InsertTransactionParams {\n119\t  wallet: string;\n120\t  game: string;\n121\t  matchId: string;\n122\t  txType: TransactionType;\n123\t  amountLamports: number;\n124\t  txSig: string;\n125\t}\n126\t\n127\t// ---------------------------------------------------------------------------\n128\t// Referral types\n129\t// ---------------------------------------------------------------------------\n130\t\n131\texport interface ReferralCode {\n132\t  id: number;\n133\t  wallet: string;\n134\t  code: string;\n135\t  created_at: Date;\n136\t  updated_at: Date;\n137\t}\n138\t\n139\texport interface ReferralLink {\n140\t  id: number;\n141\t  referrer_wallet: string;\n142\t  referee_wallet: string;\n143\t  created_at: Date;\n144\t}\n145\t\n146\texport interface ReferralEarning {\n147\t  id: number;\n148\t  referrer_wallet: string;\n149\t  referee_wallet: string;\n150\t  round_id: string;\n151\t  game_type: string;\n152\t  wager_lamports: number;\n153\t  fee_lamports: number;\n154\t  referrer_earned_lamports: number;\n155\t  referrer_rate_bps: number;\n156\t  referee_rebate_lamports: number;\n157\t  referee_rebate_rate_bps: number;\n158\t  created_at: Date;\n159\t}\n160\t\n161\texport interface ReferralStats {\n162\t  referred_count: number;\n163\t  active_count: number;\n164\t  total_volume_lamports: string;\n165\t  total_earned_lamports: string;\n166\t  total_rebate_lamports: string;\n167\t  pending_lamports: string;\n168\t}\n169\t\n170\texport interface ReferralClaim {\n171\t  id: string;\n172\t  wallet: string;\n173\t  amount_lamports: string;\n174\t  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n175\t  retry_count: number;\n176\t  tx_signature: string | null;\n177\t  error: string | null;\n178\t  requested_at: Date;\n179\t  processed_at: Date | null;\n180\t}\n181\t\n182\t// ---------------------------------------------------------------------------\n183\t// Player profile types\n184\t// ---------------------------------------------------------------------------\n185\t\n186\texport interface PlayerProfile {\n187\t  id: number;\n188\t  user_id: string;\n189\t  wallet: string;\n190\t  username: string;\n191\t  username_updated_at: Date | null;\n192\t  avatar_url: string | null;\n193\t  heat_multiplier: number;\n194\t  points_balance: number;\n195\t  created_at: Date;\n196\t}\n197\t\n198\texport interface PlayerStats {\n199\t  gamesPlayed: number;\n200\t  totalWagered: bigint;\n201\t  totalWins: number;\n202\t  winRate: number;\n203\t  netPnl: bigint;\n204\t}\n205\t\n206\texport interface PublicPlayerStats {\n207\t  gamesPlayed: number;\n208\t  totalWins: number;\n209\t  winRate: number;\n210\t}\n211\t\n212\t// ---------------------------------------------------------------------------\n213\t// Phase transition guard\n214\t// ---------------------------------------------------------------------------\n215\t\n216\t/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n217\tconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n218\t  created: [\"locked\", \"expired\"],\n219\t  locked: [\"settling\"],\n220\t  settling: [\"settled\"],\n221\t  settled: [],\n222\t  expired: [],\n223\t};\n224\t\n225\tfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n226\t  const allowed = VALID_TRANSITIONS[from];\n227\t  if (!allowed.includes(to)) {\n228\t    throw new Error(\n229\t      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n230\t    );\n231\t  }\n232\t}\n233\t\n234\t// ---------------------------------------------------------------------------\n235\t// DB client\n236\t// ---------------------------------------------------------------------------\n237\t\n238\texport interface Db {\n239\t  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n240\t  insertRound(params: InsertRoundParams): Promise<Round>;\n241\t\n242\t  /** Delete a round by PDA. Returns true if a row was removed. */\n243\t  deleteRoundByPda(pda: string): Promise<boolean>;\n244\t\n245\t  /** Transition a round's phase. Enforces unidirectional state machine.\n246\t   *  Optional `updates` can set additional columns alongside the phase change. */\n247\t  updateRoundPhase(\n248\t    pda: string,\n249\t    newPhase: RoundPhase,"}]},"parent_tool_use_id":"toolu_01Qne3pCaV5dTuUee5XP3YXa","session_id":"0ca033a0-a8fc-41b6-94ce-75284f4db80b","uuid":"e05b6f0b-dbf3-4f86-ad14-da21a97e7fac","timestamp":"2026-03-31T15:05:08.085Z"}
