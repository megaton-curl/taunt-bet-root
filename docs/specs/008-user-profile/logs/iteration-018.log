{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017X9r4jyFhS9L5VmRHdgUms","type":"tool_result","content":"1\t/**\n2\t * Database client module — typed query functions for `rounds` and `operator_events`.\n3\t *\n4\t * Phase transitions are unidirectional: created → locked → settling → settled,\n5\t * or created → expired. The application layer rejects backward transitions.\n6\t */\n7\t\n8\timport postgres from \"postgres\";\n9\timport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n10\t\n11\t// ---------------------------------------------------------------------------\n12\t// Types\n13\t// ---------------------------------------------------------------------------\n14\t\n15\texport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n16\t\n17\texport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n18\texport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n19\t\n20\texport interface CloseCallRound {\n21\t  round_id: string;\n22\t  pda: string;\n23\t  server_key: string;\n24\t  phase: CloseCallPhase;\n25\t  open_price: number;\n26\t  open_price_expo: number;\n27\t  close_price: number | null;\n28\t  outcome: CloseCallOutcome;\n29\t  green_pool: number;\n30\t  red_pool: number;\n31\t  total_fee: number;\n32\t  green_entries: Array<{ player: string; amountLamports: number }>;\n33\t  red_entries: Array<{ player: string; amountLamports: number }>;\n34\t  settle_tx: string | null;\n35\t  created_at: Date;\n36\t  settled_at: Date | null;\n37\t}\n38\t\n39\texport interface InsertCloseCallRoundParams {\n40\t  roundId: string;\n41\t  pda: string;\n42\t  serverKey: string;\n43\t  openPrice: number;\n44\t  openPriceExpo: number;\n45\t}\n46\t\n47\texport type OperatorEventType =\n48\t  | \"secret_generated\"\n49\t  | \"tx_built\"\n50\t  | \"match_detected\"\n51\t  | \"settle_submitted\"\n52\t  | \"settle_confirmed\"\n53\t  | \"settle_failed\"\n54\t  | \"settle_retried\"\n55\t  | \"timeout_detected\";\n56\t\n57\texport interface Round {\n58\t  pda: string;\n59\t  game: string;\n60\t  creator: string;\n61\t  server_key: string;\n62\t  secret: Buffer;\n63\t  commitment: Buffer;\n64\t  amount_lamports: number;\n65\t  side: number;\n66\t  match_id: string;\n67\t  phase: RoundPhase;\n68\t  target_slot: string | null;\n69\t  settle_tx: string | null;\n70\t  settle_attempts: number;\n71\t  result_hash: Buffer | null;\n72\t  result_side: number | null;\n73\t  winner: string | null;\n74\t  entries: unknown | null;\n75\t  created_at: Date;\n76\t  updated_at: Date;\n77\t}\n78\t\n79\texport interface InsertRoundParams {\n80\t  pda: string;\n81\t  game: string;\n82\t  creator: string;\n83\t  serverKey: string;\n84\t  secret: Buffer;\n85\t  commitment: Buffer;\n86\t  amountLamports: number;\n87\t  side: number;\n88\t  matchId: string;\n89\t  phase: RoundPhase;\n90\t  entries?: Array<{ player: string; amountLamports: number }>;\n91\t}\n92\t\n93\texport interface OperatorEvent {\n94\t  id: string;\n95\t  pda: string | null;\n96\t  event_type: OperatorEventType;\n97\t  payload: unknown;\n98\t  created_at: Date;\n99\t}\n100\t"}]},"parent_tool_use_id":"toolu_01Qne3pCaV5dTuUee5XP3YXa","session_id":"0ca033a0-a8fc-41b6-94ce-75284f4db80b","uuid":"0a652286-d43b-41e4-ba96-5b63829c2a7c","timestamp":"2026-03-31T15:05:05.608Z"}
