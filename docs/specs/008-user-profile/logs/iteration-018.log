{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018SiATKEWAbdgsqYe9Ao8Uz","type":"tool_result","content":"1130\t        RETURNING *\n1131\t      `;\n1132\t      return normalizePlayerProfile(rows[0]!);\n1133\t    },\n1134\t\n1135\t    async getPlayerStats(wallet) {\n1136\t      const rows = await sql<\n1137\t        Array<{\n1138\t          games_played: string;\n1139\t          total_wagered: string;\n1140\t          total_wins: string;\n1141\t          net_pnl: string;\n1142\t        }>\n1143\t      >`\n1144\t        SELECT\n1145\t          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n1146\t          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n1147\t          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n1148\t          COALESCE(\n1149\t            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n1150\t                     WHEN tx_type = 'deposit' THEN -amount_lamports\n1151\t                     ELSE 0 END),\n1152\t            0\n1153\t          )::text AS net_pnl\n1154\t        FROM transactions\n1155\t        WHERE wallet = ${wallet}\n1156\t      `;\n1157\t      const row = rows[0]!;\n1158\t      const gamesPlayed = Number(row.games_played);\n1159\t      const totalWins = Number(row.total_wins);\n1160\t      return {\n1161\t        gamesPlayed,\n1162\t        totalWagered: BigInt(row.total_wagered),\n1163\t        totalWins,\n1164\t        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n1165\t        netPnl: BigInt(row.net_pnl),\n1166\t      };\n1167\t    },\n1168\t\n1169\t    async getPublicPlayerStats(wallet) {\n1170\t      const full = await this.getPlayerStats(wallet);\n1171\t      return {\n1172\t        gamesPlayed: full.gamesPlayed,\n1173\t        totalWins: full.totalWins,\n1174\t        winRate: full.winRate,\n1175\t      };\n1176\t    },\n1177\t\n1178\t    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n1179\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1180\t      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n1181\t    },\n1182\t\n1183\t    async close() {\n1184\t      if (_isOwner) await sql.end();\n1185\t    },\n1186\t  };\n1187\t}\n1188\t"}]},"parent_tool_use_id":null,"session_id":"0ca033a0-a8fc-41b6-94ce-75284f4db80b","uuid":"42e86262-4217-4f1f-b326-780f9a4af344","timestamp":"2026-03-31T15:05:48.564Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/db.ts","content":"        RETURNING *\n      `;\n      return normalizePlayerProfile(rows[0]!);\n    },\n\n    async getPlayerStats(wallet) {\n      const rows = await sql<\n        Array<{\n          games_played: string;\n          total_wagered: string;\n          total_wins: string;\n          net_pnl: string;\n        }>\n      >`\n        SELECT\n          COUNT(DISTINCT CASE WHEN tx_type = 'deposit' THEN match_id END)::text AS games_played,\n          COALESCE(SUM(CASE WHEN tx_type = 'deposit' THEN amount_lamports ELSE 0 END), 0)::text AS total_wagered,\n          COUNT(DISTINCT CASE WHEN tx_type = 'payout' THEN match_id END)::text AS total_wins,\n          COALESCE(\n            SUM(CASE WHEN tx_type IN ('payout', 'refund') THEN amount_lamports\n                     WHEN tx_type = 'deposit' THEN -amount_lamports\n                     ELSE 0 END),\n            0\n          )::text AS net_pnl\n        FROM transactions\n        WHERE wallet = ${wallet}\n      `;\n      const row = rows[0]!;\n      const gamesPlayed = Number(row.games_played);\n      const totalWins = Number(row.total_wins);\n      return {\n        gamesPlayed,\n        totalWagered: BigInt(row.total_wagered),\n        totalWins,\n        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n        netPnl: BigInt(row.net_pnl),\n      };\n    },\n\n    async getPublicPlayerStats(wallet) {\n      const full = await this.getPlayerStats(wallet);\n      return {\n        gamesPlayed: full.gamesPlayed,\n        totalWins: full.totalWins,\n        winRate: full.winRate,\n      };\n    },\n\n    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n    },\n\n    async close() {\n      if (_isOwner) await sql.end();\n    },\n  };\n}\n","numLines":59,"startLine":1130,"totalLines":1188}}}
