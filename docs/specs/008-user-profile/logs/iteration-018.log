{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bk44HETfomTUdeqij9VfXS","type":"tool_result","content":"380\t    gameType: string;\n381\t    wagerLamports: number;\n382\t    feeLamports: number;\n383\t    referrerEarnedLamports: number;\n384\t    referrerRateBps: number;\n385\t    refereeRebateLamports: number;\n386\t    refereeRebateRateBps: number;\n387\t  }): Promise<ReferralEarning>;\n388\t\n389\t  /**\n390\t   * Get the pending (unclaimed) balance for a wallet.\n391\t   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n392\t   * wallet=referee, minus sum of completed claims for the wallet.\n393\t   * Returns a lamport string.\n394\t   */\n395\t  getPendingBalance(wallet: string): Promise<string>;\n396\t\n397\t  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n398\t  getReferralEarnings(\n399\t    wallet: string,\n400\t    page: number,\n401\t    limit: number,\n402\t  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n403\t\n404\t  /** Get referral summary stats for a wallet. */\n405\t  getReferralStats(wallet: string): Promise<ReferralStats>;\n406\t\n407\t  // -------------------------------------------------------------------------\n408\t  // Referral — claims & rates\n409\t  // -------------------------------------------------------------------------\n410\t\n411\t  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n412\t  insertReferralClaim(\n413\t    wallet: string,\n414\t    amountLamports: string,\n415\t  ): Promise<ReferralClaim>;\n416\t\n417\t  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n418\t  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n419\t\n420\t  /**\n421\t   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n422\t   * Returns the updated claim.\n423\t   */\n424\t  updateClaimStatus(\n425\t    claimId: string,\n426\t    status: ReferralClaim[\"status\"],\n427\t    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n428\t  ): Promise<ReferralClaim>;\n429\t\n430\t  /**\n431\t   * Get the effective referrer rate for a wallet in bps.\n432\t   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n433\t   */\n434\t  getReferrerRate(\n435\t    wallet: string,\n436\t    defaultRateBps: number,\n437\t  ): Promise<number>;\n438\t\n439\t  // -------------------------------------------------------------------------\n440\t  // Player profiles\n441\t  // -------------------------------------------------------------------------\n442\t\n443\t  /**\n444\t   * Create a new player profile with auto-generated user_id and username.\n445\t   * Retries up to 5 times on username collision, then falls back to `user-{random8}`.\n446\t   */\n447\t  createPlayerProfile(wallet: string): Promise<PlayerProfile>;\n448\t\n449\t  /** Get a player profile by wallet address. Returns `null` if not found. */\n450\t  getProfileByWallet(wallet: string): Promise<PlayerProfile | null>;\n451\t\n452\t  /**\n453\t   * Get a player profile by public identifier.\n454\t   * If identifier starts with `usr_`, looks up by `user_id`.\n455\t   * Otherwise looks up by username (case-insensitive).\n456\t   */\n457\t  getProfileByIdentifier(identifier: string): Promise<PlayerProfile | null>;\n458\t\n459\t  /**\n460\t   * Update a player's username. Validates 30-day cooldown (first edit is free).\n461\t   * Throws on cooldown violation or UNIQUE conflict.\n462\t   */\n463\t  updateUsername(wallet: string, newUsername: string): Promise<PlayerProfile>;\n464\t\n465\t  /**\n466\t   * Compute aggregate stats from the transactions table for a wallet.\n467\t   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n468\t   */\n469\t  getPlayerStats(wallet: string): Promise<PlayerStats>;\n470\t\n471\t  /**\n472\t   * Get public-safe subset of player stats (no wagered, no PnL).\n473\t   */\n474\t  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n475\t\n476\t  /**\n477\t   * Execute a function within a database transaction.\n478\t   * All db methods called on the transactional Db share the same transaction.\n479\t   * Rolls back on error, commits on success.\n480\t   */\n481\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n482\t\n483\t  /** Gracefully close the connection pool. */\n484\t  close(): Promise<void>;\n485\t}\n486\t\n487\tfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n488\t  return {\n489\t    ...row,\n490\t    open_price: Number(row.open_price),\n491\t    open_price_expo: Number(row.open_price_expo),\n492\t    close_price: row.close_price === null ? null : Number(row.close_price),\n493\t    green_pool: Number(row.green_pool),\n494\t    red_pool: Number(row.red_pool),\n495\t    total_fee: Number(row.total_fee),\n496\t    // JSONB comes back as parsed objects from postgres.js\n497\t    green_entries: Array.isArray(row.green_entries)\n498\t      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n499\t      : [],"}]},"parent_tool_use_id":"toolu_01Qne3pCaV5dTuUee5XP3YXa","session_id":"0ca033a0-a8fc-41b6-94ce-75284f4db80b","uuid":"6c9be7ed-6dc9-481e-981f-03a28f6606e7","timestamp":"2026-03-31T15:05:23.801Z"}
