{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KY7XV1d2FBgMPwzMuWQcmk","type":"tool_result","content":"     1→/**\n     2→ * Close Call clock worker — precise minute-boundary price capture + settlement.\n     3→ *\n     4→ * Scheduling:\n     5→ *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n     6→ *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n     7→ *   - Caches the boundary price (both close of old candle, open of next)\n     8→ *   - Settles any open rounds whose candle has closed\n     9→ *   - Schedules next tick at (next minute + 1s)\n    10→ *\n    11→ * Rounds are created on-demand by the first bettor (via /closecall/bet).\n    12→ * On start, loads the latest boundary price from DB to seed the cache.\n    13→ */\n    14→\n    15→import { performance } from \"node:perf_hooks\";\n    16→import {\n    17→  Connection,\n    18→  Keypair,\n    19→  PublicKey,\n    20→  Transaction,\n    21→} from \"@solana/web3.js\";\n    22→import type postgres from \"postgres\";\n    23→import { logger } from \"../logger.js\";\n    24→import { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    25→import {\n    26→  buildCloseCallSettleRoundIx,\n    27→} from \"./settle-tx.js\";\n    28→import {\n    29→  closeCallRoundDiscriminatorFilter,\n    30→  decodeCloseCallConfig,\n    31→  decodeCloseCallRound,\n    32→} from \"./account-decoder.js\";\n    33→import { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n    34→\n    35→/** Close Call on-chain phase values */\n    36→const PHASE_OPEN = 0;\n    37→\n    38→/** How long to wait after minute boundary before first Hermes poll (ms). */\n    39→const BOUNDARY_OFFSET_MS = 1_000;\n    40→\n    41→/** Poll Hermes every 1s when waiting for boundary price. */\n    42→const HERMES_POLL_INTERVAL_MS = 1_000;\n    43→\n    44→/** Max attempts to fetch a fresh boundary price (10s total). */\n    45→const HERMES_MAX_RETRIES = 10;\n    46→\n    47→/** Maximum retry attempts for a single tx submission. */\n    48→const MAX_TX_RETRIES = 3;\n    49→const TX_RETRY_DELAY_MS = 2_000;\n    50→\n    51→// ---------------------------------------------------------------------------\n    52→// Types\n    53→// ---------------------------------------------------------------------------\n    54→\n    55→export interface BoundaryPrice {\n    56→  price: bigint;\n    57→  expo: number;\n    58→  minuteTs: number;\n    59→  priceHuman: number;\n    60→}\n    61→\n    62→export interface CloseCallClockDeps {\n    63→  connection: Connection;\n    64→  serverKeypair: Keypair;\n    65→  /** Postgres `sql` tagged template instance for candle table access. */\n    66→  db: postgres.Sql;\n    67→  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n    68→  hermesEndpoint?: string;\n    69→}\n    70→\n    71→export interface CloseCallClockWorker {\n    72→  start(): void;\n    73→  stop(): void;\n    74→  readonly isRunning: boolean;\n    75→  /** Run a single tick (exposed for testing). */\n    76→  tick(): Promise<void>;\n    77→  /** Get the most recent minute-boundary price (from cache). */\n    78→  getLatestBoundaryPrice(): BoundaryPrice | null;\n    79→}\n    80→\n    81→// ---------------------------------------------------------------------------\n    82→// Factory\n    83→// ---------------------------------------------------------------------------\n    84→\n    85→export function createCloseCallClockWorker(\n    86→  deps: CloseCallClockDeps,\n    87→): CloseCallClockWorker {\n    88→  const { connection, serverKeypair, hermesEndpoint, db: sql } = deps;\n    89→\n    90→  const hermes: HermesFetcher = createHermesFetcher(hermesEndpoint);\n    91→\n    92→  let running = false;\n    93→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    94→\n    95→  /** Cached latest boundary price (in-memory). */\n    96→  let cachedBoundaryPrice: BoundaryPrice | null = null;\n    97→\n    98→  // -----------------------------------------------------------------------\n    99→  // Scheduling\n   100→  // -----------------------------------------------------------------------"}]},"parent_tool_use_id":"toolu_01Y6hQ138njMcrbtGDY1z6VT","session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"af2c85c0-f605-4b04-bfdc-2afb5b5e47c8","timestamp":"2026-03-19T21:50:39.360Z"}
