{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017AbzS133Fur1PYxfMmzmD2","type":"tool_result","content":"     1→/**\n     2→ * Profile routes — transaction history for the authenticated player.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import type { AppEnv } from \"../hono-env.js\";\n     7→import type { Db } from \"../db.js\";\n     8→import { logger } from \"../logger.js\";\n     9→\n    10→export interface ProfileRoutesDeps {\n    11→  db: Db;\n    12→}\n    13→\n    14→/** Map DB game names to frontend game IDs */\n    15→const GAME_TO_FRONTEND: Record<string, string> = {\n    16→  coinflip: \"coinflip\",\n    17→  lord: \"lord-of-rngs\",\n    18→  closecall: \"close-call\",\n    19→};\n    20→\n    21→/** Map frontend/DB game names to canonical DB names */\n    22→const TO_DB_GAME: Record<string, string> = {\n    23→  coinflip: \"coinflip\",\n    24→  lord: \"lord\",\n    25→  closecall: \"closecall\",\n    26→  \"lord-of-rngs\": \"lord\",\n    27→  \"close-call\": \"closecall\",\n    28→};\n    29→\n    30→export function createProfileRoutes(deps: ProfileRoutesDeps) {\n    31→  const { db } = deps;\n    32→  const app = new Hono<AppEnv>();\n    33→\n    34→  app.get(\"/transactions\", async (c) => {\n    35→    const wallet = c.get(\"wallet\");\n    36→    if (!wallet) {\n    37→      return c.json({ error: \"Authentication required\" }, 401);\n    38→    }\n    39→\n    40→    // Parse query params\n    41→    const cursor = c.req.query(\"cursor\") || undefined;\n    42→    const limitParam = c.req.query(\"limit\");\n    43→    const gameParam = c.req.query(\"game\") || undefined;\n    44→\n    45→    // Validate & clamp limit\n    46→    let limit = 20;\n    47→    if (limitParam) {\n    48→      const parsed = parseInt(limitParam, 10);\n    49→      if (!isNaN(parsed) && parsed > 0) {\n    50→        limit = Math.min(parsed, 50);\n    51→      }\n    52→    }\n    53→\n    54→    // Map game filter to DB name (accept both DB and frontend names)\n    55→    let dbGame: string | undefined;\n    56→    if (gameParam) {\n    57→      dbGame = TO_DB_GAME[gameParam];\n    58→      if (!dbGame) {\n    59→        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n    60→      }\n    61→    }\n    62→\n    63→    try {\n    64→      const rows = await db.getUserTransactions(wallet, cursor, limit, dbGame);\n    65→\n    66→      const transactions = rows.map((row) => ({\n    67→        id: row.id,\n    68→        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n    69→        matchId: row.match_id,\n    70→        event: row.event,\n    71→        amountLamports: String(row.amount_lamports),\n    72→        txSig: row.tx_sig,\n    73→        createdAt: row.created_at.toISOString(),\n    74→      }));\n    75→\n    76→      const nextCursor =\n    77→        transactions.length === limit\n    78→          ? String(transactions[transactions.length - 1]!.id)\n    79→          : null;\n    80→\n    81→      return c.json({ transactions, nextCursor });\n    82→    } catch (err) {\n    83→      logger.error(\"profile transactions query failed\", {\n    84→        wallet,\n    85→        error: err instanceof Error ? err.message : \"Unknown error\",\n    86→      });\n    87→      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    88→    }\n    89→  });\n    90→\n    91→  return app;\n    92→}\n    93→"}]},"parent_tool_use_id":null,"session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"58c83592-45b3-41d2-9c8c-5d03f0e51db7","timestamp":"2026-03-19T21:53:47.110Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/profile.ts","content":"/**\n * Profile routes — transaction history for the authenticated player.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ProfileRoutesDeps {\n  db: Db;\n}\n\n/** Map DB game names to frontend game IDs */\nconst GAME_TO_FRONTEND: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord-of-rngs\",\n  closecall: \"close-call\",\n};\n\n/** Map frontend/DB game names to canonical DB names */\nconst TO_DB_GAME: Record<string, string> = {\n  coinflip: \"coinflip\",\n  lord: \"lord\",\n  closecall: \"closecall\",\n  \"lord-of-rngs\": \"lord\",\n  \"close-call\": \"closecall\",\n};\n\nexport function createProfileRoutes(deps: ProfileRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  app.get(\"/transactions\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    // Parse query params\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limitParam = c.req.query(\"limit\");\n    const gameParam = c.req.query(\"game\") || undefined;\n\n    // Validate & clamp limit\n    let limit = 20;\n    if (limitParam) {\n      const parsed = parseInt(limitParam, 10);\n      if (!isNaN(parsed) && parsed > 0) {\n        limit = Math.min(parsed, 50);\n      }\n    }\n\n    // Map game filter to DB name (accept both DB and frontend names)\n    let dbGame: string | undefined;\n    if (gameParam) {\n      dbGame = TO_DB_GAME[gameParam];\n      if (!dbGame) {\n        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n      }\n    }\n\n    try {\n      const rows = await db.getUserTransactions(wallet, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n        matchId: row.match_id,\n        event: row.event,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return c.json({ transactions, nextCursor });\n    } catch (err) {\n      logger.error(\"profile transactions query failed\", {\n        wallet,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":93,"startLine":1,"totalLines":93}}}
