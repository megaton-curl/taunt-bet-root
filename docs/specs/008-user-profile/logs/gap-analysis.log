{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HUJkfapnzhz5x6zDzvAdVf","type":"tool_result","content":"     1→-- 008_user_transactions.sql — Player transaction history ledger.\n     2→--\n     3→-- One row per user-visible game event (join, win, loss, refund).\n     4→-- Used by the profile transactions API. Idempotent writes via\n     5→-- UNIQUE constraint on (wallet, match_id, event).\n     6→\n     7→CREATE TABLE IF NOT EXISTS user_transactions (\n     8→  id              BIGSERIAL    PRIMARY KEY,\n     9→  wallet          TEXT         NOT NULL,\n    10→  game            TEXT         NOT NULL,\n    11→  match_id        TEXT         NOT NULL,\n    12→  event           TEXT         NOT NULL,\n    13→  amount_lamports BIGINT       NOT NULL,\n    14→  tx_sig          TEXT,\n    15→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    16→);\n    17→\n    18→-- Paginated history by wallet\n    19→CREATE INDEX IF NOT EXISTS idx_user_tx_wallet_created\n    20→  ON user_transactions (wallet, created_at DESC);\n    21→\n    22→-- Dedup / lookup by match_id\n    23→CREATE INDEX IF NOT EXISTS idx_user_tx_match_id\n    24→  ON user_transactions (match_id);\n    25→\n    26→-- Idempotency guard — ON CONFLICT DO NOTHING target\n    27→ALTER TABLE user_transactions\n    28→  ADD CONSTRAINT uq_user_tx_wallet_match_event\n    29→  UNIQUE (wallet, match_id, event);\n    30→"}]},"parent_tool_use_id":null,"session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"377c52b0-8821-4b15-94d0-ef2f97ff1375","timestamp":"2026-03-19T21:53:53.235Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/008_user_transactions.sql","content":"-- 008_user_transactions.sql — Player transaction history ledger.\n--\n-- One row per user-visible game event (join, win, loss, refund).\n-- Used by the profile transactions API. Idempotent writes via\n-- UNIQUE constraint on (wallet, match_id, event).\n\nCREATE TABLE IF NOT EXISTS user_transactions (\n  id              BIGSERIAL    PRIMARY KEY,\n  wallet          TEXT         NOT NULL,\n  game            TEXT         NOT NULL,\n  match_id        TEXT         NOT NULL,\n  event           TEXT         NOT NULL,\n  amount_lamports BIGINT       NOT NULL,\n  tx_sig          TEXT,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\n-- Paginated history by wallet\nCREATE INDEX IF NOT EXISTS idx_user_tx_wallet_created\n  ON user_transactions (wallet, created_at DESC);\n\n-- Dedup / lookup by match_id\nCREATE INDEX IF NOT EXISTS idx_user_tx_match_id\n  ON user_transactions (match_id);\n\n-- Idempotency guard — ON CONFLICT DO NOTHING target\nALTER TABLE user_transactions\n  ADD CONSTRAINT uq_user_tx_wallet_match_event\n  UNIQUE (wallet, match_id, event);\n","numLines":30,"startLine":1,"totalLines":30}}}
