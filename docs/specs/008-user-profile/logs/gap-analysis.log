{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WGdhf2dbB9jDHQK6G8eLSj","type":"tool_result","content":"     1→/**\n     2→ * Local E2E test: profile transactions after coinflip settlement.\n     3→ *\n     4→ * Plays a coinflip match to completion, then navigates to the profile page\n     5→ * and verifies that transaction rows (join + win/loss) appear in the\n     6→ * Transactions tab.\n     7→ *\n     8→ * Prerequisites (handled by run-e2e-local.sh):\n     9→ * - solana-test-validator running with deployed programs\n    10→ * - Backend running with postgres + migrations applied (including user_transactions)\n    11→ * - Test wallets funded\n    12→ */\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import { fundTestWallets } from \"./helpers/wallets\";\n    16→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    17→\n    18→// Selectors for profile page elements\n    19→const profileSel = {\n    20→  header: \".profile-page__header\",\n    21→  tab: (label: string) => `button:has-text(\"${label}\")`,\n    22→  txTable: \".profile-transactions__table\",\n    23→  txRows: \".profile-transactions__table tbody tr\",\n    24→  txEmpty: \".profile-transactions__empty\",\n    25→  txSkeleton: \".profile-transactions__skeleton\",\n    26→  matchLink: \".profile-transactions__match-link\",\n    27→};\n    28→\n    29→test.describe(\"Profile transactions\", () => {\n    30→  test.describe.configure({ mode: \"serial\" });\n    31→\n    32→  test.beforeAll(async () => {\n    33→    await fundTestWallets();\n    34→    await initializeLocalnet();\n    35→  });\n    36→\n    37→  test(\"shows transaction history after coinflip settlement\", async ({\n    38→    playerAPage,\n    39→    playerBPage,\n    40→  }) => {\n    41→    const consoleA = po.trackConsoleErrors(playerAPage);\n    42→\n    43→    // ── Step 1: Play a coinflip match to generate transaction data ──\n    44→\n    45→    await po.navigateToCoinflip(playerAPage);\n    46→    await po.createMatch(playerAPage, \"iron\", \"heads\");\n    47→\n    48→    await po.navigateToCoinflip(playerBPage);\n    49→    await po.waitForLobbyMatch(playerBPage);\n    50→    await po.joinMatch(playerBPage);\n    51→\n    52→    // Wait for backend settlement\n    53→    await Promise.all([\n    54→      po.waitForResult(playerAPage, 30_000),\n    55→      po.waitForResult(playerBPage, 30_000),\n    56→    ]);\n    57→\n    58→    // ── Step 2: Navigate Player A to profile page ──\n    59→    // After page.goto(), the SPA reloads. SessionContext will restore\n    60→    // the session from the refresh token in localStorage (network call\n    61→    // to /auth/refresh or /auth/verify). We wait for that to complete\n    62→    // before clicking the Transactions tab, so the token is available\n    63→    // when useTransactions mounts.\n    64→\n    65→    const authDone = playerAPage.waitForResponse(\n    66→      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n    67→      { timeout: 15_000 },\n    68→    );\n    69→    await playerAPage.goto(\"/profile\");\n    70→    await authDone;\n    71→\n    72→    // Wait for profile header to confirm page rendered\n    73→    await expect(\n    74→      playerAPage.locator(profileSel.header),\n    75→    ).toBeVisible({ timeout: 10_000 });\n    76→\n    77→    // ── Step 3: Click Transactions tab ──\n    78→    await playerAPage.click(profileSel.tab(\"Transactions\"));\n    79→\n    80→    // ── Step 4: Wait for transaction table to appear ──\n    81→    // (not loading skeleton, not empty state)\n    82→    const table = playerAPage.locator(profileSel.txTable);\n    83→    await expect(table).toBeVisible({ timeout: 10_000 });\n    84→\n    85→    // ── Step 5: Verify Player A has exactly 2 rows: join + win/loss ──\n    86→    const rows = playerAPage.locator(profileSel.txRows);\n    87→    await expect(rows).toHaveCount(2, { timeout: 5_000 });\n    88→\n    89→    // ── Step 6: Verify game name ──\n    90→    // API returns game = \"coinflip\", GAME_NAMES maps it to \"Flip You\"\n    91→    const firstLink = playerAPage.locator(profileSel.matchLink).first();\n    92→    await expect(firstLink).toContainText(\"Flip You\");\n    93→\n    94→    // ── Step 7: Verify event types ──\n    95→    const tableText = await table.textContent();\n    96→    expect(tableText).toContain(\"JOIN\");\n    97→    // Player A is either winner or loser — check for WIN or LOSS\n    98→    const hasOutcome =\n    99→      tableText?.includes(\"WIN\") || tableText?.includes(\"LOSS\");\n   100→    expect(hasOutcome).toBe(true);\n   101→\n   102→    // ── Step 8: Verify amounts display in SOL ──\n   103→    expect(tableText).toContain(\"SOL\");\n   104→\n   105→    // ── Step 9: Verify match deep-links ──\n   106→    // Each transaction row should link to /coinflip/:matchId\n   107→    const links = playerAPage.locator(profileSel.matchLink);\n   108→    const linkCount = await links.count();\n   109→    for (let i = 0; i < linkCount; i++) {\n   110→      const href = await links.nth(i).getAttribute(\"href\");\n   111→      expect(href).toMatch(/^\\/coinflip\\/.+/);\n   112→    }\n   113→\n   114→    // No unexpected console errors\n   115→    consoleA.assertClean();\n   116→  });\n   117→});\n   118→"}]},"parent_tool_use_id":"toolu_012r4bHWdjpqbZ8wTpLbiUVJ","session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"dd475edd-c38c-4f0a-8916-e146a71870e8","timestamp":"2026-03-19T21:50:38.693Z"}
