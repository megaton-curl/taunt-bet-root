{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01Mwpw5YXR7SrU13k8RxFHD8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VN9Pw2B4DdUGNzeGbeUHBr","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts","offset":400,"limit":250},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":4,"cache_creation_input_tokens":3819,"cache_read_input_tokens":63199,"cache_creation":{"ephemeral_5m_input_tokens":3819,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01Y6hQ138njMcrbtGDY1z6VT","session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"a900abc1-15de-4f46-9d08-d5a694b0cc95"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VN9Pw2B4DdUGNzeGbeUHBr","type":"tool_result","content":"   400→      } else if (hermesPrice.price > round.openPrice) {\n   401→        remainingAccounts = round.greenEntries.map((e) => e.player);\n   402→      } else {\n   403→        remainingAccounts = round.redEntries.map((e) => e.player);\n   404→      }\n   405→\n   406→      const ix = buildCloseCallSettleRoundIx(\n   407→        serverKeypair.publicKey,\n   408→        minuteTs,\n   409→        hermesPrice.price,\n   410→        hermesPrice.expo,\n   411→        treasury,\n   412→        remainingAccounts,\n   413→      );\n   414→\n   415→      const { blockhash, lastValidBlockHeight } =\n   416→        await connection.getLatestBlockhash();\n   417→      const tx = new Transaction({\n   418→        feePayer: serverKeypair.publicKey,\n   419→        blockhash,\n   420→        lastValidBlockHeight,\n   421→      });\n   422→      tx.add(ix);\n   423→      tx.sign(serverKeypair);\n   424→\n   425→      const sig = await sendAndConfirm(tx, \"settle\");\n   426→\n   427→      const outcomeStr = isRefund\n   428→        ? \"refund\"\n   429→        : hermesPrice.price > round.openPrice\n   430→          ? \"green\"\n   431→          : \"red\";\n   432→\n   433→      logger.info(\"closecall clock: round settled\", {\n   434→        pda: roundPda.toBase58(),\n   435→        tx: sig,\n   436→        totalEntries: totalCount,\n   437→        outcome: outcomeStr,\n   438→      });\n   439→\n   440→      // Persist settlement to DB\n   441→      try {\n   442→        // Ensure round record exists (may not if created before DB persistence was added)\n   443→        await sql`\n   444→          INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo, phase, created_at)\n   445→          VALUES (\n   446→            ${String(Number(minuteTs))},\n   447→            ${roundPda.toBase58()},\n   448→            ${serverKeypair.publicKey.toBase58()},\n   449→            ${Number(round.openPrice)},\n   450→            ${round.openPriceExpo},\n   451→            'open',\n   452→            NOW()\n   453→          )\n   454→          ON CONFLICT (round_id) DO NOTHING\n   455→        `;\n   456→\n   457→        // Format entries for JSONB storage\n   458→        const greenEntries = round.greenEntries.map((e) => ({\n   459→          player: e.player.toBase58(),\n   460→          amountLamports: Number(e.amountLamports),\n   461→        }));\n   462→        const redEntries = round.redEntries.map((e) => ({\n   463→          player: e.player.toBase58(),\n   464→          amountLamports: Number(e.amountLamports),\n   465→        }));\n   466→\n   467→        // Compute fee off-chain (on-chain totalFee is only set after settle,\n   468→        // but we read the account BEFORE settlement, so it's still 0).\n   469→        // Fee = 3% (300 bps) of total pool, truncated. 0 for refund rounds.\n   470→        const totalPool = Number(round.greenPool) + Number(round.redPool);\n   471→        const computedFee = isRefund ? 0 : Math.floor(totalPool * 300 / 10_000);\n   472→\n   473→        // Update with settlement data\n   474→        await sql`\n   475→          UPDATE closecall_rounds SET\n   476→            phase = ${isRefund ? \"refunded\" : \"settled\"},\n   477→            outcome = ${outcomeStr},\n   478→            close_price = ${Number(hermesPrice.price)},\n   479→            green_pool = ${Number(round.greenPool)},\n   480→            red_pool = ${Number(round.redPool)},\n   481→            total_fee = ${computedFee},\n   482→            green_entries = ${sql.json(greenEntries)},\n   483→            red_entries = ${sql.json(redEntries)},\n   484→            settle_tx = ${sig},\n   485→            settled_at = NOW()\n   486→          WHERE round_id = ${String(Number(minuteTs))}\n   487→        `;\n   488→\n   489→        // Write user transaction rows (join + outcome per entry)\n   490→        const roundId = String(Number(minuteTs));\n   491→        const netPool = totalPool - computedFee;\n   492→\n   493→        const doInsert = (\n   494→          wallet: string,\n   495→          event: string,\n   496→          amount: number,\n   497→        ) =>\n   498→          sql`\n   499→            INSERT INTO user_transactions (wallet, game, match_id, event, amount_lamports, tx_sig)\n   500→            VALUES (${wallet}, 'closecall', ${roundId}, ${event}, ${amount}, ${sig})\n   501→            ON CONFLICT DO NOTHING\n   502→          `;\n   503→\n   504→        const userTxInserts: Promise<unknown>[] = [];\n   505→\n   506→        for (const entry of greenEntries) {\n   507→          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n   508→          if (isRefund) {\n   509→            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n   510→          } else if (outcomeStr === \"green\") {\n   511→            const greenPool = Number(round.greenPool);\n   512→            const payout = greenPool > 0\n   513→              ? Math.floor((entry.amountLamports / greenPool) * netPool)\n   514→              : 0;\n   515→            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n   516→          } else {\n   517→            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n   518→          }\n   519→        }\n   520→\n   521→        for (const entry of redEntries) {\n   522→          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n   523→          if (isRefund) {\n   524→            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n   525→          } else if (outcomeStr === \"red\") {\n   526→            const redPool = Number(round.redPool);\n   527→            const payout = redPool > 0\n   528→              ? Math.floor((entry.amountLamports / redPool) * netPool)\n   529→              : 0;\n   530→            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n   531→          } else {\n   532→            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n   533→          }\n   534→        }\n   535→\n   536→        if (userTxInserts.length > 0) {\n   537→          await Promise.all(userTxInserts);\n   538→        }\n   539→      } catch (dbErr) {\n   540→        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n   541→          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n   542→        });\n   543→      }\n   544→\n   545→      return true;\n   546→    } catch (err) {\n   547→      logger.error(\"closecall clock: settlement failed\", {\n   548→        pda: roundPda.toBase58(),\n   549→        error: err instanceof Error ? err.message : String(err),\n   550→      });\n   551→      return false;\n   552→    }\n   553→  }\n   554→\n   555→  // -----------------------------------------------------------------------\n   556→  // Tick — fires at minute boundary + 1s\n   557→  // -----------------------------------------------------------------------\n   558→\n   559→  async function tick(): Promise<void> {\n   560→    const t0 = performance.now();\n   561→    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n   562→\n   563→    // Step 1: Capture boundary price (poll Hermes until fresh)\n   564→    await captureBoundaryPrice(boundaryTs);\n   565→\n   566→    // Step 2: Discover + settle all open rounds whose candle has closed\n   567→    const openRounds = await discoverOpenRounds();\n   568→\n   569→    for (const { pda, minuteTs, round } of openRounds) {\n   570→      await settleRound(pda, minuteTs, round);\n   571→    }\n   572→\n   573→    const elapsed = Math.round(performance.now() - t0);\n   574→    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n   575→  }\n   576→\n   577→  async function loop(): Promise<void> {\n   578→    if (!running) return;\n   579→    try {\n   580→      await tick();\n   581→    } catch (err) {\n   582→      logger.error(\"closecall clock loop error\", {\n   583→        error: err instanceof Error ? err.message : String(err),\n   584→      });\n   585→    }\n   586→    if (running) {\n   587→      const delay = msUntilNextBoundary();\n   588→      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n   589→      timeoutId = setTimeout(loop, delay);\n   590→    }\n   591→  }\n   592→\n   593→  // -----------------------------------------------------------------------\n   594→  // Public interface\n   595→  // -----------------------------------------------------------------------\n   596→\n   597→  return {\n   598→    start() {\n   599→      if (running) return;\n   600→      running = true;\n   601→\n   602→      logger.info(\"closecall clock started\", {\n   603→        serverKey: serverKeypair.publicKey.toBase58(),\n   604→        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n   605→      });\n   606→\n   607→      // Load latest boundary price from DB, then schedule first tick\n   608→      loadLatestBoundaryFromDb()\n   609→        .then(() => {\n   610→          if (!running) return;\n   611→          const delay = msUntilNextBoundary();\n   612→          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n   613→          timeoutId = setTimeout(loop, delay);\n   614→        })\n   615→        .catch((err) => {\n   616→          logger.error(\"closecall clock: startup init failed\", {\n   617→            error: err instanceof Error ? err.message : String(err),\n   618→          });\n   619→          if (running) {\n   620→            const delay = msUntilNextBoundary();\n   621→            timeoutId = setTimeout(loop, delay);\n   622→          }\n   623→        });\n   624→    },\n   625→\n   626→    stop() {\n   627→      running = false;\n   628→      if (timeoutId) {\n   629→        clearTimeout(timeoutId);\n   630→        timeoutId = null;\n   631→      }\n   632→      logger.info(\"closecall clock stopped\");\n   633→    },\n   634→\n   635→    get isRunning() {\n   636→      return running;\n   637→    },\n   638→\n   639→    tick,\n   640→\n   641→    getLatestBoundaryPrice(): BoundaryPrice | null {\n   642→      return cachedBoundaryPrice;\n   643→    },\n   644→  };\n   645→}\n   646→"}]},"parent_tool_use_id":"toolu_01Y6hQ138njMcrbtGDY1z6VT","session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"96164fc7-a6f6-41da-b73a-a2f7cc7c9ea7","timestamp":"2026-03-19T21:50:43.598Z"}
