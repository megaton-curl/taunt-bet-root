→      });\n    88→    });\n    89→\n    90→    test(\"transactions tab — empty state\", async ({ stablePage }) => {\n    91→      await stablePage.addInitScript(() => {\n    92→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n    93→      });\n    94→      await stablePage.goto(\"/profile\");\n    95→\n    96→      // Connect wallet\n    97→      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n    98→      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n    99→        timeout: 5000,\n   100→      });\n   101→\n   102→      // Click the Transactions tab\n   103→      await stablePage\n   104→        .locator(\".profile-page__tab\", { hasText: \"Transactions\" })\n   105→        .click();\n   106→\n   107→      // Wait for the transactions empty state to render\n   108→      await stablePage.waitForSelector(\".profile-transactions__empty\", {\n   109→        timeout: 5000,\n   110→      });\n   111→\n   112→      // Re-inject animation freeze CSS\n   113→      await stablePage.addStyleTag({\n   114→        content: `\n   115→          *, *::before, *::after {\n   116→            animation-duration: 0s !important;\n   117→            animation-delay: 0s !important;\n   118→            transition-duration: 0s !important;\n   119→            transition-delay: 0s !important;\n   120→            scroll-behavior: auto !important;\n   121→          }\n   122→          svg { animation-play-state: paused !important; }\n   123→        `,\n   124→      });\n   125→\n   126→      await stablePage.waitForTimeout(300);\n   127→\n   128→      await expect(stablePage).toHaveScreenshot(\n   129→        \"profile-transactions-empty.png\",\n   130→        {\n   131→          fullPage: true,\n   132→          maxDiffPixelRatio: 0.03,\n   133→        },\n   134→      );\n   135→    });\n   136→  });\n   137→\n   138→  test.describe(\"Lord of the RNGs page\", () => {\n   139→    test(\"round lobby — wallet disconnected\", async 