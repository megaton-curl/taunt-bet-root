 entry of greenEntries) {\n          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n          if (isRefund) {\n            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n          } else if (outcomeStr === \"green\") {\n            const greenPool = Number(round.greenPool);\n            const payout = greenPool > 0\n              ? Math.floor((entry.amountLamports / greenPool) * netPool)\n              : 0;\n            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n          } else {\n            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n          }\n        }\n\n        for (const entry of redEntries) {\n          userTxInserts.push(doInsert(entry.player, \"join\", entry.amountLamports));\n          if (isRefund) {\n            userTxInserts.push(doInsert(entry.player, \"refund\", entry.amountLamports));\n          } else if (outcomeStr === \"red\") {\n            const redPool = Number(round.redPool);\n            const payout = redPool > 0\n              ? Math.floor((entry.amountLamports / redPool) * netPool)\n              : 0;\n            userTxInserts.push(doInsert(entry.player, \"win\", payout));\n          } else {\n            userTxInserts.push(doInsert(entry.player, \"loss\", entry.amountLamports));\n          }\n        }\n\n        if (userTxInserts.length > 0) {\n          await Promise.all(userTxInserts);\n        }\n      } catch (dbErr) {\n        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n        });\n      }\n","numLines":60,"startLine":485,"totalLines":646}}}
