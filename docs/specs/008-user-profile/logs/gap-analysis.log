{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014ZT8vRzGemBBu9YZdTGDmF","type":"tool_result","content":"   400→\n   401→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   402→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   403→  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n   404→  const { treasury } = lordConfig;\n   405→\n   406→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   407→  const resultHash = deriveResult(\n   408→    secret,\n   409→    entropy,\n   410→    roundPubkey.toBuffer(),\n   411→    roundData.algorithmVer,\n   412→  );\n   413→  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n   414→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   415→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   416→\n   417→  const raw = resultHash.readBigUInt64LE(0);\n   418→  const winningOffset = raw % roundData.totalAmountLamports;\n   419→\n   420→  let cumulative = 0n;\n   421→  let winnerEntryIndex = -1;\n   422→  let winner = roundData.entries[0]?.player;\n   423→  for (const [index, entry] of roundData.entries.entries()) {\n   424→    cumulative += entry.amountLamports;\n   425→    if (winningOffset < cumulative) {\n   426→      winnerEntryIndex = index;\n   427→      winner = entry.player;\n   428→      break;\n   429→    }\n   430→  }\n   431→\n   432→  if (!winner || winnerEntryIndex < 0) {\n   433→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   434→  }\n   435→\n   436→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   437→  const instruction = new TransactionInstruction({\n   438→    keys: [\n   439→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   440→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   441→      { pubkey: configPda, isSigner: false, isWritable: false },\n   442→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   443→      { pubkey: treasury, isSigner: false, isWritable: true },\n   444→      { pubkey: winner, isSigner: false, isWritable: true },\n   445→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   446→    ],\n   447→    programId: LORDOFRNGS_PROGRAM_ID,\n   448→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   449→  });\n   450→\n   451→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   452→  const tx = new Transaction({\n   453→    feePayer: serverKeypair.publicKey,\n   454→    blockhash,\n   455→    lastValidBlockHeight,\n   456→  });\n   457→  tx.add(instruction);\n   458→  tx.sign(serverKeypair);\n   459→\n   460→  const tBuild = performance.now();\n   461→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   462→    skipPreflight: false,\n   463→  });\n   464→  const tSend = performance.now();\n   465→\n   466→  logger.info(\"lord settlement transaction submitted\", {\n   467→    pda,\n   468→    txSignature,\n   469→    attempt: round.settle_attempts + 1,\n   470→    winningEntryIndex: winnerEntryIndex,\n   471→    dbMs: Math.round(tDb - t0),\n   472→    fetchMs: Math.round(tFetch - tDb),\n   473→    buildMs: Math.round(tBuild - tFetch),\n   474→    sendMs: Math.round(tSend - tBuild),\n   475→  });\n   476→\n   477→  const confirmation = await connection.confirmTransaction(\n   478→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   479→    \"confirmed\",\n   480→  );\n   481→  const tConfirm = performance.now();\n   482→  if (confirmation.value.err) {\n   483→    throw new TransientSettleError(\n   484→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   485→    );\n   486→  }\n   487→\n   488→  const serializedEntries = roundData.entries.map((e) => ({\n   489→    player: e.player.toBase58(),\n   490→    amountLamports: Number(e.amountLamports),\n   491→  }));\n   492→\n   493→  await db.updateRoundPhase(pda, \"settled\", {\n   494→    settle_tx: txSignature,\n   495→    result_hash: resultHash,\n   496→    result_side: winnerEntryIndex,\n   497→    winner: winner.toBase58(),\n   498→    settle_attempts: round.settle_attempts + 1,\n   499→  });\n   500→\n   501→  // Persist entries in dedicated JSONB column for direct access\n   502→  await db.updateRoundEntries(pda, serializedEntries);\n   503→\n   504→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   505→    txSignature,\n   506→    winner: winner.toBase58(),\n   507→    winningEntryIndex: winnerEntryIndex,\n   508→    game: \"lord\",\n   509→    entropy: entropy.toString(\"hex\"),\n   510→    winningOffset: winningOffset.toString(),\n   511→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   512→    payoutAmount,\n   513→    feeAmount,\n   514→    rentRefund,\n   515→    entries: serializedEntries,\n   516→  });\n   517→\n   518→  // Write user transactions — win for winner, loss for each losing entry\n   519→  const userTxInserts = [\n   520→    db.insertUserTransaction({\n   521→      wallet: winner.toBase58(),\n   522→      game: \"lord\",\n   523→      matchId: round.match_id,\n   524→      event: \"win\",\n   525→      amountLamports: payoutAmount,\n   526→      txSig: txSignature,\n   527→    }),\n   528→  ];\n   529→  for (const entry of roundData.entries) {\n   530→    if (!entry.player.equals(winner)) {\n   531→      userTxInserts.push(\n   532→        db.insertUserTransaction({\n   533→          wallet: entry.player.toBase58(),\n   534→          game: \"lord\",\n   535→          matchId: round.match_id,\n   536→          event: \"loss\",\n   537→          amountLamports: Number(entry.amountLamports),\n   538→          txSig: txSignature,\n   539→        }),\n   540→      );\n   541→    }\n   542→  }\n   543→  await Promise.all(userTxInserts);\n   544→\n   545→  const tDone = performance.now();\n   546→  logger.info(\"lord settlement transaction confirmed\", {\n   547→    pda,\n   548→    txSignature,\n   549→    winner: winner.toBase58(),\n   550→    winningEntryIndex: winnerEntryIndex,\n   551→    timing: {\n   552→      dbMs: Math.round(tDb - t0),\n   553→      fetchMs: Math.round(tFetch - tDb),\n   554→      buildMs: Math.round(tBuild - tFetch),\n   555→      sendMs: Math.round(tSend - tBuild),\n   556→      confirmMs: Math.round(tConfirm - tSend),\n   557→      dbWriteMs: Math.round(tDone - tConfirm),\n   558→      totalMs: Math.round(tDone - t0),\n   559→    },\n   560→  });\n   561→\n   562→  return {\n   563→    txSignature,\n   564→    resultHash,\n   565→    winningEntryIndex: winnerEntryIndex,\n   566→    winner: winner.toBase58(),\n   567→  };\n   568→}\n   569→\n   570→export async function settleRound(\n   571→  deps: SettleTxDeps,\n   572→  pda: string,\n   573→): Promise<SettleResult> {\n   574→  const round = await deps.db.getRoundByPda(pda);\n   575→  if (!round) {\n   576→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   577→  }\n   578→\n   579→  if (round.game === \"lord\") {\n   580→    return settleLordRound(deps, pda);\n   581→  }\n   582→\n   583→  return settleMatch(deps, pda);\n   584→}\n   585→\n   586→// ---------------------------------------------------------------------------\n   587→// Close Call — transaction builders\n   588→// ---------------------------------------------------------------------------\n   589→\n   590→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   591→  return PublicKey.findProgramAddressSync(\n   592→    [Buffer.from(\"closecall_config\")],\n   593→    CLOSECALL_PROGRAM_ID,\n   594→  );\n   595→}\n   596→\n   597→function minuteTsToBuffer(ts: bigint): Buffer {\n   598→  const buf = Buffer.alloc(8);\n   599→  buf.writeBigInt64LE(ts);"}]},"parent_tool_use_id":"toolu_01Y6hQ138njMcrbtGDY1z6VT","session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"c1b2ec30-4ac8-4400-ab98-b81d2bdd9977","timestamp":"2026-03-19T21:50:39.128Z"}
