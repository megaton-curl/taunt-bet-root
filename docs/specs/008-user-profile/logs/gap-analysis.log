\n   313→\n   314→      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n   315→      await stablePage.addStyleTag({\n   316→        content: `\n   317→          *, *::before, *::after {\n   318→            animation-duration: 0s !important;\n   319→            animation-delay: 0s !important;\n   320→            transition-duration: 0s !important;\n   321→            transition-delay: 0s !important;\n   322→            scroll-behavior: auto !important;\n   323→          }\n   324→          svg { animation-play-state: paused !important; }\n   325→        `,\n   326→      });\n   327→\n   328→      // Settle time for UI to stabilize\n   329→      await stablePage.waitForTimeout(300);\n   330→\n   331→      await expect(stablePage).toHaveScreenshot(\"coinflip-connected.png\", { fullPage: true });\n   332→    });\n   333→\n   334→    test(\"error toast below middle container\", async ({ stablePage }) => {\n   335→      await stablePage.addInitScript(() => {\n   336→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   337→      });\n   338→      await stablePage.goto(\"/coinflip\");\n   339→\n   340→      // Inject a representative error toast at runtime so placement is snapshot-tested.\n   341→      await stablePage.evaluate(() => {\n   342→        const existing = document.querySelector(\".coinflip-error-toast\");\n   343→        if (existing) existing.remove();\n   344→\n   345→        const wrapper = document.createElement(\"div\");\n   346→        wrapper.className = \"coinflip-error-toast\";\n   347→\n   348→        const toast = document.createElement(\"div\");\n   349→        toast.className = \"rng-toast rng-toast--error\";\n   350→        toast.setAttribute(\"role\", \"alert\");\n   351→\n   352→        const message = document.createElement(\"span\");\n   353→        message.className = \"rng-toast__message\";\n   354→        message.textContent = \"Transaction cancelled by user.\";\n   355→\n   356→        const close = document.createElement(\"button\");\n   357→        close.className = \"rng-toast__close\";\n   358→        close.setAttribute(\"type\", \"button\");\n   359→        close.textContent = \"×\";\n   360→\n   361→        toast.append(message, close);\n   362→        wrapper.appendChild(toast);\n   363→        document.body.appendChild(wrapper);\n   364→      });\n   365→\n   366→      await stablePage.waitForTimeout(300);\n   367→      await expect(stablePage).toHaveScreenshot(\"coinflip-error-toast-position.png\", { fullPage: true });\n   368→    });\n   369→  });\n   370→});\n   371→"}]},"parent_tool_use_id":"toolu_012r4bHWdjpqbZ8wTpLbiUVJ","session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"d2b4b88c-5b71-42d2-a76b-a17f14bf7d5f","timestamp":"2026-03-19T21:50:39.021Z"}
