{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01Hw763VnpWi2ngJJwgN6zJS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UPkLkhzrfmT16R5n9FkXPd","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/utils/mock-simulation.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":761,"cache_creation_input_tokens":3968,"cache_read_input_tokens":45147,"cache_creation":{"ephemeral_5m_input_tokens":3968,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017gmqeEKf6mhb7ddyR9LufE","session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"786aff00-e3ab-4a93-b89b-a54203faeaf9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UPkLkhzrfmT16R5n9FkXPd","type":"tool_result","content":"     1→/**\n     2→ * Mock Simulation - In-memory profile store for player profiles\n     3→ *\n     4→ * Manages player profile data, XP, stats, loot, and transactions.\n     5→ * Data is stored in memory and persists for the session.\n     6→ */\n     7→\n     8→import type {\n     9→  AvatarId,\n    10→  GameId,\n    11→  GameResultEvent,\n    12→  LootItem,\n    13→  LootSource,\n    14→  PlayerProfile,\n    15→  ProfileTransaction,\n    16→} from \"../types\";\n    17→import { AVATAR_CONFIGS, createEmptyStats, getHighestUnlockedAvatar } from \"../types\";\n    18→import { calculateGameXP, getXPProgress, getXPForLevel } from \"./xp-calculator\";\n    19→\n    20→// ============ Random Username Generator ============\n    21→\n    22→const USERNAME_ADJECTIVES = [\n    23→  \"Lucky\", \"Swift\", \"Brave\", \"Cosmic\", \"Neon\", \"Cyber\", \"Pixel\", \"Crypto\",\n    24→  \"Shadow\", \"Thunder\", \"Golden\", \"Silver\", \"Diamond\", \"Mystic\", \"Turbo\", \"Mega\",\n    25→  \"Ultra\", \"Super\", \"Hyper\", \"Epic\", \"Savage\", \"Wild\", \"Blazing\", \"Frozen\",\n    26→  \"Phantom\", \"Stellar\", \"Atomic\", \"Quantum\", \"Nova\", \"Solar\", \"Lunar\", \"Astral\",\n    27→];\n    28→\n    29→const USERNAME_NOUNS = [\n    30→  \"Player\", \"Gamer\", \"Raider\", \"Trader\", \"Flipper\", \"Whale\", \"Shark\", \"Wolf\",\n    31→  \"Dragon\", \"Phoenix\", \"Knight\", \"Wizard\", \"Ninja\", \"Samurai\", \"Viking\", \"Pirate\",\n    32→  \"Hunter\", \"Seeker\", \"Runner\", \"Rider\", \"Degen\", \"Ape\", \"Chad\", \"King\",\n    33→  \"Queen\", \"Ace\", \"Legend\", \"Hero\", \"Master\", \"Boss\", \"Chief\", \"Captain\",\n    34→];\n    35→\n    36→/**\n    37→ * Generate a random username like \"CosmicWhale42\" or \"NeonDragon17\"\n    38→ */\n    39→function generateRandomUsername(): string {\n    40→  const adjective = USERNAME_ADJECTIVES[Math.floor(Math.random() * USERNAME_ADJECTIVES.length)];\n    41→  const noun = USERNAME_NOUNS[Math.floor(Math.random() * USERNAME_NOUNS.length)];\n    42→  const number = Math.floor(Math.random() * 100);\n    43→  return `${adjective}${noun}${number}`;\n    44→}\n    45→\n    46→/**\n    47→ * Generate a random level with weighted distribution.\n    48→ * Most players are lower level, with fewer high-level players.\n    49→ */\n    50→function generateRandomLevel(): number {\n    51→  const rand = Math.random();\n    52→  // Weighted distribution: 50% levels 1-15, 30% levels 16-40, 15% levels 41-70, 5% levels 71-100\n    53→  if (rand < 0.5) {\n    54→    return Math.floor(Math.random() * 15) + 1; // 1-15\n    55→  } else if (rand < 0.8) {\n    56→    return Math.floor(Math.random() * 25) + 16; // 16-40\n    57→  } else if (rand < 0.95) {\n    58→    return Math.floor(Math.random() * 30) + 41; // 41-70\n    59→  } else {\n    60→    return Math.floor(Math.random() * 30) + 71; // 71-100\n    61→  }\n    62→}\n    63→\n    64→/**\n    65→ * Get a random unlocked avatar for a given level.\n    66→ * Picks randomly from all avatars the player could have unlocked.\n    67→ */\n    68→function getRandomUnlockedAvatar(level: number): AvatarId {\n    69→  const unlockedAvatars = AVATAR_CONFIGS.filter(a => a.unlockLevel <= level);\n    70→  if (unlockedAvatars.length === 0) return \"recruit\";\n    71→  const randomIndex = Math.floor(Math.random() * unlockedAvatars.length);\n    72→  return unlockedAvatars[randomIndex]?.id ?? \"recruit\";\n    73→}\n    74→\n    75→// ============ Store ============\n    76→\n    77→interface ProfileStore {\n    78→  profiles: Map<string, PlayerProfile>;\n    79→  transactions: Map<string, ProfileTransaction[]>;\n    80→  profileListeners: Set<(address: string, profile: PlayerProfile) => void>;\n    81→  isInitialized: boolean;\n    82→}\n    83→\n    84→const store: ProfileStore = {\n    85→  profiles: new Map(),\n    86→  transactions: new Map(),\n    87→  profileListeners: new Set(),\n    88→  isInitialized: false,\n    89→};\n    90→\n    91→// ============ Initialization ============\n    92→\n    93→/**\n    94→ * Initialize the profile store. Called once on app start.\n    95→ */\n    96→export function initializeProfileStore(): void {\n    97→  if (store.isInitialized) return;\n    98→\n    99→  // Generate some mock profiles for other players\n   100→  generateMockProfiles();\n   101→\n   102→  store.isInitialized = true;\n   103→}\n   104→\n   105→/**\n   106→ * Generate mock profiles for demonstration purposes.\n   107→ */\n   108→function generateMockProfiles(): void {\n   109→  const mockPlayers = [\n   110→    { address: \"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"CryptoKing\", level: 72 },\n   111→    { address: \"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"LuckyDice\", level: 15 },\n   112→    { address: \"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"WhaleWatch\", level: 45 },\n   113→    { address: \"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: null, level: 3 },\n   114→    { address: \"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"RNGMaster\", level: 88 },\n   115→    { address: \"DemoPlayer6xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"VoidWalker\", level: 25 },\n   116→    { address: \"DemoPlayer7xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"ShamanKing\", level: 55 },\n   117→    { address: \"DemoPlayer8xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\", username: \"TheParagon\", level: 35 },\n   118→  ];\n   119→\n   120→  for (const mock of mockPlayers) {\n   121→    // Calculate proper XP for the level\n   122→    const totalXP = getXPForLevel(mock.level) + Math.floor(Math.random() * 200);\n   123→    const xpProgress = getXPProgress(totalXP);\n   124→    const profile = createProfile(mock.address);\n   125→    profile.username = mock.username;\n   126→    profile.level = mock.level;\n   127→    profile.totalXP = totalXP;\n   128→    profile.currentXP = xpProgress.currentXP;\n   129→    // Assign the highest unlocked avatar for their level\n   130→    profile.avatarId = getHighestUnlockedAvatar(mock.level);\n   131→\n   132→    // Add some random stats\n   133→    profile.stats.gamesPlayed = Math.floor(Math.random() * 200) + 10;\n   134→    profile.stats.totalWagered = Math.random() * 100 + 5;\n   135→    profile.stats.wins = Math.floor(profile.stats.gamesPlayed * (0.4 + Math.random() * 0.2));\n   136→    profile.stats.losses = profile.stats.gamesPlayed - profile.stats.wins;\n   137→    profile.stats.totalWins = profile.stats.totalWagered * (0.8 + Math.random() * 0.4);\n   138→    profile.stats.netProfit = profile.stats.totalWins - profile.stats.totalWagered;\n   139→    profile.stats.bestWinStreak = Math.floor(Math.random() * 10) + 1;\n   140→    profile.stats.currentWinStreak = Math.floor(Math.random() * profile.stats.bestWinStreak);\n   141→\n   142→    store.profiles.set(mock.address, profile);\n   143→  }\n   144→}\n   145→\n   146→// ============ Profile CRUD ============\n   147→\n   148→/**\n   149→ * Create a new profile for an address with random username, level, and avatar.\n   150→ * @param forceLevel - Optional level to force (for testing). Defaults to random.\n   151→ */\n   152→function createProfile(address: string, forceLevel?: number): PlayerProfile {\n   153→  // Generate level and calculate XP (use forced level if provided)\n   154→  const level = forceLevel ?? generateRandomLevel();\n   155→  const totalXP = getXPForLevel(level) + Math.floor(Math.random() * 200);\n   156→  const xpProgress = getXPProgress(totalXP);\n   157→\n   158→  // Pick a random unlocked avatar for this level\n   159→  const avatarId = getRandomUnlockedAvatar(level);\n   160→\n   161→  // Generate random stats based on level\n   162→  const gamesPlayed = Math.floor(Math.random() * (level * 5)) + level;\n   163→  const wins = Math.floor(gamesPlayed * (0.4 + Math.random() * 0.2));\n   164→  const losses = gamesPlayed - wins;\n   165→  const totalWagered = Math.random() * (level * 2) + 1;\n   166→  const totalWins = totalWagered * (0.8 + Math.random() * 0.4);\n   167→  const netProfit = totalWins - totalWagered;\n   168→  const bestWinStreak = Math.floor(Math.random() * Math.min(10, level)) + 1;\n   169→\n   170→  const stats = createEmptyStats();\n   171→  stats.gamesPlayed = gamesPlayed;\n   172→  stats.totalWagered = totalWagered;\n   173→  stats.totalWins = totalWins;\n   174→  stats.netProfit = netProfit;\n   175→  stats.wins = wins;\n   176→  stats.losses = losses;\n   177→  stats.bestWinStreak = bestWinStreak;\n   178→  stats.currentWinStreak = Math.floor(Math.random() * bestWinStreak);\n   179→\n   180→  return {\n   181→    address,\n   182→    username: generateRandomUsername(),\n   183→    avatarId,\n   184→    level,\n   185→    currentXP: xpProgress.currentXP,\n   186→    totalXP,\n   187→    discordUsername: null,\n   188→    twitterHandle: null,\n   189→    stats,\n   190→    unclaimedLoot: [],\n   191→    createdAt: Date.now(),\n   192→    lastActiveAt: Date.now(),\n   193→  };\n   194→}\n   195→\n   196→/**\n   197→ * Get a profile by address. Returns null if not found.\n   198→ */\n   199→export function getProfile(address: string): PlayerProfile | null {\n   200→  return store.profiles.get(address) ?? null;\n   201→}\n   202→\n   203→/**\n   204→ * Get or create a profile for an address.\n   205→ * @param forceLevel - Optional level to force for new profiles (for testing).\n   206→ */\n   207→export function getOrCreateProfile(address: string, forceLevel?: number): PlayerProfile {\n   208→  let profile = store.profiles.get(address);\n   209→  if (!profile) {\n   210→    profile = createProfile(address, forceLevel);\n   211→    store.profiles.set(address, profile);\n   212→    notifyListeners(address, profile);\n   213→  } else if (forceLevel !== undefined && profile.level !== forceLevel) {\n   214→    // Apply forced level to existing profiles (for testing)\n   215→    const totalXP = getXPForLevel(forceLevel) + Math.floor(Math.random() * 200);\n   216→    const xpProgress = getXPProgress(totalXP);\n   217→    profile.level = forceLevel;\n   218→    profile.totalXP = totalXP;\n   219→    profile.currentXP = xpProgress.currentXP;\n   220→    store.profiles.set(address, profile);\n   221→    notifyListeners(address, profile);\n   222→  }\n   223→  return { ...profile };\n   224→}\n   225→\n   226→/**\n   227→ * Update a profile with partial data.\n   228→ */\n   229→export function updateProfile(\n   230→  address: string,\n   231→  updates: Partial<Omit<PlayerProfile, \"address\" | \"createdAt\">>\n   232→): PlayerProfile {\n   233→  const profile = getOrCreateProfile(address);\n   234→  const updatedProfile = {\n   235→    ...profile,\n   236→    ...updates,\n   237→    lastActiveAt: Date.now(),\n   238→  };\n   239→  store.profiles.set(address, updatedProfile);\n   240→  notifyListeners(address, updatedProfile);\n   241→  return { ...updatedProfile };\n   242→}\n   243→\n   244→// ============ Profile Mutations ============\n   245→\n   246→/**\n   247→ * Update username for a profile.\n   248→ */\n   249→export function updateUsername(address: string, username: string | null): PlayerProfile {\n   250→  return updateProfile(address, { username });\n   251→}\n   252→\n   253→/**\n   254→ * Update avatar for a profile.\n   255→ */\n   256→export function updateAvatar(address: string, avatarId: AvatarId): PlayerProfile {\n   257→  return updateProfile(address, { avatarId });\n   258→}\n   259→\n   260→/**\n   261→ * Connect Discord to a profile.\n   262→ */\n   263→export function connectDiscord(address: string, discordUsername: string): PlayerProfile {\n   264→  return updateProfile(address, { discordUsername });\n   265→}\n   266→\n   267→/**\n   268→ * Disconnect Discord from a profile.\n   269→ */\n   270→export function disconnectDiscord(address: string): PlayerProfile {\n   271→  return updateProfile(address, { discordUsername: null });\n   272→}\n   273→\n   274→/**\n   275→ * Connect Twitter to a profile.\n   276→ */\n   277→export function connectTwitter(address: string, twitterHandle: string): PlayerProfile {\n   278→  return updateProfile(address, { twitterHandle });\n   279→}\n   280→\n   281→/**\n   282→ * Disconnect Twitter from a profile.\n   283→ */\n   284→export function disconnectTwitter(address: string): PlayerProfile {\n   285→  return updateProfile(address, { twitterHandle: null });\n   286→}\n   287→\n   288→// ============ XP and Stats ============\n   289→\n   290→/**\n   291→ * Award XP to a player and update their level.\n   292→ */\n   293→export function awardXP(address: string, xp: number): PlayerProfile {\n   294→  const profile = getOrCreateProfile(address);\n   295→  const newTotalXP = profile.totalXP + xp;\n   296→  const xpProgress = getXPProgress(newTotalXP);\n   297→\n   298→  return updateProfile(address, {\n   299→    totalXP: newTotalXP,\n   300→    level: xpProgress.level,\n   301→    currentXP: xpProgress.currentXP,\n   302→  });\n   303→}\n   304→\n   305→/**\n   306→ * Record a game result and update stats accordingly.\n   307→ */\n   308→export function recordGameResult(event: GameResultEvent): void {\n   309→  const profile = getOrCreateProfile(event.playerAddress);\n   310→  const { gameId, wagerAmount, outcome, payoutAmount } = event;\n   311→\n   312→  // Calculate XP earned\n   313→  const xpEarned = calculateGameXP(wagerAmount, outcome === \"win\");\n   314→\n   315→  // Update aggregate stats\n   316→  const newStats = { ...profile.stats };\n   317→  newStats.gamesPlayed += 1;\n   318→  newStats.totalWagered += wagerAmount;\n   319→\n   320→  if (outcome === \"win\") {\n   321→    newStats.wins += 1;\n   322→    newStats.totalWins += payoutAmount;\n   323→    newStats.currentWinStreak += 1;\n   324→    if (newStats.currentWinStreak > newStats.bestWinStreak) {\n   325→      newStats.bestWinStreak = newStats.currentWinStreak;\n   326→    }\n   327→  } else {\n   328→    newStats.losses += 1;\n   329→    newStats.currentWinStreak = 0;\n   330→  }\n   331→\n   332→  newStats.netProfit = newStats.totalWins - newStats.totalWagered;\n   333→\n   334→  // Update per-game stats\n   335→  const gameStats = newStats.gameStats[gameId];\n   336→  gameStats.gamesPlayed += 1;\n   337→  gameStats.wagered += wagerAmount;\n   338→  if (outcome === \"win\") {\n   339→    gameStats.wins += 1;\n   340→    gameStats.winnings += payoutAmount;\n   341→  } else {\n   342→    gameStats.losses += 1;\n   343→  }\n   344→\n   345→  // Update profile with new stats\n   346→  const newTotalXP = profile.totalXP + xpEarned;\n   347→  const xpProgress = getXPProgress(newTotalXP);\n   348→\n   349→  updateProfile(event.playerAddress, {\n   350→    stats: newStats,\n   351→    totalXP: newTotalXP,\n   352→    level: xpProgress.level,\n   353→    currentXP: xpProgress.currentXP,\n   354→  });\n   355→\n   356→  // Record transaction\n   357→  recordTransaction(event);\n   358→}\n   359→\n   360→// ============ Transactions ============\n   361→\n   362→/**\n   363→ * Record a transaction for a game result.\n   364→ * Creates event-based rows matching the API shape (join + outcome).\n   365→ */\n   366→function recordTransaction(event: GameResultEvent): void {\n   367→  const { gameId, matchId, playerAddress, wagerAmount, outcome, payoutAmount, timestamp } = event;\n   368→\n   369→  const now = new Date(timestamp).toISOString();\n   370→  const wagerLamports = String(Math.round(wagerAmount * 1e9));\n   371→  const payoutLamports = String(Math.round(payoutAmount * 1e9));\n   372→\n   373→  const transactions = store.transactions.get(playerAddress) ?? [];\n   374→\n   375→  // Outcome event (most recent first)\n   376→  transactions.unshift({\n   377→    id: `tx-${Date.now()}-${Math.random().toString(36).slice(2, 8)}-out`,\n   378→    gameId,\n   379→    matchId,\n   380→    event: outcome,\n   381→    amountLamports: outcome === \"win\" ? payoutLamports : wagerLamports,\n   382→    txSig: null,\n   383→    createdAt: now,\n   384→  });\n   385→\n   386→  // Join event\n   387→  transactions.unshift({\n   388→    id: `tx-${Date.now()}-${Math.random().toString(36).slice(2, 8)}-join`,\n   389→    gameId,\n   390→    matchId,\n   391→    event: \"join\",\n   392→    amountLamports: wagerLamports,\n   393→    txSig: null,\n   394→    createdAt: now,\n   395→  });\n   396→\n   397→  // Keep only last 100 transactions per player\n   398→  while (transactions.length > 100) transactions.pop();\n   399→\n   400→  store.transactions.set(playerAddress, transactions);\n   401→}\n   402→\n   403→/**\n   404→ * Get transactions for a player.\n   405→ */\n   406→export function getTransactions(address: string, limit = 50): ProfileTransaction[] {\n   407→  const transactions = store.transactions.get(address) ?? [];\n   408→  return transactions.slice(0, limit);\n   409→}\n   410→\n   411→// ============ Loot System ============\n   412→\n   413→/**\n   414→ * Generate a unique loot ID.\n   415→ */\n   416→function generateLootId(): string {\n   417→  return `loot-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n   418→}\n   419→\n   420→/**\n   421→ * Add loot to a player's unclaimed rewards.\n   422→ */\n   423→export function addLoot(\n   424→  address: string,\n   425→  source: LootSource,\n   426→  amount: number,\n   427→  description: string,\n   428→  gameId?: GameId,\n   429→  matchId?: string,\n   430→  expiresAt?: number\n   431→): void {\n   432→  const profile = getOrCreateProfile(address);\n   433→\n   434→  const lootItem: LootItem = {\n   435→    id: generateLootId(),\n   436→    source,\n   437→    amount,\n   438→    description,\n   439→    earnedAt: Date.now(),\n   440→    expiresAt,\n   441→    gameId,\n   442→    matchId,\n   443→  };\n   444→\n   445→  const newUnclaimedLoot = [...profile.unclaimedLoot, lootItem];\n   446→  updateProfile(address, { unclaimedLoot: newUnclaimedLoot });\n   447→}\n   448→\n   449→/**\n   450→ * Claim a specific loot item. Returns the claimed amount.\n   451→ */\n   452→export function claimLoot(address: string, lootId: string): number {\n   453→  const profile = getOrCreateProfile(address);\n   454→  const lootItem = profile.unclaimedLoot.find((l) => l.id === lootId);\n   455→\n   456→  if (!lootItem) {\n   457→    return 0;\n   458→  }\n   459→\n   460→  const newUnclaimedLoot = profile.unclaimedLoot.filter((l) => l.id !== lootId);\n   461→  updateProfile(address, { unclaimedLoot: newUnclaimedLoot });\n   462→\n   463→  return lootItem.amount;\n   464→}\n   465→\n   466→/**\n   467→ * Claim all unclaimed loot. Returns the total claimed amount.\n   468→ */\n   469→export function claimAllLoot(address: string): number {\n   470→  const profile = getOrCreateProfile(address);\n   471→  const totalAmount = profile.unclaimedLoot.reduce((sum, loot) => sum + loot.amount, 0);\n   472→\n   473→  updateProfile(address, { unclaimedLoot: [] });\n   474→\n   475→  return totalAmount;\n   476→}\n   477→\n   478→/**\n   479→ * Get total unclaimed loot amount for a player.\n   480→ */\n   481→export function getUnclaimedLootTotal(address: string): number {\n   482→  const profile = getProfile(address);\n   483→  if (!profile) return 0;\n   484→  return profile.unclaimedLoot.reduce((sum, loot) => sum + loot.amount, 0);\n   485→}\n   486→\n   487→// ============ Subscriptions ============\n   488→\n   489→/**\n   490→ * Subscribe to profile updates.\n   491→ */\n   492→export function subscribeToProfiles(\n   493→  callback: (address: string, profile: PlayerProfile) => void\n   494→): () => void {\n   495→  store.profileListeners.add(callback);\n   496→  return () => {\n   497→    store.profileListeners.delete(callback);\n   498→  };\n   499→}\n   500→\n   501→/**\n   502→ * Notify all listeners of a profile update.\n   503→ */\n   504→function notifyListeners(address: string, profile: PlayerProfile): void {\n   505→  store.profileListeners.forEach((callback) => {\n   506→    try {\n   507→      callback(address, { ...profile });\n   508→    } catch (error) {\n   509→      console.error(\"[ProfileStore] Error in listener:\", error);\n   510→    }\n   511→  });\n   512→}\n   513→\n   514→// ============ Display Helpers ============\n   515→\n   516→/**\n   517→ * Truncate an address for display.\n   518→ */\n   519→export function truncateAddress(address: string): string {\n   520→  if (address.length <= 10) return address;\n   521→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n   522→}\n   523→\n   524→/**\n   525→ * Get display name for an address.\n   526→ * Creates a profile with a random username if one doesn't exist.\n   527→ */\n   528→export function getDisplayName(address: string): string {\n   529→  const profile = getOrCreateProfile(address);\n   530→  return profile.username ?? truncateAddress(address);\n   531→}\n   532→\n   533→/**\n   534→ * Get avatar ID for an address.\n   535→ * Creates a profile if one doesn't exist.\n   536→ */\n   537→export function getAvatarId(address: string): AvatarId {\n   538→  const profile = getOrCreateProfile(address);\n   539→  return profile.avatarId;\n   540→}\n   541→\n   542→/**\n   543→ * Get level for an address.\n   544→ * Creates a profile if one doesn't exist.\n   545→ */\n   546→export function getLevel(address: string): number {\n   547→  const profile = getOrCreateProfile(address);\n   548→  return profile.level;\n   549→}\n   550→\n   551→// ============ Debug / Testing ============\n   552→\n   553→/**\n   554→ * Clear all profile data (for testing).\n   555→ */\n   556→export function clearAllProfiles(): void {\n   557→  store.profiles.clear();\n   558→  store.transactions.clear();\n   559→  store.isInitialized = false;\n   560→}\n   561→\n   562→/**\n   563→ * Get all profiles (for debugging).\n   564→ */\n   565→export function getAllProfiles(): PlayerProfile[] {\n   566→  return Array.from(store.profiles.values());\n   567→}\n   568→"}]},"parent_tool_use_id":"toolu_017gmqeEKf6mhb7ddyR9LufE","session_id":"b0ecbf70-5847-4896-b164-b75514c07a62","uuid":"2b6d8f56-51e6-4703-925d-78144ec804c5","timestamp":"2026-03-19T21:50:18.725Z"}
