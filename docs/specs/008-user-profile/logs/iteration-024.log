L DEFAULT 'devnet',\n46\t        message TEXT NOT NULL,\n47\t        expires_at TIMESTAMPTZ NOT NULL,\n48\t        used BOOLEAN DEFAULT FALSE,\n49\t        created_at TIMESTAMPTZ DEFAULT now()\n50\t      )\n51\t    `;\n52\t    await rawSql`\n53\t      CREATE TABLE IF NOT EXISTS refresh_tokens (\n54\t        id BIGSERIAL PRIMARY KEY,\n55\t        wallet TEXT NOT NULL,\n56\t        token_hash BYTEA NOT NULL UNIQUE,\n57\t        family_id TEXT NOT NULL,\n58\t        expires_at TIMESTAMPTZ NOT NULL,\n59\t        revoked BOOLEAN DEFAULT FALSE,\n60\t        created_at TIMESTAMPTZ DEFAULT now()\n61\t      )\n62\t    `;\n63\t  });\n64\t\n65\t  afterAll(async () => {\n66\t    await rawSql.end();\n67\t  });\n68\t\n69\t  beforeEach(async () => {\n70\t    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n71\t    authDb = createAuthDb(rawSql);\n72\t    app = new Hono();\n73\t    app.route(\n74\t      \"/auth\",\n75\t      createAuthRoutes({\n76\t        authDb,\n77\t        db: stubDb,\n78\t        jwtSecret: JWT_SECRET,\n79\t        cluster: \"devnet\",\n80\t        challengeTtlSeconds: 300,\n81\t        accessTokenTtlSeconds: 3600,\n82\t        refreshTokenTtlDays: 14,\n83\t      }),\n84\t    );\n85\t  });\n86\t\n87\t  // -----------------------------------------------------------------------\n88\t  // POST /auth/challenge\n89\t  // -----------------------------------------------------------------------\n90\t\n91\t  it(\"returns a challenge with nonce and message\", async () => {\n92\t    const wallet = creatorKeypair.publicKey.toBase58();\n93\t    const res = await app.request(\"/auth/challenge\", {\n94\t      method: \"POST\",\n95\t      headers: { \"Content-Type\": \"application/json\" },\n96\t      body: JSON.stringify({ wallet }),\n97\t    });\n98\t\n99\t    expect(res.status).toBe(200);\n100\t    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n101\t    expect(json.nonce).toBeDefined();\n102\t    expect(json.nonce.length).toBe(64); // 32 bytes hex\n103\t    expect(json.message).toContain(\"Sign in to RNG Utopia\");\n104\t    expect(json.message).toContain(wallet);\n105\t    expect(json.message).toContain(\"devnet\");\n106\t    expect(json.expiresAt).toBeDefined();\n107\t  });\n108\t\n109\t  it(\"rejects challenge with missing wallet\", async () => {\n110\t    const res = await app.request(\"/auth/challenge\", {\n111\t      method: \"POST\",\n112\t      headers: { \"Content-Type\": \"application/json\" },\n113\t      body: JSON.stringify({}),\n114\t    });\n115\t    expect(res.status).toBe(400);\n116\t  });\n117\t\n118\t  // -----------------------------------------------------------------------\n119\t  // Full flow: challenge ‚Üí verify ‚Üí refresh ‚Üí logout\n120\t  // -----------------------------------------------------------------------\n121\t\n122\t  it(\"full auth flow: challenge ‚Üí verify ‚Üí refresh ‚Üí logout\", async () => {\n123\t    const wallet = creatorKeypair.publicKey.toBase58();\n124\t\n125\t    // 1. Request challenge\n126\t    const challengeRes = await app.request(\"/auth/challenge\", {\n127\t      method: \"POST\",\n128\t      headers: { \"Content-Type\": \"application/json\" },\n129\t      body: JSON.stringify({ wallet }),\n130\t    });\n131\t    expect(challengeRes.status).toBe(200);\n132\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n133\t\n134\t    // 2. Sign the message\n135\t    const messageBytes = new TextEncoder().encode(challenge.message);\n136\t    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n137\t    const signature = bs58.encode(signatureBytes);\n138\t\n139\t    // 3. Verify\n140\t    const verifyRes = await app.request(\"/auth/verify\", {\n141\t      method: \"POST\",\n142\t      headers: { \"Content-Type\": \"application/json\" },\n143\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n144\t    });\n145\t    expect(verifyRes.status).toBe(200);\n146\t    const tokens = (await verifyRes.json()) as {\n147\t      accessToken: string;\n148\t      accessExpiresAt: string;\n149\t      refreshToken: string;\n150\t      refreshExpiresAt: string;\n151\t    };\n152\t    expect(tokens.accessToken).toBeDefined();\n153\t    expect(tokens.refreshToken).toBeDefined();\n154\t    expect(tokens.accessExpiresAt).toBeDefined();\n155\t    expect(tokens.refreshExpiresAt).toBeDefined();\n156\t\n157\t    // Verify JWT is valid and contains the correct wallet\n158\t    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n159\t      algorithms: [\"HS256\"],\n160\t    });\n161\t    expect(payload.sub).toBe(wallet);\n162\t\n163\t    // 4. Refresh\n164\t    const refreshRes = await app.request(\"/auth/refresh\", {\n165\t      method: \"POST\",\n166\t      headers: { \"Content-Type\": \"application/json\" },\n167\t      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n168\t    });\n169\t    expect(refreshRes.status).toBe(200);\n170\t    const newTokens = (await refreshRes.json()) as {\n171\t      accessToken: string;\n172\t      refreshToken: string;\n173\t    };\n174\t    expect(newTokens.accessToken).toBeDefined();\n175\t    expect(newTokens.refreshToken).toBeDefined();\n176\t    // New refresh token should be different from the old one\n177\t    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n178\t\n179\t    // 5. Old refresh token should no longer work (it was rotated)\n180\t    const replayRes = await app.request(\"/auth/refresh\", {\n181\t      method: \"POST\",\n182\t      headers: { \"Content-Type\": \"application/json\" },\n183\t      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n184\t    });\n185\t    expect(replayRes.status).toBe(401);\n186\t    const replayJson = (await replayRes.json()) as { error: string };\n187\t    expect(replayJson.error).toContain(\"reuse\");\n188\t\n189\t    // 6. Logout with new token\n190\t    const logoutRes = await