{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UR7JAyAZ85SqMKqKoTmqPA","type":"tool_result","content":"1\t/**\n2\t * Database client module — typed query functions for `rounds` and `operator_events`.\n3\t *\n4\t * Phase transitions are unidirectional: created → locked → settling → settled,\n5\t * or created → expired. The application layer rejects backward transitions.\n6\t */\n7\t\n8\timport postgres from \"postgres\";\n9\timport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n10\t\n11\t// ---------------------------------------------------------------------------\n12\t// Types\n13\t// ---------------------------------------------------------------------------\n14\t\n15\texport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n16\t\n17\texport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n18\texport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n19\t\n20\texport interface CloseCallRound {\n21\t  round_id: string;\n22\t  pda: string;\n23\t  server_key: string;\n24\t  phase: CloseCallPhase;\n25\t  open_price: number;\n26\t  open_price_expo: number;\n27\t  close_price: number | null;\n28\t  outcome: CloseCallOutcome;\n29\t  green_pool: number;\n30\t  red_pool: number;\n31\t  total_fee: number;\n32\t  green_entries: Array<{ player: string; amountLamports: number }>;\n33\t  red_entries: Array<{ player: string; amountLamports: number }>;\n34\t  settle_tx: string | null;\n35\t  created_at: Date;\n36\t  settled_at: Date | null;\n37\t}\n38\t\n39\texport interface InsertCloseCallRoundParams {\n40\t  roundId: string;\n41\t  pda: string;\n42\t  serverKey: string;\n43\t  openPrice: number;\n44\t  openPriceExpo: number;\n45\t}\n46\t\n47\texport type OperatorEventType =\n48\t  | \"secret_generated\"\n49\t  | \"tx_built\"\n50\t  | \"match_detected\"\n51\t  | \"settle_submitted\"\n52\t  | \"settle_confirmed\"\n53\t  | \"settle_failed\"\n54\t  | \"settle_retried\"\n55\t  | \"timeout_detected\";\n56\t\n57\texport interface Round {\n58\t  pda: string;\n59\t  game: string;\n60\t  creator: string;\n61\t  server_key: string;\n62\t  secret: Buffer;\n63\t  commitment: Buffer;\n64\t  amount_lamports: number;\n65\t  side: number;\n66\t  match_id: string;\n67\t  phase: RoundPhase;\n68\t  target_slot: string | null;\n69\t  settle_tx: string | null;\n70\t  settle_attempts: number;\n71\t  result_hash: Buffer | null;\n72\t  result_side: number | null;\n73\t  winner: string | null;\n74\t  entries: unknown | null;\n75\t  created_at: Date;\n76\t  updated_at: Date;\n77\t}\n78\t\n79\texport interface InsertRoundParams {\n80\t  pda: string;\n81\t  game: string;\n82\t  creator: string;\n83\t  serverKey: string;\n84\t  secret: Buffer;\n85\t  commitment: Buffer;\n86\t  amountLamports: number;\n87\t  side: number;\n88\t  matchId: string;\n89\t  phase: RoundPhase;\n90\t  entries?: Array<{ player: string; amountLamports: number }>;\n91\t}\n92\t\n93\texport interface OperatorEvent {\n94\t  id: string;\n95\t  pda: string | null;\n96\t  event_type: OperatorEventType;\n97\t  payload: unknown;\n98\t  created_at: Date;\n99\t}\n100\t\n101\t// ---------------------------------------------------------------------------\n102\t// Transaction types\n103\t// ---------------------------------------------------------------------------\n104\t\n105\texport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n106\t\n107\texport interface Transaction {\n108\t  id: string;\n109\t  wallet: string;\n110\t  game: string;\n111\t  match_id: string;\n112\t  tx_type: TransactionType;\n113\t  amount_lamports: number;\n114\t  tx_sig: string;\n115\t  created_at: Date;\n116\t}\n117\t\n118\texport interface InsertTransactionParams {\n119\t  wallet: string;\n120\t  game: string;\n121\t  matchId: string;\n122\t  txType: TransactionType;\n123\t  amountLamports: number;\n124\t  txSig: string;\n125\t}\n126\t\n127\t// ---------------------------------------------------------------------------\n128\t// Referral types\n129\t// ---------------------------------------------------------------------------\n130\t\n131\texport interface ReferralCode {\n132\t  id: number;\n133\t  wallet: string;\n134\t  code: string;\n135\t  created_at: Date;\n136\t  updated_at: Date;\n137\t}\n138\t\n139\texport interface ReferralLink {\n140\t  id: number;\n141\t  referrer_wallet: string;\n142\t  referee_wallet: string;\n143\t  created_at: Date;\n144\t}\n145\t\n146\texport interface ReferralEarning {\n147\t  id: number;\n148\t  referrer_wallet: string;\n149\t  referee_wallet: string;\n150\t  round_id: string;\n151\t  game_type: string;\n152\t  wager_lamports: number;\n153\t  fee_lamports: number;\n154\t  referrer_earned_lamports: number;\n155\t  referrer_rate_bps: number;\n156\t  referee_rebate_lamports: number;\n157\t  referee_rebate_rate_bps: number;\n158\t  created_at: Date;\n159\t}\n160\t\n161\texport interface ReferralStats {\n162\t  referred_count: number;\n163\t  active_count: number;\n164\t  total_volume_lamports: string;\n165\t  total_earned_lamports: string;\n166\t  total_rebate_lamports: string;\n167\t  pending_lamports: string;\n168\t}\n169\t\n170\texport interface ReferralClaim {\n171\t  id: string;\n172\t  wallet: string;\n173\t  amount_lamports: string;\n174\t  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n175\t  retry_count: number;\n176\t  tx_signature: string | null;\n177\t  error: string | null;\n178\t  requested_at: Date;\n179\t  processed_at: Date | null;\n180\t}\n181\t\n182\t// ---------------------------------------------------------------------------\n183\t// Player profile types\n184\t// ---------------------------------------------------------------------------\n185\t\n186\texport interface PlayerProfile {\n187\t  id: number;\n188\t  user_id: string;\n189\t  wallet: string;\n190\t  username: string;\n191\t  username_updated_at: Date | null;\n192\t  avatar_url: string | null;\n193\t  heat_multiplier: number;\n194\t  points_balance: number;\n195\t  created_at: Date;\n196\t}\n197\t\n198\t// ---------------------------------------------------------------------------\n199\t// Phase transition guard\n200\t// ---------------------------------------------------------------------------\n201\t\n202\t/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n203\tconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n204\t  created: [\"locked\", \"expired\"],\n205\t  locked: [\"settling\"],\n206\t  settling: [\"settled\"],\n207\t  settled: [],\n208\t  expired: [],\n209\t};\n210\t\n211\tfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n212\t  const allowed = VALID_TRANSITIONS[from];\n213\t  if (!allowed.includes(to)) {\n214\t    throw new Error(\n215\t      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n216\t    );\n217\t  }\n218\t}\n219\t\n220\t// ---------------------------------------------------------------------------\n221\t// DB client\n222\t// ---------------------------------------------------------------------------\n223\t\n224\texport interface Db {\n225\t  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n226\t  insertRound(params: InsertRoundParams): Promise<Round>;\n227\t\n228\t  /** Delete a round by PDA. Returns true if a row was removed. */\n229\t  deleteRoundByPda(pda: string): Promise<boolean>;\n230\t\n231\t  /** Transition a round's phase. Enforces unidirectional state machine.\n232\t   *  Optional `updates` can set additional columns alongside the phase change. */\n233\t  updateRoundPhase(\n234\t    pda: string,\n235\t    newPhase: RoundPhase,\n236\t    updates?: Partial<\n237\t      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n238\t    >,\n239\t  ): Promise<Round>;\n240\t\n241\t  /** Update the entries JSONB column for a settled round. */\n242\t  updateRoundEntries(\n243\t    pda: string,\n244\t    entries: Array<{ player: string; amountLamports: number }>,\n245\t  ): Promise<Round>;\n246\t\n247\t  /** Get a single round by its PDA. Returns `undefined` if not found. */\n248\t  getRoundByPda(pda: string): Promise<Round | undefined>;\n249\t\n250\t  /** Get all rounds matching a given phase. */\n251\t  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n252\t\n253\t  /** Append an operator event to the audit log. */\n254\t  insertOperatorEvent(\n255\t    pda: string | null,\n256\t    eventType: OperatorEventType,\n257\t    payload?: unknown,\n258\t  ): Promise<OperatorEvent>;\n259\t\n260\t  /** Get the latest operator event for a PDA + type. */\n261\t  getLatestOperatorEvent(\n262\t    pda: string,\n263\t    eventType: OperatorEventType,\n264\t  ): Promise<OperatorEvent | undefined>;\n265\t\n266\t  /** Get a single round by its match_id. Returns `undefined` if not found. */\n267\t  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n268\t\n269\t  /** Batch-fetch the latest operator event per PDA for a given event type. */\n270\t  getLatestOperatorEventsForPdas(\n271\t    pdas: string[],\n272\t    eventType: OperatorEventType,\n273\t  ): Promise<Map<string, OperatorEvent>>;\n274\t\n275\t  /** Get recently settled rounds for a game, ordered newest first. */\n276\t  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n277\t\n278\t  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n279\t  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n280\t\n281\t  // -------------------------------------------------------------------------\n282\t  // Close Call rounds\n283\t  // -------------------------------------------------------------------------\n284\t\n285\t  /** Insert a new Close Call round. */\n286\t  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n287\t\n288\t  /** Get a Close Call round by round_id (16-char hex). */\n289\t  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n290\t\n291\t  /** Get the current active (open) Close Call round. */\n292\t  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n293\t\n294\t  /** Get the most recent settled/refunded Close Call rounds. */\n295\t  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n296\t\n297\t  /** Update a Close Call round after settlement. */\n298\t  settleCloseCallRound(\n299\t    roundId: string,\n300\t    updates: {\n301\t      phase: CloseCallPhase;\n302\t      outcome: CloseCallOutcome;\n303\t      closePrice?: number;\n304\t      greenPool?: number;\n305\t      redPool?: number;\n306\t      totalFee?: number;\n307\t      greenEntries?: Array<{ player: string; amountLamports: number }>;\n308\t      redEntries?: Array<{ player: string; amountLamports: number }>;\n309\t      settleTx?: string;\n310\t    },\n311\t  ): Promise<CloseCallRound>;\n312\t\n313\t  // -------------------------------------------------------------------------\n314\t  // Transactions\n315\t  // -------------------------------------------------------------------------\n316\t\n317\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n318\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n319\t\n320\t  /** Insert multiple transactions in a single batch. */\n321\t  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n322\t\n323\t  /** Get paginated transactions for a wallet, newest first. */\n324\t  getTransactions(\n325\t    wallet: string,\n326\t    cursor?: string,\n327\t    limit?: number,\n328\t    game?: string,\n329\t  ): Promise<Transaction[]>;\n330\t\n331\t  // -------------------------------------------------------------------------\n332\t  // Referral — codes\n333\t  // -------------------------------------------------------------------------\n334\t\n335\t  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n336\t  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n337\t\n338\t  /** Get a wallet's referral code. Returns `undefined` if none set. */\n339\t  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n340\t\n341\t  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n342\t  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n343\t\n344\t  // -------------------------------------------------------------------------\n345\t  // Referral — links\n346\t  // -------------------------------------------------------------------------\n347\t\n348\t  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n349\t  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n350\t\n351\t  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n352\t  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n353\t\n354\t  /** Get all referral links where the given wallet is the referrer. */\n355\t  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n356\t\n357\t  // -------------------------------------------------------------------------\n358\t  // Referral — earnings & stats\n359\t  // -------------------------------------------------------------------------\n360\t\n361\t  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n362\t  insertReferralEarning(params: {\n363\t    referrerWallet: string;\n364\t    refereeWallet: string;\n365\t    roundId: string;\n366\t    gameType: string;\n367\t    wagerLamports: number;\n368\t    feeLamports: number;\n369\t    referrerEarnedLamports: number;\n370\t    referrerRateBps: number;\n371\t    refereeRebateLamports: number;\n372\t    refereeRebateRateBps: number;\n373\t  }): Promise<ReferralEarning>;\n374\t\n375\t  /**\n376\t   * Get the pending (unclaimed) balance for a wallet.\n377\t   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n378\t   * wallet=referee, minus sum of completed claims for the wallet.\n379\t   * Returns a lamport string.\n380\t   */\n381\t  getPendingBalance(wallet: string): Promise<string>;\n382\t\n383\t  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n384\t  getReferralEarnings(\n385\t    wallet: string,\n386\t    page: number,\n387\t    limit: number,\n388\t  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n389\t\n390\t  /** Get referral summary stats for a wallet. */\n391\t  getReferralStats(wallet: string): Promise<ReferralStats>;\n392\t\n393\t  // -------------------------------------------------------------------------\n394\t  // Referral — claims & rates\n395\t  // -------------------------------------------------------------------------\n396\t\n397\t  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n398\t  insertReferralClaim(\n399\t    wallet: string,\n400\t    amountLamports: string,\n401\t  ): Promise<ReferralClaim>;\n402\t\n403\t  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n404\t  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n405\t\n406\t  /**\n407\t   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n408\t   * Returns the updated claim.\n409\t   */\n410\t  updateClaimStatus(\n411\t    claimId: string,\n412\t    status: ReferralClaim[\"status\"],\n413\t    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n414\t  ): Promise<ReferralClaim>;\n415\t\n416\t  /**\n417\t   * Get the effective referrer rate for a wallet in bps.\n418\t   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n419\t   */\n420\t  getReferrerRate(\n421\t    wallet: string,\n422\t    defaultRateBps: number,\n423\t  ): Promise<number>;\n424\t\n425\t  /**\n426\t   * Execute a function within a database transaction.\n427\t   * All db methods called on the transactional Db share the same transaction.\n428\t   * Rolls back on error, commits on success.\n429\t   */\n430\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n431\t\n432\t  /** Gracefully close the connection pool. */\n433\t  close(): Promise<void>;\n434\t}\n435\t\n436\tfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n437\t  return {\n438\t    ...row,\n439\t    open_price: Number(row.open_price),\n440\t    open_price_expo: Number(row.open_price_expo),\n441\t    close_price: row.close_price === null ? null : Number(row.close_price),\n442\t    green_pool: Number(row.green_pool),\n443\t    red_pool: Number(row.red_pool),\n444\t    total_fee: Number(row.total_fee),\n445\t    // JSONB comes back as parsed objects from postgres.js\n446\t    green_entries: Array.isArray(row.green_entries)\n447\t      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n448\t      : [],\n449\t    red_entries: Array.isArray(row.red_entries)\n450\t      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n451\t      : [],\n452\t  };\n453\t}\n454\t\n455\tfunction normalizeTransaction(row: Transaction): Transaction {\n456\t  return {\n457\t    ...row,\n458\t    amount_lamports: Number(row.amount_lamports),\n459\t  };\n460\t}\n461\t\n462\tfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n463\t  return {\n464\t    ...row,\n465\t    wager_lamports: Number(row.wager_lamports),\n466\t    fee_lamports: Number(row.fee_lamports),\n467\t    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n468\t    referrer_rate_bps: Number(row.referrer_rate_bps),\n469\t    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n470\t    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n471\t  };\n472\t}\n473\t\n474\tfunction normalizeRound(row: Round): Round {\n475\t  return {\n476\t    ...row,\n477\t    amount_lamports: Number(row.amount_lamports),\n478\t    side: Number(row.side),\n479\t    settle_attempts: Number(row.settle_attempts),\n480\t    result_side: row.result_side === null ? null : Number(row.result_side),\n481\t    // JSONB comes back as parsed objects from postgres.js\n482\t    entries: Array.isArray(row.entries)\n483\t      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n484\t          player: e.player,\n485\t          amountLamports: Number(e.amountLamports),\n486\t        }))\n487\t      : null,\n488\t  };\n489\t}\n490\t\n491\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n492\texport function createDb(databaseUrl: string, _txSql?: any): Db {\n493\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n494\t  const sql: any = _txSql ?? postgres(databaseUrl);\n495\t  const _isOwner = !_txSql;\n496\t\n497\t  return {\n498\t    async insertRound(params) {\n499\t      const rows = await sql<Round[]>`\n500\t        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n501\t        VALUES (\n502\t          ${params.pda},\n503\t          ${params.game},\n504\t          ${params.creator},\n505\t          ${params.serverKey},\n506\t          ${params.secret},\n507\t          ${params.commitment},\n508\t          ${params.amountLamports},\n509\t          ${params.side},\n510\t          ${params.matchId},\n511\t          ${params.phase},\n512\t          ${params.entries ? sql.json(params.entries) : null}\n513\t        )\n514\t        RETURNING *\n515\t      `;\n516\t      return normalizeRound(rows[0]!);\n517\t    },\n518\t\n519\t    async deleteRoundByPda(pda) {\n520\t      const rows = await sql<{ pda: string }[]>`\n521\t        DELETE FROM rounds WHERE pda = ${pda}\n522\t        RETURNING pda\n523\t      `;\n524\t      return rows.length > 0;\n525\t    },\n526\t\n527\t    async updateRoundPhase(pda, newPhase, updates) {\n528\t      // Fetch current phase to validate transition\n529\t      const current = await sql<Pick<Round, \"phase\">[]>`\n530\t        SELECT phase FROM rounds WHERE pda = ${pda}\n531\t      `;\n532\t\n533\t      if (current.length === 0) {\n534\t        throw new Error(`Round not found: ${pda}`);\n535\t      }\n536\t\n537\t      const currentPhase = current[0]!.phase as RoundPhase;\n538\t      assertPhaseTransition(currentPhase, newPhase);\n539\t\n540\t      // Build the update — always set phase + updated_at\n541\t      const rows = await sql<Round[]>`\n542\t        UPDATE rounds SET\n543\t          phase = ${newPhase},\n544\t          updated_at = now(),\n545\t          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n546\t          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n547\t          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n548\t          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n549\t          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n550\t          winner = COALESCE(${updates?.winner ?? null}, winner)\n551\t        WHERE pda = ${pda}\n552\t        RETURNING *\n553\t      `;\n554\t\n555\t      return normalizeRound(rows[0]!);\n556\t    },\n557\t\n558\t    async updateRoundEntries(pda, entries) {\n559\t      const rows = await sql<Round[]>`\n560\t        UPDATE rounds SET\n561\t          entries = ${sql.json(entries)},\n562\t          updated_at = now()\n563\t        WHERE pda = ${pda}\n564\t        RETURNING *\n565\t      `;\n566\t      if (rows.length === 0) {\n567\t        throw new Error(`Round not found: ${pda}`);\n568\t      }\n569\t      return normalizeRound(rows[0]!);\n570\t    },\n571\t\n572\t    async getRoundByPda(pda) {\n573\t      const rows = await sql<Round[]>`\n574\t        SELECT * FROM rounds WHERE pda = ${pda}\n575\t      `;\n576\t      return rows[0] ? normalizeRound(rows[0]) : undefined;\n577\t    },\n578\t\n579\t    async getRoundByMatchId(matchId) {\n580\t      const rows = await sql<Round[]>`\n581\t        SELECT * FROM rounds WHERE match_id = ${matchId}\n582\t      `;\n583\t      return rows[0] ? normalizeRound(rows[0]) : undefined;\n584\t    },\n585\t\n586\t    async getRoundsByPhase(phase) {\n587\t      const rows = await sql<Round[]>`\n588\t        SELECT * FROM rounds WHERE phase = ${phase}\n589\t      `;\n590\t      return rows.map(normalizeRound);\n591\t    },\n592\t\n593\t    async insertOperatorEvent(pda, eventType, payload) {\n594\t      const rows = await sql<OperatorEvent[]>`\n595\t        INSERT INTO operator_events (pda, event_type, payload)\n596\t        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n597\t        RETURNING *\n598\t      `;\n599\t      return rows[0]!;\n600\t    },\n601\t\n602\t    async getLatestOperatorEvent(pda, eventType) {\n603\t      const rows = await sql<OperatorEvent[]>`\n604\t        SELECT * FROM operator_events\n605\t        WHERE pda = ${pda} AND event_type = ${eventType}\n606\t        ORDER BY id DESC\n607\t        LIMIT 1\n608\t      `;\n609\t      return rows[0];\n610\t    },\n611\t\n612\t    async getLatestOperatorEventsForPdas(pdas, eventType) {\n613\t      if (pdas.length === 0) return new Map();\n614\t      const rows = await sql<OperatorEvent[]>`\n615\t        SELECT DISTINCT ON (pda) *\n616\t        FROM operator_events\n617\t        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n618\t        ORDER BY pda, id DESC\n619\t      `;\n620\t      const map = new Map<string, OperatorEvent>();\n621\t      for (const row of rows) {\n622\t        if (row.pda) map.set(row.pda, row);\n623\t      }\n624\t      return map;\n625\t    },\n626\t\n627\t    async getRecentSettledRounds(game, limit) {\n628\t      const rows = await sql<Round[]>`\n629\t        SELECT * FROM rounds\n630\t        WHERE game = ${game} AND phase = 'settled'\n631\t        ORDER BY updated_at DESC\n632\t        LIMIT ${limit}\n633\t      `;\n634\t      return rows.map(normalizeRound);\n635\t    },\n636\t\n637\t    async getUnsettledStats() {\n638\t      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n639\t        SELECT\n640\t          COUNT(*)::text AS count,\n641\t          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n642\t        FROM rounds\n643\t        WHERE phase NOT IN ('settled', 'expired')\n644\t      `;\n645\t      const row = rows[0]!;\n646\t      return {\n647\t        count: parseInt(row.count, 10),\n648\t        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n649\t      };\n650\t    },\n651\t\n652\t    // -----------------------------------------------------------------------\n653\t    // Close Call rounds\n654\t    // -----------------------------------------------------------------------\n655\t\n656\t    async insertCloseCallRound(params) {\n657\t      const rows = await sql<CloseCallRound[]>`\n658\t        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n659\t        VALUES (\n660\t          ${params.roundId},\n661\t          ${params.pda},\n662\t          ${params.serverKey},\n663\t          ${params.openPrice},\n664\t          ${params.openPriceExpo}\n665\t        )\n666\t        RETURNING *\n667\t      `;\n668\t      return normalizeCloseCallRound(rows[0]!);\n669\t    },\n670\t\n671\t    async getCloseCallRound(roundId) {\n672\t      const rows = await sql<CloseCallRound[]>`\n673\t        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n674\t      `;\n675\t      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n676\t    },\n677\t\n678\t    async getCloseCallCurrentRound() {\n679\t      const rows = await sql<CloseCallRound[]>`\n680\t        SELECT * FROM closecall_rounds\n681\t        WHERE phase = 'open'\n682\t        ORDER BY created_at DESC\n683\t        LIMIT 1\n684\t      `;\n685\t      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n686\t    },\n687\t\n688\t    async getCloseCallHistory(limit) {\n689\t      const rows = await sql<CloseCallRound[]>`\n690\t        SELECT * FROM closecall_rounds\n691\t        WHERE phase IN ('settled', 'refunded')\n692\t        ORDER BY settled_at DESC\n693\t        LIMIT ${limit}\n694\t      `;\n695\t      return rows.map(normalizeCloseCallRound);\n696\t    },\n697\t\n698\t    async settleCloseCallRound(roundId, updates) {\n699\t      const rows = await sql<CloseCallRound[]>`\n700\t        UPDATE closecall_rounds SET\n701\t          phase = ${updates.phase},\n702\t          outcome = ${updates.outcome},\n703\t          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n704\t          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n705\t          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n706\t          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n707\t          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n708\t          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n709\t          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n710\t          settled_at = now()\n711\t        WHERE round_id = ${roundId}\n712\t        RETURNING *\n713\t      `;\n714\t      if (rows.length === 0) {\n715\t        throw new Error(`Close Call round not found: ${roundId}`);\n716\t      }\n717\t      return normalizeCloseCallRound(rows[0]!);\n718\t    },\n719\t\n720\t    // -----------------------------------------------------------------------\n721\t    // Transactions\n722\t    // -----------------------------------------------------------------------\n723\t\n724\t    async insertTransaction(params) {\n725\t      await sql`\n726\t        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n727\t        VALUES (\n728\t          ${params.wallet},\n729\t          ${params.game},\n730\t          ${params.matchId},\n731\t          ${params.txType},\n732\t          ${params.amountLamports},\n733\t          ${params.txSig}\n734\t        )\n735\t        ON CONFLICT DO NOTHING\n736\t      `;\n737\t    },\n738\t\n739\t    async insertTransactions(params) {\n740\t      if (params.length === 0) return;\n741\t      const values = params.map((p) => ({\n742\t        wallet: p.wallet,\n743\t        game: p.game,\n744\t        match_id: p.matchId,\n745\t        tx_type: p.txType,\n746\t        amount_lamports: p.amountLamports,\n747\t        tx_sig: p.txSig,\n748\t      }));\n749\t      await sql`\n750\t        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n751\t        ON CONFLICT DO NOTHING\n752\t      `;\n753\t    },\n754\t\n755\t    async getTransactions(wallet, cursor, limit = 20, game) {\n756\t      const effectiveLimit = Math.min(limit, 50);\n757\t      if (cursor && game) {\n758\t        const rows = await sql<Transaction[]>`\n759\t          SELECT * FROM transactions\n760\t          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n761\t          ORDER BY id DESC\n762\t          LIMIT ${effectiveLimit}\n763\t        `;\n764\t        return rows.map(normalizeTransaction);\n765\t      }\n766\t      if (cursor) {\n767\t        const rows = await sql<Transaction[]>`\n768\t          SELECT * FROM transactions\n769\t          WHERE wallet = ${wallet} AND id < ${cursor}\n770\t          ORDER BY id DESC\n771\t          LIMIT ${effectiveLimit}\n772\t        `;\n773\t        return rows.map(normalizeTransaction);\n774\t      }\n775\t      if (game) {\n776\t        const rows = await sql<Transaction[]>`\n777\t          SELECT * FROM transactions\n778\t          WHERE wallet = ${wallet} AND game = ${game}\n779\t          ORDER BY id DESC\n780\t          LIMIT ${effectiveLimit}\n781\t        `;\n782\t        return rows.map(normalizeTransaction);\n783\t      }\n784\t      const rows = await sql<Transaction[]>`\n785\t        SELECT * FROM transactions\n786\t        WHERE wallet = ${wallet}\n787\t        ORDER BY id DESC\n788\t        LIMIT ${effectiveLimit}\n789\t      `;\n790\t      return rows.map(normalizeTransaction);\n791\t    },\n792\t\n793\t    // -----------------------------------------------------------------------\n794\t    // Referral — codes\n795\t    // -----------------------------------------------------------------------\n796\t\n797\t    async insertReferralCode(wallet, code) {\n798\t      const rows = await sql<ReferralCode[]>`\n799\t        INSERT INTO referral_codes (wallet, code)\n800\t        VALUES (${wallet}, ${code})\n801\t        RETURNING *\n802\t      `;\n803\t      return rows[0]!;\n804\t    },\n805\t\n806\t    async getReferralCodeByWallet(wallet) {\n807\t      const rows = await sql<ReferralCode[]>`\n808\t        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n809\t      `;\n810\t      return rows[0];\n811\t    },\n812\t\n813\t    async getReferralCodeByCode(code) {\n814\t      const rows = await sql<ReferralCode[]>`\n815\t        SELECT * FROM referral_codes WHERE code = ${code}\n816\t      `;\n817\t      return rows[0];\n818\t    },\n819\t\n820\t    // -- Referral links -------------------------------------------------------\n821\t\n822\t    async insertReferralLink(referrerWallet, refereeWallet) {\n823\t      const rows = await sql<ReferralLink[]>`\n824\t        INSERT INTO referral_links (referrer_wallet, referee_wallet)\n825\t        VALUES (${referrerWallet}, ${refereeWallet})\n826\t        RETURNING *\n827\t      `;\n828\t      return rows[0]!;\n829\t    },\n830\t\n831\t    async getReferralLinkByReferee(refereeWallet) {\n832\t      const rows = await sql<ReferralLink[]>`\n833\t        SELECT * FROM referral_links WHERE referee_wallet = ${refereeWallet}\n834\t      `;\n835\t      return rows[0];\n836\t    },\n837\t\n838\t    async getReferralLinksByReferrer(referrerWallet) {\n839\t      const rows = await sql<ReferralLink[]>`\n840\t        SELECT * FROM referral_links WHERE referrer_wallet = ${referrerWallet}\n841\t        ORDER BY created_at DESC\n842\t      `;\n843\t      return rows;\n844\t    },\n845\t\n846\t    // -- Referral earnings & stats --------------------------------------------\n847\t\n848\t    async insertReferralEarning(params) {\n849\t      const rows = await sql<ReferralEarning[]>`\n850\t        INSERT INTO referral_earnings (\n851\t          referrer_wallet, referee_wallet, round_id, game_type,\n852\t          wager_lamports, fee_lamports,\n853\t          referrer_earned_lamports, referrer_rate_bps,\n854\t          referee_rebate_lamports, referee_rebate_rate_bps\n855\t        ) VALUES (\n856\t          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n857\t          ${params.wagerLamports}, ${params.feeLamports},\n858\t          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n859\t          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n860\t        )\n861\t        RETURNING *\n862\t      `;\n863\t      return normalizeReferralEarning(rows[0]!);\n864\t    },\n865\t\n866\t    async getPendingBalance(wallet) {\n867\t      const rows = await sql<{ pending: string }[]>`\n868\t        SELECT COALESCE(\n869\t          (\n870\t            SELECT SUM(referrer_earned_lamports)\n871\t            FROM referral_earnings WHERE referrer_wallet = ${wallet}\n872\t          ), 0\n873\t        ) + COALESCE(\n874\t          (\n875\t            SELECT SUM(referee_rebate_lamports)\n876\t            FROM referral_earnings WHERE referee_wallet = ${wallet}\n877\t          ), 0\n878\t        ) - COALESCE(\n879\t          (\n880\t            SELECT SUM(amount_lamports)\n881\t            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'error', 'completed')\n882\t          ), 0\n883\t        ) AS pending\n884\t      `;\n885\t      return rows[0]!.pending;\n886\t    },\n887\t\n888\t    async getReferralEarnings(wallet, page, limit) {\n889\t      const offset = (page - 1) * limit;\n890\t      const [countRows, rows] = await Promise.all([\n891\t        sql<{ count: string }[]>`\n892\t          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n893\t          WHERE referrer_wallet = ${wallet}\n894\t        `,\n895\t        sql<ReferralEarning[]>`\n896\t          SELECT * FROM referral_earnings\n897\t          WHERE referrer_wallet = ${wallet}\n898\t          ORDER BY created_at DESC\n899\t          LIMIT ${limit} OFFSET ${offset}\n900\t        `,\n901\t      ]);\n902\t      const total = Number(countRows[0]!.count);\n903\t      const totalPages = Math.max(1, Math.ceil(total / limit));\n904\t      return { items: rows.map(normalizeReferralEarning), totalPages };\n905\t    },\n906\t\n907\t    async getReferralStats(wallet) {\n908\t      const rows = await sql<ReferralStats[]>`\n909\t        SELECT\n910\t          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n911\t            AS referred_count,\n912\t          (\n913\t            SELECT COUNT(DISTINCT re.referee_wallet)\n914\t            FROM referral_earnings re\n915\t            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n916\t            WHERE re.created_at > now() - INTERVAL '7 days'\n917\t          )::INT AS active_count,\n918\t          COALESCE(\n919\t            (\n920\t              SELECT SUM(re.wager_lamports)::TEXT\n921\t              FROM referral_earnings re\n922\t              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n923\t            ), '0'\n924\t          ) AS total_volume_lamports,\n925\t          COALESCE(\n926\t            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_wallet = ${wallet}),\n927\t            '0'\n928\t          ) AS total_earned_lamports,\n929\t          COALESCE(\n930\t            (SELECT SUM(referee_rebate_lamports)::TEXT FROM referral_earnings WHERE referee_wallet = ${wallet}),\n931\t            '0'\n932\t          ) AS total_rebate_lamports,\n933\t          (\n934\t            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_wallet = ${wallet}), 0)\n935\t            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_wallet = ${wallet}), 0)\n936\t            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending','processing','error','completed')), 0)\n937\t          )::TEXT AS pending_lamports\n938\t      `;\n939\t      return rows[0]!;\n940\t    },\n941\t\n942\t    // -----------------------------------------------------------------------\n943\t    // Referral — claims & rates\n944\t    // -----------------------------------------------------------------------\n945\t\n946\t    async insertReferralClaim(wallet, amountLamports) {\n947\t      const rows = await sql<ReferralClaim[]>`\n948\t        INSERT INTO referral_claims (wallet, amount_lamports, status)\n949\t        VALUES (${wallet}, ${amountLamports}, 'pending')\n950\t        RETURNING *\n951\t      `;\n952\t      return rows[0]!;\n953\t    },\n954\t\n955\t    async getReferralClaim(claimId) {\n956\t      const rows = await sql<ReferralClaim[]>`\n957\t        SELECT * FROM referral_claims WHERE id = ${claimId}\n958\t      `;\n959\t      return rows[0];\n960\t    },\n961\t\n962\t    async updateClaimStatus(claimId, status, meta) {\n963\t      const rows = await sql<ReferralClaim[]>`\n964\t        UPDATE referral_claims\n965\t        SET\n966\t          status = ${status},\n967\t          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n968\t          error = COALESCE(${meta?.error ?? null}, error),\n969\t          retry_count = ${meta?.incrementRetry ? sql`retry_count + 1` : sql`retry_count`},\n970\t          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n971\t        WHERE id = ${claimId}\n972\t        RETURNING *\n973\t      `;\n974\t      return rows[0]!;\n975\t    },\n976\t\n977\t    async getReferrerRate(wallet, defaultRateBps) {\n978\t      const rows = await sql<{ rate_bps: number }[]>`\n979\t        SELECT rate_bps FROM referral_kol_rates WHERE wallet = ${wallet}\n980\t      `;\n981\t      return rows[0]?.rate_bps ?? defaultRateBps;\n982\t    },\n983\t\n984\t    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n985\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n986\t      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n987\t    },\n988\t\n989\t    async close() {\n990\t      if (_isOwner) await sql.end();\n991\t    },\n992\t  };\n993\t}\n994\t"}]},"parent_tool_use_id":"toolu_01JZmCRc8e4u15PJhPmc1eay","session_id":"4603cf5e-2eec-42a2-ba7b-9521091bfde1","uuid":"581f4523-5130-4b67-9a8a-3874b277c5ab","timestamp":"2026-03-31T14:51:28.184Z"}
