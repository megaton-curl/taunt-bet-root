{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HrrHKdeHvUSBFetMg3k4Qr","type":"tool_result","content":"1\timport { randomBytes } from \"node:crypto\";\n2\t\n3\t// ── Word lists (50+ each, no profanity) ──────────────────────────\n4\t\n5\tconst ADJECTIVES = [\n6\t  \"bold\",\n7\t  \"brave\",\n8\t  \"calm\",\n9\t  \"cool\",\n10\t  \"dark\",\n11\t  \"deft\",\n12\t  \"epic\",\n13\t  \"fast\",\n14\t  \"fell\",\n15\t  \"fond\",\n16\t  \"grim\",\n17\t  \"hale\",\n18\t  \"huge\",\n19\t  \"iron\",\n20\t  \"keen\",\n21\t  \"kind\",\n22\t  \"last\",\n23\t  \"lean\",\n24\t  \"live\",\n25\t  \"lone\",\n26\t  \"loud\",\n27\t  \"mild\",\n28\t  \"mint\",\n29\t  \"neat\",\n30\t  \"next\",\n31\t  \"nova\",\n32\t  \"odd\",\n33\t  \"pale\",\n34\t  \"pure\",\n35\t  \"rare\",\n36\t  \"raw\",\n37\t  \"real\",\n38\t  \"rich\",\n39\t  \"safe\",\n40\t  \"sage\",\n41\t  \"salt\",\n42\t  \"shiny\",\n43\t  \"sly\",\n44\t  \"soft\",\n45\t  \"some\",\n46\t  \"sure\",\n47\t  \"tall\",\n48\t  \"tame\",\n49\t  \"tiny\",\n50\t  \"vast\",\n51\t  \"void\",\n52\t  \"warm\",\n53\t  \"wide\",\n54\t  \"wild\",\n55\t  \"wise\",\n56\t  \"zero\",\n57\t];\n58\t\n59\tconst NOUNS = [\n60\t  \"ace\",\n61\t  \"apex\",\n62\t  \"arch\",\n63\t  \"bear\",\n64\t  \"bell\",\n65\t  \"bird\",\n66\t  \"bolt\",\n67\t  \"byte\",\n68\t  \"card\",\n69\t  \"claw\",\n70\t  \"coil\",\n71\t  \"core\",\n72\t  \"dawn\",\n73\t  \"dusk\",\n74\t  \"edge\",\n75\t  \"fang\",\n76\t  \"fire\",\n77\t  \"flux\",\n78\t  \"fork\",\n79\t  \"frog\",\n80\t  \"gate\",\n81\t  \"gear\",\n82\t  \"glow\",\n83\t  \"grid\",\n84\t  \"haze\",\n85\t  \"helm\",\n86\t  \"hive\",\n87\t  \"jade\",\n88\t  \"kite\",\n89\t  \"lake\",\n90\t  \"lens\",\n91\t  \"link\",\n92\t  \"loom\",\n93\t  \"lynx\",\n94\t  \"mesa\",\n95\t  \"mint\",\n96\t  \"moon\",\n97\t  \"node\",\n98\t  \"opal\",\n99\t  \"orb\",\n100\t  \"peak\",\n101\t  \"pine\",\n102\t  \"reef\",\n103\t  \"ring\",\n104\t  \"root\",\n105\t  \"sage\",\n106\t  \"seed\",\n107\t  \"shard\",\n108\t  \"star\",\n109\t  \"tide\",\n110\t  \"veil\",\n111\t  \"vine\",\n112\t  \"wave\",\n113\t  \"wolf\",\n114\t  \"wren\",\n115\t  \"zeal\",\n116\t];\n117\t\n118\t// ── Helpers ──────────────────────────────────────────────────────\n119\t\n120\tconst ALPHANUMERIC = \"abcdefghijklmnopqrstuvwxyz0123456789\";\n121\t\n122\tfunction randomAlphanumeric(length: number): string {\n123\t  const bytes = randomBytes(length);\n124\t  let result = \"\";\n125\t  for (let i = 0; i < length; i++) {\n126\t    result += ALPHANUMERIC[bytes[i]! % ALPHANUMERIC.length];\n127\t  }\n128\t  return result;\n129\t}\n130\t\n131\tfunction randomInt(max: number): number {\n132\t  return randomBytes(4).readUInt32BE() % max;\n133\t}\n134\t\n135\t// ── Public API ──────────────────────────────────────────────────\n136\t\n137\t/**\n138\t * Generate a unique user ID: `usr_` + 8 random lowercase alphanumeric chars.\n139\t */\n140\texport function generateUserId(): string {\n141\t  return `usr_${randomAlphanumeric(8)}`;\n142\t}\n143\t\n144\t/**\n145\t * Generate a random username: `{adjective}-{noun}-{4digits}`.\n146\t * No DB access — collision handling is done at the DB layer.\n147\t */\n148\texport function generateUsername(): string {\n149\t  const adj = ADJECTIVES[randomInt(ADJECTIVES.length)];\n150\t  const noun = NOUNS[randomInt(NOUNS.length)];\n151\t  const digits = String(randomInt(10000)).padStart(4, \"0\");\n152\t  return `${adj}-${noun}-${digits}`;\n153\t}\n154\t"}]},"parent_tool_use_id":null,"session_id":"4603cf5e-2eec-42a2-ba7b-9521091bfde1","uuid":"02cde62a-e0d8-4dd7-bdd1-94a95260a6ee","timestamp":"2026-03-31T14:51:26.216Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/utils/username-gen.ts","content":"import { randomBytes } from \"node:crypto\";\n\n// ── Word lists (50+ each, no profanity) ──────────────────────────\n\nconst ADJECTIVES = [\n  \"bold\",\n  \"brave\",\n  \"calm\",\n  \"cool\",\n  \"dark\",\n  \"deft\",\n  \"epic\",\n  \"fast\",\n  \"fell\",\n  \"fond\",\n  \"grim\",\n  \"hale\",\n  \"huge\",\n  \"iron\",\n  \"keen\",\n  \"kind\",\n  \"last\",\n  \"lean\",\n  \"live\",\n  \"lone\",\n  \"loud\",\n  \"mild\",\n  \"mint\",\n  \"neat\",\n  \"next\",\n  \"nova\",\n  \"odd\",\n  \"pale\",\n  \"pure\",\n  \"rare\",\n  \"raw\",\n  \"real\",\n  \"rich\",\n  \"safe\",\n  \"sage\",\n  \"salt\",\n  \"shiny\",\n  \"sly\",\n  \"soft\",\n  \"some\",\n  \"sure\",\n  \"tall\",\n  \"tame\",\n  \"tiny\",\n  \"vast\",\n  \"void\",\n  \"warm\",\n  \"wide\",\n  \"wild\",\n  \"wise\",\n  \"zero\",\n];\n\nconst NOUNS = [\n  \"ace\",\n  \"apex\",\n  \"arch\",\n  \"bear\",\n  \"bell\",\n  \"bird\",\n  \"bolt\",\n  \"byte\",\n  \"card\",\n  \"claw\",\n  \"coil\",\n  \"core\",\n  \"dawn\",\n  \"dusk\",\n  \"edge\",\n  \"fang\",\n  \"fire\",\n  \"flux\",\n  \"fork\",\n  \"frog\",\n  \"gate\",\n  \"gear\",\n  \"glow\",\n  \"grid\",\n  \"haze\",\n  \"helm\",\n  \"hive\",\n  \"jade\",\n  \"kite\",\n  \"lake\",\n  \"lens\",\n  \"link\",\n  \"loom\",\n  \"lynx\",\n  \"mesa\",\n  \"mint\",\n  \"moon\",\n  \"node\",\n  \"opal\",\n  \"orb\",\n  \"peak\",\n  \"pine\",\n  \"reef\",\n  \"ring\",\n  \"root\",\n  \"sage\",\n  \"seed\",\n  \"shard\",\n  \"star\",\n  \"tide\",\n  \"veil\",\n  \"vine\",\n  \"wave\",\n  \"wolf\",\n  \"wren\",\n  \"zeal\",\n];\n\n// ── Helpers ──────────────────────────────────────────────────────\n\nconst ALPHANUMERIC = \"abcdefghijklmnopqrstuvwxyz0123456789\";\n\nfunction randomAlphanumeric(length: number): string {\n  const bytes = randomBytes(length);\n  let result = \"\";\n  for (let i = 0; i < length; i++) {\n    result += ALPHANUMERIC[bytes[i]! % ALPHANUMERIC.length];\n  }\n  return result;\n}\n\nfunction randomInt(max: number): number {\n  return randomBytes(4).readUInt32BE() % max;\n}\n\n// ── Public API ──────────────────────────────────────────────────\n\n/**\n * Generate a unique user ID: `usr_` + 8 random lowercase alphanumeric chars.\n */\nexport function generateUserId(): string {\n  return `usr_${randomAlphanumeric(8)}`;\n}\n\n/**\n * Generate a random username: `{adjective}-{noun}-{4digits}`.\n * No DB access — collision handling is done at the DB layer.\n */\nexport function generateUsername(): string {\n  const adj = ADJECTIVES[randomInt(ADJECTIVES.length)];\n  const noun = NOUNS[randomInt(NOUNS.length)];\n  const digits = String(randomInt(10000)).padStart(4, \"0\");\n  return `${adj}-${noun}-${digits}`;\n}\n","numLines":154,"startLine":1,"totalLines":154}}}
