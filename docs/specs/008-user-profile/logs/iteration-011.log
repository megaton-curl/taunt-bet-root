{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AoMXLENNqJBXgZUGX41Xr3","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// User transaction types\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→export type UserTransactionEvent = \"join\" | \"win\" | \"loss\" | \"refund\";\n   105→\n   106→export interface UserTransaction {\n   107→  id: string;\n   108→  wallet: string;\n   109→  game: string;\n   110→  match_id: string;\n   111→  event: UserTransactionEvent;\n   112→  amount_lamports: number;\n   113→  tx_sig: string | null;\n   114→  created_at: Date;\n   115→}\n   116→\n   117→export interface InsertUserTransactionParams {\n   118→  wallet: string;\n   119→  game: string;\n   120→  matchId: string;\n   121→  event: UserTransactionEvent;\n   122→  amountLamports: number;\n   123→  txSig?: string | null;\n   124→}\n   125→\n   126→// ---------------------------------------------------------------------------\n   127→// Phase transition guard\n   128→// ---------------------------------------------------------------------------\n   129→\n   130→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   131→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   132→  created: [\"locked\", \"expired\"],\n   133→  locked: [\"settling\"],\n   134→  settling: [\"settled\"],\n   135→  settled: [],\n   136→  expired: [],\n   137→};\n   138→\n   139→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   140→  const allowed = VALID_TRANSITIONS[from];\n   141→  if (!allowed.includes(to)) {\n   142→    throw new Error(\n   143→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   144→    );\n   145→  }\n   146→}\n   147→\n   148→// ---------------------------------------------------------------------------\n   149→// DB client\n   150→// ---------------------------------------------------------------------------"}]},"parent_tool_use_id":"toolu_01LzxN5vvC8UFeL2tZzCdkvU","session_id":"9dfcb3ed-4930-49c9-8526-cce92c2e50e0","uuid":"249aa4c9-72d8-49d4-a196-462feb92d9df","timestamp":"2026-03-19T20:19:37.602Z"}
