rice: number, expo: number): string {\n  const value = price * Math.pow(10, expo);\n  return `$${value.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;\n}\n\nexport function CloseCallRoundPage() {\n  const { roundId } = useParams<{ roundId: string }>();\n  const [round, setRound] = useState<RoundData | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n\n  useEffect(() => {\n    if (!roundId) return;\n\n    fetch(`${FAIRNESS_BACKEND_URL}/fairness/rounds/by-id/${roundId}`)\n      .then(async (res) => {\n        if (!res.ok) {\n          throw new Error(res.status === 404 ? \"Round not found\" : `Error ${res.status}`);\n        }\n        return res.json() as Promise<RoundData>;\n      })\n      .then(setRound)\n      .catch((err) => setError(err instanceof Error ? err.message : \"Failed to load\"))\n      .finally(() => setLoading(false));\n  }, [roundId]);\n\n  if (loading) {\n    return (\n      <div style={{ padding: \"2rem\", color: \"#94a3b8\" }}>\n        Loading round...\n      </div>\n    );\n  }\n\n  if (error || !round) {\n    return (\n      <div style={{ padding: \"2rem\" }}>\n        <p style={{ color: ERROR_COLOR }}>{error ?? \"Round not found\"}</p>\n        <Link to=\"/close-call\" style={{ color: \"#38bdf8\" }}>Back to Close Call</Link>\n      </div>\n    );\n  }\n\n  const isSettled = round.phase === \"settled\" || round.phase === \"refunded\";\n  const outcomeColor = round.outcome ? OUTCOME_COLORS[round.outcome] ?? \"#94a3b8\" : \"#94a3b8\";\n\n  return (\n    <div style={{ padding: \"2rem\", maxWidth: 640, margin: \"0 auto\" }}>\n      <Link to=\"/close-call\" style={{ color: \"#38bdf8\", fontSize: \"0.875rem\" }}>\n        &larr; Back to Close Call\n      </Link>\n\n      <h2 style={{ color: \"#e2e8f0\", marginTop: \"1rem\" }}>\n        Close Call Round Details\n      </h2>\n\n      <div style={{ background: \"#1e293b\", borderRadius: 8, padding: \"1.25rem\", marginTop: \"1rem\" }}>\n        <div style={{ display: \"grid\", gap: \"0.75rem\" }}>\n          <Row label=\"Round ID\" value={round.matchId} mono copy />\n          <Row label=\"Status\" value={round.phase} />\n          <Row label=\"Created\" value={new Date(round.createdAt).toLocaleString()} />\n\n          {/* Oracle prices */}\n          <div style={{ borderTop: \"1px solid #334155\", margin: \"0.5rem 0\" }} />\n          <h3 style={{ color: \"#cbd5e1\", fontSize: \"0.875rem\", margin: 0 }}>Oracle Prices (Pyth BTC/USD)</h3>\n\n          <Row label=\"Open Price\" value={formatPrice(round.openPrice, round.openPriceExpo)} />\n          {isSettled && round.closePrice != null && (\n            <Row label=\"Close Price\" value={formatPrice(round.closePrice, round.openPriceExpo)} />\n          )}\n          {isSettled && round.outcome && (\n            <Row\n              label=\"Outcome\"\n              value={\n                <span style={{ color: outcomeColor, fontWeight: 600 }}>\n                  {round.outcome.toUpperCase()}\n                </span>\n              }\n            />\n          )}\n\n          {/* Pool breakdown */}\n          <div style={{ borderTop: \"1px solid #334155\", margin: \"0.5rem 0\" }} />\n          <h3 style={{ color: \"#cbd5e1\", fontSize: \"0.875rem\", margin: 0 }}>Pool</h3>\n\n          <Row\n            label=\"Green Pool\"\n            value={\n              <span style={{ color: OUTCOME_COLORS.green }}>\n                {(round.greenPool / LAMPORTS_PER_SOL).toFixed(4)} SOL ({round.greenCount} {round.greenCount === 1 ? \"entry\" : \"entries\"})\n              </span>\n            }\n          />\n          <Row\n            label=\"Red Pool\"\n            value={\n              <span style={{ color: OUTCOME_COLORS.red }}>\n                {(round.redPool / LAMPORTS_PER_SOL).toFixed(4)} SOL ({round.redCount} {round.redCount === 1 ? \"entry\" : \"entries\"})\n              </span>\n            }\n          />\n          <Row label=\"Total Pool\" value={`${(round.totalPool / LAMPORTS_PER_SOL).toFixed(4)} SOL`} />\n          {isSettled && round.totalFee != null && (\n            <Row label=\"Fee Collected\" value={`${(round.totalFee / LAMPORTS_PER_SOL).toFixed(4)} SOL`} />\n          )}\n\n          {/* Entries */}\n          {(round.greenEntries.length > 0 || round.redEntries.length > 0) && (() => {\n            // Compute per-player payout when settled\n            const netPool = round.totalPool * (1 - PLATFORM_FEE);\n            const isRefund = round.outcome === \"refund\";\n            const greenWins = round.outcome === \"green\";\n            const redWins = round.outcome === \"red\";\n            const winningPoolLamports = greenWins ? round.greenPool : redWins ? round.redPool : 0;\n\n            function entryPayout(side: \"green\" | \"red\", amountLamports: number): number | null {\n              if (!isSettled) return null;\n              if (isRefund) return amountLamports; // full refund\n              const isWinner = (side === \"green\" && greenWins) || (side === \"red\" && redWins);\n              if (!isWinner) return 0;\n              if (winningPoolLamports === 0) return amountLamports;\n              return (amountLamports / winningPoolLamports) * netPool;\n            }\n\n            function formatPayout(side: \"green\" | \"red\", amountLamports: number): React.ReactNode {\n              const payout = entryPayout(side, amountLamports);\n              if (payout === null) return null;\n              if (isRefund) {\n                return <span style={{ color: OUTCOME_COLORS.refund, fontSize: \"0.75rem\" }}> refund</span>;\n              }\n              const profit = payout - amountLamports;\n              if (payout === 0) {\n                return <span style={{ color: ERROR_COLOR, fontSize: \"0.75rem\" }}> -{(amountLamports / LAMPORTS_PER_SOL).toFixed(4)}</span>;\n              }\n              return <span style={{ color: PROFIT_COLOR, fontSize: \"0.75rem\" }}> +{(profit / LAMPORTS_PER_SOL).toFixed(4)}</span>;\n            }\n\n            return (\n              <>\n                <div style={{ borderTop: \"1px solid #334155\", margin: \"0.5rem 0\" }} />\n                <h3 style={{ color: \"#cbd5e1\", fontSize: \"0.875rem\", margin: 0 }}>Entries</h3>\n                {round.greenEntries.map((e, i) => (\n                  <Row\n                    key={`g-${i}`}\n                    label={\n                      <span style={{ color: OUTCOME_COLORS.green, fontSize: \"0.75rem\" }}>GREEN</span>\n                    }\n                    value={\n                      <span>\n                        {e.player.slice(0, 4)}...{e.player.slice(-4)} — {(e.amountLamports / LAMPORTS_PER_SOL).toFixed(4)} SOL\n                        {formatPayout(\"green\", e.amountLamports)}\n                      </span>\n                    }\n                    mono\n                    copy\n                    copyValue={e.player}\n                  />\n                ))}\n                {round.redEntries.map((e, i) => (\n                  <Row\n                    key={`r-${i}`}\n                    label={\n                      <span style={{ color: OUTCOME_COLORS.red, fontSize: \"0.75rem\" }}>RED</span>\n                    }\n                    value={\n                      <span>\n                        {e.player.slice(0, 4)}...{e.player.slice(-4)} — {(e.amountLamports / LAMPORTS_PER_SOL).toFixed(4)} SOL\n                        {formatPayout(\"red\", e.amountLamports)}\n                      </span>\n                    }\n                    mono\n                    copy\n                    copyValue={e.player}\n                  />\n                ))}\n              </>\n            );\n          })()}\n\n          {/* Settlement info */}\n          {isSettled && (\n            <>\n              <div style={{ borderTop: \"1px solid #334155\", margin: \"0.5rem 0\" }} />\n              <h3 style={{ color: \"#cbd5e1\", fontSize: \"0.875rem\", margin: 0 }}>Settlement</h3>\n\n              {round.settledAt && (\n                <Row label=\"Settled At\" value={new Date(round.settledAt).toLocaleString()} />\n              )}\n              {round.settleTx && (\n                <Row\n                  label=\"Settlement Tx\"\n                  value={\n                    <a\n                      href={`https://explorer.solana.com/tx/${round.settleTx}?cluster=devnet`}\n                      target=\"_blank\"\n                      rel=\"noopener noreferrer\"\n                      style={{ color: \"#38bdf8\" }}\n                    >\n                      {round.settleTx.slice(0, 16)}...\n                    </a>\n                  }\n                />\n              )}\n              {round.verification && (\n                <>\n                  <Row label=\"Price Source\" value={round.verification.priceSource} />\n                  <Row label=\"Resolution\" value={round.verification.outcome} />\n                </>\n              )}\n\n              <div style={{ borderTop: \"1px solid #334155\", margin: \"0.5rem 0\" }} />\n              <p style={{ color: \"#94a3b8\", fontSize: \"0.75rem\", margin: 0, lineHeight: 1.5 }}>\n                <strong style={{ color: \"#cbd5e1\" }}>How to verify:</strong>{\" \"}\n                Prices are sourced from the Pyth Network BTC/USD push oracle on Solana.\n                Open price is captured when the round is created, close price is read at settlement.\n                If close &gt; open, GREEN wins. If close &lt; open, RED wins.\n                Equal price, one-sided pools, or single-player rounds trigger a full refund with no fee.\n              </p>\n            </>\n          )}\n\n          {!isSettled && (\n            <>\n              <div style={{ borderTop: \"1px solid #334155\", margin: \"0.5rem 0\" }} />\n              <p style={{ color: \"#94a3b8\", fontSize: \"0.8125rem\", margin: 0 }}>\n                Round is still open. Outcome and close price will be available after settlement.\n              </p>\n            </>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n\nfunction Row({\n  label,\n  value,\n  mono,\n  copy,\n  copyValue,\n}: {\n  label: React.ReactNode;\n  value: React.ReactNode;\n  mono?: boolean;\n  copy?: boolean;\n  copyValue?: string;\n}) {\n  const isString = typeof value === \"string\";\n  const textToCopy = copyValue ?? (isString ? value : undefined);\n  return (\n    <div style={{ display: \"flex\", justifyContent: \"space-between\", gap: \"1rem\" }}>\n      <span style={{ color: \"#94a3b8\", fontSize: \"0.8125rem\", flexShrink: 0 }}>{label}</span>\n      <span\n        style={{\n          color: \"#e2e8f0\",\n          fontSize: \"0.8125rem\",\n          fontFamily: mono ? \"monospace\" : \"inherit\",\n          wordBreak: \"break-all\",\n          textAlign: \"right\",\n          cursor: copy && textToCopy ? \"pointer\" : \"default\",\n        }}\n        title={copy && textToCopy ? \"Click to copy\" : undefined}\n        onClick={copy && textToCopy ? () => navigator.clipboard.writeText(textToCopy) : undefined}\n      >\n        {value}\n      </span>\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":87,"oldLines":7,"newStart":87,"newLines":7,"lines":["   }"," ","   const isSettled = round.phase === \"settled\" || round.phase === \"refunded\";","-  const outcomeColor = round.outcome ? OUTCOME_COLORS[round.outcome] ?? \"#94a3b8\" : \"#94a3b8\";","+  const outcomeColor = round.outcome ? OUTCOME_COLORS[round.outcome as keyof typeof OUTCOME_COLORS] ?? \"#94a3b8\" : \"#94a3b8\";"," ","   return (","     <div style={{ padding: \"2rem\", maxWidth: 640, margin: \"0 auto\" }}>"]}],"userModified":false,"replaceAll":false}}
