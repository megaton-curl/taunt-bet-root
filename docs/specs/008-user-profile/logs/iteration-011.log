{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PhFUdvHnLLoKeEDxu26C8C","type":"tool_result","content":"   150→// ---------------------------------------------------------------------------\n   151→\n   152→export interface Db {\n   153→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   154→  insertRound(params: InsertRoundParams): Promise<Round>;\n   155→\n   156→  /** Delete a round by PDA. Returns true if a row was removed. */\n   157→  deleteRoundByPda(pda: string): Promise<boolean>;\n   158→\n   159→  /** Transition a round's phase. Enforces unidirectional state machine.\n   160→   *  Optional `updates` can set additional columns alongside the phase change. */\n   161→  updateRoundPhase(\n   162→    pda: string,\n   163→    newPhase: RoundPhase,\n   164→    updates?: Partial<\n   165→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   166→    >,\n   167→  ): Promise<Round>;\n   168→\n   169→  /** Update the entries JSONB column for a settled round. */\n   170→  updateRoundEntries(\n   171→    pda: string,\n   172→    entries: Array<{ player: string; amountLamports: number }>,\n   173→  ): Promise<Round>;\n   174→\n   175→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   176→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   177→\n   178→  /** Get all rounds matching a given phase. */\n   179→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   180→\n   181→  /** Append an operator event to the audit log. */\n   182→  insertOperatorEvent(\n   183→    pda: string | null,\n   184→    eventType: OperatorEventType,\n   185→    payload?: unknown,\n   186→  ): Promise<OperatorEvent>;\n   187→\n   188→  /** Get the latest operator event for a PDA + type. */\n   189→  getLatestOperatorEvent(\n   190→    pda: string,\n   191→    eventType: OperatorEventType,\n   192→  ): Promise<OperatorEvent | undefined>;\n   193→\n   194→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   195→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   196→\n   197→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   198→  getLatestOperatorEventsForPdas(\n   199→    pdas: string[],\n   200→    eventType: OperatorEventType,\n   201→  ): Promise<Map<string, OperatorEvent>>;\n   202→\n   203→  /** Get recently settled rounds for a game, ordered newest first. */\n   204→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   205→\n   206→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   207→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   208→\n   209→  // -------------------------------------------------------------------------\n   210→  // Close Call rounds\n   211→  // -------------------------------------------------------------------------\n   212→\n   213→  /** Insert a new Close Call round. */\n   214→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   215→\n   216→  /** Get a Close Call round by round_id (16-char hex). */\n   217→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   218→\n   219→  /** Get the current active (open) Close Call round. */\n   220→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   221→\n   222→  /** Get the most recent settled/refunded Close Call rounds. */\n   223→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   224→\n   225→  /** Update a Close Call round after settlement. */\n   226→  settleCloseCallRound(\n   227→    roundId: string,\n   228→    updates: {\n   229→      phase: CloseCallPhase;\n   230→      outcome: CloseCallOutcome;\n   231→      closePrice?: number;\n   232→      greenPool?: number;\n   233→      redPool?: number;\n   234→      totalFee?: number;\n   235→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   236→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   237→      settleTx?: string;\n   238→    },\n   239→  ): Promise<CloseCallRound>;\n   240→\n   241→  // -------------------------------------------------------------------------\n   242→  // User transactions\n   243→  // -------------------------------------------------------------------------\n   244→\n   245→  /** Insert a user transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   246→  insertUserTransaction(params: InsertUserTransactionParams): Promise<void>;\n   247→\n   248→  /** Get paginated transactions for a wallet, newest first. */\n   249→  getUserTransactions(\n   250→    wallet: string,\n   251→    cursor?: string,\n   252→    limit?: number,\n   253→    game?: string,\n   254→  ): Promise<UserTransaction[]>;\n   255→\n   256→  /** Gracefully close the connection pool. */\n   257→  close(): Promise<void>;\n   258→}\n   259→\n   260→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   261→  return {\n   262→    ...row,\n   263→    open_price: Number(row.open_price),\n   264→    open_price_expo: Number(row.open_price_expo),\n   265→    close_price: row.close_price === null ? null : Number(row.close_price),\n   266→    green_pool: Number(row.green_pool),\n   267→    red_pool: Number(row.red_pool),\n   268→    total_fee: Number(row.total_fee),\n   269→    // JSONB comes back as parsed objects from postgres.js\n   270→    green_entries: Array.isArray(row.green_entries)\n   271→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   272→      : [],\n   273→    red_entries: Array.isArray(row.red_entries)\n   274→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   275→      : [],\n   276→  };\n   277→}\n   278→\n   279→function normalizeUserTransaction(row: UserTransaction): UserTransaction {\n   280→  return {\n   281→    ...row,\n   282→    amount_lamports: Number(row.amount_lamports),\n   283→  };\n   284→}\n   285→\n   286→function normalizeRound(row: Round): Round {\n   287→  return {\n   288→    ...row,\n   289→    amount_lamports: Number(row.amount_lamports),\n   290→    side: Number(row.side),\n   291→    settle_attempts: Number(row.settle_attempts),\n   292→    result_side: row.result_side === null ? null : Number(row.result_side),\n   293→    // JSONB comes back as parsed objects from postgres.js\n   294→    entries: Array.isArray(row.entries)\n   295→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   296→          player: e.player,\n   297→          amountLamports: Number(e.amountLamports),\n   298→        }))\n   299→      : null,\n   300→  };\n   301→}\n   302→\n   303→export function createDb(databaseUrl: string): Db {\n   304→  const sql = postgres(databaseUrl);\n   305→\n   306→  return {\n   307→    async insertRound(params) {\n   308→      const rows = await sql<Round[]>`\n   309→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   310→        VALUES (\n   311→          ${params.pda},\n   312→          ${params.game},\n   313→          ${params.creator},\n   314→          ${params.serverKey},\n   315→          ${params.secret},\n   316→          ${params.commitment},\n   317→          ${params.amountLamports},\n   318→          ${params.side},\n   319→          ${params.matchId},\n   320→          ${params.phase},\n   321→          ${params.entries ? sql.json(params.entries) : null}\n   322→        )\n   323→        RETURNING *\n   324→      `;\n   325→      return normalizeRound(rows[0]!);\n   326→    },\n   327→\n   328→    async deleteRoundByPda(pda) {\n   329→      const rows = await sql<{ pda: string }[]>`\n   330→        DELETE FROM rounds WHERE pda = ${pda}\n   331→        RETURNING pda\n   332→      `;\n   333→      return rows.length > 0;\n   334→    },\n   335→\n   336→    async updateRoundPhase(pda, newPhase, updates) {\n   337→      // Fetch current phase to validate transition\n   338→      const current = await sql<Pick<Round, \"phase\">[]>`\n   339→        SELECT phase FROM rounds WHERE pda = ${pda}\n   340→      `;\n   341→\n   342→      if (current.length === 0) {\n   343→        throw new Error(`Round not found: ${pda}`);\n   344→      }\n   345→\n   346→      const currentPhase = current[0]!.phase as RoundPhase;\n   347→      assertPhaseTransition(currentPhase, newPhase);\n   348→\n   349→      // Build the update — always set phase + updated_at"}]},"parent_tool_use_id":"toolu_01LzxN5vvC8UFeL2tZzCdkvU","session_id":"9dfcb3ed-4930-49c9-8526-cce92c2e50e0","uuid":"59f17d5f-5027-4e9a-bf87-4d8a767a1ab2","timestamp":"2026-03-19T20:19:41.307Z"}
