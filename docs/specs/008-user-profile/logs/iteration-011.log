{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016TmQjLayjXVXVFwx3B2FgD","type":"tool_result","content":"     1→/**\n     2→ * POST /fairness/coinflip/create — endpoint handler.\n     3→ *\n     4→ * Generates a server secret, computes the commitment, builds a partially-signed\n     5→ * create_match transaction, stores the round in the DB, and returns the\n     6→ * serialized transaction + match PDA + commitment to the caller.\n     7→ *\n     8→ * Authentication is handled by the JWT middleware upstream — the wallet address\n     9→ * is available via c.get(\"wallet\").\n    10→ */\n    11→\n    12→import { Hono } from \"hono\";\n    13→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n    14→import { generateSecret, computeCommitment, generateMatchId, deriveMatchPda } from \"../fairness.js\";\n    15→import { buildCreateMatchTx } from \"../tx-builder.js\";\n    16→import type { Db } from \"../db.js\";\n    17→import { logger } from \"../logger.js\";\n    18→import type { AppEnv } from \"../hono-env.js\";\n    19→import type { PdaWatcher } from \"../worker/pda-watcher.js\";\n    20→\n    21→export interface CreateRoutesDeps {\n    22→  db: Db;\n    23→  connection: Connection;\n    24→  serverKeypair: Keypair;\n    25→  pdaWatcher?: PdaWatcher;\n    26→}\n    27→\n    28→/** Minimum wager in lamports: 0.001 SOL */\n    29→const MIN_WAGER_LAMPORTS = 1_000_000;\n    30→const MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n    31→\n    32→interface CreateRequestBody {\n    33→  wallet: string;\n    34→  amountLamports: number;\n    35→  side: number;\n    36→}\n    37→\n    38→function isValidBase58(s: string): boolean {\n    39→  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n    40→}\n    41→\n    42→function validateBody(body: unknown): CreateRequestBody {\n    43→  if (!body || typeof body !== \"object\") {\n    44→    throw new Error(\"Request body must be a JSON object\");\n    45→  }\n    46→\n    47→  const b = body as Record<string, unknown>;\n    48→\n    49→  if (typeof b.wallet !== \"string\" || !isValidBase58(b.wallet)) {\n    50→    throw new Error(\"wallet must be a valid base58 public key\");\n    51→  }\n    52→\n    53→  if (\n    54→    typeof b.amountLamports !== \"number\" ||\n    55→    !Number.isInteger(b.amountLamports) ||\n    56→    b.amountLamports < MIN_WAGER_LAMPORTS ||\n    57→    b.amountLamports > MAX_WAGER_LAMPORTS\n    58→  ) {\n    59→    throw new Error(`amountLamports must be an integer between ${MIN_WAGER_LAMPORTS} and ${MAX_WAGER_LAMPORTS}`);\n    60→  }\n    61→\n    62→  if (typeof b.side !== \"number\" || (b.side !== 0 && b.side !== 1)) {\n    63→    throw new Error(\"side must be 0 (Heads) or 1 (Tails)\");\n    64→  }\n    65→\n    66→  return {\n    67→    wallet: b.wallet,\n    68→    amountLamports: b.amountLamports,\n    69→    side: b.side,\n    70→  };\n    71→}\n    72→\n    73→export function createCoinflipRoutes(deps: CreateRoutesDeps) {\n    74→  const { db, connection, serverKeypair, pdaWatcher } = deps;\n    75→\n    76→  const app = new Hono<AppEnv>();\n    77→\n    78→  app.post(\"/create\", async (c) => {\n    79→    // 1. Parse + validate request body\n    80→    let body: CreateRequestBody;\n    81→    try {\n    82→      const raw = await c.req.json();\n    83→      body = validateBody(raw);\n    84→    } catch (err) {\n    85→      logger.warn(\"coinflip create rejected: invalid request body\", {\n    86→        error: err instanceof Error ? err.message : \"Invalid request body\",\n    87→      });\n    88→      return c.json(\n    89→        { error: err instanceof Error ? err.message : \"Invalid request body\" },\n    90→        400,\n    91→      );\n    92→    }\n    93→\n    94→    // 2. Defense-in-depth: verify body wallet matches JWT subject\n    95→    const jwtWallet = c.get(\"wallet\") as string | undefined;\n    96→    if (jwtWallet && body.wallet !== jwtWallet) {\n    97→      logger.warn(\"coinflip create rejected: wallet mismatch with JWT\", {\n    98→        bodyWallet: body.wallet,\n    99→        jwtWallet,\n   100→      });\n   101→      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n   102→    }\n   103→\n   104→    // 3. Validate wallet is a real public key\n   105→    let creatorPubkey: PublicKey;\n   106→    try {\n   107→      creatorPubkey = new PublicKey(body.wallet);\n   108→    } catch {\n   109→      logger.warn(\"coinflip create rejected: invalid wallet\", {\n   110→        wallet: body.wallet,\n   111→      });\n   112→      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n   113→    }\n   114→\n   115→    logger.info(\"coinflip create requested\", {\n   116→      wallet: body.wallet,\n   117→      amountLamports: body.amountLamports,\n   118→      side: body.side,\n   119→    });\n   120→\n   121→    // 4. Generate secret + commitment + matchId\n   122→    const secret = generateSecret();\n   123→    const commitment = computeCommitment(secret);\n   124→    const matchId = generateMatchId();\n   125→\n   126→    // 5. Derive PDA\n   127→    const [matchPda] = deriveMatchPda(creatorPubkey, matchId);\n   128→    const matchPdaStr = matchPda.toBase58();\n   129→\n   130→    // 6. Check for duplicate PDA in DB (409 Conflict)\n   131→    const existing = await db.getRoundByPda(matchPdaStr);\n   132→    if (existing) {\n   133→      logger.warn(\"coinflip create rejected: duplicate match PDA\", {\n   134→        wallet: body.wallet,\n   135→        matchPda: matchPdaStr,\n   136→        matchId: matchId.toString(\"hex\"),\n   137→      });\n   138→      return c.json(\n   139→        { error: \"Match ID collision — please retry\" },\n   140→        409,\n   141→      );\n   142→    }\n   143→\n   144→    // 7. Build + partial-sign transaction\n   145→    let transaction: string;\n   146→    let lastValidBlockHeight: number;\n   147→    try {\n   148→      const result = await buildCreateMatchTx({\n   149→        connection,\n   150→        creator: creatorPubkey,\n   151→        serverKeypair,\n   152→        commitment,\n   153→        amountLamports: body.amountLamports,\n   154→        side: body.side,\n   155→        matchId,\n   156→      });\n   157→      transaction = result.transaction;\n   158→      lastValidBlockHeight = result.lastValidBlockHeight;\n   159→    } catch (err) {\n   160→      logger.error(\"coinflip create failed: transaction build error\", {\n   161→        wallet: body.wallet,\n   162→        matchPda: matchPdaStr,\n   163→        matchId: matchId.toString(\"hex\"),\n   164→        error: err instanceof Error ? err.message : \"Failed to build transaction\",\n   165→      });\n   166→      return c.json(\n   167→        { error: \"Failed to build transaction\" },\n   168→        500,\n   169→      );\n   170→    }\n   171→\n   172→    // 8. Store round in DB (phase: created)\n   173→    try {\n   174→      await db.insertRound({\n   175→        pda: matchPdaStr,\n   176→        game: \"coinflip\",\n   177→        creator: body.wallet,\n   178→        serverKey: serverKeypair.publicKey.toBase58(),\n   179→        secret,\n   180→        commitment,\n   181→        amountLamports: body.amountLamports,\n   182→        side: body.side,\n   183→        matchId: matchId.toString(\"hex\"),\n   184→        phase: \"created\",\n   185→      });\n   186→    } catch (err) {\n   187→      // Handle race condition — another request inserted the same PDA\n   188→      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n   189→        logger.warn(\"coinflip create rejected: round insert duplicate\", {\n   190→          wallet: body.wallet,\n   191→          matchPda: matchPdaStr,\n   192→          matchId: matchId.toString(\"hex\"),\n   193→        });\n   194→        return c.json(\n   195→          { error: \"Match ID collision — please retry\" },\n   196→          409,\n   197→        );\n   198→      }\n   199→      logger.error(\"coinflip create failed: round insert error\", {\n   200→        wallet: body.wallet,\n   201→        matchPda: matchPdaStr,\n   202→        matchId: matchId.toString(\"hex\"),\n   203→        error: err instanceof Error ? err.message : String(err),\n   204→      });\n   205→      throw err;\n   206→    }\n   207→\n   208→    // 9. Write user transaction — creator join\n   209→    await db.insertUserTransaction({\n   210→      wallet: body.wallet,\n   211→      game: \"coinflip\",\n   212→      matchId: matchId.toString(\"hex\"),\n   213→      event: \"join\",\n   214→      amountLamports: body.amountLamports,\n   215→    });\n   216→\n   217→    // 10. Write operator event\n   218→    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n   219→      creator: body.wallet,\n   220→      amountLamports: body.amountLamports,\n   221→      side: body.side,\n   222→      matchId: matchId.toString(\"hex\"),\n   223→    });\n   224→\n   225→    // 9b. Subscribe to PDA for instant join detection via WebSocket\n   226→    pdaWatcher?.watch(matchPdaStr);\n   227→\n   228→    logger.info(\"coinflip create prepared\", {\n   229→      wallet: body.wallet,\n   230→      matchPda: matchPdaStr,\n   231→      matchId: matchId.toString(\"hex\"),\n   232→      amountLamports: body.amountLamports,\n   233→      side: body.side,\n   234→      lastValidBlockHeight,\n   235→    });\n   236→\n   237→    // 10. Return response\n   238→    return c.json({\n   239→      transaction,\n   240→      matchPda: matchPdaStr,\n   241→      matchId: matchId.toString(\"hex\"),\n   242→      commitment: commitment.toString(\"hex\"),\n   243→      lastValidBlockHeight,\n   244→    });\n   245→  });\n   246→\n   247→  return app;\n   248→}\n   249→"}]},"parent_tool_use_id":"toolu_01LzxN5vvC8UFeL2tZzCdkvU","session_id":"9dfcb3ed-4930-49c9-8526-cce92c2e50e0","uuid":"9e65c956-ea82-4707-8d79-bd9c31f13ee6","timestamp":"2026-03-19T20:19:28.739Z"}
