{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WtEBoXmP5v2BJquhMwLDEp","type":"tool_result","content":"     1→/**\n     2→ * Integration test: full create → join → settle lifecycle.\n     3→ *\n     4→ * Uses a mock Solana Connection to simulate on-chain state while exercising\n     5→ * the real HTTP endpoints, database, settlement worker, and retry logic\n     6→ * end-to-end. Auth uses JWT Bearer tokens (HS256).\n     7→ */\n     8→\n     9→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    10→import { Hono } from \"hono\";\n    11→import {\n    12→  Keypair,\n    13→  PublicKey,\n    14→  SystemProgram,\n    15→  LAMPORTS_PER_SOL,\n    16→} from \"@solana/web3.js\";\n    17→import type { Connection } from \"@solana/web3.js\";\n    18→import bs58 from \"bs58\";\n    19→import { SignJWT } from \"jose\";\n    20→import postgres from \"postgres\";\n    21→import { createDb, type Db } from \"../db.js\";\n    22→import { createCoinflipRoutes } from \"../routes/create.js\";\n    23→import { createRoundsRoutes } from \"../routes/rounds.js\";\n    24→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    25→import { createSettlementWorker } from \"../worker/settlement.js\";\n    26→import { settleMatch } from \"../worker/settle-tx.js\";\n    27→import { createRetrySettler } from \"../worker/retry.js\";\n    28→import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n    29→import { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Constants\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    36→const AMOUNT_LAMPORTS = 5_000_000;\n    37→const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n    38→const SIDE_HEADS = 0;\n    39→const PHASE_LOCKED = 1;\n    40→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n    41→\n    42→// ---------------------------------------------------------------------------\n    43→// JWT helper\n    44→// ---------------------------------------------------------------------------\n    45→\n    46→async function makeJwt(wallet: string) {\n    47→  const now = Math.floor(Date.now() / 1000);\n    48→  return new SignJWT({ sub: wallet })\n    49→    .setProtectedHeader({ alg: \"HS256\" })\n    50→    .setIssuedAt(now)\n    51→    .setExpirationTime(now + 3600)\n    52→    .sign(JWT_SECRET);\n    53→}\n    54→\n    55→// ---------------------------------------------------------------------------\n    56→// Mock Connection\n    57→// ---------------------------------------------------------------------------\n    58→\n    59→/**\n    60→ * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n    61→ * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n    62→ * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n    63→ */\n    64→class MockConnection {\n    65→  private _slot = 200;\n    66→  private _accounts = new Map<\n    67→    string,\n    68→    {\n    69→      data: Buffer;\n    70→      lamports: number;\n    71→      owner: PublicKey;\n    72→      executable: boolean;\n    73→    }\n    74→  >();\n    75→  lastRawTx: Buffer | null = null;\n    76→\n    77→  set slot(s: number) {\n    78→    this._slot = s;\n    79→  }\n    80→  get slot() {\n    81→    return this._slot;\n    82→  }\n    83→\n    84→  setAccount(\n    85→    pubkey: PublicKey,\n    86→    data: Buffer,\n    87→    opts?: { lamports?: number; owner?: PublicKey },\n    88→  ) {\n    89→    this._accounts.set(pubkey.toBase58(), {\n    90→      data,\n    91→      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n    92→      owner: opts?.owner ?? SystemProgram.programId,\n    93→      executable: false,\n    94→    });\n    95→  }\n    96→\n    97→  removeAccount(pubkey: PublicKey) {\n    98→    this._accounts.delete(pubkey.toBase58());\n    99→  }\n   100→\n   101→  async getLatestBlockhash() {\n   102→    return {\n   103→      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n   104→      lastValidBlockHeight: 999_999,\n   105→    };\n   106→  }\n   107→\n   108→  async getSlot() {\n   109→    return this._slot;\n   110→  }\n   111→\n   112→  async getAccountInfo(pubkey: PublicKey) {\n   113→    const acc = this._accounts.get(pubkey.toBase58());\n   114→    if (!acc) return null;\n   115→    return { ...acc, rentEpoch: 0 };\n   116→  }\n   117→\n   118→  async getProgramAccounts(\n   119→    programId: PublicKey,\n   120→    config?: {\n   121→      filters?: Array<\n   122→        | { dataSize: number }\n   123→        | { memcmp: { offset: number; bytes: string } }\n   124→      >;\n   125→    },\n   126→  ) {\n   127→    const results: Array<{\n   128→      pubkey: PublicKey;\n   129→      account: {\n   130→        data: Buffer;\n   131→        lamports: number;\n   132→        owner: PublicKey;\n   133→        executable: boolean;\n   134→        rentEpoch: number;\n   135→      };\n   136→    }> = [];\n   137→\n   138→    for (const [key, acc] of this._accounts) {\n   139→      if (!acc.owner.equals(programId)) continue;\n   140→\n   141→      let matches = true;\n   142→      if (config?.filters) {\n   143→        for (const filter of config.filters) {\n   144→          if (\"dataSize\" in filter) {\n   145→            if (acc.data.length !== filter.dataSize) {\n   146→              matches = false;\n   147→              break;\n   148→            }\n   149→          }\n   150→          if (\"memcmp\" in filter) {\n   151→            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n   152→            const actual = acc.data.subarray(\n   153→              filter.memcmp.offset,\n   154→              filter.memcmp.offset + expected.length,\n   155→            );\n   156→            if (Buffer.compare(actual, expected) !== 0) {\n   157→              matches = false;\n   158→              break;\n   159→            }\n   160→          }\n   161→        }\n   162→      }\n   163→\n   164→      if (matches) {\n   165→        results.push({\n   166→          pubkey: new PublicKey(key),\n   167→          account: { ...acc, rentEpoch: 0 },\n   168→        });\n   169→      }\n   170→    }\n   171→    return results;\n   172→  }\n   173→\n   174→  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n   175→    this.lastRawTx = Buffer.from(rawTx);\n   176→    // Return a deterministic fake signature\n   177→    return bs58.encode(Buffer.alloc(64, 0x01));\n   178→  }\n   179→\n   180→  async confirmTransaction() {\n   181→    return { value: { err: null }, context: { slot: this._slot } };\n   182→  }\n   183→\n   184→  async getBalance() {\n   185→    return 2 * LAMPORTS_PER_SOL;\n   186→  }\n   187→}\n   188→\n   189→// ---------------------------------------------------------------------------\n   190→// Account data builders\n   191→// ---------------------------------------------------------------------------\n   192→\n   193→async function buildMatchAccountData(params: {\n   194→  creator: PublicKey;\n   195→  opponent: PublicKey;\n   196→  server: PublicKey;\n   197→  entryAmount: bigint;\n   198→  creatorSide: number;\n   199→  phase: number;\n   200→  commitment: Buffer;\n   201→  algorithmVer: number;\n   202→  targetSlot: bigint;\n   203→  resolveDeadline: bigint;\n   204→  matchId: Buffer;\n   205→}): Promise<Buffer> {\n   206→  return encodeCoinflipMatch({\n   207→    creator: params.creator,\n   208→    opponent: params.opponent,\n   209→    server: params.server,\n   210→    entryAmount: params.entryAmount,\n   211→    creatorSide: params.creatorSide,\n   212→    phase: params.phase,\n   213→    commitment: [...params.commitment],\n   214→    algorithmVer: params.algorithmVer,\n   215→    targetSlot: params.targetSlot,\n   216→    resolveDeadline: params.resolveDeadline,\n   217→    resultHash: new Array(32).fill(0),\n   218→    result: 0,\n   219→    winner: PublicKey.default,\n   220→    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n   221→    matchId: [...params.matchId],\n   222→    bump: 0,\n   223→  });\n   224→}\n   225→\n   226→async function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n   227→  return encodeCoinflipConfig({\n   228→    authority: PublicKey.default,\n   229→    treasury,\n   230→    paused: false,\n   231→    bump: 0,\n   232→  });\n   233→}\n   234→\n   235→// ---------------------------------------------------------------------------\n   236→// Test suite\n   237→// ---------------------------------------------------------------------------\n   238→\n   239→describe(\"Integration: create → join → settle lifecycle\", () => {\n   240→  let db: Db;\n   241→  let rawSql: ReturnType<typeof postgres>;\n   242→  let mockConn: MockConnection;\n   243→  let app: Hono;\n   244→\n   245→  const serverKeypair = Keypair.generate();\n   246→  const creatorKeypair = Keypair.generate();\n   247→  const opponentKeypair = Keypair.generate();\n   248→  const treasuryKeypair = Keypair.generate();\n   249→  const entropyKeypair = Keypair.generate();\n   250→  const entropyAccount = entropyKeypair.publicKey;\n   251→\n   252→  const entropyData = Buffer.alloc(32);\n   253→  entropyData[0] = 0xab;\n   254→  entropyData[1] = 0xcd;\n   255→  entropyData[15] = 0x42;\n   256→\n   257→  beforeAll(async () => {\n   258→    db = createDb(DATABASE_URL);\n   259→    rawSql = postgres(DATABASE_URL);\n   260→  });\n   261→\n   262→  afterAll(async () => {\n   263→    await db.close();\n   264→    await rawSql.end();\n   265→  });\n   266→\n   267→  beforeEach(async () => {\n   268→    // Clean tables for isolation\n   269→    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n   270→\n   271→    // Fresh mock Connection\n   272→    mockConn = new MockConnection();\n   273→\n   274→    // Pre-populate mock with entropy and config accounts\n   275→    mockConn.setAccount(entropyAccount, entropyData);\n   276→\n   277→    const [configPda] = PublicKey.findProgramAddressSync(\n   278→      [Buffer.from(\"coinflip_config\")],\n   279→      COINFLIP_PROGRAM_ID,\n   280→    );\n   281→    mockConn.setAccount(\n   282→      configPda,\n   283→      await buildConfigAccountData(treasuryKeypair.publicKey),\n   284→      { owner: COINFLIP_PROGRAM_ID },\n   285→    );\n   286→\n   287→    // Build the Hono app (no rate limiting for tests)\n   288→    app = new Hono();\n   289→\n   290→    app.use(\n   291→      \"/fairness/*\",\n   292→      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n   293→    );\n   294→\n   295→    app.route(\n   296→      \"/fairness/coinflip\",\n   297→      createCoinflipRoutes({\n   298→        db,\n   299→        connection: mockConn as unknown as Connection,\n   300→        serverKeypair,\n   301→      }),\n   302→    );\n   303→\n   304→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   305→  });\n   306→\n   307→  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n   308→    const wallet = creatorKeypair.publicKey.toBase58();\n   309→    const token = await makeJwt(wallet);\n   310→\n   311→    // ------------------------------------------------------------------\n   312→    // 1. POST /fairness/coinflip/create\n   313→    // ------------------------------------------------------------------\n   314→    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   315→\n   316→    const createRes = await app.request(\"/fairness/coinflip/create\", {\n   317→      method: \"POST\",\n   318→      headers: {\n   319→        \"Content-Type\": \"application/json\",\n   320→        \"Authorization\": `Bearer ${token}`,\n   321→      },\n   322→      body: JSON.stringify(body),\n   323→    });\n   324→\n   325→    expect(createRes.status).toBe(200);\n   326→    const createJson = (await createRes.json()) as {\n   327→      transaction: string;\n   328→      matchPda: string;\n   329→      matchId: string;\n   330→      commitment: string;\n   331→      lastValidBlockHeight: number;\n   332→    };\n   333→    expect(createJson.transaction).toBeDefined();\n   334→    expect(createJson.matchPda).toBeDefined();\n   335→    expect(createJson.commitment).toBeDefined();\n   336→    expect(createJson.lastValidBlockHeight).toBeDefined();\n   337→\n   338→    const matchPda = createJson.matchPda;\n   339→    const commitmentHex = createJson.commitment;\n   340→    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n   341→\n   342→    // ------------------------------------------------------------------\n   343→    // 2. Verify DB state — round in \"created\" phase\n   344→    // ------------------------------------------------------------------\n   345→    const round = await db.getRoundByPda(matchPda);\n   346→    expect(round).toBeDefined();\n   347→    expect(round!.phase).toBe(\"created\");\n   348→    expect(round!.game).toBe(\"coinflip\");\n   349→    expect(round!.creator).toBe(wallet);\n   350→    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n   351→    expect(round!.side).toBe(SIDE_HEADS);\n   352→    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n   353→    expect(round!.secret).toBeDefined();\n   354→    expect(round!.secret.length).toBe(32);\n   355→\n   356→    // Verify operator event was logged\n   357→    const events =\n   358→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   359→    expect(events.length).toBe(1);\n   360→    expect(events[0]!.event_type).toBe(\"secret_generated\");\n   361→\n   362→    // ------------------------------------------------------------------\n   363→    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n   364→    // ------------------------------------------------------------------\n   365→    const matchPubkey = new PublicKey(matchPda);\n   366→    const targetSlot = 150n;\n   367→    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n   368→\n   369→    const matchAccountData = await buildMatchAccountData({\n   370→      creator: creatorKeypair.publicKey,\n   371→      opponent: opponentKeypair.publicKey,\n   372→      server: serverKeypair.publicKey,\n   373→      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n   374→      creatorSide: SIDE_HEADS,\n   375→      phase: PHASE_LOCKED,\n   376→      commitment: commitmentBuf,\n   377→      algorithmVer: 1,\n   378→      targetSlot,\n   379→      resolveDeadline,\n   380→      matchId: Buffer.from(createJson.matchId, \"hex\"),\n   381→    });\n   382→\n   383→    mockConn.setAccount(matchPubkey, matchAccountData, {\n   384→      owner: COINFLIP_PROGRAM_ID,\n   385→    });\n   386→\n   387→    // Set current slot past target_slot so settlement triggers immediately\n   388→    mockConn.slot = 200;\n   389→\n   390→    // ------------------------------------------------------------------\n   391→    // 4. Create worker + retry settler, trigger poll\n   392→    // ------------------------------------------------------------------\n   393→    let settlePromise: Promise<void> | null = null;\n   394→\n   395→    const retrySettler = createRetrySettler({\n   396→      db,\n   397→      connection: mockConn as unknown as Connection,\n   398→      settleRound: (pda) =>\n   399→        settleMatch(\n   400→          {\n   401→            db,\n   402→            connection: mockConn as unknown as Connection,\n   403→            serverKeypair,\n   404→            entropyAccount,\n   405→          },\n   406→          pda,\n   407→        ),\n   408→    });\n   409→\n   410→    const worker = createSettlementWorker({\n   411→      db,\n   412→      connection: mockConn as unknown as Connection,\n   413→      serverKey: serverKeypair.publicKey,\n   414→      pollIntervalMs: 60_000, // won't auto-poll\n   415→      onSettleReady: (pda) => {\n   416→        settlePromise = retrySettler.attemptSettle(pda);\n   417→        return settlePromise;\n   418→      },\n   419→    });\n   420→\n   421→    // Single poll cycle — should discover locked match and settle it\n   422→    await worker.poll();\n   423→    if (settlePromise) await settlePromise;\n   424→\n   425→    // ------------------------------------------------------------------\n   426→    // 5. Verify DB updated to \"settled\" with result data\n   427→    // ------------------------------------------------------------------\n   428→    const settled = await db.getRoundByPda(matchPda);\n   429→    expect(settled).toBeDefined();\n   430→    expect(settled!.phase).toBe(\"settled\");\n   431→    expect(settled!.settle_tx).toBeDefined();\n   432→    expect(settled!.result_hash).toBeDefined();\n   433→    expect(settled!.result_hash!.length).toBe(32);\n   434→    expect(settled!.result_side).toBeDefined();\n   435→    expect([0, 1]).toContain(settled!.result_side);\n   436→    expect(settled!.winner).toBeDefined();\n   437→\n   438→    // Winner should be one of the two players\n   439→    expect([\n   440→      creatorKeypair.publicKey.toBase58(),\n   441→      opponentKeypair.publicKey.toBase58(),\n   442→    ]).toContain(settled!.winner);\n   443→\n   444→    // Verify operator events trail\n   445→    const allEvents =\n   446→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   447→    const eventTypes = allEvents.map(\n   448→      (e) => (e as Record<string, unknown>).event_type,\n   449→    );\n   450→    expect(eventTypes).toContain(\"secret_generated\");\n   451→    expect(eventTypes).toContain(\"match_detected\");\n   452→    expect(eventTypes).toContain(\"settle_submitted\");\n   453→    expect(eventTypes).toContain(\"settle_confirmed\");\n   454→\n   455→    // ------------------------------------------------------------------\n   456→    // 6. GET /fairness/rounds/:pda — verify response includes secret\n   457→    // ------------------------------------------------------------------\n   458→    const roundsRes = await app.request(`/fairness/rounds/${matchPda}`);\n   459→    expect(roundsRes.status).toBe(200);\n   460→\n   461→    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n   462→    expect(roundsJson.pda).toBe(matchPda);\n   463→    expect(roundsJson.phase).toBe(\"settled\");\n   464→    expect(roundsJson.game).toBe(\"coinflip\");\n   465→    expect(roundsJson.creator).toBe(wallet);\n   466→    expect(roundsJson.commitment).toBe(commitmentHex);\n   467→\n   468→    // Settled round should include secret + verification payload\n   469→    expect(roundsJson.secret).toBeDefined();\n   470→    expect(typeof roundsJson.secret).toBe(\"string\");\n   471→    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n   472→    expect(roundsJson.resultHash).toBeDefined();\n   473→    expect(roundsJson.resultSide).toBeDefined();\n   474→    expect(roundsJson.winner).toBeDefined();\n   475→    expect(roundsJson.settleTx).toBeDefined();\n   476→\n   477→    // Verification object\n   478→    const verification = roundsJson.verification as Record<string, string>;\n   479→    expect(verification).toBeDefined();\n   480→    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n   481→    expect(verification.resultFormula).toContain(\"sha256(secret\");\n   482→    expect(verification.entropySource).toContain(\"SlotHashes\");\n   483→  });\n   484→\n   485→  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n   486→    const unknownPda = Keypair.generate().publicKey.toBase58();\n   487→    const res = await app.request(`/fairness/rounds/${unknownPda}`);\n   488→    expect(res.status).toBe(404);\n   489→  });\n   490→\n   491→  it(\"unsettled round does not expose secret\", async () => {\n   492→    const wallet = creatorKeypair.publicKey.toBase58();\n   493→    const token = await makeJwt(wallet);\n   494→\n   495→    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   496→\n   497→    const res = await app.request(\"/fairness/coinflip/create\", {\n   498→      method: \"POST\",\n   499→      headers: {\n   500→        \"Content-Type\": \"application/json\",\n   501→        \"Authorization\": `Bearer ${token}`,\n   502→      },\n   503→      body: JSON.stringify(body),\n   504→    });\n   505→    expect(res.status).toBe(200);\n   506→    const json = (await res.json()) as { matchPda: string };\n   507→\n   508→    // GET the unsettled round\n   509→    const roundRes = await app.request(`/fairness/rounds/${json.matchPda}`);\n   510→    expect(roundRes.status).toBe(200);\n   511→    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n   512→    expect(roundJson.phase).toBe(\"created\");\n   513→    expect(roundJson.secret).toBeUndefined();\n   514→    expect(roundJson.resultHash).toBeUndefined();\n   515→    expect(roundJson.verification).toBeUndefined();\n   516→  });\n   517→\n   518→  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n   519→    const wallet = creatorKeypair.publicKey.toBase58();\n   520→    const token = await makeJwt(wallet);\n   521→\n   522→    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   523→    const res1 = await app.request(\"/fairness/coinflip/create\", {\n   524→      method: \"POST\",\n   525→      headers: {\n   526→        \"Content-Type\": \"application/json\",\n   527→        \"Authorization\": `Bearer ${token}`,\n   528→      },\n   529→      body: JSON.stringify(body1),\n   530→    });\n   531→    expect(res1.status).toBe(200);\n   532→\n   533→    // Second request — different random matchId generated server-side\n   534→    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   535→    const res2 = await app.request(\"/fairness/coinflip/create\", {\n   536→      method: \"POST\",\n   537→      headers: {\n   538→        \"Content-Type\": \"application/json\",\n   539→        \"Authorization\": `Bearer ${token}`,\n   540→      },\n   541→      body: JSON.stringify(body2),\n   542→    });\n   543→    expect(res2.status).toBe(200);\n   544→\n   545→    // Both should have different matchIds and PDAs\n   546→    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n   547→    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n   548→    expect(json1.matchPda).not.toBe(json2.matchPda);\n   549→    expect(json1.matchId).not.toBe(json2.matchId);\n   550→  });\n   551→});\n   552→"}]},"parent_tool_use_id":"toolu_01LzxN5vvC8UFeL2tZzCdkvU","session_id":"9dfcb3ed-4930-49c9-8526-cce92c2e50e0","uuid":"6ddd08f5-a18b-4ec1-aeb0-4be836923d5c","timestamp":"2026-03-19T20:19:27.992Z"}
