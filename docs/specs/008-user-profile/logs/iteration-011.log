ublicKey;\n   129→      account: {\n   130→        data: Buffer;\n   131→        lamports: number;\n   132→        owner: PublicKey;\n   133→        executable: boolean;\n   134→        rentEpoch: number;\n   135→      };\n   136→    }> = [];\n   137→\n   138→    for (const [key, acc] of this._accounts) {\n   139→      if (!acc.owner.equals(programId)) continue;\n   140→\n   141→      let matches = true;\n   142→      if (config?.filters) {\n   143→        for (const filter of config.filters) {\n   144→          if (\"dataSize\" in filter) {\n   145→            if (acc.data.length !== filter.dataSize) {\n   146→              matches = false;\n   147→              break;\n   148→            }\n   149→          }\n   150→          if (\"memcmp\" in filter) {\n   151→            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n   152→            const actual = acc.data.subarray(\n   153→              filter.memcmp.offset,\n   154→              filter.memcmp.offset + expected.length,\n   155→            );\n   156→            if (Buffer.compare(actual, expected) !== 0) {\n   157→              matches = false;\n   158→              break;\n   159→            }\n   160→          }\n   161→        }\n   162→      }\n   163→"}]},"parent_tool_use_id":null,"session_id":"9dfcb3ed-4930-49c9-8526-cce92c2e50e0","uuid":"1c89ac6e-dd1c-47c7-a9c4-790d4223464b","timestamp":"2026-03-19T20:24:02.633Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/integration.test.ts","content":"class MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getSlot() {\n    return this._slot;\n  }\n\n  async getAccountInfo(pubkey: PublicKey) {\n    const acc = this._accounts.get(pubkey.toBase58());\n    if (!acc) return null;\n    return { ...acc, rentEpoch: 0 };\n  }\n\n  async getProgramAccounts(\n    programId: PublicKey,\n    config?: {\n      filters?: Array<\n        | { dataSize: number }\n        | { memcmp: { offset: number; bytes: string } }\n      >;\n    },\n  ) {\n    const results: Array<{\n      pubkey: PublicKey;\n      account: {\n        data: Buffer;\n        lamports: number;\n        owner: PublicKey;\n        executable: boolean;\n        rentEpoch: number;\n      };\n    }> = [];\n\n    for (const [key, acc] of this._accounts) {\n      if (!acc.owner.equals(programId)) continue;\n\n      let matches = true;\n      if (config?.filters) {\n        for (const filter of config.filters) {\n          if (\"dataSize\" in filter) {\n            if (acc.data.length !== filter.dataSize) {\n              matches = false;\n              break;\n            }\n          }\n          if (\"memcmp\" in filter) {\n            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n            const actual = acc.data.subarray(\n              filter.memcmp.offset,\n              filter.memcmp.offset + expected.length,\n            );\n            if (Buffer.compare(actual, expected) !== 0) {\n              matches = false;\n              break;\n            }\n          }\n        }\n      }\n"