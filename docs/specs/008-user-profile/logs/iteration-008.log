{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018pUYyzc6YiHjDfK58y9DsW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015yz5bduoAGYzaqAyjxzSm4","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/hooks/useSolPrice.ts","content":"/**\n * useSolPrice — fetches cached SOL/USD price from the backend.\n *\n * Refreshes every 60s. Returns null when price is unavailable.\n */\n\nimport { useState, useEffect, useRef } from \"react\";\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\nconst REFRESH_INTERVAL_MS = 60_000;\n\nexport function useSolPrice(): number | null {\n  const [price, setPrice] = useState<number | null>(null);\n  const intervalRef = useRef<ReturnType<typeof setInterval> | null>(null);\n\n  useEffect(() => {\n    let cancelled = false;\n\n    async function fetchPrice() {\n      try {\n        const res = await fetch(`${BACKEND_URL}/price/sol-usd`);\n        if (!res.ok) return;\n        const data: { price: number } = await res.json();\n        if (!cancelled) setPrice(data.price);\n      } catch {\n        // Graceful degradation — keep previous price or null\n      }\n    }\n\n    fetchPrice();\n    intervalRef.current = setInterval(fetchPrice, REFRESH_INTERVAL_MS);\n\n    return () => {\n      cancelled = true;\n      if (intervalRef.current) clearInterval(intervalRef.current);\n    };\n  }, []);\n\n  return price;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1116,"cache_read_input_tokens":38000,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1116},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"sess