le with event types, amounts, and match links.\n */\n\nimport { GAME_NAMES } from \"../types\";\nimport type { GameId } from \"../types\";\nimport { useTransactions } from \"../hooks/useTransactions\";\n\n/** Format lamports as SOL string (e.g. \"0.50 SOL\") */\nfunction formatSol(lamports: string): string {\n  const sol = Number(lamports) / 1e9;\n  // Use up to 4 decimal places, strip trailing zeros\n  return sol.toLocaleString(\"en-US\", {\n    minimumFractionDigits: 2,\n    maximumFractionDigits: 4,\n  }) + \" SOL\";\n}\n\n/** Format ISO date as relative time */\nfunction formatTime(iso: string): string {\n  const date = new Date(iso);\n  const diffMs = Date.now() - date.getTime();\n  const diffMins = Math.floor(diffMs / 60000);\n  const diffHours = Math.floor(diffMs / 3600000);\n  const diffDays = Math.floor(diffMs / 86400000);\n\n  if (diffMins < 1) return \"Just now\";\n  if (diffMins < 60) return `${diffMins}m ago`;\n  if (diffHours < 24) return `${diffHours}h ago`;\n  if (diffDays < 7) return `${diffDays}d ago`;\n  return date.toLocaleDateString();\n}\n\n/** Build the deep-link path for a match */\nfunction matchPath(gameId: GameId, matchId: string): string {\n  return `/${gameId}/${matchId}`;\n}\n\n/** Event display label */\nconst EVENT_LABELS: Record<string, string> = {\n  join: \"JOIN\",\n  win: \"WIN\",\n  loss: \"LOSS\",\n  refund: \"REFUND\",\n};\n\nexport function ProfileTransactions() {\n  const { transactions, loading, loadingMore, nextCursor, loadMore } =\n    useTransactions();\n\n  if (loading) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__skeleton\">\n          {Array.from({ length: 5 }, (_, i) => (\n            <div key={i} className=\"profile-transactions__skeleton-row\" />\n          ))}\n        </div>\n      </div>\n    );\n  }\n\n  if (transactions.length === 0) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__empty\">\n          <p>No transactions yet.</p>\n          <p>Start playing to build your history!</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"profile-transactions\">\n      <table className=\"profile-transactions__table\">\n        <thead>\n          <tr>\n            <th>Time</th>\n            <th>Game</th>\n            <th>Event</th>\n            <th>Amount</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id}>\n              <td>{formatTime(tx.createdAt)}</td>\n              <td>\n                <a\n                  href={matchPath(tx.gameId, tx.matchId)}\n                  className=\"profile-transactions__match-link\"\n                >\n                  {GAME_NAMES[tx.gameId] ?? tx.gameId}\n                </a>\n              </td>\n              <td\n                className={`profile-transactions__event profile-transactions__event--${tx.event}`}\n              >\n                {EVENT_LABELS[tx.event] ?? tx.event}\n              </td>\n              <td>{formatSol(tx.amountLamports)}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n\n      {nextCursor && (\n        <div className=\"profile-transactions__load-more\">\n          <button\n            type=\"button\"\n            className=\"profile-transactions__load-more-btn\"\n            onClick={loadMore}\n            disabled={loadingMore}\n          >\n            {loadingMore ? \"Loading...\" : \"Load more\"}\n          </button>\n        </div>\n      )}\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":8,"oldLines":15,"newStart":8,"newLines":19,"lines":[" import { GAME_NAMES } from \"../types\";"," import type { GameId } from \"../types\";"," import { useTransactions } from \"../hooks/useTransactions\";","+import { useSolPrice } from \"../hooks/useSolPrice\";"," ","-/** Format lamports as SOL string (e.g. \"0.50 SOL\") */","-function formatSol(lamports: string): string {","+/** Format lamports as SOL string with optional USD estimate */","+function formatSol(lamports: string, solUsdPrice: number | null): string {","   const sol = Number(lamports) / 1e9;","-  // Use up to 4 decimal places, strip trailing zeros","-  return sol.toLocaleString(\"en-US\", {","-    minimumFractionDigits: 2,","-    maximumFractionDigits: 4,","-  }) + \" SOL\";","+  const solStr =","+    sol.toLocaleString(\"en-US\", {","+      minimumFractionDigits: 2,","+      maximumFractionDigits: 4,","+    }) + \" SOL\";","+  if (solUsdPrice == null) return solStr;","+  const usd = sol * solUsdPrice;","+  return `${solStr} (~$${usd.toLocaleString(\"en-US\", { minimumFractionDigits: 2, maximumFractionDigits: 2 })})`;"," }"," "," /** Format ISO date as relative time */"]}],"userModified":false,"replaceAll":false}}
