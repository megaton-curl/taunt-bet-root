{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UhZRoBKGtm9Q39AsRHubQw","type":"tool_result","content":"     1→/**\n     2→ * ProfileTransactions - Transaction history tab content\n     3→ *\n     4→ * Fetches real transaction data from the backend API and displays\n     5→ * a paginated table with event types, amounts, and match links.\n     6→ */\n     7→\n     8→import { GAME_NAMES } from \"../types\";\n     9→import type { GameId } from \"../types\";\n    10→import { useTransactions } from \"../hooks/useTransactions\";\n    11→\n    12→/** Format lamports as SOL string (e.g. \"0.50 SOL\") */\n    13→function formatSol(lamports: string): string {\n    14→  const sol = Number(lamports) / 1e9;\n    15→  // Use up to 4 decimal places, strip trailing zeros\n    16→  return sol.toLocaleString(\"en-US\", {\n    17→    minimumFractionDigits: 2,\n    18→    maximumFractionDigits: 4,\n    19→  }) + \" SOL\";\n    20→}\n    21→\n    22→/** Format ISO date as relative time */\n    23→function formatTime(iso: string): string {\n    24→  const date = new Date(iso);\n    25→  const diffMs = Date.now() - date.getTime();\n    26→  const diffMins = Math.floor(diffMs / 60000);\n    27→  const diffHours = Math.floor(diffMs / 3600000);\n    28→  const diffDays = Math.floor(diffMs / 86400000);\n    29→\n    30→  if (diffMins < 1) return \"Just now\";\n    31→  if (diffMins < 60) return `${diffMins}m ago`;\n    32→  if (diffHours < 24) return `${diffHours}h ago`;\n    33→  if (diffDays < 7) return `${diffDays}d ago`;\n    34→  return date.toLocaleDateString();\n    35→}\n    36→\n    37→/** Build the deep-link path for a match */\n    38→function matchPath(gameId: GameId, matchId: string): string {\n    39→  return `/${gameId}/${matchId}`;\n    40→}\n    41→\n    42→/** Event display label */\n    43→const EVENT_LABELS: Record<string, string> = {\n    44→  join: \"JOIN\",\n    45→  win: \"WIN\",\n    46→  loss: \"LOSS\",\n    47→  refund: \"REFUND\",\n    48→};\n    49→\n    50→export function ProfileTransactions() {\n    51→  const { transactions, loading, loadingMore, nextCursor, loadMore } =\n    52→    useTransactions();\n    53→\n    54→  if (loading) {\n    55→    return (\n    56→      <div className=\"profile-transactions\">\n    57→        <div className=\"profile-transactions__skeleton\">\n    58→          {Array.from({ length: 5 }, (_, i) => (\n    59→            <div key={i} className=\"profile-transactions__skeleton-row\" />\n    60→          ))}\n    61→        </div>\n    62→      </div>\n    63→    );\n    64→  }\n    65→\n    66→  if (transactions.length === 0) {\n    67→    return (\n    68→      <div className=\"profile-transactions\">\n    69→        <div className=\"profile-transactions__empty\">\n    70→          <p>No transactions yet.</p>\n    71→          <p>Start playing to build your history!</p>\n    72→        </div>\n    73→      </div>\n    74→    );\n    75→  }\n    76→\n    77→  return (\n    78→    <div className=\"profile-transactions\">\n    79→      <table className=\"profile-transactions__table\">\n    80→        <thead>\n    81→          <tr>\n    82→            <th>Time</th>\n    83→            <th>Game</th>\n    84→            <th>Event</th>\n    85→            <th>Amount</th>\n    86→          </tr>\n    87→        </thead>\n    88→        <tbody>\n    89→          {transactions.map((tx) => (\n    90→            <tr key={tx.id}>\n    91→              <td>{formatTime(tx.createdAt)}</td>\n    92→              <td>\n    93→                <a\n    94→                  href={matchPath(tx.gameId, tx.matchId)}\n    95→                  className=\"profile-transactions__match-link\"\n    96→                >\n    97→                  {GAME_NAMES[tx.gameId] ?? tx.gameId}\n    98→                </a>\n    99→              </td>\n   100→              <td\n   101→                className={`profile-transactions__event profile-transactions__event--${tx.event}`}\n   102→              >\n   103→                {EVENT_LABELS[tx.event] ?? tx.event}\n   104→              </td>\n   105→              <td>{formatSol(tx.amountLamports)}</td>\n   106→            </tr>\n   107→          ))}\n   108→        </tbody>\n   109→      </table>\n   110→\n   111→      {nextCursor && (\n   112→        <div className=\"profile-transactions__load-more\">\n   113→          <button\n   114→            type=\"button\"\n   115→            className=\"profile-transactions__load-more-btn\"\n   116→            onClick={loadMore}\n   117→            disabled={loadingMore}\n   118→          >\n   119→            {loadingMore ? \"Loading...\" : \"Load more\"}\n   120→          </button>\n   121→        </div>\n   122→      )}\n   123→    </div>\n   124→  );\n   125→}\n   126→"}]},"parent_tool_use_id":null,"session_id":"128b24a9-f983-447c-a735-141661f077a9","uuid":"cebfa573-d3f7-43e7-93fb-65ae9b2780f9","timestamp":"2026-03-19T19:10:02.085Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/components/ProfileTransactions.tsx","content":"/**\n * ProfileTransactions - Transaction history tab content\n *\n * Fetches real transaction data from the backend API and displays\n * a paginated table with event types, amounts, and match links.\n */\n\nimport { GAME_NAMES } from \"../types\";\nimport type { GameId } from \"../types\";\nimport { useTransactions } from \"../hooks/useTransactions\";\n\n/** Format lamports as SOL string (e.g. \"0.50 SOL\") */\nfunction formatSol(lamports: string): string {\n  const sol = Number(lamports) / 1e9;\n  // Use up to 4 decimal places, strip trailing zeros\n  return sol.toLocaleString(\"en-US\", {\n    minimumFractionDigits: 2,\n    maximumFractionDigits: 4,\n  }) + \" SOL\";\n}\n\n/** Format ISO date as relative time */\nfunction formatTime(iso: string): string {\n  const date = new Date(iso);\n  const diffMs = Date.now() - date.getTime();\n  const diffMins = Math.floor(diffMs / 60000);\n  const diffHours = Math.floor(diffMs / 3600000);\n  const diffDays = Math.floor(diffMs / 86400000);\n\n  if (diffMins < 1) return \"Just now\";\n  if (diffMins < 60) return `${diffMins}m ago`;\n  if (diffHours < 24) return `${diffHours}h ago`;\n  if (diffDays < 7) return `${diffDays}d ago`;\n  return date.toLocaleDateString();\n}\n\n/** Build the deep-link path for a match */\nfunction matchPath(gameId: GameId, matchId: string): string {\n  return `/${gameId}/${matchId}`;\n}\n\n/** Event display label */\nconst EVENT_LABELS: Record<string, string> = {\n  join: \"JOIN\",\n  win: \"WIN\",\n  loss: \"LOSS\",\n  refund: \"REFUND\",\n};\n\nexport function ProfileTransactions() {\n  const { transactions, loading, loadingMore, nextCursor, loadMore } =\n    useTransactions();\n\n  if (loading) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__skeleton\">\n          {Array.from({ length: 5 }, (_, i) => (\n            <div key={i} className=\"profile-transactions__skeleton-row\" />\n          ))}\n        </div>\n      </div>\n    );\n  }\n\n  if (transactions.length === 0) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__empty\">\n          <p>No transactions yet.</p>\n          <p>Start playing to build your history!</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"profile-transactions\">\n      <table className=\"profile-transactions__table\">\n        <thead>\n          <tr>\n            <th>Time</th>\n            <th>Game</th>\n            <th>Event</th>\n            <th>Amount</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id}>\n              <td>{formatTime(tx.createdAt)}</td>\n              <td>\n                <a\n                  href={matchPath(tx.gameId, tx.matchId)}\n                  className=\"profile-transactions__match-link\"\n                >\n                  {GAME_NAMES[tx.gameId] ?? tx.gameId}\n                </a>\n              </td>\n              <td\n                className={`profile-transactions__event profile-transactions__event--${tx.event}`}\n              >\n                {EVENT_LABELS[tx.event] ?? tx.event}\n              </td>\n              <td>{formatSol(tx.amountLamports)}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n\n      {nextCursor && (\n        <div className=\"profile-transactions__load-more\">\n          <button\n            type=\"button\"\n            className=\"profile-transactions__load-more-btn\"\n            onClick={loadMore}\n            disabled={loadingMore}\n          >\n            {loadingMore ? \"Loading...\" : \"Load more\"}\n          </button>\n        </div>\n      )}\n    </div>\n  );\n}\n","numLines":126,"startLine":1,"totalLines":126}}}
