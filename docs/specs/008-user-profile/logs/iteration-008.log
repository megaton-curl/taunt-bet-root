{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LxDhEjFcsi6etQU6zhzVfi","type":"tool_result","content":"     1→/**\n     2→ * Price routes — cached SOL/USD price from Pyth Hermes.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import { HermesClient } from \"@pythnetwork/hermes-client\";\n     7→import { logger } from \"../logger.js\";\n     8→\n     9→// SOL/USD Pyth feed ID (same on mainnet + devnet)\n    10→const SOL_USD_FEED_ID =\n    11→  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n    12→\n    13→const CACHE_TTL_MS = 60_000; // 60 seconds\n    14→\n    15→interface CachedPrice {\n    16→  price: number;\n    17→  expo: number;\n    18→  updatedAt: string;\n    19→  fetchedAt: number; // Date.now() for TTL check\n    20→}\n    21→\n    22→let cached: CachedPrice | null = null;\n    23→\n    24→const client = new HermesClient(\"https://hermes.pyth.network\", {});\n    25→\n    26→async function fetchSolPrice(): Promise<CachedPrice | null> {\n    27→  // Return cached if still fresh\n    28→  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n    29→    return cached;\n    30→  }\n    31→\n    32→  try {\n    33→    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n    34→      encoding: \"base64\",\n    35→      parsed: true,\n    36→    });\n    37→    const feed = updates.parsed?.[0];\n    38→    if (!feed?.price) return cached; // stale cache better than nothing\n    39→\n    40→    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n    41→    const expo = feed.price.expo;\n    42→    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n    43→\n    44→    cached = { price, expo, updatedAt, fetchedAt: Date.now() };\n    45→    return cached;\n    46→  } catch (err) {\n    47→    logger.warn(\"hermes: SOL/USD fetch failed\", {\n    48→      error: err instanceof Error ? err.message : String(err),\n    49→    });\n    50→    return cached; // return stale cache on error\n    51→  }\n    52→}\n    53→\n    54→export function createPriceRoutes() {\n    55→  const app = new Hono();\n    56→\n    57→  app.get(\"/sol-usd\", async (c) => {\n    58→    const result = await fetchSolPrice();\n    59→    if (!result) {\n    60→      return c.json({ error: \"Price unavailable\" }, 503);\n    61→    }\n    62→    return c.json({\n    63→      price: result.price,\n    64→      expo: result.expo,\n    65→      updatedAt: result.updatedAt,\n    66→    });\n    67→  });\n    68→\n    69→  return app;\n    70→}\n    71→"}]},"parent_tool_use_id":null,"session_id":"128b24a9-f983-447c-a735-141661f077a9","uuid":"ff9ad303-95ab-494e-8e8d-0f75b04708ff","timestamp":"2026-03-19T19:10:10.524Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/price.ts","content":"/**\n * Price routes — cached SOL/USD price from Pyth Hermes.\n */\n\nimport { Hono } from \"hono\";\nimport { HermesClient } from \"@pythnetwork/hermes-client\";\nimport { logger } from \"../logger.js\";\n\n// SOL/USD Pyth feed ID (same on mainnet + devnet)\nconst SOL_USD_FEED_ID =\n  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n\nconst CACHE_TTL_MS = 60_000; // 60 seconds\n\ninterface CachedPrice {\n  price: number;\n  expo: number;\n  updatedAt: string;\n  fetchedAt: number; // Date.now() for TTL check\n}\n\nlet cached: CachedPrice | null = null;\n\nconst client = new HermesClient(\"https://hermes.pyth.network\", {});\n\nasync function fetchSolPrice(): Promise<CachedPrice | null> {\n  // Return cached if still fresh\n  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n    return cached;\n  }\n\n  try {\n    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n      encoding: \"base64\",\n      parsed: true,\n    });\n    const feed = updates.parsed?.[0];\n    if (!feed?.price) return cached; // stale cache better than nothing\n\n    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n    const expo = feed.price.expo;\n    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n\n    cached = { price, expo, updatedAt, fetchedAt: Date.now() };\n    return cached;\n  } catch (err) {\n    logger.warn(\"hermes: SOL/USD fetch failed\", {\n      error: err instanceof Error ? err.message : String(err),\n    });\n    return cached; // return stale cache on error\n  }\n}\n\nexport function createPriceRoutes() {\n  const app = new Hono();\n\n  app.get(\"/sol-usd\", async (c) => {\n    const result = await fetchSolPrice();\n    if (!result) {\n      return c.json({ error: \"Price unavailable\" }, 503);\n    }\n    return c.json({\n      price: result.price,\n      expo: result.expo,\n      updatedAt: result.updatedAt,\n    });\n  });\n\n  return app;\n}\n","numLines":71,"startLine":1,"totalLines":71}}}
