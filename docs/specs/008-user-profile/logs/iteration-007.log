 table of game history with outcomes.\n */\n\nimport { useMemo } from \"react\";\nimport { GAME_NAMES } from \"../types\";\nimport { getTransactions } from \"../utils/mock-simulation\";\n\ninterface ProfileTransactionsProps {\n  address: string;\n}\n\nexport function ProfileTransactions({ address }: ProfileTransactionsProps) {\n  const transactions = useMemo(() => {\n    return getTransactions(address, 50);\n  }, [address]);\n\n  const formatTime = (timestamp: number): string => {\n    const date = new Date(timestamp);\n    const now = new Date();\n    const diffMs = now.getTime() - date.getTime();\n    const diffMins = Math.floor(diffMs / 60000);\n    const diffHours = Math.floor(diffMs / 3600000);\n    const diffDays = Math.floor(diffMs / 86400000);\n\n    if (diffMins < 1) return \"Just now\";\n    if (diffMins < 60) return `${diffMins}m ago`;\n    if (diffHours < 24) return `${diffHours}h ago`;\n    if (diffDays < 7) return `${diffDays}d ago`;\n    return date.toLocaleDateString();\n  };\n\n  if (transactions.length === 0) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__empty\">\n          <p>No transactions yet.</p>\n          <p>Start playing to build your history!</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"profile-transactions\">\n      <table className=\"profile-transactions__table\">\n        <thead>\n          <tr>\n            <th>Time</th>\n            <th>Game</th>\n            <th>Wager</th>\n            <th>Outcome</th>\n            <th>Payout</th>\n            <th>Net</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id}>\n              <td>{formatTime(tx.timestamp)}</td>\n              <td>{GAME_NAMES[tx.gameId]}</td>\n              <td>{\"$\" + tx.wagerAmount.toFixed(2)}</td>\n              <td className={`profile-transactions__outcome--${tx.outcome}`}>\n                {tx.outcome.toUpperCase()}\n              </td>\n              <td>{\"$\" + tx.payoutAmount.toFixed(2)}</td>\n              <td className={tx.netResult >= 0 ? \"profile-transactions__net--positive\" : \"profile-transactions__net--negative\"}>\n                {tx.netResult >= 0 ? \"+$\" : \"-$\"}{Math.abs(tx.netResult).toFixed(2)}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n"}}
