{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BuRbzVDxLoWBam9K9xByyL","type":"tool_result","content":"     1→/**\n     2→ * Shared hook for detecting on-chain settlement via WebSocket.\n     3→ *\n     4→ * Uses `connection.onAccountChange(matchPda, ...)` to detect when the match\n     5→ * account is closed (lamports → 0) by the settle instruction. This is the\n     6→ * most reliable subscription method because:\n     7→ * - Subscribes to a specific account address (not program-wide)\n     8→ * - Fires on any lamports/data change, including closure\n     9→ * - Works on all RPC providers (dRPC, Helius, public devnet)\n    10→ *\n    11→ * When closure is detected, fetches the settle tx from the backend to get\n    12→ * the full event data (winner, result, secret, etc.).\n    13→ *\n    14→ * This provides ~1-3s settlement detection vs ~15s with getAccountInfo polling.\n    15→ * Polling remains as a fallback in case the WebSocket drops.\n    16→ */\n    17→import { useEffect, useRef } from \"react\";\n    18→import { PublicKey, type Connection } from \"@solana/web3.js\";\n    19→\n    20→export interface UseSettlementEventOptions {\n    21→  connection: Connection;\n    22→  /** Base58 address of the match/round PDA to watch for closure. */\n    23→  accountAddress: string | null;\n    24→  /** Only subscribe when true (e.g. active game phase). */\n    25→  enabled: boolean;\n    26→  /** Called once when the account is closed (lamports=0). */\n    27→  onClosed: () => void;\n    28→}\n    29→\n    30→function logEvent(event: string, data?: Record<string, unknown>) {\n    31→  const ts = new Date().toISOString().slice(11, 23);\n    32→  const extra = data ? \" \" + JSON.stringify(data) : \"\";\n    33→  // eslint-disable-next-line no-console\n    34→  console.log(`[settlement-event] ${ts} ${event}${extra}`);\n    35→}\n    36→\n    37→export function useSettlementEvent({\n    38→  connection,\n    39→  accountAddress,\n    40→  enabled,\n    41→  onClosed,\n    42→}: UseSettlementEventOptions): void {\n    43→  // Store callback in ref so subscription doesn't re-create on every render\n    44→  const onClosedRef = useRef(onClosed);\n    45→  onClosedRef.current = onClosed;\n    46→\n    47→  // Prevent double-fire for the same subscription cycle\n    48→  const firedRef = useRef(false);\n    49→\n    50→  // Reset fired flag when subscription is disabled (new game cycle)\n    51→  useEffect(() => {\n    52→    if (!enabled) {\n    53→      firedRef.current = false;\n    54→    }\n    55→  }, [enabled]);\n    56→\n    57→  // accountAddress is a string — stable across renders for the same PDA\n    58→  useEffect(() => {\n    59→    if (!enabled || !accountAddress) return;\n    60→\n    61→    let subscriptionId: number | undefined;\n    62→    const pda = new PublicKey(accountAddress);\n    63→\n    64→    try {\n    65→      logEvent(\"subscribing\", { pda: accountAddress.slice(0, 12) });\n    66→\n    67→      subscriptionId = connection.onAccountChange(\n    68→        pda,\n    69→        (accountInfo) => {\n    70→          if (firedRef.current) return;\n    71→\n    72→          // Account closed = lamports drained to 0 by settle instruction\n    73→          if (accountInfo.lamports === 0) {\n    74→            firedRef.current = true;\n    75→            logEvent(\"account closed\", { pda: accountAddress.slice(0, 12) });\n    76→            onClosedRef.current();\n    77→          }\n    78→        },\n    79→        \"confirmed\",\n    80→      );\n    81→\n    82→      logEvent(\"subscribed\", { id: subscriptionId, pda: accountAddress.slice(0, 12) });\n    83→    } catch (err) {\n    84→      logEvent(\"subscribe error\", { error: String(err) });\n    85→    }\n    86→\n    87→    return () => {\n    88→      if (subscriptionId !== undefined) {\n    89→        logEvent(\"unsubscribing\", { id: subscriptionId });\n    90→        connection.removeAccountChangeListener(subscriptionId).catch(() => {});\n    91→      }\n    92→    };\n    93→  }, [connection, accountAddress, enabled]);\n    94→}\n    95→"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"4b7cfcb2-a0df-4273-8c7e-5b66e4650e55","timestamp":"2026-03-19T19:01:50.707Z"}
