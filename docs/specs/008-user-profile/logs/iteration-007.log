{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V6Tt6YE6bUReoqw7MoEREL","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { MIN_WAGER_SOL } from \"@rng-utopia/game-engine/browser\";\n    11→import type { Round } from \"../types\";\n    12→\n    13→/** How long to show the result screen before polling for the next round. */\n    14→const WINNER_DISPLAY_MS = 5000;\n    15→/** Duration of the wheel spin / reveal animation before showing the result. */\n    16→const REVEAL_ANIMATION_MS = 5000;\n    17→import {\n    18→  fetchCurrentRound,\n    19→  fetchRound,\n    20→  fetchRoundVerification,\n    21→  fetchRecentSettledRounds,\n    22→  applyBackendRoundToRound,\n    23→  fetchRoundByMatchId,\n    24→  buildBackendCreateRoundTx,\n    25→  buildJoinRoundTx,\n    26→  buildBuyMoreEntriesTx,\n    27→  BackendRequestError,\n    28→} from \"../utils/chain\";\n    29→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    30→import { useSession } from \"../../../context/SessionContext\";\n    31→import { getAccessToken } from \"../../../lib/auth-store\";\n    32→import { useSettlementEvent } from \"../../../lib/useSettlementEvent\";\n    33→import { useSendAndConfirm } from \"../../../lib/useSendAndConfirm\";\n    34→import { createTransactionErrorParser } from \"../../../lib/parse-transaction-error\";\n    35→\n    36→/** Parse transaction errors into user-friendly messages */\n    37→const parseTransactionError = createTransactionErrorParser({\n    38→  logLabel: \"lord-of-rngs\",\n    39→  gameChecks: [\n    40→    (msg) =>\n    41→      msg.includes(\"InvalidPhase\")\n    42→        ? \"This round is no longer accepting entries.\"\n    43→        : null,\n    44→    (msg) =>\n    45→      msg.includes(\"MaxEntriesReached\")\n    46→        ? \"This round has reached its current entry limit.\"\n    47→        : null,\n    48→    (msg) =>\n    49→      msg.includes(\"EntriesClosed\")\n    50→        ? \"This round is already closed for new entries.\"\n    51→        : null,\n    52→    // Anchor 3012 = AccountNotInitialized — round PDA no longer exists (settled/closed)\n    53→    (msg) =>\n    54→      msg.includes(\"Custom\\\":3012\") || msg.includes(\"Custom:3012\")\n    55→        ? \"Round not found on-chain — it may have already ended. Refreshing...\"\n    56→        : null,\n    57→  ],\n    58→});\n    59→\n    60→/** Metadata for the active round needed to build transactions */\n    61→interface RoundMeta {\n    62→  matchId: string;\n    63→}\n    64→\n    65→async function waitForRoundAvailability(\n    66→  connection: Parameters<typeof fetchRound>[0],\n    67→  matchId: string,\n    68→  wallet: string,\n    69→  maxAttempts = 10,\n    70→): Promise<Round | null> {\n    71→  for (let attempt = 1; attempt <= maxAttempts; attempt += 1) {\n    72→    const round = await fetchRound(connection, matchId, wallet);\n    73→    if (round) {\n    74→      return round;\n    75→    }\n    76→    if (attempt < maxAttempts) {\n    77→      await new Promise((resolve) => setTimeout(resolve, 1_500));\n    78→    }\n    79→  }\n    80→\n    81→  return null;\n    82→}\n    83→\n    84→interface LordOfRngsContextValue {\n    85→  // State\n    86→  activeRound: Round | null;\n    87→  userHistory: Round[];\n    88→  wagerAmount: number; // in SOL\n    89→  entryCount: number;\n    90→\n    91→  // Loading states\n    92→  loading: boolean;\n    93→  joining: boolean;\n    94→  buyingMore: boolean;\n    95→  claiming: boolean;\n    96→  spinning: boolean;\n    97→\n    98→  // Error state\n    99→  error: string | null;\n   100→  clearError: () => void;"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"632c5564-86ed-4be7-9