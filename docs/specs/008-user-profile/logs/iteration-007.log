{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CGBG7nNjXx2X5BriEYC5fv","type":"tool_result","content":"     1→/**\n     2→ * ProfileTransactions - Transaction history tab content\n     3→ *\n     4→ * Shows a table of game history with outcomes.\n     5→ */\n     6→\n     7→import { useMemo } from \"react\";\n     8→import { GAME_NAMES } from \"../types\";\n     9→import { getTransactions } from \"../utils/mock-simulation\";\n    10→\n    11→interface ProfileTransactionsProps {\n    12→  address: string;\n    13→}\n    14→\n    15→export function ProfileTransactions({ address }: ProfileTransactionsProps) {\n    16→  const transactions = useMemo(() => {\n    17→    return getTransactions(address, 50);\n    18→  }, [address]);\n    19→\n    20→  const formatTime = (timestamp: number): string => {\n    21→    const date = new Date(timestamp);\n    22→    const now = new Date();\n    23→    const diffMs = now.getTime() - date.getTime();\n    24→    const diffMins = Math.floor(diffMs / 60000);\n    25→    const diffHours = Math.floor(diffMs / 3600000);\n    26→    const diffDays = Math.floor(diffMs / 86400000);\n    27→\n    28→    if (diffMins < 1) return \"Just now\";\n    29→    if (diffMins < 60) return `${diffMins}m ago`;\n    30→    if (diffHours < 24) return `${diffHours}h ago`;\n    31→    if (diffDays < 7) return `${diffDays}d ago`;\n    32→    return date.toLocaleDateString();\n    33→  };\n    34→\n    35→  if (transactions.length === 0) {\n    36→    return (\n    37→      <div className=\"profile-transactions\">\n    38→        <div className=\"profile-transactions__empty\">\n    39→          <p>No transactions yet.</p>\n    40→          <p>Start playing to build your history!</p>\n    41→        </div>\n    42→      </div>\n    43→    );\n    44→  }\n    45→\n    46→  return (\n    47→    <div className=\"profile-transactions\">\n    48→      <table className=\"profile-transactions__table\">\n    49→        <thead>\n    50→          <tr>\n    51→            <th>Time</th>\n    52→            <th>Game</th>\n    53→            <th>Wager</th>\n    54→            <th>Outcome</th>\n    55→            <th>Payout</th>\n    56→            <th>Net</th>\n    57→          </tr>\n    58→        </thead>\n    59→        <tbody>\n    60→          {transactions.map((tx) => (\n    61→            <tr key={tx.id}>\n    62→              <td>{formatTime(tx.timestamp)}</td>\n    63→              <td>{GAME_NAMES[tx.gameId]}</td>\n    64→              <td>{\"$\" + tx.wagerAmount.toFixed(2)}</td>\n    65→              <td className={`profile-transactions__outcome--${tx.outcome}`}>\n    66→                {tx.outcome.toUpperCase()}\n    67→              </td>\n    68→              <td>{\"$\" + tx.payoutAmount.toFixed(2)}</td>\n    69→              <td className={tx.netResult >= 0 ? \"profile-transactions__net--positive\" : \"profile-transactions__net--negative\"}>\n    70→                {tx.netResult >= 0 ? \"+$\" : \"-$\"}{Math.abs(tx.netResult).toFixed(2)}\n    71→              </td>\n    72→            </tr>\n    73→          ))}\n    74→        </tbody>\n    75→      </table>\n    76→    </div>\n    77→  );\n    78→}\n    79→"}]},"parent_tool_use_id":null,"session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"5fd5d903-277d-47a6-89c5-028b8aa1d7ca","timestamp":"2026-03-19T19:02:37.925Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/components/ProfileTransactions.tsx","content":"/**\n * ProfileTransactions - Transaction history tab content\n *\n * Shows a table of game history with outcomes.\n */\n\nimport { useMemo } from \"react\";\nimport { GAME_NAMES } from \"../types\";\nimport { getTransactions } from \"../utils/mock-simulation\";\n\ninterface ProfileTransactionsProps {\n  address: string;\n}\n\nexport function ProfileTransactions({ address }: ProfileTransactionsProps) {\n  const transactions = useMemo(() => {\n    return getTransactions(address, 50);\n  }, [address]);\n\n  const formatTime = (timestamp: number): string => {\n    const date = new Date(timestamp);\n    const now = new Date();\n    const diffMs = now.getTime() - date.getTime();\n    const diffMins = Math.floor(diffMs / 60000);\n    const diffHours = Math.floor(diffMs / 3600000);\n    const diffDays = Math.floor(diffMs / 86400000);\n\n    if (diffMins < 1) return \"Just now\";\n    if (diffMins < 60) return `${diffMins}m ago`;\n    if (diffHours < 24) return `${diffHours}h ago`;\n    if (diffDays < 7) return `${diffDays}d ago`;\n    return date.toLocaleDateString();\n  };\n\n  if (transactions.length === 0) {\n    return (\n      <div className=\"profile-transactions\">\n        <div className=\"profile-transactions__empty\">\n          <p>No transactions yet.</p>\n          <p>Start playing to build your history!</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"profile-transactions\">\n      <table className=\"profile-transactions__table\">\n        <thead>\n          <tr>\n            <th>Time</th>\n            <th>Game</th>\n            <th>Wager</th>\n            <th>Outcome</th>\n            <th>Payout</th>\n            <th>Net</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id}>\n              <td>{formatTime(tx.timestamp)}</td>\n              <td>{GAME_NAMES[tx.gameId]}</td>\n              <td>{\"$\" + tx.wagerAmount.toFixed(2)}</td>\n              <td className={`profile-transactions__outcome--${tx.outcome}`}>\n                {tx.outcome.toUpperCase()}\n              </td>\n              <td>{\"$\" + tx.payoutAmount.toFixed(2)}</td>\n              <td className={tx.netResult >= 0 ? \"profile-transactions__net--positive\" : \"profile-transactions__net--negative\"}>\n                {tx.netResult >= 0 ? \"+$\" : \"-$\"}{Math.abs(tx.netResult).toFixed(2)}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
