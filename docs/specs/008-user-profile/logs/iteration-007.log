{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SFKM62xoQtVijQ6tsrvDVa","type":"tool_result","content":"     1→import { useCallback } from \"react\";\n     2→import type { Connection, Transaction } from \"@solana/web3.js\";\n     3→\n     4→/**\n     5→ * Shared hook that wraps send + confirm + retry logic for Solana transactions.\n     6→ *\n     7→ * Features:\n     8→ * - Preserves external (backend) signatures — skips blockhash overwrite\n     9→ * - Pre-flight simulation with InstructionError early-abort\n    10→ * - Retry loop with fresh blockhash on expiry (skipped for preserved-signature txs)\n    11→ * - 30s abort controller timeout per attempt\n    12→ * - Fallback getSignatureStatus check before retrying (catches devnet WS drops)\n    13→ * - refreshBalance() call on success\n    14→ */\n    15→export function useSendAndConfirm(\n    16→  connection: Connection,\n    17→  sendTransaction: (transaction: Transaction) => Promise<string>,\n    18→  refreshBalance: () => Promise<void>,\n    19→  logLabel: string,\n    20→): (transaction: Transaction) => Promise<string> {\n    21→  return useCallback(\n    22→    async (transaction: Transaction): Promise<string> => {\n    23→      // Detect if the backend already partially signed this transaction.\n    24→      // If so, we must NOT overwrite the blockhash — doing so would\n    25→      // invalidate the server's signature.\n    26→      const hasPartialSignatures = transaction.signatures.some(\n    27→        (entry) => entry.signature !== null,\n    28→      );\n    29→      const preservesExternalSignature =\n    30→        hasPartialSignatures &&\n    31→        typeof transaction.recentBlockhash === \"string\";\n    32→      const hasPinnedBlockhash =\n    33→        preservesExternalSignature &&\n    34→        typeof transaction.lastValidBlockHeight === \"number\";\n    35→\n    36→      // If the tx is externally signed but missing lastValidBlockHeight,\n    37→      // try to fetch one for confirmation tracking only. If that also\n    38→      // fails, refuse to send (incomplete confirmation contract).\n    39→      if (preservesExternalSignature && !hasPinnedBlockhash) {\n    40→        try {\n    41→          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n    42→          // Attach for confirmation tracking only — do NOT overwrite blockhash\n    43→          transaction.lastValidBlockHeight = fresh.lastValidBlockHeight;\n    44→        } catch {\n    45→          throw new Error(\n    46→            \"Backend transaction is missing lastValidBlockHeight and \" +\n    47→              \"could not fetch a fresh one. Refusing to send with an \" +\n    48→              \"incomplete confirmation contract.\",\n    49→          );\n    50→        }\n    51→      }\n    52→\n    53→      // Pre-flight simulation for diagnostics (best-effort, unsigned).\n    54→      // Abort early on InstructionError — the tx will fail on-chain too.\n    55→      // The blockhash fetched here is reused for the first send attempt.\n    56→      let cachedBlockhash: string | undefined;\n    57→      let cachedHeight: number | undefined;\n    58→      try {\n    59→        if (!preservesExternalSignature) {\n    60→          const { blockhash, lastValidBlockHeight } =\n    61→            await connection.getLatestBlockhash(\"confirmed\");\n    62→          cachedBlockhash = blockhash;\n    63→          cachedHeight = lastValidBlockHeight;\n    64→          transaction.recentBlockhash = blockhash;\n    65→        }\n    66→\n    67→        const simResult = await connection.simulateTransaction(transaction);\n    68→        if (simResult.value.err) {\n    69→          console.error(\n    70→            `[${logLabel}] simulation failed BEFORE wallet send:`,\n    71→            JSON.stringify(simResult.value.err),\n    72→          );\n    73→          if (simResult.value.logs) {\n    74→            console.error(\n    75→              `[${logLabel}] simulation logs:\\n` +\n    76→                simResult.value.logs.join(\"\\n\"),\n    77→            );\n    78→          }\n    79→          const err = simResult.value.err;\n    80→          if (\n    81→            typeof err === \"object\" &&\n    82→            err !== null &&\n    83→            \"InstructionError\" in err\n    84→          ) {\n    85→            throw new Error(`Transaction will fail: ${JSON.stringify(err)}`);\n    86→          }\n    87→        }\n    88→      } catch (simErr) {\n    89→        if (\n    90→          simErr instanceof Error &&\n    91→          simErr.message.startsWith(\"Transaction will fail:\")\n    92→        ) {\n    93→          throw simErr;\n    94→        }\n    95→        console.error(`[${logLabel}] simulation RPC error:`, simErr);\n    96→      }\n    97→\n    98→      // Send with retry — devnet txs can be dropped by validators/RPCs.\n    99→      const MAX_SEND_ATTEMPTS = preservesExternalSignature ? 1 : 3;\n   100→      for (let attempt = 1; attempt <= MAX_SEND_ATTEMPTS; attempt++) {\n   101→        let blockhash: string;\n   102→        let lastValidBlockHeight: number;\n   103→        if (preservesExternalSignature) {\n   104→          blockhash = transaction.recentBlockhash!;\n   105→          lastValidBlockHeight = transaction.lastValidBlockHeight ?? 0;\n   106→        } else if (attempt === 1 && cachedBlockhash && cachedHeight) {\n   107→          // Reuse simulation blockhash for first attempt (saves an RPC call)\n   108→          blockhash = cachedBlockhash;\n   109→          lastValidBlockHeight = cachedHeight;\n   110→        } else {\n   111→          // Fresh blockhash for retries (previous one may have expired)\n   112→          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n   113→          blockhash = fresh.blockhash;\n   114→          lastValidBlockHeight = fresh.lastValidBlockHeight;\n   115→        }\n   116→        if (!preservesExternalSignature) {\n   117→          transaction.recentBlockhash = blockhash;\n   118→        }\n   119→\n   120→        const signature = await sendTransaction(transaction);\n   121→        // eslint-disable-next-line no-console\n   122→        console.log(\n   123→          `[${logLabel}] tx sent (attempt ${attempt}/${MAX_SEND_ATTEMPTS}): ${signature}`,\n   124→        );\n   125→\n   126→        const controller = new AbortController();\n   127→        const timeout = setTimeout(() => controller.abort(), 30_000);\n   128→        try {\n   129→          await connection.confirmTransaction(\n   130→            {\n   131→              signature,\n   132→              blockhash,\n   133→              lastValidBlockHeight,\n   134→              abortSignal: controller.signal,\n   135→            },\n   136→            \"confirmed\",\n   137→          );\n   138→          // Success — refresh balance and return\n   139→          await refreshBalance();\n   140→          return signature;\n   141→        } catch (confirmErr) {\n   142→          const msg =\n   143→            confirmErr instanceof Error\n   144→              ? confirmErr.message\n   145→              : String(confirmErr);\n   146→          const isExpired =\n   147→            msg.includes(\"expired\") ||\n   148→            msg.includes(\"block height exceeded\");\n   149→          const isAborted = msg.includes(\"aborted\");\n   150→\n   151→          if ((isExpired || isAborted) && attempt < MAX_SEND_ATTEMPTS) {\n   152→            // Before retrying, check if the tx actually landed despite confirm\n   153→            // failure (common when devnet WebSocket drops the subscription\n   154→            // notification).\n   155→            try {\n   156→              const status =\n   157→                await connection.getSignatureStatus(signature);\n   158→              if (\n   159→                status.value?.confirmationStatus === \"confirmed\" ||\n   160→                status.value?.confirmationStatus === \"finalized\"\n   161→              ) {\n   162→                // eslint-disable-next-line no-console\n   163→                console.log(\n   164→                  `[${logLabel}] tx ${signature} confirmed via fallback status check`,\n   165→                );\n   166→                await refreshBalance();\n   167→                return signature;\n   168→              }\n   169→            } catch {\n   170→              // Status check failed — fall through to retry\n   171→            }\n   172→            console.warn(\n   173→              `[${logLabel}] tx dropped/expired on attempt ${attempt}, retrying...`,\n   174→            );\n   175→            continue;\n   176→          }\n   177→          throw confirmErr;\n   178→        } finally {\n   179→          clearTimeout(timeout);\n   180→        }\n   181→      }\n   182→\n   183→      throw new Error(\"Transaction failed after max retry attempts\");\n   184→    },\n   185→    [connection, sendTransaction, refreshBalance, logLabel],\n   186→  );\n   187→}\n   188→"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"7c5baa26-fda4-4c3f-a2d6-281b36bc2601","timestamp":"2026-03-19T19:01:50.645Z"}
