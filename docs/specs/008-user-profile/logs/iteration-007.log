{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XcJoU5oqaqACAvGFyRpxVx","type":"tool_result","content":"     1→import { Program, AnchorProvider, BN, type Idl } from \"@coral-xyz/anchor\";\n     2→import { Connection, PublicKey, SystemProgram, Transaction } from \"@solana/web3.js\";\n     3→import { LordofrngsIDL, type Lordofrngs } from \"@rng-utopia/anchor-client\";\n     4→import type { PlayerEntry, Round, WeightedEntry } from \"../types\";\n     5→import { PLAYER_COLORS } from \"../types\";\n     6→import bs58 from \"bs58\";\n     7→\n     8→export const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n     9→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    10→    .VITE_LORDOFRNGS_PROGRAM_ID ?? LordofrngsIDL.address\n    11→);\n    12→\n    13→const FAIRNESS_BACKEND_URL = (\n    14→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    15→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    16→).replace(/\\/$/, \"\");\n    17→\n    18→const LAMPORTS_PER_SOL = 1_000_000_000;\n    19→\n    20→export interface BackendCreateRoundResponse {\n    21→  transaction: string;\n    22→  roundPda: string;\n    23→  matchId: string;\n    24→  commitment: string;\n    25→  lastValidBlockHeight: number;\n    26→}\n    27→\n    28→export interface BackendRoundResponse {\n    29→  pda: string;\n    30→  game: string;\n    31→  phase: \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    32→  creator: string;\n    33→  commitment: string;\n    34→  amountLamports: number;\n    35→  matchId: string;\n    36→  createdAt: string;\n    37→  updatedAt: string;\n    38→  targetSlot?: number;\n    39→  secret?: string;\n    40→  resultHash?: string | null;\n    41→  winner?: string | null;\n    42→  settleTx?: string | null;\n    43→  entropy?: string | null;\n    44→  winningOffset?: string | null;\n    45→  winningEntryIndex?: number | null;\n    46→  payoutAmount?: number | null;\n    47→  feeAmount?: number | null;\n    48→  rentRefund?: number | null;\n    49→  totalAmountLamports?: number | null;\n    50→  entries?: Array<{ player: string; amountLamports: number }>;\n    51→}\n    52→\n    53→export class BackendRequestError extends Error {\n    54→  status: number;\n    55→\n    56→  constructor(status: number, message: string) {\n    57→    super(message);\n    58→    this.name = \"BackendRequestError\";\n    59→    this.status = status;\n    60→  }\n    61→}\n    62→\n    63→function getFairnessBackendCreateUrl(): string {\n    64→  return `${FAIRNESS_BACKEND_URL}/fairness/lord/create`;\n    65→}\n    66→\n    67→function getFairnessBackendCurrentUrl(): string {\n    68→  return `${FAIRNESS_BACKEND_URL}/fairness/lord/current`;\n    69→}\n    70→\n    71→function getFairnessBackendRoundUrl(roundPda: string): string {\n    72→  return `${FAIRNESS_BACKEND_URL}/fairness/rounds/${roundPda}`;\n    73→}\n    74→\n    75→async function parseBackendResponse<T>(response: Response): Promise<T> {\n    76→  let json: unknown = null;\n    77→  try {\n    78→    json = await response.json();\n    79→  } catch {\n    80→    json = null;\n    81→  }\n    82→\n    83→  if (!response.ok) {\n    84→    const errorMessage =\n    85→      typeof json === \"object\" &&\n    86→      json !== null &&\n    87→      \"error\" in json &&\n    88→      typeof (json as { error: unknown }).error === \"string\"\n    89→        ? (json as { error: string }).error\n    90→        : `Backend request failed (${response.status})`;\n    91→    throw new BackendRequestError(response.status, errorMessage);\n    92→  }\n    93→\n    94→  return json as T;\n    95→}\n    96→\n    97→export function getRoundPda(matchId: string): [PublicKey, number] {\n    98→  const matchIdBuf = Buffer.from(matchId, \"hex\");\n    99→  return PublicKey.findProgramAddressSync(\n   100→    [Buffer.from(\"jackpot_round\"), matchIdBuf],\n   101→    LORDOFRNGS_PROGRAM_ID\n   102→  );\n   103→}\n   104→\n   105→export function getConfigPda(): [PublicKey, number] {\n   106→  return PublicKey.findProgramAddressSync(\n   107→    [Buffer.from(\"lord_config\")],\n   108→    LORDOFRNGS_PROGRAM_ID\n   109→  );\n   110→}\n   111→\n   112→export function getLordProgram(connection: Connection): Program<Lordofrngs> {\n   113→  const provider = new AnchorProvider(\n   114→    connection,\n   115→    {} as AnchorProvider[\"wallet\"],\n   116→    { commitment: \"confirmed\" }\n   117→  );\n   118→  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n   119→}\n   120→\n   121→function getJackpotRoundDiscriminator(): Uint8Array {\n   122→  const discriminator = LordofrngsIDL.accounts.find(\n   123→    (entry) => entry.name === \"JackpotRound\"\n   124→  )?.discriminator;\n   125→  if (!discriminator) {\n   126→    throw new Error(\"JackpotRound discriminator not found in Lord IDL\");\n   127→  }\n   128→  return Uint8Array.from(discriminator);\n   129→}\n   130→\n   131→type RoundPhaseVariant =\n   132→  | { waiting: object }\n   133→  | { active: object }\n   134→  | { locked: object }\n   135→  | { resolving: object }\n   136→  | { settled: object }\n   137→  | { refunded: object };\n   138→\n   139→interface OnChainWeightedEntry {\n   140→  player: PublicKey;\n   141→  amountLamports: { toNumber(): number };\n   142→}\n   143→\n   144→interface OnChainRound {\n   145→  matchId: number[];\n   146→  server: PublicKey;\n   147→  phase: RoundPhaseVariant;\n   148→  commitment: number[];\n   149→  algorithmVer: number;\n   150→  entries: OnChainWeightedEntry[];"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"4d535563-16d3-4209-9461-ff7da1d7cd6f","timestamp":"2026-03-19T19:01:39.163Z"}
