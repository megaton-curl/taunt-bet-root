r,\n  AvatarConfig,\n  BorderStyle,\n  BorderConfig,\n  GameId,\n  PlayerProfile,\n  PlayerStats,\n  GameSpecificStats,\n  LootItem,\n  LootSource,\n  ProfileTransaction,\n  GameResultEvent,\n  PlayerProfileContextValue,\n} from \"./types\";\n\nexport {\n  AVATAR_CONFIGS,\n  AVATAR_SIZES,\n  AVATAR_TIER_COLORS,\n  LEVEL_BORDERS,\n  GAME_NAMES,\n  DEFAULT_AVATAR_ID,\n  MAX_USERNAME_LENGTH,\n  MIN_USERNAME_LENGTH,\n  USERNAME_REGEX,\n  createEmptyStats,\n  getHighestUnlockedAvatar,\n} from \"./types\";\n\n// XP Calculator utilities\nexport {\n  getXPForLevel,\n  getLevelFromXP,\n  getXPProgress,\n  calculateWagerXP,\n  calculateWinBonusXP,\n  calculateGameXP,\n  getBorderStyleFromLevel,\n  getLevelMilestones,\n  formatXP,\n  formatLevel,\n  type XPProgress,\n} from \"./utils/xp-calculator\";\n\n// Event bus for game integrations\nexport {\n  profileEventBus,\n  emitGameResult,\n  emitCoinflipResults,\n  emitLordOfRngsResults,\n  emitCryptoCrashResults,\n  emitCloseCallResults,\n  createGameResultEvent,\n} from \"./utils/profile-event-bus\";\n\n// Mock simulation utilities (for testing/development)\nexport {\n  getProfile,\n  getOrCreateProfile,\n  getTransactions,\n  getDisplayName,\n  getAvatarId,\n  getLevel,\n  addLoot,\n} from \"./utils/mock-simulation\";\n","structuredPatch":[{"oldStart":31,"oldLines":6,"newStart":31,"newLines":7,"lines":["   LootItem,","   LootSource,","   ProfileTransaction,","+  TransactionEvent,","   GameResultEvent,","   PlayerProfileContextValue,"," } from \"./types\";"]}],"userModified":false,"replaceAll":false}}
