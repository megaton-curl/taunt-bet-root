{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YLgcxdLmeTUHjtMiEc2wUo","type":"tool_result","content":"     1→/**\n     2→ * Thin fetch wrappers for the /auth/* backend endpoints.\n     3→ */\n     4→\n     5→const BACKEND_URL = (\n     6→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n     7→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n     8→).replace(/\\/$/, \"\");\n     9→\n    10→export interface ChallengeResponse {\n    11→  nonce: string;\n    12→  message: string;\n    13→  expiresAt: string;\n    14→}\n    15→\n    16→export interface VerifyResponse {\n    17→  accessToken: string;\n    18→  accessExpiresAt: string;\n    19→  refreshToken: string;\n    20→  refreshExpiresAt: string;\n    21→}\n    22→\n    23→export interface RefreshResponse {\n    24→  accessToken: string;\n    25→  accessExpiresAt: string;\n    26→  refreshToken: string;\n    27→  refreshExpiresAt: string;\n    28→}\n    29→\n    30→async function parseResponse<T>(res: Response): Promise<T> {\n    31→  const json = await res.json();\n    32→  if (!res.ok) {\n    33→    const msg = typeof json?.error === \"string\" ? json.error : `Auth request failed (${res.status})`;\n    34→    throw new Error(msg);\n    35→  }\n    36→  return json as T;\n    37→}\n    38→\n    39→export async function requestChallenge(wallet: string): Promise<ChallengeResponse> {\n    40→  const res = await fetch(`${BACKEND_URL}/auth/challenge`, {\n    41→    method: \"POST\",\n    42→    headers: { \"Content-Type\": \"application/json\" },\n    43→    body: JSON.stringify({ wallet }),\n    44→  });\n    45→  return parseResponse<ChallengeResponse>(res);\n    46→}\n    47→\n    48→export async function verifyChallenge(\n    49→  nonce: string,\n    50→  wallet: string,\n    51→  signature: string,\n    52→): Promise<VerifyResponse> {\n    53→  const res = await fetch(`${BACKEND_URL}/auth/verify`, {\n    54→    method: \"POST\",\n    55→    headers: { \"Content-Type\": \"application/json\" },\n    56→    body: JSON.stringify({ nonce, wallet, signature }),\n    57→  });\n    58→  return parseResponse<VerifyResponse>(res);\n    59→}\n    60→\n    61→export async function refreshSession(refreshToken: string): Promise<RefreshResponse> {\n    62→  const res = await fetch(`${BACKEND_URL}/auth/refresh`, {\n    63→    method: \"POST\",\n    64→    headers: { \"Content-Type\": \"application/json\" },\n    65→    body: JSON.stringify({ refreshToken }),\n    66→  });\n    67→  return parseResponse<RefreshResponse>(res);\n    68→}\n    69→\n    70→export async function logout(refreshToken: string): Promise<void> {\n    71→  await fetch(`${BACKEND_URL}/auth/logout`, {\n    72→    method: \"POST\",\n    73→    headers: { \"Content-Type\": \"application/json\" },\n    74→    body: JSON.stringify({ refreshToken }),\n    75→  });\n    76→}\n    77→"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"afefeb81-caea-4e9a-833d-46a74d8aca7f","timestamp":"2026-03-19T19:01:30.225Z"}
