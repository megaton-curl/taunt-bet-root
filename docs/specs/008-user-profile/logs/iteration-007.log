{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017DwHadGpqXxVtkuGbihquB","type":"tool_result","content":"     1→import { useState, useEffect, useRef } from \"react\";\n     2→import { BrowserRouter, Routes, Route, Link } from \"react-router-dom\";\n     3→import { Header } from \"./components/Header\";\n     4→import { Sidebar } from \"./components/Sidebar\";\n     5→import { Ticker } from \"./components/Ticker\";\n     6→import { BackgroundEffects } from \"./components/BackgroundEffects\";\n     7→import { CoinflipPage } from \"./pages/CoinflipPage\";\n     8→import { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\n     9→import { CloseCallPage } from \"./pages/CloseCallPage\";\n    10→import { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\n    11→import { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\n    12→import { BossRaidProvider } from \"./features/boss-raid\";\n    13→import { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatarCompact } from \"./features/player-profile\";\n    14→import { QuestsProvider, ChestDropNotification } from \"./features/quests\";\n    15→import { QuestsPage } from \"./pages/QuestsPage\";\n    16→import { LootPage } from \"./pages/LootPage\";\n    17→import { CoinflipRoundPage } from \"./pages/CoinflipRoundPage\";\n    18→import { LordRoundPage } from \"./pages/LordRoundPage\";\n    19→import { CloseCallRoundPage } from \"./pages/CloseCallRoundPage\";\n    20→import { FairnessPage } from \"./pages/FairnessPage\";\n    21→import { BuildBadge } from \"./components/BuildBadge\";\n    22→import { PriceFeedProvider } from \"@rng-utopia/price-feeds\";\n    23→\n    24→\n    25→export function App() {\n    26→  return (\n    27→    <BrowserRouter>\n    28→      <PriceFeedProvider>\n    29→        <PlayerProfileProvider>\n    30→          <QuestsProvider>\n    31→            <BossRaidProvider>\n    32→              <AppContent />\n    33→            </BossRaidProvider>\n    34→          </QuestsProvider>\n    35→        </PlayerProfileProvider>\n    36→      </PriceFeedProvider>\n    37→    </BrowserRouter>\n    38→  );\n    39→}\n    40→\n    41→\n    42→// Chat icon SVG\n    43→const ChatIcon = () => (\n    44→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    45→    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    46→    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    47→    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    48→    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n    49→  </svg>\n    50→);\n    51→\n    52→// Footer component with terms and FAQ modals\n    53→function Footer() {\n    54→  const [showTerms, setShowTerms] = useState(false);\n    55→  const [showFAQ, setShowFAQ] = useState(false);\n    56→  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n    57→  const termsModalRef = useRef<HTMLDivElement>(null);\n    58→  const faqModalRef = useRef<HTMLDivElement>(null);\n    59→\n    60→  // Close modal on outside click\n    61→  useEffect(() => {\n    62→    if (!showTerms && !showFAQ) return;\n    63→\n    64→    const handleClickOutside = (e: MouseEvent) => {\n    65→      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n    66→        setShowTerms(false);\n    67→      }\n    68→      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n    69→        setShowFAQ(false);\n    70→      }\n    71→    };\n    72→\n    73→    document.addEventListener(\"mousedown\", handleClickOutside);\n    74→    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n    75→  }, [showTerms, showFAQ]);\n    76→\n    77→  // Close on escape\n    78→  useEffect(() => {\n    79→    if (!showTerms && !showFAQ) return;\n    80→\n    81→    const handleEscape = (e: KeyboardEvent) => {\n    82→      if (e.key === \"Escape\") {\n    83→        setShowTerms(false);\n    84→        setShowFAQ(false);\n    85→      }\n    86→    };\n    87→\n    88→    document.addEventListener(\"keydown\", handleEscape);\n    89→    return () => document.removeEventListener(\"keydown\", handleEscape);\n    90→  }, [showTerms, showFAQ]);\n    91→\n    92→  const toggleFAQSection = (section: string) => {\n    93→    setExpandedFAQ(expandedFAQ === section ? null : section);\n    94→  };\n    95→\n    96→  const faqSections = [\n    97→    {\n    98→      id: \"fees\",\n    99→      title: \"Platform Fees\",\n   100→      content: `TAUNT charges a 3% platform fee on all games. This means 97% of all wagered funds go directly to winners.\n   101→\n   102→Fee breakdown:\n   103→• 1% goes to player incentives (Dogpile Raid reward pool, future promotions)\n   104→• 2% goes to platform treasury (server costs, development, operations)\n   105→\n   106→What you get:\n   107→• Winners receive: 97% of the pot\n   108→• No hidden fees or withdrawal charges\n   109→• Part of your wagers fund rewards you can win back through Dogpile Raid`\n   110→    },\n   111→    {\n   112→      id: \"raid-boss\",\n   113→      title: \"What is Dogpile Raid?\",\n   114→      content: `Dogpile Raid is a community reward mechanic where players collectively take down a Mark by playing games.\n   115→\n   116→How it works:\n   117→• A new Mark spawns every hour with a 50-minute active phase\n   118→• Every wager you make in any game lands \"hits\" on the Mark\n   119→• The Mark's Armor drains over time - it's always dropped when the timer ends\n   120→• When dropped, the reward pool is distributed to all participants\n   121→\n   122→Rewards:\n   123→• Your share is proportional to your hit contribution\n   124→• The reward pool grows from 1% of all wagers during the raid\n   125→• Higher total community hits = better loot tier = bigger multipliers\n   126→• Bonus loot is occasionally added for extra rewards\n   127→\n   128→Loot Tiers (based on total hits):\n   129→• Bronze: 0-10 SOL in hits\n   130→• Silver: 10-50 SOL in hits\n   131→• Gold: 50-150 SOL in hits\n   132→• Platinum: 150-500 SOL in hits\n   133→• Diamond: 500+ SOL in hits`\n   134→    },\n   135→    {\n   136→      id: \"pvp\",\n   137→      title: \"Why PvP Games?\",\n   138→      content: `Unlike traditional house-edge gambling where you play against the casino, TAUNT is 100% player-vs-player. This creates a fundamentally fairer system:\n   139→\n   140→• No house edge exploiting players\n   141→• Prize pools come entirely from player wagers\n   142→• The platform only takes a small facilitation fee\n   143→• Better odds than any traditional casino\n   144→• Transparent, skill-independent wagering`\n   145→    },\n   146→    {\n   147→      id: \"tiers\",\n   148→      title: \"Wagering Tiers\",\n   149→      content: `TAUNT uses wagering tiers to match players with similar risk appetites together. Each tier has a fixed SOL amount - you play against others wagering the same amount.\n   150→\n   151→Available Tiers:\n   152→• Iron: 0.005 SOL\n   153→• Bronze: 0.01 SOL\n   154→• Silver: 0.1 SOL\n   155→• Gold: 0.25 SOL\n   156→• Platinum: 0.5 SOL\n   157→• Diamond: 1 SOL\n   158→\n   159→How it works:\n   160→• Each game has separate lobbies for each tier\n   161→• Select your tier before joining a game\n   162→• You're matched only with players in the same tier\n   163→• Everyone in the round wagers the exact same amount\n   164→\n   165→Benefits:\n   166→• Fair matchmaking - compete on equal footing\n   167→• Choose the risk level you're comfortable with\n   168→• No whales dominating smaller players`\n   169→    },\n   170→    {\n   171→      id: \"leaderboard\",\n   172→      title: \"Leaderboard System\",\n   173→      content: `Leaderboard system details coming soon.\n   174→\n   175→We're working on implementing competitive leaderboards to track and reward top players. Stay tuned for updates!`\n   176→    },\n   177→    {\n   178→      id: \"fairness\",\n   179→      title: \"On-Chain Fairness\",\n   180→      content: `All game outcomes are provably fair using cryptographic verification:\n   181→\n   182→Commit-Reveal Pattern (Crash, Close Call):\n   183→1. Server publishes a hash of its seed before betting\n   184→2. Solana blockhash becomes the public seed\n   185→3. After the round, server reveals its seed\n   186→4. Anyone can verify the outcome matches\n   187→\n   188→On-Chain VRF (Jackpot, Flip You):\n   189→1. Game requests randomness from VRF provider\n   190→2. VRF generates verifiable random bytes\n   191→3. Result and proof stored on Solana blockchain\n   192→4. Anyone can verify using blockchain explorer\n   193→\n   194→Visit the Fairness page in the header for verification tools.`\n   195→    },\n   196→    {\n   197→      id: \"rng-buff\",\n   198→      title: \"Heater\",\n   199→      content: `The Heater is a powerful temporary bonus granted to players who help drop the Mark before the timer expires.\n   200→\n   201→How to get the Heater:\n   202→1. Participate in the hourly Dogpile Raid by wagering in any game\n   203→2. Your wagers land \"hits\" on the Mark\n   204→3. If the Mark is dropped before time runs out, ALL participants receive the Heater\n   205→4. The Heater lasts for 1 hour (until the next raid starts)\n   206→\n   207→Heater Benefits:\n   208→• Golden glowing border on your avatar (visible to all players)\n   209→• Chance to drop crates when wagering\n   210→• Drop chance scales with wager amount (1% base + 5% per SOL, max 25%)\n   211→\n   212→Visual Indicators:\n   213→• Golden pulsing border around your avatar everywhere in the app\n   214→• Heater icon with countdown timer in your profile header\n   215→• Star icon with timer in the main header\n   216→\n   217→The Heater expires when the next raid begins, so make the most of it!`\n   218→    },\n   219→    {\n   220→      id: \"treasure-chests\",\n   221→      title: \"Crates\",\n   222→      content: `Crates are mystery rewards that contain XP and SOL prizes. Open them in the Loot page.\n   223→\n   224→How to earn crates:\n   225→• Heater drops: Random chance when wagering with active Heater\n   226→• Complete ALL daily quests: 1 crate\n   227→• Complete weekly quests: 1 crate per quest (3 total)\n   228→• Complete ALL weekly quests: +2 bonus crates (5 total)\n   229→\n   230→Heater crate drop rates:\n   231→• Base chance: 1% per wager\n   232→• Bonus: +5% per 1 SOL wagered\n   233→• Maximum: 25% chance per wager\n   234→\n   235→Crate rarity (determined when opened):\n   236→• Common (50%): 50-100 XP, 0.001-0.005 SOL\n   237→• Uncommon (30%): 100-250 XP, 0.005-0.01 SOL\n   238→• Rare (15%): 250-500 XP, 0.01-0.025 SOL\n   239→• Epic (4%): 500-1000 XP, 0.025-0.05 SOL\n   240→• Legendary (1%): 1000-2500 XP, 0.05-0.1 SOL\n   241→\n   242→SOL rewards are paid from the platform treasury. May the RNG gods smile upon you!`\n   243→    },\n   244→  ];\n   245→\n   246→  return (\n   247→    <>\n   248→      <footer className=\"footer-v2\">\n   249→        <div className=\"ft-logo\">TAUNT<em>.</em></div>\n   250→        <div className=\"ft-links\">\n   251→          <button type=\"button\" className=\"ft-lnk\" onClick={() => setShowFAQ(true)}>FAQ</button>\n   252→          <button type=\"button\" className=\"ft-lnk\" onClick={() => setShowTerms(true)}>Terms</button>\n   253→          <a href=\"https://x.com/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"ft-lnk\">Twitter</a>\n   254→          <a href=\"https://t.me/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"ft-lnk\">Telegram</a>\n   255→        </div>\n   256→        <div className=\"ft-tag\">taunt.bet &middot; Provably Fair &middot; Solana</div>\n   257→      </footer>\n   258→\n   259→      {/* Terms Modal */}\n   260→      {showTerms && (\n   261→        <div className=\"footer-terms-overlay\">\n   262→          <div className=\"footer-terms-modal\" ref={termsModalRef}>\n   263→            <button\n   264→              type=\"button\"\n   265→              className=\"footer-terms-close\"\n   266→              onClick={() => setShowTerms(false)}\n   267→            >\n   268→              ×\n   269→            </button>\n   270→            <h3 className=\"footer-terms-title\">Terms of Use</h3>\n   271→            <div className=\"footer-terms-content\">\n   272→              <p>\n   273→                By accessing and using TAUNT, you confirm that you are not a citizen,\n   274→                resident, or located within any jurisdiction where online gambling is prohibited\n   275→                or restricted by law, including but not limited to: the United States,\n   276→                United Kingdom, France, Germany, Spain, the Netherlands, or any other\n   277→                jurisdiction with similar regulations.\n   278→              </p>\n   279→              <p>\n   280→                You are solely responsible for determining whether your use of this platform\n   281→                is lawful in your country or region of residence. TAUNT does not provide\n   282→                legal advice and assumes no liability for users who access the platform in\n   283→                violation of applicable laws.\n   284→              </p>\n   285→              <p>\n   286→                By continuing to use this service, you acknowledge and accept these terms.\n   287→              </p>\n   288→            </div>\n   289→            <button\n   290→              type=\"button\"\n   291→              className=\"footer-terms-accept\"\n   292→              onClick={() => setShowTerms(false)}\n   293→            >\n   294→              I Understand\n   295→            </button>\n   296→          </div>\n   297→        </div>\n   298→      )}\n   299→\n   300→      {/* FAQ Modal */}\n   301→      {showFAQ && (\n   302→        <div className=\"footer-faq-overlay\">\n   303→          <div className=\"footer-faq-modal\" ref={faqModalRef}>\n   304→            <button\n   305→              type=\"button\"\n   306→              className=\"footer-faq-close\"\n   307→              onClick={() => setShowFAQ(false)}\n   308→            >\n   309→              ×\n   310→            </button>\n   311→            <h3 className=\"footer-faq-title\">Frequently Asked Questions</h3>\n   312→            <div className=\"footer-faq-content\">\n   313→              {faqSections.map((section) => (\n   314→                <div key={section.id} className=\"faq-section\">\n   315→                  <button\n   316→                    type=\"button\"\n   317→                    className={`faq-section-header ${expandedFAQ === section.id ? \"expanded\" : \"\"}`}\n   318→                    onClick={() => toggleFAQSection(section.id)}\n   319→                  >\n   320→                    <span className=\"faq-section-title\">{section.title}</span>\n   321→                    <span className=\"faq-section-arrow\">{expandedFAQ === section.id ? \"−\" : \"+\"}</span>\n   322→                  </button>\n   323→                  {expandedFAQ === section.id && (\n   324→                    <div className=\"faq-section-content\">\n   325→                      {section.content.split(\"\\n\\n\").map((paragraph, idx) => (\n   326→                        <p key={idx}>{paragraph}</p>\n   327→                      ))}\n   328→                    </div>\n   329→                  )}\n   330→                </div>\n   331→              ))}\n   332→            </div>\n   333→            <button\n   334→              type=\"button\"\n   335→              className=\"footer-faq-close-btn\"\n   336→              onClick={() => setShowFAQ(false)}\n   337→            >\n   338→              Close\n   339→            </button>\n   340→          </div>\n   341→        </div>\n   342→      )}\n   343→    </>\n   344→  );\n   345→}\n   346→\n   347→function AppContent() {\n   348→  const [chatExpanded, setChatExpanded] = useState(false);\n   349→  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);\n   350→\n   351→  const toggleSidebar = () => {\n   352→    setSidebarCollapsed(!sidebarCollapsed);\n   353→    document.body.classList.toggle(\"nc\", !sidebarCollapsed);\n   354→  };\n   355→\n   356→  return (\n   357→    <div className=\"app\">\n   358→      <BackgroundEffects />\n   359→\n   360→      {/* Fixed top bar */}\n   361→      <div className=\"top-bar\">\n   362→        <Header />\n   363→        <Ticker />\n   364→      </div>\n   365→\n   366→      {/* Fixed sidebar */}\n   367→      <Sidebar collapsed={sidebarCollapsed} onToggle={toggleSidebar} />\n   368→\n   369→      <main className=\"main\">\n   370→        <Routes>\n   371→          <Route path=\"/\" element={<HomePage />} />\n   372→          <Route path=\"/coinflip\" element={<CoinflipPage />} />\n   373→          <Route path=\"/coinflip/:matchId\" element={<CoinflipPage />} />\n   374→          <Route path=\"/lord-of-rngs\" element={<LordOfRngsPage />} />\n   375→          <Route path=\"/lord-of-rngs/:matchId\" element={<LordOfRngsPage />} />\n   376→          <Route path=\"/close-call\" element={<CloseCallPage />} />\n   377→          <Route path=\"/crash\" element={<CryptoCrashPage />} />\n   378→          <Route path=\"/game-of-trades\" element={<GameOfTradesPage />} />\n   379→          <Route path=\"/profile\" element={<ProfilePage />} />\n   380→          <Route path=\"/loot\" element={<LootPage />} />\n   381→          <Route path=\"/quests\" element={<QuestsPage />} />\n   382→          <Route path=\"/fairness\" element={<FairnessPage />} />\n   383→          <Route path=\"/coinflip/:matchId/proof\" element={<CoinflipRoundPage />} />\n   384→          <Route path=\"/lord-of-rngs/:matchId/proof\" element={<LordRoundPage />} />\n   385→          <Route path=\"/close-call/:roundId\" element={<CloseCallRoundPage />} />\n   386→          <Route path=\"*\" element={<NotFoundPage />} />\n   387→        </Routes>\n   388→        <Footer />\n   389→      </main>\n   390→\n   391→      <BuildBadge />\n   392→\n   393→      {/* Floating chat button */}\n   394→      <div className=\"chat-float\">\n   395→        <button type=\"button\" className=\"chat-float__btn\" onClick={() => setChatExpanded(!chatExpanded)}>\n   396→          <ChatIcon />\n   397→          <span className=\"chat-float__dot\" />\n   398→        </button>\n   399→        {chatExpanded && (\n   400→          <div className=\"chat-float__panel\">\n   401→            <div className=\"chat-panel-header\">\n   402→              <h4>Global Chat</h4>\n   403→              <button className=\"chat-close\" onClick={() => setChatExpanded(false)}>×</button>\n   404→            </div>\n   405→            <div className=\"chat-messages\">\n   406→              <div className=\"chat-message\">\n   407→                <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   408→                <span className=\"text\">gg nice flip!</span>\n   409→              </div>\n   410→              <div className=\"chat-message\">\n   411→                <PlayerAvatarCompact address=\"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   412→                <span className=\"text\">who's ready for crash?</span>\n   413→              </div>\n   414→              <div className=\"chat-message\">\n   415→                <PlayerAvatarCompact address=\"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   416→                <span className=\"text\">close call is rigged lol jk</span>\n   417→              </div>\n   418→              <div className=\"chat-message\">\n   419→                <PlayerAvatarCompact address=\"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   420→                <span className=\"text\">just hit 5x on crash!</span>\n   421→              </div>\n   422→              <div className=\"chat-message\">\n   423→                <PlayerAvatarCompact address=\"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   424→                <span className=\"text\">coinflip is where it's at</span>\n   425→              </div>\n   426→            </div>\n   427→            <div className=\"chat-input-container\">\n   428→              <input type=\"text\" className=\"chat-input\" placeholder=\"Type a message...\" />\n   429→              <button className=\"chat-send-btn\">Send</button>\n   430→            </div>\n   431→          </div>\n   432→        )}\n   433→      </div>\n   434→\n   435→      <MiniProfileModal />\n   436→      <ChestDropNotification />\n   437→    </div>\n   438→  );\n   439→}\n   440→\n   441→// Mock recent winners data\n   442→const RECENT_WINNERS = [\n   443→  { player: \"CryptoSavage.eth\", game: \"FLIP YOU\", amount: \"+$194.00\", positive: true, taunt: \"later, bitch\", color: \"#FFB800\" },\n   444→  { player: \"degen_whale_99\", game: \"MOON OR REKT\", amount: \"+$407.40\", positive: true, taunt: \"gg ez lmao\", color: \"#FF2D55\" },\n   445→  { player: \"0x9f…22b1\", game: \"JACKPOT\", amount: \"+$38.80\", positive: true, taunt: null, color: \"#FF1F8E\" },\n   446→  { player: \"paper_hands_pete\", game: \"FLIP YOU\", amount: \"-$10.00\", positive: false, taunt: \"skill issue ngl\", color: \"#FFB800\" },\n   447→  { player: \"sol_degen_88\", game: \"GAME OF TRADES\", amount: \"+$30.00\", positive: true, taunt: null, color: \"#3D7FFF\" },\n   448→  { player: \"anon_8821\", game: \"JACKPOT\", amount: \"+$146.55\", positive: true, taunt: \"the RNG chose me\", color: \"#FF1F8E\" },\n   449→  { player: \"0x3b…81a2\", game: \"CLOSE CALL\", amount: \"+$18.40\", positive: true, taunt: null, color: \"#00E676\" },\n   450→  { player: \"moon_maxi_99\", game: \"CRYPTO CRASH\", amount: \"+$82.10\", positive: true, taunt: \"rekt. bye.\", color: \"#FF2D55\" },\n   451→];\n   452→\n   453→function HomePage() {\n   454→  return (\n   455→    <>\n   456→      {/* Page header */}\n   457→      <div className=\"page-hd\">\n   458→        <div>\n   459→          <div className=\"pg-title\">The <span className=\"pk\">Pit.</span></div>\n   460→          <div className=\"pg-sub\">Five ways to ruin someone's day</div>\n   461→        </div>\n   462→        <div className=\"pg-tags\">\n   463→          <div className=\"ptag on\">Floor Open · 24/7</div>\n   464→          <div className=\"ptag\">3% Flat Fee · Zero House Edge</div>\n   465→          <div className=\"ptag\">Provably Fair · Solana</div>\n   466→        </div>\n   467→      </div>\n   468→\n   469→      {/* Game grid */}\n   470→      <div className=\"game-grid\">\n   471→        <GameCardV2\n   472→          name=\"Flip You\"\n   473→          subtitle=\"$0.50 — $100 · P2P · 1v1\"\n   474→          description=\"Pure 50/50. One winner takes the pot. Your opponent sees your taunt the moment they lose.\"\n   475→          path=\"/coinflip\"\n   476→          visual=\"coinflip\"\n   477→          mode=\"VRF · On-chain\"\n   478→          colorClass=\"y\"\n   479→          stats={[\n   480→            { value: \"18\", label: \"Open Games\" },\n   481→            { value: \"6\", label: \"Tiers\" },\n   482→            { value: \"97%\", label: \"Payout\" },\n   483→          ]}\n   484→        />\n   485→        <GameCardV2\n   486→          name=\"Jackpot\"\n   487→          subtitle=\"$0.50 — $100 · P2P · Lottery\"\n   488→          description=\"Buy tickets, buy odds. One spin decides everything. The wheel doesn't care how many you own.\"\n   489→          path=\"/lord-of-rngs\"\n   490→          visual=\"lotr\"\n   491→          mode=\"VRF · On-chain\"\n   492→          colorClass=\"pk\"\n   493→          stats={[\n   494→            { value: \"$146\", label: \"Top Jackpot\" },\n   495→            { value: \"6\", label: \"Active\" },\n   496→            { value: \"VRF\", label: \"Randomness\" },\n   497→          ]}\n   498→        />\n   499→        <GameCardV2\n   500→          name=\"Close Call\"\n   501→          subtitle=\"$0.50 — $100 · P2P · Binary\"\n   502→          description=\"Green or red. Lock in before the round closes. Winners split the losers' side pro-rata.\"\n   503→          path=\"/close-call\"\n   504→          visual=\"close-call\"\n   505→          mode=\"Commit-Reveal\"\n   506→          colorClass=\"g\"\n   507→          stats={[\n   508→            { value: \"$892\", label: \"Active Pool\" },\n   509→            { value: \"1.46×\", label: \"Green Odds\" },\n   510→            { value: \"43s\", label: \"Time Left\" },\n   511→          ]}\n   512→        />\n   513→        <GameCardV2\n   514→          name=\"Crypto Crash\"\n   515→          subtitle=\"$0.50 — $100 · P2P · Crash\"\n   516→          description=\"Multiplier climbs. Cash out before it crashes. The last player in wins the Diamond pot.\"\n   517→          path=\"/crash\"\n   518→          visual=\"crash\"\n   519→          mode=\"Commit-Reveal\"\n   520→          colorClass=\"r\"\n   521→          stats={[\n   522→            { value: \"1.84×\", label: \"Live Multi\" },\n   523→            { value: \"$1,842\", label: \"Diamond Pot\" },\n   524→            { value: \"CR\", label: \"Provably Fair\" },\n   525→          ]}\n   526→        />\n   527→        <GameCardV2\n   528→          name=\"Game of Trades\"\n   529→          subtitle=\"$0.50 — $100 · P2P · Sim\"\n   530→          description=\"$10k paper balance. 100× leverage. 60 seconds on a live chart. Best PnL takes the pot.\"\n   531→          path=\"/game-of-trades\"\n   532→          visual=\"trades\"\n   533→          mode=\"100× Leverage\"\n   534→          colorClass=\"b\"\n   535→          stats={[\n   536→            { value: \"$600\", label: \"Largest Pot\" },\n   537→            { value: \"32\", label: \"In Lobbies\" },\n   538→            { value: \"60s\", label: \"Round Time\" },\n   539→          ]}\n   540→        />\n   541→      </div>\n   542→\n   543→      {/* Recent winners strip */}\n   544→      <div className=\"wins-strip\">\n   545→        <div className=\"wins-hd\"><div className=\"pdot\" />Recent Winners</div>\n   546→        <div className=\"wins-in\">\n   547→          {RECENT_WINNERS.map((w, i) => (\n   548→            <div key={i} className=\"wchip\" style={{ \"--wc\": w.color } as React.CSSProperties}>\n   549→              <div>\n   550→                <div className=\"wchip-player\">{w.player}</div>\n   551→                <div className=\"wchip-game\">{w.game}</div>\n   552→                {w.taunt && <div className=\"wchip-taunt\">\"{w.taunt}\"</div>}\n   553→              </div>\n   554→              <div className={`wchip-amt ${w.positive ? \"p\" : \"n\"}`}>{w.amount}</div>\n   555→            </div>\n   556→          ))}\n   557→        </div>\n   558→      </div>\n   559→    </>\n   560→  );\n   561→}\n   562→\n   563→interface GameCardV2Props {\n   564→  name: string;\n   565→  subtitle: string;\n   566→  description: string;\n   567→  path: string;\n   568→  visual: string;\n   569→  mode: string;\n   570→  colorClass: string;\n   571→  stats: { value: string; label: string }[];\n   572→}\n   573→\n   574→function GameCardV2({ name, subtitle, description, path, visual, mode, colorClass, stats }: GameCardV2Props) {\n   575→  return (\n   576→    <Link to={path} className={`gcard gc-${colorClass}`}>\n   577→      <div className=\"gcard-accent\" />\n   578→      <div className=\"gcard-vis\">\n   579→        <div className=\"gcard-bg\" />\n   580→        <GameVisualV2 type={visual} />\n   581→      </div>\n   582→      <div className=\"gcard-info\">\n   583→        <div className=\"gcard-hd\">\n   584→          <div>\n   585→            <div className=\"gcard-name\">{name}</div>\n   586→            <div className=\"gcard-sub2\">{subtitle}</div>\n   587→          </div>\n   588→          <div className=\"gcard-mode\">{mode}</div>\n   589→        </div>\n   590→        <div className=\"gcard-line\">{description}</div>\n   591→        <div className=\"gcard-stats\">\n   592→          {stats.map((s, i) => (\n   593→            <div key={i} className=\"gstat\">\n   594→              <div className=\"gstat-n\">{s.value}</div>\n   595→              <div className=\"gstat-l\">{s.label}</div>\n   596→            </div>\n   597→          ))}\n   598→        </div>\n   599→        <button type=\"button\" className=\"gcard-btn\" onClick={(e) => e.preventDefault()}>\n   600→          <div className=\"gcard-bf\" />\n   601→          <span className=\"gcard-btxt\">Enter Game</span>\n   602→          <span className=\"gcard-arr\">&rarr;</span>\n   603→        </button>\n   604→      </div>\n   605→    </Link>\n   606→  );\n   607→}\n   608→\n   609→function GameVisualV2({ type }: { type: string }) {\n   610→  switch (type) {\n   611→    case \"coinflip\":\n   612→      return (\n   613→        <svg className=\"gcard-ico coin-flip\" viewBox=\"0 0 135 135\" fill=\"none\">\n   614→          <circle cx=\"67.5\" cy=\"67.5\" r=\"60\" fill=\"#111118\" stroke=\"#FFB800\" strokeWidth=\"2.5\" />\n   615→          <circle cx=\"67.5\" cy=\"67.5\" r=\"52\" fill=\"none\" stroke=\"rgba(255,184,0,0.12)\" strokeWidth=\"1\" />\n   616→          <circle cx=\"67.5\" cy=\"67.5\" r=\"43\" fill=\"none\" stroke=\"rgba(255,184,0,0.07)\" strokeWidth=\"1\" strokeDasharray=\"5 5\" />\n   617→          <path d=\"M22 44 A60 60 0 0 1 113 44\" stroke=\"rgba(255,184,0,0.28)\" strokeWidth=\"3.5\" strokeLinecap=\"round\" fill=\"none\" />\n   618→          <text x=\"67.5\" y=\"86\" textAnchor=\"middle\" fontFamily=\"'Bebas Neue', sans-serif\" fontSize=\"46\" fill=\"#FFB800\" letterSpacing=\"2\">H</text>\n   619→          <circle cx=\"67.5\" cy=\"11\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n   620→          <circle cx=\"67.5\" cy=\"124\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n   621→          <circle cx=\"11\" cy=\"67.5\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n   622→          <circle cx=\"124\" cy=\"67.5\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n   623→        </svg>\n   624→      );\n   625→\n   626→    case \"lotr\":\n   627→      return (\n   628→        <svg className=\"gcard-ico\" viewBox=\"0 0 135 135\" fill=\"none\">\n   629→          <circle cx=\"67.5\" cy=\"67.5\" r=\"62\" fill=\"#111118\" stroke=\"#FF1F8E\" strokeWidth=\"2\" />\n   630→          <g className=\"spin-slow\">\n   631→            <path d=\"M67.5 67.5L67.5 7.5A60 60 0 0 1 119.5 37.5Z\" fill=\"rgba(255,31,142,0.2)\" stroke=\"rgba(255,31,142,0.3)\" strokeWidth=\"0.8\" />\n   632→            <path d=\"M67.5 67.5L119.5 37.5A60 60 0 0 1 127.5 67.5Z\" fill=\"rgba(255,31,142,0.08)\" stroke=\"rgba(255,31,142,0.2)\" strokeWidth=\"0.8\" />\n   633→            <path d=\"M67.5 67.5L127.5 67.5A60 60 0 0 1 119.5 97.5Z\" fill=\"rgba(255,31,142,0.2)\" stroke=\"rgba(255,31,142,0.3)\" strokeWidth=\"0.8\" />\n   634→            <path d=\"M67.5 67.5L119.5 97.5A60 60 0 0 1 67.5 127.5Z\" fill=\"rgba(255,31,142,0.08)\" stroke=\"rgba(255,31,142,0.2)\" strokeWidth=\"0.8\" />\n   635→            <path d=\"M67.5 67.5L67.5 127.5A60 60 0 0 1 15.5 97.5Z\" fill=\"rgba(255,31,142,0.2)\" stroke=\"rgba(255,31,142,0.3)\" strokeWidth=\"0.8\" />\n   636→            <path d=\"M67.5 67.5L15.5 97.5A60 60 0 0 1 7.5 67.5Z\" fill=\"rgba(255,31,142,0.08)\" stroke=\"rgba(255,31,142,0.2)\" strokeWidth=\"0.8\" />\n   637→            <path d=\"M67.5 67.5L7.5 67.5A60 60 0 0 1 15.5 37.5Z\" fill=\"rgba(255,31,142,0.2)\" stroke=\"rgba(255,31,142,0.3)\" strokeWidth=\"0.8\" />\n   638→            <path d=\"M67.5 67.5L15.5 37.5A60 60 0 0 1 67.5 7.5Z\" fill=\"rgba(255,31,142,0.08)\" stroke=\"rgba(255,31,142,0.2)\" strokeWidth=\"0.8\" />\n   639→            <circle cx=\"67.5\" cy=\"67.5\" r=\"22\" fill=\"#111118\" stroke=\"#FF1F8E\" strokeWidth=\"1.5\" />\n   640→            <circle cx=\"67.5\" cy=\"67.5\" r=\"7\" fill=\"#FF1F8E\" opacity=\"0.6\" />\n   641→          </g>\n   642→          <polygon points=\"67.5,2 74,15 61,15\" fill=\"#FFB800\" />\n   643→          <circle cx=\"67.5\" cy=\"67.5\" r=\"10\" fill=\"#0E0E1A\" stroke=\"#FF1F8E\" strokeWidth=\"1.5