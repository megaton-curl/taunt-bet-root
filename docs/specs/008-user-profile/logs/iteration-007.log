{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SrrYXc65CmyQJtv4vWHtfH","type":"tool_result","content":"     1→/**\n     2→ * Player Profile Feature - Public API\n     3→ *\n     4→ * Exports the provider, hooks, components, and types needed\n     5→ * for integrating player profiles throughout the app.\n     6→ */\n     7→\n     8→// Provider and hook\n     9→export { PlayerProfileProvider, usePlayerProfile, truncateAddress } from \"./context/PlayerProfileContext\";\n    10→\n    11→// Components\n    12→export { PlayerAvatar } from \"./components/PlayerAvatar\";\n    13→export { PlayerAvatarCompact } from \"./components/PlayerAvatarCompact\";\n    14→export { LevelProgressBar } from \"./components/LevelProgressBar\";\n    15→export { MiniProfileModal } from \"./components/MiniProfileModal\";\n    16→export { ProfilePage } from \"./components/ProfilePage\";\n    17→export { AvatarSelector } from \"./components/AvatarSelector\";\n    18→\n    19→// Types\n    20→export type {\n    21→  AvatarId,\n    22→  AvatarSize,\n    23→  AvatarTier,\n    24→  AvatarConfig,\n    25→  BorderStyle,\n    26→  BorderConfig,\n    27→  GameId,\n    28→  PlayerProfile,\n    29→  PlayerStats,\n    30→  GameSpecificStats,\n    31→  LootItem,\n    32→  LootSource,\n    33→  ProfileTransaction,\n    34→  GameResultEvent,\n    35→  PlayerProfileContextValue,\n    36→} from \"./types\";\n    37→\n    38→export {\n    39→  AVATAR_CONFIGS,\n    40→  AVATAR_SIZES,\n    41→  AVATAR_TIER_COLORS,\n    42→  LEVEL_BORDERS,\n    43→  GAME_NAMES,\n    44→  DEFAULT_AVATAR_ID,\n    45→  MAX_USERNAME_LENGTH,\n    46→  MIN_USERNAME_LENGTH,\n    47→  USERNAME_REGEX,\n    48→  createEmptyStats,\n    49→  getHighestUnlockedAvatar,\n    50→} from \"./types\";\n    51→\n    52→// XP Calculator utilities\n    53→export {\n    54→  getXPForLevel,\n    55→  getLevelFromXP,\n    56→  getXPProgress,\n    57→  calculateWagerXP,\n    58→  calculateWinBonusXP,\n    59→  calculateGameXP,\n    60→  getBorderStyleFromLevel,\n    61→  getLevelMilestones,\n    62→  formatXP,\n    63→  formatLevel,\n    64→  type XPProgress,\n    65→} from \"./utils/xp-calculator\";\n    66→\n    67→// Event bus for game integrations\n    68→export {\n    69→  profileEventBus,\n    70→  emitGameResult,\n    71→  emitCoinflipResults,\n    72→  emitLordOfRngsResults,\n    73→  emitCryptoCrashResults,\n    74→  emitCloseCallResults,\n    75→  createGameResultEvent,\n    76→} from \"./utils/profile-event-bus\";\n    77→\n    78→// Mock simulation utilities (for testing/development)\n    79→export {\n    80→  getProfile,\n    81→  getOrCreateProfile,\n    82→  getTransactions,\n    83→  getDisplayName,\n    84→  getAvatarId,\n    85→  getLevel,\n    86→  addLoot,\n    87→} from \"./utils/mock-simulation\";\n    88→"}]},"parent_tool_use_id":null,"session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"0f83d5ed-f826-4f2b-9a34-7c02fd1845ab","timestamp":"2026-03-19T19:03:09.934Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/index.ts","content":"/**\n * Player Profile Feature - Public API\n *\n * Exports the provider, hooks, components, and types needed\n * for integrating player profiles throughout the app.\n */\n\n// Provider and hook\nexport { PlayerProfileProvider, usePlayerProfile, truncateAddress } from \"./context/PlayerProfileContext\";\n\n// Components\nexport { PlayerAvatar } from \"./components/PlayerAvatar\";\nexport { PlayerAvatarCompact } from \"./components/PlayerAvatarCompact\";\nexport { LevelProgressBar } from \"./components/LevelProgressBar\";\nexport { MiniProfileModal } from \"./components/MiniProfileModal\";\nexport { ProfilePage } from \"./components/ProfilePage\";\nexport { AvatarSelector } from \"./components/AvatarSelector\";\n\n// Types\nexport type {\n  AvatarId,\n  AvatarSize,\n  AvatarTier,\n  AvatarConfig,\n  BorderStyle,\n  BorderConfig,\n  GameId,\n  PlayerProfile,\n  PlayerStats,\n  GameSpecificStats,\n  LootItem,\n  LootSource,\n  ProfileTransaction,\n  GameResultEvent,\n  PlayerProfileContextValue,\n} from \"./types\";\n\nexport {\n  AVATAR_CONFIGS,\n  AVATAR_SIZES,\n  AVATAR_TIER_COLORS,\n  LEVEL_BORDERS,\n  GAME_NAMES,\n  DEFAULT_AVATAR_ID,\n  MAX_USERNAME_LENGTH,\n  MIN_USERNAME_LENGTH,\n  USERNAME_REGEX,\n  createEmptyStats,\n  getHighestUnlockedAvatar,\n} from \"./types\";\n\n// XP Calculator utilities\nexport {\n  getXPForLevel,\n  getLevelFromXP,\n  getXPProgress,\n  calculateWagerXP,\n  calculateWinBonusXP,\n  calculateGameXP,\n  getBorderStyleFromLevel,\n  getLevelMilestones,\n  formatXP,\n  formatLevel,\n  type XPProgress,\n} from \"./utils/xp-calculator\";\n\n// Event bus for game integrations\nexport {\n  profileEventBus,\n  emitGameResult,\n  emitCoinflipResults,\n  emitLordOfRngsResults,\n  emitCryptoCrashResults,\n  emitCloseCallResults,\n  createGameResultEvent,\n} from \"./utils/profile-event-bus\";\n\n// Mock simulation utilities (for testing/development)\nexport {\n  getProfile,\n  getOrCreateProfile,\n  getTransactions,\n  getDisplayName,\n  getAvatarId,\n  getLevel,\n  addLoot,\n} from \"./utils/mock-simulation\";\n","numLines":88,"startLine":1,"totalLines":88}}}
