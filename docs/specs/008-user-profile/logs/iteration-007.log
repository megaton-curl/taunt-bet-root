{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01QgKjEV4PvDvgLCBc2DvXYS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MGZ58z9aSTZ8LUdXZAP3iF","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/utils/profile-event-bus.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":9148,"cache_read_input_tokens":30426,"cache_creation":{"ephemeral_5m_input_tokens":9148,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01FhDjN8ZwAxzsVHRaG5YiMb","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"f988cf7b-6d25-4c15-9bff-6f8b419d41f1"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MGZ58z9aSTZ8LUdXZAP3iF","type":"tool_result","content":"     1→/**\n     2→ * Profile Event Bus - Cross-feature event emitter for Player Profiles\n     3→ *\n     4→ * Games emit game result events here, and the Player Profile\n     5→ * system subscribes to track XP, stats, and transaction history.\n     6→ *\n     7→ * Pattern mirrors raid-event-bus.ts for consistency.\n     8→ */\n     9→\n    10→import type { GameId, GameResultEvent } from \"../types\";\n    11→\n    12→type GameResultCallback = (event: GameResultEvent) => void;\n    13→\n    14→class ProfileEventBus {\n    15→  private listeners = new Set<GameResultCallback>();\n    16→\n    17→  /**\n    18→   * Emit a game result event from any game\n    19→   */\n    20→  emit(event: GameResultEvent): void {\n    21→    this.listeners.forEach((callback) => {\n    22→      try {\n    23→        callback(event);\n    24→      } catch (error) {\n    25→        console.error(\"[ProfileEventBus] Error in listener:\", error);\n    26→      }\n    27→    });\n    28→  }\n    29→\n    30→  /**\n    31→   * Subscribe to game result events\n    32→   * Returns an unsubscribe function\n    33→   */\n    34→  subscribe(callback: GameResultCallback): () => void {\n    35→    this.listeners.add(callback);\n    36→    return () => {\n    37→      this.listeners.delete(callback);\n    38→    };\n    39→  }\n    40→\n    41→  /**\n    42→   * Get the number of active listeners (for debugging)\n    43→   */\n    44→  get listenerCount(): number {\n    45→    return this.listeners.size;\n    46→  }\n    47→\n    48→  /**\n    49→   * Clear all listeners (for testing)\n    50→   */\n    51→  clear(): void {\n    52→    this.listeners.clear();\n    53→  }\n    54→}\n    55→\n    56→// Singleton instance for cross-feature communication\n    57→export const profileEventBus = new ProfileEventBus();\n    58→\n    59→// ============ Helper Functions ============\n    60→\n    61→/**\n    62→ * Create a game result event (convenience function for games)\n    63→ */\n    64→export function createGameResultEvent(\n    65→  gameId: GameId,\n    66→  matchId: string,\n    67→  playerAddress: string,\n    68→  wagerAmount: number,\n    69→  outcome: \"win\" | \"loss\",\n    70→  payoutAmount: number,\n    71→): GameResultEvent {\n    72→  return {\n    73→    gameId,\n    74→    matchId,\n    75→    playerAddress,\n    76→    wagerAmount,\n    77→    outcome,\n    78→    payoutAmount,\n    79→    timestamp: Date.now(),\n    80→  };\n    81→}\n    82→\n    83→/**\n    84→ * Emit a game result for a single player\n    85→ */\n    86→export function emitGameResult(\n    87→  gameId: GameId,\n    88→  matchId: string,\n    89→  playerAddress: string,\n    90→  wagerAmount: number,\n    91→  outcome: \"win\" | \"loss\",\n    92→  payoutAmount: number,\n    93→): void {\n    94→  profileEventBus.emit(\n    95→    createGameResultEvent(gameId, matchId, playerAddress, wagerAmount, outcome, payoutAmount)\n    96→  );\n    97→}\n    98→\n    99→/**\n   100→ * Emit coinflip result for both players\n   101→ */\n   102→export function emitCoinflipResults(\n   103→  matchId: string,\n   104→  winner: string,\n   105→  loser: string,\n   106→  entryAmount: number,\n   107→  payoutAmount: number,\n   108→): void {\n   109→  emitGameResult(\"coinflip\", matchId, winner, entryAmount, \"win\", payoutAmount);\n   110→  emitGameResult(\"coinflip\", matchId, loser, entryAmount, \"loss\", 0);\n   111→}\n   112→\n   113→/**\n   114→ * Emit lord of rngs result for all players\n   115→ */\n   116→export function emitLordOfRngsResults(\n   117→  roundId: string,\n   118→  winner: string,\n   119→  participants: Array<{ address: string; totalWager: number }>,\n   120→  payoutAmount: number,\n   121→): void {\n   122→  for (const participant of participants) {\n   123→    const isWinner = participant.address === winner;\n   124→    emitGameResult(\n   125→      \"lord-of-rngs\",\n   126→      roundId,\n   127→      participant.address,\n   128→      participant.totalWager,\n   129→      isWinner ? \"win\" : \"loss\",\n   130→      isWinner ? payoutAmount : 0,\n   131→    );\n   132→  }\n   133→}\n   134→\n   135→/**\n   136→ * Emit crypto crash results for all players\n   137→ */\n   138→export function emitCryptoCrashResults(\n   139→  roundId: string,\n   140→  results: Array<{\n   141→    address: string;\n   142→    wager: number;\n   143→    outcome: \"win\" | \"loss\";\n   144→    payout: number;\n   145→  }>,\n   146→): void {\n   147→  for (const result of results) {\n   148→    emitGameResult(\n   149→      \"crypto-crash\",\n   150→      roundId,\n   151→      result.address,\n   152→      result.wager,\n   153→      result.outcome,\n   154→      result.payout,\n   155→    );\n   156→  }\n   157→}\n   158→\n   159→/**\n   160→ * Emit close call results for all players\n   161→ */\n   162→export function emitCloseCallResults(\n   163→  roundId: string,\n   164→  results: Array<{\n   165→    address: string;\n   166→    wager: number;\n   167→    outcome: \"win\" | \"loss\";\n   168→    payout: number;\n   169→  }>,\n   170→): void {\n   171→  for (const result of results) {\n   172→    emitGameResult(\n   173→      \"close-call\",\n   174→      roundId,\n   175→      result.address,\n   176→      result.wager,\n   177→      result.outcome,\n   178→      result.payout,\n   179→    );\n   180→  }\n   181→}\n   182→\n   183→/**\n   184→ * Emit game of trades results for all players\n   185→ * Winners are the top 3 who receive payouts, everyone else loses\n   186→ */\n   187→export function emitGameOfTradesResults(\n   188→  roundId: string,\n   189→  results: Array<{\n   190→    address: string;\n   191→    entryAmount: number;\n   192→    payout: number;\n   193→  }>,\n   194→): void {\n   195→  for (const result of results) {\n   196→    const isWinner = result.payout > 0;\n   197→    emitGameResult(\n   198→      \"game-of-trades\",\n   199→      roundId,\n   200→      result.address,\n   201→      result.entryAmount,\n   202→      isWinner ? \"win\" : \"loss\",\n   203→      result.payout,\n   204→    );\n   205→  }\n   206→}\n   207→"}]},"parent_tool_use_id":"toolu_01FhDjN8ZwAxzsVHRaG5YiMb","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"41fb129f-286c-4396-8eeb-ec462012efc4","timestamp":"2026-03-19T19:01:34.897Z"}
