ttom: 1px solid var(--color-border);\n}\n\n.profile-transactions__table th {\n  font-size: 1rem;\n  font-weight: 600;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.profile-transactions__outcome--win {\n  color: var(--color-neon-green);\n}\n\n.profile-transactions__outcome--loss {\n  color: var(--color-neon-pink);\n}\n\n.profile-transactions__net--positive {\n  color: var(--color-neon-green);\n}\n\n.profile-transactions__net--negative {\n  color: var(--color-neon-pink);\n}\n\n/* Profile Settings */\n.profile-settings__section {\n  margin-bottom: 32px;\n}\n\n.profile-settings__section-title {\n  font-size: 1rem;\n  font-weight: 600;\n  margin-bottom: 16px;\n  color: var(--color-text);\n}","numLines":50,"startLine":12538,"totalLines":16502}}}
