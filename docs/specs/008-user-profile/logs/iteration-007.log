{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V8wSy3tqpCoQq3N5hB6hTW","type":"tool_result","content":"   360→      } else {\n   361→        // No active round — create a new one via backend\n   362→        if (!token) {\n   363→          throw new BackendRequestError(401, \"Wallet session is not authenticated.\");\n   364→        }\n   365→\n   366→        const result = await buildBackendCreateRoundTx(\n   367→          publicKey,\n   368→          wagerAmount,\n   369→          token,\n   370→        );\n   371→        await sendAndConfirm(result.transaction);\n   372→        matchId = result.matchId;\n   373→      }\n   374→\n   375→      // Fetch the round we just joined/created\n   376→      const round = await waitForRoundAvailability(\n   377→        connection,\n   378→        matchId,\n   379→        publicKey.toBase58(),\n   380→      );\n   381→      if (round) {\n   382→        setActiveRound(round);\n   383→        setActiveRoundMeta({ matchId });\n   384→      } else {\n   385→        setActiveRoundMeta({ matchId });\n   386→      }\n   387→    } catch (err) {\n   388→      const userMsg = parseTransactionError(err);\n   389→      setError(userMsg);\n   390→      // If round PDA is gone or simulation failed, the round state is stale — auto-refresh\n   391→      const rawMsg = err instanceof Error ? err.message : String(err);\n   392→      const isStaleRound = rawMsg.includes(\"Custom\\\":3012\") || rawMsg.includes(\"Transaction will fail\");\n   393→      if (isStaleRound) {\n   394→        setActiveRound(null);\n   395→        setActiveRoundMeta(null);\n   396→        void refreshRounds();\n   397→      }\n   398→    } finally {\n   399→      setJoining(false);"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"9177d5e9-9855-4e8d-8b9e-1a1f3cb7db7c","timestamp":"2026-03-19T19:02:15.578Z"}
