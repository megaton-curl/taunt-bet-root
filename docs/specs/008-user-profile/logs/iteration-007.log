{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WECoMbcH5t4KHAeemxFoiC","type":"tool_result","content":"     1→/**\n     2→ * ProfilePage - Main profile page component\n     3→ *\n     4→ * Displays the full player profile with tabs:\n     5→ * - Statistics (player stats and game performance)\n     6→ * - Transactions (game history)\n     7→ * - Settings (username, avatar, socials)\n     8→ */\n     9→\n    10→import { useState, useRef, useEffect } from \"react\";\n    11→import { usePlayerProfile } from \"../context/PlayerProfileContext\";\n    12→import { useBossRaid } from \"../../boss-raid\";\n    13→import { PlayerAvatar } from \"./PlayerAvatar\";\n    14→import { LevelProgressBar } from \"./LevelProgressBar\";\n    15→import { ProfileStats } from \"./ProfileStats\";\n    16→import { ProfileTransactions } from \"./ProfileTransactions\";\n    17→import { ProfileSettings } from \"./ProfileSettings\";\n    18→import { AvatarSelectorModal } from \"./AvatarSelectorModal\";\n    19→import { MAX_USERNAME_LENGTH, MIN_USERNAME_LENGTH, USERNAME_REGEX } from \"../types\";\n    20→\n    21→type ProfileTab = \"stats\" | \"transactions\" | \"settings\";\n    22→\n    23→// Pencil edit icon\n    24→const EditIcon = () => (\n    25→  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    26→    <path d=\"M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z\"/>\n    27→  </svg>\n    28→);\n    29→\n    30→// Check/save icon\n    31→const CheckIcon = () => (\n    32→  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    33→    <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z\"/>\n    34→  </svg>\n    35→);\n    36→\n    37→// Cancel icon\n    38→const CancelIcon = () => (\n    39→  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    40→    <path d=\"M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z\"/>\n    41→  </svg>\n    42→);\n    43→\n    44→export function ProfilePage() {\n    45→  const { myProfile, loading, updateUsername } = usePlayerProfile();\n    46→  const { hasRNGBuff, rngBuff } = useBossRaid();\n    47→  const [activeTab, setActiveTab] = useState<ProfileTab>(\"stats\");\n    48→  const [isEditingName, setIsEditingName] = useState(false);\n    49→  const [editedName, setEditedName] = useState(\"\");\n    50→  const [savingName, setSavingName] = useState(false);\n    51→  const [nameError, setNameError] = useState<string | null>(null);\n    52→  const [isAvatarModalOpen, setIsAvatarModalOpen] = useState(false);\n    53→  const [buffTimeRemaining, setBuffTimeRemaining] = useState(0);\n    54→  const inputRef = useRef<HTMLInputElement>(null);\n    55→\n    56→  // Update buff timer every second\n    57→  useEffect(() => {\n    58→    if (!hasRNGBuff || !rngBuff) {\n    59→      setBuffTimeRemaining(0);\n    60→      return;\n    61→    }\n    62→\n    63→    const updateTimer = () => {\n    64→      const remaining = Math.max(0, rngBuff.expiresAt - Date.now());\n    65→      setBuffTimeRemaining(remaining);\n    66→    };\n    67→\n    68→    updateTimer();\n    69→    const interval = setInterval(updateTimer, 1000);\n    70→    return () => clearInterval(interval);\n    71→  }, [hasRNGBuff, rngBuff]);\n    72→\n    73→  useEffect(() => {\n    74→    if (isEditingName && inputRef.current) {\n    75→      inputRef.current.focus();\n    76→      inputRef.current.select();\n    77→    }\n    78→  }, [isEditingName]);\n    79→\n    80→  const validateUsername = (value: string): string | null => {\n    81→    if (value.length === 0) return null;\n    82→    if (value.length < MIN_USERNAME_LENGTH) {\n    83→      return `Min ${MIN_USERNAME_LENGTH} characters`;\n    84→    }\n    85→    if (value.length > MAX_USERNAME_LENGTH) {\n    86→      return `Max ${MAX_USERNAME_LENGTH} characters`;\n    87→    }\n    88→    if (!USERNAME_REGEX.test(value)) {\n    89→      return \"Letters, numbers, underscores only\";\n    90→    }\n    91→    return null;\n    92→  };\n    93→\n    94→  const handleStartEditing = () => {\n    95→    setEditedName(myProfile?.username ?? \"\");\n    96→    setNameError(null);\n    97→    setIsEditingName(true);\n    98→  };\n    99→\n   100→  const handleCancelEditing = () => {\n   101→    setIsEditingName(false);\n   102→    setEditedName(\"\");\n   103→    setNameError(null);\n   104→  };\n   105→\n   106→  const handleSaveName = async () => {\n   107→    const error = validateUsername(editedName);\n   108→    if (error) {\n   109→      setNameError(error);\n   110→      return;\n   111→    }\n   112→\n   113→    setSavingName(true);\n   114→    try {\n   115→      await updateUsername(editedName || \"\");\n   116→      setIsEditingName(false);\n   117→      setNameError(null);\n   118→    } catch (err) {\n   119→      console.error(\"Failed to save username:\", err);\n   120→    } finally {\n   121→      setSavingName(false);\n   122→    }\n   123→  };\n   124→\n   125→  const handleKeyDown = (e: React.KeyboardEvent) => {\n   126→    if (e.key === \"Enter\") {\n   127→      handleSaveName();\n   128→    } else if (e.key === \"Escape\") {\n   129→      handleCancelEditing();\n   130→    }\n   131→  };\n   132→\n   133→  if (loading) {\n   134→    return (\n   135→      <div className=\"profile-page\">\n   136→        <div className=\"profile-page__loading\">Loading profile...</div>\n   137→      </div>\n   138→    );\n   139→  }\n   140→\n   141→  if (!myProfile) {\n   142→    return (\n   143→      <div className=\"profile-page\">\n   144→        <div className=\"profile-page__connect\">\n   145→          <h2>Connect Wallet</h2>\n   146→          <p>Connect your wallet to view your profile.</p>\n   147→        </div>\n   148→      </div>\n   149→    );\n   150→  }\n   151→\n   152→  const tabs: { id: ProfileTab; label: string }[] = [\n   153→    { id: \"stats\", label: \"Statistics\" },\n   154→    { id: \"transactions\", label: \"Transactions\" },\n   155→    { id: \"settings\", label: \"Settings\" },\n   156→  ];\n   157→\n   158→  return (\n   159→    <div className=\"profile-page\">\n   160→      {/* Avatar Selector Modal */}\n   161→      <AvatarSelectorModal\n   162→        profile={myProfile}\n   163→        isOpen={isAvatarModalOpen}\n   164→        onClose={() => setIsAvatarModalOpen(false)}\n   165→      />\n   166→\n   167→      {/* Header */}\n   168→      <div className=\"profile-page__header\">\n   169→        <div\n   170→          className=\"profile-page__avatar-section profile-page__avatar-section--clickable\"\n   171→          onClick={() => setIsAvatarModalOpen(true)}\n   172→          onKeyDown={(e) => e.key === \"Enter\" && setIsAvatarModalOpen(true)}\n   173→          role=\"button\"\n   174→          tabIndex={0}\n   175→          title=\"Click to change avatar\"\n   176→        >\n   177→          <PlayerAvatar\n   178→            address={myProfile.address}\n   179→            size=\"xl\"\n   180→            showLevel={true}\n   181→            enableMiniProfile={false}\n   182→          />\n   183→          <div className=\"profile-page__avatar-edit-hint\">\n   184→            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n   185→              <path d=\"M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z\"/>\n   186→            </svg>\n   187→          </div>\n   188→        </div>\n   189→\n   190→        <div className=\"profile-page__info\">\n   191→          <div className=\"profile-page__name-row\">\n   192→            {isEditingName ? (\n   193→              <div className=\"profile-page__name-edit\">\n   194→                <input\n   195→                  ref={inputRef}\n   196→                  type=\"text\"\n   197→                  className={`profile-page__name-input ${nameError ? \"profile-page__name-input--error\" : \"\"}`}\n   198→                  value={editedName}\n   199→                  onChange={(e) => {\n   200→                    setEditedName(e.target.value);\n   201→                    setNameError(validateUsername(e.target.value));\n   202→                  }}\n   203→                  onKeyDown={handleKeyDown}\n   204→                  placeholder=\"Enter username\"\n   205→                  maxLength={MAX_USERNAME_LENGTH}\n   206→                  disabled={savingName}\n   207→                />\n   208→                <button\n   209→                  type=\"button\"\n   210→                  className=\"profile-page__name-btn profile-page__name-btn--save\"\n   211→                  onClick={handleSaveName}\n   212→                  disabled={savingName || !!nameError}\n   213→                  title=\"Save\"\n   214→                >\n   215→                  <CheckIcon />\n   216→                </button>\n   217→                <button\n   218→                  type=\"button\"\n   219→                  className=\"profile-page__name-btn profile-page__name-btn--cancel\"\n   220→                  onClick={handleCancelEditing}\n   221→                  disabled={savingName}\n   222→                  title=\"Cancel\"\n   223→                >\n   224→                  <CancelIcon />\n   225→                </button>\n   226→                {nameError && (\n   227→                  <span className=\"profile-page__name-error\">{nameError}</span>\n   228→                )}\n   229→              </div>\n   230→            ) : (\n   231→              <>\n   232→                <h1 className=\"profile-page__name\">\n   233→                  {myProfile.username ?? \"Anonymous Player\"}\n   234→                </h1>\n   235→                <button\n   236→                  type=\"button\"\n   237→                  className=\"profile-page__name-edit-btn\"\n   238→                  onClick={handleStartEditing}\n   239→                  title=\"Edit username\"\n   240→                >\n   241→                  <EditIcon />\n   242→                </button>\n   243→              </>\n   244→            )}\n   245→          </div>\n   246→          <div className=\"profile-page__level-section\">\n   247→            <LevelProgressBar totalXP={myProfile.totalXP} size=\"md\" />\n   248→\n   249→            {/* RNG Buff indicator - compact pill */}\n   250→            {hasRNGBuff && rngBuff && (\n   251→              <div className=\"profile-page__buff-indicator\" title=\"Heater grants chance for crate drops when wagering\">\n   252→                <div className=\"profile-page__buff-icon\">\n   253→                  <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n   254→                    <path\n   255→                      d=\"M12 2L14.4 8.2L21 9.2L16 14L17.6 21L12 17.8L6.4 21L8 14L3 9.2L9.6 8.2L12 2Z\"\n   256→                      fill=\"url(#profile-buff-gradient)\"\n   257→                      stroke=\"#f0b820\"\n   258→                      strokeWidth=\"1.5\"\n   259→                      strokeLinejoin=\"round\"\n   260→                    />\n   261→                    <defs>\n   262→                      <linearGradient id=\"profile-buff-gradient\" x1=\"12\" y1=\"2\" x2=\"12\" y2=\"21\" gradientUnits=\"userSpaceOnUse\">\n   263→                        <stop stopColor=\"#ffeb3b\" />\n   264→                        <stop offset=\"1\" stopColor=\"#ff9800\" />\n   265→                      </linearGradient>\n   266→                    </defs>\n   267→                  </svg>\n   268→                </div>\n   269→                <div className=\"profile-page__buff-info\">\n   270→                  <span className=\"profile-page__buff-label\">Heater</span>\n   271→                  <span className=\"profile-page__buff-timer\">\n   272→                    {Math.floor(buffTimeRemaining / 60000)}:{Math.floor((buffTimeRemaining % 60000) / 1000).toString().padStart(2, \"0\")}\n   273→                  </span>\n   274→                </div>\n   275→              </div>\n   276→            )}\n   277→          </div>\n   278→        </div>\n   279→      </div>\n   280→\n   281→      {/* Tabs */}\n   282→      <div className=\"profile-page__tabs\">\n   283→        {tabs.map((tab) => (\n   284→          <button\n   285→            key={tab.id}\n   286→            type=\"button\"\n   287→            className={`profile-page__tab ${activeTab === tab.id ? \"profile-page__tab--active\" : \"\"}`}\n   288→            onClick={() => setActiveTab(tab.id)}\n   289→          >\n   290→            {tab.label}\n   291→          </button>\n   292→        ))}\n   293→      </div>\n   294→\n   295→      {/* Content */}\n   296→      <div className=\"profile-page__content\">\n   297→        {activeTab === \"stats\" && <ProfileStats profile={myProfile} />}\n   298→        {activeTab === \"transactions\" && <ProfileTransactions address={myProfile.address} />}\n   299→        {activeTab === \"settings\" && <ProfileSettings profile={myProfile} />}\n   300→      </div>\n   301→    </div>\n   302→  );\n   303→}\n   304→"}]},"parent_tool_use_id":null,"session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"27e73fd2-ebe5-46c6-8184-6dc2ab305210","timestamp":"2026-03-19T19:03:16.694Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/components/ProfilePage.tsx","content":"/**\n * ProfilePage - Main profile page component\n *\n * Displays the full player profile with tabs:\n * - Statistics (player stats and game performance)\n * - Transactions (game history)\n * - Settings (username, avatar, socials)\n */\n\nimport { useState, useRef, useEffect } from \"react\";\nimport { usePlayerProfile } from \"../context/PlayerProfileContext\";\nimport { useBossRaid } from \"../../boss-raid\";\nimport { PlayerAvatar } from \"./PlayerAvatar\";\nimport { LevelProgressBar } from \"./LevelProgressBar\";\nimport { ProfileStats } from \"./ProfileStats\";\nimport { ProfileTransactions } from \"./ProfileTransactions\";\nimport { ProfileSettings } from \"./ProfileSettings\";\nimport { AvatarSelectorModal } from \"./AvatarSelectorModal\";\nimport { MAX_USERNAME_LENGTH, MIN_USERNAME_LENGTH, USERNAME_REGEX } from \"../types\";\n\ntype ProfileTab = \"stats\" | \"transactions\" | \"settings\";\n\n// Pencil edit icon\nconst EditIcon = () => (\n  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    <path d=\"M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z\"/>\n  </svg>\n);\n\n// Check/save icon\nconst CheckIcon = () => (\n  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z\"/>\n  </svg>\n);\n\n// Cancel icon\nconst CancelIcon = () => (\n  <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    <path d=\"M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z\"/>\n  </svg>\n);\n\nexport function ProfilePage() {\n  const { myProfile, loading, updateUsername } = usePlayerProfile();\n  const { hasRNGBuff, rngBuff } = useBossRaid();\n  const [activeTab, setActiveTab] = useState<ProfileTab>(\"stats\");\n  const [isEditingName, setIsEditingName] = useState(false);\n  const [editedName, setEditedName] = useState(\"\");\n  const [savingName, setSavingName] = useState(false);\n  const [nameError, setNameError] = useState<string | null>(null);\n  const [isAvatarModalOpen, setIsAvatarModalOpen] = useState(false);\n  const [buffTimeRemaining, setBuffTimeRemaining] = useState(0);\n  const inputRef = useRef<HTMLInputElement>(null);\n\n  // Update buff timer every second\n  useEffect(() => {\n    if (!hasRNGBuff || !rngBuff) {\n      setBuffTimeRemaining(0);\n      return;\n    }\n\n    const updateTimer = () => {\n      const remaining = Math.max(0, rngBuff.expiresAt - Date.now());\n      setBuffTimeRemaining(remaining);\n    };\n\n    updateTimer();\n    const interval = setInterval(updateTimer, 1000);\n    return () => clearInterval(interval);\n  }, [hasRNGBuff, rngBuff]);\n\n  useEffect(() => {\n    if (isEditingName && inputRef.current) {\n      inputRef.current.focus();\n      inputRef.current.select();\n    }\n  }, [isEditingName]);\n\n  const validateUsername = (value: string): string | null => {\n    if (value.length === 0) return null;\n    if (value.length < MIN_USERNAME_LENGTH) {\n      return `Min ${MIN_USERNAME_LENGTH} characters`;\n    }\n    if (value.length > MAX_USERNAME_LENGTH) {\n      return `Max ${MAX_USERNAME_LENGTH} characters`;\n    }\n    if (!USERNAME_REGEX.test(value)) {\n      return \"Letters, numbers, underscores only\";\n    }\n    return null;\n  };\n\n  const handleStartEditing = () => {\n    setEditedName(myProfile?.username ?? \"\");\n    setNameError(null);\n    setIsEditingName(true);\n  };\n\n  const handleCancelEditing = () => {\n    setIsEditingName(false);\n    setEditedName(\"\");\n    setNameError(null);\n  };\n\n  const handleSaveName = async () => {\n    const error = validateUsername(editedName);\n    if (error) {\n      setNameError(error);\n      return;\n    }\n\n    setSavingName(true);\n    try {\n      await updateUsername(editedName || \"\");\n      setIsEditingName(false);\n      setNameError(null);\n    } catch (err) {\n      console.error(\"Failed to save username:\", err);\n    } finally {\n      setSavingName(false);\n    }\n  };\n\n  const handleKeyDown = (e: React.KeyboardEvent) => {\n    if (e.key === \"Enter\") {\n      handleSaveName();\n    } else if (e.key === \"Escape\") {\n      handleCancelEditing();\n    }\n  };\n\n  if (loading) {\n    return (\n      <div className=\"profile-page\">\n        <div className=\"profile-page__loading\">Loading profile...</div>\n      </div>\n    );\n  }\n\n  if (!myProfile) {\n    return (\n      <div className=\"profile-page\">\n        <div className=\"profile-page__connect\">\n          <h2>Connect Wallet</h2>\n          <p>Connect your wallet to view your profile.</p>\n        </div>\n      </div>\n    );\n  }\n\n  const tabs: { id: ProfileTab; label: string }[] = [\n    { id: \"stats\", label: \"Statistics\" },\n    { id: \"transactions\", label: \"Transactions\" },\n    { id: \"settings\", label: \"Settings\" },\n  ];\n\n  return (\n    <div className=\"profile-page\">\n      {/* Avatar Selector Modal */}\n      <AvatarSelectorModal\n        profile={myProfile}\n        isOpen={isAvatarModalOpen}\n        onClose={() => setIsAvatarModalOpen(false)}\n      />\n\n      {/* Header */}\n      <div className=\"profile-page__header\">\n        <div\n          className=\"profile-page__avatar-section profile-page__avatar-section--clickable\"\n          onClick={() => setIsAvatarModalOpen(true)}\n          onKeyDown={(e) => e.key === \"Enter\" && setIsAvatarModalOpen(true)}\n          role=\"button\"\n          tabIndex={0}\n          title=\"Click to change avatar\"\n        >\n          <PlayerAvatar\n            address={myProfile.address}\n            size=\"xl\"\n            showLevel={true}\n            enableMiniProfile={false}\n          />\n          <div className=\"profile-page__avatar-edit-hint\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n              <path d=\"M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z\"/>\n            </svg>\n          </div>\n        </div>\n\n        <div className=\"profile-page__info\">\n          <div className=\"profile-page__name-row\">\n            {isEditingName ? (\n              <div className=\"profile-page__name-edit\">\n                <input\n                  ref={inputRef}\n                  type=\"text\"\n                  className={`profile-page__name-input ${nameError ? \"profile-page__name-input--error\" : \"\"}`}\n                  value={editedName}\n                  onChange={(e) => {\n                    setEditedName(e.target.value);\n                    setNameError(validateUsername(e.target.value));\n                  }}\n                  onKeyDown={handleKeyDown}\n                  placeholder=\"Enter username\"\n                  maxLength={MAX_USERNAME_LENGTH}\n                  disabled={savingName}\n                />\n                <button\n                  type=\"button\"\n                  className=\"profile-page__name-btn profile-page__name-btn--save\"\n                  onClick={handleSaveName}\n                  disabled={savingName || !!nameError}\n                  title=\"Save\"\n                >\n                  <CheckIcon />\n                </button>\n                <button\n                  type=\"button\"\n                  className=\"profile-page__name-btn profile-page__name-btn--cancel\"\n                  onClick={handleCancelEditing}\n                  disabled={savingName}\n                  title=\"Cancel\"\n                >\n                  <CancelIcon />\n                </button>\n                {nameError && (\n                  <span className=\"profile-page__name-error\">{nameError}</span>\n                )}\n              </div>\n            ) : (\n              <>\n                <h1 className=\"profile-page__name\">\n                  {myProfile.username ?? \"Anonymous Player\"}\n                </h1>\n                <button\n                  type=\"button\"\n                  className=\"profile-page__name-edit-btn\"\n                  onClick={handleStartEditing}\n                  title=\"Edit username\"\n                >\n                  <EditIcon />\n                </button>\n              </>\n            )}\n          </div>\n          <div className=\"profile-page__level-section\">\n            <LevelProgressBar totalXP={myProfile.totalXP} size=\"md\" />\n\n            {/* RNG Buff indicator - compact pill */}\n            {hasRNGBuff && rngBuff && (\n              <div className=\"profile-page__buff-indicator\" title=\"Heater grants chance for crate drops when wagering\">\n                <div className=\"profile-page__buff-icon\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path\n                      d=\"M12 2L14.4 8.2L21 9.2L16 14L17.6 21L12 17.8L6.4 21L8 14L3 9.2L9.6 8.2L12 2Z\"\n                      fill=\"url(#profile-buff-gradient)\"\n                      stroke=\"#f0b820\"\n                      strokeWidth=\"1.5\"\n                      strokeLinejoin=\"round\"\n                    />\n                    <defs>\n                      <linearGradient id=\"profile-buff-gradient\" x1=\"12\" y1=\"2\" x2=\"12\" y2=\"21\" gradientUnits=\"userSpaceOnUse\">\n                        <stop stopColor=\"#ffeb3b\" />\n                        <stop offset=\"1\" stopColor=\"#ff9800\" />\n                      </linearGradient>\n                    </defs>\n                  </svg>\n                </div>\n                <div className=\"profile-page__buff-info\">\n                  <span className=\"profile-page__buff-label\">Heater</span>\n                  <span className=\"profile-page__buff-timer\">\n                    {Math.floor(buffTimeRemaining / 60000)}:{Math.floor((buffTimeRemaining % 60000) / 1000).toString().padStart(2, \"0\")}\n                  </span>\n                </div>\n              </div>\n            )}\n          </div>\n        </div>\n      </div>\n\n      {/* Tabs */}\n      <div className=\"profile-page__tabs\">\n        {tabs.map((tab) => (\n          <button\n            key={tab.id}\n            type=\"button\"\n            className={`profile-page__tab ${activeTab === tab.id ? \"profile-page__tab--active\" : \"\"}`}\n            onClick={() => setActiveTab(tab.id)}\n          >\n            {tab.label}\n          </button>\n        ))}\n      </div>\n\n      {/* Content */}\n      <div className=\"profile-page__content\">\n        {activeTab === \"stats\" && <ProfileStats profile={myProfile} />}\n        {activeTab === \"transactions\" && <ProfileTransactions address={myProfile.address} />}\n        {activeTab === \"settings\" && <ProfileSettings profile={myProfile} />}\n      </div>\n    </div>\n  );\n}\n","numLines":304,"startLine":1,"totalLines":304}}}
