{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NVecQg8bXqdAM4oBMGr6xV","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey } from \"@solana/web3.js\";\n    11→import type { UIMatch, CoinSide } from \"../types\";\n    12→import {\n    13→  fetchAllOpenMatches,\n    14→  fetchClaimableMatches,\n    15→  fetchMatch,\n    16→  fetchRecentSettledMatches,\n    17→  buildJoinMatchTx,\n    18→  buildCancelMatchTx,\n    19→  buildTimeoutRefundTx,\n    20→  buildBackendCreateMatchTx,\n    21→  fetchRoundVerification,\n    22→  applyBackendRoundToMatch,\n    23→  fetchMatchByMatchId,\n    24→  BackendRequestError,\n    25→} from \"../utils/chain\";\n    26→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    27→import { useSession } from \"../../../context/SessionContext\";\n    28→import { getAccessToken } from \"../../../lib/auth-store\";\n    29→import { useSettlementEvent } from \"../../../lib/useSettlementEvent\";\n    30→import { useSendAndConfirm } from \"../../../lib/useSendAndConfirm\";\n    31→import { createTransactionErrorParser } from \"../../../lib/parse-transaction-error\";\n    32→\n    33→// ---------------------------------------------------------------------------\n    34→// Lifecycle logger — helps trace phase transitions and settlement timing.\n    35→// All logs use a shared tag so they can be filtered in devtools:\n    36→//   console filter: [coinflip]\n    37→// ---------------------------------------------------------------------------\n    38→function logLife(event: string, data?: Record<string, unknown>) {\n    39→  const ts = new Date().toISOString().slice(11, 23); // HH:mm:ss.SSS\n    40→  const extra = data ? \" \" + JSON.stringify(data) : \"\";\n    41→  // eslint-disable-next-line no-console\n    42→  console.log(`[coinflip] ${ts} ${event}${extra}`);\n    43→}\n    44→\n    45→/** Parse Solana/wallet errors into user-friendly messages */\n    46→const parseTransactionError = createTransactionErrorParser({\n    47→  logLabel: \"coinflip\",\n    48→  gameChecks: [\n    49→    // Account already in use (match already exists)\n    50→    (msg) =>\n    51→      msg.includes(\"already in use\")\n    52→        ? \"You already have an active match. Cancel it before creating a new one.\"\n    53→        : null,\n    54→    // Anchor program errors\n    55→    (msg) =>\n    56→      msg.includes(\"InvalidPhase\")\n    57→        ? \"This match is no longer available.\"\n    58→        : null,\n    59→    (msg) =>\n    60→      msg.includes(\"CannotJoinOwnMatch\")\n    61→        ? \"You cannot join your own match.\"\n    62→        : null,\n    63→    (msg) =>\n    64→      msg.includes(\"MatchAlreadyLocked\")\n    65→        ? \"This match is already locked.\"\n    66→        : null,\n    67→    (msg) =>\n    68→      msg.includes(\"AlreadyJoined\")\n    69→        ? \"You have already joined this match.\"\n    70→        : null,\n    71→    (msg) =>\n    72→      msg.includes(\"NotInWaitingPhase\")\n    73→        ? \"This match is no longer in the waiting phase.\"\n    74→        : null,\n    75→  ],\n    76→});\n    77→\n    78→interface CoinflipContextValue {\n    79→  // State\n    80→  activeMatch: UIMatch | null;\n    81→  openMatches: UIMatch[];\n    82→  claimableMatches: UIMatch[];\n    83→  userHistory: UIMatch[];\n    84→  wagerAmount: number | null;\n    85→  selectedSide: CoinSide | null;\n    86→\n    87→  // Loading states\n    88→  loading: boolean;\n    89→  creating: boolean;\n    90→  joining: boolean;\n    91→  joiningMatchId: string | null;\n    92→\n    93→  // Error state\n    94→  error: string | null;\n    95→  clearError: () => void;\n    96→\n    97→  // Verification\n    98→  lastSettleSignature: string | null;\n    99→\n   100→  // Actions"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"2e9e935c-0935-4b58-b7e8-d1bea60759e6","timestamp":"2026-03-19T19:01:36.605Z"}
