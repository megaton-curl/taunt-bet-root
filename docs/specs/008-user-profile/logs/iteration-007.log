{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EZUMtU42YWroJhrp3vsc5D","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/index.css has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"1fd22837-d76c-4a7d-924c-695c1f619ab5","timestamp":"2026-03-19T19:06:35.663Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/index.css","oldString":".profile-transactions__outcome--win {\n  color: var(--color-neon-green);\n}\n\n.profile-transactions__outcome--loss {\n  color: var(--color-neon-pink);\n}\n\n.profile-transactions__net--positive {\n  color: var(--color-neon-green);\n}\n\n.profile-transactions__net--negative {\n  color: var(--color-neon-pink);\n}","newString":".profile-transactions__event {\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.profile-transactions__event--win {\n  color: var(--color-neon-green);\n}\n\n.profile-transactions__event--loss {\n  color: var(--color-neon-pink);\n}\n\n.profile-transactions__event--join {\n  color: var(--color-text-muted);\n}\n\n.profile-transactions__event--refund {\n  color: var(--color-neon-blue, #4a9eff);\n}\n\n.profile-transactions__match-link {\n  color: var(--color-text);\n  text-decoration: none;\n}\n\n.profile-transactions__match-link:hover {\n  color: var(--color-neon-green);\n  text-decoration: underline;\n}\n\n.profile-transactions__skeleton {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  padding: 16px 0;\n}\n\n.profile-transactions__skeleton-row {\n  height: 40px;\n  border-radius: 6px;\n  background: linear-gradient(90deg, var(--color-border) 25%, transparent 50%, var(--color-border) 75%);\n  background-size: 200% 100%;\n  animation: skeleton-shimmer 1.5s infinite;\n}\n\n@keyframes skeleton-shimmer {\n  0% { background-position: 200% 0; }\n  100% { background-position: -200% 0; }\n}\n\n.profile-transactions__load-more {\n  display: flex;\n  justify-content: center;\n  padding: 16px 0;\n}\n\n.profile-transactions__load-more-btn {\n  padding: 8px 24px;\n  border-radius: 6px;\n  border: 1px solid var(--color-border);\n  background: transparent;\n  color: var(--color-text);\n  cursor: pointer;\n  font-size: 0.875rem;\n  transition: border-color 0.2s, color 0.2s;\n}\n\n.profile-transactions__load-more-btn:hover:not(:disabled) {\n  border-color: var(--color-neon-green);\n  color: var(--color-neon-green);\n}\n\n.profile-transactions__load-more-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}","originalFile":"/* ============================================\n   TAUNT - The Pit\n   Dark Cyber PVP Theme\n   ============================================ */\n\n/* Import Fonts */\n@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Barlow+Condensed:wght@300;400;600;700;900&family=JetBrains+Mono:wght@400;500&display=swap');\n\n/* ============ CSS Custom Properties ============ */\n:root {\n  /* Template palette */\n  --color-pink: #FF1F8E;\n  --color-red: #FF2D55;\n  --color-yellow: #FFB800;\n  --color-green: #00E676;\n  --color-blue: #3D7FFF;\n  --color-black: #04040A;\n  --color-surface: #0B0B16;\n  --color-card: #0E0E1A;\n  --color-border: rgba(255,255,255,0.055);\n  --color-border2: rgba(255,255,255,0.1);\n  --color-white: #EDE9E4;\n  --color-muted: #2E2E48;\n  --color-muted2: #5C5C7A;\n\n  /* Layout dimensions */\n  --nav-w: 240px;\n  --nav-col: 64px;\n  --hdr-h: 54px;\n  --tick-h: 32px;\n  --top-h: 86px;\n\n  /* Backward-compatible aliases */\n  --color-bg: var(--color-black);\n  --color-bg-darker: #020208;\n  --color-surface-elevated: var(--color-card);\n  --color-primary: var(--color-pink);\n  --color-primary-glow: rgba(255, 31, 142, 0.35);\n  --color-secondary: var(--color-green);\n  --color-secondary-glow: rgba(0, 230, 118, 0.3);\n\n  /* Neon aliases */\n  --color-neon-pink: var(--color-pink);\n  --color-neon-red: var(--color-red);\n  --color-neon-magenta: var(--color-pink);\n  --color-neon-cyan: var(--color-green);\n  --color-neon-yellow: var(--color-yellow);\n  --color-neon-green: var(--color-green);\n  --color-neon-orange: #ff6b35;\n  --color-neon-blue: var(--color-blue);\n  --color-neon-purple: var(--color-pink);\n  --color-neon-gold: var(--color-yellow);\n\n  /* Game status colors */\n  --color-success: var(--color-green);\n  --color-success-glow: rgba(0, 230, 118, 0.3);\n  --color-error: var(--color-red);\n  --color-error-glow: rgba(255, 45, 85, 0.3);\n  --color-warning: var(--color-yellow);\n  --color-warning-glow: rgba(255, 184, 0, 0.3);\n\n  /* Pool colors */\n  --color-pool-green: var(--color-green);\n  --color-pool-red: var(--color-red);\n\n  /* Text colors */\n  --color-text: var(--color-white);\n  --color-text-dim: #b0b0b0;\n  --color-text-muted: var(--color-muted2);\n\n  /* Borders */\n  --pixel-size: 1px;\n  --border-pixel: var(--pixel-size) solid;\n\n  /* Glow effects */\n  --glow-sm: 0 0 3px;\n  --glow-md: 0 0 6px;\n  --glow-lg: 0 0 10px;\n  --glow-xl: 0 0 16px;\n  --title-glow: none;\n\n  /* Fonts */\n  --font-heading: 'Bebas Neue', sans-serif;\n  --font-body: 'DM Mono', monospace;\n  --font-condensed: 'Barlow Condensed', sans-serif;\n  --font-pixel: 'DM Mono', monospace;\n  --font-mono: 'JetBrains Mono', monospace;\n\n  /* Scanline - disabled */\n  --scanline-color: transparent;\n\n  /* Grid colors */\n  --grid-color: rgba(255, 255, 255, 0.05);\n  --grid-color-bright: rgba(255, 255, 255, 0.1);\n}\n\n/* Selection */\n::selection { background: var(--color-pink); color: #000; }\n::-webkit-scrollbar { width: 2px; }\n::-webkit-scrollbar-track { background: var(--color-black); }\n::-webkit-scrollbar-thumb { background: var(--color-muted2); }\n\n/* ============ Reset & Base ============ */\n*, *::before, *::after {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nhtml {\n  font-size: 16px;\n  height: 100%;\n}\n\nbody {\n  font-family: var(--font-body);\n  background: var(--color-black);\n  color: var(--color-white);\n  line-height: 1.6;\n  min-height: 100vh;\n  overflow-x: hidden;\n}\n\n/* App shell */\n.app {\n  min-height: 100vh;\n  position: relative;\n  background: var(--color-black);\n}\n\n/* ============ Background Effects ============ */\n.bg-stage { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }\n.bg-grid {\n  position: absolute; inset: 0;\n  background-image: radial-gradient(circle, rgba(255,255,255,0.055) 1px, transparent 1px);\n  background-size: 36px 36px;\n  animation: gridDrift 70s linear infinite;\n}\n@keyframes gridDrift { 0% { background-position: 0 0; } 100% { background-position: 72px 72px; } }\n.bg-scan {\n  position: absolute; inset: 0;\n  background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.055) 3px, rgba(0,0,0,0.055) 4px);\n}\n.bg-orb { position: absolute; border-radius: 50%; filter: blur(110px); pointer-events: none; }\n.orb-1 { width: 700px; height: 700px; background: radial-gradient(circle, rgba(255,31,142,0.085) 0%, transparent 70%); top: -12%; left: -8%; animation: oA 28s ease-in-out infinite alternate; }\n.orb-2 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(61,127,255,0.07) 0%, transparent 70%); bottom: -8%; right: -2%; animation: oB 22s ease-in-out infinite alternate; }\n.orb-3 { width: 380px; height: 380px; background: radial-gradient(circle, rgba(255,184,0,0.045) 0%, transparent 70%); top: 48%; left: 35%; animation: oC 35s ease-in-out infinite alternate; }\n.orb-4 { width: 280px; height: 280px; background: radial-gradient(circle, rgba(0,230,118,0.038) 0%, transparent 70%); top: 8%; right: 22%; animation: oD 18s ease-in-out infinite alternate; }\n@keyframes oA { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(55px,-45px) scale(1.1); } }\n@keyframes oB { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(-35px,40px) scale(1.08); } }\n@keyframes oC { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(-55px,-25px) scale(1.14); } }\n@keyframes oD { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(25px,55px) scale(0.9); } }\n\n/* Particles */\n.particle { position: absolute; border-radius: 50%; opacity: 0; animation: pFloat linear infinite; }\n@keyframes pFloat {\n  0% { transform: translateY(0) translateX(0); opacity: 0; }\n  8% { opacity: 0.7; }\n  88% { opacity: 0.15; }\n  100% { transform: translateY(-130px) translateX(var(--pd)); opacity: 0; }\n}\n\n/* Beams */\n.beam {\n  position: absolute; left: 0; right: 0; height: 1px;\n  background: linear-gradient(90deg, transparent 0%, rgba(255,31,142,0.12) 25%, rgba(255,31,142,0.28) 50%, rgba(255,31,142,0.12) 75%, transparent 100%);\n  opacity: 0; animation: bSweep linear infinite;\n}\n@keyframes bSweep {\n  0% { opacity: 0; transform: translateY(0); }\n  6% { opacity: 1; }\n  94% { opacity: 0.4; }\n  100% { opacity: 0; transform: translateY(180px); }\n}\n\n/* ============ Top Bar (fixed) ============ */\n.top-bar { position: fixed; top: 0; left: 0; right: 0; z-index: 200; }\n\n/* ============ Main Content ============ */\n.main {\n  margin-left: var(--nav-w);\n  margin-top: var(--top-h);\n  min-height: calc(100vh - var(--top-h));\n  transition: margin-left 0.3s cubic-bezier(0.4,0,0.2,1);\n  position: relative;\n  z-index: 10;\n  padding: 0;\n}\nbody.nc .main { margin-left: var(--nav-col); }\n\n/* ============ Typography ============ */\nh1, h2, h3, h4, h5, h6 {\n  font-family: var(--font-heading);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\nh1 {\n  font-size: 1.5rem;\n}\n\nh2 {\n  font-size: 1.125rem;\n}\n\nh3 {\n  font-size: 0.875rem;\n}\n\np {\n  font-size: 1rem;\n}\n\na {\n  color: var(--color-neon-cyan);\n  text-decoration: none;\n  transition: all 0.2s;\n}\n\na:hover {\n  color: var(--color-neon-pink);\n  text-shadow: none;\n}\n\n/* ============ App Layout ============ */\n.app-content {\n  display: flex;\n  flex: 1;\n}\n\n/* ============ Header (Top Bar) ============ */\n.header {\n  height: var(--hdr-h);\n  background: rgba(4,4,10,0.97);\n  backdrop-filter: blur(24px);\n  border-bottom: 1px solid var(--color-border);\n  display: flex;\n  align-items: center;\n  position: relative;\n  z-index: 100;\n}\n\n.hdr-logo-z {\n  width: var(--nav-w);\n  height: 100%;\n  display: flex;\n  align-items: center;\n  padding: 0 24px;\n  border-right: 1px solid var(--color-border);\n  flex-shrink: 0;\n  transition: width 0.3s cubic-bezier(0.4,0,0.2,1);\n  overflow: hidden;\n}\nbody.nc .hdr-logo-z { width: var(--nav-col); }\n\n.header-logo {\n  text-decoration: none;\n  flex-shrink: 0;\n}\n\n.header-logo h1,\n.header h1,\n.logo {\n  font-family: var(--font-heading);\n  font-size: 36px;\n  font-weight: 400;\n  letter-spacing: 0.15em;\n  color: var(--color-white);\n  white-space: nowrap;\n  user-select: none;\n  background: none;\n  -webkit-background-clip: unset;\n  -webkit-text-fill-color: unset;\n  background-clip: unset;\n  filter: none;\n  animation: none;\n}\n.logo em, .header-logo em { color: var(--color-pink); font-style: normal; }\n.logo-sx { transition: opacity 0.22s, max-width 0.3s; max-width: 80px; display: inline-block; overflow: hidden; vertical-align: baseline; }\nbody.nc .logo-sx { opacity: 0; max-width: 0; }\n\n.header-logo:hover h1 {\n  color: var(--color-white);\n  filter: none;\n  transform: none;\n}\n\n.hdr-mid {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  gap: 2px;\n  padding: 0 20px;\n}\n\n.hstat {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 7px 18px;\n  border: 1px solid var(--color-border);\n  background: rgba(255,255,255,0.018);\n}\n.hstat-n {\n  font-family: var(--font-heading);\n  font-size: 22px;\n  letter-spacing: 0.04em;\n  line-height: 1;\n}\n.hstat-l {\n  font-size: 8px;\n  color: var(--color-muted2);\n  letter-spacing: 0.18em;\n  text-transform: uppercase;\n}\n\n.hdr-right {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding-right: 24px;\n  margin-left: auto;\n}\n\n.bal-tag {\n  font-size: 11px;\n  letter-spacing: 0.08em;\n  color: var(--color-yellow);\n  border: 1px solid rgba(255,184,0,0.2);\n  padding: 5px 14px;\n}\n\n.header-top {\n  display: flex;\n  align-items: center;\n  width: 100%;\n  height: 100%;\n}\n\n/* Header Nav Strip */\n.header-nav {\n  display: flex;\n  gap: 0;\n  align-items: center;\n  padding: 0 2rem;\n  background: var(--color-surface);\n  border-top: 1px solid var(--color-border);\n}\n\n.header-nav a {\n  font-family: var(--font-heading);\n  font-size: 1.125rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  letter-spacing: 2px;\n  padding: 0.75rem 1.25rem;\n  border-bottom: 3px solid transparent;\n  transition: all 0.15s ease;\n  position: relative;\n  text-decoration: none;\n}\n\n.header-nav a:hover {\n  color: var(--color-text);\n  border-bottom-color: var(--color-primary);\n  background: rgba(255, 255, 255, 0.03);\n}\n\n.header-nav a.active {\n  color: var(--color-primary);\n  border-bottom-color: var(--color-primary);\n}\n\n/* Header Center - RNG Drop */\n.header-blessing {\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n  flex-shrink: 0;\n  padding: 0.5rem 1rem;\n  background: rgba(17, 17, 17, 0.8);\n  border: 1px solid rgba(255, 0, 84, 0.4);\n  border-radius: 2px;\n  position: relative;\n  transition: all 0.3s ease;\n}\n\n.header-blessing:hover {\n  border-color: rgba(255, 0, 84, 0.7);\n  box-shadow: none;\n}\n\n.rng-drop-content {\n  display: flex;\n  flex-direction: column;\n  gap: 0.125rem;\n}\n\n.blessing-label {\n  font-size: 1rem;\n  color: rgba(255, 0, 84, 0.9);\n  text-transform: uppercase;\n  white-space: nowrap;\n  letter-spacing: 2px;\n  text-shadow: 0 0 8px rgba(255, 0, 84, 0.5);\n}\n\n.blessing-timer {\n  background: transparent;\n  border: none;\n  padding: 0;\n  min-width: auto;\n  text-align: left;\n}\n\n.blessing-timer span {\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  font-family: var(--font-mono);\n  letter-spacing: 3px;\n  text-shadow: 0 0 10px rgba(0, 255, 136, 0.8);\n}\n\n.rng-drop-amount {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.rng-drop-amount .solana-logo {\n  filter: none;\n}\n\n.blessing-amount {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  white-space: nowrap;\n  font-family: var(--font-mono);\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n/* ============================================\n   BOSS RAID STYLES\n   ============================================ */\n\n/* Header Dogpile Raid - Compact header display */\n.header-boss-raid {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.4rem 0.6rem;\n  background: rgba(20, 20, 20, 0.9);\n  border: 1px solid rgba(255, 0, 84, 0.5);\n  border-radius: 2px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  position: relative;\n  overflow: hidden;\n}\n\n.header-boss-raid::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: linear-gradient(135deg, rgba(255, 0, 84, 0.1), transparent);\n  pointer-events: none;\n}\n\n.header-boss-raid:hover {\n  border-color: rgba(255, 0, 84, 0.8);\n  box-shadow: 0 0 15px rgba(255, 0, 84, 0.3);\n  transform: translateY(-1px);\n}\n\n.header-boss-raid--active {\n  animation: raid-active-pulse 2s ease-in-out infinite;\n}\n\n.header-boss-raid--defeated {\n  border-color: rgba(0, 255, 136, 0.7);\n  background: rgba(0, 255, 136, 0.1);\n}\n\n.header-boss-raid--escaped {\n  border-color: rgba(255, 215, 0, 0.7);\n  background: rgba(255, 215, 0, 0.1);\n}\n\n.header-boss-raid--loading,\n.header-boss-raid--intermission {\n  opacity: 0.8;\n}\n\n@keyframes raid-active-pulse {\n  0%, 100% { box-shadow: 0 0 8px rgba(255, 0, 84, 0.2); }\n  50% { box-shadow: 0 0 15px rgba(255, 0, 84, 0.4); }\n}\n\n/* Dogpile Status - timer display */\n.header-boss-raid__status {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.15rem;\n  min-width: 70px;\n}\n\n/* Divider between sections */\n.header-boss-raid__divider {\n  width: 1px;\n  height: 24px;\n  background: rgba(255, 0, 84, 0.4);\n  flex-shrink: 0;\n}\n\n.header-boss-raid__timer-value {\n  font-size: 0.65rem;\n  font-family: var(--font-mono);\n  color: var(--color-neon-cyan);\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n  letter-spacing: 0.5px;\n  white-space: nowrap;\n}\n\n/* Prize pool section */\n.header-boss-raid__pool {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  min-width: 56px;\n}\n\n.header-boss-raid__pool-amount {\n  font-size: 0.8rem;\n  font-weight: 600;\n  font-family: var(--font-mono);\n  color: var(--color-neon-green);\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n.header-boss-raid__intermission {\n  display: flex;\n  flex-direction: column;\n  gap: 0.125rem;\n}\n\n.header-boss-raid__intermission-text {\n  font-size: 1rem;\n  color: rgba(255, 0, 84, 0.8);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.header-boss-raid__intermission-timer {\n  font-size: 1rem;\n  font-family: var(--font-mono);\n  color: var(--color-text-dim);\n}\n\n.header-boss-raid__result {\n  display: flex;\n  flex-direction: column;\n  gap: 0.125rem;\n}\n\n.header-boss-raid__result-text {\n  font-size: 0.875rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.header-boss-raid--defeated .header-boss-raid__result-text {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 10px rgba(0, 255, 136, 0.6);\n}\n\n.header-boss-raid--escaped .header-boss-raid__result-text {\n  color: var(--color-neon-yellow);\n  text-shadow: 0 0 10px rgba(255, 215, 0, 0.6);\n}\n\n.header-boss-raid__result-pool {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  font-size: 1rem;\n  font-family: var(--font-mono);\n  color: var(--color-neon-green);\n}\n\n.header-boss-raid__loading-text {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n}\n\n/* Dogpile Icon styling */\n.header-boss-raid__icon {\n  flex-shrink: 0;\n  color: var(--color-pink);\n  transition: color 0.3s ease;\n}\n\n.header-boss-raid__icon--active {\n  color: var(--color-pink);\n  filter: drop-shadow(0 0 6px rgba(255, 31, 142, 0.6));\n  animation: dogpile-icon-pulse 2s ease-in-out infinite;\n}\n\n.header-boss-raid__icon--dropped {\n  color: var(--color-green);\n  filter: drop-shadow(0 0 6px rgba(0, 230, 118, 0.6));\n}\n\n.header-boss-raid__icon--slipped {\n  color: var(--color-muted2);\n  opacity: 0.6;\n}\n\n.header-boss-raid__icon--muted {\n  color: var(--color-muted2);\n  opacity: 0.5;\n}\n\n@keyframes dogpile-icon-pulse {\n  0%, 100% { filter: drop-shadow(0 0 4px rgba(255, 31, 142, 0.4)); }\n  50% { filter: drop-shadow(0 0 10px rgba(255, 31, 142, 0.8)); }\n}\n\n/* Header Center - Groups Dogpile + Heater */\n.header-center {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n}\n\n/* Heater Indicator */\n.rng-buff-indicator {\n  display: flex;\n  align-items: center;\n  gap: 0.35rem;\n  padding: 0.3rem 0.5rem;\n  background: rgba(255, 215, 0, 0.1);\n  border: 1px solid rgba(255, 215, 0, 0.5);\n  border-radius: 2px;\n  cursor: help;\n  position: relative;\n}\n\n.rng-buff-indicator__icon {\n  position: relative;\n  width: 20px;\n  height: 20px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.rng-buff-indicator__icon svg {\n  animation: buff-star-pulse 1.5s ease-in-out infinite;\n}\n\n@keyframes buff-star-pulse {\n  0%, 100% { transform: scale(1); filter: none; }\n  50% { transform: scale(1.1); filter: none; }\n}\n\n.rng-buff-indicator__pulse {\n  position: absolute;\n  inset: -4px;\n  border-radius: 50%;\n  background: rgba(255, 215, 0, 0.3);\n  animation: buff-ring-pulse 2s ease-out infinite;\n}\n\n@keyframes buff-ring-pulse {\n  0% { transform: scale(0.8); opacity: 0.8; }\n  100% { transform: scale(1.8); opacity: 0; }\n}\n\n.rng-buff-indicator__timer {\n  font-size: 0.65rem;\n  font-family: var(--font-mono);\n  color: #ffd700;\n  text-shadow: 0 0 6px rgba(255, 215, 0, 0.6);\n  letter-spacing: 0.5px;\n}\n\n/* Buff text variant on defeated result */\n.header-boss-raid__result-text--buff {\n  color: #00ff88 !important;\n  font-size: 0.8rem !important;\n}\n\n.header-boss-raid__result-text--escaped {\n  color: #ff6644 !important;\n}\n\n.header-boss-raid__result-pool--faded {\n  opacity: 0.5;\n  color: var(--color-text-dim) !important;\n}\n\n/* Next spawn countdown (shown after defeat/escape) */\n.header-boss-raid__next-spawn {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.1rem;\n  padding-left: 0.5rem;\n  margin-left: 0.5rem;\n  border-left: 1px solid rgba(255, 0, 84, 0.3);\n}\n\n.header-boss-raid__next-spawn-label {\n  font-size: 0.45rem;\n  color: rgba(255, 0, 84, 0.7);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.header-boss-raid__next-spawn-timer {\n  font-size: 0.65rem;\n  font-family: var(--font-mono);\n  color: var(--color-neon-cyan);\n  text-shadow: 0 0 6px rgba(0, 255, 136, 0.5);\n}\n\n/* Dogpile Raid Modal */\n.boss-raid-modal-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(0, 0, 0, 0.85);\n  display: flex;\n  align-items: flex-start;\n  justify-content: center;\n  z-index: 1000;\n  opacity: 0;\n  transition: opacity 0.2s ease;\n  padding: 1rem;\n  overflow-y: auto;\n}\n\n.boss-raid-modal-overlay--visible {\n  opacity: 1;\n}\n\n.boss-raid-modal {\n  background: var(--color-surface);\n  border: 1px solid var(--color-primary);\n  border-radius: 3px;\n  max-width: 600px;\n  width: 100%;\n  margin: auto;\n  position: relative;\n  box-shadow: 0 0 40px rgba(255, 0, 84, 0.3);\n  animation: modal-slide-up 0.3s ease;\n}\n\n@keyframes modal-slide-up {\n  from {\n    opacity: 0;\n    transform: translateY(20px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.boss-raid-modal__close {\n  position: absolute;\n  top: 0.75rem;\n  right: 0.75rem;\n  width: 32px;\n  height: 32px;\n  border: none;\n  background: rgba(255, 255, 255, 0.1);\n  color: var(--color-text);\n  font-size: 1.5rem;\n  line-height: 1;\n  border-radius: 50%;\n  cursor: pointer;\n  transition: all 0.2s;\n  z-index: 10;\n}\n\n.boss-raid-modal__close:hover {\n  background: rgba(255, 0, 84, 0.3);\n  color: var(--color-neon-pink);\n}\n\n/* Modal Dogpile Icon */\n.boss-raid-modal__icon {\n  color: var(--color-pink);\n  filter: drop-shadow(0 0 12px rgba(255, 31, 142, 0.5));\n}\n\n.boss-raid-modal__header--defeated .boss-raid-modal__icon {\n  color: var(--color-green);\n  filter: drop-shadow(0 0 12px rgba(0, 230, 118, 0.5));\n}\n\n.boss-raid-modal__header--escaped .boss-raid-modal__icon {\n  color: var(--color-muted2);\n  filter: none;\n}\n\n/* Modal Header */\n.boss-raid-modal__header {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.75rem;\n  padding: 1.5rem;\n  border-bottom: 1px solid rgba(255, 0, 84, 0.3);\n  background: linear-gradient(180deg, rgba(255, 0, 84, 0.1) 0%, transparent 100%);\n}\n\n.boss-raid-modal__header--defeated {\n  background: linear-gradient(180deg, rgba(0, 255, 136, 0.1) 0%, transparent 100%);\n  border-color: rgba(0, 255, 136, 0.3);\n}\n\n.boss-raid-modal__header--escaped {\n  background: linear-gradient(180deg, rgba(255, 215, 0, 0.1) 0%, transparent 100%);\n  border-color: rgba(255, 215, 0, 0.3);\n}\n\n.boss-raid-modal__title {\n  font-size: 1rem;\n  font-weight: 700;\n  color: var(--color-neon-purple);\n  text-shadow: 0 0 15px rgba(255, 0, 84, 0.6);\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  margin: 0;\n  text-align: center;\n  width: 100%;\n}\n\n.boss-raid-modal__timer {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.boss-raid-modal__timer-label {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.boss-raid-modal__timer-value {\n  font-size: 1.5rem;\n  font-family: var(--font-mono);\n  color: var(--color-neon-cyan);\n  text-shadow: 0 0 10px rgba(0, 255, 136, 0.6);\n  letter-spacing: 2px;\n}\n\n.boss-raid-modal__result {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.boss-raid-modal__result-text {\n  font-size: 1.25rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 2px;\n}\n\n.boss-raid-modal__result--defeated .boss-raid-modal__result-text {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 15px rgba(0, 255, 136, 0.6);\n}\n\n.boss-raid-modal__result--escaped .boss-raid-modal__result-text {\n  color: var(--color-neon-yellow);\n  text-shadow: 0 0 15px rgba(255, 215, 0, 0.6);\n}\n\n.boss-raid-modal__result-carryover {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n/* Modal Stats Grid */\n.boss-raid-modal__stats {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 1rem;\n  padding: 1rem 1.5rem;\n  border-bottom: 1px solid rgba(255, 0, 84, 0.2);\n}\n\n.boss-raid-modal__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.boss-raid-modal__stat-label {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.boss-raid-modal__stat-value {\n  font-size: 1rem;\n  font-family: var(--font-mono);\n  color: var(--color-text);\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.boss-raid-modal__stat--pool .boss-raid-modal__stat-value {\n  color: var(--color-neon-green);\n}\n\n/* User Stats Section */\n.boss-raid-modal__user-stats {\n  padding: 1rem 1.5rem;\n  background: rgba(255, 0, 84, 0.05);\n  border-bottom: 1px solid rgba(255, 0, 84, 0.2);\n}\n\n.boss-raid-modal__section-title {\n  font-size: 1rem;\n  color: var(--color-neon-purple);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin: 0 0 0.75rem 0;\n}\n\n.boss-raid-modal__user-stats-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 0.75rem;\n}\n\n.boss-raid-modal__user-stat {\n  display: flex;\n  flex-direction: column;\n  gap: 0.125rem;\n}\n\n.boss-raid-modal__user-stat-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.boss-raid-modal__user-stat-value {\n  font-size: 0.875rem;\n  font-family: var(--font-mono);\n  color: var(--color-text);\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.boss-raid-modal__user-stat--payout .boss-raid-modal__user-stat-value {\n  color: var(--color-neon-green);\n}\n\n/* Dogpile Raid Claim Button */\n.boss-raid-modal__claim-btn {\n  margin-top: 1rem;\n  padding: 0.75rem 1.5rem;\n  width: 100%;\n  font-family: var(--font-pixel);\n  font-size: 0.8rem;\n  text-transform: uppercase;\n  background: linear-gradient(135deg, var(--color-neon-green) 0%, #39cc14 100%);\n  border: none;\n  border-radius: 2px;\n  color: #000;\n  cursor: pointer;\n  transition: all 0.2s;\n  font-weight: 700;\n  letter-spacing: 1px;\n}\n\n.boss-raid-modal__claim-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: scale(1.02);\n}\n\n.boss-raid-modal__claim-btn:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n\n.boss-raid-modal__claimed-text {\n  margin-top: 0.75rem;\n  font-size: 0.8rem;\n  color: var(--color-neon-green);\n  text-align: center;\n  font-weight: 600;\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n/* Loot Tier Styling */\n.boss-raid-modal__stat--loot .boss-raid-modal__stat-value {\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.boss-raid-modal__loot-tier {\n  text-shadow: 0 0 8px currentColor;\n}\n\n/* Bonus Loot Indicator */\n.boss-raid-modal__bonus {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n  padding: 0.5rem 1.5rem;\n  background: rgba(0, 255, 136, 0.08);\n  border-bottom: 1px solid rgba(0, 255, 136, 0.2);\n}\n\n.boss-raid-modal__bonus-label {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.boss-raid-modal__bonus-value {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  font-size: 0.875rem;\n  font-family: var(--font-mono);\n  font-weight: 700;\n  color: var(--color-neon-green);\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n/* Modal Tabs */\n.boss-raid-modal__tabs {\n  display: flex;\n  gap: 0;\n  padding: 0 1.5rem;\n  border-bottom: 1px solid rgba(255, 0, 84, 0.2);\n}\n\n.boss-raid-modal__tab {\n  padding: 0.75rem 1.5rem;\n  background: transparent;\n  border: none;\n  color: var(--color-text-muted);\n  font-size: 1rem;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  cursor: pointer;\n  transition: all 0.2s;\n  position: relative;\n}\n\n.boss-raid-modal__tab:hover {\n  color: var(--color-text);\n}\n\n.boss-raid-modal__tab--active {\n  color: var(--color-neon-purple);\n}\n\n.boss-raid-modal__tab--active::after {\n  content: '';\n  position: absolute;\n  bottom: -1px;\n  left: 0;\n  right: 0;\n  height: 2px;\n  background: var(--color-neon-purple);\n}\n\n/* Modal Tab Content */\n.boss-raid-modal__tab-content {\n  padding: 1rem 1.5rem;\n  min-height: 200px;\n  max-height: 300px;\n  overflow-y: auto;\n}\n\n/* Legacy Modal Content (removed grid) */\n.boss-raid-modal__content {\n  display: flex;\n  flex-direction: column;\n  gap: 1rem;\n  padding: 1rem 1.5rem;\n}\n\n.boss-raid-modal__feed,\n.boss-raid-modal__leaderboard {\n  min-height: 150px;\n}\n\n/* Modal Footer */\n.boss-raid-modal__footer {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.75rem;\n  padding: 1rem 1.5rem;\n  border-top: 1px solid rgba(255, 0, 84, 0.2);\n}\n\n.boss-raid-modal__hint {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  margin: 0;\n}\n\n.boss-raid-modal__close-btn {\n  padding: 0.5rem 2rem;\n  background: rgba(255, 0, 84, 0.2);\n  border: 1px solid rgba(255, 0, 84, 0.5);\n  border-radius: 2px;\n  color: var(--color-text);\n  font-size: 0.875rem;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.boss-raid-modal__close-btn:hover {\n  background: rgba(255, 0, 84, 0.3);\n  border-color: rgba(255, 0, 84, 0.8);\n}\n\n.boss-raid-modal__empty {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  padding: 3rem;\n  color: var(--color-text-muted);\n  text-align: center;\n}\n\n/* Hit Feed */\n.damage-event-feed {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n}\n\n.damage-event-feed__header {\n  padding: 0.5rem;\n  border-bottom: 1px solid rgba(255, 0, 84, 0.2);\n}\n\n.damage-event-feed__title {\n  font-size: 0.875rem;\n  color: var(--color-neon-purple);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.damage-event-feed__list {\n  flex: 1;\n  overflow-y: auto;\n  max-height: 180px;\n  padding: 0.5rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n}\n\n.damage-event-feed__item {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.25rem 0.5rem;\n  font-size: 1rem;\n  background: rgba(0, 0, 0, 0.2);\n  border-radius: 3px;\n  animation: damage-event-in 0.3s ease;\n}\n\n@keyframes damage-event-in {\n  from {\n    opacity: 0;\n    transform: translateX(-10px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n\n.damage-event-feed__item--user {\n  background: rgba(0, 255, 136, 0.1);\n  border-left: 2px solid var(--color-neon-green);\n}\n\n.damage-event-feed__item--phase {\n  background: rgba(255, 215, 0, 0.1);\n  border-left: 2px solid var(--color-neon-yellow);\n  color: var(--color-neon-yellow);\n}\n\n.damage-event-feed__item--end {\n  justify-content: center;\n  font-weight: 700;\n  padding: 0.5rem;\n}\n\n.damage-event-feed__item--defeated {\n  background: rgba(0, 255, 136, 0.15);\n  color: var(--color-neon-green);\n}\n\n.damage-event-feed__item--escaped {\n  background: rgba(255, 215, 0, 0.15);\n  color: var(--color-neon-yellow);\n}\n\n.damage-event-feed__icon {\n  font-size: 0.875rem;\n}\n\n.damage-event-feed__player {\n  color: var(--color-text-dim);\n  min-width: 70px;\n}\n\n.damage-event-feed__item--user .damage-event-feed__player {\n  color: var(--color-neon-green);\n  font-weight: 600;\n}\n\n.damage-event-feed__text {\n  color: var(--color-text-muted);\n}\n\n.damage-event-feed__damage {\n  color: var(--color-neon-pink);\n  font-family: var(--font-mono);\n  margin-left: auto;\n}\n\n.damage-event-feed__phase-icon {\n  font-size: 1rem;\n}\n\n.damage-event-feed__phase-text {\n  font-weight: 600;\n}\n\n.damage-event-feed__end-icon {\n  font-size: 1.25rem;\n}\n\n.damage-event-feed__end-text {\n  letter-spacing: 1px;\n}\n\n.damage-event-feed--empty {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n}\n\n.damage-event-feed__empty-text {\n  color: var(--color-text-muted);\n  font-size: 1rem;\n}\n\n/* Raid Leaderboard */\n.raid-leaderboard {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n}\n\n.raid-leaderboard__header {\n  padding: 0.5rem;\n  border-bottom: 1px solid rgba(255, 0, 84, 0.2);\n}\n\n.raid-leaderboard__title {\n  font-size: 0.875rem;\n  color: var(--color-neon-purple);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.raid-leaderboard__list {\n  flex: 1;\n  overflow-y: auto;\n  max-height: 180px;\n  padding: 0.5rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n}\n\n.raid-leaderboard__item {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.25rem 0.5rem;\n  font-size: 1rem;\n  background: rgba(0, 0, 0, 0.2);\n  border-radius: 3px;\n}\n\n.raid-leaderboard__item--user {\n  background: rgba(0, 255, 136, 0.1);\n  border-left: 2px solid var(--color-neon-green);\n}\n\n.raid-leaderboard__item--rank-1 {\n  background: rgba(255, 215, 0, 0.15);\n}\n\n.raid-leaderboard__item--rank-2 {\n  background: rgba(192, 192, 192, 0.1);\n}\n\n.raid-leaderboard__item--rank-3 {\n  background: rgba(205, 127, 50, 0.1);\n}\n\n.raid-leaderboard__rank {\n  min-width: 28px;\n  text-align: center;\n}\n\n.raid-leaderboard__player {\n  color: var(--color-text-dim);\n  flex: 1;\n}\n\n.raid-leaderboard__item--user .raid-leaderboard__player {\n  color: var(--color-neon-green);\n  font-weight: 600;\n}\n\n.raid-leaderboard__damage {\n  font-family: var(--font-mono);\n  color: var(--color-text);\n}\n\n.raid-leaderboard__percent {\n  font-family: var(--font-mono);\n  color: var(--color-text-muted);\n  font-size: 0.875rem;\n}\n\n.raid-leaderboard--empty {\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n}\n\n.raid-leaderboard__empty-text {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex: 1;\n  color: var(--color-text-muted);\n  font-size: 1rem;\n}\n\n/* Mobile Responsive for Dogpile Raid */\n@media (max-width: 768px) {\n  .header-boss-raid {\n    padding: 0.3rem 0.5rem;\n    gap: 0.4rem;\n  }\n\n  .kraken-avatar {\n    width: 24px;\n    height: 24px;\n  }\n\n  .header-boss-raid__status {\n    min-width: 55px;\n    gap: 0.1rem;\n  }\n\n  .header-boss-raid__divider {\n    height: 18px;\n  }\n\n  .header-boss-raid__timer-value {\n    font-size: 0.8rem;\n  }\n\n  .header-boss-raid__pool-amount {\n    font-size: 0.875rem;\n  }\n\n  .header-boss-raid__pool {\n    min-width: 48px;\n  }\n\n  .boss-raid-modal__stats {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  .boss-raid-modal__user-stats-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  .boss-raid-modal__tabs {\n    padding: 0 1rem;\n  }\n\n  .boss-raid-modal__tab {\n    padding: 0.5rem 1rem;\n    font-size: 0.65rem;\n  }\n\n  .boss-raid-modal__tab-content {\n    padding: 0.75rem 1rem;\n    max-height: 250px;\n  }\n}\n\n/* Header Right (legacy compat) */\n.header-right {\n  display: flex;\n  align-items: center;\n  gap: 1.5rem;\n}\n\n/* Nav badges */\n.header-nav a {\n  position: relative;\n}\n\n.nav-badge {\n  position: absolute;\n  top: 0.25rem;\n  right: 0.25rem;\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--color-warning);\n  animation: nav-badge-pulse 1.5s ease-in-out infinite;\n}\n\n.nav-badge--yellow {\n  background: var(--color-warning);\n}\n\n.nav-badge--red {\n  background: var(--color-error);\n}\n\n.nav-badge--green {\n  background: var(--color-success);\n}\n\n@keyframes nav-badge-pulse {\n  0%, 100% { transform: scale(1); opacity: 1; }\n  50% { transform: scale(1.2); opacity: 0.8; }\n}\n\n/* Nav Button (Fairness) */\n.nav-btn {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  padding: 0.5rem 0.75rem;\n  border: 1px solid transparent;\n  background: transparent;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.nav-btn:hover {\n  color: var(--color-neon-pink);\n  border-color: var(--color-neon-pink);\n  text-shadow: none;\n}\n\n.fairness-btn.active {\n  color: var(--color-neon-cyan);\n  border-color: var(--color-neon-cyan);\n}\n\n/* Fairness Dropdown */\n.fairness-dropdown {\n  position: absolute;\n  top: 100%;\n  left: 50%;\n  transform: translateX(-50%);\n  background: var(--color-surface);\n  border: 1px solid var(--color-neon-cyan);\n  box-shadow: none;\n  z-index: 200;\n  min-width: 320px;\n}\n\n.fairness-dropdown-content {\n  padding: 1rem;\n}\n\n.fairness-dropdown-content h4 {\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  margin-bottom: 0.75rem;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  text-shadow: none;\n}\n\n.fairness-dropdown-content h4::before {\n  content: '';\n  width: 8px;\n  height: 8px;\n  background: var(--color-neon-green);\n  border-radius: 50%;\n  box-shadow: none;\n}\n\n.fairness-dropdown-content p {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  margin-bottom: 0.5rem;\n  line-height: 1.8;\n}\n\n.fairness-details {\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n  margin: 0.75rem 0;\n  padding: 0.5rem;\n  background: var(--color-bg);\n  border: 1px solid var(--color-surface-elevated);\n}\n\n.fairness-details span {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  font-family: var(--font-mono);\n}\n\n/* ============ Wallet Button ============ */\n.rng-wallet-button-container {\n  position: relative;\n}\n\n.rng-wallet-button {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-text);\n  border: none;\n  padding: 0.625rem 1rem;\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.rng-wallet-button--disconnected {\n  background: linear-gradient(135deg, var(--color-neon-pink) 0%, var(--color-neon-magenta) 100%);\n  box-shadow: none;\n}\n\n.rng-wallet-button--disconnected:hover {\n  background: linear-gradient(135deg, var(--color-neon-cyan) 0%, var(--color-neon-blue) 100%);\n  box-shadow: none;\n  transform: translateY(-2px);\n}\n\n.rng-wallet-button--connected {\n  background: var(--color-surface-elevated);\n  border: 2px solid var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n}\n\n.rng-wallet-button--connected:hover {\n  background: rgba(0, 255, 136, 0.1);\n  box-shadow: none;\n}\n\n.rng-wallet-button--connecting {\n  background: var(--color-surface-elevated);\n  border: 2px solid var(--color-text-muted);\n  color: var(--color-text-muted);\n  cursor: wait;\n}\n\n.rng-wallet-button__spinner {\n  width: 12px;\n  height: 12px;\n  border: 2px solid currentColor;\n  border-top-color: transparent;\n  border-radius: 50%;\n  animation: spin 0.8s linear infinite;\n}\n\n.rng-wallet-button__balance {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.rng-wallet-button__sol-icon {\n  filter: none;\n  flex-shrink: 0;\n}\n\n.rng-wallet-button__address {\n  color: var(--color-text);\n}\n\n.rng-wallet-button__chevron {\n  font-size: 1rem;\n  transition: transform 0.2s;\n}\n\n.rng-wallet-button__chevron.open {\n  transform: rotate(180deg);\n}\n\n/* Wallet Dropdown */\n.rng-wallet-dropdown {\n  position: absolute;\n  top: calc(100% + 8px);\n  right: 0;\n  background: var(--color-surface);\n  border: 2px solid var(--color-neon-cyan);\n  padding: 1rem;\n  min-width: 220px;\n  z-index: 100;\n  box-shadow: none;\n}\n\n.rng-wallet-dropdown__address,\n.rng-wallet-dropdown__balance {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.5rem 0;\n  border-bottom: 1px solid var(--color-border);\n}\n\n.rng-wallet-dropdown__label {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.rng-wallet-dropdown__value {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-text);\n}\n\n.rng-wallet-dropdown__sol-icon {\n  filter: none;\n  margin-right: 0.25rem;\n  flex-shrink: 0;\n}\n\n.rng-wallet-dropdown__copy,\n.rng-wallet-dropdown__explorer,\n.rng-wallet-dropdown__disconnect {\n  display: block;\n  width: 100%;\n  padding: 0.625rem;\n  margin-top: 0.5rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  text-transform: uppercase;\n  text-align: center;\n  text-decoration: none;\n  cursor: pointer;\n  border: none;\n  transition: all 0.2s;\n}\n\n.rng-wallet-dropdown__copy,\n.rng-wallet-dropdown__explorer {\n  background: var(--color-surface-elevated);\n  color: var(--color-text);\n  border: 1px solid var(--color-border);\n}\n\n.rng-wallet-dropdown__copy:hover,\n.rng-wallet-dropdown__explorer:hover {\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n}\n\n.rng-wallet-dropdown__disconnect {\n  background: transparent;\n  color: var(--color-pool-red);\n  border: 1px solid var(--color-pool-red);\n}\n\n.rng-wallet-dropdown__disconnect:hover {\n  background: rgba(212, 93, 93, 0.1);\n  box-shadow: none;\n}\n\n/* Balance Display */\n.rng-balance {\n  display: flex;\n  align-items: center;\n  gap: 0.375rem;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.rng-balance__icon {\n  width: 14px;\n  height: 14px;\n}\n\n.rng-balance__loading {\n  color: var(--color-text-muted);\n  animation: pulse 1.5s ease-in-out infinite;\n}\n\n.rng-balance__error {\n  color: var(--color-pool-red);\n}\n\n.rng-balance__value {\n  color: var(--color-neon-green);\n}\n\n.rng-balance__empty {\n  color: var(--color-text-muted);\n}\n\n.rng-balance__unit {\n  color: var(--color-text-muted);\n  font-size: 1rem;\n}\n\n.rng-balance__refresh {\n  background: none;\n  border: none;\n  color: var(--color-text-muted);\n  cursor: pointer;\n  padding: 0.25rem;\n  font-size: 1rem;\n  transition: color 0.2s;\n}\n\n.rng-balance__refresh:hover {\n  color: var(--color-neon-cyan);\n}\n\n.rng-balance__refresh:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n/* Fee Breakdown */\n.rng-fee-breakdown {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: var(--color-surface-elevated);\n  border: 1px solid var(--color-border);\n  margin-top: 1rem;\n}\n\n.rng-fee-breakdown__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  width: 100%;\n  padding: 0.75rem;\n  background: none;\n  border: none;\n  color: var(--color-text);\n  cursor: pointer;\n  text-transform: uppercase;\n}\n\n.rng-fee-breakdown__label {\n  color: var(--color-text-muted);\n}\n\n.rng-fee-breakdown__total {\n  color: var(--color-neon-cyan);\n}\n\n.rng-fee-breakdown__toggle {\n  font-size: 0.375rem;\n  color: var(--color-text-muted);\n  transition: transform 0.2s;\n}\n\n.rng-fee-breakdown__toggle.expanded {\n  transform: rotate(180deg);\n}\n\n.rng-fee-breakdown__details {\n  padding: 0.75rem;\n  border-top: 1px solid var(--color-border);\n}\n\n.rng-fee-breakdown__item {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  padding: 0.375rem 0;\n}\n\n.rng-fee-breakdown__item-name {\n  color: var(--color-text);\n}\n\n.rng-fee-breakdown__item-desc {\n  display: block;\n  color: var(--color-text-muted);\n  font-size: 0.375rem;\n}\n\n.rng-fee-breakdown__item-value {\n  color: var(--color-neon-cyan);\n}\n\n.rng-fee-breakdown__note {\n  margin-top: 0.75rem;\n  padding-top: 0.75rem;\n  border-top: 1px solid var(--color-border);\n  color: var(--color-neon-green);\n  text-align: center;\n}\n\n@keyframes spin {\n  to {\n    transform: rotate(360deg);\n  }\n}\n\n/* ============ Game Layout ============ */\n.rng-game-layout {\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.rng-game-layout__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  margin-bottom: 1.5rem;\n  padding-bottom: 1rem;\n  border-bottom: 1px solid var(--color-border);\n}\n\n.rng-game-layout__title {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: var(--color-neon-pink);\n  text-shadow: none;\n  margin: 0;\n}\n\n.rng-game-layout__description {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  margin: 0.5rem 0 0;\n}\n\n.rng-game-layout__body {\n  display: grid;\n  grid-template-columns: 1fr 320px;\n  gap: 1.5rem;\n}\n\n/* Single column when no sidebar */\n.rng-game-layout__body:not(:has(.rng-game-layout__sidebar)) {\n  grid-template-columns: 1fr;\n}\n\n.rng-game-layout__main {\n  position: relative;\n  min-height: 400px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  min-width: 0;\n}\n\n.rng-game-layout__sidebar {\n  position: sticky;\n  top: 1rem;\n  align-self: start;\n  min-width: 0;\n}\n\n.rng-game-layout__history {\n  margin-top: 2rem;\n  padding-top: 1.5rem;\n  border-top: 1px solid var(--color-border);\n}\n\n@media (max-width: 900px) {\n  .rng-game-layout__body {\n    grid-template-columns: 1fr;\n  }\n\n  .rng-game-layout__sidebar {\n    position: static;\n  }\n}\n\n/* ============ Tier Selector ============ */\n.rng-tier-selector {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 0.5rem;\n  margin-bottom: 1rem;\n}\n\n.rng-tier-selector--with-all {\n  grid-template-columns: repeat(7, 1fr);\n}\n\n.rng-tier-btn--all {\n  border-color: var(--color-text-muted);\n}\n\n.rng-tier-btn {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  padding: 0.75rem 0.5rem;\n  min-height: 3.5rem;\n  background: var(--color-surface-elevated);\n  border: 2px solid var(--tier-color, var(--color-border));\n  cursor: pointer;\n  transition: all 0.2s;\n  font-family: var(--font-pixel);\n}\n\n.rng-tier-btn:hover:not(:disabled) {\n  background: rgba(var(--tier-color-rgb, 255, 255, 255), 0.1);\n  box-shadow: none;\n}\n\n.rng-tier-btn--selected {\n  background: rgba(var(--tier-color-rgb, 255, 255, 255), 0.15);\n  box-shadow: none;\n}\n\n.rng-tier-btn--disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n}\n\n.rng-tier-btn__name {\n  font-size: 1rem;\n  color: var(--tier-color);\n  text-transform: uppercase;\n  margin-bottom: 0.25rem;\n}\n\n.rng-tier-btn__amount {\n  font-size: 0.875rem;\n  color: var(--color-text);\n}\n\n/* ============ Wager Input ============ */\n.rng-wager-input {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.rng-wager-input__field {\n  display: flex;\n  align-items: center;\n  background: var(--color-bg-darker);\n  border: 1px solid var(--color-border2);\n  border-radius: 6px;\n  padding: 0.5rem 0.75rem;\n  transition: border-color 0.15s;\n}\n\n.rng-wager-input__field:focus-within {\n  border-color: var(--color-neon-cyan);\n  box-shadow: 0 0 0 1px rgba(0, 255, 136, 0.15);\n}\n\n.rng-wager-input__field--error {\n  border-color: var(--color-neon-red);\n}\n\n.rng-wager-input__field--error:focus-within {\n  border-color: var(--color-neon-red);\n  box-shadow: 0 0 0 1px rgba(255, 77, 77, 0.15);\n}\n\n.rng-wager-input__input {\n  flex: 1;\n  background: none;\n  border: none;\n  outline: none;\n  color: var(--color-text);\n  font-family: var(--font-mono);\n  font-size: 1.125rem;\n  min-width: 0;\n}\n\n.rng-wager-input__input::placeholder {\n  color: var(--color-text-muted);\n  font-size: 0.875rem;\n}\n\n.rng-wager-input__input:disabled {\n  opacity: 0.4;\n}\n\n.rng-wager-input__suffix {\n  font-family: var(--font-pixel);\n  font-size: 0.75rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin-left: 0.5rem;\n  flex-shrink: 0;\n}\n\n.rng-wager-input__error {\n  font-size: 0.75rem;\n  color: var(--color-neon-red);\n}\n\n.rng-wager-input__presets {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.375rem;\n}\n\n.rng-wager-btn {\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  padding: 0.25rem 0.5rem;\n  background: var(--color-surface);\n  color: var(--color-text-dim);\n  border: 1px solid var(--color-border2);\n  border-radius: 4px;\n  cursor: pointer;\n  transition: all 0.12s;\n}\n\n.rng-wager-btn:hover:not(:disabled) {\n  background: rgba(0, 255, 136, 0.08);\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n}\n\n.rng-wager-btn--selected {\n  background: rgba(0, 255, 136, 0.12);\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n}\n\n.rng-wager-btn:disabled {\n  opacity: 0.3;\n  cursor: not-allowed;\n}\n\n/* ============ Betting Panel ============ */\n.rng-betting-panel {\n  background: var(--color-surface);\n  border: 2px solid var(--color-neon-pink);\n  padding: 1.25rem;\n}\n\n.rng-betting-panel__title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-pink);\n  text-shadow: none;\n  margin: 0 0 1rem;\n  text-transform: uppercase;\n}\n\n.rng-betting-panel__sides {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 0.5rem;\n  margin-bottom: 1rem;\n}\n\n.rng-side-btn {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  padding: 0.75rem;\n  border: 2px solid;\n  cursor: pointer;\n  transition: all 0.2s;\n  text-transform: uppercase;\n}\n\n.rng-side-btn--green {\n  border-color: var(--color-pool-green);\n  background: rgba(77, 212, 93, 0.1);\n  color: var(--color-pool-green);\n}\n\n.rng-side-btn--green:hover,\n.rng-side-btn--green.rng-side-btn--selected {\n  background: rgba(77, 212, 93, 0.25);\n  box-shadow: none;\n}\n\n.rng-side-btn--red {\n  border-color: var(--color-pool-red);\n  background: rgba(212, 93, 93, 0.1);\n  color: var(--color-pool-red);\n}\n\n.rng-side-btn--red:hover,\n.rng-side-btn--red.rng-side-btn--selected {\n  background: rgba(212, 93, 93, 0.25);\n  box-shadow: none;\n}\n\n.rng-betting-panel__summary {\n  background: var(--color-surface-elevated);\n  padding: 0.75rem;\n  margin-bottom: 1rem;\n  border: 1px solid var(--color-border);\n}\n\n.rng-betting-panel__row {\n  display: flex;\n  justify-content: space-between;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  padding: 0.375rem 0;\n}\n\n.rng-betting-panel__row--highlight {\n  padding-top: 0.5rem;\n  margin-top: 0.375rem;\n  border-top: 1px solid var(--color-border);\n}\n\n.rng-betting-panel__value {\n  color: var(--color-text);\n}\n\n.rng-betting-panel__value--payout {\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.rng-betting-panel__actions {\n  margin-top: 1rem;\n}\n\n.rng-betting-panel__btn {\n  width: 100%;\n}\n\n/* ============ History Panel ============ */\n.rng-history-panel {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  padding: 1rem;\n}\n\n.rng-history-panel__title {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  margin: 0 0 1rem;\n}\n\n.rng-history-panel__list {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.rng-history-panel__empty {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-align: center;\n  padding: 2rem;\n}\n\n.rng-history-panel__loading {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-align: center;\n  padding: 1rem;\n}\n\n.rng-history-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.5rem 0.75rem;\n  background: var(--color-surface-elevated);\n  border: 1px solid var(--color-border);\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n}\n\n.rng-history-item--won {\n  border-color: var(--color-neon-green);\n}\n\n.rng-history-item__main {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n}\n\n.rng-history-item__round {\n  color: var(--color-text-muted);\n}\n\n.rng-history-item__result {\n  color: var(--color-text);\n}\n\n.rng-history-item__meta {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n}\n\n.rng-history-item__payout {\n  color: var(--color-text-muted);\n}\n\n.rng-history-item__payout--positive {\n  color: var(--color-neon-green);\n}\n\n.rng-history-item__payout--negative {\n  color: var(--color-pool-red);\n}\n\n.rng-history-item__time {\n  color: var(--color-text-muted);\n}\n\n.rng-history-item__verified {\n  color: var(--color-neon-cyan);\n}\n\n.rng-history-item--clickable {\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.rng-history-item--clickable:hover {\n  background: rgba(0, 255, 136, 0.05);\n  border-color: rgba(0, 255, 136, 0.3);\n}\n\n.rng-history-item--clickable:focus {\n  outline: none;\n  border-color: var(--color-neon-green);\n}\n\n.rng-history-panel__more {\n  width: 100%;\n  margin-top: 0.75rem;\n  padding: 0.5rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: none;\n  border: 1px solid var(--color-border);\n  color: var(--color-text-muted);\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n}\n\n.rng-history-panel__more:hover {\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n}\n\n/* ============ Main Content ============ */\n.main {\n  flex: 1;\n  padding: 1.5rem;\n  padding-left: 68px;\n  position: relative;\n  z-index: 1;\n}\n\n/* ============ Home Page ============ */\n.home {\n  max-width: 1200px;\n  margin: 0 auto;\n  text-align: center;\n  position: relative;\n}\n\n.arcade-header {\n  margin-bottom: 2rem;\n}\n\n.arcade-header h2 {\n  font-size: 1.25rem;\n  color: var(--color-neon-pink);\n  margin-bottom: 0.5rem;\n  text-shadow: none;\n}\n\n.subtitle {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  animation: none;\n  text-shadow: none;\n}\n\n@keyframes blink {\n  50% { opacity: 0; }\n}\n\n/* ============ Games Grid ============ */\n.games-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n  gap: 1.5rem;\n  text-align: left;\n}\n\n/* Game Card */\n.game-card {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  text-decoration: none;\n  color: var(--color-text);\n  display: flex;\n  flex-direction: column;\n  position: relative;\n  overflow: hidden;\n  transition: all 0.3s;\n  box-shadow: none;\n}\n\n.game-card:hover {\n  border-color: var(--color-primary);\n  box-shadow: 2px 2px 0 rgba(255, 0, 84, 0.2);\n  transform: translateY(-2px);\n}\n\n.game-card.locked {\n  opacity: 0.6;\n  border-color: var(--color-text-muted);\n  box-shadow: none;\n}\n\n.game-card.locked:hover {\n  transform: none;\n  box-shadow: none;\n}\n\n/* Game Card Visual */\n.game-visual {\n  height: 120px;\n  background: var(--color-bg);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  position: relative;\n  overflow: hidden;\n  border-bottom: 1px solid rgba(255, 0, 84, 0.3);\n}\n\n/* Close Call Visual - Candlestick pool bar */\n.close-call-visual {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  width: 100%;\n  height: 100%;\n  padding: 0.5rem;\n}\n\n.pool-container {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  height: 100%;\n  position: relative;\n}\n\n/* Wicks (top and bottom) */\n.pool-wick {\n  width: 4px;\n  height: 12px;\n  background: var(--color-text-dim);\n}\n\n.pool-wick--green {\n  background: #00ff88;\n}\n\n.pool-wick--red {\n  background: #ff0054;\n}\n\n/* Green and Red halves - equal height/width */\n.pool-green {\n  width: 40px;\n  height: 36px;\n  background: var(--color-pool-green);\n  box-shadow: none;\n}\n\n.pool-red {\n  width: 40px;\n  height: 36px;\n  background: var(--color-pool-red);\n  box-shadow: none;\n}\n\n.pool-label {\n  position: absolute;\n  font-size: 1rem;\n  white-space: nowrap;\n}\n\n.pool-label.green {\n  color: var(--color-pool-green);\n  text-shadow: none;\n  top: 20%;\n  right: calc(100% + 8px);\n}\n\n.pool-label.red {\n  color: var(--color-pool-red);\n  text-shadow: none;\n  bottom: 20%;\n  left: calc(100% + 8px);\n}\n\n/* Crash Visual - SVG Candlestick chart */\n.crash-visual {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  padding: 0.5rem;\n}\n\n.crash-visual svg {\n  width: 100%;\n  height: 100%;\n}\n\n/* Lord of RNGs Visual - Player circles */\n.lotr-visual {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n  width: 100%;\n  height: 100%;\n  position: relative;\n}\n\n.lotr-container {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  border: 2px solid var(--color-text-muted);\n  padding: 0.75rem;\n}\n\n/* Golden player circles */\n.player-circle {\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  border: 2px solid #ffd700;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  opacity: 0.5;\n}\n\n.player-circle.selected {\n  opacity: 1;\n  border-width: 3px;\n  box-shadow: 0 0 6px rgba(255, 215, 0, 0.4);\n}\n\n.player-circle svg {\n  width: 20px;\n  height: 20px;\n  fill: #ffd700;\n}\n\n.selection-arrow {\n  position: absolute;\n  top: 0.5rem;\n  left: 50%;\n  transform: translateX(-50%);\n  width: 0;\n  height: 0;\n  border-left: 8px solid transparent;\n  border-right: 8px solid transparent;\n  border-top: 10px solid #ffd700;\n  filter: none;\n}\n\n/* Generic game visual */\n.generic-visual {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.generic-visual svg {\n  width: 48px;\n  height: 48px;\n  filter: none;\n}\n\n/* Coinflip game visual */\n.coinflip-visual {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  padding: 0.5rem;\n}\n\n.coinflip-visual svg {\n  width: 100%;\n  height: 100%;\n  max-width: 80px;\n  filter:\n    drop-shadow(0 0 8px rgba(0, 204, 136, 0.5))\n    drop-shadow(0 0 8px rgba(255, 102, 68, 0.5));\n}\n\n/* Game Card Info */\n.game-info {\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  flex: 1;\n}\n\n.game-card h3 {\n  font-size: 1rem;\n  text-transform: uppercase;\n  margin: 0 0 0.5rem 0;\n  color: var(--color-neon-pink);\n  text-shadow: none;\n}\n\n.game-card:hover h3 {\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n@keyframes pulse-dot {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.4; }\n}\n\n.game-description {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  margin-bottom: 0.75rem;\n}\n\n.game-footer {\n  margin-top: auto;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.play-text {\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  text-transform: uppercase;\n  text-shadow: none;\n}\n\n.game-card:hover .play-text {\n  color: var(--color-text);\n  text-shadow: none;\n}\n\n/* Badges */\n.hot-badge {\n  position: absolute;\n  top: 8px;\n  left: 8px;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: var(--color-neon-pink);\n  color: var(--color-text);\n  padding: 0.25rem 0.5rem;\n  z-index: 10;\n  box-shadow: none;\n  animation: pulse-badge 1.5s ease-in-out infinite;\n}\n\n@keyframes pulse-badge {\n  0%, 100% { box-shadow: none; }\n  50% { box-shadow: none; }\n}\n\n.player-count-badge {\n  position: absolute;\n  top: 8px;\n  right: 8px;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: rgba(0, 255, 136, 0.2);\n  color: var(--color-neon-green);\n  padding: 0.25rem 0.5rem;\n  z-index: 10;\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  border: 1px solid var(--color-neon-green);\n}\n\n.player-count-badge::before {\n  content: '';\n  width: 6px;\n  height: 6px;\n  background: var(--color-neon-green);\n  border-radius: 50%;\n  animation: pulse-dot 1.5s ease-in-out infinite;\n  box-shadow: none;\n}\n\n.lock-badge {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-bg);\n  background: var(--color-warning);\n  padding: 0.25rem 0.5rem;\n}\n\n.lock-icon {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  font-size: 2rem;\n  z-index: 5;\n  filter: drop-shadow(0 0 10px rgba(0, 0, 0, 0.8));\n}\n\n/* ============ RNG Blessing Countdown ============ */\n.blessing-section {\n  background: linear-gradient(180deg, rgba(26, 26, 26, 0.9) 0%, rgba(17, 17, 17, 0.95) 100%);\n  border: 2px solid var(--color-neon-purple);\n  box-shadow: none;\n  padding: 1.25rem;\n}\n\n.blessing-section h3 {\n  font-size: 1rem;\n  color: var(--color-neon-purple);\n  margin-bottom: 1rem;\n  text-align: center;\n  text-shadow: none;\n}\n\n.blessing-countdown {\n  display: flex;\n  justify-content: center;\n  gap: 1rem;\n  margin-bottom: 1rem;\n}\n\n.countdown-unit {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.countdown-value {\n  font-size: 1.375rem;\n  color: var(--color-text);\n  background: var(--color-bg);\n  padding: 0.5rem 0.75rem;\n  border: 2px solid var(--color-neon-purple);\n  min-width: 50px;\n  text-shadow: none;\n}\n\n.countdown-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  margin-top: 0.25rem;\n}\n\n.blessing-info {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  text-align: center;\n}\n\n.blessing-pool {\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n/* ============ Fairness Section ============ */\n.fairness-section {\n  background: linear-gradient(180deg, rgba(26, 26, 26, 0.9) 0%, rgba(17, 17, 17, 0.95) 100%);\n  border: 2px solid var(--color-neon-cyan);\n  box-shadow: none;\n  padding: 1.25rem;\n}\n\n.fairness-section h3 {\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  margin-bottom: 1rem;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  text-shadow: none;\n}\n\n.fairness-section h3::before {\n  content: '';\n  width: 8px;\n  height: 8px;\n  background: var(--color-neon-green);\n  border-radius: 50%;\n  box-shadow: none;\n}\n\n.fairness-content {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  line-height: 2;\n}\n\n.fairness-content p {\n  margin-bottom: 0.75rem;\n}\n\n.verify-btn {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  background: transparent;\n  color: var(--color-neon-cyan);\n  border: 2px solid var(--color-neon-cyan);\n  padding: 0.5rem 1rem;\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n  width: 100%;\n  margin-top: 0.5rem;\n  display: block;\n  text-align: center;\n  text-decoration: none;\n}\n\n.verify-btn:hover {\n  background: var(--color-neon-cyan);\n  color: var(--color-bg);\n  box-shadow: none;\n}\n\n/* ============ Stats Bar ============ */\n.stats-bar {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 2rem;\n  padding: 1rem 2rem;\n  margin-bottom: 1.5rem;\n  background: var(--color-surface);\n  border: 1px solid var(--color-neon-pink);\n  box-shadow: none;\n}\n\n.stat-item {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n}\n\n.stat-divider {\n  width: 1px;\n  height: 24px;\n  background: var(--color-neon-pink);\n  box-shadow: none;\n}\n\n.stat-value {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.stat-label {\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n}\n\n/* ============ RNG High Score Section ============ */\n.rng-high-score {\n  position: absolute;\n  top: 1.5rem;\n  right: 49px;\n  width: 240px;\n  z-index: 10;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  overflow: hidden;\n  box-shadow: none;\n}\n\n.rng-high-score-header {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n  padding: 0.5rem;\n  background: rgba(255, 215, 0, 0.08);\n  border-bottom: 1px solid rgba(255, 215, 0, 0.3);\n}\n\n.rng-high-score-header .trophy {\n  font-size: 1rem;\n}\n\n.rng-high-score-header .title {\n  font-size: 1rem;\n  color: #ffd700;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  text-shadow: 0 0 8px rgba(255, 215, 0, 0.6);\n}\n\n.rng-high-score-content {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  padding: 1rem 0.75rem;\n  gap: 0.5rem;\n}\n\n.rng-player-avatar {\n  width: 48px;\n  height: 48px;\n  border-radius: 50%;\n  background: rgba(255, 215, 0, 0.1);\n  border: 1px solid rgba(255, 215, 0, 0.4);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: rgba(255, 215, 0, 0.7);\n}\n\n.rng-player-avatar svg {\n  width: 28px;\n  height: 28px;\n}\n\n.rng-player-name {\n  font-size: 0.875rem;\n  color: var(--color-text);\n  font-family: var(--font-mono);\n  letter-spacing: 1px;\n}\n\n.rng-win-streak {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-size: 1rem;\n}\n\n.rng-win-streak .streak-label {\n  color: var(--color-text-muted);\n}\n\n.rng-win-streak .streak-value {\n  font-size: 1rem;\n  color: #ffd700;\n  font-weight: bold;\n  text-shadow: 0 0 8px rgba(255, 215, 0, 0.6);\n}\n\n.rng-high-score-footer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n  padding: 0.75rem;\n  background: rgba(0, 0, 0, 0.3);\n  border-top: 1px solid rgba(255, 215, 0, 0.2);\n}\n\n.rng-high-score-footer .sol-icon {\n  filter: none;\n  flex-shrink: 0;\n}\n\n.rng-high-score-footer .win-amount {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  font-family: var(--font-mono);\n}\n\n.rng-high-score-footer .win-usd {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n/* ============ Chat Section (Left Side) ============ */\n.chat-section {\n  position: absolute;\n  top: 8.2rem; /* Below header */\n  left: 1.5rem;\n  z-index: 10;\n  display: flex;\n  flex-direction: row;\n  align-items: flex-start;\n  pointer-events: none;\n}\n\n.chat-toggle-btn {\n  width: 44px;\n  height: 44px;\n  background: var(--color-surface);\n  border: 1px solid var(--color-neon-pink);\n  border-radius: 2px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  transition: all 0.2s;\n  color: var(--color-neon-pink);\n  pointer-events: auto;\n  position: relative;\n  flex-shrink: 0;\n  box-shadow: none;\n}\n\n.chat-toggle-btn::after {\n  content: '';\n  position: absolute;\n  top: 6px;\n  right: 6px;\n  width: 8px;\n  height: 8px;\n  background: var(--color-neon-green);\n  border-radius: 50%;\n  box-shadow: none;\n}\n\n.chat-toggle-btn:hover {\n  background: var(--color-surface-elevated);\n  box-shadow: none;\n}\n\n.chat-toggle-btn svg {\n  width: 20px;\n  height: 20px;\n}\n\n.chat-section.expanded .chat-toggle-btn {\n  display: none;\n}\n\n.chat-panel {\n  background: var(--color-surface);\n  border: 1px solid var(--color-neon-pink);\n  border-radius: 2px;\n  width: 0;\n  height: 0;\n  overflow: hidden;\n  transition: width 0.3s ease, height 0.3s ease, opacity 0.3s ease;\n  display: flex;\n  flex-direction: column;\n  pointer-events: none;\n  opacity: 0;\n  box-shadow: none;\n  margin-left: 0.5rem;\n}\n\n.chat-panel.expanded {\n  width: 300px;\n  height: calc(100vh - 8.2rem - 4rem); /* Extend to bottom, above footer */\n  pointer-events: auto;\n  opacity: 1;\n}\n\n.chat-panel-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 0.75rem 1rem;\n  border-bottom: 1px solid var(--color-surface-elevated);\n  flex-shrink: 0;\n}\n\n.chat-panel-header h4 {\n  font-size: 0.875rem;\n  color: var(--color-neon-pink);\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.chat-panel-header h4::before {\n  content: '';\n  width: 6px;\n  height: 6px;\n  background: var(--color-neon-green);\n  border-radius: 50%;\n  box-shadow: none;\n}\n\n.chat-close {\n  background: none;\n  border: none;\n  color: var(--color-text-muted);\n  font-size: 1.25rem;\n  cursor: pointer;\n  line-height: 1;\n  padding: 0;\n}\n\n.chat-close:hover {\n  color: var(--color-neon-pink);\n}\n\n.chat-messages {\n  flex: 1;\n  overflow-y: auto;\n  padding: 0.75rem;\n  min-height: 0;\n}\n\n.chat-message {\n  margin-bottom: 0.5rem;\n  font-size: 0.875rem;\n}\n\n.chat-message .username {\n  color: var(--color-neon-pink);\n}\n\n.chat-message .text {\n  color: var(--color-text-dim);\n}\n\n.chat-input-container {\n  padding: 1rem 1.25rem;\n  border-top: 1px solid var(--color-surface);\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n}\n\n.chat-input {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  flex: 1;\n  min-width: 0;\n  background: var(--color-bg);\n  border: 1px solid var(--color-neon-pink);\n  color: var(--color-text);\n  padding: 0.5rem;\n}\n\n.chat-send-btn {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: var(--color-neon-pink);\n  border: none;\n  color: var(--color-text);\n  padding: 0.5rem 0.75rem;\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n  flex-shrink: 0;\n}\n\n.chat-send-btn:hover {\n  background: var(--color-neon-magenta);\n  box-shadow: none;\n}\n\n.chat-input:focus {\n  outline: none;\n  border-color: var(--color-neon-magenta);\n  box-shadow: none;\n}\n\n/* ============ Footer ============ */\n.footer {\n  padding: 1rem 2rem;\n  background: var(--color-bg-darker);\n  border-top: 2px solid var(--color-primary);\n  box-shadow: none;\n  position: relative;\n  z-index: 10;\n}\n\n.footer-content {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  max-width: 1400px;\n  margin: 0 auto;\n  gap: 0.75rem;\n}\n\n.footer-section {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.footer-section--center {\n  flex-direction: column;\n  text-align: center;\n  gap: 0.25rem;\n}\n\n.footer-brand {\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  color: var(--color-neon-pink);\n  text-shadow: none;\n  margin: 0;\n}\n\n.footer-links {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.footer-link {\n  font-family: var(--font-pixel);\n  font-size: 0.8rem;\n  color: var(--color-neon-cyan);\n  text-shadow: 0 0 4px var(--color-neon-cyan);\n  background: none;\n  border: none;\n  cursor: pointer;\n  text-decoration: none;\n  transition: all 0.2s ease;\n}\n\n.footer-link:hover {\n  color: #fff;\n  text-shadow: 0 0 8px var(--color-neon-cyan);\n}\n\n.footer-link-divider {\n  color: #444;\n  font-size: 1rem;\n}\n\n.footer-copyright {\n  font-family: var(--font-pixel);\n  font-size: 0.45rem;\n  color: #555;\n  margin: 0;\n}\n\n.footer-section--socials {\n  gap: 0.75rem;\n}\n\n.footer-social {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 32px;\n  height: 32px;\n  border-radius: 50%;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  color: #888;\n  transition: all 0.2s ease;\n}\n\n.footer-social:hover {\n  background: rgba(0, 255, 136, 0.1);\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n  box-shadow: 0 0 12px rgba(0, 255, 136, 0.3);\n}\n\n.footer-social svg {\n  width: 16px;\n  height: 16px;\n}\n\n/* Footer Terms Modal */\n.footer-terms-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(0, 0, 0, 0.85);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n  animation: fadeIn 0.2s ease;\n}\n\n.footer-terms-modal {\n  background: var(--color-surface);\n  border: 1px solid var(--color-primary);\n  border-radius: 2px;\n  padding: 1.5rem;\n  max-width: 500px;\n  width: 90%;\n  position: relative;\n  box-shadow: 4px 4px 0 rgba(255, 0, 84, 0.15);\n  animation: slideUp 0.3s ease;\n}\n\n@keyframes slideUp {\n  from {\n    opacity: 0;\n    transform: translateY(20px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.footer-terms-close {\n  position: absolute;\n  top: 0.75rem;\n  right: 0.75rem;\n  background: none;\n  border: none;\n  color: #888;\n  font-size: 1.5rem;\n  cursor: pointer;\n  line-height: 1;\n  transition: color 0.2s ease;\n}\n\n.footer-terms-close:hover {\n  color: var(--color-neon-pink);\n}\n\n.footer-terms-title {\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  color: var(--color-neon-pink);\n  text-shadow: 0 0 8px var(--color-neon-pink);\n  margin: 0 0 1rem 0;\n  text-align: center;\n}\n\n.footer-terms-content {\n  font-family: var(--font-pixel);\n  font-size: 0.8rem;\n  line-height: 1.6;\n  color: #aaa;\n  margin-bottom: 1.5rem;\n}\n\n.footer-terms-content p {\n  margin: 0 0 1rem 0;\n}\n\n.footer-terms-content p:last-child {\n  margin-bottom: 0;\n}\n\n.footer-terms-accept {\n  display: block;\n  width: 100%;\n  padding: 0.75rem;\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  color: #000;\n  background: var(--color-neon-green);\n  border: none;\n  border-radius: 2px;\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s ease;\n}\n\n.footer-terms-accept:hover {\n  background: #4dff4d;\n  box-shadow: 0 0 16px rgba(0, 255, 136, 0.5);\n}\n\n/* Footer FAQ Modal */\n.footer-faq-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(0, 0, 0, 0.85);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n  animation: fadeIn 0.2s ease;\n}\n\n.footer-faq-modal {\n  background: var(--color-surface);\n  border: 1px solid var(--color-secondary);\n  border-radius: 2px;\n  padding: 1.5rem;\n  max-width: 600px;\n  width: 90%;\n  max-height: 80vh;\n  position: relative;\n  box-shadow: 4px 4px 0 rgba(0, 255, 136, 0.15);\n  animation: slideUp 0.3s ease;\n  display: flex;\n  flex-direction: column;\n}\n\n.footer-faq-close {\n  position: absolute;\n  top: 0.75rem;\n  right: 0.75rem;\n  background: none;\n  border: none;\n  color: #888;\n  font-size: 1.5rem;\n  cursor: pointer;\n  line-height: 1;\n  transition: color 0.2s ease;\n}\n\n.footer-faq-close:hover {\n  color: var(--color-neon-cyan);\n}\n\n.footer-faq-title {\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  color: var(--color-neon-cyan);\n  text-shadow: 0 0 8px var(--color-neon-cyan);\n  margin: 0 0 1rem 0;\n  text-align: center;\n}\n\n.footer-faq-content {\n  flex: 1;\n  overflow-y: auto;\n  margin-bottom: 1rem;\n  padding-right: 0.5rem;\n}\n\n.footer-faq-content::-webkit-scrollbar {\n  width: 4px;\n}\n\n.footer-faq-content::-webkit-scrollbar-track {\n  background: rgba(255, 255, 255, 0.05);\n  border-radius: 2px;\n}\n\n.footer-faq-content::-webkit-scrollbar-thumb {\n  background: var(--color-neon-cyan);\n  border-radius: 2px;\n}\n\n.faq-section {\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  margin-bottom: 0.5rem;\n  overflow: hidden;\n}\n\n.faq-section-header {\n  width: 100%;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.75rem 1rem;\n  background: rgba(255, 255, 255, 0.03);\n  border: none;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.faq-section-header:hover {\n  background: rgba(0, 255, 136, 0.1);\n}\n\n.faq-section-header.expanded {\n  background: rgba(0, 255, 136, 0.15);\n  border-bottom: 1px solid rgba(0, 255, 136, 0.3);\n}\n\n.faq-section-title {\n  font-family: var(--font-pixel);\n  font-size: 0.65rem;\n  color: var(--color-neon-cyan);\n  text-align: left;\n}\n\n.faq-section-arrow {\n  font-size: 1.2rem;\n  color: var(--color-neon-cyan);\n  font-weight: bold;\n}\n\n.faq-section-content {\n  padding: 1rem;\n  background: rgba(0, 0, 0, 0.3);\n  animation: fadeIn 0.2s ease;\n}\n\n.faq-section-content p {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  line-height: 1.7;\n  color: #aaa;\n  margin: 0 0 0.75rem 0;\n  white-space: pre-line;\n}\n\n.faq-section-content p:last-child {\n  margin-bottom: 0;\n}\n\n.footer-faq-close-btn {\n  display: block;\n  width: 100%;\n  padding: 0.75rem;\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  color: #000;\n  background: var(--color-neon-cyan);\n  border: none;\n  border-radius: 2px;\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s ease;\n}\n\n.footer-faq-close-btn:hover {\n  background: #4dffff;\n  box-shadow: 0 0 16px rgba(0, 255, 136, 0.5);\n}\n\n/* Footer responsive */\n@media (max-width: 768px) {\n  .footer-content {\n    gap: 0.5rem;\n  }\n}\n\n/* ============ 404 Page ============ */\n.not-found {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  min-height: 60vh;\n  text-align: center;\n}\n\n.error-code {\n  display: flex;\n  gap: 0.5rem;\n  margin-bottom: 1.5rem;\n}\n\n.error-code .digit {\n  font-size: 4rem;\n  color: var(--color-neon-pink);\n  text-shadow: none;\n  animation: digit-flicker 3s infinite;\n}\n\n.error-code .digit.zero {\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n@keyframes digit-flicker {\n  0%, 90%, 100% { opacity: 1; }\n  92%, 94%, 96%, 98% { opacity: 0.5; }\n}\n\n.not-found h2 {\n  font-size: 1.125rem;\n  color: var(--color-neon-pink);\n  margin-bottom: 1rem;\n  text-shadow: none;\n}\n\n.not-found p {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  margin-bottom: 0.5rem;\n}\n\n.not-found .hint {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.continue-btn {\n  display: inline-block;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  padding: 0.75rem 1.5rem;\n  background: linear-gradient(135deg, var(--color-neon-pink) 0%, var(--color-neon-magenta) 100%);\n  color: var(--color-text);\n  text-decoration: none;\n  text-transform: uppercase;\n  margin-top: 1.5rem;\n  box-shadow: none;\n  animation: pulse-btn 2s ease-in-out infinite;\n}\n\n@keyframes pulse-btn {\n  0%, 100% { box-shadow: none; }\n  50% { box-shadow: none; }\n}\n\n.continue-btn:hover {\n  background: linear-gradient(135deg, var(--color-neon-cyan) 0%, var(--color-neon-blue) 100%);\n  box-shadow: none;\n  animation: none;\n}\n\n/* ============ UI Components ============ */\n\n/* Button Component */\n.rng-button {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  border: none;\n  cursor: pointer;\n  transition: all 0.2s;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n}\n\n.rng-button--primary {\n  background: linear-gradient(135deg, var(--color-neon-pink) 0%, var(--color-neon-magenta) 100%);\n  color: var(--color-text);\n  box-shadow: none;\n}\n\n.rng-button--primary:hover:not(:disabled) {\n  box-shadow: 2px 2px 0 rgba(255, 0, 84, 0.3);\n  transform: translateY(-2px);\n}\n\n.rng-button--outline {\n  background: transparent;\n  color: var(--color-neon-cyan);\n  border: 2px solid var(--color-neon-cyan);\n}\n\n.rng-button--outline:hover:not(:disabled) {\n  background: var(--color-neon-cyan);\n  color: var(--color-bg);\n  box-shadow: none;\n}\n\n.rng-button--sm { padding: 0.5rem 0.75rem; font-size: 1rem; }\n.rng-button--md { padding: 0.625rem 1rem; }\n.rng-button--lg { padding: 0.75rem 1.5rem; font-size: 1rem; }\n\n.rng-button:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n/* Card Component */\n.rng-card {\n  background: linear-gradient(180deg, rgba(26, 26, 26, 0.9) 0%, rgba(17, 17, 17, 0.95) 100%);\n  border: 1px solid var(--color-border);\n  box-shadow: none;\n}\n\n.rng-card__header {\n  padding: 0.75rem 1rem;\n  border-bottom: 1px solid var(--color-surface-elevated);\n  font-size: 1rem;\n  text-transform: uppercase;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.rng-card__body {\n  padding: 1rem;\n}\n\n.rng-card__footer {\n  padding: 0.75rem 1rem;\n  border-top: 1px solid var(--color-surface-elevated);\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n}\n\n/* Input Component */\n.rng-input {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  background: var(--color-bg);\n  color: var(--color-text);\n  border: 2px solid var(--color-text-muted);\n  padding: 0.625rem 0.75rem;\n  width: 100%;\n  transition: all 0.2s;\n}\n\n.rng-input:focus {\n  outline: none;\n  border-color: var(--color-neon-cyan);\n  box-shadow: none;\n}\n\n/* Modal Component */\n.rng-modal-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(17, 17, 17, 0.9);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n}\n\n.rng-modal {\n  background: var(--color-surface);\n  border: 2px solid var(--color-neon-pink);\n  box-shadow: 4px 4px 0 rgba(255, 0, 84, 0.2);\n  max-width: 90%;\n  max-height: 90%;\n  overflow: auto;\n}\n\n.rng-modal__header {\n  padding: 1rem;\n  border-bottom: 1px solid var(--color-surface-elevated);\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n}\n\n.rng-modal__title {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.rng-modal__close {\n  background: none;\n  border: none;\n  color: var(--color-text-muted);\n  font-size: 1rem;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.rng-modal__close:hover {\n  color: var(--color-neon-pink);\n  text-shadow: none;\n}\n\n.rng-modal__body {\n  padding: 1rem;\n}\n\n/* History Detail Modal */\n.lotr-history-modal,\n.coinflip-history-modal {\n  min-width: 350px;\n  padding: 0.5rem 1rem 1rem 1rem;\n}\n\n.lotr-history-modal__section,\n.coinflip-history-modal__section {\n  margin-bottom: 1.25rem;\n  padding: 0 0.25rem;\n}\n\n.lotr-history-modal__section:last-of-type,\n.coinflip-history-modal__section:last-of-type {\n  margin-bottom: 1rem;\n}\n\n.lotr-history-modal__section-title,\n.coinflip-history-modal__section-title {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin: 0 0 0.75rem 0;\n  padding-bottom: 0.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.lotr-history-modal__lock,\n.coinflip-history-modal__lock {\n  font-size: 1rem;\n}\n\n.lotr-history-modal__row,\n.coinflip-history-modal__row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.625rem 0.25rem;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.lotr-history-modal__row:last-child,\n.coinflip-history-modal__row:last-child {\n  border-bottom: none;\n}\n\n.lotr-history-modal__row > span:first-child,\n.coinflip-history-modal__row > span:first-child {\n  color: var(--color-text-muted);\n}\n\n.lotr-history-modal__highlight,\n.coinflip-history-modal__highlight {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n}\n\n.lotr-history-modal__winner--you,\n.coinflip-history-modal__winner--you {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 8px var(--color-neon-green);\n  font-weight: bold;\n}\n\n.lotr-history-modal__hash,\n.coinflip-history-modal__hash {\n  font-family: var(--font-mono);\n  font-size: 1rem;\n  color: #888;\n  background: rgba(0, 0, 0, 0.3);\n  padding: 0.25rem 0.5rem;\n  border-radius: 2px;\n  max-width: 200px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  cursor: pointer;\n}\n\n.lotr-history-modal__hash:hover,\n.coinflip-history-modal__hash:hover {\n  color: var(--color-neon-green);\n  background: rgba(0, 255, 136, 0.1);\n}\n\n.lotr-history-modal__hash--revealed,\n.coinflip-history-modal__hash--revealed {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n}\n\n.lotr-history-modal__verify-link,\n.coinflip-history-modal__verify-link {\n  display: block;\n  text-align: center;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-decoration: none;\n  padding: 0.75rem;\n  border: 1px solid var(--color-neon-cyan);\n  border-radius: 2px;\n  transition: all 0.2s ease;\n}\n\n.lotr-history-modal__verify-link:hover,\n.coinflip-history-modal__verify-link:hover {\n  background: rgba(0, 255, 255, 0.1);\n  box-shadow: 0 0 8px var(--color-neon-cyan);\n}\n\n/* Toast Component */\n.rng-toast {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  padding: 0.75rem 1rem;\n  border: 2px solid;\n}\n\n.rng-toast--success {\n  background: rgba(0, 255, 136, 0.1);\n  border-color: var(--color-success);\n  color: var(--color-success);\n  box-shadow: none;\n}\n\n.rng-toast--error {\n  background: rgba(255, 0, 84, 0.1);\n  border-color: var(--color-error);\n  color: var(--color-error);\n  box-shadow: none;\n}\n\n.rng-toast--warning {\n  background: rgba(249, 240, 2, 0.1);\n  border-color: var(--color-warning);\n  color: var(--color-warning);\n  box-shadow: none;\n}\n\n.rng-toast--info {\n  background: rgba(0, 255, 136, 0.1);\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n  box-shadow: none;\n}\n\n/* ============ Tier Colors (for in-game use) ============ */\n.tier-iron { color: #888888; }\n.tier-bronze { color: #cc6633; }\n.tier-silver { color: #c0c0c0; }\n.tier-gold { color: #ffcc00; }\n.tier-platinum { color: #00ffcc; }\n.tier-diamond { color: #ff0054; }\n\n/* ============ Fairness Page ============ */\n.fairness-page {\n  max-width: 900px;\n  margin: 0 auto;\n  padding: 1.5rem;\n}\n\n.fairness-page .fairness-header {\n  text-align: center;\n  margin-bottom: 2rem;\n}\n\n.fairness-page .fairness-header h2 {\n  font-size: 1.125rem;\n  color: var(--color-neon-pink);\n  margin-bottom: 0.5rem;\n  text-shadow: none;\n}\n\n.fairness-subtitle {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n}\n\n/* Fairness Tabs */\n.fairness-tabs {\n  display: flex;\n  gap: 0.5rem;\n  margin-bottom: 1.5rem;\n  border-bottom: 2px solid var(--color-surface-elevated);\n  padding-bottom: 0.5rem;\n}\n\n.fairness-tab {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  background: transparent;\n  color: var(--color-text-dim);\n  border: 2px solid transparent;\n  padding: 0.625rem 1rem;\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n}\n\n.fairness-tab:hover {\n  color: var(--color-neon-pink);\n  text-shadow: none;\n}\n\n.fairness-tab.active {\n  color: var(--color-neon-cyan);\n  border-color: var(--color-neon-cyan);\n  background: rgba(0, 255, 136, 0.1);\n  box-shadow: none;\n}\n\n/* Fairness Content */\n.fairness-page .fairness-content {\n  background: linear-gradient(180deg, rgba(26, 26, 26, 0.9) 0%, rgba(17, 17, 17, 0.95) 100%);\n  border: 2px solid var(--color-neon-pink);\n  box-shadow: none;\n  padding: 1.5rem;\n}\n\n/* How It Works Section */\n.fairness-how {\n  display: flex;\n  flex-direction: column;\n  gap: 2rem;\n}\n\n.fairness-page .fairness-section {\n  padding-bottom: 1.5rem;\n  border-bottom: 1px solid var(--color-surface-elevated);\n  background: transparent;\n  border-left: none;\n  border-right: none;\n  border-top: none;\n  box-shadow: none;\n}\n\n.fairness-page .fairness-section:last-child {\n  padding-bottom: 0;\n  border-bottom: none;\n}\n\n.fairness-page .fairness-section h3 {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  margin-bottom: 0.75rem;\n  text-shadow: none;\n}\n\n.fairness-page .fairness-section h3::before {\n  display: none;\n}\n\n.fairness-page .fairness-section p {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  line-height: 1.8;\n}\n\n.pattern-label {\n  color: var(--color-neon-green) !important;\n  font-size: 1rem !important;\n  margin-bottom: 1rem !important;\n  text-shadow: none !important;\n}\n\n/* Steps */\n.fairness-steps {\n  display: flex;\n  flex-direction: column;\n  gap: 1rem;\n  margin-top: 1rem;\n}\n\n.step {\n  display: flex;\n  gap: 1rem;\n  align-items: flex-start;\n}\n\n.step-num {\n  width: 28px;\n  height: 28px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--color-neon-pink);\n  color: var(--color-bg);\n  font-size: 0.875rem;\n  font-weight: bold;\n  flex-shrink: 0;\n  box-shadow: none;\n}\n\n.step-content {\n  flex: 1;\n}\n\n.step-content strong {\n  font-size: 0.875rem;\n  color: var(--color-text);\n  display: block;\n  margin-bottom: 0.25rem;\n}\n\n.step-content p {\n  font-size: 1rem;\n  margin: 0;\n}\n\n/* Formula Box */\n.formula-box {\n  background: var(--color-bg);\n  border: 2px solid var(--color-neon-purple);\n  box-shadow: none;\n  padding: 1rem;\n  margin-top: 1rem;\n  text-align: center;\n}\n\n.formula-box code {\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n  color: var(--color-neon-purple);\n  word-break: break-all;\n  text-shadow: none;\n}\n\n/* Guarantees */\n.guarantees {\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n  margin-top: 1rem;\n}\n\n.guarantee {\n  display: flex;\n  align-items: flex-start;\n  gap: 0.75rem;\n}\n\n.check-icon {\n  color: var(--color-neon-green);\n  font-size: 0.875rem;\n  flex-shrink: 0;\n  text-shadow: none;\n}\n\n.guarantee span:last-child {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  line-height: 1.6;\n}\n\n/* Verify Section */\n.fairness-verify {\n  display: flex;\n  flex-direction: column;\n  gap: 2rem;\n}\n\n.verify-section {\n  padding-bottom: 1.5rem;\n  border-bottom: 1px solid var(--color-surface-elevated);\n}\n\n.verify-section:last-child {\n  padding-bottom: 0;\n  border-bottom: none;\n}\n\n.verify-section h3 {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  margin-bottom: 0.5rem;\n  text-shadow: none;\n}\n\n.verify-section > p {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  margin-bottom: 1rem;\n}\n\n/* Form */\n.verify-form {\n  display: flex;\n  flex-direction: column;\n  gap: 1rem;\n}\n\n.form-group {\n  display: flex;\n  flex-direction: column;\n  gap: 0.375rem;\n}\n\n.form-group label {\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n}\n\n.form-row {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 1rem;\n}\n\n.verify-input {\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n  background: var(--color-bg);\n  color: var(--color-text);\n  border: 2px solid var(--color-text-muted);\n  padding: 0.625rem 0.75rem;\n  width: 100%;\n  transition: all 0.2s;\n}\n\n.verify-input:focus {\n  outline: none;\n  border-color: var(--color-neon-cyan);\n  box-shadow: none;\n}\n\n.verify-input::placeholder {\n  color: var(--color-text-muted);\n}\n\n.verify-select {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  background: var(--color-bg);\n  color: var(--color-text);\n  border: 2px solid var(--color-text-muted);\n  padding: 0.625rem 0.75rem;\n  width: 100%;\n  cursor: pointer;\n}\n\n.verify-select:focus {\n  outline: none;\n  border-color: var(--color-neon-cyan);\n  box-shadow: none;\n}\n\n/* Verify Buttons */\n.verify-buttons {\n  display: flex;\n  gap: 1rem;\n  margin-top: 0.5rem;\n}\n\n.verify-action-btn {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  padding: 0.75rem 1.25rem;\n  border: 2px solid var(--color-neon-cyan);\n  background: transparent;\n  color: var(--color-neon-cyan);\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n}\n\n.verify-action-btn:hover {\n  background: var(--color-neon-cyan);\n  color: var(--color-bg);\n  box-shadow: none;\n}\n\n.verify-action-btn.primary {\n  background: linear-gradient(135deg, var(--color-neon-pink) 0%, var(--color-neon-magenta) 100%);\n  border-color: var(--color-neon-pink);\n  color: var(--color-text);\n  box-shadow: none;\n}\n\n.verify-action-btn.primary:hover {\n  box-shadow: none;\n}\n\n/* Verification Result */\n.verification-result {\n  padding: 1rem;\n  margin-top: 1rem;\n  border: 2px solid;\n}\n\n.verification-result.valid {\n  border-color: var(--color-neon-green);\n  background: rgba(0, 255, 136, 0.1);\n  box-shadow: none;\n}\n\n.verification-result.invalid {\n  border-color: var(--color-error);\n  background: rgba(255, 0, 84, 0.1);\n  box-shadow: none;\n}\n\n.result-status {\n  display: flex;\n  align-items: flex-start;\n  gap: 0.75rem;\n}\n\n.status-icon {\n  font-size: 1rem;\n  line-height: 1;\n}\n\n.status-icon.valid {\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.status-icon.invalid {\n  color: var(--color-error);\n  text-shadow: none;\n}\n\n.status-text {\n  font-size: 0.875rem;\n  color: var(--color-text);\n  line-height: 1.6;\n  word-break: break-all;\n}\n\n.result-value {\n  margin-top: 1rem;\n  padding-top: 1rem;\n  border-top: 1px solid var(--color-surface-elevated);\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n}\n\n.result-label {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n}\n\n.crash-point {\n  font-size: 1.375rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n/* Quick Lookup */\n.quick-lookup {\n  display: flex;\n  gap: 0.75rem;\n}\n\n.quick-lookup .verify-input {\n  flex: 1;\n}\n\n.lookup-btn {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  padding: 0.625rem 1rem;\n  background: var(--color-surface-elevated);\n  color: var(--color-text);\n  border: 2px solid var(--color-text-muted);\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n}\n\n.lookup-btn:hover {\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n  box-shadow: none;\n}\n\n/* Seeds Section */\n.fairness-seeds h3,\n.fairness-history h3 {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  margin-bottom: 0.5rem;\n  text-shadow: none;\n}\n\n.fairness-seeds > p,\n.fairness-history > p {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  margin-bottom: 1.5rem;\n}\n\n/* Seeds Table */\n.seeds-table,\n.history-table {\n  border: 2px solid var(--color-surface-elevated);\n}\n\n.seeds-header,\n.history-header {\n  display: grid;\n  gap: 0.5rem;\n  padding: 0.75rem 1rem;\n  background: var(--color-bg);\n  border-bottom: 2px solid var(--color-surface-elevated);\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.seeds-header {\n  grid-template-columns: 1fr 0.5fr 2fr 0.75fr 0.5fr;\n}\n\n.history-header {\n  grid-template-columns: 0.75fr 1fr 1fr 1fr 0.75fr 0.75fr;\n}\n\n.seed-row,\n.history-row {\n  display: grid;\n  gap: 0.5rem;\n  padding: 0.75rem 1rem;\n  border-bottom: 1px solid var(--color-surface-elevated);\n  font-size: 0.875rem;\n  align-items: center;\n}\n\n.seed-row {\n  grid-template-columns: 1fr 0.5fr 2fr 0.75fr 0.5fr;\n}\n\n.history-row {\n  grid-template-columns: 0.75fr 1fr 1fr 1fr 0.75fr 0.75fr;\n}\n\n.seed-row:last-child,\n.history-row:last-child {\n  border-bottom: none;\n}\n\n.seed-game,\n.round-game {\n  color: var(--color-text);\n}\n\n.seed-tier {\n  color: var(--color-text-dim);\n}\n\n.seed-hash,\n.round-commitment {\n  font-family: var(--font-mono);\n  color: var(--color-text-muted);\n  font-size: 1rem;\n}\n\n.seed-status {\n  font-size: 1rem;\n  text-transform: uppercase;\n  padding: 0.25rem 0.5rem;\n  text-align: center;\n}\n\n.seed-status.active {\n  background: rgba(0, 255, 136, 0.2);\n  color: var(--color-neon-green);\n  box-shadow: none;\n}\n\n.seed-status.betting {\n  background: rgba(255, 215, 0, 0.2);\n  color: #ffd700;\n  box-shadow: none;\n}\n\n.seed-time {\n  font-family: var(--font-mono);\n  color: var(--color-text);\n}\n\n.round-id {\n  font-family: var(--font-mono);\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.round-result {\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.round-status {\n  font-size: 1rem;\n  text-transform: uppercase;\n  padding: 0.25rem 0.5rem;\n  text-align: center;\n}\n\n.round-status.verified {\n  background: rgba(0, 255, 136, 0.2);\n  color: var(--color-neon-green);\n}\n\n.round-status.pending {\n  background: rgba(249, 240, 2, 0.2);\n  color: var(--color-warning);\n}\n\n.round-verify-btn {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  padding: 0.375rem 0.625rem;\n  background: transparent;\n  color: var(--color-neon-cyan);\n  border: 1px solid var(--color-neon-cyan);\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n}\n\n.round-verify-btn:hover {\n  background: var(--color-neon-cyan);\n  color: var(--color-bg);\n  box-shadow: none;\n}\n\n/* Seeds Info */\n.seeds-info {\n  margin-top: 1.5rem;\n  padding: 1rem;\n  background: var(--color-bg);\n  border: 1px solid var(--color-surface-elevated);\n}\n\n.seeds-info h4 {\n  font-size: 0.875rem;\n  color: var(--color-text);\n  margin-bottom: 0.5rem;\n}\n\n.seeds-info p {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  line-height: 1.8;\n}\n\n/* History Pagination */\n.history-pagination {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 1rem;\n  margin-top: 1.5rem;\n}\n\n.page-btn {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  padding: 0.5rem 0.75rem;\n  background: var(--color-surface-elevated);\n  color: var(--color-text);\n  border: 1px solid var(--color-text-muted);\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n}\n\n.page-btn:hover:not(:disabled) {\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n  box-shadow: none;\n}\n\n.page-btn:disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n}\n\n.page-info {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n/* Fairness Page Responsive */\n@media (max-width: 768px) {\n  .fairness-page {\n    padding: 1rem;\n  }\n\n  .fairness-tabs {\n    flex-wrap: wrap;\n  }\n\n  .form-row {\n    grid-template-columns: 1fr;\n  }\n\n  .verify-buttons {\n    flex-direction: column;\n  }\n\n  .seeds-header,\n  .seed-row {\n    grid-template-columns: 1fr 1fr;\n    gap: 0.5rem;\n  }\n\n  .seed-hash {\n    grid-column: span 2;\n  }\n\n  .history-header,\n  .history-row {\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 0.5rem;\n  }\n\n  .round-commitment {\n    display: none;\n  }\n}\n\n/* ============ Utility Classes ============ */\n.pulse {\n  animation: pulse 2s ease-in-out infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.6; }\n}\n\n.glow-text-pink {\n  text-shadow: none;\n}\n\n.glow-text-cyan {\n  text-shadow: none;\n}\n\n.glow-text-green {\n  text-shadow: none;\n}\n\n/* ============ Responsive Design ============ */\n@media (max-width: 768px) {\n  .header-top {\n    flex-wrap: wrap;\n    gap: 0.75rem;\n    padding: 0.75rem 1rem;\n  }\n\n  .header-nav {\n    overflow-x: auto;\n    padding: 0 1rem;\n    -webkit-overflow-scrolling: touch;\n  }\n\n  .header-nav a {\n    font-size: 0.875rem;\n    padding: 0.5rem 0.75rem;\n    white-space: nowrap;\n  }\n\n  .header-blessing {\n    order: 3;\n    width: 100%;\n    justify-content: center;\n  }\n\n  .games-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .main {\n    padding: 1rem;\n  }\n\n  .stats-bar {\n    flex-wrap: wrap;\n    gap: 1rem;\n    padding: 0.75rem 1rem;\n  }\n\n  .stat-divider {\n    display: none;\n  }\n\n  .chat-section {\n    left: 0.5rem;\n  }\n\n  .chat-panel.expanded {\n    width: 280px;\n    height: calc(100vh - 8.2rem - 4rem);\n  }\n\n  /* Hide shooting stars on mobile */\n  .shooting-star {\n    display: none;\n  }\n}\n\n/* ============ Coinflip Game ============ */\n\n/* Center the game title for Coinflip */\n.rng-game-layout:has(.coinflip-main) .rng-game-layout__header {\n  justify-content: center;\n}\n\n.rng-game-layout:has(.coinflip-main) .rng-game-layout__title-section {\n  text-align: center;\n}\n\n/* Main Container */\n.coinflip-main {\n  display: flex;\n  flex-direction: column;\n  align-items: stretch;\n  min-height: 400px;\n  padding: 1rem 0;\n  width: 100%;\n}\n\n.coinflip-lobby {\n  width: 100%;\n}\n\n/* Side Selector */\n.coinflip-side-selector {\n  display: flex;\n  gap: 1rem;\n  margin: 0.5rem 0;\n}\n\n.coinflip-side-btn {\n  flex: 1;\n  padding: 1.25rem 1rem;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  cursor: pointer;\n  transition: all 0.2s;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.5rem;\n  font-family: var(--font-pixel);\n}\n\n.coinflip-side-btn--heads {\n  --btn-color: #00cc88;\n}\n\n.coinflip-side-btn--tails {\n  --btn-color: #ff6644;\n}\n\n.coinflip-side-btn:hover:not(:disabled) {\n  border-color: var(--btn-color);\n  box-shadow: none;\n}\n\n.coinflip-side-btn--selected {\n  border-color: var(--btn-color);\n  box-shadow: 1px 1px 0 var(--btn-color);\n  background: rgba(0, 204, 136, 0.1);\n}\n\n.coinflip-side-btn--selected.coinflip-side-btn--tails {\n  background: rgba(255, 102, 68, 0.1);\n}\n\n.coinflip-side-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.coinflip-side-btn__icon {\n  width: 48px;\n  height: 48px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.coinflip-side-btn__label {\n  font-size: 0.875rem;\n  color: var(--btn-color);\n  text-transform: uppercase;\n}\n\n/* RNG Pixel Art */\n.rng-pixel-art {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.rng-pixel-art__text {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  font-weight: bold;\n  letter-spacing: 0.05em;\n  text-shadow:\n    1px 1px 0 rgba(0, 0, 0, 0.5),\n    -1px -1px 0 rgba(255, 255, 255, 0.2);\n}\n\n.rng-pixel-art--heads .rng-pixel-art__text {\n  color: #001a0d;\n  text-shadow:\n    0 0 8px rgba(0, 255, 170, 0.8),\n    1px 1px 0 rgba(0, 0, 0, 0.5);\n}\n\n.rng-pixel-art--tails .rng-pixel-art__text {\n  color: #1a0500;\n  text-shadow:\n    0 0 8px rgba(255, 170, 100, 0.8),\n    1px 1px 0 rgba(0, 0, 0, 0.5);\n}\n\n/* Coin Animation */\n.coinflip-coin-container {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1rem;\n  perspective: 1000px;\n}\n\n.coinflip-coin {\n  position: relative;\n  transform-style: preserve-3d;\n  transition: transform 0.3s ease-out;\n}\n\n.coinflip-coin--sm {\n  width: 80px;\n  height: 80px;\n}\n\n.coinflip-coin--md {\n  width: 120px;\n  height: 120px;\n}\n\n.coinflip-coin--lg {\n  width: 160px;\n  height: 160px;\n}\n\n.coinflip-coin__face {\n  position: absolute;\n  width: 100%;\n  height: 100%;\n  backface-visibility: hidden;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.coinflip-coin__face--heads {\n  /* default front face */\n}\n\n.coinflip-coin__face--tails {\n  transform: rotateY(180deg);\n}\n\n.coinflip-coin__letter,\n.coinflip-coin__rng {\n  font-size: 1.75rem;\n  font-weight: bold;\n  font-family: var(--font-pixel);\n  letter-spacing: 0.05em;\n}\n\n.coinflip-coin__rng--heads {\n  color: #001a0d;\n  text-shadow:\n    0 0 10px rgba(0, 255, 170, 0.8),\n    2px 2px 0 rgba(0, 0, 0, 0.3);\n}\n\n.coinflip-coin__rng--tails {\n  color: #1a0500;\n  text-shadow:\n    0 0 10px rgba(255, 170, 100, 0.8),\n    2px 2px 0 rgba(0, 0, 0, 0.3);\n}\n\n.coinflip-coin--lg .coinflip-coin__letter,\n.coinflip-coin--lg .coinflip-coin__rng {\n  font-size: 2.5rem;\n}\n\n.coinflip-coin--tails {\n  transform: rotateY(180deg);\n}\n\n/* Explicit animation classes - use these instead of relying on CSS specificity */\n.coinflip-coin--spinning-heads {\n  animation: coinflip-spin-heads 3s cubic-bezier(0.17, 0.67, 0.12, 0.99) forwards !important;\n}\n\n.coinflip-coin--spinning-tails {\n  animation: coinflip-spin-tails 3s cubic-bezier(0.17, 0.67, 0.12, 0.99) forwards !important;\n}\n\n@keyframes coinflip-spin-heads {\n  0% { transform: rotateY(0deg) scale(1); }\n  50% { transform: rotateY(900deg) scale(1.1); }\n  100% { transform: rotateY(1800deg) scale(1); }\n}\n\n@keyframes coinflip-spin-tails {\n  0% { transform: rotateY(0deg) scale(1); }\n  50% { transform: rotateY(900deg) scale(1.1); }\n  100% { transform: rotateY(1980deg) scale(1); }\n}\n\n.coinflip-coin__result {\n  font-size: 1.25rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n}\n\n/* Match Card */\n.coinflip-match-card {\n  display: grid;\n  grid-template-columns: 1fr auto 1fr;\n  align-items: center;\n  padding: 1rem;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  transition: all 0.2s;\n  margin-bottom: 0.5rem;\n  gap: 1rem;\n}\n\n.coinflip-match-card:hover {\n  border-color: var(--color-neon-pink);\n  box-shadow: none;\n}\n\n.coinflip-match-card--own {\n  border-color: var(--color-neon-cyan);\n  background: rgba(0, 255, 136, 0.05);\n}\n\n.coinflip-match-card__creator {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  min-width: 0;\n}\n\n.coinflip-match-card__avatar {\n  width: 32px;\n  height: 32px;\n  border-radius: 50%;\n  background: var(--color-surface-elevated);\n  border: 1px solid var(--color-neon-cyan);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 0.875rem;\n  font-family: var(--font-mono);\n  color: var(--color-neon-cyan);\n}\n\n.coinflip-match-card__info {\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n  min-width: 0;\n}\n\n.coinflip-match-card__address {\n  font-size: 1rem;\n  font-family: var(--font-mono);\n  color: var(--color-text);\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  max-width: 150px;\n}\n\n.coinflip-match-card__you {\n  color: var(--color-neon-cyan);\n  font-size: 0.875rem;\n}\n\n.coinflip-match-card__time {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n}\n\n.coinflip-match-card__bet {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.coinflip-match-card__side {\n  width: 32px;\n  height: 32px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 1rem;\n  font-weight: bold;\n  font-family: var(--font-pixel);\n}\n\n.coinflip-match-card__side--heads {\n  background: linear-gradient(135deg, #00cc88 0%, #009966 100%);\n  border: 2px solid #00cc88;\n  box-shadow: none;\n}\n\n.coinflip-match-card__side--tails {\n  background: linear-gradient(135deg, #ff6644 0%, #cc4422 100%);\n  border: 2px solid #ff6644;\n  box-shadow: none;\n}\n\n.coinflip-match-card__rng {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  font-weight: bold;\n  letter-spacing: 0.02em;\n}\n\n.coinflip-match-card__side--heads .coinflip-match-card__rng {\n  color: #001a0d;\n  text-shadow: 0 0 4px rgba(0, 255, 170, 0.6);\n}\n\n.coinflip-match-card__side--tails .coinflip-match-card__rng {\n  color: #1a0500;\n  text-shadow: 0 0 4px rgba(255, 170, 100, 0.6);\n}\n\n.coinflip-match-card__amount {\n  font-size: 1rem;\n  color: var(--color-neon-green);\n  font-family: var(--font-mono);\n}\n\n.coinflip-match-card__tier {\n  font-size: 1rem;\n  text-transform: uppercase;\n  color: var(--color-text-muted);\n}\n\n.coinflip-match-card__actions {\n  display: flex;\n  justify-content: flex-end;\n  align-items: center;\n}\n\n.coinflip-match-card__join-btn {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  padding: 0.5rem 1rem;\n  background: linear-gradient(135deg, var(--color-neon-pink) 0%, var(--color-neon-magenta) 100%);\n  border: none;\n  color: white;\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n}\n\n.coinflip-match-card__join-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: scale(1.05);\n}\n\n.coinflip-match-card__join-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.coinflip-match-card__status {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  font-family: var(--font-pixel);\n  text-transform: uppercase;\n}\n\n/* Open Matches List */\n.coinflip-matches {\n  width: 100%;\n}\n\n.coinflip-matches--loading,\n.coinflip-matches--empty {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  padding: 3rem;\n  text-align: center;\n}\n\n.coinflip-matches__spinner {\n  width: 48px;\n  height: 48px;\n  border: 2px solid var(--color-neon-cyan);\n  border-top-color: transparent;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n  margin-bottom: 1rem;\n}\n\n@keyframes spin {\n  to { transform: rotate(360deg); }\n}\n\n.coinflip-matches__empty-text {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  margin-bottom: 0.5rem;\n}\n\n.coinflip-matches__empty-hint {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  opacity: 0.7;\n}\n\n.coinflip-matches__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 1rem;\n  padding-bottom: 0.5rem;\n  border-bottom: 1px solid var(--color-border);\n}\n\n.coinflip-matches__title {\n  font-size: 0.875rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-cyan);\n  margin: 0;\n}\n\n.coinflip-matches__count {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n}\n\n/* Sidebar */\n.coinflip-sidebar {\n  display: flex;\n  flex-direction: column;\n  gap: 1.5rem;\n  min-width: 0;\n  word-break: break-word;\n}\n\n.coinflip-sidebar__title {\n  font-size: 0.875rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-pink);\n  margin: 0 0 0.5rem 0;\n  text-transform: uppercase;\n}\n\n.coinflip-sidebar__section {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.coinflip-sidebar__label {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.coinflip-sidebar__sol-icon {\n  width: 16px;\n  height: 16px;\n  filter: brightness(0) saturate(100%) invert(75%) sepia(61%) saturate(1500%) hue-rotate(100deg) brightness(100%) contrast(104%);\n}\n\n.coinflip-sidebar__label-row {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 0.5rem;\n}\n\n.coinflip-sidebar__all-btn {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: transparent;\n  border: 1px solid var(--color-text-muted);\n  color: var(--color-text-muted);\n  padding: 0.25rem 0.5rem;\n  cursor: pointer;\n  text-transform: uppercase;\n  transition: all 0.2s;\n}\n\n.coinflip-sidebar__all-btn:hover {\n  border-color: var(--color-text);\n  color: var(--color-text);\n}\n\n.coinflip-sidebar__all-btn--active {\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n  box-shadow: none;\n}\n\n.coinflip-sidebar__summary {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.coinflip-sidebar__row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 1rem;\n  gap: 0.5rem;\n}\n\n.coinflip-sidebar__row > span:first-child {\n  color: var(--color-text-muted);\n  flex-shrink: 0;\n}\n\n.coinflip-sidebar__row > span:last-child {\n  text-align: right;\n  font-family: var(--font-pixel);\n}\n\n.coinflip-sidebar__payout {\n  color: var(--color-neon-green);\n  font-weight: bold;\n}\n\n.coinflip-sidebar__tier {\n  text-transform: uppercase;\n  color: var(--color-neon-yellow);\n}\n\n.coinflip-sidebar__status {\n  color: var(--color-neon-cyan);\n}\n\n.coinflip-sidebar__game-info {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n}\n\n.coinflip-sidebar__pot {\n  color: var(--color-neon-green);\n  text-shadow: none;\n  font-weight: bold;\n}\n\n/* Round Fairness Section */\n.coinflip-sidebar__fairness {\n  padding: 0.75rem;\n  background: rgba(20, 20, 35, 0.6);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  margin-top: 0.75rem;\n}\n\n.coinflip-sidebar__fairness-title {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin: 0 0 0.5rem 0;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.coinflip-sidebar__fairness-title::before {\n  content: \"🔒\";\n  font-size: 1rem;\n}\n\n.coinflip-sidebar__fairness-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 0.875rem;\n  padding: 0.25rem 0;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.coinflip-sidebar__fairness-row:last-child {\n  border-bottom: none;\n}\n\n.coinflip-sidebar__fairness-row > span:first-child {\n  color: var(--color-text-muted);\n}\n\n.coinflip-sidebar__hash {\n  font-family: var(--font-mono);\n  color: #888;\n  cursor: pointer;\n  padding: 0.125rem 0.25rem;\n  background: rgba(0, 0, 0, 0.3);\n  border-radius: 2px;\n  transition: all 0.2s ease;\n}\n\n.coinflip-sidebar__hash:hover {\n  color: var(--color-neon-pink);\n  background: rgba(255, 0, 128, 0.1);\n}\n\n.coinflip-sidebar__hash--revealed {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n}\n\n.coinflip-sidebar__verify-link {\n  display: block;\n  margin-top: 0.5rem;\n  font-size: 0.75rem;\n  color: #38bdf8;\n  text-decoration: none;\n  text-align: right;\n}\n.coinflip-sidebar__verify-link:hover {\n  text-decoration: underline;\n}\n\n/* Action Button */\n.coinflip-action-btn {\n  width: 100%;\n  padding: 1rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  text-transform: uppercase;\n  background: linear-gradient(135deg, var(--color-neon-pink) 0%, var(--color-neon-magenta) 100%);\n  border: none;\n  color: white;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.coinflip-action-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: translateY(-2px);\n}\n\n.coinflip-action-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n  transform: none;\n}\n\n.coinflip-action-btn--secondary {\n  background: var(--color-surface);\n  border: 2px solid var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n}\n\n.coinflip-action-btn--secondary:hover:not(:disabled) {\n  box-shadow: none;\n}\n\n/* Active Match View */\n.coinflip-active-match {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.5rem;\n  padding: 2rem;\n  text-align: center;\n}\n\n.coinflip-active-match__title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n  margin: 0 0 1rem 0;\n  text-transform: uppercase;\n}\n\n.coinflip-active-match__title--won {\n  color: var(--color-neon-green);\n  text-shadow: none;\n  font-size: 1.5rem;\n}\n\n.coinflip-active-match__title--lost {\n  color: #ff4444;\n  text-shadow: none;\n  font-size: 1.5rem;\n}\n\n.coinflip-active-match__info {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n  font-size: 0.875rem;\n}\n\n.coinflip-active-match__info strong:not([class*=\"side-\"]) {\n  color: var(--color-neon-yellow);\n}\n\n.coinflip-active-match__hint {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.coinflip-waiting__spinner {\n  width: 64px;\n  height: 64px;\n  border: 2px solid var(--color-neon-cyan);\n  border-top-color: transparent;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n  margin: 1rem 0;\n}\n\n/* Players Display */\n.coinflip-active-match__players {\n  display: flex;\n  align-items: center;\n  gap: 2rem;\n  margin: 1rem 0;\n}\n\n.coinflip-player {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.coinflip-player__label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  font-family: var(--font-mono);\n}\n\n.coinflip-player--you .coinflip-player__label {\n  color: var(--color-neon-cyan);\n}\n\n.coinflip-player__side {\n  font-size: 1.25rem;\n  font-family: var(--font-pixel);\n  font-weight: bold;\n}\n\n.coinflip-active-match__vs {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-pink);\n  text-shadow: none;\n}\n\n/* Countdown */\n.coinflip-countdown {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  margin: 1.5rem 0;\n  gap: 0.5rem;\n}\n\n.coinflip-countdown__text {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n}\n\n.coinflip-countdown__number {\n  font-family: var(--font-pixel);\n  font-size: 5rem;\n  font-weight: bold;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n  animation: countdown-pulse 1s ease-in-out infinite;\n}\n\n@keyframes countdown-pulse {\n  0%, 100% { transform: scale(1); opacity: 1; }\n  50% { transform: scale(1.1); opacity: 0.8; }\n}\n\n/* Inline countdown (in title) */\n.coinflip-countdown-inline {\n  display: inline-flex;\n  align-items: baseline;\n  gap: 0.5rem;\n}\n\n.coinflip-countdown-inline__number {\n  font-size: inherit;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n  animation: countdown-pulse 1s ease-in-out infinite;\n}\n\n.coinflip-active-match__pot {\n  font-size: 0.875rem;\n  color: var(--color-text);\n  margin-top: 1.5rem;\n}\n\n.coinflip-active-match__pot strong {\n  color: var(--color-neon-green);\n  font-size: 1rem;\n}\n\n/* Side colors */\n.side-heads {\n  color: #00cc88;\n  text-shadow: none;\n}\n\n.side-tails {\n  color: #ff6644;\n  text-shadow: none;\n}\n\n/* Result */\n.coinflip-result {\n  padding: 1.5rem;\n  text-align: center;\n}\n\n.coinflip-result__title {\n  font-family: var(--font-pixel);\n  font-size: 1.5rem;\n  margin: 0 0 1rem 0;\n  text-transform: uppercase;\n}\n\n.coinflip-result--won .coinflip-result__title {\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.coinflip-result--lost .coinflip-result__title {\n  color: #d45d5d;\n  text-shadow: none;\n}\n\n.coinflip-result__outcome {\n  font-size: 0.875rem;\n  margin: 0.5rem 0;\n}\n\n.coinflip-result__outcome strong {\n  color: var(--color-neon-cyan);\n}\n\n.coinflip-result__payout {\n  font-size: 1rem;\n  color: var(--color-neon-green);\n  margin: 0.5rem 0;\n}\n\n.coinflip-result__payout strong {\n  font-size: 1.25rem;\n}\n\n.coinflip-result__breakdown {\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n  margin-top: 0.75rem;\n  padding: 0.5rem 0.75rem;\n  border-radius: 6px;\n  background: rgba(255, 255, 255, 0.03);\n  font-size: 0.8rem;\n}\n\n.coinflip-result__breakdown-row {\n  display: flex;\n  justify-content: space-between;\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.coinflip-result__breakdown-row--muted {\n  color: rgba(255, 255, 255, 0.4);\n  font-size: 0.75rem;\n}\n\n.coinflip-claim-btn {\n  margin-top: 1.5rem;\n  padding: 1rem 2rem;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  background: linear-gradient(135deg, var(--color-neon-green) 0%, #39cc14 100%);\n  border: none;\n  color: #000;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.coinflip-claim-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: scale(1.05);\n}\n\n.coinflip-claim-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.coinflip-claimed-text {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  margin-top: 1rem;\n}\n\n/* Coinflip History Result */\n.coinflip-history-result {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.35rem;\n  font-size: 1rem;\n  font-weight: 600;\n}\n\n.coinflip-history-result__separator {\n  color: rgba(255, 255, 255, 0.3);\n  font-weight: 400;\n}\n\n/* ========== Win Animation - Star Burst ========== */\n.coinflip-win-animation {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  pointer-events: none;\n  z-index: 10;\n}\n\n.coinflip-win-animation__stars {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.coinflip-win-animation__star {\n  position: absolute;\n  font-size: 2rem;\n  color: var(--color-neon-yellow, #ffff00);\n  text-shadow: 0 0 10px var(--color-neon-yellow, #ffff00), 0 0 20px var(--color-neon-yellow, #ffff00);\n  animation: star-burst 1.5s ease-out forwards;\n  animation-delay: calc(var(--star-index) * 0.05s);\n  opacity: 0;\n}\n\n.coinflip-win-animation__star:nth-child(1) { --angle: 0deg; }\n.coinflip-win-animation__star:nth-child(2) { --angle: 45deg; }\n.coinflip-win-animation__star:nth-child(3) { --angle: 90deg; }\n.coinflip-win-animation__star:nth-child(4) { --angle: 135deg; }\n.coinflip-win-animation__star:nth-child(5) { --angle: 180deg; }\n.coinflip-win-animation__star:nth-child(6) { --angle: 225deg; }\n.coinflip-win-animation__star:nth-child(7) { --angle: 270deg; }\n.coinflip-win-animation__star:nth-child(8) { --angle: 315deg; }\n\n@keyframes star-burst {\n  0% {\n    opacity: 1;\n    transform: rotate(var(--angle)) translateY(0) scale(0.5);\n  }\n  50% {\n    opacity: 1;\n  }\n  100% {\n    opacity: 0;\n    transform: rotate(var(--angle)) translateY(-120px) scale(1.2);\n  }\n}\n\n.coinflip-win-animation__coins {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.coinflip-win-animation__coin {\n  position: absolute;\n  font-size: 1.5rem;\n  color: var(--color-gold, #ffd700);\n  text-shadow: 0 0 8px var(--color-gold, #ffd700), 0 0 16px #ff9900;\n  animation: coin-fountain 1.8s ease-out forwards;\n  animation-delay: calc(var(--coin-index) * 0.1s);\n  opacity: 0;\n}\n\n.coinflip-win-animation__coin:nth-child(1) { --coin-x: -60px; }\n.coinflip-win-animation__coin:nth-child(2) { --coin-x: -30px; }\n.coinflip-win-animation__coin:nth-child(3) { --coin-x: 0px; }\n.coinflip-win-animation__coin:nth-child(4) { --coin-x: 30px; }\n.coinflip-win-animation__coin:nth-child(5) { --coin-x: 60px; }\n.coinflip-win-animation__coin:nth-child(6) { --coin-x: 0px; }\n\n@keyframes coin-fountain {\n  0% {\n    opacity: 1;\n    transform: translateX(var(--coin-x)) translateY(0) scale(0.5);\n  }\n  30% {\n    opacity: 1;\n    transform: translateX(var(--coin-x)) translateY(-80px) scale(1);\n  }\n  100% {\n    opacity: 0;\n    transform: translateX(var(--coin-x)) translateY(60px) scale(0.8);\n  }\n}\n\n/* ========== Lose Animation - Inline Broken Heart ========== */\n.coinflip-lose-title {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  position: relative;\n}\n\n.coinflip-lose-title__heart {\n  display: inline;\n  font-size: 1.2rem;\n  vertical-align: middle;\n  opacity: 0.75;\n  filter: saturate(0.7);\n}\n\n.coinflip-lose-title__shards {\n  position: absolute;\n  top: 50%;\n  right: -0.5rem;\n  transform: translateY(-50%);\n  pointer-events: none;\n}\n\n.coinflip-lose-title__shard {\n  position: absolute;\n  font-size: 1rem;\n  color: #d45d5d;\n  text-shadow: 0 0 4px #d45d5d;\n  animation: shard-fall-inline 1.5s ease-out forwards;\n  animation-delay: calc(0.6s + var(--shard-index) * 0.08s);\n  opacity: 0;\n}\n\n.coinflip-lose-title__shard:nth-child(1) { --shard-x: -20px; --shard-y: 25px; --shard-rot: -45deg; }\n.coinflip-lose-title__shard:nth-child(2) { --shard-x: -5px; --shard-y: 35px; --shard-rot: 30deg; }\n.coinflip-lose-title__shard:nth-child(3) { --shard-x: 8px; --shard-y: 30px; --shard-rot: -60deg; }\n.coinflip-lose-title__shard:nth-child(4) { --shard-x: 18px; --shard-y: 28px; --shard-rot: 45deg; }\n.coinflip-lose-title__shard:nth-child(5) { --shard-x: 0px; --shard-y: 40px; --shard-rot: 0deg; }\n\n@keyframes shard-fall-inline {\n  0% {\n    opacity: 1;\n    transform: translateX(0) translateY(0) rotate(0deg) scale(1);\n  }\n  100% {\n    opacity: 0;\n    transform: translateX(var(--shard-x)) translateY(var(--shard-y)) rotate(var(--shard-rot)) scale(0.5);\n  }\n}\n\n/* Slot progress bar — fairness indicator during flip animation */\n.slot-progress {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 6px;\n  width: 100%;\n  max-width: 220px;\n  margin: 0 auto;\n}\n\n.slot-progress__bar-track {\n  width: 100%;\n  height: 3px;\n  background: rgba(255, 255, 255, 0.08);\n  border-radius: 2px;\n  overflow: hidden;\n}\n\n.slot-progress__bar-fill {\n  height: 100%;\n  background: rgba(0, 204, 136, 0.5);\n  border-radius: 2px;\n  transition: width 0.6s ease-out;\n}\n\n.slot-progress__bar-fill--complete {\n  background: rgba(0, 204, 136, 0.25);\n  animation: slot-pulse 1.5s ease-in-out infinite;\n}\n\n.slot-progress__label {\n  font-family: var(--font-mono, monospace);\n  font-size: 0.65rem;\n  color: rgba(255, 255, 255, 0.35);\n  letter-spacing: 0.03em;\n  user-select: none;\n}\n\n@keyframes slot-pulse {\n  0%, 100% { opacity: 0.4; }\n  50% { opacity: 0.8; }\n}\n\n/* Make the playing container position relative for animations */\n.coinflip-active-match__playing {\n  position: relative;\n}\n\n/* Coinflip Responsive */\n@media (max-width: 768px) {\n  .coinflip-active-match__players {\n    gap: 1rem;\n  }\n\n  .coinflip-coin--lg {\n    width: 120px;\n    height: 120px;\n  }\n\n  .coinflip-coin--lg .coinflip-coin__letter {\n    font-size: 3rem;\n  }\n\n  /* Prevent overlap with chat section on smaller screens */\n  .coinflip-main {\n    padding: 1rem;\n    min-height: 350px;\n  }\n\n  .coinflip-active-match {\n    gap: 1rem;\n    padding: 1rem;\n  }\n\n  .coinflip-active-match__title {\n    font-size: 0.875rem;\n  }\n\n  .coinflip-active-match__title--won,\n  .coinflip-active-match__title--lost {\n    font-size: 1.25rem;\n  }\n\n  .coinflip-result {\n    padding: 1rem;\n  }\n\n  /* Adjust high score panel on smaller screens */\n  .rng-high-score {\n    width: 200px;\n    right: 0.75rem;\n  }\n}\n\n/* Extra small screens */\n@media (max-width: 480px) {\n  .coinflip-active-match__title--won,\n  .coinflip-active-match__title--lost {\n    font-size: 1rem;\n  }\n\n  .coinflip-coin--lg {\n    width: 100px;\n    height: 100px;\n  }\n\n  /* Hide high score on very small screens */\n  .rng-high-score {\n    display: none;\n  }\n\n  .chat-section {\n    left: 0.5rem;\n  }\n\n  .chat-panel.expanded {\n    width: calc(100vw - 4rem);\n    height: calc(100vh - 8.2rem - 4rem);\n  }\n}\n\n/* ========================================\n   LORD OF THE RNGS STYLES\n   ======================================== */\n\n/* Main Layout */\n.lotr-main {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.5rem;\n  padding: 1rem;\n  height: 100%;\n}\n\n/* Center the game title and description for Lord of RNGs */\n.rng-game-layout:has(.lotr-main) .rng-game-layout__header {\n  justify-content: center;\n}\n\n.rng-game-layout:has(.lotr-main) .rng-game-layout__title-section {\n  text-align: center;\n}\n\n/* Tier Lobby */\n.lotr-tier-lobby {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.5rem;\n  width: 100%;\n}\n\n.lotr-tier-lobby__instruction {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-align: center;\n  margin: 0;\n}\n\n.lotr-tier-lobby__grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(280px, 400px));\n  gap: 1rem;\n  justify-content: center;\n  width: 100%;\n}\n\n.lotr-tier-lobby__loading {\n  text-align: center;\n  color: var(--color-text-muted);\n  padding: 2rem;\n}\n\n/* Tier Cards */\n.lotr-tier-card {\n  background: var(--color-surface);\n  border: 2px solid var(--color-border);\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n  cursor: pointer;\n  transition: all 0.2s;\n  text-align: left;\n}\n\n.lotr-tier-card:hover {\n  border-color: var(--tier-color);\n  box-shadow: none;\n}\n\n.lotr-tier-card--selected {\n  border-color: var(--tier-color);\n  box-shadow: none;\n}\n\n.lotr-tier-card--countdown {\n  animation: tier-pulse 1s ease-in-out infinite;\n}\n\n.lotr-tier-card--spinning {\n  border-color: var(--color-neon-yellow);\n  animation: tier-spin-glow 0.5s ease-in-out infinite alternate;\n}\n\n@keyframes tier-pulse {\n  0%, 100% { box-shadow: none; }\n  50% { box-shadow: none; }\n}\n\n@keyframes tier-spin-glow {\n  0% { box-shadow: none; }\n  100% { box-shadow: none; }\n}\n\n.lotr-tier-card__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.lotr-tier-card__name {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--tier-color);\n  text-transform: uppercase;\n  text-shadow: none;\n}\n\n.lotr-tier-card__amount {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  font-weight: bold;\n}\n\n.lotr-tier-card__stats {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 0.5rem;\n}\n\n.lotr-tier-card__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.lotr-tier-card__stat-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.lotr-tier-card__stat-value {\n  font-size: 1rem;\n  color: var(--color-text);\n  font-weight: bold;\n}\n\n.lotr-tier-card__phase {\n  text-align: center;\n  padding-top: 0.5rem;\n  border-top: 1px solid var(--color-border);\n}\n\n.lotr-tier-card__phase-text {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n/* Countdown Timer */\n.lotr-countdown {\n  display: flex;\n  flex-direction: row;\n  align-items: baseline;\n  gap: 0.5rem;\n}\n\n.lotr-countdown--small .lotr-countdown__time {\n  font-size: 1rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-cyan);\n}\n\n.lotr-countdown--large {\n  padding: 0.5rem;\n}\n\n.lotr-countdown--large .lotr-countdown__time {\n  font-size: 1.5rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.lotr-countdown__label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.lotr-countdown--urgent .lotr-countdown__time {\n  color: var(--color-neon-yellow);\n  text-shadow: none;\n}\n\n.lotr-countdown--final .lotr-countdown__time {\n  color: #ff4444;\n  text-shadow: none;\n  animation: countdown-pulse 0.5s ease-in-out infinite;\n}\n\n@keyframes countdown-pulse {\n  0%, 100% { transform: scale(1); }\n  50% { transform: scale(1.1); }\n}\n\n/* Horizontal Wheel Visualization */\n.lotr-hwheel {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.5rem;\n  width: 100%;\n  padding: 1rem 0;\n}\n\n/* THE ONE - Golden Arrow Indicator (Points Down) */\n.lotr-hwheel__indicator {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n  z-index: 20;\n}\n\n.lotr-hwheel__indicator-arrow {\n  width: 20px;\n  height: 12px;\n  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));\n}\n\n.lotr-hwheel__indicator-arrow svg {\n  width: 100%;\n  height: 100%;\n}\n\n.lotr-hwheel__indicator-label {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: #ffd700;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  text-shadow: 0 0 8px #ffd700;\n  margin-bottom: 2px;\n}\n\n/* Wheel Container - width set dynamically via JS based on visible slots */\n.lotr-hwheel__container {\n  position: relative;\n  /* Width is set via inline style: VISIBLE_SLOTS * SLOT_WIDTH */\n  height: 130px;\n  overflow: hidden;\n  background: linear-gradient(180deg,\n    rgba(20, 20, 35, 0.9) 0%,\n    rgba(10, 10, 20, 1) 30%,\n    rgba(10, 10, 20, 1) 70%,\n    rgba(20, 20, 35, 0.9) 100%\n  );\n  border: 2px solid var(--color-border);\n  border-radius: 2px;\n  box-shadow:\n    inset 0 5px 15px rgba(0, 0, 0, 0.5),\n    inset 0 -5px 15px rgba(0, 0, 0, 0.5),\n    0 4px 20px rgba(0, 0, 0, 0.3);\n}\n\n/* Scrolling Strip */\n.lotr-hwheel__strip {\n  display: flex;\n  position: absolute;\n  top: 0;\n  left: 0;\n  height: 100%;\n  will-change: transform;\n  backface-visibility: hidden;\n  -webkit-backface-visibility: hidden;\n}\n\n/* Individual Slot */\n.lotr-hwheel__slot {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  padding: 8px 4px;\n  box-sizing: border-box;\n}\n\n/* Slot Container - adds depth and separation */\n.lotr-hwheel__slot-container {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 0.4rem;\n  width: 74px; /* Fixed width for consistent slot sizes */\n  padding: 8px 6px;\n  background: linear-gradient(180deg,\n    rgba(50, 50, 70, 0.9) 0%,\n    rgba(30, 30, 50, 0.95) 30%,\n    rgba(25, 25, 40, 1) 50%,\n    rgba(30, 30, 50, 0.95) 70%,\n    rgba(50, 50, 70, 0.9) 100%\n  );\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  border-top-color: rgba(255, 255, 255, 0.25);\n  border-bottom-color: rgba(0, 0, 0, 0.4);\n  border-radius: 2px;\n  box-shadow:\n    inset 0 2px 3px rgba(255, 255, 255, 0.1),\n    inset 0 -2px 3px rgba(0, 0, 0, 0.4),\n    0 3px 8px rgba(0, 0, 0, 0.5),\n    0 1px 2px rgba(0, 0, 0, 0.3);\n}\n\n.lotr-hwheel__slot--you .lotr-hwheel__slot-container {\n  background: linear-gradient(180deg,\n    rgba(0, 255, 136, 0.2) 0%,\n    rgba(30, 45, 30, 0.95) 30%,\n    rgba(25, 35, 25, 1) 50%,\n    rgba(30, 45, 30, 0.95) 70%,\n    rgba(0, 255, 136, 0.2) 100%\n  );\n  border-color: rgba(0, 255, 136, 0.4);\n  border-top-color: rgba(0, 255, 136, 0.5);\n  box-shadow:\n    inset 0 2px 3px rgba(0, 255, 136, 0.15),\n    inset 0 -2px 3px rgba(0, 0, 0, 0.4),\n    0 3px 8px rgba(0, 0, 0, 0.5),\n    0 0 12px rgba(0, 255, 136, 0.15);\n}\n\n/* Winner slot */\n.lotr-hwheel__slot--winner .lotr-hwheel__slot-container {\n  background: linear-gradient(180deg,\n    rgba(255, 215, 0, 0.4) 0%,\n    rgba(60, 55, 25, 0.95) 30%,\n    rgba(50, 45, 20, 1) 50%,\n    rgba(60, 55, 25, 0.95) 70%,\n    rgba(255, 215, 0, 0.4) 100%\n  );\n  border: 2px solid #ffd700;\n  border-top-color: #ffe650;\n  box-shadow:\n    inset 0 2px 4px rgba(255, 215, 0, 0.3),\n    inset 0 -2px 4px rgba(0, 0, 0, 0.4),\n    0 0 20px rgba(255, 215, 0, 0.5),\n    0 0 40px rgba(255, 215, 0, 0.3);\n}\n\n.lotr-hwheel__slot--winner .lotr-hwheel__avatar {\n  animation: winner-avatar-pulse 0.5s ease-in-out infinite alternate;\n}\n\n@keyframes winner-avatar-pulse {\n  0% { transform: scale(1); }\n  100% { transform: scale(1.08); }\n}\n\n/* \"You\" slot avatar - green border for recognition */\n.lotr-hwheel__slot--you .lotr-hwheel__avatar {\n  border: 3px solid var(--color-neon-green);\n  box-shadow:\n    0 0 8px rgba(0, 255, 136, 0.4),\n    inset 0 2px 4px rgba(255, 255, 255, 0.2);\n}\n\n/* Player Avatar */\n.lotr-hwheel__avatar {\n  width: 48px;\n  height: 48px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  border: 2px solid rgba(255, 255, 255, 0.35);\n  border-top-color: rgba(255, 255, 255, 0.5);\n  border-bottom-color: rgba(0, 0, 0, 0.3);\n  box-shadow:\n    inset 0 4px 8px rgba(255, 255, 255, 0.25),\n    inset 0 -4px 8px rgba(0, 0, 0, 0.3),\n    0 4px 10px rgba(0, 0, 0, 0.5),\n    0 2px 4px rgba(0, 0, 0, 0.3);\n  position: relative;\n}\n\n/* Add glossy overlay effect to filled avatars */\n.lotr-hwheel__avatar::before {\n  content: '';\n  position: absolute;\n  top: 2px;\n  left: 10%;\n  right: 10%;\n  height: 40%;\n  background: linear-gradient(180deg,\n    rgba(255, 255, 255, 0.3) 0%,\n    rgba(255, 255, 255, 0.1) 50%,\n    transparent 100%\n  );\n  border-radius: 50% 50% 40% 40%;\n  pointer-events: none;\n}\n\n.lotr-hwheel__avatar-icon {\n  width: 26px;\n  height: 26px;\n  color: rgba(0, 0, 0, 0.65);\n  filter: drop-shadow(0 1px 1px rgba(255, 255, 255, 0.2));\n}\n\n.lotr-hwheel__avatar-placeholder {\n  font-size: 1.5rem;\n  font-family: var(--font-pixel);\n  color: rgba(100, 100, 130, 0.5);\n}\n\n.lotr-hwheel__slot-name {\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n  text-align: center;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  max-width: 70px;\n  font-weight: 500;\n}\n\n.lotr-hwheel__slot--you .lotr-hwheel__slot-name {\n  color: var(--color-neon-green);\n  font-weight: bold;\n  text-shadow: 0 0 6px var(--color-neon-green);\n}\n\n.lotr-hwheel__slot--winner .lotr-hwheel__slot-name {\n  color: #ffd700;\n  text-shadow: 0 0 6px #ffd700;\n}\n\n/* Empty placeholder slot */\n.lotr-hwheel__slot--empty .lotr-hwheel__slot-container {\n  background: linear-gradient(180deg,\n    rgba(30, 30, 45, 0.6) 0%,\n    rgba(20, 20, 35, 0.7) 50%,\n    rgba(30, 30, 45, 0.6) 100%\n  );\n  border-color: rgba(255, 255, 255, 0.05);\n  opacity: 0.6;\n}\n\n.lotr-hwheel__slot--empty .lotr-hwheel__avatar {\n  background: rgba(60, 60, 80, 0.5);\n  border-color: rgba(255, 255, 255, 0.1);\n  box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.3);\n}\n\n/* Remove glossy effect from empty slots */\n.lotr-hwheel__slot--empty .lotr-hwheel__avatar::before {\n  display: none;\n}\n\n.lotr-hwheel__slot--empty .lotr-hwheel__avatar-icon {\n  color: rgba(150, 150, 180, 0.4);\n}\n\n.lotr-hwheel__slot--empty .lotr-hwheel__slot-name {\n  color: rgba(150, 150, 180, 0.4);\n}\n\n/* Edge Fades - deeper shadows */\n.lotr-hwheel__fade {\n  position: absolute;\n  top: 0;\n  bottom: 0;\n  width: 100px;\n  pointer-events: none;\n  z-index: 10;\n}\n\n.lotr-hwheel__fade--left {\n  left: 0;\n  background: linear-gradient(90deg,\n    rgba(10, 10, 20, 1) 0%,\n    rgba(10, 10, 20, 0.8) 30%,\n    transparent 100%\n  );\n}\n\n.lotr-hwheel__fade--right {\n  right: 0;\n  background: linear-gradient(270deg,\n    rgba(10, 10, 20, 1) 0%,\n    rgba(10, 10, 20, 0.8) 30%,\n    transparent 100%\n  );\n}\n\n/* Winner Announcement */\n.lotr-hwheel__winner-announce {\n  position: relative;\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n  padding: 1rem 1.5rem;\n  background: rgba(255, 215, 0, 0.1);\n  border: 2px solid #ffd700;\n  border-radius: 2px;\n  animation: winner-announce-glow 0.8s ease-in-out infinite alternate;\n  margin-top: 0.5rem;\n}\n\n@keyframes winner-announce-glow {\n  0% { box-shadow: 0 0 10px #ffd700; }\n  100% { box-shadow: 0 0 30px #ffd700, 0 0 50px rgba(255, 215, 0, 0.5); }\n}\n\n.lotr-hwheel__winner-avatar {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 2;\n}\n\n.lotr-hwheel__winner-avatar svg {\n  width: 24px;\n  height: 24px;\n  color: rgba(0, 0, 0, 0.7);\n}\n\n.lotr-hwheel__winner-text {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: #ffd700;\n  text-shadow: 0 0 10px #ffd700;\n  z-index: 2;\n}\n\n.lotr-hwheel__winner-text--you {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 10px var(--color-neon-green);\n}\n\n.lotr-hwheel__payout-breakdown {\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n  margin-top: 0.5rem;\n  padding: 0.4rem 0.75rem;\n  border-radius: 6px;\n  background: rgba(0, 0, 0, 0.3);\n  font-size: 0.8rem;\n  width: 100%;\n  max-width: 280px;\n  z-index: 2;\n}\n\n.lotr-hwheel__breakdown-row {\n  display: flex;\n  justify-content: space-between;\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.lotr-hwheel__breakdown-row--muted {\n  color: rgba(255, 255, 255, 0.4);\n  font-size: 0.75rem;\n}\n\n/* Win Animation - Star Burst */\n.lotr-hwheel__win-animation {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  pointer-events: none;\n  z-index: 1;\n}\n\n.lotr-hwheel__win-stars {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.lotr-hwheel__win-star {\n  position: absolute;\n  font-size: 1.5rem;\n  color: #ffd700;\n  text-shadow: 0 0 10px #ffd700, 0 0 20px #ffd700;\n  animation: lotr-star-burst 1.5s ease-out forwards;\n  animation-delay: calc(var(--star-index) * 0.05s);\n  opacity: 0;\n}\n\n.lotr-hwheel__win-star:nth-child(1) { --angle: 0deg; }\n.lotr-hwheel__win-star:nth-child(2) { --angle: 45deg; }\n.lotr-hwheel__win-star:nth-child(3) { --angle: 90deg; }\n.lotr-hwheel__win-star:nth-child(4) { --angle: 135deg; }\n.lotr-hwheel__win-star:nth-child(5) { --angle: 180deg; }\n.lotr-hwheel__win-star:nth-child(6) { --angle: 225deg; }\n.lotr-hwheel__win-star:nth-child(7) { --angle: 270deg; }\n.lotr-hwheel__win-star:nth-child(8) { --angle: 315deg; }\n\n@keyframes lotr-star-burst {\n  0% {\n    opacity: 1;\n    transform: rotate(var(--angle)) translateY(0) scale(0.5);\n  }\n  50% {\n    opacity: 1;\n  }\n  100% {\n    opacity: 0;\n    transform: rotate(var(--angle)) translateY(-100px) scale(1.2);\n  }\n}\n\n.lotr-hwheel__win-coins {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.lotr-hwheel__win-coin {\n  position: absolute;\n  font-size: 1.2rem;\n  color: #ffd700;\n  text-shadow: 0 0 8px #ffd700, 0 0 16px #ff9900;\n  animation: lotr-coin-fountain 1.8s ease-out forwards;\n  animation-delay: calc(var(--coin-index) * 0.1s);\n  opacity: 0;\n}\n\n.lotr-hwheel__win-coin:nth-child(1) { --coin-x: -50px; }\n.lotr-hwheel__win-coin:nth-child(2) { --coin-x: -25px; }\n.lotr-hwheel__win-coin:nth-child(3) { --coin-x: 0px; }\n.lotr-hwheel__win-coin:nth-child(4) { --coin-x: 25px; }\n.lotr-hwheel__win-coin:nth-child(5) { --coin-x: 50px; }\n.lotr-hwheel__win-coin:nth-child(6) { --coin-x: 0px; }\n\n@keyframes lotr-coin-fountain {\n  0% {\n    opacity: 1;\n    transform: translateX(var(--coin-x)) translateY(0) scale(0.5);\n  }\n  30% {\n    opacity: 1;\n    transform: translateX(var(--coin-x)) translateY(-60px) scale(1);\n  }\n  100% {\n    opacity: 0;\n    transform: translateX(var(--coin-x)) translateY(40px) scale(0.8);\n  }\n}\n\n/* Player Legend */\n.lotr-hwheel__legend {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n  width: 100%;\n  max-width: 900px;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  padding: 0.75rem;\n  margin-top: 0.5rem;\n}\n\n.lotr-hwheel__legend-item {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-size: 1rem;\n  padding: 0.25rem;\n  border-radius: 2px;\n}\n\n.lotr-hwheel__legend-item--you {\n  background: rgba(0, 255, 136, 0.1);\n  border: 1px solid var(--color-neon-green);\n}\n\n.lotr-hwheel__legend-item--winner {\n  background: rgba(255, 215, 0, 0.2);\n  border: 1px solid #ffd700;\n  animation: winner-glow 0.5s ease-in-out infinite alternate;\n}\n\n@keyframes winner-glow {\n  0% { box-shadow: 0 0 5px #ffd700; }\n  100% { box-shadow: 0 0 15px #ffd700; }\n}\n\n.lotr-hwheel__legend-color {\n  width: 12px;\n  height: 12px;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n\n.lotr-hwheel__legend-name {\n  flex: 1;\n  color: var(--color-text);\n}\n\n.lotr-hwheel__legend-entries {\n  color: var(--color-text-muted);\n  font-size: 0.875rem;\n}\n\n.lotr-hwheel__legend-prob {\n  color: var(--color-neon-cyan);\n  font-weight: bold;\n  min-width: 40px;\n  text-align: right;\n}\n\n.lotr-hwheel__legend-empty {\n  text-align: center;\n  color: var(--color-text-muted);\n  font-size: 1rem;\n  padding: 1rem;\n}\n\n/* Active Round View */\n.lotr-active-round {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.5rem;\n  padding: 1rem;\n  width: 100%;\n  max-width: 900px;\n  margin: 0 auto;\n}\n\n.lotr-active-round__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  width: 100%;\n  max-width: 500px;\n}\n\n.lotr-active-round__tier {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  text-transform: uppercase;\n}\n\n.lotr-active-round__pool {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-end;\n  gap: 0.25rem;\n}\n\n.lotr-active-round__pool-label {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.lotr-active-round__pool-amount {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.lotr-active-round__pool-payout {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n}\n\n.lotr-active-round__phase {\n  text-align: center;\n}\n\n.lotr-active-round__phase-message {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n  text-transform: uppercase;\n}\n\n.lotr-active-round__phase-message--winner {\n  font-size: 1.5rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n  animation: winner-text-pulse 0.5s ease-in-out infinite alternate;\n}\n\n@keyframes winner-text-pulse {\n  0% { transform: scale(1); }\n  100% { transform: scale(1.05); }\n}\n\n.lotr-active-round__wheel {\n  width: 100%;\n  display: flex;\n  justify-content: center;\n}\n\n.lotr-active-round__your-stats {\n  display: flex;\n  gap: 2rem;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  padding: 1rem 2rem;\n}\n\n.lotr-active-round__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.lotr-active-round__stat-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.lotr-active-round__stat-value {\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  font-weight: bold;\n}\n\n.lotr-active-round__actions {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1rem;\n  width: 100%;\n  max-width: 400px;\n}\n\n.lotr-active-round__buy-more {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.5rem;\n  width: 100%;\n}\n\n.lotr-active-round__buy-more-label {\n  font-size: 1rem;\n  color: var(--color-neon-yellow);\n  text-transform: uppercase;\n}\n\n.lotr-active-round__buy-more-buttons {\n  display: flex;\n  gap: 0.5rem;\n}\n\n.lotr-active-round__buy-btn {\n  padding: 0.5rem 1rem;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  background: var(--color-surface);\n  border: 1px solid var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.lotr-active-round__buy-btn:hover:not(:disabled) {\n  background: var(--color-neon-cyan);\n  color: var(--color-bg);\n  box-shadow: none;\n}\n\n.lotr-active-round__buy-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.lotr-active-round__result {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1rem;\n}\n\n.lotr-active-round__winner-banner {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  padding: 1rem 2rem;\n  background: rgba(0, 255, 136, 0.1);\n  border: 2px solid var(--color-neon-green);\n  animation: winner-glow 0.5s ease-in-out infinite alternate;\n}\n\n.lotr-active-round__winner-icon {\n  font-size: 2rem;\n}\n\n.lotr-active-round__winner-text {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.lotr-active-round__loser-banner {\n  padding: 1rem 2rem;\n  background: rgba(212, 93, 93, 0.1);\n  border: 2px solid #d45d5d;\n}\n\n.lotr-active-round__loser-text {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: #d45d5d;\n}\n\n.lotr-active-round__back-btn {\n  padding: 0.75rem 1.5rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  text-transform: uppercase;\n  background: var(--color-surface);\n  border: 2px solid var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.lotr-active-round__back-btn:hover {\n  box-shadow: none;\n}\n\n.lotr-active-round__spinning-message {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-yellow);\n  text-shadow: none;\n  animation: spin-text-pulse 0.3s ease-in-out infinite alternate;\n}\n\n@keyframes spin-text-pulse {\n  0% { opacity: 0.7; }\n  100% { opacity: 1; }\n}\n\n/* Sidebar Styles */\n.lotr-sidebar {\n  display: flex;\n  flex-direction: column;\n  gap: 1.5rem;\n  /* Align with wheel (below back button + countdown) */\n  padding-top: 5rem;\n}\n\n.lotr-sidebar__title {\n  font-size: 0.875rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-pink);\n  margin: 0 0 0.5rem 0;\n  text-transform: uppercase;\n}\n\n.lotr-sidebar__section {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.lotr-sidebar__label {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.lotr-sidebar__sol-icon {\n  width: 16px;\n  height: 16px;\n  filter: brightness(0) saturate(100%) invert(75%) sepia(61%) saturate(1500%) hue-rotate(100deg) brightness(100%) contrast(104%);\n}\n\n.lotr-sidebar__label-row {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 0.5rem;\n}\n\n.lotr-sidebar__entry-selector {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 1rem;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  padding: 0.75rem;\n}\n\n.lotr-sidebar__entry-btn {\n  width: 32px;\n  height: 32px;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: var(--color-bg);\n  border: 1px solid var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.lotr-sidebar__entry-btn:hover:not(:disabled) {\n  background: var(--color-neon-cyan);\n  color: var(--color-bg);\n}\n\n.lotr-sidebar__entry-btn:disabled {\n  opacity: 0.3;\n  cursor: not-allowed;\n}\n\n.lotr-sidebar__entry-count {\n  font-family: var(--font-pixel);\n  font-size: 1.5rem;\n  color: var(--color-neon-green);\n  min-width: 40px;\n  text-align: center;\n}\n\n.lotr-sidebar__entry-hint {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-align: center;\n  margin: 0;\n}\n\n/* Round Fairness Section */\n.lotr-sidebar__fairness {\n  padding: 0.75rem;\n  background: rgba(20, 20, 35, 0.6);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  margin-bottom: 0.75rem;\n}\n\n.lotr-sidebar__fairness-title {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin: 0 0 0.5rem 0;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.lotr-sidebar__fairness-title::before {\n  content: \"🔒\";\n  font-size: 1rem;\n}\n\n.lotr-sidebar__fairness-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 0.875rem;\n  padding: 0.25rem 0;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.lotr-sidebar__fairness-row:last-child {\n  border-bottom: none;\n}\n\n.lotr-sidebar__fairness-row > span:first-child {\n  color: var(--color-text-muted);\n}\n\n.lotr-sidebar__hash {\n  font-family: var(--font-mono);\n  color: #888;\n  cursor: pointer;\n  padding: 0.125rem 0.25rem;\n  background: rgba(0, 0, 0, 0.3);\n  border-radius: 2px;\n  transition: all 0.2s ease;\n}\n\n.lotr-sidebar__hash:hover {\n  color: var(--color-neon-green);\n  background: rgba(0, 255, 136, 0.1);\n}\n\n.lotr-sidebar__hash--revealed {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n}\n\n.lotr-sidebar__verify-link {\n  display: block;\n  margin-top: 0.5rem;\n  font-size: 0.75rem;\n  color: #38bdf8;\n  text-decoration: none;\n  text-align: right;\n}\n.lotr-sidebar__verify-link:hover {\n  text-decoration: underline;\n}\n\n/* Your Stats in Sidebar */\n.lotr-sidebar__your-stats {\n  display: flex;\n  justify-content: space-around;\n  gap: 1rem;\n  padding: 1rem;\n  background: linear-gradient(180deg,\n    rgba(0, 255, 136, 0.05) 0%,\n    rgba(20, 20, 35, 0.9) 50%,\n    rgba(0, 255, 136, 0.05) 100%\n  );\n  border: 1px solid rgba(0, 255, 136, 0.2);\n  border-radius: 2px;\n}\n\n.lotr-sidebar__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.lotr-sidebar__stat-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.lotr-sidebar__stat-value {\n  font-size: 1rem;\n  font-family: var(--font-mono);\n  color: var(--color-neon-green);\n  text-shadow: 0 0 8px var(--color-neon-green);\n}\n\n.lotr-sidebar__row {\n  display: flex;\n  justify-content: space-between;\n  font-size: 1rem;\n}\n\n.lotr-sidebar__payout {\n  color: var(--color-neon-green);\n  font-weight: bold;\n}\n\n.lotr-sidebar__tier {\n  text-transform: uppercase;\n}\n\n.lotr-sidebar__status {\n  color: var(--color-neon-cyan);\n}\n\n.lotr-sidebar__game-info {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n}\n\n.lotr-sidebar__pot {\n  color: var(--color-neon-green);\n  text-shadow: none;\n  font-weight: bold;\n}\n\n/* Action Button */\n.lotr-action-btn {\n  width: 100%;\n  padding: 1rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  text-transform: uppercase;\n  background: linear-gradient(135deg, var(--color-neon-pink) 0%, var(--color-neon-magenta) 100%);\n  border: none;\n  color: white;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.lotr-action-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: translateY(-2px);\n}\n\n.lotr-action-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n  transform: none;\n}\n\n.lotr-action-btn--secondary {\n  background: var(--color-surface);\n  border: 2px solid var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n}\n\n.lotr-action-btn--secondary:hover:not(:disabled) {\n  box-shadow: none;\n}\n\n/* History Result Styling */\n.lotr-history-result {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.35rem;\n  font-size: 1rem;\n  font-weight: 600;\n}\n\n.lotr-history-result__separator {\n  color: rgba(255, 255, 255, 0.3);\n  font-weight: 400;\n}\n\n/* Sidebar Empty State */\n.lotr-sidebar__empty {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.lotr-sidebar__hint {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  margin: 0;\n}\n\n/* ============ Tier Round View ============ */\n.lotr-tier-round {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.5rem;\n  padding: 1rem;\n  width: 100%;\n  max-width: 900px;\n  margin: 0 auto;\n}\n\n.lotr-tier-round__back {\n  position: absolute;\n  top: 0.5rem;\n  left: 0;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  background: none;\n  border: none;\n  color: var(--color-text-muted);\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  cursor: pointer;\n  padding: 0.5rem;\n  transition: all 0.2s;\n  z-index: 10;\n}\n\n.lotr-tier-round__back:hover {\n  color: var(--color-neon-cyan);\n}\n\n.lotr-tier-round__back svg {\n  width: 16px;\n  height: 16px;\n}\n\n.lotr-tier-round__header {\n  text-align: center;\n}\n\n.lotr-tier-round__tier-name {\n  font-family: var(--font-pixel);\n  font-size: 1.75rem;\n  margin: 0 0 0.5rem 0;\n}\n\n.lotr-tier-round__entry-amount {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n}\n\n.lotr-tier-round__phase {\n  text-align: center;\n}\n\n.lotr-tier-round__phase-message {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.lotr-tier-round__wheel {\n  width: 100%;\n  display: flex;\n  justify-content: center;\n}\n\n.lotr-tier-round__empty-wheel {\n  width: 280px;\n  height: 280px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.lotr-tier-round__empty-wheel-circle {\n  width: 200px;\n  height: 200px;\n  border-radius: 50%;\n  border: 3px dashed var(--color-border);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n  color: var(--color-text-muted);\n  font-size: 0.875rem;\n  text-align: center;\n}\n\n.lotr-tier-round__empty-wheel-hint {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.lotr-tier-round__stats {\n  display: flex;\n  justify-content: center;\n  gap: 2rem;\n  padding: 1rem 2rem;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  width: 100%;\n}\n\n.lotr-tier-round__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.lotr-tier-round__stat-label {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.lotr-tier-round__stat-value {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.lotr-tier-round__join-section {\n  width: 100%;\n  display: flex;\n  flex-direction: column;\n  gap: 1rem;\n}\n\n.lotr-tier-round__join-summary {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.lotr-tier-round__join-row {\n  display: flex;\n  justify-content: space-between;\n  font-size: 0.875rem;\n}\n\n.lotr-tier-round__payout {\n  color: var(--color-neon-green);\n  font-weight: bold;\n}\n\n.lotr-tier-round__join-btn {\n  width: 100%;\n  padding: 1rem 1.5rem;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  background: linear-gradient(135deg, var(--color-neon-pink) 0%, var(--color-neon-magenta) 100%);\n  border: none;\n  color: white;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.lotr-tier-round__join-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: translateY(-2px);\n}\n\n.lotr-tier-round__join-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n  transform: none;\n}\n\n.lotr-tier-round__actions {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.75rem;\n  margin-top: 1rem;\n  width: 100%;\n  max-width: 300px;\n  margin-left: auto;\n  margin-right: auto;\n}\n\n/* Lord of RNGs Claim Button */\n.lotr-claim-btn {\n  padding: 1rem 2rem;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  background: linear-gradient(135deg, var(--color-neon-green) 0%, #39cc14 100%);\n  border: none;\n  color: #000;\n  cursor: pointer;\n  transition: all 0.2s;\n  width: 100%;\n}\n\n.lotr-claim-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: scale(1.05);\n}\n\n.lotr-claim-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.lotr-claimed-text {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n/* Lord of RNGs Responsive */\n@media (max-width: 768px) {\n  .lotr-tier-lobby__grid {\n    grid-template-columns: 1fr;\n  }\n\n  .lotr-hwheel__container {\n    height: 110px;\n  }\n\n  .lotr-hwheel__slot-container {\n    width: 62px;\n    padding: 6px 4px;\n  }\n\n  .lotr-hwheel__avatar {\n    width: 38px;\n    height: 38px;\n  }\n\n  .lotr-hwheel__avatar-icon {\n    width: 22px;\n    height: 22px;\n  }\n\n  .lotr-hwheel__legend {\n    max-width: 100%;\n  }\n\n  .lotr-active-round__your-stats {\n    gap: 1rem;\n    padding: 0.75rem 1rem;\n  }\n}\n\n@media (max-width: 480px) {\n  .lotr-hwheel__container {\n    height: 100px;\n  }\n\n  .lotr-hwheel__slot-container {\n    width: 52px;\n    padding: 5px 3px;\n    gap: 0.25rem;\n  }\n\n  .lotr-hwheel__avatar {\n    width: 34px;\n    height: 34px;\n  }\n\n  .lotr-hwheel__avatar-icon {\n    width: 18px;\n    height: 18px;\n  }\n\n  .lotr-hwheel__slot-name {\n    font-size: 1rem;\n    max-width: 50px;\n  }\n\n  .lotr-hwheel__fade {\n    width: 50px;\n  }\n\n  .lotr-countdown--large .lotr-countdown__time {\n    font-size: 1.25rem;\n  }\n\n  .lotr-active-round__winner-banner {\n    padding: 0.75rem 1rem;\n  }\n\n  .lotr-active-round__winner-text {\n    font-size: 0.875rem;\n  }\n\n  .lotr-hwheel__winner-announce {\n    padding: 0.75rem 1rem;\n    gap: 0.5rem;\n  }\n\n  .lotr-hwheel__winner-text {\n    font-size: 1rem;\n  }\n}\n\n/* ============ Close Call Game ============ */\n\n/* Main Layout */\n.close-call-main {\n  position: relative;\n  display: flex;\n  flex-direction: column;\n  gap: 1.5rem;\n  padding: 1rem;\n  min-height: 100%;\n}\n\n.close-call-sidebar {\n  display: flex;\n  flex-direction: column;\n  gap: 1.25rem;\n}\n\n.close-call-sidebar__title {\n  font-family: var(--font-display);\n  font-size: 1.25rem;\n  color: #fff;\n  margin: 0 0 0.5rem 0;\n  text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);\n}\n\n.close-call-sidebar__section {\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n}\n\n.close-call-sidebar__label {\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.7);\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n/* Potential Payout Preview */\n.close-call-sidebar__payout-preview {\n  background: linear-gradient(135deg, rgba(0, 255, 136, 0.12), rgba(0, 255, 136, 0.05));\n  border: 1px solid rgba(0, 255, 136, 0.25);\n  border-radius: 3px;\n  padding: 0.75rem 1rem;\n  text-align: center;\n  animation: payout-fade-in 0.3s ease;\n}\n\n@keyframes payout-fade-in {\n  from { opacity: 0; transform: translateY(-5px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n.close-call-sidebar__payout-label {\n  font-size: 0.65rem;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  color: rgba(0, 255, 136, 0.7);\n  margin-bottom: 0.25rem;\n}\n\n.close-call-sidebar__payout-amount {\n  display: flex;\n  align-items: baseline;\n  justify-content: center;\n  gap: 0.5rem;\n}\n\n.close-call-sidebar__payout-sol {\n  font-family: var(--font-mono);\n  font-size: 1.25rem;\n  font-weight: 700;\n  color: #00ff88;\n  text-shadow: 0 0 12px rgba(0, 255, 136, 0.4);\n}\n\n.close-call-sidebar__payout-usd {\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.close-call-sidebar__payout-profit {\n  font-family: var(--font-mono);\n  font-size: 1rem;\n  color: rgba(0, 255, 136, 0.8);\n  margin-top: 0.25rem;\n}\n\n/* Chart Container */\n.close-call-chart {\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 3px;\n  padding: 1rem;\n  position: relative;\n}\n\n/* Header: Asset name and O/H/L prices */\n.close-call-chart__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 0.75rem;\n}\n\n.close-call-chart__asset-name {\n  font-family: var(--font-display);\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.9);\n  font-weight: 600;\n}\n\n\n/* Chart container - for lightweight-charts */\n.close-call-chart__container {\n  height: 280px;\n  border-radius: 2px;\n  overflow: hidden;\n  position: relative;\n}\n\n/* Lightweight charts wrapper */\n.close-call-chart__container--lw {\n  background: rgba(0, 0, 0, 0.2);\n}\n\n.close-call-chart__lw-chart {\n  width: 100%;\n  height: 100%;\n}\n\n/* Price info panel - centered in right half of chart */\n.close-call-chart__price-panel {\n  position: absolute;\n  top: 35%;\n  right: 0;\n  width: 35%;\n  transform: translateY(-50%);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  pointer-events: none;\n  z-index: 3;\n}\n\n.close-call-chart__current-price {\n  font-family: var(--font-mono);\n  font-size: 1.75rem;\n  font-weight: 700;\n  text-shadow: 0 0 12px currentColor;\n  margin-bottom: 12px;\n}\n\n.close-call-chart__current-label {\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  color: rgba(255, 255, 255, 0.5);\n  margin-bottom: 4px;\n}\n\n.close-call-chart__ohl {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.close-call-chart__ohl-item {\n  display: flex;\n  align-items: center;\n  gap: 3px;\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n}\n\n.close-call-chart__ohl-label {\n  color: rgba(255, 255, 255, 0.4);\n}\n\n.close-call-chart__ohl-value {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n/* Footer: Progress bar and status */\n.close-call-chart__footer {\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n  margin-top: 0.75rem;\n  padding-top: 0.75rem;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n/* Progress bar with two phases */\n.close-call-chart__progress {\n  width: 100%;\n}\n\n.close-call-chart__progress-track {\n  display: flex;\n  height: 6px;\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 3px;\n  overflow: hidden;\n}\n\n.close-call-chart__progress-betting {\n  position: relative;\n  height: 100%;\n  background: rgba(255, 255, 255, 0.15);\n}\n\n.close-call-chart__progress-locked {\n  position: relative;\n  height: 100%;\n  background: rgba(255, 255, 255, 0.05);\n}\n\n.close-call-chart__progress-fill {\n  position: absolute;\n  top: 0;\n  left: 0;\n  height: 100%;\n  transition: width 0.1s linear;\n}\n\n.close-call-chart__progress-fill--betting {\n  background: #ffffff;\n  box-shadow: 0 0 8px rgba(255, 255, 255, 0.5);\n}\n\n.close-call-chart__progress-fill--locked {\n  background: rgba(255, 255, 255, 0.4);\n}\n\n/* Countdown label */\n.close-call-chart__label {\n  font-size: 1rem;\n  text-align: center;\n}\n\n.close-call-chart__label--betting {\n  color: #ffffff;\n  font-weight: 600;\n}\n\n.close-call-chart__label--locked {\n  color: rgba(255, 255, 255, 0.5);\n}\n\n/* Bet Amount Input */\n.close-call-bet-input {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.close-call-bet-input__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.close-call-bet-input__label {\n  display: flex;\n  align-items: center;\n  gap: 0.375rem;\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.7);\n}\n\n.close-call-bet-input__sol-icon {\n  opacity: 0.7;\n}\n\n.close-call-bet-input__usd {\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.5);\n  font-family: var(--font-mono);\n}\n\n.close-call-bet-input__row {\n  display: flex;\n  gap: 0.5rem;\n}\n\n.close-call-bet-input__field {\n  flex: 1;\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  border-radius: 2px;\n  padding: 0.75rem 1rem;\n  font-family: var(--font-mono);\n  font-size: 1rem;\n  color: #fff;\n  outline: none;\n  transition: border-color 0.2s, box-shadow 0.2s;\n}\n\n.close-call-bet-input__field:focus {\n  border-color: rgba(0, 255, 136, 0.5);\n  box-shadow: 0 0 10px rgba(0, 255, 136, 0.2);\n}\n\n.close-call-bet-input__field:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.close-call-bet-input__adjustments {\n  display: flex;\n  gap: 0.25rem;\n}\n\n.close-call-bet-input__adj-btn {\n  background: rgba(255, 255, 255, 0.1);\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  border-radius: 2px;\n  padding: 0.5rem 0.75rem;\n  font-family: var(--font-mono);\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.8);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.close-call-bet-input__adj-btn:hover:not(:disabled) {\n  background: rgba(255, 255, 255, 0.2);\n  border-color: rgba(255, 255, 255, 0.3);\n}\n\n.close-call-bet-input__adj-btn:disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n}\n\n/* Inline adjustment buttons */\n.close-call-bet-input__btn {\n  background: rgba(255, 255, 255, 0.15);\n  border: 1px solid rgba(255, 255, 255, 0.3);\n  border-radius: 2px;\n  padding: 0.75rem 0.875rem;\n  font-family: var(--font-mono);\n  font-weight: 600;\n  font-size: 0.875rem;\n  color: #fff;\n  cursor: pointer;\n  transition: all 0.2s;\n  white-space: nowrap;\n}\n\n.close-call-bet-input__btn:hover:not(:disabled) {\n  background: rgba(255, 255, 255, 0.2);\n  border-color: rgba(255, 255, 255, 0.3);\n}\n\n.close-call-bet-input__btn:disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n}\n\n.close-call-bet-input__btn--max {\n  background: rgba(0, 255, 136, 0.1);\n  border-color: rgba(0, 255, 136, 0.3);\n  color: rgba(0, 255, 136, 0.9);\n}\n\n.close-call-bet-input__btn--max:hover:not(:disabled) {\n  background: rgba(0, 255, 136, 0.2);\n  border-color: rgba(0, 255, 136, 0.5);\n}\n\n.close-call-bet-input__range {\n  display: flex;\n  justify-content: space-between;\n  font-size: 0.9rem;\n  color: rgba(255, 255, 255, 0.4);\n  font-family: var(--font-mono);\n}\n\n/* Side Selector */\n.close-call-side-selector {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 0.75rem;\n}\n\n.close-call-side-btn {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 1rem;\n  background: rgba(0, 0, 0, 0.3);\n  border: 2px solid rgba(255, 255, 255, 0.1);\n  border-radius: 3px;\n  cursor: pointer;\n  transition: all 0.3s;\n}\n\n.close-call-side-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.close-call-side-btn--green {\n  border-color: rgba(0, 255, 136, 0.3);\n}\n\n.close-call-side-btn--green:hover:not(:disabled) {\n  border-color: rgba(0, 255, 136, 0.6);\n  background: rgba(0, 255, 136, 0.1);\n  box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);\n}\n\n.close-call-side-btn--green.close-call-side-btn--selected {\n  border-color: #00ff88;\n  background: rgba(0, 255, 136, 0.2);\n  box-shadow: 0 0 25px rgba(0, 255, 136, 0.4);\n}\n\n.close-call-side-btn--red {\n  border-color: rgba(255, 0, 84, 0.3);\n}\n\n.close-call-side-btn--red:hover:not(:disabled) {\n  border-color: rgba(255, 0, 84, 0.6);\n  background: rgba(255, 0, 84, 0.1);\n  box-shadow: 0 0 20px rgba(255, 0, 84, 0.2);\n}\n\n.close-call-side-btn--red.close-call-side-btn--selected {\n  border-color: #ff0054;\n  background: rgba(255, 0, 84, 0.2);\n  box-shadow: 0 0 25px rgba(255, 0, 84, 0.4);\n}\n\n.close-call-side-btn__icon {\n  font-size: 1.5rem;\n}\n\n.close-call-side-btn__label {\n  font-family: var(--font-display);\n  font-size: 1rem;\n  font-weight: 600;\n}\n\n.close-call-side-btn--green .close-call-side-btn__label {\n  color: #00ff88;\n  text-shadow: 0 0 10px rgba(0, 255, 136, 0.5);\n}\n\n.close-call-side-btn--red .close-call-side-btn__label {\n  color: #ff0054;\n  text-shadow: 0 0 10px rgba(255, 0, 84, 0.5);\n}\n\n.close-call-side-btn__sublabel {\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.5);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.close-call-side-btn__pool {\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.7);\n}\n\n.close-call-side-btn__odds {\n  font-family: var(--font-mono);\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.5);\n}\n\n/* Pool Distribution Bar */\n.close-call-pool-bar {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.close-call-pool-bar__labels {\n  display: flex;\n  justify-content: space-between;\n  font-size: 1rem;\n}\n\n.close-call-pool-bar__label--green {\n  color: #00ff88;\n}\n\n.close-call-pool-bar__label--red {\n  color: #ff0054;\n}\n\n.close-call-pool-bar__bar {\n  height: 8px;\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  overflow: hidden;\n  display: flex;\n}\n\n.close-call-pool-bar__green {\n  height: 100%;\n  background: linear-gradient(90deg, #00cc88, #00aa77);\n  transition: width 0.3s ease;\n}\n\n.close-call-pool-bar__red {\n  height: 100%;\n  background: linear-gradient(90deg, #ff6655, #ff4466);\n  transition: width 0.3s ease;\n}\n\n.close-call-pool-bar__total {\n  text-align: center;\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.7);\n  margin-top: 0.25rem;\n}\n\n.close-call-pool-bar__total-amount {\n  font-family: var(--font-mono);\n  color: #fff;\n}\n\n/* Prize Pool - Striking Display */\n.close-call-pool-bar__prize {\n  margin-top: 1rem;\n  padding: 0.875rem 1rem;\n  background: linear-gradient(135deg, rgba(255, 215, 0, 0.15), rgba(255, 170, 0, 0.08));\n  border: 1px solid rgba(255, 215, 0, 0.3);\n  border-radius: 3px;\n  text-align: center;\n  position: relative;\n  overflow: hidden;\n}\n\n.close-call-pool-bar__prize::before {\n  content: \"\";\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 200%;\n  height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.1), transparent);\n  animation: prize-shimmer 3s infinite;\n}\n\n@keyframes prize-shimmer {\n  0% { transform: translateX(0); }\n  100% { transform: translateX(100%); }\n}\n\n.close-call-pool-bar__prize-label {\n  font-size: 0.65rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.15em;\n  color: rgba(255, 215, 0, 0.8);\n  margin-bottom: 0.25rem;\n}\n\n.close-call-pool-bar__prize-amount {\n  display: flex;\n  align-items: baseline;\n  justify-content: center;\n  gap: 0.5rem;\n}\n\n.close-call-pool-bar__prize-sol {\n  font-family: var(--font-mono);\n  font-size: 1.375rem;\n  font-weight: 700;\n  color: #ffd700;\n  text-shadow: 0 0 15px rgba(255, 215, 0, 0.5), 0 0 30px rgba(255, 215, 0, 0.3);\n}\n\n.close-call-pool-bar__prize-usd {\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.close-call-pool-bar__prize-jackpot {\n  font-size: 0.9rem;\n  color: #ffaa00;\n  margin-top: 0.375rem;\n  text-shadow: 0 0 8px rgba(255, 170, 0, 0.4);\n}\n\n/* User's bet stats within prize pool */\n.close-call-pool-bar__user-bet {\n  position: relative;\n  margin-top: 1rem;\n  padding-top: 0.875rem;\n  border-top: 1px solid rgba(255, 215, 0, 0.2);\n  animation: fadeIn 0.3s ease;\n  overflow: hidden;\n}\n\n.close-call-pool-bar__user-bet--won {\n  background: linear-gradient(135deg, rgba(0, 255, 136, 0.1), rgba(0, 255, 136, 0.05));\n  border-radius: 2px;\n  padding: 0.875rem;\n  margin-top: 0.75rem;\n  border-top: none;\n  border: 1px solid rgba(0, 255, 136, 0.3);\n}\n\n.close-call-pool-bar__user-bet--lost {\n  background: linear-gradient(135deg, rgba(255, 0, 84, 0.1), rgba(255, 0, 84, 0.05));\n  border-radius: 2px;\n  padding: 0.875rem;\n  margin-top: 0.75rem;\n  border-top: none;\n  border: 1px solid rgba(255, 0, 84, 0.3);\n}\n\n.close-call-pool-bar__user-bet-header {\n  font-size: 1rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  text-align: center;\n  margin-bottom: 0.5rem;\n  text-shadow: 0 0 8px currentColor;\n}\n\n.close-call-pool-bar__user-bet-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.25rem 0;\n}\n\n.close-call-pool-bar__user-bet-row--payout {\n  margin-top: 0.25rem;\n  padding-top: 0.375rem;\n  border-top: 1px dashed rgba(255, 255, 255, 0.15);\n}\n\n.close-call-pool-bar__user-bet-label {\n  font-size: 0.9rem;\n  color: rgba(255, 255, 255, 0.6);\n  text-transform: uppercase;\n  letter-spacing: 0.03em;\n}\n\n.close-call-pool-bar__user-bet-value {\n  font-family: var(--font-mono);\n  font-size: 0.85rem;\n  font-weight: 600;\n  color: #fff;\n  display: flex;\n  align-items: baseline;\n  gap: 0.375rem;\n}\n\n.close-call-pool-bar__user-bet-value--won {\n  color: #00ff88;\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n.close-call-pool-bar__user-bet-usd {\n  font-size: 0.9rem;\n  font-weight: 400;\n  color: rgba(255, 255, 255, 0.5);\n}\n\n/* Win animation in bet stats */\n.close-call-pool-bar__win-animation {\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  pointer-events: none;\n  overflow: hidden;\n}\n\n.close-call-pool-bar__stars {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.close-call-pool-bar__star {\n  position: absolute;\n  font-size: 1rem;\n  color: #ffd700;\n  animation: poolStarBurst 1.5s ease-out forwards;\n  animation-delay: calc(var(--star-index) * 0.1s);\n  opacity: 0;\n}\n\n.close-call-pool-bar__star:nth-child(1) { transform: translate(-30px, -20px); }\n.close-call-pool-bar__star:nth-child(2) { transform: translate(30px, -20px); }\n.close-call-pool-bar__star:nth-child(3) { transform: translate(-40px, 0); }\n.close-call-pool-bar__star:nth-child(4) { transform: translate(40px, 0); }\n.close-call-pool-bar__star:nth-child(5) { transform: translate(-30px, 20px); }\n.close-call-pool-bar__star:nth-child(6) { transform: translate(30px, 20px); }\n\n@keyframes poolStarBurst {\n  0% {\n    opacity: 1;\n    transform: translate(0, 0) scale(0.5);\n  }\n  50% {\n    opacity: 1;\n    transform: scale(1.2);\n  }\n  100% {\n    opacity: 0;\n    transform: scale(0.8);\n  }\n}\n\n.close-call-pool-bar__coins {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.close-call-pool-bar__coin {\n  position: absolute;\n  font-size: 1rem;\n  color: #00ff88;\n  animation: poolCoinFountain 1.2s ease-out forwards;\n  animation-delay: calc(var(--coin-index) * 0.15s);\n  opacity: 0;\n  text-shadow: 0 0 4px rgba(0, 255, 136, 0.8);\n}\n\n.close-call-pool-bar__coin:nth-child(1) { --coin-x: -25px; --coin-y: -30px; }\n.close-call-pool-bar__coin:nth-child(2) { --coin-x: -10px; --coin-y: -35px; }\n.close-call-pool-bar__coin:nth-child(3) { --coin-x: 10px; --coin-y: -35px; }\n.close-call-pool-bar__coin:nth-child(4) { --coin-x: 25px; --coin-y: -30px; }\n\n@keyframes poolCoinFountain {\n  0% {\n    opacity: 1;\n    transform: translate(0, 0);\n  }\n  50% {\n    opacity: 1;\n  }\n  100% {\n    opacity: 0;\n    transform: translate(var(--coin-x), var(--coin-y));\n  }\n}\n\n/* Loss animation in bet stats */\n.close-call-pool-bar__loss-animation {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  pointer-events: none;\n  z-index: 1;\n}\n\n.close-call-pool-bar__heartbreak {\n  font-size: 1.5rem;\n  animation: heartbreak 1s ease-out forwards;\n  display: block;\n}\n\n@keyframes heartbreak {\n  0% {\n    opacity: 0;\n    transform: scale(0.5);\n  }\n  20% {\n    opacity: 1;\n    transform: scale(1.3);\n  }\n  40% {\n    transform: scale(1);\n  }\n  60% {\n    opacity: 1;\n  }\n  100% {\n    opacity: 0;\n    transform: scale(0.8) translateY(-15px);\n  }\n}\n\n.close-call-pool-bar__track {\n  height: 8px;\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  overflow: hidden;\n  display: flex;\n}\n\n.close-call-pool-bar__fill {\n  height: 100%;\n  transition: width 0.3s ease;\n}\n\n.close-call-pool-bar__fill--green {\n  background: linear-gradient(90deg, #00cc88, #00ff88);\n}\n\n.close-call-pool-bar__fill--red {\n  background: linear-gradient(90deg, #ff6655, #ff0054);\n}\n\n.close-call-pool-bar__stats {\n  display: flex;\n  justify-content: space-between;\n  margin-top: 0.5rem;\n}\n\n.close-call-pool-bar__stat {\n  display: flex;\n  flex-direction: column;\n  gap: 0.125rem;\n}\n\n.close-call-pool-bar__stat--green {\n  align-items: flex-start;\n}\n\n.close-call-pool-bar__stat--red {\n  align-items: flex-end;\n}\n\n.close-call-pool-bar__pool-amount {\n  font-family: var(--font-mono);\n  font-size: 0.8rem;\n  text-shadow: 0 0 6px currentColor;\n}\n\n.close-call-pool-bar__odds {\n  font-family: var(--font-mono);\n  font-size: 1rem;\n  opacity: 0.8;\n}\n\n.close-call-pool-bar__carryover {\n  display: block;\n  font-size: 1rem;\n  color: rgba(255, 170, 0, 0.8);\n  margin-top: 0.25rem;\n}\n\n/* Carryover Banner */\n.close-call-carryover {\n  background: linear-gradient(135deg, rgba(255, 170, 0, 0.2), rgba(255, 136, 0, 0.1));\n  border: 1px solid rgba(255, 170, 0, 0.4);\n  border-radius: 3px;\n  padding: 0.75rem 1rem;\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n}\n\n.close-call-carryover__icon {\n  font-size: 1.5rem;\n}\n\n.close-call-carryover__content {\n  flex: 1;\n}\n\n.close-call-carryover__label {\n  font-size: 1rem;\n  color: rgba(255, 170, 0, 0.8);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.close-call-carryover__amount {\n  font-family: var(--font-mono);\n  font-size: 1.125rem;\n  color: #ffaa00;\n  text-shadow: 0 0 10px rgba(255, 170, 0, 0.5);\n}\n\n/* Summary Section */\n.close-call-sidebar__summary {\n  background: rgba(0, 0, 0, 0.2);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 3px;\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.close-call-sidebar__row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.7);\n}\n\n.close-call-sidebar__payout {\n  color: #00ff88;\n  font-family: var(--font-mono);\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n.close-call-sidebar__odds {\n  font-family: var(--font-mono);\n  color: #ffaa00;\n}\n\n/* Action Button */\n.close-call-action-btn {\n  width: 100%;\n  padding: 1rem;\n  background: linear-gradient(135deg, #00ff88, #00cc88);\n  border: none;\n  border-radius: 3px;\n  font-family: var(--font-display);\n  font-size: 1rem;\n  font-weight: 600;\n  color: #000;\n  cursor: pointer;\n  transition: all 0.3s;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.close-call-action-btn:hover:not(:disabled) {\n  transform: translateY(-2px);\n  box-shadow: 0 5px 25px rgba(0, 255, 136, 0.4);\n}\n\n.close-call-action-btn:disabled {\n  background: rgba(255, 255, 255, 0.1);\n  color: rgba(255, 255, 255, 0.4);\n  cursor: not-allowed;\n  transform: none;\n}\n\n.close-call-action-btn--locked {\n  background: linear-gradient(135deg, #ff6644, #ff4466);\n}\n\n/* Result Section with Claim Button */\n.close-call-result-section {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1rem;\n}\n\n/* Claim Payout Button */\n.close-call-claim-btn {\n  padding: 1rem 2rem;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  background: linear-gradient(135deg, var(--color-neon-green) 0%, #39cc14 100%);\n  border: none;\n  color: #000;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.close-call-claim-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: scale(1.05);\n}\n\n.close-call-claim-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n/* Auto-payout received message */\n.close-call-payout-received {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n  padding: 1rem 2rem;\n  background: linear-gradient(135deg, rgba(57, 204, 20, 0.2) 0%, rgba(57, 204, 20, 0.1) 100%);\n  border: 1px solid var(--color-neon-green);\n  border-radius: 2px;\n}\n\n.close-call-payout-received__label {\n  font-family: var(--font-pixel);\n  font-size: 0.65rem;\n  text-transform: uppercase;\n  color: var(--color-neon-green);\n  letter-spacing: 0.05em;\n}\n\n.close-call-payout-received__amount {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-green);\n  text-shadow: 0 0 8px var(--color-neon-green);\n}\n\n/* Active Bet View */\n.close-call-active-bet {\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  border-radius: 3px;\n  padding: 1.25rem;\n}\n\n.close-call-active-bet__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 1rem;\n}\n\n.close-call-active-bet__title {\n  font-family: var(--font-display);\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.close-call-active-bet__status {\n  font-size: 1rem;\n  padding: 0.25rem 0.75rem;\n  border-radius: 20px;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.close-call-active-bet__status--betting {\n  background: rgba(0, 255, 136, 0.2);\n  color: #00ff88;\n  border: 1px solid rgba(0, 255, 136, 0.3);\n}\n\n.close-call-active-bet__status--locked {\n  background: rgba(255, 170, 0, 0.2);\n  color: #ffaa00;\n  border: 1px solid rgba(255, 170, 0, 0.3);\n}\n\n.close-call-active-bet__status--resolving {\n  background: rgba(136, 136, 255, 0.2);\n  color: #8888ff;\n  border: 1px solid rgba(136, 136, 255, 0.3);\n  animation: pulse-resolving 1s ease-in-out infinite;\n}\n\n@keyframes pulse-resolving {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.6; }\n}\n\n.close-call-active-bet__content {\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n}\n\n.close-call-active-bet__row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 0.875rem;\n}\n\n.close-call-active-bet__label {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.close-call-active-bet__value {\n  color: #fff;\n  font-family: var(--font-mono);\n}\n\n.close-call-active-bet__value--green {\n  color: #00cc88;\n  text-shadow: 0 0 8px rgba(0, 204, 136, 0.5);\n}\n\n.close-call-active-bet__value--red {\n  color: #ff4466;\n  text-shadow: 0 0 8px rgba(255, 68, 102, 0.5);\n}\n\n.close-call-active-bet__value--highlight {\n  color: #00ff88;\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n  font-size: 1rem;\n}\n\n/* Round Result Overlay */\n.close-call-result-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(0, 0, 0, 0.85);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n  animation: fadeIn 0.3s ease;\n}\n\n@keyframes fadeIn {\n  from { opacity: 0; }\n  to { opacity: 1; }\n}\n\n.close-call-result {\n  background: rgba(20, 20, 30, 0.95);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 20px;\n  padding: 2rem;\n  text-align: center;\n  max-width: 400px;\n  width: 90%;\n  animation: scaleIn 0.3s ease;\n}\n\n@keyframes scaleIn {\n  from { transform: scale(0.9); opacity: 0; }\n  to { transform: scale(1); opacity: 1; }\n}\n\n.close-call-result--win {\n  border-color: rgba(0, 255, 136, 0.3);\n  box-shadow: 0 0 50px rgba(0, 255, 136, 0.2);\n}\n\n.close-call-result--loss {\n  border-color: rgba(255, 68, 102, 0.3);\n  box-shadow: 0 0 50px rgba(255, 68, 102, 0.2);\n}\n\n.close-call-result--doji {\n  border-color: rgba(255, 170, 0, 0.3);\n  box-shadow: 0 0 50px rgba(255, 170, 0, 0.2);\n}\n\n.close-call-result__icon {\n  font-size: 4rem;\n  margin-bottom: 1rem;\n}\n\n.close-call-result__title {\n  font-family: var(--font-display);\n  font-size: 1.5rem;\n  margin-bottom: 0.5rem;\n}\n\n.close-call-result--win .close-call-result__title {\n  color: #00ff88;\n  text-shadow: 0 0 20px rgba(0, 255, 136, 0.5);\n}\n\n.close-call-result--loss .close-call-result__title {\n  color: #ff4466;\n  text-shadow: 0 0 20px rgba(255, 68, 102, 0.5);\n}\n\n.close-call-result--doji .close-call-result__title {\n  color: #ffaa00;\n  text-shadow: 0 0 20px rgba(255, 170, 0, 0.5);\n}\n\n.close-call-result__outcome {\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.7);\n  margin-bottom: 1.5rem;\n}\n\n.close-call-result__outcome-side {\n  font-weight: 600;\n}\n\n.close-call-result__outcome-side--green {\n  color: #00cc88;\n}\n\n.close-call-result__outcome-side--red {\n  color: #ff4466;\n}\n\n.close-call-result__stats {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n  margin-bottom: 1.5rem;\n  padding: 1rem;\n  background: rgba(0, 0, 0, 0.3);\n  border-radius: 3px;\n}\n\n.close-call-result__stat {\n  display: flex;\n  justify-content: space-between;\n  font-size: 0.875rem;\n}\n\n.close-call-result__stat-label {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.close-call-result__stat-value {\n  color: #fff;\n  font-family: var(--font-mono);\n}\n\n.close-call-result__stat-value--positive {\n  color: #00ff88;\n}\n\n.close-call-result__stat-value--negative {\n  color: #ff4466;\n}\n\n.close-call-result__close-btn {\n  width: 100%;\n  padding: 0.875rem;\n  background: rgba(255, 255, 255, 0.1);\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  border-radius: 3px;\n  color: #fff;\n  font-family: var(--font-display);\n  font-size: 0.875rem;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.close-call-result__close-btn:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n/* Fairness Info */\n.close-call-sidebar__fairness {\n  background: rgba(0, 0, 0, 0.2);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 3px;\n  padding: 0.75rem 1rem;\n}\n\n.close-call-sidebar__fairness-title {\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.5);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin-bottom: 0.5rem;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.close-call-sidebar__fairness-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 1rem;\n  padding: 0.25rem 0;\n}\n\n.close-call-sidebar__fairness-row span:first-child {\n  color: rgba(255, 255, 255, 0.5);\n}\n\n.close-call-sidebar__hash {\n  font-family: var(--font-mono);\n  color: rgba(255, 255, 255, 0.7);\n  font-size: 0.9rem;\n  cursor: pointer;\n  transition: color 0.2s;\n}\n\n.close-call-sidebar__hash:hover {\n  color: #fff;\n}\n\n.close-call-sidebar__hash--revealed {\n  color: #00ff88;\n}\n\n/* History Modal */\n.close-call-history-modal {\n  display: flex;\n  flex-direction: column;\n  gap: 1.5rem;\n}\n\n.close-call-history-modal__section {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.close-call-history-modal__section-title {\n  font-family: var(--font-display);\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.6);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  margin-bottom: 0.25rem;\n}\n\n.close-call-history-modal__row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.375rem 0;\n  font-size: 0.875rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.close-call-history-modal__row:last-child {\n  border-bottom: none;\n}\n\n.close-call-history-modal__row span:first-child {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.close-call-history-modal__highlight {\n  color: #00ff88;\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n.close-call-history-modal__hash {\n  font-family: var(--font-mono);\n  font-size: 0.9rem;\n  color: rgba(255, 255, 255, 0.5);\n  max-width: 200px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.close-call-history-modal__hash--revealed {\n  color: #00ff88;\n}\n\n.close-call-result-link {\n  display: inline-block;\n  margin-top: 0.5rem;\n  padding: 0.3rem 0.75rem;\n  color: #fff;\n  font-size: 0.8rem;\n  font-weight: 600;\n  text-decoration: none;\n  background: rgba(255, 255, 255, 0.12);\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  border-radius: 4px;\n  transition: background 0.2s, border-color 0.2s;\n}\n\n.close-call-result-link:hover {\n  background: rgba(255, 255, 255, 0.2);\n  border-color: rgba(255, 255, 255, 0.35);\n}\n\n.close-call-history-modal__verify-link {\n  display: block;\n  text-align: center;\n  padding: 0.75rem;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  color: rgba(255, 255, 255, 0.7);\n  text-decoration: none;\n  font-size: 0.875rem;\n  transition: all 0.2s;\n}\n\n.close-call-history-modal__verify-link:hover {\n  background: rgba(255, 255, 255, 0.1);\n  color: #fff;\n}\n\n/* History Entry Result */\n.close-call-history-result {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n}\n\n.close-call-history-result__separator {\n  color: rgba(255, 255, 255, 0.3);\n}\n\n/* Result Overlay Content */\n.close-call-result-overlay__content {\n  position: relative;\n  background: rgba(20, 20, 30, 0.95);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 20px;\n  padding: 2rem;\n  text-align: center;\n  max-width: 400px;\n  width: 90%;\n  animation: scaleIn 0.3s ease;\n  overflow: visible;\n}\n\n.close-call-result-overlay__content--win {\n  border-color: rgba(0, 255, 136, 0.3);\n  box-shadow: 0 0 50px rgba(0, 255, 136, 0.2);\n}\n\n.close-call-result-overlay__content--loss {\n  border-color: rgba(255, 68, 102, 0.3);\n  box-shadow: 0 0 50px rgba(255, 68, 102, 0.2);\n}\n\n.close-call-result-overlay__content--doji {\n  border-color: rgba(255, 170, 0, 0.3);\n  box-shadow: 0 0 50px rgba(255, 170, 0, 0.2);\n}\n\n.close-call-result-overlay__candle {\n  display: flex;\n  justify-content: center;\n  margin-bottom: 1rem;\n}\n\n.close-call-result-overlay__candle-body {\n  width: 30px;\n  height: 60px;\n  border-radius: 2px;\n  animation: candlePulse 1s ease-in-out infinite;\n}\n\n@keyframes candlePulse {\n  0%, 100% { opacity: 1; transform: scale(1); }\n  50% { opacity: 0.8; transform: scale(1.05); }\n}\n\n.close-call-result-overlay__result {\n  font-family: var(--font-display);\n  font-size: 1.75rem;\n  font-weight: bold;\n  margin-bottom: 1rem;\n  text-shadow: 0 0 20px currentColor;\n}\n\n.close-call-result-overlay__payout {\n  font-family: var(--font-mono);\n  font-size: 1.125rem;\n  color: rgba(255, 255, 255, 0.8);\n  margin-bottom: 1.5rem;\n}\n\n.close-call-result-overlay__payout--win {\n  color: #00ff88;\n  text-shadow: 0 0 10px rgba(0, 255, 136, 0.5);\n}\n\n.close-call-result-overlay__details {\n  display: flex;\n  gap: 1.5rem;\n  justify-content: center;\n  margin-bottom: 1.5rem;\n  padding: 0.75rem;\n  background: rgba(0, 0, 0, 0.3);\n  border-radius: 3px;\n}\n\n.close-call-result-overlay__price {\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.close-call-result-overlay__change {\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n  font-weight: bold;\n}\n\n.close-call-result-overlay__fairness {\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n  margin-bottom: 1.5rem;\n  padding: 0.75rem;\n  background: rgba(0, 0, 0, 0.2);\n  border-radius: 2px;\n  font-size: 1rem;\n}\n\n.close-call-result-overlay__fairness-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.close-call-result-overlay__fairness-row span:first-child {\n  color: rgba(255, 255, 255, 0.5);\n}\n\n.close-call-result-overlay__hash {\n  font-family: var(--font-mono);\n  color: rgba(255, 255, 255, 0.6);\n  font-size: 0.9rem;\n}\n\n.close-call-result-overlay__hash--revealed {\n  color: #00ff88;\n}\n\n.close-call-result-overlay__close {\n  width: 100%;\n  padding: 0.875rem;\n  background: rgba(255, 255, 255, 0.1);\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  border-radius: 3px;\n  color: #fff;\n  font-family: var(--font-display);\n  font-size: 0.875rem;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.close-call-result-overlay__close:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n/* Win Animation - Coin Fountain */\n.close-call-win-animation {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  pointer-events: none;\n  z-index: 10;\n}\n\n.close-call-win-animation__stars {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.close-call-win-animation__star {\n  position: absolute;\n  font-size: 1.5rem;\n  color: #ffd700;\n  text-shadow: 0 0 8px #ffd700;\n  animation: close-call-star-burst 1s ease-out forwards;\n  animation-delay: calc(var(--star-index) * 0.05s);\n  opacity: 0;\n}\n\n.close-call-win-animation__star:nth-child(1) { --star-angle: 0deg; }\n.close-call-win-animation__star:nth-child(2) { --star-angle: 45deg; }\n.close-call-win-animation__star:nth-child(3) { --star-angle: 90deg; }\n.close-call-win-animation__star:nth-child(4) { --star-angle: 135deg; }\n.close-call-win-animation__star:nth-child(5) { --star-angle: 180deg; }\n.close-call-win-animation__star:nth-child(6) { --star-angle: 225deg; }\n.close-call-win-animation__star:nth-child(7) { --star-angle: 270deg; }\n.close-call-win-animation__star:nth-child(8) { --star-angle: 315deg; }\n\n@keyframes close-call-star-burst {\n  0% {\n    opacity: 1;\n    transform: rotate(var(--star-angle)) translateY(0) scale(0.5);\n  }\n  50% {\n    opacity: 1;\n    transform: rotate(var(--star-angle)) translateY(-80px) scale(1);\n  }\n  100% {\n    opacity: 0;\n    transform: rotate(var(--star-angle)) translateY(-120px) scale(0.5);\n  }\n}\n\n.close-call-win-animation__coins {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n.close-call-win-animation__coin {\n  position: absolute;\n  font-size: 1.5rem;\n  color: var(--color-gold, #ffd700);\n  text-shadow: 0 0 8px var(--color-gold, #ffd700), 0 0 16px #ff9900;\n  animation: close-call-coin-fountain 1.8s ease-out forwards;\n  animation-delay: calc(var(--coin-index) * 0.1s);\n  opacity: 0;\n}\n\n.close-call-win-animation__coin:nth-child(1) { --coin-x: -60px; }\n.close-call-win-animation__coin:nth-child(2) { --coin-x: -30px; }\n.close-call-win-animation__coin:nth-child(3) { --coin-x: 0px; }\n.close-call-win-animation__coin:nth-child(4) { --coin-x: 30px; }\n.close-call-win-animation__coin:nth-child(5) { --coin-x: 60px; }\n.close-call-win-animation__coin:nth-child(6) { --coin-x: 0px; }\n\n@keyframes close-call-coin-fountain {\n  0% {\n    opacity: 1;\n    transform: translateX(var(--coin-x)) translateY(0) scale(0.5);\n  }\n  30% {\n    opacity: 1;\n    transform: translateX(var(--coin-x)) translateY(-100px) scale(1);\n  }\n  100% {\n    opacity: 0;\n    transform: translateX(var(--coin-x)) translateY(50px) scale(0.3);\n  }\n}\n\n/* ===========================================\n   Result Banner - Shared Game Result Notification\n   =========================================== */\n.rng-result-banner {\n  position: absolute;\n  top: 8px;\n  left: 50%;\n  transform: translateX(-50%) translateY(-20px);\n  z-index: 100;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n  padding: 0.75rem 1.5rem;\n  background: linear-gradient(135deg, rgba(20, 20, 30, 0.97), rgba(30, 30, 45, 0.97));\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  border-radius: 3px;\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), 0 0 24px rgba(0, 0, 0, 0.4);\n  backdrop-filter: blur(16px);\n  cursor: pointer;\n  opacity: 0;\n  transition: all 0.3s ease;\n}\n\n.rng-result-banner--visible {\n  opacity: 1;\n  transform: translateX(-50%) translateY(0);\n}\n\n.rng-result-banner__outcome {\n  font-family: var(--font-display);\n  font-size: 1.25rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.rng-result-banner__user-result {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  font-family: var(--font-mono);\n  font-size: 0.875rem;\n}\n\n.rng-result-banner__user-result--won {\n  color: #00ff88;\n}\n\n.rng-result-banner__user-result--lost {\n  color: #ff6b6b;\n}\n\n.rng-result-banner__status {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  font-weight: 600;\n}\n\n.rng-result-banner__heartbreak {\n  animation: rng-banner-heartbreak 0.6s ease-out;\n}\n\n@keyframes rng-banner-heartbreak {\n  0%, 100% { transform: scale(1); }\n  25% { transform: scale(1.3); }\n  50% { transform: scale(0.9); }\n  75% { transform: scale(1.1); }\n}\n\n.rng-result-banner__payout {\n  color: #00ff88;\n  font-weight: 700;\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n.rng-result-banner__payout--lost {\n  color: #ff6b6b;\n  text-shadow: 0 0 8px rgba(255, 107, 107, 0.5);\n}\n\n.rng-result-banner__usd {\n  color: #888;\n  font-size: 1rem;\n  margin-left: 0.25rem;\n}\n\n/* Banner win animation */\n.rng-result-banner__win-animation {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  pointer-events: none;\n}\n\n.rng-result-banner__star {\n  position: absolute;\n  font-size: 1rem;\n  color: #ffd700;\n  text-shadow: 0 0 6px #ffd700;\n  animation: rng-banner-star-burst 0.8s ease-out forwards;\n  animation-delay: calc(var(--star-index) * 0.05s);\n  opacity: 0;\n}\n\n.rng-result-banner__star:nth-child(1) { --star-angle: 0deg; }\n.rng-result-banner__star:nth-child(2) { --star-angle: 60deg; }\n.rng-result-banner__star:nth-child(3) { --star-angle: 120deg; }\n.rng-result-banner__star:nth-child(4) { --star-angle: 180deg; }\n.rng-result-banner__star:nth-child(5) { --star-angle: 240deg; }\n.rng-result-banner__star:nth-child(6) { --star-angle: 300deg; }\n\n@keyframes rng-banner-star-burst {\n  0% {\n    opacity: 1;\n    transform: rotate(var(--star-angle)) translateX(0) scale(0.5);\n  }\n  100% {\n    opacity: 0;\n    transform: rotate(var(--star-angle)) translateX(60px) scale(1);\n  }\n}\n\n/* Responsive */\n@media (max-width: 768px) {\n  .close-call-chart__container {\n    height: 220px;\n  }\n\n  .close-call-chart__current-price {\n    font-size: 1.5rem;\n  }\n\n  .close-call-chart__ohl {\n    gap: 1px;\n  }\n\n  .close-call-side-selector {\n    gap: 0.5rem;\n  }\n\n  .close-call-side-btn {\n    padding: 0.75rem;\n  }\n\n  .close-call-side-btn__icon {\n    font-size: 1.25rem;\n  }\n\n  .close-call-side-btn__label {\n    font-size: 0.875rem;\n  }\n\n  .close-call-result {\n    padding: 1.5rem;\n  }\n\n  .close-call-result__icon {\n    font-size: 3rem;\n  }\n\n  .close-call-result__title {\n    font-size: 1.25rem;\n  }\n}\n\n@media (max-width: 480px) {\n  .close-call-chart__container {\n    height: 200px;\n  }\n\n  .close-call-chart__current-price {\n    font-size: 1.25rem;\n  }\n\n  .close-call-chart__price-panel {\n    width: 40%;\n  }\n\n  .close-call-chart__ohl {\n    gap: 1px;\n  }\n\n  .close-call-bet-input__row {\n    flex-direction: column;\n  }\n\n  .close-call-bet-input__adjustments {\n    justify-content: center;\n  }\n\n  .close-call-side-btn__pool,\n  .close-call-side-btn__odds {\n    font-size: 0.9rem;\n  }\n}\n\n/* ============================================\n   CRYPTO CRASH SIMULATOR - Game Styles\n   ============================================ */\n\n.crash-main {\n  width: 100%;\n  min-height: 500px;\n}\n\n/* Active Round View */\n.crash-active-round {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  height: 100%;\n  position: relative;\n}\n\n/* Back to Tiers button - consistent with Lord of RNGs */\n.crash-active-round__back {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  background: none;\n  border: none;\n  color: var(--color-text-muted);\n  font-family: var(--font-pixel);\n  font-size: 0.65rem;\n  cursor: pointer;\n  transition: color 0.2s;\n  padding: 0.25rem 0;\n  margin-bottom: 0.5rem;\n  align-self: flex-start;\n}\n\n.crash-active-round__back:hover {\n  color: var(--color-neon-cyan);\n}\n\n.crash-active-round__back svg {\n  width: 16px;\n  height: 16px;\n}\n\n.crash-active-round--loading {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  min-height: 400px;\n}\n\n.crash-active-round__loading {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.crash-active-round__main {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n  flex: 1;\n}\n\n.crash-active-round__chart-container {\n  position: relative;\n  flex: 1;\n  min-height: 350px;\n}\n\n.crash-active-round__controls {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.crash-active-round__winner-overlay {\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(17, 17, 17, 0.92);\n  z-index: 10;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: 2px;\n  backdrop-filter: blur(4px);\n}\n\n.crash-active-round__connect-prompt {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 16px 24px;\n  text-align: center;\n  color: var(--color-text-muted);\n  font-size: 0.9rem;\n}\n\n.crash-active-round__betting {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.crash-active-round__bet-button {\n  background: linear-gradient(135deg, var(--color-neon-green), #00cc66);\n  color: #001a00;\n  border: none;\n  padding: 12px 32px;\n  font-size: 0.9rem;\n  font-family: var(--font-pixel);\n  text-transform: uppercase;\n  cursor: pointer;\n  border-radius: 2px;\n  text-shadow: none;\n  transition: all 0.2s ease;\n  min-width: 200px;\n}\n\n.crash-active-round__bet-button:hover:not(:disabled) {\n  transform: translateY(-2px);\n  box-shadow: 0 4px 16px var(--color-success-glow);\n}\n\n.crash-active-round__bet-button:disabled {\n  background: var(--color-surface);\n  color: var(--color-text-muted);\n  cursor: not-allowed;\n}\n\n.crash-active-round__bet-placed {\n  background: var(--color-surface);\n  border: 1px solid var(--color-neon-green);\n  border-radius: 2px;\n  padding: 12px 24px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 16px;\n}\n\n.crash-active-round__bet-placed-label {\n  color: var(--color-neon-green);\n  font-size: 0.9rem;\n  text-shadow: none;\n  font-family: var(--font-pixel);\n}\n\n.crash-active-round__bet-placed-tier {\n  color: var(--color-text);\n  font-size: 0.65rem;\n  text-transform: uppercase;\n}\n\n.crash-active-round__bet-placed-wait {\n  color: var(--color-text-muted);\n  font-size: 0.8rem;\n}\n\n.crash-active-round__tier-overview {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-active-round__tier-overview-title {\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n  margin-bottom: 8px;\n  text-transform: uppercase;\n}\n\n.crash-active-round__tier-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 8px;\n  border-radius: 2px;\n  margin-bottom: 4px;\n  background: rgba(255, 255, 255, 0.02);\n}\n\n.crash-active-round__tier-item--user {\n  background: rgba(0, 255, 136, 0.1);\n  border: 1px solid rgba(0, 255, 136, 0.3);\n}\n\n.crash-active-round__tier-item-name {\n  font-size: 0.6rem;\n  color: var(--color-text);\n  text-transform: capitalize;\n}\n\n.crash-active-round__tier-item-players {\n  font-size: 0.8rem;\n  color: var(--color-text-muted);\n}\n\n.crash-active-round__tier-item-pool {\n  font-size: 0.6rem;\n  color: var(--color-neon-cyan);\n}\n\n/* Crash Chart */\n.crash-chart {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px 16px;\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n}\n\n.crash-chart__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 8px;\n  flex-shrink: 0;\n}\n\n.crash-chart__title {\n  font-size: 0.65rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.crash-chart__status {\n  font-size: 0.8rem;\n  padding: 3px 8px;\n  border-radius: 2px;\n  font-family: var(--font-pixel);\n}\n\n.crash-chart__status--betting {\n  background: rgba(255, 215, 0, 0.2);\n  color: var(--color-neon-yellow);\n}\n\n.crash-chart__status--running {\n  background: rgba(0, 255, 136, 0.2);\n  color: var(--color-neon-green);\n  animation: pulse-glow 1s infinite;\n}\n\n.crash-chart__status--crashed {\n  background: rgba(255, 0, 84, 0.2);\n  color: var(--color-neon-pink);\n}\n\n.crash-chart__container {\n  position: relative;\n  flex: 1;\n  min-height: 320px;\n}\n\n.crash-chart__canvas {\n  width: 100%;\n  height: 100%;\n}\n\n.crash-chart__multiplier-overlay {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  text-align: center;\n  pointer-events: none;\n}\n\n.crash-chart__multiplier-overlay--crashed {\n  animation: crash-shake 0.3s ease-out;\n}\n\n.crash-chart__multiplier {\n  font-size: 3rem;\n  font-family: var(--font-pixel);\n  text-shadow: none;\n}\n\n.crash-chart__betting-overlay {\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(17, 17, 17, 0.7);\n}\n\n.crash-chart__waiting-text {\n  font-size: 1.2rem;\n  color: var(--color-neon-yellow);\n  text-shadow: none;\n}\n\n@keyframes crash-shake {\n  0%, 100% { transform: translate(-50%, -50%); }\n  25% { transform: translate(-52%, -48%); }\n  50% { transform: translate(-48%, -52%); }\n  75% { transform: translate(-50%, -50%) scale(1.05); }\n}\n\n/* Status Bar (compact multiplier display) */\n.crash-status-bar {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 8px 16px;\n  gap: 16px;\n}\n\n.crash-status-bar--running {\n  border-color: var(--color-neon-green);\n  box-shadow: 0 0 8px rgba(0, 255, 136, 0.2);\n}\n\n.crash-status-bar--crashed,\n.crash-status-bar--revealing {\n  border-color: var(--color-neon-pink);\n  box-shadow: 0 0 8px rgba(255, 0, 84, 0.2);\n}\n\n.crash-status-bar__phase {\n  min-width: 70px;\n}\n\n.crash-status-bar__phase-text {\n  font-size: 0.8rem;\n  font-family: var(--font-pixel);\n  text-transform: uppercase;\n  padding: 4px 8px;\n  border-radius: 2px;\n}\n\n.crash-status-bar__phase-text--betting {\n  background: rgba(255, 215, 0, 0.2);\n  color: var(--color-neon-yellow);\n}\n\n.crash-status-bar__phase-text--running {\n  background: rgba(0, 255, 136, 0.2);\n  color: var(--color-neon-green);\n  animation: pulse-glow 1s infinite;\n}\n\n.crash-status-bar__phase-text--crashed {\n  background: rgba(255, 0, 84, 0.2);\n  color: var(--color-neon-pink);\n}\n\n.crash-status-bar__center {\n  flex: 1;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}\n\n.crash-status-bar__countdown {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.crash-status-bar__countdown-time {\n  font-size: 1rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-yellow);\n  text-shadow: none;\n  min-width: 32px;\n  text-align: center;\n}\n\n.crash-status-bar__progress {\n  width: 120px;\n  height: 4px;\n  background: var(--color-surface-elevated);\n  border-radius: 2px;\n  overflow: hidden;\n}\n\n.crash-status-bar__progress-fill {\n  height: 100%;\n  background: linear-gradient(90deg, var(--color-neon-yellow), var(--color-neon-orange));\n  transition: width 0.1s linear;\n}\n\n.crash-status-bar__multiplier {\n  font-size: 1.2rem;\n  font-family: var(--font-pixel);\n}\n\n.crash-status-bar__multiplier--running {\n  color: var(--color-neon-green);\n  text-shadow: none;\n  animation: multiplier-pulse 0.5s ease-in-out infinite;\n}\n\n.crash-status-bar__multiplier--crashed,\n.crash-status-bar__multiplier--revealing {\n  color: var(--color-neon-pink);\n  text-shadow: none;\n}\n\n.crash-status-bar__status {\n  min-width: 100px;\n  text-align: right;\n  font-size: 0.8rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n/* Waiting for players state */\n.crash-status-bar--waiting {\n  border-color: var(--color-neon-orange);\n}\n\n.crash-status-bar__phase-text--waiting {\n  color: var(--color-neon-orange);\n  text-shadow: none;\n  animation: waiting-pulse 1.5s ease-in-out infinite;\n}\n\n.crash-status-bar__waiting {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n.crash-status-bar__waiting-text {\n  font-size: 0.9rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-orange);\n  text-shadow: none;\n}\n\n@keyframes waiting-pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.6; }\n}\n\n@keyframes multiplier-pulse {\n  0%, 100% { transform: scale(1); }\n  50% { transform: scale(1.02); }\n}\n\n/* Tier Selector */\n.crash-tier-selector {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-tier-selector__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 12px;\n}\n\n.crash-tier-selector__title {\n  font-size: 0.65rem;\n  color: var(--color-text);\n  text-transform: uppercase;\n}\n\n.crash-tier-selector__locked {\n  font-size: 0.8rem;\n  color: var(--color-neon-pink);\n}\n\n.crash-tier-selector__grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 8px;\n}\n\n.crash-tier-card {\n  background: var(--color-surface-elevated);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 10px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  position: relative;\n  overflow: hidden;\n}\n\n.crash-tier-card:hover:not(:disabled) {\n  border-color: var(--tier-color, var(--color-border));\n  box-shadow: 0 0 8px rgba(var(--tier-color), 0.3);\n}\n\n.crash-tier-card--selected {\n  border-color: var(--tier-color, var(--color-neon-cyan));\n  background: rgba(255, 255, 255, 0.05);\n}\n\n.crash-tier-card--jackpot {\n  animation: jackpot-pulse 2s infinite;\n}\n\n.crash-tier-card:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.crash-tier-card__jackpot-badge {\n  position: absolute;\n  top: -1px;\n  left: -1px;\n  right: -1px;\n  background: linear-gradient(90deg, var(--color-neon-gold), var(--color-neon-orange));\n  color: #000;\n  font-size: 0.45rem;\n  padding: 2px 4px;\n  text-align: center;\n  font-weight: bold;\n  text-transform: uppercase;\n}\n\n.crash-tier-card__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 6px;\n}\n\n.crash-tier-card__name {\n  font-size: 0.8rem;\n  color: var(--tier-color, var(--color-text));\n  text-transform: uppercase;\n  text-shadow: none;\n}\n\n.crash-tier-card__amount {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.crash-tier-card__stats {\n  display: flex;\n  gap: 8px;\n}\n\n.crash-tier-card__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 2px;\n}\n\n.crash-tier-card__stat-value {\n  font-size: 0.6rem;\n  color: var(--color-text);\n}\n\n.crash-tier-card__stat-label {\n  font-size: 0.45rem;\n  color: var(--color-text-muted);\n}\n\n.crash-tier-card__user-bet {\n  position: absolute;\n  bottom: 2px;\n  right: 4px;\n  font-size: 0.4rem;\n  color: var(--color-neon-green);\n  text-transform: uppercase;\n}\n\n@keyframes jackpot-pulse {\n  0%, 100% { box-shadow: 0 0 8px rgba(255, 215, 0, 0.3); }\n  50% { box-shadow: 0 0 16px rgba(255, 215, 0, 0.6); }\n}\n\n/* Crash Tier Lobby (Full Page) */\n.crash-tier-lobby {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.5rem;\n  width: 100%;\n  padding: 2rem 1rem;\n}\n\n.crash-tier-lobby--loading {\n  justify-content: center;\n  min-height: 300px;\n}\n\n.crash-tier-lobby__loading {\n  text-align: center;\n  color: var(--color-text-muted);\n  font-size: 0.875rem;\n}\n\n.crash-tier-lobby__instruction {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-align: center;\n  margin: 0;\n}\n\n.crash-tier-lobby__grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(280px, 400px));\n  gap: 1rem;\n  justify-content: center;\n  width: 100%;\n}\n\n/* Crash Tier Lobby Cards */\n.crash-tier-lobby .crash-tier-card {\n  background: var(--color-surface);\n  border: 2px solid var(--color-border);\n  border-radius: 0;\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n  cursor: pointer;\n  transition: all 0.2s;\n  text-align: left;\n  position: relative;\n  overflow: visible;\n}\n\n.crash-tier-lobby .crash-tier-card:hover {\n  border-color: var(--tier-color);\n  box-shadow: none;\n}\n\n.crash-tier-lobby .crash-tier-card--countdown {\n  animation: tier-pulse 1s ease-in-out infinite;\n}\n\n.crash-tier-lobby .crash-tier-card--running {\n  border-color: var(--color-neon-green);\n  animation: crash-running-glow 0.5s ease-in-out infinite alternate;\n}\n\n.crash-tier-lobby .crash-tier-card--crashed {\n  border-color: var(--color-neon-pink);\n}\n\n.crash-tier-lobby .crash-tier-card--jackpot {\n  animation: crash-jackpot-shine 2s infinite;\n}\n\n.crash-tier-lobby .crash-tier-card--jackpot::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  border: 2px solid var(--color-neon-gold);\n  pointer-events: none;\n  animation: jackpot-border-pulse 2s infinite;\n}\n\n@keyframes crash-running-glow {\n  0% { box-shadow: none; }\n  100% { box-shadow: none; }\n}\n\n@keyframes crash-jackpot-shine {\n  0%, 100% {\n    box-shadow: 0 0 8px rgba(255, 215, 0, 0.3), inset 0 0 20px rgba(255, 215, 0, 0.05);\n  }\n  50% {\n    box-shadow: 0 0 20px rgba(255, 215, 0, 0.5), inset 0 0 30px rgba(255, 215, 0, 0.1);\n  }\n}\n\n@keyframes jackpot-border-pulse {\n  0%, 100% { border-color: var(--color-neon-gold); opacity: 0.5; }\n  50% { border-color: var(--color-neon-orange); opacity: 1; }\n}\n\n.crash-tier-lobby .crash-tier-card__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 0;\n}\n\n.crash-tier-lobby .crash-tier-card__name {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--tier-color);\n  text-transform: uppercase;\n  text-shadow: none;\n}\n\n.crash-tier-lobby .crash-tier-card__amount {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  font-weight: bold;\n}\n\n/* Jackpot Badge */\n.crash-tier-card__jackpot {\n  background: linear-gradient(90deg, var(--color-neon-gold), var(--color-neon-orange));\n  color: #000;\n  padding: 0.5rem 0.75rem;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin: -0.25rem 0 0.25rem 0;\n  animation: jackpot-shimmer 3s infinite;\n}\n\n.crash-tier-card__jackpot-label {\n  font-size: 0.6rem;\n  font-weight: bold;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n}\n\n.crash-tier-card__jackpot-amount {\n  font-size: 1rem;\n  font-weight: bold;\n  font-family: var(--font-pixel);\n}\n\n@keyframes jackpot-shimmer {\n  0% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n  100% { background-position: 0% 50%; }\n}\n\n.crash-tier-lobby .crash-tier-card__stats {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 0.5rem;\n}\n\n.crash-tier-lobby .crash-tier-card__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.crash-tier-lobby .crash-tier-card__stat-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.crash-tier-lobby .crash-tier-card__stat-value {\n  font-size: 1rem;\n  color: var(--color-text);\n  font-weight: bold;\n}\n\n.crash-tier-lobby .crash-tier-card__stat-value--highlight {\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n/* Phase Display */\n.crash-tier-lobby .crash-tier-card__phase {\n  text-align: center;\n  padding-top: 0.5rem;\n  border-top: 1px solid var(--color-border);\n  min-height: 2rem;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.crash-tier-lobby .crash-tier-card__phase-text {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.crash-tier-lobby .crash-tier-card__countdown {\n  display: flex;\n  flex-direction: row;\n  align-items: baseline;\n  gap: 0.5rem;\n}\n\n.crash-tier-lobby .crash-tier-card__countdown-value {\n  font-size: 1.25rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.crash-tier-lobby .crash-tier-card__countdown-label {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.crash-tier-lobby .crash-tier-card__multiplier {\n  font-size: 1.5rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-green);\n  text-shadow: none;\n  animation: multiplier-pulse 0.5s ease-in-out infinite alternate;\n}\n\n@keyframes multiplier-pulse {\n  0% { transform: scale(1); }\n  100% { transform: scale(1.05); }\n}\n\n/* Responsive for Crash Tier Lobby */\n@media (max-width: 768px) {\n  .crash-tier-lobby__grid {\n    grid-template-columns: 1fr;\n    max-width: 400px;\n  }\n}\n\n/* Cash Out Button */\n.crash-cashout {\n  display: flex;\n  justify-content: center;\n}\n\n.crash-cashout__button {\n  min-width: 220px;\n  border: none;\n  border-radius: 2px;\n  padding: 12px 24px;\n  font-family: var(--font-pixel);\n  cursor: pointer;\n  transition: all 0.2s ease;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 2px;\n}\n\n.crash-cashout__button--disabled {\n  background: var(--color-surface);\n  color: var(--color-text-muted);\n  cursor: not-allowed;\n}\n\n.crash-cashout__button--waiting {\n  background: var(--color-surface-elevated);\n  color: var(--color-text-dim);\n  cursor: wait;\n}\n\n.crash-cashout__button--active {\n  background: linear-gradient(135deg, var(--color-neon-pink), var(--color-neon-magenta));\n  color: #fff;\n  animation: cashout-ready 1s infinite;\n}\n\n.crash-cashout__button--active:hover {\n  transform: scale(1.02);\n  box-shadow: 0 0 24px var(--color-primary-glow);\n}\n\n.crash-cashout__button--loading {\n  opacity: 0.8;\n  cursor: wait;\n}\n\n.crash-cashout__button-main {\n  font-size: 0.8rem;\n  text-transform: uppercase;\n}\n\n.crash-cashout__button-multiplier {\n  font-size: 0.65rem;\n  opacity: 0.9;\n}\n\n.crash-cashout__button-payout {\n  font-size: 0.8rem;\n  opacity: 0.8;\n}\n\n.crash-cashout__button-text {\n  font-size: 0.65rem;\n}\n\n.crash-cashout__cashed-out,\n.crash-cashout__lost {\n  background: var(--color-surface);\n  border-radius: 2px;\n  padding: 12px 24px;\n  text-align: center;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 16px;\n}\n\n.crash-cashout__cashed-out {\n  border: 1px solid var(--color-neon-green);\n}\n\n.crash-cashout__lost {\n  border: 1px solid var(--color-neon-pink);\n}\n\n.crash-cashout__label {\n  font-size: 0.6rem;\n  text-transform: uppercase;\n  font-family: var(--font-pixel);\n}\n\n.crash-cashout__cashed-out .crash-cashout__label {\n  color: var(--color-neon-green);\n}\n\n.crash-cashout__lost .crash-cashout__label {\n  color: var(--color-neon-pink);\n}\n\n.crash-cashout__locked-multiplier {\n  font-size: 1.1rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.crash-cashout__result {\n  font-size: 0.8rem;\n  color: var(--color-text-muted);\n}\n\n.crash-cashout__result--success {\n  color: var(--color-neon-green);\n}\n\n.crash-cashout__lost-text {\n  font-size: 0.8rem;\n  color: var(--color-text-muted);\n}\n\n@keyframes cashout-ready {\n  0%, 100% { box-shadow: 0 0 8px var(--color-primary-glow); }\n  50% { box-shadow: 0 0 24px var(--color-primary-glow); }\n}\n\n/* Player Cashouts */\n.crash-cashouts {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-cashouts__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 8px;\n}\n\n.crash-cashouts__title {\n  font-size: 0.6rem;\n  color: var(--color-text);\n  text-transform: uppercase;\n}\n\n.crash-cashouts__count {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.crash-cashouts__empty {\n  font-size: 0.8rem;\n  color: var(--color-text-muted);\n  text-align: center;\n  padding: 16px;\n}\n\n.crash-cashouts__list {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  max-height: 150px;\n  overflow-y: auto;\n}\n\n.crash-cashouts__item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 6px 8px;\n  background: rgba(255, 255, 255, 0.02);\n  border-radius: 2px;\n  font-size: 0.8rem;\n}\n\n.crash-cashouts__item--user {\n  background: rgba(0, 255, 136, 0.1);\n  border: 1px solid rgba(0, 255, 136, 0.2);\n}\n\n.crash-cashouts__player {\n  color: var(--color-text);\n}\n\n.crash-cashouts__tier {\n  color: var(--tier-color, var(--color-text-muted));\n  text-transform: capitalize;\n  font-size: 1rem;\n}\n\n.crash-cashouts__multiplier {\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n/* Winner Reveal */\n.crash-winner-reveal {\n  padding: 24px;\n  width: 100%;\n  max-width: 500px;\n}\n\n.crash-winner-reveal__user-win {\n  margin-bottom: 24px;\n}\n\n.crash-winner-reveal__celebration {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 8px;\n  padding: 24px;\n  background: linear-gradient(135deg, rgba(0, 255, 136, 0.2), rgba(0, 255, 128, 0.1));\n  border: 2px solid var(--color-neon-green);\n  border-radius: 3px;\n  animation: winner-glow 1s infinite;\n}\n\n.crash-winner-reveal__celebration-text {\n  font-size: 1.5rem;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.crash-winner-reveal__celebration-tier {\n  font-size: 0.8rem;\n  color: var(--color-text);\n}\n\n.crash-winner-reveal__celebration-payout {\n  font-size: 1.2rem;\n  color: var(--color-neon-yellow);\n  text-shadow: none;\n}\n\n.crash-winner-reveal__celebration-multiplier {\n  font-size: 0.9rem;\n  color: var(--color-text-muted);\n}\n\n@keyframes winner-glow {\n  0%, 100% { box-shadow: 0 0 16px var(--color-success-glow); }\n  50% { box-shadow: 0 0 32px var(--color-success-glow); }\n}\n\n.crash-winner-reveal__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 16px;\n}\n\n.crash-winner-reveal__title {\n  font-size: 0.8rem;\n  color: var(--color-text);\n}\n\n.crash-winner-reveal__crash-point {\n  font-size: 0.9rem;\n  color: var(--color-neon-pink);\n}\n\n.crash-winner-reveal__close {\n  background: transparent;\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  color: var(--color-text-muted);\n  font-size: 1.2rem;\n  line-height: 1;\n  padding: 2px 8px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.crash-winner-reveal__close:hover {\n  background: rgba(255, 255, 255, 0.1);\n  color: var(--color-text);\n  border-color: var(--color-text-muted);\n}\n\n.crash-winner-reveal__tiers {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.crash-winner-reveal__tier {\n  background: var(--color-surface-elevated);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-winner-reveal__tier--user-win {\n  border-color: var(--color-neon-green);\n  background: rgba(0, 255, 136, 0.1);\n}\n\n.crash-winner-reveal__tier-header {\n  display: flex;\n  justify-content: space-between;\n  margin-bottom: 8px;\n}\n\n.crash-winner-reveal__tier-name {\n  font-size: 0.65rem;\n  color: var(--tier-color, var(--color-text));\n  text-transform: uppercase;\n}\n\n.crash-winner-reveal__tier-pool {\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n}\n\n.crash-winner-reveal__tier-winner {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.crash-winner-reveal__winner-name {\n  font-size: 0.6rem;\n  color: var(--color-text);\n}\n\n.crash-winner-reveal__winner-multiplier {\n  font-size: 0.65rem;\n  color: var(--color-neon-green);\n}\n\n.crash-winner-reveal__winner-payout {\n  font-size: 0.9rem;\n  color: var(--color-neon-yellow);\n  text-shadow: none;\n}\n\n.crash-winner-reveal__tier-no-winner {\n  text-align: center;\n}\n\n.crash-winner-reveal__no-winner-text {\n  font-size: 0.8rem;\n  color: var(--color-neon-orange);\n}\n\n.crash-winner-reveal__next {\n  margin-top: 16px;\n  text-align: center;\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n}\n\n/* Crash Sidebar */\n.crash-sidebar {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.crash-sidebar__title {\n  font-size: 0.9rem;\n  color: var(--color-text);\n  margin-bottom: 8px;\n}\n\n.crash-sidebar__game-info {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-sidebar__row {\n  display: flex;\n  justify-content: space-between;\n  padding: 4px 0;\n  font-size: 0.6rem;\n}\n\n.crash-sidebar__row span:first-child {\n  color: var(--color-text-muted);\n}\n\n.crash-sidebar__phase {\n  text-transform: uppercase;\n}\n\n.crash-sidebar__phase--betting {\n  color: var(--color-neon-yellow);\n}\n\n.crash-sidebar__phase--running {\n  color: var(--color-neon-green);\n}\n\n.crash-sidebar__phase--crashed,\n.crash-sidebar__phase--revealing {\n  color: var(--color-neon-pink);\n}\n\n.crash-sidebar__multiplier {\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.crash-sidebar__crash-point {\n  color: var(--color-neon-pink);\n}\n\n.crash-sidebar__pools {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-sidebar__pools-title {\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n  margin-bottom: 8px;\n  text-transform: uppercase;\n}\n\n.crash-sidebar__pool {\n  display: flex;\n  justify-content: space-between;\n  padding: 6px 8px;\n  background: rgba(255, 255, 255, 0.02);\n  border-radius: 2px;\n  margin-bottom: 4px;\n}\n\n.crash-sidebar__pool--user {\n  background: rgba(0, 255, 136, 0.1);\n  border: 1px solid rgba(0, 255, 136, 0.2);\n}\n\n.crash-sidebar__pool-tier {\n  font-size: 0.8rem;\n  color: var(--color-text);\n  text-transform: capitalize;\n}\n\n.crash-sidebar__pool-info {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.crash-sidebar__your-bet {\n  background: var(--color-surface);\n  border: 1px solid var(--color-neon-green);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-sidebar__your-bet-title {\n  font-size: 0.6rem;\n  color: var(--color-neon-green);\n  margin-bottom: 8px;\n  text-transform: uppercase;\n}\n\n.crash-sidebar__cashed-out {\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.crash-sidebar__fairness {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-sidebar__fairness-title {\n  font-size: 0.8rem;\n  color: var(--color-text-muted);\n  margin-bottom: 8px;\n  text-transform: uppercase;\n}\n\n.crash-sidebar__fairness-row {\n  display: flex;\n  justify-content: space-between;\n  padding: 3px 0;\n  font-size: 1rem;\n}\n\n.crash-sidebar__fairness-row span:first-child {\n  color: var(--color-text-muted);\n}\n\n.crash-sidebar__hash {\n  color: var(--color-neon-cyan);\n  font-family: var(--font-mono);\n  font-size: 0.45rem;\n}\n\n.crash-sidebar__hash--revealed {\n  color: var(--color-neon-green);\n}\n\n.crash-sidebar__connect-btn {\n  background: linear-gradient(135deg, var(--color-neon-purple), var(--color-neon-pink));\n  color: #fff;\n  border: none;\n  padding: 12px 16px;\n  font-size: 0.65rem;\n  font-family: var(--font-pixel);\n  border-radius: 2px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.crash-sidebar__connect-btn:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 4px 16px var(--color-primary-glow);\n}\n\n/* Sidebar Tier Selector */\n.crash-sidebar__tier-selector {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-sidebar__tier-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 6px;\n}\n\n.crash-sidebar__tier-btn {\n  background: var(--color-surface-elevated);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 6px 4px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 2px;\n  position: relative;\n  min-height: 48px;\n}\n\n.crash-sidebar__tier-btn:hover {\n  border-color: var(--tier-color, var(--color-border));\n  background: rgba(255, 255, 255, 0.03);\n}\n\n.crash-sidebar__tier-btn--selected {\n  border-color: var(--tier-color, var(--color-neon-cyan));\n  background: rgba(255, 255, 255, 0.05);\n  box-shadow: 0 0 8px color-mix(in srgb, var(--tier-color) 30%, transparent);\n}\n\n.crash-sidebar__tier-btn--jackpot {\n  animation: jackpot-pulse 2s infinite;\n}\n\n.crash-sidebar__tier-btn-name {\n  font-size: 0.9rem;\n  color: var(--tier-color, var(--color-text));\n  text-transform: capitalize;\n  font-weight: 600;\n}\n\n.crash-sidebar__tier-btn-amount {\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n}\n\n.crash-sidebar__tier-btn-jackpot {\n  font-size: 0.4rem;\n  color: var(--color-neon-gold);\n  text-shadow: none;\n  position: absolute;\n  bottom: 2px;\n  left: 50%;\n  transform: translateX(-50%);\n}\n\n.crash-sidebar__tier {\n  text-transform: capitalize;\n  font-weight: 500;\n}\n\n/* Sidebar Bet Controls */\n.crash-sidebar__bet-controls {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.crash-sidebar__bet-button {\n  width: 100%;\n  padding: 12px 16px;\n  background: linear-gradient(135deg, var(--color-neon-cyan), var(--color-neon-green));\n  border: none;\n  border-radius: 2px;\n  color: #000;\n  font-weight: 600;\n  font-size: 0.65rem;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  text-transform: uppercase;\n}\n\n.crash-sidebar__bet-button:hover:not(:disabled) {\n  transform: translateY(-1px);\n  box-shadow: 0 4px 12px rgba(0, 255, 136, 0.3);\n}\n\n.crash-sidebar__bet-button:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n\n.crash-sidebar__bet-status {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 4px;\n  padding: 10px;\n  border-radius: 2px;\n  text-align: center;\n}\n\n.crash-sidebar__bet-status--placed {\n  background: rgba(0, 255, 136, 0.1);\n  border: 1px solid rgba(0, 255, 136, 0.3);\n}\n\n.crash-sidebar__bet-status--cashed {\n  background: rgba(0, 255, 255, 0.1);\n  border: 1px solid rgba(0, 255, 255, 0.3);\n}\n\n.crash-sidebar__bet-status--busted {\n  background: rgba(255, 0, 84, 0.1);\n  border: 1px solid rgba(255, 0, 84, 0.3);\n}\n\n.crash-sidebar__bet-status-label {\n  font-size: 0.6rem;\n  font-weight: 600;\n  text-transform: uppercase;\n}\n\n.crash-sidebar__bet-status--placed .crash-sidebar__bet-status-label {\n  color: var(--color-neon-green);\n}\n\n.crash-sidebar__bet-status--cashed .crash-sidebar__bet-status-label {\n  color: var(--color-neon-cyan);\n}\n\n.crash-sidebar__bet-status--busted .crash-sidebar__bet-status-label {\n  color: var(--color-neon-pink);\n}\n\n.crash-sidebar__bet-status-info {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.crash-sidebar__bet-status-wait {\n  font-size: 0.45rem;\n  color: var(--color-text-muted);\n  font-style: italic;\n}\n\n.crash-sidebar__bet-status-multiplier {\n  font-size: 0.9rem;\n  font-weight: 600;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.crash-sidebar__connect-prompt {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n  text-align: center;\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n/* Round Players Section (below chart) */\n.crash-round-players {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n  margin-top: 12px;\n}\n\n.crash-round-players__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 12px;\n  padding-bottom: 8px;\n  border-bottom: 1px solid var(--color-border);\n}\n\n.crash-round-players__tier {\n  font-size: 0.9rem;\n  font-weight: 600;\n  text-transform: uppercase;\n}\n\n.crash-round-players__count {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.crash-round-players__prize-pool {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 8px 12px;\n  margin-bottom: 12px;\n  background: rgba(0, 255, 157, 0.08);\n  border: 1px solid var(--color-neon-green);\n  border-radius: 2px;\n}\n\n.crash-round-players__prize-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.crash-round-players__prize-amount {\n  font-size: 0.9rem;\n  font-weight: 700;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.crash-round-players__crash-point {\n  font-size: 0.8rem;\n  color: var(--color-neon-pink);\n  font-weight: 600;\n}\n\n.crash-round-players__empty {\n  text-align: center;\n  padding: 20px;\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.crash-round-players__no-players {\n  text-align: center;\n  padding: 16px;\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  font-style: italic;\n}\n\n/* Waiting for players state */\n.crash-round-players--waiting {\n  border-color: var(--color-neon-orange);\n}\n\n.crash-round-players__waiting {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 4px;\n  padding: 12px;\n  margin-bottom: 8px;\n  background: rgba(255, 165, 0, 0.1);\n  border-radius: 2px;\n  border: 1px dashed var(--color-neon-orange);\n}\n\n.crash-round-players__waiting-icon {\n  font-size: 1.2rem;\n  animation: waiting-pulse 1.5s ease-in-out infinite;\n}\n\n.crash-round-players__waiting-text {\n  font-size: 0.6rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-orange);\n  text-shadow: none;\n}\n\n.crash-round-players__running-info {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 4px;\n  padding: 16px;\n}\n\n.crash-round-players__running-text {\n  font-size: 0.6rem;\n  color: var(--color-neon-green);\n  animation: pulse 1.5s infinite;\n}\n\n.crash-round-players__running-hint {\n  font-size: 0.45rem;\n  color: var(--color-text-muted);\n}\n\n.crash-round-players__list {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  max-height: 200px;\n  overflow-y: auto;\n}\n\n.crash-round-players__item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 6px 8px;\n  background: var(--color-surface-elevated);\n  border-radius: 2px;\n  font-size: 1rem;\n}\n\n.crash-round-players__item--user {\n  background: rgba(0, 255, 255, 0.1);\n  border: 1px solid rgba(0, 255, 255, 0.2);\n}\n\n.crash-round-players__item--winner {\n  background: rgba(255, 215, 0, 0.1);\n  border: 1px solid rgba(255, 215, 0, 0.3);\n}\n\n.crash-round-players__item--invalid {\n  opacity: 0.5;\n}\n\n.crash-round-players__item--busted {\n  opacity: 0.6;\n}\n\n.crash-round-players__rank {\n  font-size: 0.45rem;\n  color: var(--color-text-muted);\n  min-width: 24px;\n}\n\n.crash-round-players__name {\n  flex: 1;\n  color: var(--color-text);\n}\n\n.crash-round-players__bet,\n.crash-round-players__mult {\n  color: var(--color-text-muted);\n}\n\n.crash-round-players__mult--busted {\n  color: var(--color-neon-pink);\n}\n\n/* Winner Section */\n.crash-round-players__winner {\n  position: relative;\n  background: linear-gradient(135deg, rgba(255, 215, 0, 0.1), rgba(255, 215, 0, 0.05));\n  border: 1px solid rgba(255, 215, 0, 0.3);\n  border-radius: 2px;\n  padding: 12px;\n  margin-bottom: 12px;\n  text-align: center;\n  overflow: visible;\n}\n\n.crash-round-players__winner-badge {\n  font-size: 0.6rem;\n  font-weight: 600;\n  color: var(--color-neon-gold);\n  text-shadow: none;\n  margin-bottom: 8px;\n}\n\n.crash-round-players__winner-info {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.crash-round-players__winner-name {\n  font-size: 0.6rem;\n  color: var(--color-text);\n  font-weight: 500;\n}\n\n.crash-round-players__winner-mult {\n  font-size: 0.8rem;\n  color: var(--color-neon-cyan);\n}\n\n.crash-round-players__winner-payout {\n  font-size: 0.9rem;\n  font-weight: 600;\n  color: var(--color-neon-green);\n  text-shadow: none;\n}\n\n.crash-round-players__winner-name--you {\n  color: var(--color-neon-green);\n  text-shadow: none;\n  font-size: 0.8rem;\n}\n\n/* Crypto Crash Claim Button */\n.crash-claim-btn {\n  margin-top: 0.75rem;\n  padding: 0.75rem 1.5rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  text-transform: uppercase;\n  background: linear-gradient(135deg, var(--color-neon-green) 0%, #39cc14 100%);\n  border: none;\n  color: #000;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.crash-claim-btn:hover:not(:disabled) {\n  box-shadow: none;\n  transform: scale(1.05);\n}\n\n.crash-claim-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n/* Auto-payout received message */\n.crash-sidebar__payout-received {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n  margin-top: 0.75rem;\n  padding: 0.75rem 1rem;\n  background: linear-gradient(135deg, rgba(57, 204, 20, 0.2) 0%, rgba(57, 204, 20, 0.1) 100%);\n  border: 1px solid var(--color-neon-green);\n  border-radius: 2px;\n}\n\n.crash-sidebar__payout-label {\n  font-family: var(--font-pixel);\n  font-size: 0.65rem;\n  text-transform: uppercase;\n  color: var(--color-neon-green);\n  letter-spacing: 0.05em;\n}\n\n.crash-sidebar__payout-amount {\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  color: var(--color-neon-green);\n  text-shadow: 0 0 8px var(--color-neon-green);\n}\n\n/* Win Animation - consistent with Coinflip/Close Call */\n.crash-win-animation {\n  position: absolute;\n  top: 0;\n  left: 50%;\n  transform: translateX(-50%);\n  pointer-events: none;\n  z-index: 100;\n}\n\n.crash-win-animation__stars {\n  position: absolute;\n  top: 0;\n  left: 50%;\n  transform: translateX(-50%);\n}\n\n.crash-win-animation__star {\n  position: absolute;\n  color: #ffd700;\n  font-size: 1.5rem;\n  text-shadow: 0 0 10px #ffd700;\n  animation: crash-star-burst 1.5s ease-out forwards;\n  animation-delay: calc(var(--star-index) * 0.08s);\n  opacity: 0;\n}\n\n.crash-win-animation__coins {\n  position: absolute;\n  top: 0;\n  left: 50%;\n  transform: translateX(-50%);\n}\n\n.crash-win-animation__coin {\n  position: absolute;\n  color: var(--color-neon-green);\n  font-size: 0.8rem;\n  text-shadow: 0 0 8px var(--color-neon-green);\n  animation: crash-coin-fall 1.8s ease-out forwards;\n  animation-delay: calc(var(--coin-index) * 0.1s + 0.3s);\n  opacity: 0;\n}\n\n@keyframes crash-star-burst {\n  0% {\n    opacity: 1;\n    transform: translate(0, 0) scale(0.5);\n  }\n  100% {\n    opacity: 0;\n    transform: translate(\n      calc(cos(calc(var(--star-index) * 45deg)) * 80px),\n      calc(sin(calc(var(--star-index) * 45deg)) * 80px - 20px)\n    ) scale(1.2);\n  }\n}\n\n@keyframes crash-coin-fall {\n  0% {\n    opacity: 1;\n    transform: translate(calc((var(--coin-index) - 2.5) * 25px), -30px) scale(0.5);\n  }\n  50% {\n    opacity: 1;\n    transform: translate(calc((var(--coin-index) - 2.5) * 35px), 10px) scale(1);\n  }\n  100% {\n    opacity: 0;\n    transform: translate(calc((var(--coin-index) - 2.5) * 45px), 60px) scale(0.8);\n  }\n}\n\n/* Loss Animation */\n.crash-round-players__user-result {\n  margin-top: 8px;\n  padding: 8px 12px;\n  border-radius: 2px;\n  text-align: center;\n}\n\n.crash-round-players__user-result--lost {\n  background: rgba(255, 0, 84, 0.1);\n  border: 1px solid rgba(255, 0, 84, 0.3);\n}\n\n.crash-round-players__user-result-title {\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  color: var(--color-neon-pink);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n}\n\n.crash-round-players__heartbreak {\n  display: inline;\n  font-size: 0.9rem;\n  vertical-align: middle;\n  opacity: 0.75;\n  filter: saturate(0.7);\n}\n\n.crash-round-players__no-winner {\n  background: rgba(255, 215, 0, 0.05);\n  border: 1px solid rgba(255, 215, 0, 0.2);\n  border-radius: 2px;\n  padding: 12px;\n  margin-bottom: 12px;\n  text-align: center;\n}\n\n.crash-round-players__no-winner-text {\n  font-size: 0.8rem;\n  color: var(--color-neon-gold);\n}\n\n/* Results and Busted sections */\n.crash-round-players__results,\n.crash-round-players__busted {\n  margin-top: 12px;\n}\n\n.crash-round-players__results-title,\n.crash-round-players__busted-title {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  margin-bottom: 8px;\n}\n\n.crash-round-players__busted-title {\n  color: var(--color-neon-pink);\n}\n\n/* Sidebar Round Info */\n.crash-sidebar__round-info {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-sidebar__round-info-title {\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n  margin-bottom: 8px;\n  text-transform: uppercase;\n}\n\n.crash-sidebar__pot {\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.crash-sidebar__pot--total {\n  color: var(--color-neon-green);\n  font-weight: 700;\n  text-shadow: none;\n}\n\n.crash-sidebar__jackpot {\n  color: var(--color-text-muted);\n}\n\n.crash-sidebar__jackpot--active {\n  color: var(--color-neon-gold);\n  text-shadow: none;\n}\n\n/* Sidebar Player Scores */\n.crash-sidebar__scores {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  padding: 12px;\n}\n\n.crash-sidebar__scores-title {\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n  margin-bottom: 8px;\n  text-transform: uppercase;\n}\n\n.crash-sidebar__scores-list {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  max-height: 150px;\n  overflow-y: auto;\n}\n\n.crash-sidebar__score-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 6px 8px;\n  background: rgba(255, 255, 255, 0.02);\n  border-radius: 2px;\n  font-size: 0.8rem;\n}\n\n.crash-sidebar__score-item--user {\n  background: rgba(0, 255, 136, 0.1);\n  border: 1px solid rgba(0, 255, 136, 0.2);\n}\n\n.crash-sidebar__score-item--winner {\n  background: rgba(255, 215, 0, 0.1);\n  border: 1px solid rgba(255, 215, 0, 0.3);\n}\n\n.crash-sidebar__score-name {\n  color: var(--color-text);\n}\n\n.crash-sidebar__score-mult {\n  color: var(--color-neon-green);\n  font-family: var(--font-mono);\n}\n\n.crash-sidebar__score-item--winner .crash-sidebar__score-mult {\n  color: var(--color-neon-gold);\n  text-shadow: none;\n}\n\n/* Sidebar Winner */\n.crash-sidebar__winner {\n  background: linear-gradient(135deg, rgba(255, 215, 0, 0.1), rgba(255, 140, 0, 0.1));\n  border: 1px solid rgba(255, 215, 0, 0.3);\n  border-radius: 2px;\n  padding: 12px;\n  text-align: center;\n}\n\n.crash-sidebar__winner-title {\n  font-size: 0.9rem;\n  color: var(--color-neon-gold);\n  margin-bottom: 8px;\n  text-shadow: none;\n}\n\n.crash-sidebar__winner-info {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.crash-sidebar__winner-name {\n  font-size: 0.65rem;\n  color: var(--color-text);\n}\n\n.crash-sidebar__winner-mult {\n  font-size: 0.6rem;\n  color: var(--color-neon-green);\n}\n\n.crash-sidebar__winner-payout {\n  font-size: 0.9rem;\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.crash-sidebar__no-winner {\n  background: var(--color-surface);\n  border: 1px solid var(--color-neon-orange);\n  border-radius: 2px;\n  padding: 12px;\n  text-align: center;\n  font-size: 0.6rem;\n  color: var(--color-neon-orange);\n}\n\n/* Select tier prompt */\n.crash-active-round__select-tier-prompt {\n  background: var(--color-surface);\n  border: 1px dashed var(--color-border);\n  border-radius: 2px;\n  padding: 12px 24px;\n  text-align: center;\n  font-size: 0.6rem;\n  color: var(--color-text-muted);\n}\n\n/* Responsive */\n@media (max-width: 900px) {\n  .crash-sidebar__tier-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n}\n\n@media (max-width: 600px) {\n  .crash-status-bar {\n    flex-wrap: wrap;\n    gap: 8px;\n    padding: 8px 12px;\n  }\n\n  .crash-status-bar__phase {\n    min-width: auto;\n  }\n\n  .crash-status-bar__status {\n    min-width: auto;\n    text-align: center;\n    width: 100%;\n  }\n\n  .crash-status-bar__multiplier {\n    font-size: 1rem;\n  }\n\n  .crash-active-round__chart-container {\n    min-height: 250px;\n  }\n\n  .crash-chart__container {\n    min-height: 220px;\n  }\n\n  .crash-sidebar__tier-grid {\n    grid-template-columns: repeat(3, 1fr);\n  }\n\n  .crash-sidebar__tier-btn {\n    padding: 4px 2px;\n  }\n\n  .crash-sidebar__tier-btn-name {\n    font-size: 0.6rem;\n  }\n\n  .crash-sidebar__tier-btn-amount {\n    font-size: 1rem;\n  }\n}\n\n/* ============ Crash History Modal ============ */\n.crash-history-modal {\n  min-width: 380px;\n  padding: 0.5rem 1rem 1rem 1rem;\n}\n\n.crash-history-modal__section {\n  margin-bottom: 1.25rem;\n  padding: 0 0.25rem;\n}\n\n.crash-history-modal__section:last-of-type {\n  margin-bottom: 1rem;\n}\n\n.crash-history-modal__section h4 {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin: 0 0 0.75rem 0;\n  padding-bottom: 0.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.crash-history-modal__row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.5rem 0.25rem;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.crash-history-modal__row:last-child {\n  border-bottom: none;\n}\n\n.crash-history-modal__row > span:first-child {\n  color: var(--color-text-muted);\n}\n\n.crash-history-modal__crash-point {\n  color: var(--color-neon-pink);\n  text-shadow: 0 0 8px var(--color-neon-pink);\n  font-weight: bold;\n  font-size: 1rem;\n}\n\n.crash-history-modal__hash {\n  font-family: var(--font-mono);\n  font-size: 1rem;\n  color: #888;\n  background: rgba(0, 0, 0, 0.3);\n  padding: 0.25rem 0.5rem;\n  border-radius: 2px;\n  max-width: 180px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.crash-history-modal__hash--revealed {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n}\n\n.crash-history-modal__tier {\n  background: rgba(0, 0, 0, 0.2);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 0.75rem;\n  margin-bottom: 0.75rem;\n}\n\n.crash-history-modal__tier:last-child {\n  margin-bottom: 0;\n}\n\n.crash-history-modal__tier-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 0.5rem;\n  padding-bottom: 0.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.crash-history-modal__tier-name {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  font-weight: bold;\n  text-transform: uppercase;\n}\n\n.crash-history-modal__tier-players {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.crash-history-modal__tier-details .crash-history-modal__row {\n  padding: 0.375rem 0;\n}\n\n.crash-history-modal__winner {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n}\n\n.crash-history-modal__multiplier {\n  color: var(--color-neon-cyan);\n  text-shadow: 0 0 4px var(--color-neon-cyan);\n}\n\n.crash-history-modal__payout {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n  font-weight: bold;\n}\n\n.crash-history-modal__no-winner {\n  color: var(--color-text-muted);\n  font-style: italic;\n}\n\n.crash-history-modal__verify-link {\n  display: block;\n  text-align: center;\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-decoration: none;\n  padding: 0.75rem;\n  border: 1px solid var(--color-neon-cyan);\n  border-radius: 2px;\n  transition: all 0.2s ease;\n  margin-top: 0.5rem;\n}\n\n.crash-history-modal__verify-link:hover {\n  background: rgba(0, 255, 255, 0.1);\n  box-shadow: 0 0 8px var(--color-neon-cyan);\n}\n\n/* Crash History Result in Panel */\n.crash-history-result {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  width: 100%;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n}\n\n.crash-history-result__left {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.crash-history-result__right {\n  display: flex;\n  align-items: center;\n  gap: 0.35rem;\n  margin-left: auto;\n  padding-left: 0.5rem;\n}\n\n.crash-history-result__crash {\n  color: var(--color-neon-pink);\n  text-shadow: 0 0 4px var(--color-neon-pink);\n  font-weight: bold;\n}\n\n.crash-history-result__divider {\n  color: var(--color-text-muted);\n  opacity: 0.5;\n}\n\n.crash-history-result__tier {\n  font-weight: bold;\n}\n\n.crash-history-result__winner {\n  color: var(--color-neon-green);\n}\n\n.crash-history-result__no-winner {\n  color: var(--color-text-muted);\n  font-style: italic;\n}\n\n.crash-history-result__players {\n  color: var(--color-text-muted);\n}\n\n.crash-history-result__wagered {\n  color: var(--color-neon-cyan);\n}\n\n.crash-history-result__user-won {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n  font-weight: bold;\n}\n\n.crash-history-result__user-busted {\n  color: var(--color-neon-pink);\n  opacity: 0.8;\n}\n\n.crash-history-result__user-cashout {\n  color: var(--color-neon-cyan);\n}\n\n.crash-history-result__user-amount {\n  font-weight: bold;\n}\n\n.crash-history-result__user-amount--won {\n  color: var(--color-neon-green);\n  text-shadow: 0 0 4px var(--color-neon-green);\n}\n\n.crash-history-result__user-amount--lost {\n  color: var(--color-neon-pink);\n  opacity: 0.8;\n}\n\n/* ============ Player Profile Styles ============ */\n\n/* Player Avatar */\n.player-avatar {\n  position: relative;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: 50%;\n  border: 2px solid rgba(255, 255, 255, 0.2);\n  background: var(--color-surface);\n  overflow: visible;\n  transition: transform 0.2s ease;\n}\n\n.player-avatar__image {\n  border-radius: 50%;\n  overflow: hidden;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.player-avatar:hover {\n  transform: scale(1.05);\n  border-color: rgba(255, 255, 255, 0.4);\n}\n\n.player-avatar:focus {\n  outline: 2px solid var(--color-neon-blue);\n  outline-offset: 2px;\n}\n\n/* RNG God special hot pink glow effect */\n.player-avatar--rng-god {\n  border-color: #ff0054;\n  box-shadow:\n    0 0 10px #ff0054,\n    0 0 20px rgba(255, 0, 84, 0.6),\n    0 0 30px rgba(255, 0, 84, 0.4),\n    0 0 40px rgba(255, 0, 84, 0.2);\n  animation: rng-god-pulse 2s ease-in-out infinite;\n}\n\n.player-avatar--rng-god:hover {\n  border-color: #ff6b9d;\n  box-shadow:\n    0 0 15px #ff0054,\n    0 0 30px rgba(255, 0, 84, 0.7),\n    0 0 45px rgba(255, 0, 84, 0.5),\n    0 0 60px rgba(255, 0, 84, 0.3);\n}\n\n@keyframes rng-god-pulse {\n  0%, 100% {\n    box-shadow:\n      0 0 10px #ff0054,\n      0 0 20px rgba(255, 0, 84, 0.6),\n      0 0 30px rgba(255, 0, 84, 0.4),\n      0 0 40px rgba(255, 0, 84, 0.2);\n  }\n  50% {\n    box-shadow:\n      0 0 15px #ff0054,\n      0 0 25px rgba(255, 0, 84, 0.7),\n      0 0 40px rgba(255, 0, 84, 0.5),\n      0 0 55px rgba(255, 0, 84, 0.3);\n  }\n}\n\n/* Heater golden border - players with active buff have golden glow */\n.player-avatar--has-buff {\n  border-color: #ffd700;\n  box-shadow:\n    0 0 8px #ffd700,\n    0 0 16px rgba(255, 215, 0, 0.5),\n    0 0 24px rgba(255, 170, 0, 0.3);\n  animation: rng-buff-pulse 2s ease-in-out infinite;\n}\n\n.player-avatar--has-buff:hover {\n  border-color: #ffeb3b;\n  box-shadow:\n    0 0 12px #ffd700,\n    0 0 24px rgba(255, 215, 0, 0.6),\n    0 0 36px rgba(255, 170, 0, 0.4);\n}\n\n@keyframes rng-buff-pulse {\n  0%, 100% {\n    box-shadow:\n      0 0 8px #ffd700,\n      0 0 16px rgba(255, 215, 0, 0.5),\n      0 0 24px rgba(255, 170, 0, 0.3);\n  }\n  50% {\n    box-shadow:\n      0 0 12px #ffd700,\n      0 0 20px rgba(255, 215, 0, 0.6),\n      0 0 32px rgba(255, 170, 0, 0.4);\n  }\n}\n\n.player-avatar__image svg {\n  display: block;\n}\n\n/* Level badge - small circular ring at bottom-right of avatar */\n.player-avatar__level-badge {\n  position: absolute;\n  bottom: -2px;\n  right: -2px;\n  width: 18px;\n  height: 18px;\n  font-size: 0.8rem;\n  font-weight: 700;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--color-surface-dark, #1a1a2e);\n  border: 2px solid rgba(255, 255, 255, 0.3);\n  border-radius: 50%;\n  color: #fff;\n  z-index: 2;\n  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);\n}\n\n/* Size variations for level badge */\n.player-avatar--xs .player-avatar__level-badge {\n  width: 14px;\n  height: 14px;\n  font-size: 0.45rem;\n  border-width: 2px;\n  bottom: -1px;\n  right: -1px;\n}\n\n.player-avatar--sm .player-avatar__level-badge {\n  width: 16px;\n  height: 16px;\n  font-size: 1rem;\n  border-width: 2px;\n  bottom: -1px;\n  right: -1px;\n}\n\n.player-avatar--lg .player-avatar__level-badge {\n  width: 22px;\n  height: 22px;\n  font-size: 0.6rem;\n  border-width: 2px;\n  bottom: -2px;\n  right: -2px;\n}\n\n.player-avatar--xl .player-avatar__level-badge {\n  width: 28px;\n  height: 28px;\n  font-size: 0.9rem;\n  border-width: 3px;\n  bottom: -3px;\n  right: -3px;\n}\n\n/* Username */\n.player-avatar__username {\n  position: absolute;\n  bottom: -20px;\n  left: 50%;\n  transform: translateX(-50%);\n  font-size: 0.9rem;\n  white-space: nowrap;\n  color: var(--color-text-muted);\n  max-width: 80px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n/* Player Avatar Compact (inline) */\n.player-avatar-compact {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 2px 8px 2px 2px;\n  border-radius: 20px;\n  background: rgba(255, 255, 255, 0.05);\n  transition: background 0.2s ease;\n}\n\n.player-avatar-compact:hover {\n  background: rgba(255, 255, 255, 0.1);\n}\n\n.player-avatar-compact:focus {\n  outline: 2px solid var(--color-neon-blue);\n  outline-offset: 1px;\n}\n\n/* Avatar within compact - don't scale on hover */\n.player-avatar-compact__avatar {\n  flex-shrink: 0;\n}\n\n.player-avatar-compact__avatar:hover {\n  transform: none;\n}\n\n.player-avatar-compact__name {\n  font-size: 0.8rem;\n  font-weight: 500;\n  color: var(--color-text);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  max-width: 120px;\n}\n\n/* Current user (me) - cyan highlighted name */\n.player-avatar-compact--me .player-avatar-compact__name {\n  color: var(--color-neon-cyan);\n  text-shadow: 0 0 6px rgba(0, 255, 136, 0.5);\n}\n\n/* RNG God compact - hot pink glow effect */\n.player-avatar-compact--rng-god {\n  background: rgba(255, 0, 84, 0.1);\n  box-shadow: 0 0 8px rgba(255, 0, 84, 0.3);\n}\n\n.player-avatar-compact--rng-god:hover {\n  background: rgba(255, 0, 84, 0.15);\n  box-shadow: 0 0 12px rgba(255, 0, 84, 0.4);\n}\n\n.player-avatar-compact--rng-god .player-avatar-compact__name {\n  color: #ff6b9d;\n  text-shadow: 0 0 6px rgba(255, 0, 84, 0.5);\n}\n\n/* Heater compact - golden glow effect */\n.player-avatar-compact--has-buff {\n  background: rgba(255, 215, 0, 0.1);\n  box-shadow: 0 0 8px rgba(255, 215, 0, 0.3);\n}\n\n.player-avatar-compact--has-buff:hover {\n  background: rgba(255, 215, 0, 0.15);\n  box-shadow: 0 0 12px rgba(255, 215, 0, 0.4);\n}\n\n.player-avatar-compact--has-buff .player-avatar-compact__name {\n  color: #ffd700;\n  text-shadow: 0 0 6px rgba(255, 215, 0, 0.5);\n}\n\n/* Level Progress Bar */\n.level-progress-bar {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.level-progress-bar__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.level-progress-bar__level {\n  font-weight: 700;\n  font-size: 0.9rem;\n}\n\n.level-progress-bar__xp {\n  color: var(--color-text-muted);\n}\n\n.level-progress-bar__max {\n  color: #b9f2ff;\n  text-shadow: 0 0 8px #b9f2ff;\n  font-weight: 700;\n}\n\n.level-progress-bar__track {\n  width: 100%;\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  overflow: hidden;\n}\n\n.level-progress-bar__fill {\n  height: 100%;\n  border-radius: 2px;\n  transition: width 0.3s ease;\n}\n\n.level-progress-bar--sm .level-progress-bar__header {\n  gap: 8px;\n}\n\n.level-progress-bar--sm .level-progress-bar__level {\n  font-size: 1rem;\n}\n\n.level-progress-bar--lg .level-progress-bar__level {\n  font-size: 1.1rem;\n}\n\n/* Mini Profile Modal */\n.mini-profile-modal-overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.6);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 10001;\n  animation: fade-in 0.2s ease;\n  isolation: isolate;\n}\n\n.mini-profile-modal {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 4px;\n  padding: 24px;\n  min-width: 320px;\n  max-width: 400px;\n  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);\n  animation: modal-slide-up 0.3s ease;\n}\n\n@keyframes modal-slide-up {\n  from {\n    opacity: 0;\n    transform: translateY(20px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.mini-profile-modal__header {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 12px;\n  margin-bottom: 20px;\n}\n\n.mini-profile-modal__avatar {\n  width: 80px;\n  height: 80px;\n}\n\n/* Golden border animation for players with Heater */\n.mini-profile-modal__avatar--has-buff {\n  animation: rng-buff-pulse 2s ease-in-out infinite;\n}\n\n.mini-profile-modal__name {\n  font-size: 1.25rem;\n  font-weight: 700;\n  color: var(--color-text);\n}\n\n/* Current user (me) - cyan highlighted name */\n.mini-profile-modal__name--me {\n  color: var(--color-neon-cyan);\n  text-shadow: 0 0 8px rgba(0, 255, 136, 0.5);\n}\n\n.mini-profile-modal__level-bar {\n  width: 100%;\n  max-width: 200px;\n}\n\n.mini-profile-modal__stats {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 12px;\n  margin-bottom: 20px;\n}\n\n.mini-profile-modal__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  padding: 12px;\n  background: rgba(255, 255, 255, 0.03);\n  border-radius: 2px;\n}\n\n.mini-profile-modal__stat-value {\n  font-size: 1.1rem;\n  font-weight: 700;\n  color: var(--color-neon-blue);\n}\n\n.mini-profile-modal__stat-value--positive {\n  color: var(--color-neon-green);\n}\n\n.mini-profile-modal__stat-value--negative {\n  color: var(--color-neon-pink);\n}\n\n.mini-profile-modal__stat-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.mini-profile-modal__actions {\n  display: flex;\n  gap: 12px;\n}\n\n.mini-profile-modal__btn {\n  flex: 1;\n  padding: 10px 16px;\n  border-radius: 2px;\n  font-weight: 600;\n  font-size: 0.875rem;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.mini-profile-modal__btn--primary {\n  background: var(--color-neon-blue);\n  color: var(--color-bg);\n  border: none;\n}\n\n.mini-profile-modal__btn--primary:hover {\n  background: var(--color-neon-blue-bright);\n  box-shadow: 0 0 20px var(--color-neon-blue);\n}\n\n.mini-profile-modal__btn--secondary {\n  background: transparent;\n  color: var(--color-text);\n  border: 1px solid var(--color-border);\n}\n\n.mini-profile-modal__btn--secondary:hover {\n  background: rgba(255, 255, 255, 0.05);\n}\n\n/* Profile Page */\n.profile-page {\n  max-width: 1000px;\n  margin: 0 auto;\n  padding: 24px;\n}\n\n.profile-page__header {\n  display: flex;\n  align-items: flex-start;\n  gap: 24px;\n  margin-bottom: 32px;\n  padding: 24px;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 4px;\n}\n\n.profile-page__avatar-section {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 12px;\n}\n\n.profile-page__info {\n  flex: 1;\n}\n\n.profile-page__name {\n  font-size: 1.5rem;\n  font-weight: 700;\n  margin: 0;\n}\n\n.profile-page__name-row {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  margin-bottom: 4px;\n}\n\n.profile-page__name-edit-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 28px;\n  height: 28px;\n  background: rgba(255, 255, 255, 0.1);\n  border: none;\n  border-radius: 2px;\n  color: var(--color-text-muted);\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.profile-page__name-edit-btn:hover {\n  background: rgba(255, 255, 255, 0.2);\n  color: var(--color-text);\n}\n\n.profile-page__name-edit {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  flex-wrap: wrap;\n}\n\n.profile-page__name-input {\n  font-size: 1.25rem;\n  font-weight: 600;\n  padding: 6px 12px;\n  background: rgba(0, 0, 0, 0.3);\n  border: 2px solid var(--color-border);\n  border-radius: 2px;\n  color: var(--color-text);\n  min-width: 200px;\n  max-width: 300px;\n  transition: border-color 0.2s ease;\n}\n\n.profile-page__name-input:focus {\n  outline: none;\n  border-color: var(--color-neon-blue);\n}\n\n.profile-page__name-input--error {\n  border-color: #ff6b6b;\n}\n\n.profile-page__name-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 32px;\n  height: 32px;\n  border: none;\n  border-radius: 2px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.profile-page__name-btn--save {\n  background: var(--color-neon-green);\n  color: #000;\n}\n\n.profile-page__name-btn--save:hover:not(:disabled) {\n  background: #00ff88;\n}\n\n.profile-page__name-btn--save:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.profile-page__name-btn--cancel {\n  background: rgba(255, 255, 255, 0.1);\n  color: var(--color-text-muted);\n}\n\n.profile-page__name-btn--cancel:hover:not(:disabled) {\n  background: rgba(255, 107, 107, 0.2);\n  color: #ff6b6b;\n}\n\n.profile-page__name-error {\n  font-size: 1rem;\n  color: #ff6b6b;\n  width: 100%;\n  margin-top: 4px;\n}\n\n.profile-page__address {\n  font-size: 0.8rem;\n  color: var(--color-text-muted);\n  font-family: monospace;\n  margin-bottom: 16px;\n}\n\n.profile-page__level-section {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  flex-wrap: wrap;\n}\n\n.profile-page__level-section .level-progress-bar {\n  max-width: 280px;\n  flex-shrink: 0;\n}\n\n/* Heater indicator - compact pill style */\n.profile-page__buff-indicator {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 4px 10px 4px 6px;\n  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(255, 170, 0, 0.15));\n  border: 1px solid rgba(255, 215, 0, 0.5);\n  border-radius: 20px;\n  animation: profile-buff-pulse 2s ease-in-out infinite;\n}\n\n@keyframes profile-buff-pulse {\n  0%, 100% {\n    box-shadow: 0 0 6px rgba(255, 215, 0, 0.3);\n  }\n  50% {\n    box-shadow: 0 0 12px rgba(255, 215, 0, 0.5);\n  }\n}\n\n.profile-page__buff-icon {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 18px;\n  height: 18px;\n  flex-shrink: 0;\n}\n\n.profile-page__buff-icon svg {\n  width: 16px;\n  height: 16px;\n  filter: none;\n}\n\n.profile-page__buff-info {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n.profile-page__buff-label {\n  font-size: 0.9rem;\n  font-weight: 600;\n  color: #ffd700;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.profile-page__buff-timer {\n  font-size: 1rem;\n  font-weight: 700;\n  color: #ffeb3b;\n  font-family: monospace;\n}\n\n.profile-page__tabs {\n  display: flex;\n  gap: 4px;\n  margin-bottom: 24px;\n  padding: 4px;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 3px;\n}\n\n.profile-page__tab {\n  flex: 1;\n  padding: 12px 16px;\n  background: transparent;\n  border: none;\n  border-radius: 2px;\n  color: var(--color-text-muted);\n  font-weight: 600;\n  font-size: 0.875rem;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.profile-page__tab:hover {\n  color: var(--color-text);\n  background: rgba(255, 255, 255, 0.05);\n}\n\n.profile-page__tab--active {\n  color: var(--color-neon-blue);\n  background: rgba(67, 97, 238, 0.15);\n}\n\n/* Yellow pulsing dot for loot tab (same as header nav) */\n.profile-page__tab-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: #ffd700;\n  box-shadow: 0 0 6px #ffd700;\n  margin-left: 6px;\n  animation: nav-badge-pulse 1.5s ease-in-out infinite;\n}\n\n/* Loot count badge */\n.profile-page__tab-badge {\n  margin-left: 4px;\n  padding: 2px 6px;\n  font-size: 0.9rem;\n  font-weight: 700;\n  background: rgba(255, 215, 0, 0.2);\n  color: #ffd700;\n  border-radius: 3px;\n}\n\n.profile-page__content {\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 4px;\n  padding: 24px;\n}\n\n/* Profile Stats */\n.profile-stats__grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));\n  gap: 16px;\n  margin-bottom: 32px;\n}\n\n.profile-stats__card {\n  padding: 20px;\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid var(--color-border);\n  border-radius: 3px;\n  text-align: center;\n}\n\n.profile-stats__card-value {\n  font-size: 1.5rem;\n  font-weight: 700;\n  color: var(--color-neon-blue);\n  margin-bottom: 4px;\n}\n\n.profile-stats__card-value--positive {\n  color: var(--color-neon-green);\n}\n\n.profile-stats__card-value--negative {\n  color: var(--color-neon-pink);\n}\n\n.profile-stats__card-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.profile-stats__game-breakdown {\n  margin-top: 32px;\n  background: rgba(0, 0, 0, 0.2);\n  border-radius: 3px;\n  padding: 20px;\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.profile-stats__game-breakdown-title {\n  font-size: 0.85rem;\n  font-weight: 700;\n  margin-bottom: 20px;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.profile-stats__game-row {\n  display: grid;\n  grid-template-columns: 140px 1fr 1fr 1fr 1fr;\n  align-items: center;\n  padding: 14px 16px;\n  background: rgba(255, 255, 255, 0.03);\n  border-radius: 2px;\n  margin-bottom: 8px;\n  transition: background 0.2s ease;\n}\n\n.profile-stats__game-row:hover {\n  background: rgba(255, 255, 255, 0.06);\n}\n\n.profile-stats__game-row:last-child {\n  margin-bottom: 0;\n}\n\n.profile-stats__game-name {\n  font-weight: 600;\n  font-size: 0.9rem;\n  color: var(--color-text);\n}\n\n.profile-stats__game-stat {\n  text-align: center;\n  font-size: 0.85rem;\n  color: var(--color-text-muted);\n  font-family: \"JetBrains Mono\", monospace;\n}\n\n.profile-stats__game-stat:last-child {\n  text-align: right;\n  color: var(--color-neon-blue);\n}\n\n/* Profile Loot */\n.profile-loot__empty {\n  text-align: center;\n  padding: 40px;\n  color: var(--color-text-muted);\n}\n\n.profile-loot__list {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.profile-loot__item {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 16px;\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid var(--color-border);\n  border-radius: 3px;\n}\n\n.profile-loot__item-icon {\n  width: 40px;\n  height: 40px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(67, 97, 238, 0.2);\n  border-radius: 2px;\n  font-size: 1.25rem;\n}\n\n.profile-loot__item-info {\n  flex: 1;\n}\n\n.profile-loot__item-desc {\n  font-weight: 500;\n  margin-bottom: 4px;\n}\n\n.profile-loot__item-source {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n}\n\n.profile-loot__item-amount {\n  font-size: 1.1rem;\n  font-weight: 700;\n  color: var(--color-neon-green);\n}\n\n.profile-loot__claim-btn {\n  padding: 8px 16px;\n  background: var(--color-neon-green);\n  color: var(--color-bg);\n  border: none;\n  border-radius: 2px;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.profile-loot__claim-btn:hover {\n  box-shadow: 0 0 20px var(--color-neon-green);\n}\n\n.profile-loot__claim-all {\n  margin-top: 16px;\n  text-align: center;\n}\n\n/* Profile Transactions */\n.profile-transactions__table {\n  width: 100%;\n  border-collapse: collapse;\n}\n\n.profile-transactions__table th,\n.profile-transactions__table td {\n  padding: 12px;\n  text-align: left;\n  border-bottom: 1px solid var(--color-border);\n}\n\n.profile-transactions__table th {\n  font-size: 1rem;\n  font-weight: 600;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.profile-transactions__outcome--win {\n  color: var(--color-neon-green);\n}\n\n.profile-transactions__outcome--loss {\n  color: var(--color-neon-pink);\n}\n\n.profile-transactions__net--positive {\n  color: var(--color-neon-green);\n}\n\n.profile-transactions__net--negative {\n  color: var(--color-neon-pink);\n}\n\n/* Profile Settings */\n.profile-settings__section {\n  margin-bottom: 32px;\n}\n\n.profile-settings__section-title {\n  font-size: 1rem;\n  font-weight: 600;\n  margin-bottom: 16px;\n  color: var(--color-text);\n}\n\n.profile-settings__input-group {\n  display: flex;\n  gap: 12px;\n  margin-bottom: 16px;\n}\n\n.profile-settings__input {\n  flex: 1;\n  padding: 12px 16px;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n  color: var(--color-text);\n  font-size: 1rem;\n}\n\n.profile-settings__input:focus {\n  outline: none;\n  border-color: var(--color-neon-blue);\n}\n\n.profile-settings__save-btn {\n  padding: 12px 24px;\n  background: var(--color-neon-blue);\n  color: var(--color-bg);\n  border: none;\n  border-radius: 2px;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.profile-settings__save-btn:hover {\n  box-shadow: 0 0 20px var(--color-neon-blue);\n}\n\n/* Avatar Selector */\n.avatar-selector-wrapper {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n}\n\n.avatar-selector-category {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.avatar-selector-category__title {\n  font-size: 0.85rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin: 0;\n}\n\n.avatar-selector {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));\n  gap: 12px;\n}\n\n.avatar-selector__item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 6px;\n  padding: 10px 8px;\n  background: rgba(255, 255, 255, 0.03);\n  border: 2px solid transparent;\n  border-radius: 3px;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.avatar-selector__item:hover:not(.avatar-selector__item--locked) {\n  background: rgba(255, 255, 255, 0.08);\n  transform: translateY(-2px);\n}\n\n.avatar-selector__item--selected {\n  background: rgba(255, 255, 255, 0.08);\n}\n\n.avatar-selector__item--locked {\n  cursor: not-allowed;\n}\n\n.avatar-selector__item--locked:hover {\n  background: rgba(255, 255, 255, 0.03);\n}\n\n.avatar-selector__avatar {\n  position: relative;\n  border-radius: 50%;\n  overflow: visible;\n}\n\n.avatar-selector__lock-overlay {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(0, 0, 0, 0.7);\n  border-radius: 50%;\n}\n\n.avatar-selector__lock-icon {\n  font-size: 16px;\n  filter: grayscale(100%);\n}\n\n.avatar-selector__item-name {\n  font-size: 0.9rem;\n  font-weight: 500;\n  color: var(--color-text);\n  text-align: center;\n  line-height: 1.2;\n}\n\n.avatar-selector__item--locked .avatar-selector__item-name {\n  color: var(--color-text-muted);\n}\n\n.avatar-selector__item-level {\n  font-size: 0.6rem;\n  font-weight: 600;\n}\n\n.avatar-selector__item--locked .avatar-selector__item-level {\n  opacity: 0.6;\n}\n\n/* Avatar Selector Modal */\n.avatar-selector-modal-overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.9);\n  display: flex;\n  align-items: flex-start;\n  justify-content: center;\n  z-index: 10001;\n  padding: 100px 24px 24px;\n  overflow-y: auto;\n  isolation: isolate;\n}\n\n.avatar-selector-modal {\n  background: var(--color-bg);\n  border: 1px solid var(--color-border);\n  border-radius: 4px;\n  max-width: 600px;\n  width: 100%;\n  max-height: calc(100vh - 124px);\n  overflow-y: auto;\n}\n\n.avatar-selector-modal__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 20px 24px;\n  border-bottom: 1px solid var(--color-border);\n  position: sticky;\n  top: 0;\n  background: var(--color-surface);\n  z-index: 1;\n}\n\n.avatar-selector-modal__title {\n  font-size: 1.25rem;\n  font-weight: 600;\n  color: var(--color-text);\n  margin: 0;\n}\n\n.avatar-selector-modal__saving {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  font-weight: 400;\n}\n\n.avatar-selector-modal__close {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  background: transparent;\n  border: 1px solid var(--color-border);\n  color: var(--color-text-muted);\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.avatar-selector-modal__close:hover {\n  background: rgba(255, 255, 255, 0.1);\n  color: var(--color-text);\n}\n\n.avatar-selector-modal__content {\n  padding: 24px;\n}\n\n/* Profile Page Avatar Section - Clickable */\n.profile-page__avatar-section--clickable {\n  cursor: pointer;\n  position: relative;\n  transition: transform 0.2s ease;\n}\n\n.profile-page__avatar-section--clickable:hover {\n  transform: scale(1.03);\n}\n\n.profile-page__avatar-section--clickable:hover .profile-page__avatar-edit-hint {\n  opacity: 1;\n}\n\n.profile-page__avatar-edit-hint {\n  position: absolute;\n  top: 8px;\n  right: 8px;\n  background: var(--color-surface);\n  border: 1px solid var(--color-border);\n  border-radius: 50%;\n  width: 28px;\n  height: 28px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  opacity: 0.6;\n  transition: opacity 0.2s ease;\n  color: var(--color-text);\n}\n\n/* Profile Settings - Wallet Section */\n.profile-settings__wallet {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 16px;\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid var(--color-border);\n  border-radius: 3px;\n}\n\n.profile-settings__wallet-icon {\n  width: 40px;\n  height: 40px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--color-neon-cyan);\n  flex-shrink: 0;\n}\n\n.profile-settings__wallet-info {\n  flex: 1;\n  min-width: 0;\n}\n\n.profile-settings__wallet-address {\n  font-size: 1rem;\n  font-weight: 600;\n  color: var(--color-text);\n  font-family: monospace;\n}\n\n.profile-settings__wallet-full {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  font-family: monospace;\n  margin-top: 4px;\n  word-break: break-all;\n  opacity: 0.7;\n}\n\n/* Social Connections */\n.profile-socials__list {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.profile-socials__item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 12px 16px;\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid var(--color-border);\n  border-radius: 2px;\n}\n\n.profile-socials__icon {\n  width: 32px;\n  height: 32px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.profile-socials__info {\n  flex: 1;\n}\n\n.profile-socials__name {\n  font-weight: 500;\n}\n\n.profile-socials__username {\n  font-size: 0.8rem;\n  color: var(--color-text-muted);\n}\n\n.profile-socials__btn {\n  padding: 8px 16px;\n  border-radius: 2px;\n  font-weight: 600;\n  font-size: 0.8rem;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.profile-socials__btn--connect {\n  background: var(--color-neon-blue);\n  color: var(--color-bg);\n  border: none;\n}\n\n.profile-socials__btn--disconnect {\n  background: transparent;\n  color: var(--color-neon-pink);\n  border: 1px solid var(--color-neon-pink);\n}\n\n/* ============ Print Styles ============ */\n@media print {\n  body::before,\n  body::after {\n    display: none;\n  }\n\n  .app::before,\n  .app::after {\n    display: none;\n  }\n\n  * {\n    animation: none !important;\n    text-shadow: none !important;\n    box-shadow: none !important;\n  }\n}\n\n/* ============================================\n   QUESTS SYSTEM STYLES\n   ============================================ */\n\n/* QuestsPanel - Sidebar component */\n.quests-panel {\n  background: rgba(0, 0, 0, 0.4);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 1rem;\n}\n\n.quests-panel--loading {\n  min-height: 200px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.quests-panel__loader {\n  color: rgba(255, 255, 255, 0.5);\n  font-size: 0.875rem;\n}\n\n.quests-panel__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 0.75rem;\n}\n\n.quests-panel__title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  margin: 0;\n}\n\n.quests-panel__chest-badge {\n  background: linear-gradient(135deg, #ffd700 0%, #ff9500 100%);\n  color: #000;\n  padding: 0.25rem 0.5rem;\n  border-radius: 3px;\n  font-size: 1rem;\n  font-weight: 600;\n}\n\n/* Quest tabs */\n.quests-panel__tabs {\n  display: flex;\n  gap: 0.5rem;\n  margin-bottom: 0.75rem;\n}\n\n.quests-panel__tab {\n  flex: 1;\n  padding: 0.5rem;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  color: rgba(255, 255, 255, 0.6);\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  cursor: pointer;\n  transition: all 0.2s;\n  position: relative;\n}\n\n.quests-panel__tab:hover {\n  background: rgba(255, 255, 255, 0.1);\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.quests-panel__tab--active {\n  background: rgba(0, 255, 255, 0.1);\n  border-color: var(--color-neon-cyan);\n  color: var(--color-neon-cyan);\n}\n\n.quests-panel__tab-badge {\n  position: absolute;\n  top: -4px;\n  right: -4px;\n  width: 16px;\n  height: 16px;\n  background: var(--color-neon-green);\n  color: #000;\n  border-radius: 50%;\n  font-size: 0.65rem;\n  font-weight: 700;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 0 8px var(--color-neon-green);\n  animation: nav-badge-pulse 1.5s ease-in-out infinite;\n}\n\n/* Reset timer */\n.quests-panel__reset {\n  font-size: 0.9rem;\n  color: rgba(255, 255, 255, 0.5);\n  text-align: center;\n  margin-bottom: 0.75rem;\n}\n\n.quests-panel__reset-time {\n  color: var(--color-neon-cyan);\n  font-weight: 600;\n}\n\n/* Quest list */\n.quests-panel__list {\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n}\n\n/* Individual quest item */\n.quest-item {\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 0.75rem;\n  transition: all 0.2s;\n}\n\n.quest-item--completed:not(.quest-item--claimed) {\n  border-color: var(--color-neon-green);\n  background: rgba(57, 204, 20, 0.1);\n}\n\n.quest-item--claimed {\n  opacity: 0.6;\n  border-color: rgba(255, 255, 255, 0.05);\n}\n\n.quest-item__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 0.25rem;\n}\n\n.quest-item__title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: #fff;\n}\n\n.quest-item__checkmark {\n  color: var(--color-neon-green);\n  font-size: 1rem;\n}\n\n.quest-item__description {\n  font-size: 0.9rem;\n  color: rgba(255, 255, 255, 0.6);\n  margin: 0 0 0.5rem 0;\n}\n\n/* Progress bar */\n.quest-item__progress {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  margin-bottom: 0.5rem;\n}\n\n.quest-item__progress-bar {\n  flex: 1;\n  height: 6px;\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 3px;\n  overflow: hidden;\n}\n\n.quest-item__progress-fill {\n  height: 100%;\n  background: linear-gradient(90deg, var(--color-neon-cyan), var(--color-neon-green));\n  border-radius: 3px;\n  transition: width 0.3s ease;\n}\n\n.quest-item--completed .quest-item__progress-fill {\n  background: var(--color-neon-green);\n}\n\n.quest-item__progress-text {\n  font-size: 0.65rem;\n  color: rgba(255, 255, 255, 0.7);\n  min-width: 40px;\n  text-align: right;\n}\n\n/* Games list for win_each_game */\n.quest-item__games {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.25rem 0.5rem;\n  margin-bottom: 0.5rem;\n}\n\n.quest-item__game {\n  font-size: 0.65rem;\n  color: rgba(255, 255, 255, 0.5);\n}\n\n.quest-item__game--won {\n  color: var(--color-neon-green);\n}\n\n/* Rewards display */\n.quest-item__rewards {\n  display: flex;\n  gap: 0.75rem;\n  margin-bottom: 0.5rem;\n}\n\n.quest-item__reward {\n  font-size: 0.65rem;\n  font-weight: 600;\n}\n\n.quest-item__reward--xp {\n  color: var(--color-neon-cyan);\n}\n\n.quest-item__reward--chest {\n  color: #ffd700;\n}\n\n/* Claim button */\n.quest-item__claim-btn {\n  width: 100%;\n  padding: 0.5rem;\n  background: linear-gradient(135deg, var(--color-neon-green) 0%, #39cc14 100%);\n  border: none;\n  border-radius: 2px;\n  color: #000;\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.quest-item__claim-btn:hover:not(:disabled) {\n  transform: scale(1.02);\n  box-shadow: 0 0 12px var(--color-neon-green);\n}\n\n.quest-item__claim-btn:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n\n/* Unclaimed notice */\n.quests-panel__unclaimed {\n  margin-top: 0.75rem;\n  padding: 0.5rem;\n  background: rgba(57, 204, 20, 0.15);\n  border: 1px solid var(--color-neon-green);\n  border-radius: 2px;\n  text-align: center;\n  font-size: 0.9rem;\n  color: var(--color-neon-green);\n  animation: pulse-glow 2s infinite;\n}\n\n/* Bonus info */\n.quests-panel__bonus {\n  margin-top: 1rem;\n  padding: 0.75rem;\n  background: rgba(255, 215, 0, 0.1);\n  border: 1px dashed rgba(255, 215, 0, 0.4);\n  border-radius: 2px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n  font-size: 1rem;\n  color: var(--color-neon-gold);\n}\n\n.quests-panel__bonus--earned {\n  background: rgba(0, 255, 136, 0.15);\n  border: 1px solid var(--color-neon-green);\n  border-style: solid;\n  color: var(--color-neon-green);\n}\n\n@keyframes pulse-glow {\n  0%, 100% { box-shadow: 0 0 4px var(--color-neon-green); }\n  50% { box-shadow: 0 0 12px var(--color-neon-green); }\n}\n\n/* ============================================\n   TREASURE CHEST PANEL STYLES\n   ============================================ */\n\n.treasure-chest-panel {\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 1.25rem;\n}\n\n.treasure-chest-panel__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 1rem;\n}\n\n.treasure-chest-panel__title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: #ffd700;\n  margin: 0;\n}\n\n.treasure-chest-panel__count {\n  margin-left: 0.5rem;\n  color: rgba(255, 255, 255, 0.7);\n}\n\n.treasure-chest-panel__open-all {\n  padding: 0.5rem 1rem;\n  background: linear-gradient(135deg, #ffd700 0%, #ff9500 100%);\n  border: none;\n  border-radius: 2px;\n  color: #000;\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.treasure-chest-panel__open-all:hover:not(:disabled) {\n  transform: scale(1.05);\n  box-shadow: 0 0 12px rgba(255, 215, 0, 0.5);\n}\n\n.treasure-chest-panel__open-all:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n\n/* Result display */\n.treasure-chest-panel__result {\n  position: relative;\n  background: rgba(0, 0, 0, 0.5);\n  border: 2px solid #ffd700;\n  border-radius: 2px;\n  padding: 1rem;\n  margin-bottom: 1rem;\n  text-align: center;\n  animation: chest-open-flash 0.5s ease;\n}\n\n@keyframes chest-open-flash {\n  0% { transform: scale(0.9); opacity: 0; }\n  50% { transform: scale(1.05); }\n  100% { transform: scale(1); opacity: 1; }\n}\n\n.treasure-chest-panel__result--bulk {\n  border-color: var(--color-neon-green);\n}\n\n.treasure-chest-panel__result-close {\n  position: absolute;\n  top: 0.5rem;\n  right: 0.5rem;\n  width: 24px;\n  height: 24px;\n  background: rgba(255, 255, 255, 0.1);\n  border: none;\n  border-radius: 50%;\n  color: rgba(255, 255, 255, 0.6);\n  cursor: pointer;\n  font-size: 1rem;\n  line-height: 1;\n}\n\n.treasure-chest-panel__result-close:hover {\n  background: rgba(255, 255, 255, 0.2);\n  color: #fff;\n}\n\n.treasure-chest-panel__result-rarity {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  font-weight: 700;\n  margin-bottom: 0.5rem;\n  text-shadow: 0 0 10px currentColor;\n}\n\n.treasure-chest-panel__result-title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-green);\n  margin-bottom: 0.5rem;\n}\n\n.treasure-chest-panel__result-contents {\n  display: flex;\n  justify-content: center;\n  gap: 1.5rem;\n}\n\n.treasure-chest-panel__result-xp {\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  font-weight: 600;\n}\n\n.treasure-chest-panel__result-sol {\n  font-size: 1rem;\n  color: var(--color-neon-green);\n  font-weight: 600;\n}\n\n/* Chest grid */\n.treasure-chest-panel__grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));\n  gap: 0.75rem;\n  margin-bottom: 1rem;\n}\n\n.treasure-chest-panel__chest {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n  padding: 0.75rem;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid rgba(255, 215, 0, 0.3);\n  border-radius: 2px;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.treasure-chest-panel__chest:hover:not(:disabled) {\n  background: rgba(255, 215, 0, 0.1);\n  border-color: #ffd700;\n  transform: scale(1.05);\n}\n\n.treasure-chest-panel__chest:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.treasure-chest-panel__chest--opening {\n  animation: chest-shake 0.5s ease infinite;\n}\n\n@keyframes chest-shake {\n  0%, 100% { transform: translateX(0) rotate(0deg); }\n  25% { transform: translateX(-2px) rotate(-2deg); }\n  75% { transform: translateX(2px) rotate(2deg); }\n}\n\n.treasure-chest-panel__chest-icon {\n  font-size: 2rem;\n}\n\n.treasure-chest-panel__chest-source {\n  font-size: 0.6rem;\n  color: rgba(255, 255, 255, 0.5);\n  text-transform: uppercase;\n}\n\n/* Empty state */\n.treasure-chest-panel__empty {\n  text-align: center;\n  padding: 2rem 1rem;\n}\n\n.treasure-chest-panel__empty-text {\n  color: rgba(255, 255, 255, 0.6);\n  margin: 0 0 0.5rem 0;\n}\n\n.treasure-chest-panel__empty-hint {\n  font-size: 0.8rem;\n  color: rgba(255, 255, 255, 0.4);\n  margin: 0;\n}\n\n/* History section */\n.treasure-chest-panel__history {\n  margin-top: 1rem;\n  padding-top: 1rem;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.treasure-chest-panel__history-title {\n  font-family: var(--font-pixel);\n  font-size: 0.8rem;\n  color: rgba(255, 255, 255, 0.6);\n  margin: 0 0 0.75rem 0;\n}\n\n.treasure-chest-panel__history-list {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.treasure-chest-panel__history-item {\n  display: flex;\n  justify-content: space-between;\n  padding: 0.5rem;\n  background: rgba(255, 255, 255, 0.03);\n  border-left: 3px solid #a8a8a8;\n  border-radius: 0 4px 4px 0;\n  font-size: 1rem;\n}\n\n.treasure-chest-panel__history-rarity {\n  text-transform: capitalize;\n  color: rgba(255, 255, 255, 0.7);\n}\n\n.treasure-chest-panel__history-contents {\n  color: rgba(255, 255, 255, 0.5);\n}\n\n/* FAQ link */\n.treasure-chest-panel__faq {\n  margin-top: 1rem;\n  text-align: center;\n}\n\n.treasure-chest-panel__faq-link {\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  text-decoration: none;\n}\n\n.treasure-chest-panel__faq-link:hover {\n  text-decoration: underline;\n}\n\n/* ============================================\n   CHEST DROP NOTIFICATION (Toast)\n   ============================================ */\n\n.chest-drop-notification {\n  position: fixed;\n  top: 80px;\n  left: 50%;\n  transform: translateX(-50%);\n  z-index: 10000;\n  animation: chest-notification-enter 0.4s ease-out;\n}\n\n@keyframes chest-notification-enter {\n  0% {\n    opacity: 0;\n    transform: translateX(-50%) translateY(-20px) scale(0.9);\n  }\n  100% {\n    opacity: 1;\n    transform: translateX(-50%) translateY(0) scale(1);\n  }\n}\n\n.chest-drop-notification__content {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 12px 20px;\n  background: linear-gradient(135deg, rgba(139, 69, 19, 0.95), rgba(93, 58, 26, 0.95));\n  border: 2px solid #ffd700;\n  border-radius: 3px;\n  box-shadow:\n    0 0 20px rgba(255, 215, 0, 0.4),\n    0 4px 20px rgba(0, 0, 0, 0.5);\n  animation: chest-glow-pulse 1.5s ease-in-out infinite;\n}\n\n@keyframes chest-glow-pulse {\n  0%, 100% {\n    box-shadow:\n      0 0 20px rgba(255, 215, 0, 0.4),\n      0 4px 20px rgba(0, 0, 0, 0.5);\n  }\n  50% {\n    box-shadow:\n      0 0 30px rgba(255, 215, 0, 0.6),\n      0 4px 20px rgba(0, 0, 0, 0.5);\n  }\n}\n\n.chest-drop-notification__icon {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  animation: chest-icon-bounce 0.6s ease-out;\n}\n\n@keyframes chest-icon-bounce {\n  0%, 100% { transform: translateY(0); }\n  50% { transform: translateY(-4px); }\n}\n\n.chest-drop-notification__text {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.chest-drop-notification__title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: #ffd700;\n  text-shadow: 0 0 8px rgba(255, 215, 0, 0.5);\n}\n\n.chest-drop-notification__subtitle {\n  font-size: 1rem;\n  color: rgba(255, 255, 255, 0.8);\n}\n\n/* ============================================\n   TREASURE CHEST FAQ STYLES\n   ============================================ */\n\n.chest-faq {\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 1.5rem;\n  margin-top: 1.5rem;\n}\n\n.chest-faq__title {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: #ffd700;\n  margin: 0 0 1.5rem 0;\n  text-align: center;\n}\n\n.chest-faq__section {\n  margin-bottom: 1.25rem;\n}\n\n.chest-faq__section:last-child {\n  margin-bottom: 0;\n}\n\n.chest-faq__question {\n  font-family: var(--font-pixel);\n  font-size: 0.85rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 0.5rem 0;\n}\n\n.chest-faq__answer {\n  font-size: 0.85rem;\n  color: rgba(255, 255, 255, 0.8);\n  margin: 0;\n  line-height: 1.5;\n}\n\n/* Rarity table */\n.chest-faq__table {\n  background: rgba(0, 0, 0, 0.3);\n  border-radius: 2px;\n  overflow: hidden;\n  margin-top: 0.5rem;\n}\n\n.chest-faq__table-header {\n  display: grid;\n  grid-template-columns: 1fr 0.7fr 1fr 1fr;\n  gap: 0.5rem;\n  padding: 0.75rem;\n  background: rgba(255, 255, 255, 0.05);\n  font-family: var(--font-pixel);\n  font-size: 0.9rem;\n  color: rgba(255, 255, 255, 0.6);\n  text-transform: uppercase;\n}\n\n.chest-faq__table-row {\n  display: grid;\n  grid-template-columns: 1fr 0.7fr 1fr 1fr;\n  gap: 0.5rem;\n  padding: 0.75rem;\n  border-left: 3px solid #a8a8a8;\n  font-size: 0.8rem;\n  color: rgba(255, 255, 255, 0.7);\n}\n\n.chest-faq__table-row:nth-child(even) {\n  background: rgba(255, 255, 255, 0.02);\n}\n\n.chest-faq__rarity {\n  font-weight: 600;\n}\n\n/* ============================================\n   QUESTS PAGE STYLES\n   ============================================ */\n\n.quests-page {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 1rem 2rem 2rem;\n}\n\n.quests-page__header {\n  text-align: center;\n  margin-bottom: 2rem;\n}\n\n.quests-page__title {\n  font-family: var(--font-pixel);\n  font-size: 2rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 0.5rem 0;\n  text-shadow: none;\n}\n\n.quests-page__subtitle {\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  margin: 0;\n}\n\n.quests-page__content {\n  display: flex;\n  justify-content: center;\n  align-items: start;\n}\n\n.quests-page__main {\n  width: 100%;\n  max-width: 500px;\n}\n\n.quests-page__main .quests-panel {\n  background: rgba(0, 0, 0, 0.4);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 1.5rem;\n}\n\n.quests-page__sidebar {\n  display: flex;\n  flex-direction: column;\n  gap: 1.5rem;\n  min-width: 0;\n}\n\n.quests-page__section {\n  background: rgba(0, 0, 0, 0.4);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 1.5rem;\n}\n\n.quests-page__section-title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-gold);\n  margin: 0 0 1rem 0;\n  padding-bottom: 0.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n/* Responsive adjustments for quests page */\n@media (max-width: 900px) {\n  .quests-page__content {\n    grid-template-columns: 1fr;\n  }\n\n  .quests-page {\n    padding: 1rem;\n  }\n}\n\n@media (max-width: 480px) {\n  .quests-page__title {\n    font-size: 1.5rem;\n  }\n\n  .quests-page__subtitle {\n    font-size: 0.875rem;\n  }\n}\n\n/* =====================\n   Loot Page\n   ===================== */\n\n.loot-page {\n  max-width: 800px;\n  margin: 0 auto;\n  padding: 1rem 2rem 2rem;\n}\n\n.loot-page__header {\n  text-align: center;\n  margin-bottom: 2rem;\n}\n\n.loot-page__title {\n  font-family: var(--font-pixel);\n  font-size: 2rem;\n  color: var(--color-neon-gold);\n  margin: 0 0 0.5rem 0;\n  text-shadow: none;\n}\n\n.loot-page__subtitle {\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  margin: 0;\n}\n\n.loot-page__content {\n  background: rgba(0, 0, 0, 0.4);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 1.5rem;\n}\n\n.loot-page__loading,\n.loot-page__connect {\n  text-align: center;\n  padding: 4rem 2rem;\n}\n\n.loot-page__connect h2 {\n  font-family: var(--font-pixel);\n  color: var(--color-neon-gold);\n  margin: 0 0 0.5rem 0;\n}\n\n.loot-page__connect p {\n  color: var(--color-text-dim);\n  margin: 0;\n}\n\n@media (max-width: 640px) {\n  .loot-page {\n    padding: 1rem;\n  }\n\n  .loot-page__title {\n    font-size: 1.5rem;\n  }\n\n  .loot-page__subtitle {\n    font-size: 0.875rem;\n  }\n}\n\n/* Profile loot section styles */\n.profile-loot__section {\n  margin-bottom: 2rem;\n}\n\n.profile-loot__section-title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 1rem 0;\n  padding-bottom: 0.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n/* ==========================================\n   GAME OF TRADES\n   ========================================== */\n\n.got-main {\n  width: 100%;\n  min-height: 400px;\n  position: relative;\n}\n\n/* Countdown Timer */\n.got-countdown {\n  display: flex;\n  flex-direction: row;\n  align-items: baseline;\n  gap: 0.5rem;\n}\n\n.got-countdown--small .got-countdown__time {\n  font-size: 1rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-cyan);\n}\n\n.got-countdown--large {\n  padding: 0.5rem;\n}\n\n.got-countdown--large .got-countdown__time {\n  font-size: 1.5rem;\n  font-family: var(--font-pixel);\n  color: var(--color-neon-cyan);\n  text-shadow: none;\n}\n\n.got-countdown__label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.got-countdown--urgent .got-countdown__time {\n  color: var(--color-neon-yellow);\n  text-shadow: none;\n}\n\n.got-countdown--final .got-countdown__time {\n  color: #ff4444;\n  text-shadow: none;\n  animation: countdown-pulse 0.5s ease-in-out infinite;\n}\n\n/* Tier Lobby */\n.got-tier-lobby {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1.5rem;\n  width: 100%;\n}\n\n.got-tier-lobby__instruction {\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  text-align: center;\n  margin: 0;\n}\n\n.got-tier-lobby__grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(280px, 400px));\n  gap: 1rem;\n  justify-content: center;\n  width: 100%;\n}\n\n.got-tier-lobby__loading {\n  text-align: center;\n  color: var(--color-text-muted);\n  padding: 2rem;\n}\n\n/* Tier Cards */\n.got-tier-card {\n  background: var(--color-surface);\n  border: 2px solid var(--color-border);\n  padding: 1rem;\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n  cursor: pointer;\n  transition: all 0.2s;\n  text-align: left;\n}\n\n.got-tier-card:hover {\n  border-color: var(--tier-color);\n  box-shadow: none;\n}\n\n.got-tier-card--selected {\n  border-color: var(--tier-color);\n  box-shadow: none;\n}\n\n.got-tier-card--lobby {\n  animation: got-tier-pulse 1s ease-in-out infinite;\n}\n\n.got-tier-card--trading {\n  border-color: var(--color-neon-yellow);\n  animation: got-trading-glow 0.5s ease-in-out infinite alternate;\n}\n\n@keyframes got-tier-pulse {\n  0%, 100% { box-shadow: none; }\n  50% { box-shadow: none; }\n}\n\n@keyframes got-trading-glow {\n  0% { box-shadow: none; }\n  100% { box-shadow: none; }\n}\n\n@keyframes got-pulse {\n  0%, 100% {\n    opacity: 1;\n    transform: scale(1);\n    text-shadow: 0 0 8px var(--color-neon-red);\n  }\n  50% {\n    opacity: 0.7;\n    transform: scale(1.05);\n    text-shadow: 0 0 16px var(--color-neon-red), 0 0 24px var(--color-neon-red);\n  }\n}\n\n.got-tier-card__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.got-tier-card__name {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--tier-color);\n  text-transform: uppercase;\n  text-shadow: none;\n}\n\n.got-tier-card__amount {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  font-weight: bold;\n}\n\n.got-tier-card__stats {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 0.5rem;\n}\n\n.got-tier-card__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.got-tier-card__stat-label {\n  font-size: 1rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n.got-tier-card__stat-value {\n  font-size: 1rem;\n  color: var(--color-text);\n  font-weight: bold;\n}\n\n.got-tier-card__phase {\n  text-align: center;\n  padding-top: 0.5rem;\n  border-top: 1px solid var(--color-border);\n}\n\n.got-tier-card__phase-text {\n  font-size: 0.875rem;\n  color: var(--color-text-muted);\n  text-transform: uppercase;\n}\n\n/* Game Lobby */\n.got-game-lobby {\n  padding: 3rem 1.5rem 1.5rem;\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n.got-game-lobby__back {\n  position: absolute;\n  top: 0.75rem;\n  left: 0.75rem;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  background: transparent;\n  border: none;\n  color: var(--color-text-dim);\n  cursor: pointer;\n  padding: 0.5rem;\n  transition: color 0.2s;\n  z-index: 10;\n}\n\n.got-game-lobby__back:hover {\n  color: var(--color-text);\n}\n\n.got-game-lobby__back svg {\n  width: 20px;\n  height: 20px;\n}\n\n.got-game-lobby__tier-badge {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-end;\n}\n\n.got-game-lobby__tier-name {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: var(--tier-color);\n  text-transform: uppercase;\n}\n\n.got-game-lobby__tier-entry {\n  font-size: 1rem;\n  color: var(--color-neon-gold);\n}\n\n.got-game-lobby__prize {\n  text-align: center;\n  margin-bottom: 1.5rem;\n}\n\n.got-game-lobby__prize-label {\n  display: block;\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  margin-bottom: 0.25rem;\n}\n\n.got-game-lobby__prize-value {\n  font-family: var(--font-pixel);\n  font-size: 2rem;\n  color: var(--color-neon-gold);\n  text-shadow: 0 0 10px var(--color-neon-gold);\n}\n\n.got-game-lobby__status {\n  text-align: center;\n  margin-bottom: 1.5rem;\n}\n\n.got-game-lobby__countdown {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.got-game-lobby__countdown-label {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n}\n\n.got-game-lobby__waiting {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.75rem;\n  color: var(--color-text-dim);\n}\n\n.got-game-lobby__waiting-spinner {\n  width: 40px;\n  height: 40px;\n  border: 3px solid rgba(255, 255, 255, 0.1);\n  border-top-color: var(--color-neon-cyan);\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n.got-game-lobby__players {\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 1rem;\n  margin-bottom: 1.5rem;\n}\n\n.got-game-lobby__players-title {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 0.75rem 0;\n}\n\n.got-game-lobby__players-list {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.5rem;\n}\n\n.got-game-lobby__players-empty {\n  color: var(--color-text-dim);\n  font-size: 0.875rem;\n  text-align: center;\n  padding: 1rem;\n}\n\n.got-game-lobby__player {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  background: rgba(255, 255, 255, 0.05);\n  padding: 0.25rem 0.5rem;\n  border-radius: 2px;\n}\n\n.got-game-lobby__player--you {\n  border: 1px solid var(--color-neon-green);\n}\n\n.got-game-lobby__player-you {\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n}\n\n.got-game-lobby__actions {\n  margin-bottom: 1.5rem;\n}\n\n.got-game-lobby__join-btn {\n  width: 100%;\n  padding: 1rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: linear-gradient(180deg, var(--tier-color) 0%, color-mix(in srgb, var(--tier-color) 70%, black) 100%);\n  border: none;\n  border-radius: 2px;\n  color: white;\n  cursor: pointer;\n  transition: all 0.2s;\n  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);\n}\n\n.got-game-lobby__join-btn:hover:not(:disabled) {\n  transform: translateY(-2px);\n  box-shadow: 0 4px 20px color-mix(in srgb, var(--tier-color) 50%, transparent);\n}\n\n.got-game-lobby__join-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.got-game-lobby__leave-btn {\n  width: 100%;\n  padding: 1rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: rgba(255, 255, 255, 0.1);\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  border-radius: 2px;\n  color: var(--color-text);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.got-game-lobby__leave-btn:hover:not(:disabled) {\n  background: rgba(255, 255, 255, 0.15);\n}\n\n.got-game-lobby__leave-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.got-game-lobby__rules {\n  background: rgba(0, 0, 0, 0.2);\n  border-radius: 2px;\n  overflow: hidden;\n}\n\n.got-game-lobby__rules-toggle {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  width: 100%;\n  padding: 0.75rem 1rem;\n  background: transparent;\n  border: none;\n  cursor: pointer;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  transition: background 0.2s;\n}\n\n.got-game-lobby__rules-toggle:hover {\n  background: rgba(255, 255, 255, 0.05);\n}\n\n.got-game-lobby__rules-chevron {\n  width: 16px;\n  height: 16px;\n  transition: transform 0.2s;\n}\n\n.got-game-lobby__rules--expanded .got-game-lobby__rules-chevron {\n  transform: rotate(180deg);\n}\n\n.got-game-lobby__rules-list {\n  margin: 0;\n  padding: 0 1rem 1rem 2.25rem;\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  line-height: 1.6;\n}\n\n/* Loading Screen */\n.got-loading-screen {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  padding: 2rem;\n  min-height: 400px;\n  text-align: center;\n}\n\n.got-loading-screen__title {\n  font-family: var(--font-pixel);\n  font-size: 1.5rem;\n  color: var(--color-text);\n  margin: 0 0 1rem 0;\n}\n\n.got-loading-screen__tier {\n  text-shadow: 0 0 10px currentColor;\n}\n\n.got-loading-screen__prize {\n  margin-bottom: 2rem;\n}\n\n.got-loading-screen__prize-label {\n  display: block;\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  margin-bottom: 0.25rem;\n}\n\n.got-loading-screen__prize-value {\n  font-family: var(--font-pixel);\n  font-size: 2.5rem;\n  color: var(--color-neon-green);\n  text-shadow: 0 0 15px var(--color-neon-gold);\n}\n\n.got-loading-screen__players {\n  margin-bottom: 2rem;\n}\n\n.got-loading-screen__players-title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 1rem 0;\n}\n\n.got-loading-screen__players-grid {\n  display: flex;\n  flex-wrap: wrap;\n  justify-content: center;\n  gap: 0.75rem;\n}\n\n.got-loading-screen__player {\n  background: rgba(255, 255, 255, 0.05);\n  padding: 0.5rem 0.75rem;\n  border-radius: 2px;\n}\n\n.got-loading-screen__player--you {\n  border: 1px solid var(--color-neon-green);\n}\n\n.got-loading-screen__chart {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1rem;\n  margin-bottom: 2rem;\n}\n\n.got-loading-screen__chart-icon {\n  width: 60px;\n  height: 60px;\n  animation: got-chart-pulse 1.5s ease-in-out infinite;\n}\n\n.got-loading-screen__chart-icon svg {\n  width: 100%;\n  height: 100%;\n  stroke: var(--color-neon-cyan);\n}\n\n@keyframes got-chart-pulse {\n  0%, 100% { opacity: 0.5; transform: scale(1); }\n  50% { opacity: 1; transform: scale(1.1); }\n}\n\n.got-loading-screen__chart-text {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n}\n\n.got-loading-screen__chart-bar {\n  width: 200px;\n  height: 4px;\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  overflow: hidden;\n}\n\n.got-loading-screen__chart-progress {\n  height: 100%;\n  width: 30%;\n  background: var(--color-neon-cyan);\n  border-radius: 2px;\n  animation: got-loading-progress 1.5s ease-in-out infinite;\n}\n\n@keyframes got-loading-progress {\n  0% { width: 0%; margin-left: 0; }\n  50% { width: 50%; margin-left: 25%; }\n  100% { width: 0%; margin-left: 100%; }\n}\n\n.got-loading-screen__tips {\n  max-width: 400px;\n  padding: 1rem;\n  background: rgba(255, 255, 255, 0.05);\n  border-radius: 2px;\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n}\n\n.got-loading-screen__tips strong {\n  color: var(--color-neon-gold);\n}\n\n/* Trading View Layout */\n.got-trading-view {\n  display: grid;\n  grid-template-columns: 1fr 360px;\n  gap: 0.75rem;\n  padding: 0.75rem;\n  height: 100%;\n  position: relative;\n}\n\n.got-trading-view--finishing {\n  pointer-events: none;\n}\n\n.got-trading-view__finishing-overlay {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(0, 0, 0, 0.7);\n  z-index: 100;\n  animation: got-finishing-fade-in 0.3s ease-out;\n}\n\n@keyframes got-finishing-fade-in {\n  from {\n    opacity: 0;\n  }\n  to {\n    opacity: 1;\n  }\n}\n\n.got-trading-view__finishing-text {\n  font-family: var(--font-pixel);\n  font-size: 2.5rem;\n  color: var(--color-neon-red);\n  text-shadow: 0 0 20px var(--color-neon-red), 0 0 40px var(--color-neon-red);\n  animation: got-times-up-pulse 0.5s ease-in-out infinite;\n}\n\n@keyframes got-times-up-pulse {\n  0%, 100% {\n    transform: scale(1);\n  }\n  50% {\n    transform: scale(1.05);\n  }\n}\n\n.got-trading-view__main {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n  min-width: 0;\n}\n\n.got-trading-view__chart-section {\n  flex-shrink: 0;\n}\n\n.got-trading-view__controls-section {\n  flex-shrink: 0;\n}\n\n.got-trading-view__history-section {\n  flex-shrink: 0;\n}\n\n.got-trading-view__sidebar {\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n  min-height: 0;\n}\n\n/* Trading Chart */\n.got-trading-chart {\n  background: rgba(0, 0, 0, 0.4);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 0.75rem;\n}\n\n.got-trading-chart__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 0.25rem;\n}\n\n.got-trading-chart__asset {\n  display: flex;\n  align-items: center;\n  gap: 0.375rem;\n}\n\n.got-trading-chart__asset-name {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text);\n}\n\n.got-trading-chart__asset-leverage {\n  font-size: 1rem;\n  padding: 0.125rem 0.25rem;\n  background: var(--color-neon-red);\n  color: white;\n  border-radius: 2px;\n}\n\n.got-trading-chart__timer {\n  display: flex;\n  align-items: baseline;\n  gap: 0.25rem;\n}\n\n.got-trading-chart__timer-value {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: var(--color-neon-green);\n  text-shadow: 0 0 8px var(--color-neon-green);\n}\n\n.got-trading-chart__timer-value--urgent {\n  color: var(--color-neon-red);\n  text-shadow: 0 0 8px var(--color-neon-red);\n  animation: got-pulse 0.5s ease-in-out infinite;\n}\n\n.got-trading-chart__timer-label {\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n}\n\n.got-trading-chart__price-display {\n  display: flex;\n  align-items: baseline;\n  gap: 0.5rem;\n  margin-bottom: 0.25rem;\n}\n\n.got-trading-chart__current-price {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n}\n\n.got-trading-chart__price-change {\n  font-size: 0.875rem;\n}\n\n.got-trading-chart__container {\n  position: relative;\n  height: 300px;\n}\n\n.got-trading-chart__canvas {\n  width: 100%;\n  height: 100%;\n}\n\n.got-trading-chart__markers {\n  position: absolute;\n  bottom: 60px;\n  left: 10px;\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n  pointer-events: none;\n}\n\n.got-trading-chart__marker {\n  display: flex;\n  align-items: center;\n  gap: 0.375rem;\n  padding: 0.25rem 0.5rem;\n  background: rgba(0, 0, 0, 0.7);\n  border-radius: 2px;\n  font-size: 1rem;\n}\n\n.got-trading-chart__marker--long .got-trading-chart__marker-icon {\n  color: var(--color-neon-green);\n}\n\n.got-trading-chart__marker--short .got-trading-chart__marker-icon {\n  color: var(--color-neon-red);\n}\n\n.got-trading-chart__marker-pnl--profit {\n  color: var(--color-neon-green);\n}\n\n.got-trading-chart__marker-pnl--loss {\n  color: var(--color-neon-red);\n}\n\n/* Open Positions Overlay */\n.got-trading-chart__positions-overlay {\n  position: absolute;\n  bottom: 8px;\n  right: 8px;\n  display: flex;\n  flex-direction: column;\n  align-items: flex-end;\n  gap: 2px;\n  z-index: 10;\n}\n\n.got-trading-chart__position {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  padding: 0.125rem 0.25rem;\n  background: rgba(0, 0, 0, 0.75);\n  border-radius: 3px;\n  font-size: 0.875rem;\n  backdrop-filter: blur(4px);\n  border-left: 2px solid;\n}\n\n.got-trading-chart__position--long {\n  border-left-color: var(--color-neon-green);\n}\n\n.got-trading-chart__position--short {\n  border-left-color: var(--color-neon-red);\n}\n\n.got-trading-chart__position-side {\n  font-weight: bold;\n}\n\n.got-trading-chart__position--long .got-trading-chart__position-side {\n  color: var(--color-neon-green);\n}\n\n.got-trading-chart__position--short .got-trading-chart__position-side {\n  color: var(--color-neon-red);\n}\n\n.got-trading-chart__position-entry {\n  color: var(--color-text-dim);\n  font-size: 0.5625rem;\n}\n\n.got-trading-chart__position-pnl {\n  font-weight: bold;\n  min-width: 55px;\n  text-align: right;\n}\n\n.got-trading-chart__position-pnl--profit {\n  color: var(--color-neon-green);\n}\n\n.got-trading-chart__position-pnl--loss {\n  color: var(--color-neon-red);\n}\n\n.got-trading-chart__position-close {\n  padding: 0.125rem 0.25rem;\n  margin-right: 0.25rem;\n  border: none;\n  border-radius: 2px;\n  background: rgba(255, 59, 59, 0.2);\n  color: var(--color-neon-red);\n  font-size: 1rem;\n  font-weight: bold;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: all 0.1s ease;\n  white-space: nowrap;\n  text-transform: uppercase;\n}\n\n.got-trading-chart__position-close:hover:not(:disabled) {\n  background: rgba(255, 59, 59, 0.5);\n  color: #fff;\n}\n\n.got-trading-chart__position-close:disabled {\n  opacity: 0.3;\n  cursor: not-allowed;\n}\n\n.got-trading-chart__last-trade {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding-top: 0.5rem;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n  font-size: 1rem;\n}\n\n.got-trading-chart__last-trade-label {\n  color: var(--color-text-dim);\n}\n\n.got-trading-chart__last-trade-info--long {\n  color: var(--color-neon-green);\n}\n\n.got-trading-chart__last-trade-info--short {\n  color: var(--color-neon-red);\n}\n\n.got-trading-chart__pnl--profit {\n  color: var(--color-neon-green);\n}\n\n.got-trading-chart__pnl--loss {\n  color: var(--color-neon-red);\n}\n\n/* Trading Controls */\n.got-trading-controls {\n  position: relative;\n  background: rgba(0, 0, 0, 0.4);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 0.75rem;\n}\n\n.got-trading-controls--liquidated {\n  opacity: 0.5;\n  pointer-events: none;\n}\n\n.got-trading-controls__liquidated-overlay {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  background: rgba(0, 0, 0, 0.8);\n  border-radius: 2px;\n  z-index: 10;\n  pointer-events: auto;\n}\n\n.got-trading-controls__liquidated-icon {\n  font-size: 3rem;\n}\n\n.got-trading-controls__liquidated-text {\n  font-family: var(--font-pixel);\n  font-size: 1.5rem;\n  color: var(--color-neon-red);\n  text-shadow: 0 0 10px var(--color-neon-red);\n}\n\n.got-trading-controls__balance {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 0.5rem;\n  padding-bottom: 0.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-trading-controls__balance-label {\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n}\n\n.got-trading-controls__balance-value {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-gold);\n}\n\n.got-trading-controls__size {\n  margin-bottom: 0.5rem;\n}\n\n.got-trading-controls__size-label {\n  display: block;\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  margin-bottom: 0.25rem;\n}\n\n.got-trading-controls__size-options {\n  display: flex;\n  gap: 0.375rem;\n  margin-bottom: 0.375rem;\n}\n\n.got-trading-controls__size-btn {\n  flex: 1;\n  padding: 0.375rem;\n  font-size: 0.875rem;\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  color: var(--color-text-dim);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.got-trading-controls__size-btn:hover:not(:disabled) {\n  background: rgba(255, 255, 255, 0.1);\n}\n\n.got-trading-controls__size-btn--active {\n  background: var(--color-neon-cyan);\n  border-color: var(--color-neon-cyan);\n  color: black;\n}\n\n.got-trading-controls__size-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.got-trading-controls__size-info {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n}\n\n.got-trading-controls__action-buttons {\n  display: flex;\n  gap: 0.375rem;\n  margin-bottom: 0.5rem;\n}\n\n.got-trading-controls__btn {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.125rem;\n  padding: 0.5rem;\n  border: none;\n  border-radius: 2px;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.got-trading-controls__btn--long {\n  background: linear-gradient(180deg, var(--color-neon-green) 0%, #1a8a0e 100%);\n  color: white;\n}\n\n.got-trading-controls__btn--short {\n  background: linear-gradient(180deg, var(--color-neon-red) 0%, #8a1a1a 100%);\n  color: white;\n}\n\n.got-trading-controls__btn--close {\n  background: linear-gradient(180deg, #666 0%, #333 100%);\n  color: white;\n}\n\n.got-trading-controls__btn--close:not(:disabled) {\n  background: linear-gradient(180deg, var(--color-neon-orange) 0%, #8a4a1a 100%);\n}\n\n.got-trading-controls__btn:hover:not(:disabled) {\n  transform: translateY(-2px);\n  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);\n}\n\n.got-trading-controls__btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n  transform: none;\n}\n\n.got-trading-controls__btn-icon {\n  font-size: 1rem;\n}\n\n.got-trading-controls__btn-text {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n}\n\n.got-trading-controls__positions {\n  margin-bottom: 0.5rem;\n  padding: 0.5rem;\n  background: rgba(255, 255, 255, 0.03);\n  border-radius: 2px;\n}\n\n.got-trading-controls__positions-title {\n  display: block;\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  margin-bottom: 0.25rem;\n}\n\n.got-trading-controls__position {\n  display: flex;\n  align-items: center;\n  gap: 0.375rem;\n  padding: 0.375rem;\n  background: rgba(0, 0, 0, 0.3);\n  border-radius: 2px;\n  margin-bottom: 0.25rem;\n}\n\n.got-trading-controls__position:last-child {\n  margin-bottom: 0;\n}\n\n.got-trading-controls__position--long {\n  border-left: 3px solid var(--color-neon-green);\n}\n\n.got-trading-controls__position--short {\n  border-left: 3px solid var(--color-neon-red);\n}\n\n.got-trading-controls__position-info {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 0.125rem;\n}\n\n.got-trading-controls__position-side {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n}\n\n.got-trading-controls__position--long .got-trading-controls__position-side {\n  color: var(--color-neon-green);\n}\n\n.got-trading-controls__position--short .got-trading-controls__position-side {\n  color: var(--color-neon-red);\n}\n\n.got-trading-controls__position-size {\n  font-size: 1rem;\n  color: var(--color-text);\n}\n\n.got-trading-controls__position-entry {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n}\n\n.got-trading-controls__position-pnl {\n  text-align: right;\n}\n\n.got-trading-controls__pnl-value {\n  font-size: 1rem;\n}\n\n.got-trading-controls__pnl-value--profit {\n  color: var(--color-neon-green);\n}\n\n.got-trading-controls__pnl-value--loss {\n  color: var(--color-neon-red);\n}\n\n.got-trading-controls__position-close-btn {\n  width: 20px;\n  height: 20px;\n  padding: 0;\n  border: none;\n  border-radius: 3px;\n  background: rgba(255, 255, 255, 0.1);\n  color: var(--color-text-dim);\n  font-size: 0.875rem;\n  font-weight: bold;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: all 0.15s ease;\n  flex-shrink: 0;\n}\n\n.got-trading-controls__position-close-btn:hover:not(:disabled) {\n  background: rgba(255, 59, 59, 0.3);\n  color: var(--color-neon-red);\n}\n\n.got-trading-controls__position-close-btn:disabled {\n  opacity: 0.3;\n  cursor: not-allowed;\n}\n\n.got-trading-controls__realized {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding-top: 0.5rem;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-trading-controls__realized-label {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n}\n\n.got-trading-controls__realized-value {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n}\n\n.got-trading-controls__realized-value--profit {\n  color: var(--color-neon-green);\n}\n\n.got-trading-controls__realized-value--loss {\n  color: var(--color-neon-red);\n}\n\n.got-trading-controls__realized-percent {\n  font-size: 1rem;\n  margin-left: 0.25rem;\n}\n\n.got-trading-controls__warning {\n  margin-top: 0.5rem;\n  padding: 0.375rem;\n  background: rgba(255, 200, 0, 0.1);\n  border: 1px solid rgba(255, 200, 0, 0.3);\n  border-radius: 2px;\n  font-size: 1rem;\n  color: var(--color-neon-gold);\n  text-align: center;\n}\n\n/* Live Scoreboard */\n.got-scoreboard {\n  background: rgba(0, 0, 0, 0.4);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 0.75rem;\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  min-height: 0;\n}\n\n.got-scoreboard__info {\n  display: flex;\n  flex-direction: column;\n  gap: 0.375rem;\n  margin-bottom: 0.75rem;\n  padding-bottom: 0.75rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-scoreboard__tier {\n  text-align: center;\n}\n\n.got-scoreboard__tier-name {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--tier-color);\n  text-transform: uppercase;\n  text-shadow: 0 0 8px var(--tier-color);\n}\n\n.got-scoreboard__prize,\n.got-scoreboard__players-count {\n  display: flex;\n  justify-content: space-between;\n  font-size: 1rem;\n}\n\n.got-scoreboard__prize-label,\n.got-scoreboard__players-label {\n  color: var(--color-text-dim);\n}\n\n.got-scoreboard__prize-value {\n  color: var(--color-neon-green);\n}\n\n.got-scoreboard__rankings {\n  margin-bottom: 0.5rem;\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  min-height: 0;\n  overflow: hidden;\n}\n\n.got-scoreboard__rankings-title {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 0.375rem 0;\n}\n\n.got-scoreboard__rankings-header {\n  display: grid;\n  grid-template-columns: 24px 1fr 80px;\n  gap: 0.375rem;\n  padding: 0.25rem 0;\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-scoreboard__rankings-list {\n  flex: 1;\n  overflow-y: auto;\n  min-height: 0;\n}\n\n.got-scoreboard__player {\n  display: grid;\n  grid-template-columns: 24px 1fr 80px;\n  gap: 0.375rem;\n  padding: 0.25rem 0;\n  align-items: center;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.got-scoreboard__player--you {\n  background: rgba(0, 255, 136, 0.1);\n  margin: 0 -0.5rem;\n  padding-left: 0.5rem;\n  padding-right: 0.5rem;\n  border-radius: 2px;\n}\n\n.got-scoreboard__player--top3 {\n  font-weight: bold;\n}\n\n.got-scoreboard__player--liquidated {\n  opacity: 0.5;\n}\n\n.got-scoreboard__col-rank {\n  font-size: 0.875rem;\n}\n\n.got-scoreboard__col-player {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  font-size: 1rem;\n  overflow: hidden;\n}\n\n.got-scoreboard__liquidated-tag {\n  font-size: 1rem;\n}\n\n.got-scoreboard__col-pnl {\n  text-align: right;\n  font-size: 1rem;\n}\n\n.got-scoreboard__col-pnl--profit {\n  color: var(--color-neon-green);\n}\n\n.got-scoreboard__col-pnl--loss {\n  color: var(--color-neon-red);\n}\n\n.got-scoreboard__col-pnl--inactive {\n  color: var(--color-text-dim);\n}\n\n.got-scoreboard__payouts {\n  padding-top: 0.75rem;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-scoreboard__payouts-title {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  margin: 0 0 0.5rem 0;\n  text-transform: uppercase;\n}\n\n.got-scoreboard__payout-row {\n  display: flex;\n  justify-content: space-between;\n  font-size: 0.875rem;\n  padding: 0.125rem 0;\n  color: var(--color-text-dim);\n}\n\n.got-scoreboard__payout-row--fee {\n  opacity: 0.6;\n}\n\n/* Trade History */\n.got-trade-history {\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n  padding: 0.5rem;\n}\n\n.got-trade-history--empty {\n  text-align: center;\n  padding: 1rem;\n}\n\n.got-trade-history__empty-text {\n  font-size: 1rem;\n  color: var(--color-text-dim);\n}\n\n.got-trade-history__header {\n  display: grid;\n  grid-template-columns: 70px 60px 80px 1fr 80px;\n  gap: 0.5rem;\n  padding: 0.25rem 0.5rem;\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-trade-history__list {\n  max-height: 100px;\n  overflow-y: auto;\n}\n\n.got-trade-history__row {\n  display: grid;\n  grid-template-columns: 70px 60px 80px 1fr 80px;\n  gap: 0.5rem;\n  padding: 0.25rem 0.5rem;\n  font-size: 0.875rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n  align-items: center;\n}\n\n.got-trade-history__col-time {\n  color: var(--color-text-dim);\n}\n\n.got-trade-history__col-type {\n  text-align: center;\n}\n\n.got-trade-history__col-side {\n  text-align: center;\n}\n\n.got-trade-history__col-price {\n  text-align: right;\n}\n\n.got-trade-history__col-pnl {\n  text-align: right;\n}\n\n.got-trade-history__type--open {\n  color: var(--color-neon-cyan);\n}\n\n.got-trade-history__type--close {\n  color: var(--color-neon-gold);\n}\n\n.got-trade-history__side--long {\n  color: var(--color-neon-green);\n}\n\n.got-trade-history__side--short {\n  color: var(--color-neon-red);\n}\n\n.got-trade-history__pnl--profit {\n  color: var(--color-neon-green);\n}\n\n.got-trade-history__pnl--loss {\n  color: var(--color-neon-red);\n}\n\n/* Round Summary */\n.got-round-summary {\n  padding: 1.5rem;\n  max-width: 600px;\n  margin: 0 auto;\n  text-align: center;\n}\n\n.got-round-summary__header {\n  margin-bottom: 0.75rem;\n}\n\n.got-round-summary__title {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: var(--color-neon-green);\n  margin: 0 0 0.25rem 0;\n  text-shadow: 0 0 15px var(--color-neon-green);\n}\n\n.got-round-summary__tier {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--tier-color);\n  text-shadow: 0 0 8px var(--tier-color);\n}\n\n.got-round-summary__prize {\n  margin-bottom: 1rem;\n}\n\n.got-round-summary__prize-label {\n  display: block;\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  margin-bottom: 0.25rem;\n}\n\n.got-round-summary__prize-value {\n  font-family: var(--font-pixel);\n  font-size: 1.25rem;\n  color: var(--color-neon-green);\n  text-shadow: 0 0 10px var(--color-neon-green);\n}\n\n.got-round-summary__prize-fee {\n  display: block;\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  margin-top: 0.25rem;\n}\n\n.got-round-summary__podium {\n  margin-bottom: 1rem;\n}\n\n.got-round-summary__podium-title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 1rem 0;\n}\n\n.got-round-summary__winners {\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n}\n\n.got-round-summary__no-winners {\n  color: var(--color-text-dim);\n  padding: 1rem;\n}\n\n.got-round-summary__winner {\n  display: flex;\n  align-items: center;\n  flex-wrap: wrap;\n  gap: 0.5rem 0.75rem;\n  padding: 0.75rem;\n  background: rgba(0, 0, 0, 0.3);\n  border-radius: 2px;\n  text-align: left;\n  overflow: hidden;\n}\n\n.got-round-summary__winner--1 {\n  background: linear-gradient(90deg, rgba(255, 215, 0, 0.2) 0%, transparent 100%);\n  border: 1px solid rgba(255, 215, 0, 0.3);\n}\n\n.got-round-summary__winner--2 {\n  background: linear-gradient(90deg, rgba(192, 192, 192, 0.2) 0%, transparent 100%);\n  border: 1px solid rgba(192, 192, 192, 0.3);\n}\n\n.got-round-summary__winner--3 {\n  background: linear-gradient(90deg, rgba(205, 127, 50, 0.2) 0%, transparent 100%);\n  border: 1px solid rgba(205, 127, 50, 0.3);\n}\n\n.got-round-summary__winner--you {\n  box-shadow: 0 0 15px rgba(0, 255, 136, 0.3);\n}\n\n.got-round-summary__winner-medal {\n  font-size: 1.5rem;\n}\n\n.got-round-summary__winner-place {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  min-width: 60px;\n}\n\n.got-round-summary__winner-player {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.got-round-summary__you-tag {\n  font-size: 1rem;\n  color: var(--color-neon-green);\n}\n\n.got-round-summary__winner-pnl {\n  font-size: 1rem;\n}\n\n.got-round-summary__pnl--profit {\n  color: var(--color-neon-green);\n}\n\n.got-round-summary__pnl--loss {\n  color: var(--color-neon-red);\n}\n\n.got-round-summary__winner-payout {\n  flex-shrink: 0;\n  text-align: right;\n}\n\n.got-round-summary__payout-value {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-green);\n  white-space: nowrap;\n}\n\n.got-round-summary__your-result {\n  margin-bottom: 1rem;\n  padding: 1rem;\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 2px;\n}\n\n.got-round-summary__your-result--winner {\n  border-color: var(--color-neon-green);\n  box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);\n}\n\n.got-round-summary__your-result-title {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 0.75rem 0;\n}\n\n.got-round-summary__your-result-inactive {\n  color: var(--color-text-dim);\n  font-size: 0.875rem;\n}\n\n.got-round-summary__your-result-stats {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 0.75rem;\n  text-align: left;\n}\n\n.got-round-summary__stat {\n  display: flex;\n  flex-direction: column;\n  gap: 0.125rem;\n}\n\n.got-round-summary__stat-label {\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n}\n\n.got-round-summary__stat-value {\n  font-size: 0.875rem;\n  color: var(--color-text);\n}\n\n.got-round-summary__stat-value--gold {\n  color: #ffd700;\n  text-shadow: 0 0 8px rgba(255, 215, 0, 0.5);\n}\n\n.got-round-summary__stat-value--silver {\n  color: #c0c0c0;\n  text-shadow: 0 0 8px rgba(192, 192, 192, 0.5);\n}\n\n.got-round-summary__stat-value--bronze {\n  color: #cd7f32;\n  text-shadow: 0 0 8px rgba(205, 127, 50, 0.5);\n}\n\n.got-round-summary__stat-percent {\n  font-size: 1rem;\n  margin-left: 0.25rem;\n}\n\n.got-round-summary__usd {\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  margin-left: 0.25rem;\n}\n\n.got-round-summary__stat--payout .got-round-summary__stat-value {\n  color: var(--color-neon-green);\n}\n\n.got-round-summary__payout-highlight {\n  font-family: var(--font-pixel);\n  color: var(--color-neon-green);\n  text-shadow: 0 0 8px var(--color-neon-green);\n}\n\n.got-round-summary__full-rankings {\n  margin-bottom: 1.5rem;\n  text-align: left;\n}\n\n.got-round-summary__rankings-title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  margin: 0 0 0.5rem 0;\n}\n\n.got-round-summary__rankings-header {\n  display: grid;\n  grid-template-columns: 40px 1fr 80px 60px;\n  gap: 0.5rem;\n  padding: 0.25rem 0;\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  text-transform: uppercase;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-round-summary__rankings-list {\n  max-height: 200px;\n  overflow-y: auto;\n}\n\n.got-round-summary__no-rankings {\n  text-align: center;\n  padding: 1rem;\n  color: var(--color-text-dim);\n  font-size: 0.875rem;\n}\n\n.got-round-summary__ranking-row {\n  display: grid;\n  grid-template-columns: 40px 1fr 80px 60px;\n  gap: 0.5rem;\n  padding: 0.375rem 0;\n  font-size: 1rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n  align-items: center;\n}\n\n.got-round-summary__ranking-row--you {\n  background: rgba(0, 255, 136, 0.1);\n  margin: 0 -0.5rem;\n  padding-left: 0.5rem;\n  padding-right: 0.5rem;\n  border-radius: 2px;\n}\n\n.got-round-summary__col-rank {\n  font-size: 0.875rem;\n}\n\n.got-round-summary__col-player {\n  display: flex;\n  align-items: center;\n  gap: 0.25rem;\n  overflow: hidden;\n}\n\n.got-round-summary__col-pnl {\n  text-align: right;\n}\n\n.got-round-summary__col-trades {\n  text-align: right;\n  color: var(--color-text-dim);\n}\n\n.got-round-summary__back-btn {\n  width: 100%;\n  max-width: 300px;\n  padding: 1rem;\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  background: rgba(255, 255, 255, 0.1);\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  border-radius: 2px;\n  color: var(--color-text);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.got-round-summary__back-btn:hover {\n  background: rgba(255, 255, 255, 0.15);\n  transform: translateY(-2px);\n}\n\n/* Sidebar */\n.got-sidebar {\n  padding: 0;\n}\n\n.got-sidebar__title {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-neon-cyan);\n  margin: 0 0 1rem 0;\n}\n\n.got-sidebar__info {\n  margin-bottom: 1rem;\n}\n\n.got-sidebar__row {\n  display: flex;\n  justify-content: space-between;\n  padding: 0.375rem 0;\n  font-size: 0.875rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.got-sidebar__tier {\n  text-transform: capitalize;\n}\n\n.got-sidebar__pool {\n  color: var(--color-neon-green);\n}\n\n.got-sidebar__rules {\n  margin-bottom: 1rem;\n  padding-top: 0.75rem;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-sidebar__rules h4 {\n  font-family: var(--font-pixel);\n  font-size: 1rem;\n  color: var(--color-text-dim);\n  margin: 0 0 0.5rem 0;\n}\n\n.got-sidebar__payout-row {\n  display: flex;\n  justify-content: space-between;\n  font-size: 1rem;\n  padding: 0.125rem 0;\n  color: var(--color-text-dim);\n}\n\n.got-sidebar__payout-row--fee {\n  opacity: 0.6;\n}\n\n.got-sidebar__fairness {\n  padding-top: 0.75rem;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.got-sidebar__fairness-title {\n  font-family: var(--font-pixel);\n  font-size: 0.875rem;\n  color: var(--color-text-dim);\n  margin: 0 0 0.5rem 0;\n  text-transform: uppercase;\n}\n\n.got-sidebar__fairness-row {\n  display: flex;\n  justify-content: space-between;\n  font-size: 0.875rem;\n  padding: 0.125rem 0;\n  color: var(--color-text-dim);\n}\n\n.got-sidebar__hash {\n  font-family: monospace;\n  color: var(--color-text);\n}\n\n/* Responsive */\n@media (max-width: 1024px) {\n  .got-trading-view {\n    grid-template-columns: 1fr;\n    min-height: auto;\n  }\n\n  .got-trading-view__sidebar {\n    order: -1;\n    min-height: auto;\n  }\n\n  .got-scoreboard__rankings-list {\n    max-height: 200px;\n  }\n}\n\n@media (max-width: 768px) {\n  .got-tier-lobby__grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 640px) {\n  .got-game-lobby {\n    padding: 1rem;\n  }\n\n  .got-round-summary {\n    padding: 1rem;\n  }\n\n  .got-round-summary__your-result-stats {\n    grid-template-columns: 1fr;\n  }\n\n  .got-trade-history__header,\n  .got-trade-history__row {\n    grid-template-columns: 60px 45px 60px 75px 60px;\n    font-size: 1rem;\n  }\n}\n\n\n/* ============================================================\n   TAUNT TEMPLATE - New Layout Components\n   ============================================================ */\n\n/* ── TICKER ── */\n.ticker {\n  height: var(--tick-h);\n  background: rgba(4,4,10,0.99);\n  border-bottom: 1px solid var(--color-border);\n  display: flex;\n  align-items: center;\n  overflow: hidden;\n}\n.tick-badge {\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  gap: 7px;\n  padding: 0 18px;\n  height: 100%;\n  border-right: 1px solid var(--color-border);\n  font-size: 8px;\n  letter-spacing: 0.25em;\n  text-transform: uppercase;\n  color: var(--color-green);\n  background: rgba(0,230,118,0.03);\n}\n.pdot {\n  width: 5px;\n  height: 5px;\n  background: var(--color-green);\n  border-radius: 50%;\n  animation: pdotP 1.6s ease-in-out infinite;\n}\n@keyframes pdotP {\n  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(0,230,118,0.5); }\n  50% { opacity: 0.4; box-shadow: 0 0 0 5px transparent; }\n}\n.tick-scroll { flex: 1; overflow: hidden; }\n.tick-track {\n  display: flex;\n  width: max-content;\n  animation: tScroll 58s linear infinite;\n}\n.tick-track:hover { animation-play-state: paused; }\n@keyframes tScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }\n.tick {\n  display: flex;\n  align-items: center;\n  gap: 9px;\n  padding: 0 26px;\n  height: 32px;\n  font-size: 10px;\n  color: var(--color-muted2);\n  letter-spacing: 0.03em;\n  white-space: nowrap;\n  border-right: 1px solid var(--color-border);\n}\n.tick b { color: var(--color-white); }\n.tw { color: var(--color-green); }\n.tl { color: var(--color-red); }\n.tq { color: var(--color-pink); font-style: italic; }\n.ts { color: var(--color-muted); }\n\n/* ── SIDEBAR ── */\n.sidebar {\n  position: fixed;\n  top: var(--top-h);\n  left: 0;\n  bottom: 0;\n  width: var(--nav-w);\n  background: rgba(6,6,14,0.98);\n  backdrop-filter: blur(20px);\n  border-right: 1px solid var(--color-border);\n  z-index: 150;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  transition: width 0.3s cubic-bezier(0.4,0,0.2,1);\n}\nbody.nc .sidebar, .sidebar--collapsed { width: var(--nav-col); }\n\n.sb-top {\n  display: flex;\n  align-items: center;\n  justify-content: flex-end;\n  padding: 12px 14px;\n  border-bottom: 1px solid var(--color-border);\n  flex-shrink: 0;\n}\nbody.nc .sb-top, .sidebar--collapsed .sb-top { justify-content: center; }\n\n.tog-btn {\n  width: 30px;\n  height: 30px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(255,255,255,0.03);\n  border: 1px solid var(--color-border2);\n  cursor: pointer;\n  color: var(--color-muted2);\n  transition: all 0.2s;\n  flex-shrink: 0;\n}\n.tog-btn:hover { color: var(--color-white); background: rgba(255,255,255,0.06); }\n\n/* Raid sidebar */\n.raid-sidebar {\n  margin: 12px 12px 6px;\n  padding: 12px 14px;\n  background: rgba(255,31,142,0.04);\n  border: 1px solid rgba(255,31,142,0.12);\n  transition: all 0.2s;\n  overflow: hidden;\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n.raid-sidebar:hover { border-color: rgba(255,31,142,0.28); background: rgba(255,31,142,0.07); }\n\n.sb-body {\n  flex: 1;\n  overflow-y: auto;\n  overflow-x: hidden;\n  scrollbar-width: none;\n}\n.sb-body::-webkit-scrollbar { display: none; }\n\n.nv-sec { padding: 18px 0 8px; }\n.nv-sec + .nv-sec { border-top: 1px solid var(--color-border); }\n.nv-sec-lbl {\n  font-family: var(--font-body);\n  font-size: 8px;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: var(--color-muted);\n  padding: 0 18px 10px;\n  white-space: nowrap;\n  transition: opacity 0.2s;\n}\nbody.nc .nv-sec-lbl, .sidebar--collapsed .nv-sec-lbl { opacity: 0; }\n\n.nv-item {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  padding: 12px 18px;\n  cursor: pointer;\n  transition: background 0.15s;\n  position: relative;\n  white-space: nowrap;\n  overflow: hidden;\n  text-decoration: none;\n  color: inherit;\n}\n.nv-item::before {\n  content: '';\n  position: absolute;\n  left: 0;\n  top: 0;\n  bottom: 0;\n  width: 0;\n  background: var(--nc, var(--color-pink));\n  transition: width 0.15s;\n}\n.nv-item:hover::before, .nv-item.active::before { width: 2px; }\n.nv-item:hover { background: rgba(255,255,255,0.03); }\n.nv-item.active { background: rgba(255,255,255,0.04); }\n\n.nv-ico {\n  width: 22px;\n  height: 22px;\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--color-muted2);\n  transition: color 0.15s;\n}\n.nv-ico svg { width: 17px; height: 17px; }\n.nv-item:hover .nv-ico, .nv-item.active .nv-ico { color: var(--nc, var(--color-pink)); }\n\n.nv-lbl {\n  font-family: var(--font-condensed);\n  font-weight: 700;\n  font-size: 16px;\n  letter-spacing: 0.09em;\n  text-transform: uppercase;\n  color: var(--color-muted2);\n  transition: color 0.15s, opacity 0.22s;\n  white-space: nowrap;\n}\n.nv-item:hover .nv-lbl, .nv-item.active .nv-lbl { color: var(--color-white); }\nbody.nc .nv-lbl, .sidebar--collapsed .nv-lbl { opacity: 0; pointer-events: none; }\n\n.nv-bdg {\n  margin-left: auto;\n  font-family: var(--font-body);\n  font-size: 8px;\n  font-weight: 700;\n  padding: 2px 6px;\n  flex-shrink: 0;\n  transition: opacity 0.2s;\n  color: #000;\n}\n.nv-bdg.pk { background: var(--color-pink); }\n.nv-bdg.gr { background: var(--color-green); }\n.nv-bdg.yl { background: var(--color-yellow); }\nbody.nc .nv-bdg, .sidebar--collapsed .nv-bdg { opacity: 0; }\n\n.sb-foot {\n  padding: 14px;\n  border-top: 1px solid var(--color-border);\n  flex-shrink: 0;\n}\n.sf-user { display: flex; align-items: center; gap: 11px; overflow: hidden; }\n.sf-av {\n  width: 34px;\n  height: 34px;\n  border-radius: 3px;\n  background: linear-gradient(135deg, var(--color-pink), var(--color-blue));\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n  color: #fff;\n}\n.sf-av svg { width: 18px; height: 18px; }\n.sf-info { overflow: hidden; transition: opacity 0.22s; }\nbody.nc .sf-info, .sidebar--collapsed .sf-info { opacity: 0; }\n.sf-name {\n  font-family: var(--font-condensed);\n  font-size: 15px;\n  font-weight: 700;\n  letter-spacing: 0.07em;\n  color: var(--color-white);\n  white-space: nowrap;\n}\n\n/* ── PAGE HEADER ── */\n.page-hd {\n  padding: 32px 52px 24px;\n  border-bottom: 1px solid var(--color-border);\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 32px;\n}\n.pg-title {\n  font-family: var(--font-heading);\n  font-size: clamp(36px, 5vw, 56px);\n  line-height: 1;\n  letter-spacing: 0.03em;\n  color: var(--color-white);\n}\n.pg-title .pk { color: var(--color-pink); }\n.pg-sub {\n  font-size: 10px;\n  color: var(--color-muted2);\n  letter-spacing: 0.22em;\n  text-transform: uppercase;\n  margin-top: 6px;\n}\n.pg-tags { display: flex; flex-direction: column; align-items: flex-end; gap: 7px; padding-bottom: 6px; }\n.ptag {\n  font-family: var(--font-body);\n  font-size: 9px;\n  letter-spacing: 0.14em;\n  color: var(--color-muted2);\n  border: 1px solid var(--color-border2);\n  padding: 4px 13px;\n}\n.ptag.on {\n  color: var(--color-green);\n  border-color: rgba(0,230,118,0.22);\n  background: rgba(0,230,118,0.03);\n}\n\n/* ── GAME GRID ── */\n.game-grid {\n  padding: 44px 52px 64px;\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));\n  gap: 22px;\n}\n\n/* ── GAME CARD V2 ── */\n.gcard {\n  position: relative;\n  background: var(--color-card);\n  border: 1px solid var(--color-border);\n  overflow: hidden;\n  cursor: pointer;\n  transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s;\n  display: flex;\n  flex-direction: column;\n  min-height: 430px;\n  text-decoration: none;\n  color: inherit;\n}\n.gcard:hover {\n  transform: translateY(-7px) scale(1.01);\n  box-shadow: 0 40px 90px rgba(0,0,0,0.65), 0 0 0 1px var(--gc);\n}\n.gcard-accent { height: 3px; width: 100%; flex-shrink: 0; background: var(--gc); }\n.gcard::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(circle at 50% 0%, var(--gc), transparent 60%);\n  opacity: 0;\n  transition: opacity 0.3s;\n  pointer-events: none;\n}\n.gcard:hover::after { opacity: 0.055; }\n\n.gcard-live {\n  position: absolute;\n  top: 18px;\n  right: 18px;\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  font-size: 8px;\n  letter-spacing: 0.2em;\n  text-transform: uppercase;\n  color: var(--color-green);\n  z-index: 5;\n}\n.gcard-ldot {\n  width: 4px;\n  height: 4px;\n  border-radius: 50%;\n  background: var(--color-green);\n  animation: pdotP 1.6s ease-in-out infinite;\n}\n\n.gcard-vis {\n  flex: 0 0 210px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  position: relative;\n  overflow: hidden;\n}\n.gcard-bg {\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(circle at 50% 45%, var(--gc), transparent 65%);\n  opacity: 0.055;\n  transition: opacity 0.3s;\n}\n.gcard:hover .gcard-bg { opacity: 0.12; }\n.gcard-ico { position: relative; z-index: 2; width: 135px; height: 135px; }\n\n.gcard-info {\n  flex: 1;\n  padding: 22px 26px 26px;\n  border-top: 1px solid var(--color-border);\n  display: flex;\n  flex-direction: column;\n  gap: 15px;\n}\n.gcard-hd { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }\n.gcard-name {\n  font-family: var(--font-heading);\n  font-size: 38px;\n  letter-spacing: 0.06em;\n  line-height: 0.95;\n  color: var(--gc);\n}\n.gcard-sub2 {\n  font-size: 9px;\n  color: var(--color-muted2);\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  margin-top: 5px;\n}\n.gcard-mode {\n  font-size: 8px;\n  letter-spacing: 0.16em;\n  text-transform: uppercase;\n  padding: 3px 9px;\n  border: 1px solid var(--color-border2);\n  color: var(--color-muted2);\n  flex-shrink: 0;\n  margin-top: 5px;\n}\n.gcard-line {\n  font-size: 11px;\n  color: var(--color-muted2);\n  line-height: 1.7;\n  letter-spacing: 0.02em;\n}\n.gcard-stats { display: flex; gap: 2px; }\n.gstat 