{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ChfmLrrWoQrmwjU4BZ79Q4","type":"tool_result","content":"   218→export async function fetchAllOpenMatches(\n   219→  connection: Connection\n   220→): Promise<UIMatch[]> {\n   221→  const program = getCoinflipProgram(connection);\n   222→  const accounts = await program.account.coinflipMatch.all([\n   223→    { dataSize: program.account.coinflipMatch.size },\n   224→  ]);\n   225→\n   226→  return accounts\n   227→    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n   228→    .map((acc) =>\n   229→      onChainMatchToUI(\n   230→        acc.publicKey,\n   231→        acc.account as unknown as OnChainMatch\n   232→      )\n   233→    );\n   234→}\n   235→\n   236→/**\n   237→ * Fetch all matches where playerPubkey is creator OR opponent,\n   238→ * phase is non-terminal (not refunded/settled with PDA closed).\n   239→ * Uses memcmp filters for efficient on-chain filtering.\n   240→ *\n   241→ * Account layout offsets (after 8-byte discriminator):\n   242→ *   creator:  8   (32 bytes)\n   243→ *   opponent: 40  (32 bytes)\n   244→ */\n   245→export async function fetchClaimableMatches(\n   246→  connection: Connection,\n   247→  playerPubkey: PublicKey\n   248→): Promise<UIMatch[]> {\n   249→  const program = getCoinflipProgram(connection);\n   250→  const playerBase58 = playerPubkey.toBase58();\n   251→\n   252→  const [asCreator, asOpponent] = await Promise.all([\n   253→    program.account.coinflipMatch.all([\n   254→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   255→      { dataSize: program.account.coinflipMatch.size },\n   256→    ]),\n   257→    program.account.coinflipMatch.all([\n   258→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   259→      { dataSize: program.account.coinflipMatch.size },\n   260→    ]),\n   261→  ]);\n   262→\n   263→  // Merge and deduplicate by public key\n   264→  const seen = new Set<string>();\n   265→  const matches: UIMatch[] = [];\n   266→\n   267→  for (const acc of [...asCreator, ...asOpponent]) {\n   268→    const key = acc.publicKey.toBase58();\n   269→    if (seen.has(key)) continue;\n   270→    seen.add(key);\n   271→\n   272→    const data = acc.account as unknown as OnChainMatch;\n   273→    // Skip terminal phases\n   274→    if (data.phase === PHASE_REFUNDED || data.phase === PHASE_SETTLED) continue;\n   275→\n   276→    matches.push(onChainMatchToUI(acc.publicKey, data));\n   277→  }\n   278→\n   279→  return matches;\n   280→}\n   281→\n   282→/**\n   283→ * Find all active (non-terminal) matches for a creator using memcmp filters.\n   284→ * Returns all matches, not just the first one (supports multiple concurrent matches).\n   285→ */\n   286→export async function fetchMatchesByCreator(\n   287→  connection: Connection,\n   288→  creator: PublicKey\n   289→): Promise<UIMatch[]> {\n   290→  const program = getCoinflipProgram(connection);\n   291→\n   292→  const matches = await program.account.coinflipMatch.all([\n   293→    { memcmp: { offset: 8, bytes: creator.toBase58() } },\n   294→    { dataSize: program.account.coinflipMatch.size },\n   295→  ]);\n   296→\n   297→  return matches"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"0c55397f-34b1-434f-adfd-e8a566e4e750","timestamp":"2026-03-19T19:01:45.043Z"}
