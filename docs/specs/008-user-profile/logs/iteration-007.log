}\n   103→    },\n   104→    [game],\n   105→  );\n   106→\n   107→  useEffect(() => {\n   108→    setLoading(true);\n   109→    setTransactions([]);\n   110→    setNextCursor(null);\n   111→    fetchPage();\n   112→    return () => abortRef.current?.abort();\n   113→  }, [fetchPage]);\n   114→\n   115→  const loadMore = useCallback(() => {\n   116→    if (!nextCursor || loadingMore) return;\n   117→    setLoadingMore(true);\n   118→    fetchPage(nextCursor);\n   119→  }, [nextCursor, loadingMore, fetchPage]);\n   120→\n   121→  return { transactions, loading, loadingMore, error, nextCursor, loadMore };\n   122→}\n   123→"}]},"parent_tool_use_id":null,"session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"a0bbc2ce-b52f-4af0-b1c5-6279a121cc0b","timestamp":"2026-03-19T19:07:32.681Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/hooks/useTransactions.ts","content":"/**\n * useTransactions — fetches transaction history from the real API.\n *\n * Uses JWT auth (from auth-store) and cursor-based pagination.\n */\n\nimport { useState, useCallback, useEffect, useRef } from \"react\";\nimport { getAccessToken } from \"../../../lib/auth-store\";\nimport type { GameId, TransactionEvent } from \"../types\";\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\ninterface ApiTransaction {\n  id: string;\n  game: string;\n  matchId: string;\n  event: TransactionEvent;\n  amountLamports: string;\n  txSig: string | null;\n  createdAt: string;\n}\n\ninterface ApiResponse {\n  transactions: ApiTransaction[];\n  nextCursor: string | null;\n}\n\nexport interface Transaction {\n  id: string;\n  gameId: GameId;\n  matchId: string;\n  event: TransactionEvent;\n  amountLamports: string;\n  txSig: string | null;\n  createdAt: string;\n}\n\nexport function useTransactions(game?: string) {\n  const [transactions, setTransactions] = useState<Transaction[]>([]);\n  const [nextCursor, setNextCursor] = useState<string | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [loadingMore, setLoadingMore] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n  const abortRef = useRef<AbortController | null>(null);\n\n  const fetchPage = useCallback(\n    async (cursor?: string) => {\n      const token = getAccessToken();\n      if (!token) {\n        setTransactions([]);\n        setLoading(false);\n        return;\n      }\n\n      const params = new URLSearchParams();\n      if (cursor) params.set(\"cursor\", cursor);\n      if (game) params.set(\"game\", game);\n      params.set(\"limit\", \"20\");\n\n      // Abort any in-flight request\n      abortRef.current?.abort();\n      const controller = new AbortController();\n      abortRef.current = controller;\n\n      try {\n        const res = await fetch(\n          `${BACKEND_URL}/profile/transactions?${params.toString()}`,\n          {\n            headers: { Authorization: `Bearer ${token}` },\n            signal: controller.signal,\n          },\n        );\n        if (!res.ok) throw new Error(`HTTP ${res.status}`);\n        const data: ApiResponse = await res.json();\n\n        const mapped: Transaction[] = data.transactions.map((tx) => ({\n          id: tx.id,\n          gameId: tx.game as GameId,\n          matchId: tx.matchId,\n          event: tx.event,\n          amountLamports: tx.amountLamports,\n          txSig: tx.txSig,\n          createdAt: tx.createdAt,\n        }));\n\n        if (cursor) {\n          setTransactions((prev) => [...prev, ...mapped]);\n        } else {\n          setTransactions(mapped);\n        }\n        setNextCursor(data.nextCursor);\n        setError(null);\n      } catch (err) {\n        if (err instanceof DOMException && err.name === \"AbortError\") return;\n        setError(err instanceof Error ? err.message : \"Failed to fetch\");\n      } finally {\n        setLoading(false);\n        setLoadingMore(false);\n      }\n    },\n    [game],\n  );\n\n  useEffect(() => {\n    setLoading(true);\n    setTransactions([]);\n    setNextCursor(null);\n    fetchPage();\n    return () => abortRef.current?.abort();\n  }, [fetchPage]);\n\n  const loadMore = useCallback(() => {\n    if (!nextCursor || loadingMore) return;\n    setLoadingMore(true);\n    fetchPage(nextCursor);\n  }, [nextCursor, loadingMore, fetchPage]);\n\n  return { transactions, loading, loadingMore, error, nextCursor, loadMore };\n}\n","numLines":123,"startLine":1,"totalLines":123}}}
