{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011DAMa4fZjzf7T7iSo1uvaS","type":"tool_result","content":"     1→/**\n     2→ * Shared transaction error parser.\n     3→ *\n     4→ * Each game calls `createTransactionErrorParser` with its own game-specific\n     5→ * checks and a log label. The returned function runs game overrides first,\n     6→ * then falls through to the shared checks that are common across all games.\n     7→ */\n     8→\n     9→// ---------------------------------------------------------------------------\n    10→// Types\n    11→// ---------------------------------------------------------------------------\n    12→\n    13→/** A single error check: test the raw message, return a user-friendly string. */\n    14→export type ErrorCheck = (msg: string) => string | null;\n    15→\n    16→export interface TransactionErrorParserOptions {\n    17→  /** Short tag for console.error fallback, e.g. \"coinflip\", \"closecall\" */\n    18→  logLabel: string;\n    19→  /** Game-specific checks — run BEFORE shared checks so they take priority. */\n    20→  gameChecks?: ErrorCheck[];\n    21→}\n    22→\n    23→// ---------------------------------------------------------------------------\n    24→// Shared checks (appear in 2+ game files)\n    25→// ---------------------------------------------------------------------------\n    26→\n    27→const sharedChecks: ErrorCheck[] = [\n    28→  // Wallet not connected\n    29→  (msg) =>\n    30→    msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")\n    31→      ? \"Wallet not connected. Please connect your wallet first.\"\n    32→      : null,\n    33→\n    34→  // User rejected\n    35→  (msg) =>\n    36→    msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")\n    37→      ? \"Transaction cancelled by user.\"\n    38→      : null,\n    39→\n    40→  // Insufficient funds (Solana runtime error)\n    41→  (msg) =>\n    42→    msg.includes(\"insufficient lamports\") ||\n    43→    msg.includes(\"Insufficient funds\") ||\n    44→    msg.includes(\"0x1\")\n    45→      ? \"Insufficient balance. You need more SOL to complete this transaction.\"\n    46→      : null,\n    47→\n    48→  // Network / RPC errors\n    49→  (msg) =>\n    50→    msg.includes(\"Failed to fetch\") ||\n    51→    msg.includes(\"NetworkError\") ||\n    52→    msg.includes(\"ECONNREFUSED\")\n    53→      ? \"Network error. Please check your connection and try again.\"\n    54→      : null,\n    55→\n    56→  // Simulation / preflight failures\n    57→  (msg) =>\n    58→    msg.includes(\"Simulation failed\") ||\n    59→    msg.includes(\"Transaction simulation failed\") ||\n    60→    msg.includes(\"Transaction will fail\")\n    61→      ? \"Transaction simulation failed. The game state may have changed.\"\n    62→      : null,\n    63→\n    64→  // Blockhash expiry\n    65→  (msg) =>\n    66→    msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")\n    67→      ? \"Transaction expired. Please try again.\"\n    68→      : null,\n    69→\n    70→  // Wallet adapter unexpected error\n    71→  (msg) =>\n    72→    msg.includes(\"Unexpected error\")\n    73→      ? \"Wallet encountered an error sending the transaction. Please try again.\"\n    74→      : null,\n    75→];\n    76→\n    77→// ---------------------------------------------------------------------------\n    78→// Backend request error check (duck-typed — checks for `.status` property)\n    79→// Used by Coinflip and LordOfRngs; CloseCall doesn't use BackendRequestError.\n    80→// ---------------------------------------------------------------------------\n    81→\n    82→function checkBackendRequestError(err: unknown): string | null {\n    83→  if (\n    84→    typeof err === \"object\" &&\n    85→    err !== null &&\n    86→    \"status\" in err &&\n    87→    typeof (err as Record<string, unknown>).status === \"number\" &&\n    88→    \"message\" in err\n    89→  ) {\n    90→    const status = (err as { status: number }).status;\n    91→    const message = (err as { message: string }).message;\n    92→\n    93→    if (status === 401) {\n    94→      return \"Backend authentication failed. Please approve message signing and try again.\";\n    95→    }\n    96→    if (status === 409) {\n    97→      return \"Action failed due to a conflict — please retry.\";\n    98→    }\n    99→    if (status === 429) {\n   100→      return \"Too many attempts. Please wait a moment and try again.\";\n   101→    }\n   102→    return message;\n   103→  }\n   104→  return null;\n   105→}\n   106→\n   107→// ---------------------------------------------------------------------------\n   108→// Factory\n   109→// ---------------------------------------------------------------------------\n   110→\n   111→/**\n   112→ * Creates a transaction error parser with game-specific overrides.\n   113→ *\n   114→ * Game-specific checks run first, then shared checks. If nothing matches,\n   115→ * the raw error is logged under `[logLabel]` and a truncated fallback is\n   116→ * returned.\n   117→ */\n   118→export function createTransactionErrorParser(\n   119→  options: TransactionErrorParserOptions,\n   120→): (err: unknown) => string {\n   121→  const { logLabel, gameChecks = [] } = options;\n   122→\n   123→  return (err: unknown): string => {\n   124→    // 1. Duck-typed BackendRequestError check (before stringifying)\n   125→    const backendResult = checkBackendRequestError(err);\n   126→    if (backendResult !== null) return backendResult;\n   127→\n   128→    // 2. Stringify the error once\n   129→    const msg = err instanceof Error ? err.message : String(err);\n   130→\n   131→    // 3. Game-specific checks (run first — higher priority)\n   132→    for (const check of gameChecks) {\n   133→      const result = check(msg);\n   134→      if (result !== null) return result;\n   135→    }\n   136→\n   137→    // 4. Shared checks\n   138→    for (const check of sharedChecks) {\n   139→      const result = check(msg);\n   140→      if (result !== null) return result;\n   141→    }\n   142→\n   143→    // 5. Fallback — log full error, return truncated message\n   144→    console.error(`[${logLabel}] unhandled transaction error:`, err);\n   145→    return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n   146→  };\n   147→}\n   148→"}]},"parent_tool_use_id":"toolu_01LgqpdpARA17zoWCfBSBv32","session_id":"6352b9d5-eba7-498a-a945-ee2c953d2486","uuid":"6b2b519f-eb6a-4c81-9178-d4599eae6ba1","timestamp":"2026-03-19T19:01:57.024Z"}
