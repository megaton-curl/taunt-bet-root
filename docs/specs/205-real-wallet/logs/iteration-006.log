{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T5jcmUUAfcRqg6AjUrzoDY","type":"tool_result","content":"     1→import { ReactNode, lazy, Suspense } from \"react\";\n     2→import { ConnectionProvider } from \"@solana/wallet-adapter-react\";\n     3→import { MockWalletProvider } from \"./mock\";\n     4→\n     5→// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     6→const RealWalletProvider = lazy(() =>\n     7→  import(\"./real/RealWalletProvider\").then((m) => ({\n     8→    default: m.RealWalletProvider,\n     9→  })),\n    10→);\n    11→\n    12→// Re-export WalletContext from the shared context file\n    13→export { WalletContext } from \"./context\";\n    14→\n    15→const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    16→\n    17→function getRpcUrl(): string {\n    18→  const envUrl =\n    19→    typeof import.meta !== \"undefined\"\n    20→      ? import.meta.env?.VITE_RPC_URL\n    21→      : undefined;\n    22→  return envUrl || DEFAULT_RPC_URL;\n    23→}\n    24→\n    25→interface WalletProviderProps {\n    26→  children: ReactNode;\n    27→}\n    28→\n    29→function isMockMode(): boolean {\n    30→  const flag =\n    31→    typeof import.meta !== \"undefined\"\n    32→      ? import.meta.env?.VITE_MOCK_MODE\n    33→      : undefined;\n    34→  // Default to mock mode when unset or explicitly \"true\"\n    35→  return flag === undefined || flag === \"\" || flag === \"true\";\n    36→}\n    37→\n    38→/**\n    39→ * Unified WalletProvider.\n    40→ * Wraps both Mock and Real providers with a shared ConnectionProvider.\n    41→ */\n    42→export function WalletProvider({ children }: WalletProviderProps) {\n    43→  const endpoint = getRpcUrl();\n    44→\n    45→  const inner = isMockMode() ? (\n    46→    <MockWalletProvider>{children}</MockWalletProvider>\n    47→  ) : (\n    48→    <Suspense fallback={null}>\n    49→      <RealWalletProvider>{children}</RealWalletProvider>\n    50→    </Suspense>\n    51→  );\n    52→\n    53→  return <ConnectionProvider endpoint={endpoint}>{inner}</ConnectionProvider>;\n    54→}\n    55→"}]},"parent_tool_use_id":null,"session_id":"e148c6ae-d46e-4f5a-b974-9f3c7b2cbc1a","uuid":"fb1f5de8-7642-49c8-ad85-89b4f53858d3","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/WalletProvider.tsx","content":"import { ReactNode, lazy, Suspense } from \"react\";\nimport { ConnectionProvider } from \"@solana/wallet-adapter-react\";\nimport { MockWalletProvider } from \"./mock\";\n\n// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\nconst RealWalletProvider = lazy(() =>\n  import(\"./real/RealWalletProvider\").then((m) => ({\n    default: m.RealWalletProvider,\n  })),\n);\n\n// Re-export WalletContext from the shared context file\nexport { WalletContext } from \"./context\";\n\nconst DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n\nfunction getRpcUrl(): string {\n  const envUrl =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_RPC_URL\n      : undefined;\n  return envUrl || DEFAULT_RPC_URL;\n}\n\ninterface WalletProviderProps {\n  children: ReactNode;\n}\n\nfunction isMockMode(): boolean {\n  const flag =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_MOCK_MODE\n      : undefined;\n  // Default to mock mode when unset or explicitly \"true\"\n  return flag === undefined || flag === \"\" || flag === \"true\";\n}\n\n/**\n * Unified WalletProvider.\n * Wraps both Mock and Real providers with a shared ConnectionProvider.\n */\nexport function WalletProvider({ children }: WalletProviderProps) {\n  const endpoint = getRpcUrl();\n\n  const inner = isMockMode() ? (\n    <MockWalletProvider>{children}</MockWalletProvider>\n  ) : (\n    <Suspense fallback={null}>\n      <RealWalletProvider>{children}</RealWalletProvider>\n    </Suspense>\n  );\n\n  return <ConnectionProvider endpoint={endpoint}>{inner}</ConnectionProvider>;\n}\n","numLines":55,"startLine":1,"totalLines":55}}}
