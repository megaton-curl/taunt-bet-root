{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SPxia3LKckR4pgh1pzwbx1","type":"tool_result","content":"     1→import { ReactNode, useState, useCallback, useMemo, useEffect } from \"react\";\n     2→import {\n     3→  Connection,\n     4→  Keypair,\n     5→  Transaction,\n     6→  sendAndConfirmTransaction,\n     7→} from \"@solana/web3.js\";\n     8→import { WalletContext } from \"../context\";\n     9→import type { WalletContextValue } from \"../types\";\n    10→\n    11→const DEFAULT_RPC_URL = \"http://127.0.0.1:8899\";\n    12→\n    13→interface TestWalletProviderProps {\n    14→  children: ReactNode;\n    15→  /** Keypair to use for signing transactions */\n    16→  keypair: Keypair;\n    17→  /** RPC URL (defaults to localhost:8899) */\n    18→  rpcUrl?: string;\n    19→  /** Auto-connect on mount (default: true) */\n    20→  autoConnect?: boolean;\n    21→}\n    22→\n    23→/**\n    24→ * Test wallet provider that signs real transactions with an injected Keypair.\n    25→ * For E2E testing against local test-validator — no browser extension needed.\n    26→ */\n    27→export function TestWalletProvider({\n    28→  children,\n    29→  keypair,\n    30→  rpcUrl = DEFAULT_RPC_URL,\n    31→  autoConnect = true,\n    32→}: TestWalletProviderProps) {\n    33→  const [connected, setConnected] = useState(false);\n    34→  const [connecting, setConnecting] = useState(false);\n    35→\n    36→  const connection = useMemo(\n    37→    () => new Connection(rpcUrl, \"confirmed\"),\n    38→    [rpcUrl],\n    39→  );\n    40→\n    41→  const connect = useCallback(async () => {\n    42→    setConnecting(true);\n    43→    try {\n    44→      // Verify the keypair works by checking if the account exists\n    45→      await connection.getBalance(keypair.publicKey);\n    46→      setConnected(true);\n    47→    } finally {\n    48→      setConnecting(false);\n    49→    }\n    50→  }, [connection, keypair]);\n    51→\n    52→  const disconnect = useCallback(async () => {\n    53→    setConnected(false);\n    54→  }, []);\n    55→\n    56→  const sendTransaction = useCallback(\n    57→    async (transaction: Transaction): Promise<string> => {\n    58→      if (!connected) {\n    59→        throw new Error(\"Wallet not connected\");\n    60→      }\n    61→      transaction.feePayer = keypair.publicKey;\n    62→      const signature = await sendAndConfirmTransaction(\n    63→        connection,\n    64→        transaction,\n    65→        [keypair],\n    66→      );\n    67→      return signature;\n    68→    },\n    69→    [connected, keypair, connection],\n    70→  );\n    71→\n    72→  const signMessage = useCallback(\n    73→    async (_message: Uint8Array): Promise<Uint8Array> => {\n    74→      if (!connected) {\n    75→        throw new Error(\"Wallet not connected\");\n    76→      }\n    77→      // Return a deterministic signature from the keypair's secret key\n    78→      const sig = new Uint8Array(64);\n    79→      sig.set(keypair.secretKey.slice(0, 64));\n    80→      return sig;\n    81→    },\n    82→    [connected, keypair],\n    83→  );\n    84→\n    85→  // Auto-connect\n    86→  useEffect(() => {\n    87→    if (autoConnect && !connected && !connecting) {\n    88→      connect();\n    89→    }\n    90→  }, [autoConnect, connected, connecting, connect]);\n    91→\n    92→  const value: WalletContextValue = useMemo(\n    93→    () => ({\n    94→      connected,\n    95→      connecting,\n    96→      address: connected ? keypair.publicKey.toBase58() : null,\n    97→      publicKey: connected ? keypair.publicKey : null,\n    98→      connect,\n    99→      disconnect,\n   100→      sendTransaction,\n   101→      signMessage,\n   102→      isMock: false,\n   103→    }),\n   104→    [\n   105→      connected,\n   106→      connecting,\n   107→      keypair,\n   108→      connect,\n   109→      disconnect,\n   110→      sendTransaction,\n   111→      signMessage,\n   112→    ],\n   113→  );\n   114→\n   115→  return (\n   116→    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n   117→  );\n   118→}\n   119→"}]},"parent_tool_use_id":null,"session_id":"e148c6ae-d46e-4f5a-b974-9f3c7b2cbc1a","uuid":"cf9b52cb-9915-4797-b864-6f2489a3ce6d","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/test/TestWalletProvider.tsx","content":"import { ReactNode, useState, useCallback, useMemo, useEffect } from \"react\";\nimport {\n  Connection,\n  Keypair,\n  Transaction,\n  sendAndConfirmTransaction,\n} from \"@solana/web3.js\";\nimport { WalletContext } from \"../context\";\nimport type { WalletContextValue } from \"../types\";\n\nconst DEFAULT_RPC_URL = \"http://127.0.0.1:8899\";\n\ninterface TestWalletProviderProps {\n  children: ReactNode;\n  /** Keypair to use for signing transactions */\n  keypair: Keypair;\n  /** RPC URL (defaults to localhost:8899) */\n  rpcUrl?: string;\n  /** Auto-connect on mount (default: true) */\n  autoConnect?: boolean;\n}\n\n/**\n * Test wallet provider that signs real transactions with an injected Keypair.\n * For E2E testing against local test-validator — no browser extension needed.\n */\nexport function TestWalletProvider({\n  children,\n  keypair,\n  rpcUrl = DEFAULT_RPC_URL,\n  autoConnect = true,\n}: TestWalletProviderProps) {\n  const [connected, setConnected] = useState(false);\n  const [connecting, setConnecting] = useState(false);\n\n  const connection = useMemo(\n    () => new Connection(rpcUrl, \"confirmed\"),\n    [rpcUrl],\n  );\n\n  const connect = useCallback(async () => {\n    setConnecting(true);\n    try {\n      // Verify the keypair works by checking if the account exists\n      await connection.getBalance(keypair.publicKey);\n      setConnected(true);\n    } finally {\n      setConnecting(false);\n    }\n  }, [connection, keypair]);\n\n  const disconnect = useCallback(async () => {\n    setConnected(false);\n  }, []);\n\n  const sendTransaction = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      if (!connected) {\n        throw new Error(\"Wallet not connected\");\n      }\n      transaction.feePayer = keypair.publicKey;\n      const signature = await sendAndConfirmTransaction(\n        connection,\n        transaction,\n        [keypair],\n      );\n      return signature;\n    },\n    [connected, keypair, connection],\n  );\n\n  const signMessage = useCallback(\n    async (_message: Uint8Array): Promise<Uint8Array> => {\n      if (!connected) {\n        throw new Error(\"Wallet not connected\");\n      }\n      // Return a deterministic signature from the keypair's secret key\n      const sig = new Uint8Array(64);\n      sig.set(keypair.secretKey.slice(0, 64));\n      return sig;\n    },\n    [connected, keypair],\n  );\n\n  // Auto-connect\n  useEffect(() => {\n    if (autoConnect && !connected && !connecting) {\n      connect();\n    }\n  }, [autoConnect, connected, connecting, connect]);\n\n  const value: WalletContextValue = useMemo(\n    () => ({\n      connected,\n      connecting,\n      address: connected ? keypair.publicKey.toBase58() : null,\n      publicKey: connected ? keypair.publicKey : null,\n      connect,\n      disconnect,\n      sendTransaction,\n      signMessage,\n      isMock: false,\n    }),\n    [\n      connected,\n      connecting,\n      keypair,\n      connect,\n      disconnect,\n      sendTransaction,\n      signMessage,\n    ],\n  );\n\n  return (\n    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n  );\n}\n","numLines":119,"startLine":1,"totalLines":119}}}
