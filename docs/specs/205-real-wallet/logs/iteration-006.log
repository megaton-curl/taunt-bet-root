{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PyDSruD2WvgXsLZ8sz7a1N","type":"tool_result","content":"     1→import { PublicKey, Transaction } from \"@solana/web3.js\";\n     2→\n     3→export interface WalletState {\n     4→  connected: boolean;\n     5→  connecting: boolean;\n     6→  address: string | null;\n     7→  publicKey: PublicKey | null;\n     8→}\n     9→\n    10→export interface WalletContextValue extends WalletState {\n    11→  connect: () => Promise<void>;\n    12→  disconnect: () => Promise<void>;\n    13→  sendTransaction: (transaction: Transaction) => Promise<string>;\n    14→  signMessage: (message: Uint8Array) => Promise<Uint8Array>;\n    15→  /** True if using mock wallet */\n    16→  isMock?: boolean;\n    17→  /** Get mock balance in SOL (mock mode only) */\n    18→  getBalance?: () => number;\n    19→  /** Get mock balance in lamports (mock mode only) */\n    20→  getBalanceLamports?: () => number;\n    21→  /** Update mock balance (mock mode only) */\n    22→  updateBalance?: (deltaLamports: number) => void;\n    23→}\n    24→"}]},"parent_tool_use_id":null,"session_id":"e148c6ae-d46e-4f5a-b974-9f3c7b2cbc1a","uuid":"18b2a725-bea9-4a66-8e20-eedae0c414b8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/types.ts","content":"import { PublicKey, Transaction } from \"@solana/web3.js\";\n\nexport interface WalletState {\n  connected: boolean;\n  connecting: boolean;\n  address: string | null;\n  publicKey: PublicKey | null;\n}\n\nexport interface WalletContextValue extends WalletState {\n  connect: () => Promise<void>;\n  disconnect: () => Promise<void>;\n  sendTransaction: (transaction: Transaction) => Promise<string>;\n  signMessage: (message: Uint8Array) => Promise<Uint8Array>;\n  /** True if using mock wallet */\n  isMock?: boolean;\n  /** Get mock balance in SOL (mock mode only) */\n  getBalance?: () => number;\n  /** Get mock balance in lamports (mock mode only) */\n  getBalanceLamports?: () => number;\n  /** Update mock balance (mock mode only) */\n  updateBalance?: (deltaLamports: number) => void;\n}\n","numLines":24,"startLine":1,"totalLines":24}}}
