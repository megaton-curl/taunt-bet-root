{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E891CHcJxk7BQD4pchkqd6","type":"tool_result","content":"     1→import { ReactNode, useCallback, useMemo } from \"react\";\n     2→import { Transaction } from \"@solana/web3.js\";\n     3→import {\n     4→  ConnectionProvider,\n     5→  useConnection,\n     6→  useWallet as useAdapterWallet,\n     7→} from \"@solana/wallet-adapter-react\";\n     8→import {\n     9→  UnifiedWalletProvider,\n    10→  useUnifiedWalletContext,\n    11→} from \"@jup-ag/wallet-adapter\";\n    12→import { WalletContext } from \"../context\";\n    13→import type { WalletContextValue } from \"../types\";\n    14→\n    15→const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    16→\n    17→function getRpcUrl(): string {\n    18→  const envUrl =\n    19→    typeof import.meta !== \"undefined\" ? import.meta.env?.VITE_RPC_URL : undefined;\n    20→  return envUrl || DEFAULT_RPC_URL;\n    21→}\n    22→\n    23→function getCluster(): \"devnet\" | \"testnet\" | \"mainnet-beta\" {\n    24→  const network =\n    25→    typeof import.meta !== \"undefined\"\n    26→      ? import.meta.env?.VITE_SOLANA_NETWORK\n    27→      : undefined;\n    28→  if (network === \"mainnet-beta\" || network === \"testnet\") return network;\n    29→  return \"devnet\";\n    30→}\n    31→\n    32→/**\n    33→ * Bridge component that reads from @solana/wallet-adapter-react hooks\n    34→ * and maps them to our WalletContextValue, then provides via WalletContext.\n    35→ */\n    36→function WalletBridge({ children }: { children: ReactNode }) {\n    37→  const adapter = useAdapterWallet();\n    38→  const { connection } = useConnection();\n    39→  const { setShowModal } = useUnifiedWalletContext();\n    40→\n    41→  const connect = useCallback(async () => {\n    42→    // If already connected to a wallet, just reconnect\n    43→    if (adapter.wallet) {\n    44→      await adapter.connect();\n    45→      return;\n    46→    }\n    47→    // Otherwise open the Unified Wallet modal for wallet selection\n    48→    setShowModal(true);\n    49→  }, [adapter, setShowModal]);\n    50→\n    51→  const disconnect = useCallback(async () => {\n    52→    await adapter.disconnect();\n    53→  }, [adapter]);\n    54→\n    55→  const sendTransaction = useCallback(\n    56→    async (transaction: Transaction): Promise<string> => {\n    57→      if (!adapter.publicKey) {\n    58→        throw new Error(\"Wallet not connected\");\n    59→      }\n    60→      const signature = await adapter.sendTransaction(transaction, connection);\n    61→      return signature;\n    62→    },\n    63→    [adapter, connection],\n    64→  );\n    65→\n    66→  const signMessage = useCallback(\n    67→    async (message: Uint8Array): Promise<Uint8Array> => {\n    68→      if (!adapter.signMessage) {\n    69→        throw new Error(\"Wallet does not support message signing\");\n    70→      }\n    71→      return adapter.signMessage(message);\n    72→    },\n    73→    [adapter],\n    74→  );\n    75→\n    76→  const value: WalletContextValue = useMemo(\n    77→    () => ({\n    78→      connected: adapter.connected,\n    79→      connecting: adapter.connecting,\n    80→      address: adapter.publicKey?.toBase58() ?? null,\n    81→      publicKey: adapter.publicKey,\n    82→      connect,\n    83→      disconnect,\n    84→      sendTransaction,\n    85→      signMessage,\n    86→      isMock: false,\n    87→    }),\n    88→    [\n    89→      adapter.connected,\n    90→      adapter.connecting,\n    91→      adapter.publicKey,\n    92→      connect,\n    93→      disconnect,\n    94→      sendTransaction,\n    95→      signMessage,\n    96→    ],\n    97→  );\n    98→\n    99→  return (\n   100→    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n   101→  );\n   102→}\n   103→\n   104→interface RealWalletProviderProps {\n   105→  children: ReactNode;\n   106→}\n   107→\n   108→export function RealWalletProvider({ children }: RealWalletProviderProps) {\n   109→  const endpoint = getRpcUrl();\n   110→  const cluster = getCluster();\n   111→\n   112→  return (\n   113→    <ConnectionProvider endpoint={endpoint}>\n   114→      <UnifiedWalletProvider\n   115→        wallets={[]}\n   116→        config={{\n   117→          autoConnect: true,\n   118→          env: cluster,\n   119→          metadata: {\n   120→            name: \"RNG Utopia\",\n   121→            description: \"The ultimate on-chain gaming platform\",\n   122→            url: \"https://rngutopia.com\",\n   123→            iconUrls: [],\n   124→          },\n   125→          theme: \"dark\",\n   126→        }}\n   127→      >\n   128→        <WalletBridge>{children}</WalletBridge>\n   129→      </UnifiedWalletProvider>\n   130→    </ConnectionProvider>\n   131→  );\n   132→}\n   133→"}]},"parent_tool_use_id":null,"session_id":"248ce8da-d011-4be0-b32e-c11f0cfd1d76","uuid":"0282444d-368c-42fb-a569-fb9538fa2d6c","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/real/RealWalletProvider.tsx","content":"import { ReactNode, useCallback, useMemo } from \"react\";\nimport { Transaction } from \"@solana/web3.js\";\nimport {\n  ConnectionProvider,\n  useConnection,\n  useWallet as useAdapterWallet,\n} from \"@solana/wallet-adapter-react\";\nimport {\n  UnifiedWalletProvider,\n  useUnifiedWalletContext,\n} from \"@jup-ag/wallet-adapter\";\nimport { WalletContext } from \"../context\";\nimport type { WalletContextValue } from \"../types\";\n\nconst DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n\nfunction getRpcUrl(): string {\n  const envUrl =\n    typeof import.meta !== \"undefined\" ? import.meta.env?.VITE_RPC_URL : undefined;\n  return envUrl || DEFAULT_RPC_URL;\n}\n\nfunction getCluster(): \"devnet\" | \"testnet\" | \"mainnet-beta\" {\n  const network =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_SOLANA_NETWORK\n      : undefined;\n  if (network === \"mainnet-beta\" || network === \"testnet\") return network;\n  return \"devnet\";\n}\n\n/**\n * Bridge component that reads from @solana/wallet-adapter-react hooks\n * and maps them to our WalletContextValue, then provides via WalletContext.\n */\nfunction WalletBridge({ children }: { children: ReactNode }) {\n  const adapter = useAdapterWallet();\n  const { connection } = useConnection();\n  const { setShowModal } = useUnifiedWalletContext();\n\n  const connect = useCallback(async () => {\n    // If already connected to a wallet, just reconnect\n    if (adapter.wallet) {\n      await adapter.connect();\n      return;\n    }\n    // Otherwise open the Unified Wallet modal for wallet selection\n    setShowModal(true);\n  }, [adapter, setShowModal]);\n\n  const disconnect = useCallback(async () => {\n    await adapter.disconnect();\n  }, [adapter]);\n\n  const sendTransaction = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      if (!adapter.publicKey) {\n        throw new Error(\"Wallet not connected\");\n      }\n      const signature = await adapter.sendTransaction(transaction, connection);\n      return signature;\n    },\n    [adapter, connection],\n  );\n\n  const signMessage = useCallback(\n    async (message: Uint8Array): Promise<Uint8Array> => {\n      if (!adapter.signMessage) {\n        throw new Error(\"Wallet does not support message signing\");\n      }\n      return adapter.signMessage(message);\n    },\n    [adapter],\n  );\n\n  const value: WalletContextValue = useMemo(\n    () => ({\n      connected: adapter.connected,\n      connecting: adapter.connecting,\n      address: adapter.publicKey?.toBase58() ?? null,\n      publicKey: adapter.publicKey,\n      connect,\n      disconnect,\n      sendTransaction,\n      signMessage,\n      isMock: false,\n    }),\n    [\n      adapter.connected,\n      adapter.connecting,\n      adapter.publicKey,\n      connect,\n      disconnect,\n      sendTransaction,\n      signMessage,\n    ],\n  );\n\n  return (\n    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n  );\n}\n\ninterface RealWalletProviderProps {\n  children: ReactNode;\n}\n\nexport function RealWalletProvider({ children }: RealWalletProviderProps) {\n  const endpoint = getRpcUrl();\n  const cluster = getCluster();\n\n  return (\n    <ConnectionProvider endpoint={endpoint}>\n      <UnifiedWalletProvider\n        wallets={[]}\n        config={{\n          autoConnect: true,\n          env: cluster,\n          metadata: {\n            name: \"RNG Utopia\",\n            description: \"The ultimate on-chain gaming platform\",\n            url: \"https://rngutopia.com\",\n            iconUrls: [],\n          },\n          theme: \"dark\",\n        }}\n      >\n        <WalletBridge>{children}</WalletBridge>\n      </UnifiedWalletProvider>\n    </ConnectionProvider>\n  );\n}\n","numLines":133,"startLine":1,"totalLines":133}}}
