\n   110→          description: \"The ultimate on-chain gaming platform\",\n   111→          url: \"https://rngutopia.com\",\n   112→          iconUrls: [],\n   113→        },\n   114→        theme: \"dark\",\n   115→      }}\n   116→    >\n   117→      <WalletBridge>{children}</WalletBridge>\n   118→    </UnifiedWalletProvider>\n   119→  );\n   120→}\n   121→"}]},"parent_tool_use_id":null,"session_id":"248ce8da-d011-4be0-b32e-c11f0cfd1d76","uuid":"2414fa83-bfa7-43dd-a783-d4c87d5fc3f6","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/real/RealWalletProvider.tsx","content":"import { ReactNode, useCallback, useMemo } from \"react\";\nimport { Transaction } from \"@solana/web3.js\";\nimport {\n  useConnection,\n  useWallet as useAdapterWallet,\n} from \"@solana/wallet-adapter-react\";\nimport {\n  UnifiedWalletProvider,\n  useUnifiedWalletContext,\n} from \"@jup-ag/wallet-adapter\";\nimport { WalletContext } from \"../context\";\nimport type { WalletContextValue } from \"../types\";\n\nfunction getCluster(): \"devnet\" | \"testnet\" | \"mainnet-beta\" {\n  const network =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_SOLANA_NETWORK\n      : undefined;\n  if (network === \"mainnet-beta\" || network === \"testnet\") return network;\n  return \"devnet\";\n}\n\n/**\n * Bridge component that reads from @solana/wallet-adapter-react hooks\n * and maps them to our WalletContextValue, then provides via WalletContext.\n */\nfunction WalletBridge({ children }: { children: ReactNode }) {\n  const adapter = useAdapterWallet();\n  const { connection } = useConnection();\n  const { setShowModal } = useUnifiedWalletContext();\n\n  const connect = useCallback(async () => {\n    // If already connected to a wallet, just reconnect\n    if (adapter.wallet) {\n      await adapter.connect();\n      return;\n    }\n    // Otherwise open the Unified Wallet modal for wallet selection\n    setShowModal(true);\n  }, [adapter, setShowModal]);\n\n  const disconnect = useCallback(async () => {\n    await adapter.disconnect();\n  }, [adapter]);\n\n  const sendTransaction = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      if (!adapter.publicKey) {\n        throw new Error(\"Wallet not connected\");\n      }\n      const signature = await adapter.sendTransaction(transaction, connection);\n      return signature;\n    },\n    [adapter, connection],\n  );\n\n  const signMessage = useCallback(\n    async (message: Uint8Array): Promise<Uint8Array> => {\n      if (!adapter.signMessage) {\n        throw new Error(\"Wallet does not support message signing\");\n      }\n      return adapter.signMessage(message);\n    },\n    [adapter],\n  );\n\n  const value: WalletContextValue = useMemo(\n    () => ({\n      connected: adapter.connected,\n      connecting: adapter.connecting,\n      address: adapter.publicKey?.toBase58() ?? null,\n      publicKey: adapter.publicKey,\n      connect,\n      disconnect,\n      sendTransaction,\n      signMessage,\n      isMock: false,\n    }),\n    [\n      adapter.connected,\n      adapter.connecting,\n      adapter.publicKey,\n      connect,\n      disconnect,\n      sendTransaction,\n      signMessage,\n    ],\n  );\n\n  return (\n    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n  );\n}\n\ninterface RealWalletProviderProps {\n  children: ReactNode;\n}\n\nexport function RealWalletProvider({ children }: RealWalletProviderProps) {\n  const cluster = getCluster();\n\n  return (\n    <UnifiedWalletProvider\n      wallets={[]}\n      config={{\n        autoConnect: true,\n        env: cluster,\n        metadata: {\n          name: \"RNG Utopia\",\n          description: \"The ultimate on-chain gaming platform\",\n          url: \"https://rngutopia.com\",\n          iconUrls: [],\n        },\n        theme: \"dark\",\n      }}\n    >\n      <WalletBridge>{children}</WalletBridge>\n    </UnifiedWalletProvider>\n  );\n}\n","numLines":121,"startLine":1,"totalLines":121}}}
