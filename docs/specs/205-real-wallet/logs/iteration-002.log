{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DZ9XM7LN3FK1oC63gRLUes","type":"tool_result","content":"     1→import { ReactNode, lazy, Suspense } from \"react\";\n     2→import { MockWalletProvider } from \"./mock\";\n     3→\n     4→// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     5→const RealWalletProvider = lazy(() =>\n     6→  import(\"./real/RealWalletProvider\").then((m) => ({\n     7→    default: m.RealWalletProvider,\n     8→  })),\n     9→);\n    10→\n    11→// Re-export WalletContext from the shared context file\n    12→export { WalletContext } from \"./context\";\n    13→\n    14→interface WalletProviderProps {\n    15→  children: ReactNode;\n    16→}\n    17→\n    18→function isMockMode(): boolean {\n    19→  const flag =\n    20→    typeof import.meta !== \"undefined\"\n    21→      ? import.meta.env?.VITE_MOCK_MODE\n    22→      : undefined;\n    23→  // Default to mock mode when unset or explicitly \"true\"\n    24→  return flag === undefined || flag === \"\" || flag === \"true\";\n    25→}\n    26→\n    27→/**\n    28→ * Unified WalletProvider.\n    29→ * Delegates to MockWalletProvider or RealWalletProvider based on VITE_MOCK_MODE.\n    30→ */\n    31→export function WalletProvider({ children }: WalletProviderProps) {\n    32→  if (isMockMode()) {\n    33→    return <MockWalletProvider>{children}</MockWalletProvider>;\n    34→  }\n    35→\n    36→  return (\n    37→    <Suspense fallback={null}>\n    38→      <RealWalletProvider>{children}</RealWalletProvider>\n    39→    </Suspense>\n    40→  );\n    41→}\n    42→"}]},"parent_tool_use_id":null,"session_id":"248ce8da-d011-4be0-b32e-c11f0cfd1d76","uuid":"8c368be8-d545-4572-8c61-2924d2460a0b","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/WalletProvider.tsx","content":"import { ReactNode, lazy, Suspense } from \"react\";\nimport { MockWalletProvider } from \"./mock\";\n\n// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\nconst RealWalletProvider = lazy(() =>\n  import(\"./real/RealWalletProvider\").then((m) => ({\n    default: m.RealWalletProvider,\n  })),\n);\n\n// Re-export WalletContext from the shared context file\nexport { WalletContext } from \"./context\";\n\ninterface WalletProviderProps {\n  children: ReactNode;\n}\n\nfunction isMockMode(): boolean {\n  const flag =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_MOCK_MODE\n      : undefined;\n  // Default to mock mode when unset or explicitly \"true\"\n  return flag === undefined || flag === \"\" || flag === \"true\";\n}\n\n/**\n * Unified WalletProvider.\n * Delegates to MockWalletProvider or RealWalletProvider based on VITE_MOCK_MODE.\n */\nexport function WalletProvider({ children }: WalletProviderProps) {\n  if (isMockMode()) {\n    return <MockWalletProvider>{children}</MockWalletProvider>;\n  }\n\n  return (\n    <Suspense fallback={null}>\n      <RealWalletProvider>{children}</RealWalletProvider>\n    </Suspense>\n  );\n}\n","numLines":42,"startLine":1,"totalLines":42}}}
