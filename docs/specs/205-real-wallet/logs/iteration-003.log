llInterval);\n    }\n\n    return () => {\n      if (pollIntervalRef.current) {\n        clearInterval(pollIntervalRef.current);\n        pollIntervalRef.current = null;\n      }\n    };\n  }, [connected, publicKey, pollInterval, fetchBalance]);\n\n  // Cleanup connection on unmount\n  useEffect(() => {\n    return () => {\n      connectionRef.current = null;\n    };\n  }, []);\n\n  // Manual refresh\n  const refresh = useCallback(async () => {\n    await fetchBalance();\n  }, [fetchBalance]);\n\n  // Calculate derived values\n  const balance =\n    balanceLamports !== null ? balanceLamports / LAMPORTS_PER_SOL : null;\n  const formatted =\n    balanceLamports !== null ? formatAmount(balanceLamports) : null;\n  const formattedCompact =\n    balanceLamports !== null ? formatAmountCompact(balanceLamports) : null;\n\n  return {\n    balance,\n    balanceLamports,\n    loading,\n    error,\n    refresh,\n    formatted,\n    formattedCompact,\n    lastUpdated,\n  };\n}\n","structuredPatch":[{"oldStart":108,"oldLines":13,"newStart":108,"newLines":6,"lines":["     };","   }, [connected, publicKey, pollInterval, fetchBalance]);"," ","-  // Cleanup connection on unmount","-  useEffect(() => {","-    return () => {","-      connectionRef.current = null;","-    };","-  }, []);","-","   // Manual refresh","   const refresh = useCallback(async () => {","     await fetchBalance();"]}],"userModified":false,"replaceAll":false}}
