xport function CoinflipProvider({ children }: { children: ReactNode }) {\n   102→  const { connected, publicKey, sendTransaction } = useWallet();\n   103→\n   104→  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n   105→\n   106→  // Selection state\n   107→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   108→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   109→\n   110→  // Match state\n   111→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   112→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   113→  const [userHistory] = useState<UIMatch[]>([]);\n   114→\n   115→  // Loading states\n   116→  const [loading, setLoading] = useState(true);\n   117→  const [creating, setCreating] = useState(false);\n   118→  const [joining, setJoining] = useState(false);\n   119→  const [claiming, setClaiming] = useState(false);\n   120→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   121→\n   122→  // Error state\n   123→  const [error, setError] = useState<string | null>(null);\n   124→  const clearError = useCallback(() => setError(null), []);\n   125→\n   126→  // Fetch open matches from on-chain\n   127→  const refreshMatches = useCallback(() => {\n   128→    fetchAllOpenMatches(connection)\n   129→      .then((matches) => {\n   130→        setOpenMatches(matches);\n   131→        setLoading(false);\n   132→      })\n   133→      .catch(() => {\n   134→        setLoading(false);\n   135→      });\n   136→  }, [connection]);\n   137→\n   138→  // Initial load\n   139→  useEffect(() => {\n   140→    setLoading(true);\n   141→    refreshMatches();\n   142→  }, [refreshMatches]);\n   143→\n   144→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   145→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   146→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   147→\n   148→  useEffect(() => {\n   149→    const interval = setInterval(() => {\n   150→      refreshMatches();\n   151→\n   152→      // If there's an active match, refresh it too\n   153→      if (activeMatch) {\n   154→        const matchPda = new PublicKey(activeMatch.id);\n   155→        fetchMatch(connection, matchPda)\n   156→          .then((updated) => {\n   157→            if (updated) {\n   158→              setActiveMatch(updated);\n   159→            } else {\n   160→              // Match account closed (claimed or cancelled)\n   161→              setActiveMatch(null);\n   162→            }\n   163→          })\n   164→          .catch(() => {\n   165→            // Ignore polling errors\n   166→          });\n   167→      }\n   168→    }, pollInterval);\n   169→    return () => clearInterval(interval);\n   170→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   171→\n   172→  const createMatch = useCallback(async () => {\n   173→    if (!connected || !publicKey) {\n   174→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   175→      return;\n   176→    }\n   177→    if (!selectedTier || !selectedSide) {\n   178→      setError(\"Select tier and side first.\");\n   179→      return;\n   180→    }\n   181→\n   182→    setCreating(true);\n   183→    setError(null);\n   184→    try {\n   185→      const { transaction, matchPda } = await buildCreateMatchTx(\n   186→        connection,\n   187→        publicKey,\n   188→        selectedTier,\n   189→        selectedSide\n   190→      );\n   191→\n   192→      await sendTransaction(transaction);\n   193→\n   194→      // Fetch the created match from on-chain\n   195→      const match = await fetchMatch(connection, matchPda);\n   196→      if (match) {\n   197→        setActiveMatch(match);\n   198→      }\n   199→\n   200→      setSelectedSide(null);\n   201→      refreshMatches();\n   202→    } catch (err) {\n   203→      setError(parseTransactionError(err));\n   204→    } finally {\n   205→      setCreating(false);\n   206→    }\n   207→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n   208→\n   209→  const joinMatch = useCallback(\n   210→    async (matchId: string) => {\n   211→      if (!connected || !publicKey) {\n   212→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   213→        return;\n   214→      }\n   215→\n   216→      setJoining(true);\n   217→      setJoiningMatchId(matchId);\n   218→      setError(null);\n   219→      try {\n   220→        // matchId is the match PDA base58 — fetch to get the creator\n   221→        const matchPda = new PublicKey(matchId);\n   222→        const existingMatch = await fetchMatch(connection, matchPda);\n   223→        if (!existingMatch) {\n   224→          setError(\"Match not found. It may have been cancelled.\");\n   225→          return;\n   226→        }\n   227→\n   228→        const matchCreator = new PublicKey(existingMatch.player1);\n   229→        const transaction = await buildJoinMatchTx(\n   230→          connection,\n   231→          publicKey,\n   232→          matchCreator\n   233→        );\n   234→\n   235→        await sendTransaction(transaction);\n   236→\n   237→        // Fetch updated match\n   238→        const updated = await fetchMatch(connection, matchPda);\n   239→        if (updated) {\n   240→          setActiveMatch(updated);\n   241→        }\n   242→\n   243→        refreshMatches();\n   244→      } catch (err) {\n   245→        setError(parseTransactionError(err));\n   246→      } finally {\n   247→        setJoining(false);\n   248→        setJoiningMatchId(null);\n   249→      }\n   250→    },\n   251→    [connected, publicKey, connection, sendTransaction, refreshMatches]\n   252→  );\n   253→\n   254→  const cancelMatch = useCallback(async () => {\n   255→    if (!connected || !publicKey || !activeMatch) {\n   256→      setError(\"No active match to cancel.\");\n   257→      return;\n   258→    }\n   259→\n   260→    setError(null);\n   261→    try {\n   262→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   263→      await sendTransaction(transaction);\n   264→      setActiveMatch(null);\n   265→      refreshMatches();\n   266→    } catch (err) {\n   267→      setError(parseTransactionError(err));\n   268→    }\n   269→  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n   270→\n   271→  const claimPayout = useCallback(async () => {\n   272→    if (!connected || !publicKey || !activeMatch) {\n   273→      setError(\"No active match to claim.\");\n   274→      return;\n   275→    }\n   276→\n   277→    setClaiming(true);\n   278→    setError(null);\n   279→    try {\n   280→      const matchCreator = new PublicKey(activeMatch.player1);\n   281→      const opponent = activeMatch.player2\n   282→        ? new PublicKey(activeMatch.player2)\n   283→        : PublicKey.default;\n   284→\n   285→      const transaction = await buildClaimPayoutTx(\n   286→        connection,\n   287→        publicKey,\n   288→        matchCreator,\n   289→        opponent\n   290→      );\n   291→\n   292→      await sendTransaction(transaction);\n   293→\n   294→      // Update local state\n   295→      setActiveMatch({ ...activeMatch, claimed: true });\n   296→    } catch (err) {\n   297→      setError(parseTransactionError(err));\n   298→    } finally {\n   299→      setClaiming(false);\n   300→    }\n   301→  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n   302→\n   303→  // Track if user explicitly cleared the match\n   304→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   305→\n   306→  const clearActiveMatch = useCallback(() => {\n   307→    setActiveMatch(null);\n   308→    setUserClearedMatch(true);\n   309→    setError(null);\n   310→    refreshMatches();\n   311→  }, [refreshMatches]);\n   312→\n   313→  // Check for existing active match on wallet connect\n   314→  useEffect(() => {\n   315→    if (publicKey && !activeMatch && !userClearedMatch) {\n   316→      fetchMatchByCreator(connection, publicKey)\n   317→        .then((match) => {\n   318→          if (match) {\n   319→            setActiveMatch(match);\n   320→          }\n   321→        })\n   322→        .catch(() => {\n   323→          // No active match found\n   324→        });\n   325→    }\n   326→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   327→\n   328→  // Reset userClearedMatch when creating or joining a new match\n   329→  useEffect(() => {\n   330→    if (activeMatch) {\n   331→      setUserClearedMatch(false);\n   332→    }\n   333→  }, [activeMatch]);\n   334→\n   335→  const value: CoinflipContextValue = {\n   336→    activeMatch,\n   337→    openMatches,\n   338→    userHistory,\n   339→    selectedTier,\n   340→    selectedSide,\n   341→    loading,\n   342→    creating,\n   343→    joining,\n   344→    claiming,\n   345→    joiningMatchId,\n   346→    error,\n   347→    clearError,\n   348→    setSelectedTier,\n   349→    setSelectedSide,\n   350→    createMatch,\n   351→    joinMatch,\n   352→    cancelMatch,\n   353→    claimPayout,\n   354→    clearActiveMatch,\n   355→    refreshMatches,\n   356→  };\n   357→\n   358→  return (\n   359→    <CoinflipContext.Provider value={value}>\n   360→      {children}\n   361→    </CoinflipContext.Provider>\n   362→  );\n   363→}\n   364→\n   365→export function useCoinflip(): CoinflipContextValue {\n   366→  const context = useContext(CoinflipContext);\n   367→  if (!context) {\n   368→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   369→  }\n   370→  return context;\n   371→}\n   372→"}]},"parent_tool_use_id":null,"session_id":"dc9fbb5c-f0ae-42eb-8036-00379cf160bf","uuid":"22977447-2df2-4d52-8249-477b6d73f129","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\n// RPC endpoint — defaults to localhost for development\nconst RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n\n/** Parse Solana/wallet errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  // Wallet not connected\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n\n  // User rejected\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n\n  // Insufficient funds (Solana runtime error)\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n\n  // Account already in use (match already exists)\n  if (msg.includes(\"already in use\")) {\n    return \"You already have an active match. Cancel it before creating a new one.\";\n  }\n\n  // Network / RPC errors\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n\n  // Anchor program errors\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This match is no longer available.\";\n  }\n  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    return \"You cannot join your own match.\";\n  }\n\n  // Generic fallback\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n\n  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection, pollInterval]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendTransaction(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":372,"startLine":1,"totalLines":372}}}
