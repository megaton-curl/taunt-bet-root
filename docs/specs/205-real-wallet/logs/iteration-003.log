   </Suspense>\n    51→  );\n    52→\n    53→  return <ConnectionProvider endpoint={endpoint}>{inner}</ConnectionProvider>;\n    54→}\n    55→"}]},"parent_tool_use_id":null,"session_id":"dc9fbb5c-f0ae-42eb-8036-00379cf160bf","uuid":"b2420ebe-8319-43ef-bd21-ba14dd40e751","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/WalletProvider.tsx","content":"import { ReactNode, lazy, Suspense } from \"react\";\nimport { ConnectionProvider } from \"@solana/wallet-adapter-react\";\nimport { MockWalletProvider } from \"./mock\";\n\n// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\nconst RealWalletProvider = lazy(() =>\n  import(\"./real/RealWalletProvider\").then((m) => ({\n    default: m.RealWalletProvider,\n  })),\n);\n\n// Re-export WalletContext from the shared context file\nexport { WalletContext } from \"./context\";\n\nconst DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n\nfunction getRpcUrl(): string {\n  const envUrl =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_RPC_URL\n      : undefined;\n  return envUrl || DEFAULT_RPC_URL;\n}\n\ninterface WalletProviderProps {\n  children: ReactNode;\n}\n\nfunction isMockMode(): boolean {\n  const flag =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_MOCK_MODE\n      : undefined;\n  // Default to mock mode when unset or explicitly \"true\"\n  return flag === undefined || flag === \"\" || flag === \"true\";\n}\n\n/**\n * Unified WalletProvider.\n * Wraps both Mock and Real providers with a shared ConnectionProvider.\n */\nexport function WalletProvider({ children }: WalletProviderProps) {\n  const endpoint = getRpcUrl();\n\n  const inner = isMockMode() ? (\n    <MockWalletProvider>{children}</MockWalletProvider>\n  ) : (\n    <Suspense fallback={null}>\n      <RealWalletProvider>{children}</RealWalletProvider>\n    </Suspense>\n  );\n\n  return <ConnectionProvider endpoint={endpoint}>{inner}</ConnectionProvider>;\n}\n","numLines":55,"startLine":1,"totalLines":55}}}
