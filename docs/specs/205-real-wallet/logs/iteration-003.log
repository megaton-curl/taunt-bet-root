{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013D4VP1T1LpaVZSZCMH2GoL","type":"tool_result","content":"     1→import { useState, useEffect, useCallback, useRef } from \"react\";\n     2→import { LAMPORTS_PER_SOL } from \"@solana/web3.js\";\n     3→import { useConnection } from \"@solana/wallet-adapter-react\";\n     4→import { useWallet } from \"./useWallet\";\n     5→import { formatAmount, formatAmountCompact } from \"./balance\";\n     6→\n     7→export interface BalanceResult {\n     8→  /** Balance in SOL (null if not connected or loading) */\n     9→  balance: number | null;\n    10→  /** Balance in lamports (null if not connected or loading) */\n    11→  balanceLamports: number | null;\n    12→  /** Loading state */\n    13→  loading: boolean;\n    14→  /** Error if fetch failed */\n    15→  error: Error | null;\n    16→  /** Manually refresh the balance */\n    17→  refresh: () => Promise<void>;\n    18→  /** Formatted balance (e.g., \"1.2345\") */\n    19→  formatted: string | null;\n    20→  /** Compact formatted balance (e.g., \"1.2k\") */\n    21→  formattedCompact: string | null;\n    22→  /** Last update timestamp */\n    23→  lastUpdated: Date | null;\n    24→}\n    25→\n    26→interface UseBalanceOptions {\n    27→  /** Polling interval in ms (default: 10000, set to 0 to disable) */\n    28→  pollInterval?: number;\n    29→}\n    30→\n    31→const DEFAULT_POLL_INTERVAL = 10_000; // 10 seconds\n    32→\n    33→export function useBalance(options: UseBalanceOptions = {}): BalanceResult {\n    34→  const { pollInterval = DEFAULT_POLL_INTERVAL } = options;\n    35→\n    36→  const wallet = useWallet();\n    37→  const { publicKey, connected, isMock, getBalanceLamports: getMockBalance } = wallet;\n    38→  const { connection } = useConnection();\n    39→  const [balanceLamports, setBalanceLamports] = useState<number | null>(null);\n    40→  const [loading, setLoading] = useState(false);\n    41→  const [error, setError] = useState<Error | null>(null);\n    42→  const [lastUpdated, setLastUpdated] = useState<Date | null>(null);\n    43→\n    44→  const pollIntervalRef = useRef<ReturnType<typeof setInterval> | null>(null);\n    45→\n    46→  // Fetch balance (mock or real)\n    47→  const fetchBalance = useCallback(async () => {\n    48→    if (!connected || !publicKey) {\n    49→      setBalanceLamports(null);\n    50→      setError(null);\n    51→      return;\n    52→    }\n    53→\n    54→    setLoading(true);\n    55→    setError(null);\n    56→\n    57→    try {\n    58→      // Use mock balance if in mock mode\n    59→      if (isMock && getMockBalance) {\n    60→        const lamports = getMockBalance();\n    61→        setBalanceLamports(lamports);\n    62→        setLastUpdated(new Date());\n    63→      } else {\n    64→        // Fetch from RPC for real wallet\n    65→        const lamports = await connection.getBalance(publicKey);\n    66→        setBalanceLamports(lamports);\n    67→        setLastUpdated(new Date());\n    68→      }\n    69→    } catch (err) {\n    70→      console.error(\"Failed to fetch balance:\", err);\n    71→      setError(\n    72→        err instanceof Error ? err : new Error(\"Failed to fetch balance\")\n    73→      );\n    74→    } finally {\n    75→      setLoading(false);\n    76→    }\n    77→  }, [connected, publicKey, connection, isMock, getMockBalance]);\n    78→\n    79→  // Initial fetch and polling\n    80→  useEffect(() => {\n    81→    // Clear previous interval\n    82→    if (pollIntervalRef.current) {\n    83→      clearInterval(pollIntervalRef.current);\n    84→      pollIntervalRef.current = null;\n    85→    }\n    86→\n    87→    // Reset state if disconnected\n    88→    if (!connected || !publicKey) {\n    89→      setBalanceLamports(null);\n    90→      setError(null);\n    91→      setLastUpdated(null);\n    92→      return;\n    93→    }\n    94→\n    95→    // Initial fetch\n    96→    fetchBalance();\n    97→\n    98→    // Set up polling if enabled\n    99→    if (pollInterval > 0) {\n   100→      pollIntervalRef.current = setInterval(fetchBalance, pollInterval);\n   101→    }\n   102→\n   103→    return () => {\n   104→      if (pollIntervalRef.current) {\n   105→        clearInterval(pollIntervalRef.current);\n   106→        pollIntervalRef.current = null;\n   107→      }\n   108→    };\n   109→  }, [connected, publicKey, pollInterval, fetchBalance]);\n   110→\n   111→  // Manual refresh\n   112→  const refresh = useCallback(async () => {\n   113→    await fetchBalance();\n   114→  }, [fetchBalance]);\n   115→\n   116→  // Calculate derived values\n   117→  const balance =\n   118→    balanceLamports !== null ? balanceLamports / LAMPORTS_PER_SOL : null;\n   119→  const formatted =\n   120→    balanceLamports !== null ? formatAmount(balanceLamports) : null;\n   121→  const formattedCompact =\n   122→    balanceLamports !== null ? formatAmountCompact(balanceLamports) : null;\n   123→\n   124→  return {\n   125→    balance,\n   126→    balanceLamports,\n   127→    loading,\n   128→    error,\n   129→    refresh,\n   130→    formatted,\n   131→    formattedCompact,\n   132→    lastUpdated,\n   133→  };\n   134→}\n   135→"}]},"parent_tool_use_id":null,"session_id":"dc9fbb5c-f0ae-42eb-8036-00379cf160bf","uuid":"dd01412b-4694-46c2-8236-34541f955ad8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/useBalance.ts","content":"import { useState, useEffect, useCallback, useRef } from \"react\";\nimport { LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport { useConnection } from \"@solana/wallet-adapter-react\";\nimport { useWallet } from \"./useWallet\";\nimport { formatAmount, formatAmountCompact } from \"./balance\";\n\nexport interface BalanceResult {\n  /** Balance in SOL (null if not connected or loading) */\n  balance: number | null;\n  /** Balance in lamports (null if not connected or loading) */\n  balanceLamports: number | null;\n  /** Loading state */\n  loading: boolean;\n  /** Error if fetch failed */\n  error: Error | null;\n  /** Manually refresh the balance */\n  refresh: () => Promise<void>;\n  /** Formatted balance (e.g., \"1.2345\") */\n  formatted: string | null;\n  /** Compact formatted balance (e.g., \"1.2k\") */\n  formattedCompact: string | null;\n  /** Last update timestamp */\n  lastUpdated: Date | null;\n}\n\ninterface UseBalanceOptions {\n  /** Polling interval in ms (default: 10000, set to 0 to disable) */\n  pollInterval?: number;\n}\n\nconst DEFAULT_POLL_INTERVAL = 10_000; // 10 seconds\n\nexport function useBalance(options: UseBalanceOptions = {}): BalanceResult {\n  const { pollInterval = DEFAULT_POLL_INTERVAL } = options;\n\n  const wallet = useWallet();\n  const { publicKey, connected, isMock, getBalanceLamports: getMockBalance } = wallet;\n  const { connection } = useConnection();\n  const [balanceLamports, setBalanceLamports] = useState<number | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState<Error | null>(null);\n  const [lastUpdated, setLastUpdated] = useState<Date | null>(null);\n\n  const pollIntervalRef = useRef<ReturnType<typeof setInterval> | null>(null);\n\n  // Fetch balance (mock or real)\n  const fetchBalance = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setBalanceLamports(null);\n      setError(null);\n      return;\n    }\n\n    setLoading(true);\n    setError(null);\n\n    try {\n      // Use mock balance if in mock mode\n      if (isMock && getMockBalance) {\n        const lamports = getMockBalance();\n        setBalanceLamports(lamports);\n        setLastUpdated(new Date());\n      } else {\n        // Fetch from RPC for real wallet\n        const lamports = await connection.getBalance(publicKey);\n        setBalanceLamports(lamports);\n        setLastUpdated(new Date());\n      }\n    } catch (err) {\n      console.error(\"Failed to fetch balance:\", err);\n      setError(\n        err instanceof Error ? err : new Error(\"Failed to fetch balance\")\n      );\n    } finally {\n      setLoading(false);\n    }\n  }, [connected, publicKey, connection, isMock, getMockBalance]);\n\n  // Initial fetch and polling\n  useEffect(() => {\n    // Clear previous interval\n    if (pollIntervalRef.current) {\n      clearInterval(pollIntervalRef.current);\n      pollIntervalRef.current = null;\n    }\n\n    // Reset state if disconnected\n    if (!connected || !publicKey) {\n      setBalanceLamports(null);\n      setError(null);\n      setLastUpdated(null);\n      return;\n    }\n\n    // Initial fetch\n    fetchBalance();\n\n    // Set up polling if enabled\n    if (pollInterval > 0) {\n      pollIntervalRef.current = setInterval(fetchBalance, pollInterval);\n    }\n\n    return () => {\n      if (pollIntervalRef.current) {\n        clearInterval(pollIntervalRef.current);\n        pollIntervalRef.current = null;\n      }\n    };\n  }, [connected, publicKey, pollInterval, fetchBalance]);\n\n  // Manual refresh\n  const refresh = useCallback(async () => {\n    await fetchBalance();\n  }, [fetchBalance]);\n\n  // Calculate derived values\n  const balance =\n    balanceLamports !== null ? balanceLamports / LAMPORTS_PER_SOL : null;\n  const formatted =\n    balanceLamports !== null ? formatAmount(balanceLamports) : null;\n  const formattedCompact =\n    balanceLamports !== null ? formatAmountCompact(balanceLamports) : null;\n\n  return {\n    balance,\n    balanceLamports,\n    loading,\n    error,\n    refresh,\n    formatted,\n    formattedCompact,\n    lastUpdated,\n  };\n}\n","numLines":135,"startLine":1,"totalLines":135}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01DAmBHr2cvLC11EXPER2b7e","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Pw899rCDWu186fPwqQc45X","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":345,"cache_read_input_tokens":55446,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":345},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"dc9fbb5c-f0ae-42eb-8036-00379cf160bf","uuid":"bd965c36-418c-48d4-af8a-294607ba21e0"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pw899rCDWu186fPwqQc45X","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  type ReactNode,\n     8→} from \"react\";\n     9→import { PublicKey } from \"@solana/web3.js\";\n    10→import { useConnection } from \"@solana/wallet-adapter-react\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchMatchByCreator,\n    16→  fetchMatch,\n    17→  buildCreateMatchTx,\n    18→  buildJoinMatchTx,\n    19→  buildCancelMatchTx,\n    20→  buildClaimPayoutTx,\n    21→} from \"../utils/chain\";\n    22→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    23→\n    24→/** Parse Solana/wallet errors into user-friendly messages */\n    25→function parseTransactionError(err: unknown): string {\n    26→  const msg = err instanceof Error ? err.message : String(err);\n    27→\n    28→  // Wallet not connected\n    29→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    30→    return \"Wallet not connected. Please connect your wallet first.\";\n    31→  }\n    32→\n    33→  // User rejected\n    34→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    35→    return \"Transaction cancelled by user.\";\n    36→  }\n    37→\n    38→  // Insufficient funds (Solana runtime error)\n    39→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    40→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    41→  }\n    42→\n    43→  // Account already in use (match already exists)\n    44→  if (msg.includes(\"already in use\")) {\n    45→    return \"You already have an active match. Cancel it before creating a new one.\";\n    46→  }\n    47→\n    48→  // Network / RPC errors\n    49→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    50→    return \"Network error. Please check your connection and try again.\";\n    51→  }\n    52→\n    53→  // Anchor program errors\n    54→  if (msg.includes(\"InvalidPhase\")) {\n    55→    return \"This match is no longer available.\";\n    56→  }\n    57→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    58→    return \"You cannot join your own match.\";\n    59→  }\n    60→\n    61→  // Generic fallback\n    62→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    63→}\n    64→\n    65→interface CoinflipContextValue {\n    66→  // State\n    67→  activeMatch: UIMatch | null;\n    68→  openMatches: UIMatch[];\n    69→  userHistory: UIMatch[];\n    70→  selectedTier: Tier | null;\n    71→  selectedSide: CoinSide | null;\n    72→\n    73→  // Loading states\n    74→  loading: boolean;\n    75→  creating: boolean;\n    76→  joining: boolean;\n    77→  claiming: boolean;\n    78→  joiningMatchId: string | null;\n    79→\n    80→  // Error state\n    81→  error: string | null;\n    82→  clearError: () => void;\n    83→\n    84→  // Actions\n    85→  setSelectedTier: (tier: Tier | null) => void;\n    86→  setSelectedSide: (side: CoinSide | null) => void;\n    87→  createMatch: () => Promise<void>;\n    88→  joinMatch: (matchId: string) => Promise<void>;\n    89→  cancelMatch: () => Promise<void>;\n    90→  claimPayout: () => Promise<void>;\n    91→  clearActiveMatch: () => void;\n    92→  refreshMatches: () => void;\n    93→}\n    94→\n    95→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n    96→\n    97→export function CoinflipProvider({ children }: { children: ReactNode }) {\n    98→  const { connected, publicKey, sendTransaction } = useWallet();\n    99→  const { connection } = useConnection();\n   100→\n   101→  // Selection state\n   102→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   103→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   104→\n   105→  // Match state\n   106→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   107→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   108→  const [userHistory] = useState<UIMatch[]>([]);\n   109→\n   110→  // Loading states\n   111→  const [loading, setLoading] = useState(true);\n   112→  const [creating, setCreating] = useState(false);\n   113→  const [joining, setJoining] = useState(false);\n   114→  const [claiming, setClaiming] = useState(false);\n   115→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   116→\n   117→  // Error state\n   118→  const [error, setError] = useState<string | null>(null);\n   119→  const clearError = useCallback(() => setError(null), []);\n   120→\n   121→  // Fetch open matches from on-chain\n   122→  const refreshMatches = useCallback(() => {\n   123→    fetchAllOpenMatches(connection)\n   124→      .then((matches) => {\n   125→        setOpenMatches(matches);\n   126→        setLoading(false);\n   127→      })\n   128→      .catch(() => {\n   129→        setLoading(false);\n   130→      });\n   131→  }, [connection]);\n   132→\n   133→  // Initial load\n   134→  useEffect(() => {\n   135→    setLoading(true);\n   136→    refreshMatches();\n   137→  }, [refreshMatches]);\n   138→\n   139→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   140→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   141→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   142→\n   143→  useEffect(() => {\n   144→    const interval = setInterval(() => {\n   145→      refreshMatches();\n   146→\n   147→      // If there's an active match, refresh it too\n   148→      if (activeMatch) {\n   149→        const matchPda = new PublicKey(activeMatch.id);\n   150→        fetchMatch(connection, matchPda)\n   151→          .then((updated) => {\n   152→            if (updated) {\n   153→              setActiveMatch(updated);\n   154→            } else {\n   155→              // Match account closed (claimed or cancelled)\n   156→              setActiveMatch(null);\n   157→            }\n   158→          })\n   159→          .catch(() => {\n   160→            // Ignore polling errors\n   161→          });\n   162→      }\n   163→    }, pollInterval);\n   164→    return () => clearInterval(interval);\n   165→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   166→\n   167→  const createMatch = useCallback(async () => {\n   168→    if (!connected || !publicKey) {\n   169→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   170→      return;\n   171→    }\n   172→    if (!selectedTier || !selectedSide) {\n   173→      setError(\"Select tier and side first.\");\n   174→      return;\n   175→    }\n   176→\n   177→    setCreating(true);\n   178→    setError(null);\n   179→    try {\n   180→      const { transaction, matchPda } = await buildCreateMatchTx(\n   181→        connection,\n   182→        publicKey,\n   183→        selectedTier,\n   184→        selectedSide\n   185→      );\n   186→\n   187→      await sendTransaction(transaction);\n   188→\n   189→      // Fetch the created match from on-chain\n   190→      const match = await fetchMatch(connection, matchPda);\n   191→      if (match) {\n   192→        setActiveMatch(match);\n   193→      }\n   194→\n   195→      setSelectedSide(null);\n   196→      refreshMatches();\n   197→    } catch (err) {\n   198→      setError(parseTransactionError(err));\n   199→    } finally {\n   200→      setCreating(false);\n   201→    }\n   202→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n   203→\n   204→  const joinMatch = useCallback(\n   205→    async (matchId: string) => {\n   206→      if (!connected || !publicKey) {\n   207→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   208→        return;\n   209→      }\n   210→\n   211→      setJoining(true);\n   212→      setJoiningMatchId(matchId);\n   213→      setError(null);\n   214→      try {\n   215→        // matchId is the match PDA base58 — fetch to get the creator\n   216→        const matchPda = new PublicKey(matchId);\n   217→        const existingMatch = await fetchMatch(connection, matchPda);\n   218→        if (!existingMatch) {\n   219→          setError(\"Match not found. It may have been cancelled.\");\n   220→          return;\n   221→        }\n   222→\n   223→        const matchCreator = new PublicKey(existingMatch.player1);\n   224→        const transaction = await buildJoinMatchTx(\n   225→          connection,\n   226→          publicKey,\n   227→          matchCreator\n   228→        );\n   229→\n   230→        await sendTransaction(transaction);\n   231→\n   232→        // Fetch updated match\n   233→        const updated = await fetchMatch(connection, matchPda);\n   234→        if (updated) {\n   235→          setActiveMatch(updated);\n   236→        }\n   237→\n   238→        refreshMatches();\n   239→      } catch (err) {\n   240→        setError(parseTransactionError(err));\n   241→      } finally {\n   242→        setJoining(false);\n   243→        setJoiningMatchId(null);\n   244→      }\n   245→    },\n   246→    [connected, publicKey, connection, sendTransaction, refreshMatches]\n   247→  );\n   248→\n   249→  const cancelMatch = useCallback(async () => {\n   250→    if (!connected || !publicKey || !activeMatch) {\n   251→      setError(\"No active match to cancel.\");\n   252→      return;\n   253→    }\n   254→\n   255→    setError(null);\n   256→    try {\n   257→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   258→      await sendTransaction(transaction);\n   259→      setActiveMatch(null);\n   260→      refreshMatches();\n   261→    } catch (err) {\n   262→      setError(parseTransactionError(err));\n   263→    }\n   264→  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n   265→\n   266→  const claimPayout = useCallback(async () => {\n   267→    if (!connected || !publicKey || !activeMatch) {\n   268→      setError(\"No active match to claim.\");\n   269→      return;\n   270→    }\n   271→\n   272→    setClaiming(true);\n   273→    setError(null);\n   274→    try {\n   275→      const matchCreator = new PublicKey(activeMatch.player1);\n   276→      const opponent = activeMatch.player2\n   277→        ? new PublicKey(activeMatch.player2)\n   278→        : PublicKey.default;\n   279→\n   280→      const transaction = await buildClaimPayoutTx(\n   281→        connection,\n   282→        publicKey,\n   283→        matchCreator,\n   284→        opponent\n   285→      );\n   286→\n   287→      await sendTransaction(transaction);\n   288→\n   289→      // Update local state\n   290→      setActiveMatch({ ...activeMatch, claimed: true });\n   291→    } catch (err) {\n   292→      setError(parseTransactionError(err));\n   293→    } finally {\n   294→      setClaiming(false);\n   295→    }\n   296→  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n   297→\n   298→  // Track if user explicitly cleared the match\n   299→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   300→\n   301→  const clearActiveMatch = useCallback(() => {\n   302→    setActiveMatch(null);\n   303→    setUserClearedMatch(true);\n   304→    setError(null);\n   305→    refreshMatches();\n   306→  }, [refreshMatches]);\n   307→\n   308→  // Check for existing active match on wallet connect\n   309→  useEffect(() => {\n   310→    if (publicKey && !activeMatch && !userClearedMatch) {\n   311→      fetchMatchByCreator(connection, publicKey)\n   312→        .then((match) => {\n   313→          if (match) {\n   314→            setActiveMatch(match);\n   315→          }\n   316→        })\n   317→        .catch(() => {\n   318→          // No active match found\n   319→        });\n   320→    }\n   321→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   322→\n   323→  // Reset userClearedMatch when creating or joining a new match\n   324→  useEffect(() => {\n   325→    if (activeMatch) {\n   326→      setUserClearedMatch(false);\n   327→    }\n   328→  }, [activeMatch]);\n   329→\n   330→  const value: CoinflipContextValue = {\n   331→    activeMatch,\n   332→    openMatches,\n   333→    userHistory,\n   334→    selectedTier,\n   335→    selectedSide,\n   336→    loading,\n   337→    creating,\n   338→    joining,\n   339→    claiming,\n   340→    joiningMatchId,\n   341→    error,\n   342→    clearError,\n   343→    setSelectedTier,\n   344→    setSelectedSide,\n   345→    createMatch,\n   346→    joinMatch,\n   347→    cancelMatch,\n   348→    claimPayout,\n   349→    clearActiveMatch,\n   350→    refreshMatches,\n   351→  };\n   352→\n   353→  return (\n   354→    <CoinflipContext.Provider value={value}>\n   355→      {children}\n   356→    </CoinflipContext.Provider>\n   357→  );\n   358→}\n   359→\n   360→export function useCoinflip(): CoinflipContextValue {\n   361→  const context = useContext(CoinflipContext);\n   362→  if (!context) {\n   363→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   364→  }\n   365→  return context;\n   366→}\n   367→"}]},"parent_tool_use_id":null,"session_id":"dc9fbb5c-f0ae-42eb-8036-00379cf160bf","uuid":"964d5025-0a7a-41d6-bdf2-937388fb07ef","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  type ReactNode,\n} from \"react\";\nimport { PublicKey } from \"@solana/web3.js\";\nimport { useConnection } from \"@solana/wallet-adapter-react\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse Solana/wallet errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  // Wallet not connected\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n\n  // User rejected\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n\n  // Insufficient funds (Solana runtime error)\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n\n  // Account already in use (match already exists)\n  if (msg.includes(\"already in use\")) {\n    return \"You already have an active match. Cancel it before creating a new one.\";\n  }\n\n  // Network / RPC errors\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n\n  // Anchor program errors\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This match is no longer available.\";\n  }\n  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    return \"You cannot join your own match.\";\n  }\n\n  // Generic fallback\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection, pollInterval]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendTransaction(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":367,"startLine":1,"totalLines":367}}}
