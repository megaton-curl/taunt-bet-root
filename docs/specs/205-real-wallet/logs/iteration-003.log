→      setError(\n    95→        err instanceof Error ? err : new Error(\"Failed to fetch balance\")\n    96→      );\n    97→    } finally {\n    98→      setLoading(false);\n    99→    }\n   100→  }, [connected, publicKey, getConnection, isMock, getMockBalance]);\n   101→\n   102→  // Initial fetch and polling\n   103→  useEffect(() => {\n   104→    // Clear previous interval\n   105→    if (pollIntervalRef.current) {\n   106→      clearInterval(pollIntervalRef.current);\n   107→      pollIntervalRef.current = null;\n   108→    }\n   109→\n   110→    // Reset state if disconnected\n   111→    if (!connected || !publicKey) {\n   112→      setBalanceLamports(null);\n   113→      setError(null);\n   114→      setLastUpdated(null);\n   115→      return;\n   116→    }\n   117→\n   118→    // Initial fetch\n   119→    fetchBalance();\n   120→\n   121→    // Set up polling if enabled\n   122→    if (pollInterval > 0) {\n   123→      pollIntervalRef.current = setInterval(fetchBalance, pollInterval);\n   124→    }\n   125→\n   126→    return () => {\n   127→      if (pollIntervalRef.current) {\n   128→        clearInterval(pollIntervalRef.current);\n   129→        pollIntervalRef.current = null;\n   130→      }\n   131→    };\n   132→  }, [connected, publicKey, pollInterval, fetchBalance]);\n   133→\n   134→  // Cleanup connection on unmount\n   135→  useEffect(() => {\n   136→    return () => {\n   137→      connectionRef.current = null;\n   138→    };\n   139→  }, []);\n   140→\n   141→  // Manual refresh\n   142→  const refresh = useCallback(async () => {\n   143→    await fetchBalance();\n   144→  }, [fetchBalance]);\n   145→\n   146→  // Calculate derived values\n   147→  const balance =\n   148→    balanceLamports !== null ? balanceLamports / LAMPORTS_PER_SOL : null;\n   149→  const formatted =\n   150→    balanceLamports !== null ? formatAmount(balanceLamports) : null;\n   151→  const formattedCompact =\n   152→    balanceLamports !== null ? formatAmountCompact(balanceLamports) : null;\n   153→\n   154→  return {\n   155→    balance,\n   156→    balanceLamports,\n   157→    loading,\n   158→    error,\n   159→    refresh,\n   160→    formatted,\n   161→    formattedCompact,\n   162→    lastUpdated,\n   163→  };\n   164→}\n   165→"}]},"parent_tool_use_id":null,"session_id":"dc9fbb5c-f0ae-42eb-8036-00379cf160bf","uuid":"b76e2bee-7bb1-40e9-a42c-94b10fed1a75","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/useBalance.ts","content":"import { useState, useEffect, useCallback, useRef } from \"react\";\nimport { Connection, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport { useWallet } from \"./useWallet\";\nimport { formatAmount, formatAmountCompact } from \"./balance\";\n\nexport interface BalanceResult {\n  /** Balance in SOL (null if not connected or loading) */\n  balance: number | null;\n  /** Balance in lamports (null if not connected or loading) */\n  balanceLamports: number | null;\n  /** Loading state */\n  loading: boolean;\n  /** Error if fetch failed */\n  error: Error | null;\n  /** Manually refresh the balance */\n  refresh: () => Promise<void>;\n  /** Formatted balance (e.g., \"1.2345\") */\n  formatted: string | null;\n  /** Compact formatted balance (e.g., \"1.2k\") */\n  formattedCompact: string | null;\n  /** Last update timestamp */\n  lastUpdated: Date | null;\n}\n\ninterface UseBalanceOptions {\n  /** Polling interval in ms (default: 10000, set to 0 to disable) */\n  pollInterval?: number;\n  /** Custom RPC URL (defaults to env variable or devnet) */\n  rpcUrl?: string;\n}\n\nconst DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\nconst DEFAULT_POLL_INTERVAL = 10_000; // 10 seconds\n\nfunction getRpcUrl(customUrl?: string): string {\n  if (customUrl) return customUrl;\n\n  // Check environment variable\n  const envUrl = import.meta.env?.VITE_RPC_URL;\n  if (envUrl) return envUrl;\n\n  return DEFAULT_RPC_URL;\n}\n\nexport function useBalance(options: UseBalanceOptions = {}): BalanceResult {\n  const { pollInterval = DEFAULT_POLL_INTERVAL, rpcUrl: customRpcUrl } =\n    options;\n\n  const wallet = useWallet();\n  const { publicKey, connected, isMock, getBalanceLamports: getMockBalance } = wallet;\n  const [balanceLamports, setBalanceLamports] = useState<number | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState<Error | null>(null);\n  const [lastUpdated, setLastUpdated] = useState<Date | null>(null);\n\n  const connectionRef = useRef<Connection | null>(null);\n  const pollIntervalRef = useRef<ReturnType<typeof setInterval> | null>(null);\n\n  // Get or create connection\n  const getConnection = useCallback(() => {\n    const rpcUrl = getRpcUrl(customRpcUrl);\n    if (!connectionRef.current) {\n      connectionRef.current = new Connection(rpcUrl, \"confirmed\");\n    }\n    return connectionRef.current;\n  }, [customRpcUrl]);\n\n  // Fetch balance (mock or real)\n  const fetchBalance = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setBalanceLamports(null);\n      setError(null);\n      return;\n    }\n\n    setLoading(true);\n    setError(null);\n\n    try {\n      // Use mock balance if in mock mode\n      if (isMock && getMockBalance) {\n        const lamports = getMockBalance();\n        setBalanceLamports(lamports);\n        setLastUpdated(new Date());\n      } else {\n        // Fetch from RPC for real wallet\n        const connection = getConnection();\n        const lamports = await connection.getBalance(publicKey);\n        setBalanceLamports(lamports);\n        setLastUpdated(new Date());\n      }\n    } catch (err) {\n      console.error(\"Failed to fetch balance:\", err);\n      setError(\n        err instanceof Error ? err : new Error(\"Failed to fetch balance\")\n      );\n    } finally {\n      setLoading(false);\n    }\n  }, [connected, publicKey, getConnection, isMock, getMockBalance]);\n\n  // Initial fetch and polling\n  useEffect(() => {\n    // Clear previous interval\n    if (pollIntervalRef.current) {\n      clearInterval(pollIntervalRef.current);\n      pollIntervalRef.current = null;\n    }\n\n    // Reset state if disconnected\n    if (!connected || !publicKey) {\n      setBalanceLamports(null);\n      setError(null);\n      setLastUpdated(null);\n      return;\n    }\n\n    // Initial fetch\n    fetchBalance();\n\n    // Set up polling if enabled\n    if (pollInterval > 0) {\n      pollIntervalRef.current = setInterval(fetchBalance, pollInterval);\n    }\n\n    return () => {\n      if (pollIntervalRef.current) {\n        clearInterval(pollIntervalRef.current);\n        pollIntervalRef.current = null;\n      }\n    };\n  }, [connected, publicKey, pollInterval, fetchBalance]);\n\n  // Cleanup connection on unmount\n  useEffect(() => {\n    return () => {\n      connectionRef.current = null;\n    };\n  }, []);\n\n  // Manual refresh\n  const refresh = useCallback(async () => {\n    await fetchBalance();\n  }, [fetchBalance]);\n\n  // Calculate derived values\n  const balance =\n    balanceLamports !== null ? balanceLamports / LAMPORTS_PER_SOL : null;\n  const formatted =\n    balanceLamports !== null ? formatAmount(balanceLamports) : null;\n  const formattedCompact =\n    balanceLamports !== null ? formatAmountCompact(balanceLamports) : null;\n\n  return {\n    balance,\n    balanceLamports,\n    loading,\n    error,\n    refresh,\n    formatted,\n    formattedCompact,\n    lastUpdated,\n  };\n}\n","numLines":165,"startLine":1,"totalLines":165}}}
