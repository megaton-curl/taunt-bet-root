{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PNqojAT6Mnz3tWgP4DTZe5","type":"tool_result","content":"     1→import { defineConfig, devices } from \"@playwright/test\";\n     2→\n     3→export default defineConfig({\n     4→  testDir: \"./e2e\",\n     5→  fullyParallel: true,\n     6→  forbidOnly: !!process.env.CI,\n     7→  retries: 0,\n     8→  workers: 1,\n     9→  reporter: \"list\",\n    10→\n    11→  snapshotPathTemplate:\n    12→    \"{testDir}/__snapshots__/{testFilePath}/{arg}{ext}\",\n    13→\n    14→  expect: {\n    15→    toHaveScreenshot: {\n    16→      maxDiffPixelRatio: 0.015,\n    17→    },\n    18→  },\n    19→\n    20→  use: {\n    21→    baseURL: \"http://localhost:3000\",\n    22→    screenshot: \"off\",\n    23→    trace: \"off\",\n    24→    ...devices[\"Desktop Chrome\"],\n    25→    viewport: { width: 1280, height: 1080 },\n    26→  },\n    27→\n    28→  projects: [\n    29→    {\n    30→      name: \"chromium\",\n    31→      use: { ...devices[\"Desktop Chrome\"], viewport: { width: 1280, height: 1080 } },\n    32→    },\n    33→  ],\n    34→\n    35→  webServer: {\n    36→    command: \"pnpm dev\",\n    37→    url: \"http://localhost:3000\",\n    38→    reuseExistingServer: !process.env.CI,\n    39→    timeout: 30_000,\n    40→  },\n    41→});\n    42→"}]},"parent_tool_use_id":"toolu_01U5ZaVqNW1qxPv5CdWvwn6W","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"abe93a30-5a52-44a5-be81-56244cbd811a"}
