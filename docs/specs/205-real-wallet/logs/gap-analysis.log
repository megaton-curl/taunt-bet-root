{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TpW9qySxBGnndU985sriUH","type":"tool_result","content":"     1→import { describe, it, expect, vi } from \"vitest\";\n     2→import { renderHook, waitFor } from \"@testing-library/react\";\n     3→import { Keypair } from \"@solana/web3.js\";\n     4→import { TestWalletProvider } from \"./TestWalletProvider\";\n     5→import { MockWalletProvider } from \"../mock/MockWalletProvider\";\n     6→import { useWallet } from \"../useWallet\";\n     7→import type { ReactNode } from \"react\";\n     8→\n     9→// Mock Connection.getBalance so TestWalletProvider.connect() succeeds without a real RPC\n    10→vi.mock(\"@solana/web3.js\", async (importOriginal) => {\n    11→  const actual = await importOriginal<typeof import(\"@solana/web3.js\")>();\n    12→  return {\n    13→    ...actual,\n    14→    Connection: class MockConnection {\n    15→      constructor(\n    16→        public endpoint: string,\n    17→        public commitmentOrConfig?: string,\n    18→      ) {}\n    19→      async getBalance() {\n    20→        return 1_000_000_000; // 1 SOL\n    21→      }\n    22→    },\n    23→  };\n    24→});\n    25→\n    26→describe(\"TestWalletProvider\", () => {\n    27→  it(\"auto-connects and exposes publicKey matching the keypair\", async () => {\n    28→    const keypair = Keypair.generate();\n    29→\n    30→    const wrapper = ({ children }: { children: ReactNode }) => (\n    31→      <TestWalletProvider\n    32→        keypair={keypair}\n    33→        rpcUrl=\"https://api.devnet.solana.com\"\n    34→      >\n    35→        {children}\n    36→      </TestWalletProvider>\n    37→    );\n    38→\n    39→    const { result } = renderHook(() => useWallet(), { wrapper });\n    40→\n    41→    await waitFor(() => {\n    42→      expect(result.current.connected).toBe(true);\n    43→    });\n    44→\n    45→    expect(result.current.publicKey?.toBase58()).toBe(\n    46→      keypair.publicKey.toBase58(),\n    47→    );\n    48→    expect(result.current.address).toBe(keypair.publicKey.toBase58());\n    49→    expect(result.current.isMock).toBe(false);\n    50→  });\n    51→});\n    52→\n    53→describe(\"MockWalletProvider\", () => {\n    54→  it(\"starts disconnected by default\", () => {\n    55→    const wrapper = ({ children }: { children: ReactNode }) => (\n    56→      <MockWalletProvider config={{ simulatedLatency: 0 }}>\n    57→        {children}\n    58→      </MockWalletProvider>\n    59→    );\n    60→\n    61→    const { result } = renderHook(() => useWallet(), { wrapper });\n    62→\n    63→    expect(result.current.connected).toBe(false);\n    64→    expect(result.current.publicKey).toBeNull();\n    65→    expect(result.current.address).toBeNull();\n    66→    expect(result.current.isMock).toBe(true);\n    67→  });\n    68→});\n    69→"}]},"parent_tool_use_id":"toolu_0195YbLK77c4daza5NhtSdhg","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"47cb6782-c9a9-44c6-be36-be6431ff83aa"}
