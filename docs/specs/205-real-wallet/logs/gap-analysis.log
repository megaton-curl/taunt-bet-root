{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017Doxj4wB8y9evwYBGroz7i","type":"tool_result","content":"     1→import { ReactNode, useState, useCallback, useMemo, useEffect } from \"react\";\n     2→import {\n     3→  Connection,\n     4→  Keypair,\n     5→  Transaction,\n     6→  sendAndConfirmTransaction,\n     7→} from \"@solana/web3.js\";\n     8→import { WalletContext } from \"../context\";\n     9→import type { WalletContextValue } from \"../types\";\n    10→\n    11→const DEFAULT_RPC_URL = \"http://127.0.0.1:8899\";\n    12→\n    13→interface TestWalletProviderProps {\n    14→  children: ReactNode;\n    15→  /** Keypair to use for signing transactions */\n    16→  keypair: Keypair;\n    17→  /** RPC URL (defaults to localhost:8899) */\n    18→  rpcUrl?: string;\n    19→  /** Auto-connect on mount (default: true) */\n    20→  autoConnect?: boolean;\n    21→}\n    22→\n    23→/**\n    24→ * Test wallet provider that signs real transactions with an injected Keypair.\n    25→ * For E2E testing against local test-validator — no browser extension needed.\n    26→ */\n    27→export function TestWalletProvider({\n    28→  children,\n    29→  keypair,\n    30→  rpcUrl = DEFAULT_RPC_URL,\n    31→  autoConnect = true,\n    32→}: TestWalletProviderProps) {\n    33→  const [connected, setConnected] = useState(false);\n    34→  const [connecting, setConnecting] = useState(false);\n    35→\n    36→  const connection = useMemo(\n    37→    () => new Connection(rpcUrl, \"confirmed\"),\n    38→    [rpcUrl],\n    39→  );\n    40→\n    41→  const connect = useCallback(async () => {\n    42→    setConnecting(true);\n    43→    try {\n    44→      // Verify the keypair works by checking if the account exists\n    45→      await connection.getBalance(keypair.publicKey);\n    46→      setConnected(true);\n    47→    } finally {\n    48→      setConnecting(false);\n    49→    }\n    50→  }, [connection, keypair]);\n    51→\n    52→  const disconnect = useCallback(async () => {\n    53→    setConnected(false);\n    54→  }, []);\n    55→\n    56→  const sendTransaction = useCallback(\n    57→    async (transaction: Transaction): Promise<string> => {\n    58→      if (!connected) {\n    59→        throw new Error(\"Wallet not connected\");\n    60→      }\n    61→      transaction.feePayer = keypair.publicKey;\n    62→      const signature = await sendAndConfirmTransaction(\n    63→        connection,\n    64→        transaction,\n    65→        [keypair],\n    66→      );\n    67→      return signature;\n    68→    },\n    69→    [connected, keypair, connection],\n    70→  );\n    71→\n    72→  const signMessage = useCallback(\n    73→    async (_message: Uint8Array): Promise<Uint8Array> => {\n    74→      if (!connected) {\n    75→        throw new Error(\"Wallet not connected\");\n    76→      }\n    77→      // Return a deterministic signature from the keypair's secret key\n    78→      const sig = new Uint8Array(64);\n    79→      sig.set(keypair.secretKey.slice(0, 64));\n    80→      return sig;\n    81→    },\n    82→    [connected, keypair],\n    83→  );\n    84→\n    85→  // Auto-connect\n    86→  useEffect(() => {\n    87→    if (autoConnect && !connected && !connecting) {\n    88→      connect();\n    89→    }\n    90→  }, [autoConnect, connected, connecting, connect]);\n    91→\n    92→  const value: WalletContextValue = useMemo(\n    93→    () => ({\n    94→      connected,\n    95→      connecting,\n    96→      address: connected ? keypair.publicKey.toBase58() : null,\n    97→      publicKey: connected ? keypair.publicKey : null,\n    98→      connect,\n    99→      disconnect,\n   100→      sendTransaction,\n   101→      signMessage,\n   102→      isMock: false,\n   103→    }),\n   104→    [\n   105→      connected,\n   106→      connecting,\n   107→      keypair,\n   108→      connect,\n   109→      disconnect,\n   110→      sendTransaction,\n   111→      signMessage,\n   112→    ],\n   113→  );\n   114→\n   115→  return (\n   116→    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n   117→  );\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_0195YbLK77c4daza5NhtSdhg","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"0d1ba903-742e-449e-aa0e-4d0a0b069925"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LCZkGfk1X6H6LGL9xKKf46","type":"tool_result","content":"     1→import { PublicKey, Transaction } from \"@solana/web3.js\";\n     2→\n     3→export interface WalletState {\n     4→  connected: boolean;\n     5→  connecting: boolean;\n     6→  address: string | null;\n     7→  publicKey: PublicKey | null;\n     8→}\n     9→\n    10→export interface WalletContextValue extends WalletState {\n    11→  connect: () => Promise<void>;\n    12→  disconnect: () => Promise<void>;\n    13→  sendTransaction: (transaction: Transaction) => Promise<string>;\n    14→  signMessage: (message: Uint8Array) => Promise<Uint8Array>;\n    15→  /** True if using mock wallet */\n    16→  isMock?: boolean;\n    17→  /** Get mock balance in SOL (mock mode only) */\n    18→  getBalance?: () => number;\n    19→  /** Get mock balance in lamports (mock mode only) */\n    20→  getBalanceLamports?: () => number;\n    21→  /** Update mock balance (mock mode only) */\n    22→  updateBalance?: (deltaLamports: number) => void;\n    23→}\n    24→"}]},"parent_tool_use_id":"toolu_01U5ZaVqNW1qxPv5CdWvwn6W","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"75250439-51d5-442e-b69f-8292dc9aaa79"}
