{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EwvPx3aYqNwSmQJ9N4xzgA","type":"tool_result","content":"     1→import { ReactNode, lazy, Suspense } from \"react\";\n     2→import { ConnectionProvider } from \"@solana/wallet-adapter-react\";\n     3→import { MockWalletProvider } from \"./mock\";\n     4→\n     5→// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     6→const RealWalletProvider = lazy(() =>\n     7→  import(\"./real/RealWalletProvider\").then((m) => ({\n     8→    default: m.RealWalletProvider,\n     9→  })),\n    10→);\n    11→\n    12→// Re-export WalletContext from the shared context file\n    13→export { WalletContext } from \"./context\";\n    14→\n    15→const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    16→\n    17→function getRpcUrl(): string {\n    18→  const envUrl =\n    19→    typeof import.meta !== \"undefined\"\n    20→      ? import.meta.env?.VITE_RPC_URL\n    21→      : undefined;\n    22→  return envUrl || DEFAULT_RPC_URL;\n    23→}\n    24→\n    25→interface WalletProviderProps {\n    26→  children: ReactNode;\n    27→}\n    28→\n    29→function isMockMode(): boolean {\n    30→  const flag =\n    31→    typeof import.meta !== \"undefined\"\n    32→      ? import.meta.env?.VITE_MOCK_MODE\n    33→      : undefined;\n    34→  // Default to mock mode when unset or explicitly \"true\"\n    35→  return flag === undefined || flag === \"\" || flag === \"true\";\n    36→}\n    37→\n    38→/**\n    39→ * Unified WalletProvider.\n    40→ * Wraps both Mock and Real providers with a shared ConnectionProvider.\n    41→ */\n    42→export function WalletProvider({ children }: WalletProviderProps) {\n    43→  const endpoint = getRpcUrl();\n    44→\n    45→  const inner = isMockMode() ? (\n    46→    <MockWalletProvider>{children}</MockWalletProvider>\n    47→  ) : (\n    48→    <Suspense fallback={null}>\n    49→      <RealWalletProvider>{children}</RealWalletProvider>\n    50→    </Suspense>\n    51→  );\n    52→\n    53→  return <ConnectionProvider endpoint={endpoint}>{inner}</ConnectionProvider>;\n    54→}\n    55→"}]},"parent_tool_use_id":"toolu_01U5ZaVqNW1qxPv5CdWvwn6W","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"8e4b1c65-c319-4a4c-8f49-8df8082867ec"}
