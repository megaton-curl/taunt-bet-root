{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XbvUcG4hudhhP4gqfGKAzy","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→\n     3→// Fee constants (from ARCHITECTURE.md)\n     4→export const FEE_CONSTANTS = {\n     5→  /** Total fee in basis points (300 = 3%) */\n     6→  TOTAL_BPS: 300,\n     7→  /** Platform revenue in basis points (200 = 2%) */\n     8→  PLATFORM_REVENUE_BPS: 200,\n     9→  /** Cashback pool in basis points (50 = 0.5%) */\n    10→  CASHBACK_POOL_BPS: 50,\n    11→  /** Rewards budget in basis points (50 = 0.5%) */\n    12→  REWARDS_BUDGET_BPS: 50,\n    13→} as const;\n    14→\n    15→// Fee breakdown for display\n    16→export const FEE_BREAKDOWN = {\n    17→  total: { bps: 300, display: \"3%\" },\n    18→  platformRevenue: { bps: 200, display: \"2%\" },\n    19→  cashbackPool: { bps: 50, display: \"0.5%\" },\n    20→  rewardsBudget: { bps: 50, display: \"0.5%\" },\n    21→} as const;\n    22→\n    23→// Hard limits from architecture (cannot be changed on-chain)\n    24→export const LIMITS = {\n    25→  /** Maximum fee in basis points (1000 = 10%) */\n    26→  MAX_FEE_BPS: 1000,\n    27→  /** Maximum bet in lamports (1000 SOL) */\n    28→  MAX_BET_LAMPORTS: 1_000_000_000_000n,\n    29→  /** Maximum players per round */\n    30→  MAX_PLAYERS_PER_ROUND: 10_000,\n    31→} as const;\n    32→\n    33→// Placeholder program IDs - update with deployed addresses\n    34→export const PROGRAM_IDS = {\n    35→  /** Pool manager program ID */\n    36→  POOL_MANAGER: new PublicKey(\"11111111111111111111111111111111\"),\n    37→  /** VRF consumer program ID */\n    38→  VRF_CONSUMER: new PublicKey(\"11111111111111111111111111111111\"),\n    39→  /** Game config program ID */\n    40→  GAME_CONFIG: new PublicKey(\"11111111111111111111111111111111\"),\n    41→} as const;\n    42→\n    43→// Treasury addresses - update with deployed addresses\n    44→export const TREASURY_ADDRESSES = {\n    45→  mainnet: {\n    46→    treasury: new PublicKey(\"11111111111111111111111111111111\"),\n    47→    rakeback: new PublicKey(\"11111111111111111111111111111111\"),\n    48→    referral: new PublicKey(\"11111111111111111111111111111111\"),\n    49→  },\n    50→  devnet: {\n    51→    treasury: new PublicKey(\"11111111111111111111111111111111\"),\n    52→    rakeback: new PublicKey(\"11111111111111111111111111111111\"),\n    53→    referral: new PublicKey(\"11111111111111111111111111111111\"),\n    54→  },\n    55→} as const;\n    56→\n    57→/**\n    58→ * Calculate fee amount from pool total\n    59→ */\n    60→export function calculateFee(poolTotalLamports: bigint): bigint {\n    61→  return (poolTotalLamports * BigInt(FEE_CONSTANTS.TOTAL_BPS)) / 10000n;\n    62→}\n    63→\n    64→/**\n    65→ * Calculate winner payout from pool total (after fees)\n    66→ */\n    67→export function calculatePayout(poolTotalLamports: bigint): bigint {\n    68→  const fee = calculateFee(poolTotalLamports);\n    69→  return poolTotalLamports - fee;\n    70→}\n    71→\n    72→/**\n    73→ * Calculate fee breakdown from pool total\n    74→ */\n    75→export function calculateFeeBreakdown(poolTotalLamports: bigint): {\n    76→  total: bigint;\n    77→  platformRevenue: bigint;\n    78→  cashbackPool: bigint;\n    79→  rewardsBudget: bigint;\n    80→} {\n    81→  const total = calculateFee(poolTotalLamports);\n    82→  const platformRevenue =\n    83→    (poolTotalLamports * BigInt(FEE_CONSTANTS.PLATFORM_REVENUE_BPS)) / 10000n;\n    84→  const cashbackPool =\n    85→    (poolTotalLamports * BigInt(FEE_CONSTANTS.CASHBACK_POOL_BPS)) / 10000n;\n    86→  const rewardsBudget =\n    87→    (poolTotalLamports * BigInt(FEE_CONSTANTS.REWARDS_BUDGET_BPS)) / 10000n;\n    88→\n    89→  return {\n    90→    total,\n    91→    platformRevenue,\n    92→    cashbackPool,\n    93→    rewardsBudget,\n    94→  };\n    95→}\n    96→"}]},"parent_tool_use_id":"toolu_01WekmSXGn4JNbzkgRELFy3p","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"05de8497-a9c1-4a6c-9c8f-8eea20c1ed2c"}
