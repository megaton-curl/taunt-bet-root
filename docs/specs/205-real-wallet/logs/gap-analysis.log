{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01By1VMVQpzo34M9H25gqLGR","type":"tool_result","content":"     1→import { Keypair, PublicKey } from \"@solana/web3.js\";\n     2→\n     3→export interface MockConfig {\n     4→  initialBalance: number; // in SOL\n     5→  autoConnect: boolean;\n     6→  simulatedLatency: number; // ms\n     7→  persistState: boolean;\n     8→}\n     9→\n    10→export const DEFAULT_MOCK_CONFIG: MockConfig = {\n    11→  initialBalance: 1000,\n    12→  autoConnect: false,\n    13→  simulatedLatency: 500,\n    14→  persistState: true,\n    15→};\n    16→\n    17→const STORAGE_KEY = \"rng-utopia-mock-wallet\";\n    18→\n    19→interface PersistedState {\n    20→  address: string;\n    21→  balance: number; // in lamports\n    22→}\n    23→\n    24→export function createMockKeypair(): Keypair {\n    25→  return Keypair.generate();\n    26→}\n    27→\n    28→export function loadPersistedState(): PersistedState | null {\n    29→  if (typeof window === \"undefined\") return null;\n    30→  try {\n    31→    const stored = localStorage.getItem(STORAGE_KEY);\n    32→    if (stored) {\n    33→      return JSON.parse(stored);\n    34→    }\n    35→  } catch {\n    36→    // Ignore parse errors\n    37→  }\n    38→  return null;\n    39→}\n    40→\n    41→export function persistState(state: PersistedState): void {\n    42→  if (typeof window === \"undefined\") return;\n    43→  try {\n    44→    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));\n    45→  } catch {\n    46→    // Ignore storage errors\n    47→  }\n    48→}\n    49→\n    50→export function clearPersistedState(): void {\n    51→  if (typeof window === \"undefined\") return;\n    52→  try {\n    53→    localStorage.removeItem(STORAGE_KEY);\n    54→  } catch {\n    55→    // Ignore storage errors\n    56→  }\n    57→}\n    58→\n    59→export function generateMockSignature(): string {\n    60→  const bytes = new Uint8Array(64);\n    61→  crypto.getRandomValues(bytes);\n    62→  return Array.from(bytes)\n    63→    .map((b) => b.toString(16).padStart(2, \"0\"))\n    64→    .join(\"\");\n    65→}\n    66→\n    67→export function delay(ms: number): Promise<void> {\n    68→  return new Promise((resolve) => setTimeout(resolve, ms));\n    69→}\n    70→\n    71→export function solToLamports(sol: number): number {\n    72→  return Math.floor(sol * 1_000_000_000);\n    73→}\n    74→\n    75→export function lamportsToSol(lamports: number): number {\n    76→  return lamports / 1_000_000_000;\n    77→}\n    78→\n    79→export function getPublicKeyFromAddress(address: string): PublicKey {\n    80→  return new PublicKey(address);\n    81→}\n    82→"}]},"parent_tool_use_id":"toolu_01WekmSXGn4JNbzkgRELFy3p","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"d62bc9af-97b2-4fec-ad05-542df539e93b"}
