{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LNwGhdc9gaYe6NCdLLZj3v","type":"tool_result","content":"     1→import { LAMPORTS_PER_SOL } from \"@solana/web3.js\";\n     2→\n     3→/**\n     4→ * Format lamports to a display amount with specified precision\n     5→ */\n     6→export function formatAmount(lamports: number | bigint, precision = 2): string {\n     7→  const sol = Number(lamports) / LAMPORTS_PER_SOL;\n     8→  return sol.toFixed(precision);\n     9→}\n    10→\n    11→/**\n    12→ * Format balance in compact form (e.g., 1.2k for 1200)\n    13→ */\n    14→export function formatAmountCompact(lamports: number | bigint): string {\n    15→  const sol = Number(lamports) / LAMPORTS_PER_SOL;\n    16→  if (sol >= 1_000_000) return `${(sol / 1_000_000).toFixed(1)}M`;\n    17→  if (sol >= 1000) return `${(sol / 1000).toFixed(1)}k`;\n    18→  if (sol >= 1) return sol.toFixed(2);\n    19→  if (sol >= 0.01) return sol.toFixed(3);\n    20→  return sol.toFixed(4);\n    21→}\n    22→\n    23→/**\n    24→ * Convert lamports to SOL\n    25→ * @legacy Kept for wallet internals that still use lamport conversion\n    26→ */\n    27→export function lamportsToSOL(lamports: number | bigint): number {\n    28→  return Number(lamports) / LAMPORTS_PER_SOL;\n    29→}\n    30→\n    31→/**\n    32→ * Convert SOL to lamports\n    33→ */\n    34→export function SOLToLamports(sol: number): bigint {\n    35→  return BigInt(Math.floor(sol * LAMPORTS_PER_SOL));\n    36→}\n    37→\n    38→/**\n    39→ * Format a balance for display with $ prefix\n    40→ */\n    41→export function formatBalanceDisplay(\n    42→  lamports: number | bigint | null,\n    43→  options: {\n    44→    precision?: number;\n    45→    showSymbol?: boolean;\n    46→    compact?: boolean;\n    47→  } = {}\n    48→): string {\n    49→  const { precision = 4, showSymbol = true, compact = false } = options;\n    50→\n    51→  if (lamports === null) {\n    52→    return showSymbol ? \"$-.----\" : \"-.----\";\n    53→  }\n    54→\n    55→  const formatted = compact\n    56→    ? formatAmountCompact(lamports)\n    57→    : formatAmount(lamports, precision);\n    58→\n    59→  return showSymbol ? `$${formatted}` : formatted;\n    60→}\n    61→\n    62→/**\n    63→ * Parse a dollar amount string to lamports\n    64→ * Returns null if invalid\n    65→ */\n    66→export function parseSOLInput(input: string): bigint | null {\n    67→  const trimmed = input.trim().replace(/,/g, \"\");\n    68→  const value = parseFloat(trimmed);\n    69→\n    70→  if (isNaN(value) || value < 0) {\n    71→    return null;\n    72→  }\n    73→\n    74→  return SOLToLamports(value);\n    75→}\n    76→\n    77→/**\n    78→ * Validate if a string is a valid amount\n    79→ */\n    80→export function isValidSOLAmount(input: string): boolean {\n    81→  return parseSOLInput(input) !== null;\n    82→}\n    83→"}]},"parent_tool_use_id":"toolu_01WekmSXGn4JNbzkgRELFy3p","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"f0369b5a-85a4-4963-8851-12add388cc9a"}
