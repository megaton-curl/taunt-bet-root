{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KEA1e2pgQUf112HpZduQ2m","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  SYSVAR_SLOT_HASHES_PUBKEY,\n     7→  Transaction,\n     8→  type TransactionInstruction,\n     9→} from \"@solana/web3.js\";\n    10→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n    11→import {\n    12→  TIER_VALUES,\n    13→  COIN_SIDE_VALUES,\n    14→  TIER_AMOUNTS,\n    15→  type Tier,\n    16→  type CoinSide,\n    17→} from \"@rng-utopia/game-engine/browser\";\n    18→import type { UIMatch } from \"../types\";\n    19→\n    20→// ============ Constants ============\n    21→\n    22→const COINFLIP_PROGRAM_ID = new PublicKey(\n    23→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    24→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    25→);\n    26→\n    27→// MagicBlock Ephemeral VRF constants\n    28→const VRF_DEFAULT_QUEUE = new PublicKey(\"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\");\n    29→const VRF_PROGRAM_ID = new PublicKey(\"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\");\n    30→const VRF_PROGRAM_IDENTITY = new PublicKey(\"9irBy75QS2BN81FUgXuHcjqceJJRuc9oDkAe8TKVvvAw\");\n    31→\n    32→// On-chain phase constants\n    33→const PHASE_WAITING = 0;\n    34→const PHASE_LOCKED = 1;\n    35→const PHASE_SETTLED = 2;\n    36→\n    37→// ============ PDA Derivation ============\n    38→\n    39→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    40→  return PublicKey.findProgramAddressSync(\n    41→    [Buffer.from(\"match\"), creator.toBuffer()],\n    42→    COINFLIP_PROGRAM_ID\n    43→  );\n    44→}\n    45→\n    46→export function getConfigPda(): [PublicKey, number] {\n    47→  return PublicKey.findProgramAddressSync(\n    48→    [Buffer.from(\"coinflip_config\")],\n    49→    COINFLIP_PROGRAM_ID\n    50→  );\n    51→}\n    52→\n    53→// ============ Program Instance ============\n    54→\n    55→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    56→  // Read-only provider (no wallet needed for queries)\n    57→  const provider = new AnchorProvider(\n    58→    connection,\n    59→    {} as AnchorProvider[\"wallet\"],\n    60→    { commitment: \"confirmed\" }\n    61→  );\n    62→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    63→}\n    64→\n    65→// ============ On-Chain Account Types ============\n    66→\n    67→interface OnChainMatch {\n    68→  creator: PublicKey;\n    69→  opponent: PublicKey;\n    70→  tier: number;\n    71→  entryAmount: { toNumber(): number };\n    72→  creatorSide: number;\n    73→  phase: number;\n    74→  result: number;\n    75→  winner: PublicKey;\n    76→  claimed: boolean;\n    77→  bump: number;\n    78→}\n    79→\n    80→// ============ Converters ============\n    81→\n    82→function tierFromIndex(index: number): Tier {\n    83→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"emerald\", \"diamond\"];\n    84→  return tiers[index] ?? \"iron\";\n    85→}\n    86→\n    87→function sideFromIndex(index: number): CoinSide {\n    88→  return index === 0 ? \"heads\" : \"tails\";\n    89→}\n    90→\n    91→function phaseToUI(phase: number): UIMatch[\"phase\"] {\n    92→  switch (phase) {\n    93→    case PHASE_WAITING:\n    94→      return \"created\";\n    95→    case PHASE_LOCKED:\n    96→      return \"ready\";\n    97→    case PHASE_SETTLED:\n    98→      return \"complete\";\n    99→    default:\n   100→      return \"created\";\n   101→  }\n   102→}\n   103→\n   104→const DEFAULT_PUBKEY = PublicKey.default;\n   105→\n   106→function isDefaultPubkey(key: PublicKey): boolean {\n   107→  return key.equals(DEFAULT_PUBKEY);\n   108→}\n   109→\n   110→export function onChainMatchToUI(\n   111→  matchPda: PublicKey,\n   112→  data: OnChainMatch\n   113→): UIMatch {\n   114→  const tier = tierFromIndex(data.tier);\n   115→  const creatorSide = sideFromIndex(data.creatorSide);\n   116→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   117→  const phase = phaseToUI(data.phase);\n   118→  const isSettled = data.phase === PHASE_SETTLED;\n   119→\n   120→  const entryAmountSol = TIER_AMOUNTS[tier];\n   121→  const totalPool = entryAmountSol * 2;\n   122→  const payoutAmount = totalPool * 0.97;\n   123→\n   124→  return {\n   125→    id: matchPda.toBase58(),\n   126→    tier,\n   127→    entryAmount: entryAmountSol,\n   128→    player1: data.creator.toBase58(),\n   129→    player1Side: creatorSide,\n   130→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   131→    player2Side: hasOpponent\n   132→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   133→      : null,\n   134→    phase,\n   135→    createdAt: Date.now(),\n   136→    result: isSettled ? sideFromIndex(data.result) : null,\n   137→    winner: isSettled && !isDefaultPubkey(data.winner)\n   138→      ? data.winner.toBase58()\n   139→      : null,\n   140→    claimed: data.claimed,\n   141→    payoutAmount,\n   142→    seedHash: \"\",\n   143→  };\n   144→}\n   145→\n   146→// ============ Account Queries ============\n   147→\n   148→export async function fetchAllOpenMatches(\n   149→  connection: Connection\n   150→): Promise<UIMatch[]> {\n   151→  const program = getCoinflipProgram(connection);\n   152→  const accounts = await program.account.coinflipMatch.all();\n   153→\n   154→  return accounts\n   155→    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n   156→    .map((acc) =>\n   157→      onChainMatchToUI(\n   158→        acc.publicKey,\n   159→        acc.account as unknown as OnChainMatch\n   160→      )\n   161→    );\n   162→}\n   163→\n   164→export async function fetchMatchByCreator(\n   165→  connection: Connection,\n   166→  creator: PublicKey\n   167→): Promise<UIMatch | null> {\n   168→  const program = getCoinflipProgram(connection);\n   169→  const [matchPda] = getMatchPda(creator);\n   170→\n   171→  try {\n   172→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   173→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   174→  } catch {\n   175→    // Account doesn't exist\n   176→    return null;\n   177→  }\n   178→}\n   179→\n   180→export async function fetchMatch(\n   181→  connection: Connection,\n   182→  matchPda: PublicKey\n   183→): Promise<UIMatch | null> {\n   184→  const program = getCoinflipProgram(connection);\n   185→\n   186→  try {\n   187→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   188→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   189→  } catch {\n   190→    return null;\n   191→  }\n   192→}\n   193→\n   194→// ============ Instruction Builders ============\n   195→\n   196→export function buildCreateMatchInstruction(\n   197→  creator: PublicKey,\n   198→  tier: Tier,\n   199→  side: CoinSide\n   200→): { instruction: TransactionInstruction; matchPda: PublicKey } {\n   201→  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n   202→  const [matchPda] = getMatchPda(creator);\n   203→\n   204→  const tierIndex = TIER_VALUES[tier];\n   205→  const sideIndex = COIN_SIDE_VALUES[side];\n   206→\n   207→  const instruction = program.methods\n   208→    .createMatch(tierIndex, sideIndex)\n   209→    .accountsStrict({\n   210→      creator,\n   211→      coinflipMatch: matchPda,\n   212→      systemProgram: SystemProgram.programId,\n   213→    })\n   214→    .instruction();\n   215→\n   216→  // instruction() returns a Promise<TransactionInstruction>, but we return\n   217→  // it synchronously wrapped — callers must await the instruction.\n   218→  // For now, build the transaction inline.\n   219→  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n   220→}\n   221→\n   222→export async function buildCreateMatchTx(\n   223→  connection: Connection,\n   224→  creator: PublicKey,\n   225→  tier: Tier,\n   226→  side: CoinSide\n   227→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   228→  const program = getCoinflipProgram(connection);\n   229→  const [matchPda] = getMatchPda(creator);\n   230→\n   231→  const tierIndex = TIER_VALUES[tier];\n   232→  const sideIndex = COIN_SIDE_VALUES[side];\n   233→\n   234→  const ix = await program.methods\n   235→    .createMatch(tierIndex, sideIndex)\n   236→    .accountsStrict({\n   237→      creator,\n   238→      coinflipMatch: matchPda,\n   239→      systemProgram: SystemProgram.programId,\n   240→    })\n   241→    .instruction();\n   242→\n   243→  const tx = new Transaction().add(ix);\n   244→  tx.feePayer = creator;\n   245→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   246→\n   247→  return { transaction: tx, matchPda };\n   248→}\n   249→\n   250→export async function buildJoinMatchTx(\n   251→  connection: Connection,\n   252→  opponent: PublicKey,\n   253→  matchCreator: PublicKey\n   254→): Promise<Transaction> {\n   255→  const program = getCoinflipProgram(connection);\n   256→  const [matchPda] = getMatchPda(matchCreator);\n   257→  const [configPda] = getConfigPda();\n   258→\n   259→  const ix = await program.methods\n   260→    .joinMatch()\n   261→    .accountsStrict({\n   262→      opponent,\n   263→      coinflipMatch: matchPda,\n   264→      config: configPda,\n   265→      oracleQueue: VRF_DEFAULT_QUEUE,\n   266→      programIdentity: VRF_PROGRAM_IDENTITY,\n   267→      vrfProgram: VRF_PROGRAM_ID,\n   268→      slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n   269→      systemProgram: SystemProgram.programId,\n   270→    })\n   271→    .instruction();\n   272→\n   273→  const tx = new Transaction().add(ix);\n   274→  tx.feePayer = opponent;\n   275→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   276→\n   277→  return tx;\n   278→}\n   279→\n   280→export async function buildCancelMatchTx(\n   281→  connection: Connection,\n   282→  creator: PublicKey\n   283→): Promise<Transaction> {\n   284→  const program = getCoinflipProgram(connection);\n   285→  const [matchPda] = getMatchPda(creator);\n   286→\n   287→  const ix = await program.methods\n   288→    .cancelMatch()\n   289→    .accountsStrict({\n   290→      creator,\n   291→      coinflipMatch: matchPda,\n   292→      systemProgram: SystemProgram.programId,\n   293→    })\n   294→    .instruction();\n   295→\n   296→  const tx = new Transaction().add(ix);\n   297→  tx.feePayer = creator;\n   298→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   299→\n   300→  return tx;\n   301→}\n   302→\n   303→export async function buildClaimPayoutTx(\n   304→  connection: Connection,\n   305→  winner: PublicKey,\n   306→  matchCreator: PublicKey,\n   307→  opponent: PublicKey\n   308→): Promise<Transaction> {\n   309→  const program = getCoinflipProgram(connection);\n   310→  const [matchPda] = getMatchPda(matchCreator);\n   311→  const [configPda] = getConfigPda();\n   312→\n   313→  // Fetch config to get treasury address\n   314→  const config = await program.account.coinflipConfig.fetch(configPda);\n   315→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   316→\n   317→  // Derive player profile PDAs for CPI\n   318→  const PLATFORM_PROGRAM_ID = new PublicKey(\n   319→    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n   320→      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n   321→  );\n   322→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   323→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   324→    PLATFORM_PROGRAM_ID\n   325→  );\n   326→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   327→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   328→    PLATFORM_PROGRAM_ID\n   329→  );\n   330→\n   331→  const ix = await program.methods\n   332→    .claimPayout()\n   333→    .accountsStrict({\n   334→      winner,\n   335→      coinflipMatch: matchPda,\n   336→      config: configPda,\n   337→      treasury,\n   338→      creator: matchCreator,\n   339→      creatorProfile,\n   340→      opponentProfile,\n   341→      platformProgram: PLATFORM_PROGRAM_ID,\n   342→      systemProgram: SystemProgram.programId,\n   343→    })\n   344→    .instruction();\n   345→\n   346→  const tx = new Transaction().add(ix);\n   347→  tx.feePayer = winner;\n   348→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   349→\n   350→  return tx;\n   351→}\n   352→"}]},"parent_tool_use_id":"toolu_01U5ZaVqNW1qxPv5CdWvwn6W","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"406b8a8f-8dd9-4a6c-ba34-f3c688a9ff18"}
