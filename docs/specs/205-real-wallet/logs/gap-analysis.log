{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018PYZtfDUdm3AbUiUjs7umu","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LqmPSJTQdyZE6wdQBS1muS","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4282,"cache_read_input_tokens":65755,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4282},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"cc2f3521-646c-4824-9be6-325a3304b092"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LqmPSJTQdyZE6wdQBS1muS","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  type ReactNode,\n     8→} from \"react\";\n     9→import { PublicKey } from \"@solana/web3.js\";\n    10→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    11→import type { UIMatch, CoinSide } from \"../types\";\n    12→import {\n    13→  fetchAllOpenMatches,\n    14→  fetchMatchByCreator,\n    15→  fetchMatch,\n    16→  buildCreateMatchTx,\n    17→  buildJoinMatchTx,\n    18→  buildCancelMatchTx,\n    19→  buildClaimPayoutTx,\n    20→} from \"../utils/chain\";\n    21→import { useWallet, useConnection } from \"@rng-utopia/wallet/hooks\";\n    22→\n    23→/** Parse Solana/wallet errors into user-friendly messages */\n    24→function parseTransactionError(err: unknown): string {\n    25→  const msg = err instanceof Error ? err.message : String(err);\n    26→\n    27→  // Wallet not connected\n    28→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    29→    return \"Wallet not connected. Please connect your wallet first.\";\n    30→  }\n    31→\n    32→  // User rejected\n    33→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    34→    return \"Transaction cancelled by user.\";\n    35→  }\n    36→\n    37→  // Insufficient funds (Solana runtime error)\n    38→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    39→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    40→  }\n    41→\n    42→  // Account already in use (match already exists)\n    43→  if (msg.includes(\"already in use\")) {\n    44→    return \"You already have an active match. Cancel it before creating a new one.\";\n    45→  }\n    46→\n    47→  // Network / RPC errors\n    48→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    49→    return \"Network error. Please check your connection and try again.\";\n    50→  }\n    51→\n    52→  // Anchor program errors\n    53→  if (msg.includes(\"InvalidPhase\")) {\n    54→    return \"This match is no longer available.\";\n    55→  }\n    56→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    57→    return \"You cannot join your own match.\";\n    58→  }\n    59→\n    60→  // Generic fallback\n    61→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    62→}\n    63→\n    64→interface CoinflipContextValue {\n    65→  // State\n    66→  activeMatch: UIMatch | null;\n    67→  openMatches: UIMatch[];\n    68→  userHistory: UIMatch[];\n    69→  selectedTier: Tier | null;\n    70→  selectedSide: CoinSide | null;\n    71→\n    72→  // Loading states\n    73→  loading: boolean;\n    74→  creating: boolean;\n    75→  joining: boolean;\n    76→  claiming: boolean;\n    77→  joiningMatchId: string | null;\n    78→\n    79→  // Error state\n    80→  error: string | null;\n    81→  clearError: () => void;\n    82→\n    83→  // Actions\n    84→  setSelectedTier: (tier: Tier | null) => void;\n    85→  setSelectedSide: (side: CoinSide | null) => void;\n    86→  createMatch: () => Promise<void>;\n    87→  joinMatch: (matchId: string) => Promise<void>;\n    88→  cancelMatch: () => Promise<void>;\n    89→  claimPayout: () => Promise<void>;\n    90→  clearActiveMatch: () => void;\n    91→  refreshMatches: () => void;\n    92→}\n    93→\n    94→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n    95→\n    96→export function CoinflipProvider({ children }: { children: ReactNode }) {\n    97→  const { connected, publicKey, sendTransaction } = useWallet();\n    98→  const { connection } = useConnection();\n    99→\n   100→  // Selection state\n   101→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   102→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   103→\n   104→  // Match state\n   105→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   106→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   107→  const [userHistory] = useState<UIMatch[]>([]);\n   108→\n   109→  // Loading states\n   110→  const [loading, setLoading] = useState(true);\n   111→  const [creating, setCreating] = useState(false);\n   112→  const [joining, setJoining] = useState(false);\n   113→  const [claiming, setClaiming] = useState(false);\n   114→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   115→\n   116→  // Error state\n   117→  const [error, setError] = useState<string | null>(null);\n   118→  const clearError = useCallback(() => setError(null), []);\n   119→\n   120→  // Fetch open matches from on-chain\n   121→  const refreshMatches = useCallback(() => {\n   122→    fetchAllOpenMatches(connection)\n   123→      .then((matches) => {\n   124→        setOpenMatches(matches);\n   125→        setLoading(false);\n   126→      })\n   127→      .catch(() => {\n   128→        setLoading(false);\n   129→      });\n   130→  }, [connection]);\n   131→\n   132→  // Initial load\n   133→  useEffect(() => {\n   134→    setLoading(true);\n   135→    refreshMatches();\n   136→  }, [refreshMatches]);\n   137→\n   138→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   139→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   140→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   141→\n   142→  useEffect(() => {\n   143→    const interval = setInterval(() => {\n   144→      refreshMatches();\n   145→\n   146→      // If there's an active match, refresh it too\n   147→      if (activeMatch) {\n   148→        const matchPda = new PublicKey(activeMatch.id);\n   149→        fetchMatch(connection, matchPda)\n   150→          .then((updated) => {\n   151→            if (updated) {\n   152→              setActiveMatch(updated);\n   153→            } else {\n   154→              // Match account closed (claimed or cancelled)\n   155→              setActiveMatch(null);\n   156→            }\n   157→          })\n   158→          .catch(() => {\n   159→            // Ignore polling errors\n   160→          });\n   161→      }\n   162→    }, pollInterval);\n   163→    return () => clearInterval(interval);\n   164→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   165→\n   166→  const createMatch = useCallback(async () => {\n   167→    if (!connected || !publicKey) {\n   168→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   169→      return;\n   170→    }\n   171→    if (!selectedTier || !selectedSide) {\n   172→      setError(\"Select tier and side first.\");\n   173→      return;\n   174→    }\n   175→\n   176→    setCreating(true);\n   177→    setError(null);\n   178→    try {\n   179→      const { transaction, matchPda } = await buildCreateMatchTx(\n   180→        connection,\n   181→        publicKey,\n   182→        selectedTier,\n   183→        selectedSide\n   184→      );\n   185→\n   186→      await sendTransaction(transaction);\n   187→\n   188→      // Fetch the created match from on-chain\n   189→      const match = await fetchMatch(connection, matchPda);\n   190→      if (match) {\n   191→        setActiveMatch(match);\n   192→      }\n   193→\n   194→      setSelectedSide(null);\n   195→      refreshMatches();\n   196→    } catch (err) {\n   197→      setError(parseTransactionError(err));\n   198→    } finally {\n   199→      setCreating(false);\n   200→    }\n   201→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n   202→\n   203→  const joinMatch = useCallback(\n   204→    async (matchId: string) => {\n   205→      if (!connected || !publicKey) {\n   206→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   207→        return;\n   208→      }\n   209→\n   210→      setJoining(true);\n   211→      setJoiningMatchId(matchId);\n   212→      setError(null);\n   213→      try {\n   214→        // matchId is the match PDA base58 — fetch to get the creator\n   215→        const matchPda = new PublicKey(matchId);\n   216→        const existingMatch = await fetchMatch(connection, matchPda);\n   217→        if (!existingMatch) {\n   218→          setError(\"Match not found. It may have been cancelled.\");\n   219→          return;\n   220→        }\n   221→\n   222→        const matchCreator = new PublicKey(existingMatch.player1);\n   223→        const transaction = await buildJoinMatchTx(\n   224→          connection,\n   225→          publicKey,\n   226→          matchCreator\n   227→        );\n   228→\n   229→        await sendTransaction(transaction);\n   230→\n   231→        // Fetch updated match\n   232→        const updated = await fetchMatch(connection, matchPda);\n   233→        if (updated) {\n   234→          setActiveMatch(updated);\n   235→        }\n   236→\n   237→        refreshMatches();\n   238→      } catch (err) {\n   239→        setError(parseTransactionError(err));\n   240→      } finally {\n   241→        setJoining(false);\n   242→        setJoiningMatchId(null);\n   243→      }\n   244→    },\n   245→    [connected, publicKey, connection, sendTransaction, refreshMatches]\n   246→  );\n   247→\n   248→  const cancelMatch = useCallback(async () => {\n   249→    if (!connected || !publicKey || !activeMatch) {\n   250→      setError(\"No active match to cancel.\");\n   251→      return;\n   252→    }\n   253→\n   254→    setError(null);\n   255→    try {\n   256→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   257→      await sendTransaction(transaction);\n   258→      setActiveMatch(null);\n   259→      refreshMatches();\n   260→    } catch (err) {\n   261→      setError(parseTransactionError(err));\n   262→    }\n   263→  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n   264→\n   265→  const claimPayout = useCallback(async () => {\n   266→    if (!connected || !publicKey || !activeMatch) {\n   267→      setError(\"No active match to claim.\");\n   268→      return;\n   269→    }\n   270→\n   271→    setClaiming(true);\n   272→    setError(null);\n   273→    try {\n   274→      const matchCreator = new PublicKey(activeMatch.player1);\n   275→      const opponent = activeMatch.player2\n   276→        ? new PublicKey(activeMatch.player2)\n   277→        : PublicKey.default;\n   278→\n   279→      const transaction = await buildClaimPayoutTx(\n   280→        connection,\n   281→        publicKey,\n   282→        matchCreator,\n   283→        opponent\n   284→      );\n   285→\n   286→      await sendTransaction(transaction);\n   287→\n   288→      // Update local state\n   289→      setActiveMatch({ ...activeMatch, claimed: true });\n   290→    } catch (err) {\n   291→      setError(parseTransactionError(err));\n   292→    } finally {\n   293→      setClaiming(false);\n   294→    }\n   295→  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n   296→\n   297→  // Track if user explicitly cleared the match\n   298→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   299→\n   300→  const clearActiveMatch = useCallback(() => {\n   301→    setActiveMatch(null);\n   302→    setUserClearedMatch(true);\n   303→    setError(null);\n   304→    refreshMatches();\n   305→  }, [refreshMatches]);\n   306→\n   307→  // Check for existing active match on wallet connect\n   308→  useEffect(() => {\n   309→    if (publicKey && !activeMatch && !userClearedMatch) {\n   310→      fetchMatchByCreator(connection, publicKey)\n   311→        .then((match) => {\n   312→          if (match) {\n   313→            setActiveMatch(match);\n   314→          }\n   315→        })\n   316→        .catch(() => {\n   317→          // No active match found\n   318→        });\n   319→    }\n   320→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   321→\n   322→  // Reset userClearedMatch when creating or joining a new match\n   323→  useEffect(() => {\n   324→    if (activeMatch) {\n   325→      setUserClearedMatch(false);\n   326→    }\n   327→  }, [activeMatch]);\n   328→\n   329→  const value: CoinflipContextValue = {\n   330→    activeMatch,\n   331→    openMatches,\n   332→    userHistory,\n   333→    selectedTier,\n   334→    selectedSide,\n   335→    loading,\n   336→    creating,\n   337→    joining,\n   338→    claiming,\n   339→    joiningMatchId,\n   340→    error,\n   341→    clearError,\n   342→    setSelectedTier,\n   343→    setSelectedSide,\n   344→    createMatch,\n   345→    joinMatch,\n   346→    cancelMatch,\n   347→    claimPayout,\n   348→    clearActiveMatch,\n   349→    refreshMatches,\n   350→  };\n   351→\n   352→  return (\n   353→    <CoinflipContext.Provider value={value}>\n   354→      {children}\n   355→    </CoinflipContext.Provider>\n   356→  );\n   357→}\n   358→\n   359→export function useCoinflip(): CoinflipContextValue {\n   360→  const context = useContext(CoinflipContext);\n   361→  if (!context) {\n   362→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   363→  }\n   364→  return context;\n   365→}\n   366→"}]},"parent_tool_use_id":null,"session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"f71a6122-15c6-44d6-8a49-205d3f700d43","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  type ReactNode,\n} from \"react\";\nimport { PublicKey } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet, useConnection } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse Solana/wallet errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  // Wallet not connected\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n\n  // User rejected\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n\n  // Insufficient funds (Solana runtime error)\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n\n  // Account already in use (match already exists)\n  if (msg.includes(\"already in use\")) {\n    return \"You already have an active match. Cancel it before creating a new one.\";\n  }\n\n  // Network / RPC errors\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n\n  // Anchor program errors\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This match is no longer available.\";\n  }\n  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    return \"You cannot join your own match.\";\n  }\n\n  // Generic fallback\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection, pollInterval]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendTransaction(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":366,"startLine":1,"totalLines":366}}}
