{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MefLcFNbqUWnd6qV52p5KF","type":"tool_result","content":"     1→import { useContext } from \"react\";\n     2→import { WalletContext } from \"./context\";\n     3→import { WalletContextValue } from \"./types\";\n     4→\n     5→export function useWallet(): WalletContextValue {\n     6→  const context = useContext(WalletContext);\n     7→  if (!context) {\n     8→    throw new Error(\"useWallet must be used within a WalletProvider\");\n     9→  }\n    10→  return context;\n    11→}\n    12→"}]},"parent_tool_use_id":"toolu_01U5ZaVqNW1qxPv5CdWvwn6W","session_id":"0f6af63c-d689-426d-9dd8-218925b8488a","uuid":"ea91f5bb-f7fa-4e74-b21b-048f9856cf20"}
