   });\n  });\n\n  test.describe(\"Profile page\", () => {\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/profile\");\n\n      // Click the wallet icon to trigger connect\n      await stablePage.locator(\".rpg-wallet-icon\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rpg-wallet-icon--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"profile-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Coinflip page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      // Clear any persisted wallet state to ensure disconnected\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/coinflip\");\n      await expect(stablePage).toHaveScreenshot(\"coinflip-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/coinflip\");\n\n      // Click the wallet icon to trigger connect\n      await stablePage.locator(\".rpg-wallet-icon\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rpg-wallet-icon--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"coinflip-connected.png\", { fullPage: true });\n    });\n  });\n});\n","numLines":133,"startLine":1,"totalLines":133}}}
