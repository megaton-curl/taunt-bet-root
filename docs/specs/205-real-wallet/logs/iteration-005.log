{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012MYVoo2yscppvzjp6aQUiX","type":"tool_result","content":"     1→// Context (standalone - no provider dependencies)\n     2→export { WalletContext } from \"./context\";\n     3→\n     4→// Core hooks (import context, not providers)\n     5→export { useWallet } from \"./useWallet\";\n     6→export { useBalance } from \"./useBalance\";\n     7→export type { WalletState, WalletContextValue } from \"./types\";\n     8→\n     9→// Mock wallet exports (lightweight - no adapter dependency)\n    10→export { MockWalletProvider, DEFAULT_MOCK_CONFIG } from \"./mock\";\n    11→export type { MockConfig } from \"./mock\";\n    12→\n    13→// Real wallet exports (lazy-loaded via WalletProvider, or direct import)\n    14→export { RealWalletProvider } from \"./real\";\n    15→\n    16→// Test wallet exports (for E2E against local test-validator)\n    17→export { TestWalletProvider } from \"./test\";\n    18→\n    19→// Full wallet provider\n    20→export { WalletProvider } from \"./WalletProvider\";\n    21→\n    22→// Balance utilities\n    23→export { solToLamports, lamportsToSol } from \"./mock\";\n    24→export {\n    25→  formatAmount,\n    26→  formatAmountCompact,\n    27→  lamportsToSOL,\n    28→  SOLToLamports,\n    29→  formatBalanceDisplay,\n    30→  parseSOLInput,\n    31→  isValidSOLAmount,\n    32→} from \"./balance\";\n    33→export type { BalanceResult } from \"./useBalance\";\n    34→\n    35→// Transaction management\n    36→export {\n    37→  TransactionProvider,\n    38→  useTransaction,\n    39→} from \"./transactions\";\n    40→export type {\n    41→  TransactionState,\n    42→  TransactionStatus,\n    43→  TransactionContextValue,\n    44→} from \"./transactions\";\n    45→\n    46→// Treasury utilities\n    47→export {\n    48→  FEE_CONSTANTS,\n    49→  FEE_BREAKDOWN,\n    50→  LIMITS,\n    51→  PROGRAM_IDS,\n    52→  TREASURY_ADDRESSES,\n    53→  calculateFee,\n    54→  calculatePayout,\n    55→  calculateFeeBreakdown,\n    56→} from \"./treasury\";\n    57→"}]},"parent_tool_use_id":"toolu_017Yu3A84GWfFXspsRfxzQMN","session_id":"1e81398f-978c-4fff-848f-a37f36dac162","uuid":"5dd6f8e1-b2f2-4e11-97d1-047301a1b7c3"}
