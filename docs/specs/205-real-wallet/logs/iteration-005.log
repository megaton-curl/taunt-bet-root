{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N3wVai4s7wPEH6rpLdp826","type":"tool_result","content":"     1→import { ReactNode, useState, useCallback, useEffect } from \"react\";\n     2→import { PublicKey, Transaction } from \"@solana/web3.js\";\n     3→import { WalletContext } from \"../context\";\n     4→import { WalletContextValue, WalletState } from \"../types\";\n     5→import {\n     6→  MockConfig,\n     7→  DEFAULT_MOCK_CONFIG,\n     8→  createMockKeypair,\n     9→  loadPersistedState,\n    10→  persistState,\n    11→  clearPersistedState,\n    12→  generateMockSignature,\n    13→  delay,\n    14→  solToLamports,\n    15→  lamportsToSol,\n    16→  getPublicKeyFromAddress,\n    17→} from \"./MockWalletState\";\n    18→\n    19→interface MockWalletProviderProps {\n    20→  children: ReactNode;\n    21→  config?: Partial<MockConfig>;\n    22→}\n    23→\n    24→const initialState: WalletState = {\n    25→  connected: false,\n    26→  connecting: false,\n    27→  address: null,\n    28→  publicKey: null,\n    29→};\n    30→\n    31→export function MockWalletProvider({\n    32→  children,\n    33→  config: userConfig,\n    34→}: MockWalletProviderProps) {\n    35→  const config: MockConfig = { ...DEFAULT_MOCK_CONFIG, ...userConfig };\n    36→\n    37→  const [state, setState] = useState<WalletState>(initialState);\n    38→  const [balanceLamports, setBalanceLamports] = useState<number>(\n    39→    solToLamports(config.initialBalance)\n    40→  );\n    41→\n    42→  // Load persisted state on mount\n    43→  useEffect(() => {\n    44→    if (config.persistState) {\n    45→      const persisted = loadPersistedState();\n    46→      if (persisted) {\n    47→        setBalanceLamports(persisted.balance);\n    48→        if (config.autoConnect) {\n    49→          const pubKey = getPublicKeyFromAddress(persisted.address);\n    50→          setState({\n    51→            connected: true,\n    52→            connecting: false,\n    53→            address: persisted.address,\n    54→            publicKey: pubKey,\n    55→          });\n    56→        }\n    57→      }\n    58→    }\n    59→  }, [config.persistState, config.autoConnect]);\n    60→\n    61→  // Persist state changes\n    62→  useEffect(() => {\n    63→    if (config.persistState && state.connected && state.address) {\n    64→      persistState({\n    65→        address: state.address,\n    66→        balance: balanceLamports,\n    67→      });\n    68→    }\n    69→  }, [config.persistState, state.connected, state.address, balanceLamports]);\n    70→\n    71→  const connect = useCallback(async () => {\n    72→    setState((prev) => ({ ...prev, connecting: true }));\n    73→\n    74→    try {\n    75→      await delay(config.simulatedLatency);\n    76→\n    77→      // Check for persisted state first\n    78→      const persisted = loadPersistedState();\n    79→      let address: string;\n    80→      let pubKey: PublicKey;\n    81→\n    82→      if (persisted) {\n    83→        address = persisted.address;\n    84→        pubKey = getPublicKeyFromAddress(address);\n    85→        setBalanceLamports(solToLamports(config.initialBalance));\n    86→      } else {\n    87→        // Generate new mock keypair\n    88→        const keypair = createMockKeypair();\n    89→        address = keypair.publicKey.toBase58();\n    90→        pubKey = keypair.publicKey;\n    91→        setBalanceLamports(solToLamports(config.initialBalance));\n    92→      }\n    93→\n    94→      setState({\n    95→        connected: true,\n    96→        connecting: false,\n    97→        address,\n    98→        publicKey: pubKey,\n    99→      });\n   100→    } catch (error) {\n   101→      console.error(\"Mock wallet connect failed:\", error);\n   102→      setState((prev) => ({ ...prev, connecting: false }));\n   103→      throw error;\n   104→    }\n   105→  }, [config.simulatedLatency, config.initialBalance]);\n   106→\n   107→  const disconnect = useCallback(async () => {\n   108→    await delay(config.simulatedLatency / 2);\n   109→\n   110→    if (!config.persistState) {\n   111→      clearPersistedState();\n   112→    }\n   113→\n   114→    setState(initialState);\n   115→  }, [config.simulatedLatency, config.persistState]);\n   116→\n   117→  const sendTransaction = useCallback(\n   118→    async (_transaction: Transaction): Promise<string> => {\n   119→      if (!state.connected) {\n   120→        throw new Error(\"Wallet not connected\");\n   121→      }\n   122→\n   123→      await delay(config.simulatedLatency);\n   124→\n   125→      // Simulate random failure (5% chance)\n   126→      if (Math.random() < 0.05) {\n   127→        throw new Error(\"Mock transaction simulation failed\");\n   128→      }\n   129→\n   130→      // Return mock signature\n   131→      return generateMockSignature();\n   132→    },\n   133→    [state.connected, config.simulatedLatency]\n   134→  );\n   135→\n   136→  const signMessage = useCallback(\n   137→    async (_message: Uint8Array): Promise<Uint8Array> => {\n   138→      if (!state.connected) {\n   139→        throw new Error(\"Wallet not connected\");\n   140→      }\n   141→\n   142→      await delay(config.simulatedLatency / 2);\n   143→\n   144→      // Return mock signature (64 bytes)\n   145→      const mockSig = new Uint8Array(64);\n   146→      crypto.getRandomValues(mockSig);\n   147→      return mockSig;\n   148→    },\n   149→    [state.connected, config.simulatedLatency]\n   150→  );\n   151→\n   152→  // Expose balance management for mock transactions\n   153→  const updateBalance = useCallback((deltaLamports: number) => {\n   154→    setBalanceLamports((prev) => Math.max(0, prev + deltaLamports));\n   155→  }, []);\n   156→\n   157→  const getBalance = useCallback(() => {\n   158→    return lamportsToSol(balanceLamports);\n   159→  }, [balanceLamports]);\n   160→\n   161→  const getBalanceLamports = useCallback(() => {\n   162→    return balanceLamports;\n   163→  }, [balanceLamports]);\n   164→\n   165→  // Extended context value with mock-specific methods\n   166→  const value: WalletContextValue & {\n   167→    updateBalance: (deltaLamports: number) => void;\n   168→    getBalance: () => number;\n   169→    getBalanceLamports: () => number;\n   170→    isMock: boolean;\n   171→  } = {\n   172→    ...state,\n   173→    connect,\n   174→    disconnect,\n   175→    sendTransaction,\n   176→    signMessage,\n   177→    updateBalance,\n   178→    getBalance,\n   179→    getBalanceLamports,\n   180→    isMock: true,\n   181→  };\n   182→\n   183→  return (\n   184→    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n   185→  );\n   186→}\n   187→"}]},"parent_tool_use_id":"toolu_017Yu3A84GWfFXspsRfxzQMN","session_id":"1e81398f-978c-4fff-848f-a37f36dac162","uuid":"b10cd11f-e2d6-401f-940c-576dae4537c7"}
