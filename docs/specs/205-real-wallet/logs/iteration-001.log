{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cwap6jBmDUWPwwhXDzNJeL","type":"tool_result","content":"     1→import { ReactNode, lazy, Suspense } from \"react\";\n     2→import { MockWalletProvider } from \"./mock\";\n     3→\n     4→// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     5→const RealWalletProvider = lazy(() =>\n     6→  import(\"./real/RealWalletProvider\").then((m) => ({\n     7→    default: m.RealWalletProvider,\n     8→  })),\n     9→);\n    10→\n    11→// Re-export WalletContext from the shared context file\n    12→export { WalletContext } from \"./context\";\n    13→\n    14→interface WalletProviderProps {\n    15→  children: ReactNode;\n    16→}\n    17→\n    18→function isMockMode(): boolean {\n    19→  const flag =\n    20→    typeof import.meta !== \"undefined\"\n    21→      ? import.meta.env?.VITE_MOCK_MODE\n    22→      : undefined;\n    23→  // Default to mock mode when unset or explicitly \"true\"\n    24→  return flag === undefined || flag === \"\" || flag === \"true\";\n    25→}\n    26→\n    27→/**\n    28→ * Unified WalletProvider.\n    29→ * Delegates to MockWalletProvider or RealWalletProvider based on VITE_MOCK_MODE.\n    30→ */\n    31→export function WalletProvider({ children }: WalletProviderProps) {\n    32→  if (isMockMode()) {\n    33→    return <MockWalletProvider>{children}</MockWalletProvider>;\n    34→  }\n    35→\n    36→  return (\n    37→    <Suspense fallback={null}>\n    38→      <RealWalletProvider>{children}</RealWalletProvider>\n    39→    </Suspense>\n    40→  );\n    41→}\n    42→"}]},"parent_tool_use_id":"toolu_017q3EMcjcKziJekWkE24mre","session_id":"dcb8cfea-3149-4f02-a81d-4deae733513a","uuid":"c99a46bd-4287-4c76-baa9-e99e95fb038f"}
