{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UhtMFSZ9SdNWfnZevd8DK5","type":"tool_result","content":"     1→{\n     2→  \"name\": \"@rng-utopia/wallet\",\n     3→  \"version\": \"0.1.0\",\n     4→  \"private\": true,\n     5→  \"type\": \"module\",\n     6→  \"main\": \"./src/index.ts\",\n     7→  \"types\": \"./src/index.ts\",\n     8→  \"exports\": {\n     9→    \".\": \"./src/index.ts\",\n    10→    \"./mock\": \"./src/mock/index.ts\",\n    11→    \"./real\": \"./src/real/index.ts\",\n    12→    \"./test\": \"./src/test/index.ts\",\n    13→    \"./context\": \"./src/context.ts\",\n    14→    \"./hooks\": {\n    15→      \"import\": \"./src/hooks.ts\",\n    16→      \"types\": \"./src/hooks.ts\"\n    17→    }\n    18→  },\n    19→  \"scripts\": {\n    20→    \"lint\": \"eslint .\",\n    21→    \"lint:fix\": \"eslint . --fix\",\n    22→    \"typecheck\": \"tsc --noEmit\"\n    23→  },\n    24→  \"dependencies\": {\n    25→    \"@jup-ag/wallet-adapter\": \"^0.2.6\",\n    26→    \"@solana/wallet-adapter-base\": \"^0.9.23\",\n    27→    \"@solana/wallet-adapter-react\": \"^0.15.35\",\n    28→    \"@solana/web3.js\": \"^1.98.0\",\n    29→    \"react\": \"^18.3.1\"\n    30→  },\n    31→  \"devDependencies\": {\n    32→    \"@rng-utopia/config\": \"workspace:*\",\n    33→    \"@types/react\": \"^18.3.0\",\n    34→    \"typescript\": \"^5.7.0\",\n    35→    \"vite\": \"^6.0.0\"\n    36→  },\n    37→  \"peerDependencies\": {\n    38→    \"react\": \"^18.0.0\"\n    39→  }\n    40→}\n    41→"}]},"parent_tool_use_id":"toolu_017q3EMcjcKziJekWkE24mre","session_id":"dcb8cfea-3149-4f02-a81d-4deae733513a","uuid":"72cfa41e-75f8-4bcc-8c4d-7e4acb0a2211"}
