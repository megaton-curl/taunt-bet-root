{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SyhUUJLZxKmJJEyUeddiTQ","type":"tool_result","content":"     1→import { useContext } from \"react\";\n     2→import { WalletContext } from \"./context\";\n     3→import { WalletContextValue } from \"./types\";\n     4→\n     5→export function useWallet(): WalletContextValue {\n     6→  const context = useContext(WalletContext);\n     7→  if (!context) {\n     8→    throw new Error(\"useWallet must be used within a WalletProvider\");\n     9→  }\n    10→  return context;\n    11→}\n    12→"}]},"parent_tool_use_id":"toolu_017q3EMcjcKziJekWkE24mre","session_id":"dcb8cfea-3149-4f02-a81d-4deae733513a","uuid":"92c1f5c4-a5f1-4745-9932-d30af1f25234"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01DxLJn8qm1JaZTUe3eBjtqr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NUsPN4foVWdjh4bew7GChJ","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/useBalance.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":5,"cache_creation_input_tokens":774,"cache_read_input_tokens":23783,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":774},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017q3EMcjcKziJekWkE24mre","session_id":"dcb8cfea-3149-4f02-a81d-4deae733513a","uuid":"b06dfaf4-c48f-427c-a789-bbdd3114976a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NUsPN4foVWdjh4bew7GChJ","type":"tool_result","content":"     1→import { useState, useEffect, useCallback, useRef } from \"react\";\n     2→import { Connection, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\n     3→import { useWallet } from \"./useWallet\";\n     4→import { formatAmount, formatAmountCompact } from \"./balance\";\n     5→\n     6→export interface BalanceResult {\n     7→  /** Balance in SOL (null if not connected or loading) */\n     8→  balance: number | null;\n     9→  /** Balance in lamports (null if not connected or loading) */\n    10→  balanceLamports: number | null;\n    11→  /** Loading state */\n    12→  loading: boolean;\n    13→  /** Error if fetch failed */\n    14→  error: Error | null;\n    15→  /** Manually refresh the balance */\n    16→  refresh: () => Promise<void>;\n    17→  /** Formatted balance (e.g., \"1.2345\") */\n    18→  formatted: string | null;\n    19→  /** Compact formatted balance (e.g., \"1.2k\") */\n    20→  formattedCompact: string | null;\n    21→  /** Last update timestamp */\n    22→  lastUpdated: Date | null;\n    23→}\n    24→\n    25→interface UseBalanceOptions {\n    26→  /** Polling interval in ms (default: 10000, set to 0 to disable) */\n    27→  pollInterval?: number;\n    28→  /** Custom RPC URL (defaults to env variable or devnet) */\n    29→  rpcUrl?: string;\n    30→}\n    31→\n    32→const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    33→const DEFAULT_POLL_INTERVAL = 10_000; // 10 seconds\n    34→\n    35→function getRpcUrl(customUrl?: string): string {\n    36→  if (customUrl) return customUrl;\n    37→\n    38→  // Check environment variable\n    39→  const envUrl = import.meta.env?.VITE_RPC_URL;\n    40→  if (envUrl) return envUrl;\n    41→\n    42→  return DEFAULT_RPC_URL;\n    43→}\n    44→\n    45→export function useBalance(options: UseBalanceOptions = {}): BalanceResult {\n    46→  const { pollInterval = DEFAULT_POLL_INTERVAL, rpcUrl: customRpcUrl } =\n    47→    options;\n    48→\n    49→  const wallet = useWallet();\n    50→  const { publicKey, connected, isMock, getBalanceLamports: getMockBalance } = wallet;\n    51→  const [balanceLamports, setBalanceLamports] = useState<number | null>(null);\n    52→  const [loading, setLoading] = useState(false);\n    53→  const [error, setError] = useState<Error | null>(null);\n    54→  const [lastUpdated, setLastUpdated] = useState<Date | null>(null);\n    55→\n    56→  const connectionRef = useRef<Connection | null>(null);\n    57→  const pollIntervalRef = useRef<ReturnType<typeof setInterval> | null>(null);\n    58→\n    59→  // Get or create connection\n    60→  const getConnection = useCallback(() => {\n    61→    const rpcUrl = getRpcUrl(customRpcUrl);\n    62→    if (!connectionRef.current) {\n    63→      connectionRef.current = new Connection(rpcUrl, \"confirmed\");\n    64→    }\n    65→    return connectionRef.current;\n    66→  }, [customRpcUrl]);\n    67→\n    68→  // Fetch balance (mock or real)\n    69→  const fetchBalance = useCallback(async () => {\n    70→    if (!connected || !publicKey) {\n    71→      setBalanceLamports(null);\n    72→      setError(null);\n    73→      return;\n    74→    }\n    75→\n    76→    setLoading(true);\n    77→    setError(null);\n    78→\n    79→    try {\n    80→      // Use mock balance if in mock mode\n    81→      if (isMock && getMockBalance) {\n    82→        const lamports = getMockBalance();\n    83→        setBalanceLamports(lamports);\n    84→        setLastUpdated(new Date());\n    85→      } else {\n    86→        // Fetch from RPC for real wallet\n    87→        const connection = getConnection();\n    88→        const lamports = await connection.getBalance(publicKey);\n    89→        setBalanceLamports(lamports);\n    90→        setLastUpdated(new Date());\n    91→      }\n    92→    } catch (err) {\n    93→      console.error(\"Failed to fetch balance:\", err);\n    94→      setError(\n    95→        err instanceof Error ? err : new Error(\"Failed to fetch balance\")\n    96→      );\n    97→    } finally {\n    98→      setLoading(false);\n    99→    }\n   100→  }, [connected, publicKey, getConnection, isMock, getMockBalance]);\n   101→\n   102→  // Initial fetch and polling\n   103→  useEffect(() => {\n   104→    // Clear previous interval\n   105→    if (pollIntervalRef.current) {\n   106→      clearInterval(pollIntervalRef.current);\n   107→      pollIntervalRef.current = null;\n   108→    }\n   109→\n   110→    // Reset state if disconnected\n   111→    if (!connected || !publicKey) {\n   112→      setBalanceLamports(null);\n   113→      setError(null);\n   114→      setLastUpdated(null);\n   115→      return;\n   116→    }\n   117→\n   118→    // Initial fetch\n   119→    fetchBalance();\n   120→\n   121→    // Set up polling if enabled\n   122→    if (pollInterval > 0) {\n   123→      pollIntervalRef.current = setInterval(fetchBalance, pollInterval);\n   124→    }\n   125→\n   126→    return () => {\n   127→      if (pollIntervalRef.current) {\n   128→        clearInterval(pollIntervalRef.current);\n   129→        pollIntervalRef.current = null;\n   130→      }\n   131→    };\n   132→  }, [connected, publicKey, pollInterval, fetchBalance]);\n   133→\n   134→  // Cleanup connection on unmount\n   135→  useEffect(() => {\n   136→    return () => {\n   137→      connectionRef.current = null;\n   138→    };\n   139→  }, []);\n   140→\n   141→  // Manual refresh\n   142→  const refresh = useCallback(async () => {\n   143→    await fetchBalance();\n   144→  }, [fetchBalance]);\n   145→\n   146→  // Calculate derived values\n   147→  const balance =\n   148→    balanceLamports !== null ? balanceLamports / LAMPORTS_PER_SOL : null;\n   149→  const formatted =\n   150→    balanceLamports !== null ? formatAmount(balanceLamports) : null;\n   151→  const formattedCompact =\n   152→    balanceLamports !== null ? formatAmountCompact(balanceLamports) : null;\n   153→\n   154→  return {\n   155→    balance,\n   156→    balanceLamports,\n   157→    loading,\n   158→    error,\n   159→    refresh,\n   160→    formatted,\n   161→    formattedCompact,\n   162→    lastUpdated,\n   163→  };\n   164→}\n   165→"}]},"parent_tool_use_id":"toolu_017q3EMcjcKziJekWkE24mre","session_id":"dcb8cfea-3149-4f02-a81d-4deae733513a","uuid":"80592b6f-ed47-4e2e-9fb1-fa9b4e197f66"}
