{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EmH85o68eDaww13hRCawGh","type":"tool_result","content":"     1→import { useState, useEffect, useRef } from \"react\";\n     2→import { BrowserRouter, Routes, Route, Link, NavLink, useLocation, useNavigate } from \"react-router-dom\";\n     3→import { CoinflipPage } from \"./pages/CoinflipPage\";\n     4→import { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\n     5→import { CloseCallPage } from \"./pages/CloseCallPage\";\n     6→import { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\n     7→import { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\n     8→import { BossRaidProvider, HeaderBossRaid, BossRaidModal, RNGBuffIndicator } from \"./features/boss-raid\";\n     9→import { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatar, PlayerAvatarCompact, getOrCreateProfile } from \"./features/player-profile\";\n    10→import { QuestsProvider, ChestDropNotification, useQuests } from \"./features/quests\";\n    11→import { QuestsPage } from \"./pages/QuestsPage\";\n    12→import { LootPage } from \"./pages/LootPage\";\n    13→import { useWallet, useBalance } from \"@rng-utopia/wallet/hooks\";\n    14→// WalletButton replaced by inline rpg-wallet-icon in scene area\n    15→\n    16→export function App() {\n    17→  return (\n    18→    <BrowserRouter>\n    19→      <PlayerProfileProvider>\n    20→        <QuestsProvider>\n    21→          <BossRaidProvider>\n    22→            <AppContent />\n    23→            <MiniProfileModal />\n    24→            <ChestDropNotification />\n    25→          </BossRaidProvider>\n    26→        </QuestsProvider>\n    27→      </PlayerProfileProvider>\n    28→    </BrowserRouter>\n    29→  );\n    30→}\n    31→\n    32→\n    33→// FAQ sections data\n    34→const faqSections = [\n    35→    {\n    36→      id: \"fees\",\n    37→      title: \"Platform Fees\",\n    38→      content: `RNG Wooftopia charges a 3% platform fee on all games. This means 97% of all wagered funds go directly to winners.\n    39→\n    40→Fee breakdown:\n    41→• 1% goes to player incentives (RNG Raid Boss reward pool, future promotions)\n    42→• 2% goes to platform treasury (server costs, development, operations)\n    43→\n    44→What you get:\n    45→• Winners receive: 97% of the pot\n    46→• No hidden fees or withdrawal charges\n    47→• Part of your wagers fund rewards you can win back through Raid Boss`\n    48→    },\n    49→    {\n    50→      id: \"raid-boss\",\n    51→      title: \"What is RNG Raid Boss?\",\n    52→      content: `RNG Raid Boss is a community reward mechanic where players collectively battle a boss by playing games.\n    53→\n    54→How it works:\n    55→• A new boss spawns every hour with a 50-minute active phase\n    56→• Every wager you make in any game deals \"damage\" to the boss\n    57→• The boss HP drains over time - it's always defeated when the timer ends\n    58→• When defeated, the reward pool is distributed to all participants\n    59→\n    60→Rewards:\n    61→• Your share is proportional to your damage contribution\n    62→• The reward pool grows from 1% of all wagers during the raid\n    63→• Higher total community damage = better loot tier = bigger multipliers\n    64→• Bonus loot is occasionally added for extra rewards\n    65→\n    66→Loot Tiers (based on total damage):\n    67→• Bronze: $0-$10 damage\n    68→• Silver: $10-$50 damage\n    69→• Gold: $50-$150 damage\n    70→• Emerald: $150-$500 damage\n    71→• Diamond: $500+ damage`\n    72→    },\n    73→    {\n    74→      id: \"pvp\",\n    75→      title: \"Why PvP Games?\",\n    76→      content: `Unlike traditional house-edge gambling where you play against the casino, RNG Wooftopia is 100% player-vs-player. This creates a fundamentally fairer system:\n    77→\n    78→• No house edge exploiting players\n    79→• Prize pools come entirely from player wagers\n    80→• The platform only takes a small facilitation fee\n    81→• Better odds than any traditional casino\n    82→• Transparent, skill-independent wagering`\n    83→    },\n    84→    {\n    85→      id: \"tiers\",\n    86→      title: \"Wagering Tiers\",\n    87→      content: `RNG Wooftopia uses wagering tiers to match players with similar risk appetites together. Each tier has a fixed $ amount - you play against others wagering the same amount.\n    88→\n    89→Available Tiers:\n    90→• Iron: $0.50\n    91→• Bronze: $1\n    92→• Silver: $5\n    93→• Gold: $10\n    94→• Emerald: $25\n    95→• Diamond: $100\n    96→\n    97→How it works:\n    98→• Each game has separate lobbies for each tier\n    99→• Select your tier before joining a game\n   100→• You're matched only with players in the same tier\n   101→• Everyone in the round wagers the exact same amount\n   102→\n   103→Benefits:\n   104→• Fair matchmaking - compete on equal footing\n   105→• Choose the risk level you're comfortable with\n   106→• No whales dominating smaller players`\n   107→    },\n   108→    {\n   109→      id: \"leaderboard\",\n   110→      title: \"Leaderboard System\",\n   111→      content: `Leaderboard system details coming soon.\n   112→\n   113→We're working on implementing competitive leaderboards to track and reward top players. Stay tuned for updates!`\n   114→    },\n   115→    {\n   116→      id: \"fairness\",\n   117→      title: \"On-Chain Fairness\",\n   118→      content: `All game outcomes are provably fair using cryptographic verification:\n   119→\n   120→Commit-Reveal Pattern (Crash, Close Call):\n   121→1. Server publishes a hash of its seed before betting\n   122→2. Solana blockhash becomes the public seed\n   123→3. After the round, server reveals its seed\n   124→4. Anyone can verify the outcome matches\n   125→\n   126→On-Chain VRF (Lord of RNGs, Coinflip):\n   127→1. Game requests randomness from VRF provider\n   128→2. VRF generates verifiable random bytes\n   129→3. Result and proof stored on Solana blockchain\n   130→4. Anyone can verify using blockchain explorer\n   131→\n   132→Visit the Fairness page in the header for verification tools.`\n   133→    },\n   134→    {\n   135→      id: \"rng-buff\",\n   136→      title: \"RNG Buff\",\n   137→      content: `The RNG Buff is a powerful temporary bonus granted to players who help defeat the Raid Boss before the timer expires.\n   138→\n   139→How to get the RNG Buff:\n   140→1. Participate in the hourly Raid Boss by wagering in any game\n   141→2. Your wagers deal \"damage\" to the boss\n   142→3. If the boss is defeated before time runs out, ALL participants receive the buff\n   143→4. The buff lasts for 1 hour (until the next raid starts)\n   144→\n   145→Buff Benefits:\n   146→• Golden glowing border on your avatar (visible to all players)\n   147→• Chance to drop treasure chests when wagering\n   148→• Drop chance scales with wager amount (1% base + 5% per $1, max 25%)\n   149→\n   150→Visual Indicators:\n   151→• Golden pulsing border around your avatar everywhere in the app\n   152→• RNG Buff icon with countdown timer in your profile header\n   153→• Star icon with timer in the main header\n   154→\n   155→The buff expires when the next raid begins, so make the most of it!`\n   156→    },\n   157→    {\n   158→      id: \"treasure-chests\",\n   159→      title: \"Treasure Chests\",\n   160→      content: `Treasure chests are mystery rewards that contain XP and $ prizes. Open them in the Loot page.\n   161→\n   162→How to earn chests:\n   163→• RNG Buff drops: Random chance when wagering with active RNG Buff\n   164→• Complete ALL daily quests: 1 chest\n   165→• Complete weekly quests: 1 chest per quest (3 total)\n   166→• Complete ALL weekly quests: +2 bonus chests (5 total)\n   167→\n   168→RNG Buff chest drop rates:\n   169→• Base chance: 1% per wager\n   170→• Bonus: +5% per $1 wagered\n   171→• Maximum: 25% chance per wager\n   172→\n   173→Chest rarity (determined when opened):\n   174→• Common (50%): 50-100 XP, $0.001-$0.005\n   175→• Uncommon (30%): 100-250 XP, $0.005-$0.01\n   176→• Rare (15%): 250-500 XP, $0.01-$0.025\n   177→• Epic (4%): 500-1000 XP, $0.025-$0.05\n   178→• Legendary (1%): 1000-2500 XP, $0.05-$0.1\n   179→\n   180→$ rewards are paid from the platform treasury. May the RNG gods smile upon you!`\n   181→    },\n   182→  ];\n   183→\n   184→// Terms Modal component\n   185→function TermsModal({ onClose }: { onClose: () => void }) {\n   186→  const ref = useRef<HTMLDivElement>(null);\n   187→\n   188→  useEffect(() => {\n   189→    const handle = (e: MouseEvent) => {\n   190→      if (ref.current && !ref.current.contains(e.target as Node)) onClose();\n   191→    };\n   192→    const esc = (e: KeyboardEvent) => { if (e.key === \"Escape\") onClose(); };\n   193→    document.addEventListener(\"mousedown\", handle);\n   194→    document.addEventListener(\"keydown\", esc);\n   195→    return () => { document.removeEventListener(\"mousedown\", handle); document.removeEventListener(\"keydown\", esc); };\n   196→  }, [onClose]);\n   197→\n   198→  return (\n   199→    <div className=\"footer-terms-overlay\">\n   200→      <div className=\"footer-terms-modal\" ref={ref}>\n   201→        <button type=\"button\" className=\"footer-terms-close\" onClick={onClose}>×</button>\n   202→        <h3 className=\"footer-terms-title\">Terms of Use</h3>\n   203→        <div className=\"footer-terms-content\">\n   204→          <p>By accessing and using RNG Wooftopia, you confirm that you are not a citizen, resident, or located within any jurisdiction where online gambling is prohibited or restricted by law, including but not limited to: the United States, United Kingdom, France, Germany, Spain, the Netherlands, or any other jurisdiction with similar regulations.</p>\n   205→          <p>You are solely responsible for determining whether your use of this platform is lawful in your country or region of residence. RNG Wooftopia does not provide legal advice and assumes no liability for users who access the platform in violation of applicable laws.</p>\n   206→          <p>By continuing to use this service, you acknowledge and accept these terms.</p>\n   207→        </div>\n   208→        <button type=\"button\" className=\"footer-terms-accept\" onClick={onClose}>I Understand</button>\n   209→      </div>\n   210→    </div>\n   211→  );\n   212→}\n   213→\n   214→// FAQ Modal component\n   215→function FAQModal({ onClose }: { onClose: () => void }) {\n   216→  const ref = useRef<HTMLDivElement>(null);\n   217→  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n   218→\n   219→  useEffect(() => {\n   220→    const handle = (e: MouseEvent) => {\n   221→      if (ref.current && !ref.current.contains(e.target as Node)) onClose();\n   222→    };\n   223→    const esc = (e: KeyboardEvent) => { if (e.key === \"Escape\") onClose(); };\n   224→    document.addEventListener(\"mousedown\", handle);\n   225→    document.addEventListener(\"keydown\", esc);\n   226→    return () => { document.removeEventListener(\"mousedown\", handle); document.removeEventListener(\"keydown\", esc); };\n   227→  }, [onClose]);\n   228→\n   229→  return (\n   230→    <div className=\"footer-faq-overlay\">\n   231→      <div className=\"footer-faq-modal\" ref={ref}>\n   232→        <button type=\"button\" className=\"footer-faq-close\" onClick={onClose}>×</button>\n   233→        <h3 className=\"footer-faq-title\">Frequently Asked Questions</h3>\n   234→        <div className=\"footer-faq-content\">\n   235→          {faqSections.map((section) => (\n   236→            <div key={section.id} className=\"faq-section\">\n   237→              <button type=\"button\" className={`faq-section-header ${expandedFAQ === section.id ? \"expanded\" : \"\"}`} onClick={() => setExpandedFAQ(expandedFAQ === section.id ? null : section.id)}>\n   238→                <span className=\"faq-section-title\">{section.title}</span>\n   239→                <span className=\"faq-section-arrow\">{expandedFAQ === section.id ? \"−\" : \"+\"}</span>\n   240→              </button>\n   241→              {expandedFAQ === section.id && (\n   242→                <div className=\"faq-section-content\">\n   243→                  {section.content.split(\"\\n\\n\").map((paragraph, idx) => (\n   244→                    <p key={idx}>{paragraph}</p>\n   245→                  ))}\n   246→                </div>\n   247→              )}\n   248→            </div>\n   249→          ))}\n   250→        </div>\n   251→        <button type=\"button\" className=\"footer-faq-close-btn\" onClick={onClose}>Close</button>\n   252→      </div>\n   253→    </div>\n   254→  );\n   255→}\n   256→\n   257→// FooterModals - renders Terms and FAQ modals (triggered from Info popover)\n   258→function FooterModals() {\n   259→  // These modals are now triggered from the InfoPopover component\n   260→  // This component is kept as a placeholder for any global footer-level modals\n   261→  return null;\n   262→}\n   263→\n   264→\n   265→function AppContent() {\n   266→  const [chatExpanded, setChatExpanded] = useState(false);\n   267→  const [showInfoPopover, setShowInfoPopover] = useState(false);\n   268→  const navigate = useNavigate();\n   269→  const { connected, connecting, address, connect, disconnect } = useWallet();\n   270→  const { formatted } = useBalance();\n   271→  const infoRef = useRef<HTMLDivElement>(null);\n   272→\n   273→  // Close info popover on outside click\n   274→  useEffect(() => {\n   275→    if (!showInfoPopover) return;\n   276→    const handle = (e: MouseEvent) => {\n   277→      if (infoRef.current && !infoRef.current.contains(e.target as Node)) {\n   278→        setShowInfoPopover(false);\n   279→      }\n   280→    };\n   281→    document.addEventListener(\"mousedown\", handle);\n   282→    return () => document.removeEventListener(\"mousedown\", handle);\n   283→  }, [showInfoPopover]);\n   284→\n   285→  return (\n   286→    <div className=\"app rpg-menu\">\n   287→      {/* Background Scene (static composited image) */}\n   288→      <div className=\"rpg-scene-bg\" />\n   289→\n   290→      {/* Shooting Stars */}\n   291→      <div className=\"shooting-star shooting-star--1\" />\n   292→      <div className=\"shooting-star shooting-star--2\" />\n   293→      <div className=\"shooting-star shooting-star--3\" />\n   294→      <div className=\"shooting-star shooting-star--4\" />\n   295→      <div className=\"shooting-star shooting-star--5\" />\n   296→\n   297→      {/* HUD: Top-left - Raid Boss */}\n   298→      <div className=\"rpg-hud rpg-hud--top-left\">\n   299→        <HeaderBossRaid />\n   300→      </div>\n   301→      <BossRaidModal />\n   302→\n   303→      {/* HUD: Top-right - Chat (positioned below the moon) */}\n   304→      <div className=\"rpg-hud rpg-hud--top-right\">\n   305→        {/* Chat Panel (toggled by campfire) */}\n   306→        <div className={`rpg-chat-panel ${chatExpanded ? \"expanded\" : \"\"}`}>\n   307→          <div className=\"chat-panel-header\">\n   308→            <h4>Global Chat</h4>\n   309→            <button className=\"chat-close\" onClick={() => setChatExpanded(false)}>×</button>\n   310→          </div>\n   311→          <div className=\"chat-messages\">\n   312→            <div className=\"chat-message\">\n   313→              <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   314→              <span className=\"text\">gg nice flip!</span>\n   315→            </div>\n   316→            <div className=\"chat-message\">\n   317→              <PlayerAvatarCompact address=\"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   318→              <span className=\"text\">who&apos;s ready for crash?</span>\n   319→            </div>\n   320→            <div className=\"chat-message\">\n   321→              <PlayerAvatarCompact address=\"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   322→              <span className=\"text\">close call is rigged lol jk</span>\n   323→            </div>\n   324→            <div className=\"chat-message\">\n   325→              <PlayerAvatarCompact address=\"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   326→              <span className=\"text\">just hit 5x on crash!</span>\n   327→            </div>\n   328→            <div className=\"chat-message\">\n   329→              <PlayerAvatarCompact address=\"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   330→              <span className=\"text\">coinflip is where it&apos;s at</span>\n   331→            </div>\n   332→            <div className=\"chat-message\">\n   333→              <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   334→              <span className=\"text\">how do I verify fairness?</span>\n   335→            </div>\n   336→          </div>\n   337→          <div className=\"chat-input-container\">\n   338→            <input type=\"text\" className=\"chat-input\" placeholder=\"Type a message...\" />\n   339→            <button className=\"chat-send-btn\">Send</button>\n   340→          </div>\n   341→        </div>\n   342→      </div>\n   343→\n   344→      {/* Title */}\n   345→      <h1 className=\"rpg-title\">RNG Wooftopia</h1>\n   346→\n   347→      {/* Nav Bar */}\n   348→      <RPGNavBar />\n   349→\n   350→      {/* Central Window */}\n   351→      <div className=\"rpg-central-window\">\n   352→        <div className=\"rpg-window-frame\">\n   353→          <div className=\"rpg-window-bolt rpg-window-bolt--tl\" />\n   354→          <div className=\"rpg-window-bolt rpg-window-bolt--tr\" />\n   355→          <div className=\"rpg-window-bolt rpg-window-bolt--bl\" />\n   356→          <div className=\"rpg-window-bolt rpg-window-bolt--br\" />\n   357→\n   358→          <div className=\"rpg-window-content\">\n   359→            <Routes>\n   360→              <Route path=\"/\" element={<HomePage />} />\n   361→              <Route path=\"/coinflip\" element={<CoinflipPage />} />\n   362→              <Route path=\"/lord-of-rngs\" element={<LordOfRngsPage />} />\n   363→              <Route path=\"/close-call\" element={<CloseCallPage />} />\n   364→              <Route path=\"/crash\" element={<CryptoCrashPage />} />\n   365→              <Route path=\"/game-of-trades\" element={<GameOfTradesPage />} />\n   366→              <Route path=\"/profile\" element={<ProfilePage />} />\n   367→              <Route path=\"/loot\" element={<LootPage />} />\n   368→              <Route path=\"/quests\" element={<QuestsPage />} />\n   369→              <Route path=\"/fairness\" element={<FairnessPage />} />\n   370→              <Route path=\"/leaderboard\" element={<LeaderboardPage />} />\n   371→              <Route path=\"*\" element={<NotFoundPage />} />\n   372→            </Routes>\n   373→          </div>\n   374→        </div>\n   375→      </div>\n   376→\n   377→      {/* Scene: Quest Board + Treasure Chest (bottom-left) */}\n   378→      <div className=\"rpg-scene-bottom-left\">\n   379→        <div\n   380→          className=\"rpg-scene-quest-board\"\n   381→          onClick={() => navigate(\"/quests\")}\n   382→          title=\"Quest Board\"\n   383→        />\n   384→        <SceneChest onClick={() => navigate(\"/loot\")} />\n   385→      </div>\n   386→\n   387→      {/* Info Button (bottom-center) */}\n   388→      <div className=\"rpg-info-btn-wrapper\" ref={infoRef}>\n   389→        <button className=\"rpg-info-btn\" onClick={() => setShowInfoPopover(!showInfoPopover)}>\n   390→          ?\n   391→        </button>\n   392→        {showInfoPopover && <InfoPopover onClose={() => setShowInfoPopover(false)} />}\n   393→      </div>\n   394→\n   395→      {/* Scene: Campfire + Avatar (bottom-right, avatar at edge) */}\n   396→      <div className=\"rpg-scene-campfire-area\">\n   397→        <div\n   398→          className={`rpg-scene-campfire ${chatExpanded ? \"rpg-scene-campfire--chat-active\" : \"\"}`}\n   399→          onClick={() => setChatExpanded(!chatExpanded)}\n   400→        >\n   401→          <div className=\"rpg-scene-campfire__logs\" />\n   402→          <div className=\"rpg-scene-campfire__flame\" />\n   403→          <div className=\"rpg-scene-campfire__glow\" />\n   404→        </div>\n   405→        <div className=\"rpg-scene-avatar\" onClick={() => navigate(\"/profile\")}>\n   406→          <RNGBuffIndicator />\n   407→          <PlayerAvatar\n   408→            address={address || \"DefaultPlayer\"}\n   409→            size=\"lg\"\n   410→            enableMiniProfile={false}\n   411→          />\n   412→        </div>\n   413→        <div\n   414→          className={`rpg-wallet-icon ${connected ? \"rpg-wallet-icon--connected\" : \"\"} ${connecting ? \"rpg-wallet-icon--connecting\" : \"\"}`}\n   415→          onClick={() => connected ? disconnect() : connect()}\n   416→          title={connected ? `$${formatted ?? \"0\"}` : \"Connect Wallet\"}\n   417→        >\n   418→          <span className=\"rpg-wallet-icon__amount\">\n   419→            {connecting ? \"...\" : connected ? `$${formatted ?? \"0\"}` : \"—\"}\n   420→          </span>\n   421→          <div className=\"rpg-wallet-icon__bag\" />\n   422→        </div>\n   423→      </div>\n   424→\n   425→      {/* Footer modals (Terms/FAQ) - rendered globally */}\n   426→      <FooterModals />\n   427→    </div>\n   428→  );\n   429→}\n   430→\n   431→// RPG Nav Bar\n   432→function RPGNavBar() {\n   433→  const { claimableQuestCount, unopenedChestCount } = useQuests();\n   434→\n   435→  return (\n   436→    <nav className=\"rpg-nav-bar\">\n   437→      <NavLink to=\"/\" end className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n   438→        Games\n   439→      </NavLink>\n   440→      <NavLink to=\"/quests\" className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n   441→        Quests\n   442→        {claimableQuestCount > 0 && <span className=\"rpg-nav-badge rpg-nav-badge--yellow\" />}\n   443→      </NavLink>\n   444→      <NavLink to=\"/loot\" className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n   445→        Loot\n   446→        {unopenedChestCount > 0 && <span className=\"rpg-nav-badge rpg-nav-badge--yellow\" />}\n   447→      </NavLink>\n   448→      <NavLink to=\"/profile\" className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n   449→        Profile\n   450→      </NavLink>\n   451→      <NavLink to=\"/leaderboard\" className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n   452→        Leaderboard\n   453→      </NavLink>\n   454→    </nav>\n   455→  );\n   456→}\n   457→\n   458→// Scene Treasure Chest (bottom-left)\n   459→function SceneChest({ onClick }: { onClick: () => void }) {\n   460→  const { unopenedChestCount } = useQuests();\n   461→  const location = useLocation();\n   462→  const hasLoot = unopenedChestCount > 0;\n   463→  const isLootPage = location.pathname === \"/loot\";\n   464→\n   465→  return (\n   466→    <div\n   467→      className={`rpg-scene-chest ${hasLoot ? \"rpg-scene-chest--has-loot\" : \"\"} ${isLootPage ? \"rpg-scene-chest--open\" : \"\"}`}\n   468→      onClick={onClick}\n   469→      title={hasLoot ? \"You have loot!\" : \"Treasure chest\"}\n   470→    />\n   471→  );\n   472→}\n   473→\n   474→// Info Popover (Terms, FAQ, Socials)\n   475→function InfoPopover({ onClose }: { onClose: () => void }) {\n   476→  const [showTerms, setShowTerms] = useState(false);\n   477→  const [showFAQ, setShowFAQ] = useState(false);\n   478→\n   479→  if (showTerms) {\n   480→    return <TermsModal onClose={() => { setShowTerms(false); onClose(); }} />;\n   481→  }\n   482→  if (showFAQ) {\n   483→    return <FAQModal onClose={() => { setShowFAQ(false); onClose(); }} />;\n   484→  }\n   485→\n   486→  return (\n   487→    <div className=\"rpg-info-popover\">\n   488→      <button className=\"rpg-info-popover__link\" onClick={() => setShowTerms(true)}>Terms</button>\n   489→      <button className=\"rpg-info-popover__link\" onClick={() => setShowFAQ(true)}>FAQ</button>\n   490→      <div className=\"rpg-info-popover__divider\" />\n   491→      <a href=\"https://x.com/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"rpg-info-popover__link\">\n   492→        X (Twitter)\n   493→      </a>\n   494→      <a href=\"https://t.me/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"rpg-info-popover__link\">\n   495→        Telegram\n   496→      </a>\n   497→      <div className=\"rpg-info-popover__divider\" />\n   498→      <span className=\"rpg-info-popover__link\" style={{ opacity: 0.5, cursor: \"default\", fontSize: \"0.4rem\" }}>\n   499→        &copy; 2025 RNG Wooftopia\n   500→      </span>\n   501→    </div>\n   502→  );\n   503→}\n   504→\n   505→// Mock Leaderboard Data\n   506→const MOCK_LEADERBOARD_ADDRESSES = [\n   507→  \"0xLB01aaa\", \"0xLB02bbb\", \"0xLB03ccc\", \"0xLB04ddd\", \"0xLB05eee\",\n   508→  \"0xLB06fff\", \"0xLB07aab\", \"0xLB08bbc\", \"0xLB09ccd\", \"0xLB10dde\",\n   509→  \"0xLB11eef\", \"0xLB12ffa\", \"0xLB13aac\", \"0xLB14bbd\", \"0xLB15cce\",\n   510→  \"0xLB16ddf\", \"0xLB17eea\", \"0xLB18ffb\", \"0xLB19abc\", \"0xLB20def\",\n   511→];\n   512→\n   513→interface LeaderboardEntry {\n   514→  address: string;\n   515→  wagered: number;\n   516→  points: number;\n   517→}\n   518→\n   519→function generateLeaderboardData(): LeaderboardEntry[] {\n   520→  return MOCK_LEADERBOARD_ADDRESSES.map((addr) => {\n   521→    const profile = getOrCreateProfile(addr);\n   522→    const lvl = profile.level;\n   523→    // Wagered scales with level: lv1 ~$15, lv50 ~$1750, lv100 ~$6000\n   524→    const baseWager = lvl * lvl * 0.5 + lvl * 10;\n   525→    const wagered = Math.round(baseWager * (0.7 + Math.random() * 0.6) * 100) / 100;\n   526→    const points = Math.round(wagered * (1 + lvl * 0.05) + profile.stats.wins * 10);\n   527→    return { address: addr, wagered, points };\n   528→  }).sort((a, b) => b.points - a.points);\n   529→}\n   530→\n   531→function LeaderboardPage() {\n   532→  const { address: myAddress } = useWallet();\n   533→  const [entries] = useState<LeaderboardEntry[]>(() => generateLeaderboardData());\n   534→\n   535→  return (\n   536→    <div className=\"leaderboard-page\">\n   537→      <h2 className=\"leaderboard-page__title\">Leaderboard</h2>\n   538→      <p className=\"leaderboard-page__subtitle\">Play wagered games, earn points, climb the leaderboard for seasonal rewards!</p>\n   539→\n   540→      <div className=\"leaderboard-page__table\">\n   541→        <div className=\"leaderboard-page__row leaderboard-page__row--header\">\n   542→          <span className=\"leaderboard-page__col leaderboard-page__col--rank\">#</span>\n   543→          <span className=\"leaderboard-page__col leaderboard-page__col--player\">Player</span>\n   544→          <span className=\"leaderboard-page__col leaderboard-page__col--wagered\">Wagered</span>\n   545→          <span className=\"leaderboard-page__col leaderboard-page__col--points\">Points</span>\n   546→        </div>\n   547→\n   548→        {entries.map((entry, i) => {\n   549→          const isMe = entry.address === myAddress;\n   550→          return (\n   551→            <div\n   552→              key={entry.address}\n   553→              className={`leaderboard-page__row ${isMe ? \"leaderboard-page__row--me\" : \"\"}`}\n   554→            >\n   555→              <span className=\"leaderboard-page__col leaderboard-page__col--rank\">\n   556→                {i + 1}\n   557→              </span>\n   558→              <span className=\"leaderboard-page__col leaderboard-page__col--player\">\n   559→                <PlayerAvatarCompact address={entry.address} showLevel isCurrentUser={isMe} />\n   560→              </span>\n   561→              <span className=\"leaderboard-page__col leaderboard-page__col--wagered\">\n   562→                {\"$\"}{entry.wagered.toFixed(2)}\n   563→              </span>\n   564→              <span className=\"leaderboard-page__col leaderboard-page__col--points\">\n   565→                {entry.points.toLocaleString()}\n   566→              </span>\n   567→            </div>\n   568→          );\n   569→        })}\n   570→      </div>\n   571→    </div>\n   572→  );\n   573→}\n   574→\n   575→function HomePage() {\n   576→  return (\n   577→    <div className=\"home\">\n   578→      <div className=\"arcade-header\">\n   579→        <h2>Select Your Game</h2>\n   580→        <p className=\"subtitle\">Insert Conviction</p>\n   581→      </div>\n   582→\n   583→      <div className=\"games-grid\">\n   584→        <GameCard\n   585→          name=\"Coinflip\"\n   586→          description=\"Heads or Tails - 1v1 battles\"\n   587→          path=\"/coinflip\"\n   588→          visual=\"coinflip\"\n   589→        />\n   590→        <GameCard\n   591→          name=\"Lord of the RNGs\"\n   592→          description=\"Jackpot game - One RNG to win them all\"\n   593→          path=\"/lord-of-rngs\"\n   594→          visual=\"lotr\"\n   595→        />\n   596→        <GameCard\n   597→          name=\"Close Call\"\n   598→          description=\"Predict the outcome of the live 1 min candle close: Green or Red\"\n   599→          path=\"/close-call\"\n   600→          visual=\"close-call\"\n   601→        />\n   602→        <GameCard\n   603→          name=\"Crypto Crash Simulator\"\n   604→          description=\"Cash out before the crash - with multiplayer survival mode\"\n   605→          path=\"/crash\"\n   606→          visual=\"crash\"\n   607→          hot\n   608→        />\n   609→        <GameCard\n   610→          name=\"Game of Trades\"\n   611→          description=\"Fast paced, 1 minute, multiplayer trading rounds. Best performance wins the pot\"\n   612→          path=\"/game-of-trades\"\n   613→          visual=\"trades\"\n   614→        />\n   615→        {/* TODO: Chart the Course, Tug of Earn, Slots Utopia — add back when implemented */}\n   616→      </div>\n   617→    </div>\n   618→  );\n   619→}\n   620→\n   621→interface GameCardProps {\n   622→  name: string;\n   623→  description: string;\n   624→  path: string;\n   625→  visual: \"close-call\" | \"crash\" | \"lotr\" | \"coinflip\" | \"trades\" | \"slots\" | \"chart\" | \"tug\";\n   626→  locked?: boolean;\n   627→  hot?: boolean;\n   628→}\n   629→\n   630→function GameCard({\n   631→  name,\n   632→  description,\n   633→  path,\n   634→  visual,\n   635→  locked = false,\n   636→  hot = false,\n   637→}: GameCardProps) {\n   638→  return (\n   639→    <Link\n   640→      to={locked ? \"#\" : path}\n   641→      className={`game-card game-card--${visual} ${locked ? \"locked\" : \"\"}`}\n   642→      onClick={(e) => locked && e.preventDefault()}\n   643→    >\n   644→      {hot && <span className=\"hot-badge\">HOT</span>}\n   645→      {locked && <span className=\"lock-icon\">🔒</span>}\n   646→\n   647→      {/* Game Icon */}\n   648→      <div className=\"game-card-icon\">\n   649→        <GameCardIcon visual={visual} />\n   650→      </div>\n   651→\n   652→      {/* Game Info */}\n   653→      <div className=\"game-info\">\n   654→        <h3>{name}</h3>\n   655→        <p className=\"game-description\">{description}</p>\n   656→      </div>\n   657→\n   658→      {/* Footer */}\n   659→      <div className=\"game-footer\">\n   660→        {locked ? (\n   661→          <span className=\"lock-badge\">🔒</span>\n   662→        ) : (\n   663→          <span className=\"play-text\">PLAY</span>\n   664→        )}\n   665→      </div>\n   666→    </Link>\n   667→  );\n   668→}\n   669→\n   670→// Game card icons — inline SVGs for each game type\n   671→function GameCardIcon({ visual }: { visual: GameCardProps[\"visual\"] }) {\n   672→  switch (visual) {\n   673→    case \"coinflip\":\n   674→      return <CoinflipIcon />;\n   675→    case \"lotr\":\n   676→      return <LordOfRngsIcon />;\n   677→    case \"close-call\":\n   678→      return <CloseCallIcon />;\n   679→    case \"crash\":\n   680→      return <CrashIcon />;\n   681→    case \"trades\":\n   682→      return <TradesIcon />;\n   683→    default:\n   684→      return null;\n   685→  }\n   686→}\n   687→\n   688→// Coinflip: Two shields (green + red) with crossed medieval swords behind\n   689→function CoinflipIcon() {\n   690→  return (\n   691→    <div className=\"coinflip-icon\">\n   692→      <svg className=\"coinflip-icon__swords\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n   693→        {/* Left sword (tip top-right) */}\n   694→        <g transform=\"rotate(45 50 50)\">\n   695→          <polygon points=\"48,8 50,2 52,8 52,52 48,52\" fill=\"url(#blade)\" stroke=\"#888\" strokeWidth=\"0.5\" />\n   696→          <rect x=\"42\" y=\"52\" width=\"16\" height=\"4\" rx=\"1\" fill=\"url(#guard)\" />\n   697→          <rect x=\"47\" y=\"56\" width=\"6\" height=\"14\" rx=\"1\" fill=\"#5a3a1a\" />\n   698→          <rect x=\"48\" y=\"58\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n   699→          <rect x=\"48\" y=\"62\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n   700→          <rect x=\"48\" y=\"66\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n   701→          <circle cx=\"50\" cy=\"72\" r=\"3.5\" fill=\"url(#guard)\" />\n   702→        </g>\n   703→        {/* Right sword (tip top-left) */}\n   704→        <g transform=\"rotate(-45 50 50)\">\n   705→          <polygon points=\"48,8 50,2 52,8 52,52 48,52\" fill=\"url(#blade)\" stroke=\"#888\" strokeWidth=\"0.5\" />\n   706→          <rect x=\"42\" y=\"52\" width=\"16\" height=\"4\" rx=\"1\" fill=\"url(#guard)\" />\n   707→          <rect x=\"47\" y=\"56\" width=\"6\" height=\"14\" rx=\"1\" fill=\"#5a3a1a\" />\n   708→          <rect x=\"48\" y=\"58\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n   709→          <rect x=\"48\" y=\"62\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n   710→          <rect x=\"48\" y=\"66\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n   711→          <circle cx=\"50\" cy=\"72\" r=\"3.5\" fill=\"url(#guard)\" />\n   712→        </g>\n   713→        <defs>\n   714→          <linearGradient id=\"blade\" x1=\"48\" y1=\"2\" x2=\"52\" y2=\"2\" gradientUnits=\"userSpaceOnUse\">\n   715→            <stop offset=\"0%\" stopColor=\"#b8b8b8\" />\n   716→            <stop offset=\"30%\" stopColor=\"#e8e8e8\" />\n   717→            <stop offset=\"70%\" stopColor=\"#d0d0d0\" />\n   718→            <stop offset=\"100%\" stopColor=\"#a0a0a0\" />\n   719→          </linearGradient>\n   720→          <linearGradient id=\"guard\" x1=\"42\" y1=\"52\" x2=\"42\" y2=\"56\" gradientUnits=\"userSpaceOnUse\">\n   721→            <stop offset=\"0%\" stopColor=\"#d4a840\" />\n   722→            <stop offset=\"100%\" stopColor=\"#8a6020\" />\n   723→          </linearGradient>\n   724→        </defs>\n   725→      </svg>\n   726→      <img src=\"/sprites/red-shield.png\" alt=\"\" className=\"coinflip-icon__shield coinflip-icon__shield--red\" />\n   727→      <img src=\"/sprites/green-shield.png\" alt=\"\" className=\"coinflip-icon__shield coinflip-icon__shield--green\" />\n   728→    </div>\n   729→  );\n   730→}\n   731→\n   732→// Lord of RNGs: Wide horizontal row of player silhouettes, center one is the winner\n   733→function LordOfRngsIcon() {\n   734→  return (\n   735→    <svg viewBox=\"0 0 100 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" className=\"game-card-svg\">\n   736→      {/* Container border */}\n   737→      <rect x=\"2\" y=\"12\" width=\"96\" height=\"32\" rx=\"2\" fill=\"none\" stroke=\"#5a4830\" strokeWidth=\"2\" />\n   738→      <rect x=\"2\" y=\"12\" width=\"96\" height=\"32\" rx=\"2\" fill=\"#2a1c10\" opacity=\"0.3\" />\n   739→      {/* Player 1 (far left, dimmed) */}\n   740→      <circle cx=\"14\" cy=\"28\" r=\"7\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"1.2\" opacity=\"0.35\" />\n   741→      <circle cx=\"14\" cy=\"26\" r=\"2.5\" fill=\"#f0b820\" opacity=\"0.35\" />\n   742→      <path d=\"M 9.5 34 Q 14 31 18.5 34\" stroke=\"#f0b820\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.35\" />\n   743→      {/* Player 2 (left, dimmed) */}\n   744→      <circle cx=\"32\" cy=\"28\" r=\"7\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"1.2\" opacity=\"0.4\" />\n   745→      <circle cx=\"32\" cy=\"26\" r=\"2.5\" fill=\"#f0b820\" opacity=\"0.4\" />\n   746→      <path d=\"M 27.5 34 Q 32 31 36.5 34\" stroke=\"#f0b820\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.4\" />\n   747→      {/* Player 3 (CENTER — WINNER, highlighted) */}\n   748→      <circle cx=\"50\" cy=\"28\" r=\"8\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"2\" opacity=\"1\" />\n   749→      <circle cx=\"50\" cy=\"28\" r=\"8\" fill=\"rgba(240,184,32,0.08)\" />\n   750→      <circle cx=\"50\" cy=\"26\" r=\"3\" fill=\"#f0b820\" opacity=\"0.9\" />\n   751→      <path d=\"M 44.5 35 Q 50 31.5 55.5 35\" stroke=\"#f0b820\" strokeWidth=\"1.3\" fill=\"none\" opacity=\"0.9\" />\n   752→      {/* Selection arrow pointing down toward winner */}\n   753→      <polygon points=\"50,12 46,6 54,6\" fill=\"#f0b820\" stroke=\"#8a6010\" strokeWidth=\"0.6\" />\n   754→      {/* Crown on winner */}\n   755→      <polygon points=\"45,3 46.5,0 48,2.5 50,-1 52,2.5 53.5,0 55,3\" fill=\"#f0b820\" stroke=\"#8a6010\" strokeWidth=\"0.6\" />\n   756→      <circle cx=\"50\" cy=\"-1\" r=\"0.8\" fill=\"#e070a0\" />\n   757→      {/* Player 4 (right, dimmed) */}\n   758→      <circle cx=\"68\" cy=\"28\" r=\"7\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"1.2\" opacity=\"0.4\" />\n   759→      <circle cx=\"68\" cy=\"26\" r=\"2.5\" fill=\"#f0b820\" opacity=\"0.4\" />\n   760→      <path d=\"M 63.5 34 Q 68 31 72.5 34\" stroke=\"#f0b820\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.4\" />\n   761→      {/* Player 5 (far right, dimmed) */}\n   762→      <circle cx=\"86\" cy=\"28\" r=\"7\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"1.2\" opacity=\"0.3\" />\n   763→      <circle cx=\"86\" cy=\"26\" r=\"2.5\" fill=\"#f0b820\" opacity=\"0.3\" />\n   764→      <path d=\"M 81.5 34 Q 86 31 90.5 34\" stroke=\"#f0b820\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.3\" />\n   765→    </svg>\n   766→  );\n   767→}\n   768→\n   769→// Close Call: Balance scale tilted toward green, bigger candles\n   770→function CloseCallIcon() {\n   771→  return (\n   772→    <svg viewBox=\"0 0 64 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" className=\"game-card-svg\">\n   773→      {/* Center pillar */}\n   774→      <rect x=\"30\" y=\"10\" width=\"4\" height=\"32\" fill=\"#5a4830\" />\n   775→      <rect x=\"27\" y=\"40\" width=\"10\" height=\"4\" rx=\"1\" fill=\"#6a5838\" />\n   776→      {/* Fulcrum triangle */}\n   777→      <polygon points=\"32,7 27,13 37,13\" fill=\"#8a7040\" stroke=\"#5a4830\" strokeWidth=\"0.8\" />\n   778→      {/* Balance beam — tilted: left side (green) is heavier, dips down */}\n   779→      <line x1=\"4\" y1=\"18\" x2=\"60\" y2=\"14\" stroke=\"#8a7040\" strokeWidth=\"2.5\" strokeLinecap=\"round\" />\n   780→      {/* Left pan strings (lower — heavier side) */}\n   781→      <line x1=\"4\" y1=\"18\" x2=\"9\" y2=\"28\" stroke=\"#6a5838\" strokeWidth=\"1\" />\n   782→      <line x1=\"22\" y1=\"16.7\" x2=\"19\" y2=\"28\" stroke=\"#6a5838\" strokeWidth=\"1\" />\n   783→      {/* Left pan */}\n   784→      <ellipse cx=\"14\" cy=\"29\" rx=\"10\" ry=\"2.5\" fill=\"#5a4830\" stroke=\"#6a5838\" strokeWidth=\"0.8\" />\n   785→      {/* BIG green candle on left pan */}\n   786→      <rect x=\"12.5\" y=\"32\" width=\"1.5\" height=\"2\" fill=\"#45b058\" opacity=\"0.5\" />\n   787→      <rect x=\"10\" y=\"14\" width=\"7\" height=\"18\" rx=\"0.5\" fill=\"#45b058\" />\n   788→      <rect x=\"13\" y=\"10\" width=\"1.5\" height=\"4\" fill=\"#45b058\" opacity=\"0.7\" />\n   789→      {/* Green candle inner highlight */}\n   790→      <rect x=\"11\" y=\"15\" width=\"2\" height=\"16\" fill=\"#5cd070\" opacity=\"0.3\" />\n   791→      {/* Right pan strings (higher — lighter side) */}\n   792→      <line x1=\"42\" y1=\"15\" x2=\"46\" y2=\"24\" stroke=\"#6a5838\" strokeWidth=\"1\" />\n   793→      <line x1=\"60\" y1=\"14\" x2=\"56\" y2=\"24\" stroke=\"#6a5838\" strokeWidth=\"1\" />\n   794→      {/* Right pan */}\n   795→      <ellipse cx=\"51\" cy=\"25\" rx=\"10\" ry=\"2.5\" fill=\"#5a4830\" stroke=\"#6a5838\" strokeWidth=\"0.8\" />\n   796→      {/* Smaller red candle on right pan */}\n   797→      <rect x=\"49\" y=\"14\" width=\"1.5\" height=\"2\" fill=\"#cc4444\" opacity=\"0.5\" />\n   798→      <rect x=\"47\" y=\"16\" width=\"6\" height=\"12\" rx=\"0.5\" fill=\"#cc4444\" />\n   799→      <rect x=\"49.5\" y=\"28\" width=\"1.5\" height=\"3\" fill=\"#cc4444\" opacity=\"0.5\" />\n   800→      {/* Red candle inner highlight */}\n   801→      <rect x=\"48\" y=\"17\" width=\"2\" height=\"10\" fill=\"#e05858\" opacity=\"0.3\" />\n   802→      {/* Scale indicator dot */}\n   803→      <circle cx=\"32\" cy=\"7\" r=\"2\" fill=\"#f0b820\" />\n   804→    </svg>\n   805→  );\n   806→}\n   807→\n   808→// Crypto Crash: Green ascending candlesticks then one massive red crash candle\n   809→function CrashIcon() {\n   810→  return (\n   811→    <svg viewBox=\"0 0 64 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" className=\"game-card-svg\">\n   812→      {/* Baseline */}\n   813→      <line x1=\"2\" y1=\"46\" x2=\"62\" y2=\"46\" stroke=\"#3a3020\" strokeWidth=\"0.5\" />\n   814→      {/* Green candle 1 — opens 40, closes 36 (body), wick 34-42 */}\n   815→      <line x1=\"7\" y1=\"34\" x2=\"7\" y2=\"42\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n   816→      <rect x=\"5\" y=\"36\" width=\"4\" height=\"6\" rx=\"0.3\" fill=\"#45b058\" />\n   817→      {/* Green candle 2 — opens 34, closes 28 */}\n   818→      <line x1=\"14\" y1=\"26\" x2=\"14\" y2=\"36\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n   819→      <rect x=\"12\" y=\"28\" width=\"4\" height=\"8\" rx=\"0.3\" fill=\"#45b058\" />\n   820→      {/* Green candle 3 — opens 28, closes 20 */}\n   821→      <line x1=\"21\" y1=\"18\" x2=\"21\" y2=\"30\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n   822→      <rect x=\"19\" y=\"20\" width=\"4\" height=\"10\" rx=\"0.3\" fill=\"#45b058\" />\n   823→      {/* Green candle 4 — opens 20, closes 10 */}\n   824→      <line x1=\"28\" y1=\"8\" x2=\"28\" y2=\"22\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n   825→      <rect x=\"26\" y=\"10\" width=\"4\" height=\"12\" rx=\"0.3\" fill=\"#45b058\" />\n   826→      {/* Green candle 5 (peak) — opens 10, closes 4 */}\n   827→      <line x1=\"35\" y1=\"2\" x2=\"35\" y2=\"12\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n   828→      <rect x=\"33\" y=\"4\" width=\"4\" height=\"8\" rx=\"0.3\" fill=\"#45b058\" />\n   829→      {/* BIG RED crash candle — opens at top (4), crashes all the way to bottom (45) */}\n   830→      <line x1=\"46\" y1=\"2\" x2=\"46\" y2=\"46\" stroke=\"#cc4444\" strokeWidth=\"1\" />\n   831→      <rect x=\"42\" y=\"3\" width=\"8\" height=\"42\" rx=\"0.3\" fill=\"#cc4444\" />\n   832→      {/* Red candle inner shade */}\n   833→      <rect x=\"43\" y=\"4\" width=\"3\" height=\"40\" fill=\"#e05858\" opacity=\"0.25\" />\n   834→      {/* Crash lightning bolt accent */}\n   835→      <path d=\"M 55 8 L 52 20 L 56 20 L 52 34\" stroke=\"#ff6666\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.5\" />\n   836→    </svg>\n   837→  );\n   838→}\n   839→\n   840→// Game of Trades: Chart line with podium (1st/2nd/3rd)\n   841→function TradesIcon() {\n   842→  return (\n   843→    <svg viewBox=\"0 0 64 52\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" className=\"game-card-svg\">\n   844→      {/* Chart area */}\n   845→      {/* Axes */}\n   846→      <line x1=\"4\" y1=\"2\" x2=\"4\" y2=\"28\" stroke=\"#5a4830\" strokeWidth=\"1\" />\n   847→      <line x1=\"4\" y1=\"28\" x2=\"60\" y2=\"28\" stroke=\"#5a4830\" strokeWidth=\"1\" />\n   848→      {/* Grid lines */}\n   849→      <line x1=\"4\" y1=\"10\" x2=\"60\" y2=\"10\" stroke=\"#3a2810\" strokeWidth=\"0.3\" opacity=\"0.5\" />\n   850→      <line x1=\"4\" y1=\"18\" x2=\"60\" y2=\"18\" stroke=\"#3a2810\" strokeWidth=\"0.3\" opacity=\"0.5\" />\n   851→      {/* Chart line (zigzag trading) */}\n   852→      <polyline\n   853→        points=\"6,22 12,18 18,20 24,12 30,16 36,8 42,14 48,6 54,10 58,8\"\n   854→        fill=\"none\"\n   855→        stroke=\"#f0b820\"\n   856→        strokeWidth=\"1.5\"\n   857→        strokeLinecap=\"round\"\n   858→        strokeLinejoin=\"round\"\n   859→      />\n   860→      {/* Glow under the chart line */}\n   861→      <polygon\n   862→        points=\"6,22 12,18 18,20 24,12 30,16 36,8 42,14 48,6 54,10 58,8 58,28 6,28\"\n   863→        fill=\"url(#tradeGrad)\"\n   864→        opacity=\"0.2\"\n   865→      />\n   866→      <defs>\n   867→        <linearGradient id=\"tradeGrad\" x1=\"32\" y1=\"0\" x2=\"32\" y2=\"28\" gradientUnits=\"userSpaceOnUse\">\n   868→          <stop offset=\"0%\" stopColor=\"#f0b820\" />\n   869→          <stop offset=\"100%\" stopColor=\"#f0b820\" stopOpacity=\"0\" />\n   870→        </linearGradient>\n   871→      </defs>\n   872→\n   873→      {/* Podium */}\n   874→      {/* 2nd place (left, shorter) */}\n   875→      <rect x=\"12\" y=\"40\" width=\"12\" height=\"12\" fill=\"#a8b8c8\" stroke=\"#607080\" strokeWidth=\"0.8\" />\n   876→      <text x=\"18\" y=\"48\" textAnchor=\"middle\" fill=\"#2a1c08\" fontSize=\"6\" fontWeight=\"bold\" fontFamily=\"monospace\">2</text>\n   877→      {/* 1st place (center, tallest) */}\n   878→      <rect x=\"26\" y=\"34\" width=\"12\" height=\"18\" fill=\"#f0b820\" stroke=\"#8a6010\" strokeWidth=\"0.8\" />\n   879→      <text x=\"32\" y=\"45\" textAnchor=\"middle\" fill=\"#2a1c08\" fontSize=\"7\" fontWeight=\"bold\" fontFamily=\"monospace\">1</text>\n   880→      {/* Crown on 1st */}\n   881→      <polygon points=\"29,33 30,30 32,32 34,30 35,33\" fill=\"#f0b820\" stroke=\"#8a6010\" strokeWidth=\"0.5\" />\n   882→      {/* 3rd place (right, shortest) */}\n   883→      <rect x=\"40\" y=\"44\" width=\"12\" height=\"8\" fill=\"#cd7f32\" stroke=\"#8a5520\" strokeWidth=\"0.8\" />\n   884→      <text x=\"46\" y=\"50\" textAnchor=\"middle\" fill=\"#2a1c08\" fontSize=\"5\" fontWeight=\"bold\" fontFamily=\"monospace\">3</text>\n   885→    </svg>\n   886→  );\n   887→}\n   888→\n   889→// Fairness verification page\n   890→function FairnessPage() {\n   891→  const [activeTab, setActiveTab] = useState<'how' | 'verify' | 'seeds' | 'history'>('how');\n   892→  const [serverSeed, setServerSeed] = useState('');\n   893→  const [publicSeed, setPublicSeed] = useState('');\n   894→  const [roundId, setRoundId] = useState('');\n   895→  const [gameId, setGameId] = useState('crash');\n   896→  const [commitmentHash, setCommitmentHash] = useState('');\n   897→  const [verificationResult, setVerificationResult] = useState<{\n   898→    valid: boolean;\n   899→    message: string;\n   900→    crashPoint?: string;\n   901→  } | null>(null);\n   902→\n   903→  // SHA-256 hash function (using Web Crypto API)\n   904→  const sha256 = async (message: string): Promise<string> => {\n   905→    const encoder = new TextEncoder();\n   906→    const data = encoder.encode(message);\n   907→    const hashBuffer = await crypto.subtle.digest('SHA-256', data);\n   908→    const hashArray = Array.from(new Uint8Array(hashBuffer));\n   909→    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n   910→  };\n   911→\n   912→  // HMAC-SHA256 function\n   913→  const hmacSha256 = async (key: string, message: string): Promise<string> => {\n   914→    const encoder = new TextEncoder();\n   915→    const keyData = encoder.encode(key);\n   916→    const messageData = encoder.encode(message);\n   917→\n   918→    const cryptoKey = await crypto.subtle.importKey(\n   919→      'raw',\n   920→      keyData,\n   921→      { name: 'HMAC', hash: 'SHA-256' },\n   922→      false,\n   923→      ['sign']\n   924→    );\n   925→\n   926→    const signature = await crypto.subtle.sign('HMAC', cryptoKey, messageData);\n   927→    const hashArray = Array.from(new Uint8Array(signature));\n   928→    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n   929→  };\n   930→\n   931→  // Convert hash to crash point (standard algorithm)\n   932→  const hashToCrashPoint = (hash: string): number => {\n   933→    // Take first 13 hex characters (52 bits)\n   934→    const h = parseInt(hash.substring(0, 13), 16);\n   935→    // House edge: 1% (1 in 100 instant crash)\n   936→    const e = Math.pow(2, 52);\n   937→    const result = Math.floor((100 * e - h) / (e - h)) / 100;\n   938→    return Math.max(1.00, result);\n   939→  };\n   940→\n   941→  // Verify commitment\n   942→  const verifyCommitment = async () => {\n   943→    if (!serverSeed) {\n   944→      setVerificationResult({\n   945→        valid: false,\n   946→        message: 'Please enter a server seed'\n   947→      });\n   948→      return;\n   949→    }\n   950→\n   951→    const computedHash = await sha256(serverSeed);\n   952→\n   953→    if (commitmentHash) {\n   954→      const isValid = computedHash.toLowerCase() === commitmentHash.toLowerCase();\n   955→      setVerificationResult({\n   956→        valid: isValid,\n   957→        message: isValid\n   958→          ? 'Commitment verified! The server seed matches the published hash.'\n   959→          : 'Commitment FAILED! The server seed does not match the published hash.'\n   960→      });\n   961→    } else {\n   962→      setVerificationResult({\n   963→        valid: true,\n   964→        message: `Computed commitment hash: ${computedHash}`\n   965→      });\n   966→    }\n   967→  };\n   968→\n   969→  // Calculate crash point\n   970→  const calculateCrashPoint = async () => {\n   971→    if (!serverSeed || !publicSeed) {\n   972→      setVerificationResult({\n   973→        valid: false,\n   974→        message: 'Please enter both server seed and public seed'\n   975→      });\n   976→      return;\n   977→    }\n   978→\n   979→    // Combine seeds with round info\n   980→    const message = `${publicSeed}:${roundId}:${gameId}`;\n   981→    const hash = await hmacSha256(serverSeed, message);\n   982→    const crashPoint = hashToCrashPoint(hash);\n   983→\n   984→    setVerificationResult({\n   985→      valid: true,\n   986→      message: `Round outcome verified successfully.`,\n   987→      crashPoint: crashPoint.toFixed(2)\n   988→    });\n   989→  };\n   990→\n   991→  // Mock recent rounds data\n   992→  const recentRounds = [\n   993→    { id: '847291', game: 'Crash', result: '2.47x', commitment: 'a3f2...8e1c', verified: true },\n   994→    { id: '847290', game: 'Crash', result: '1.23x', commitment: 'b7e1...2f9a', verified: true },\n   995→    { id: '847289', game: 'Lord of the RNGs', result: 'Player_42', commitment: 'c9d3...7b4e', verified: true },\n   996→    { id: '847288', game: 'Close Call', result: 'GREEN', commitment: 'd2a8...1c5f', verified: true },\n   997→    { id: '847287', game: 'Coinflip', result: 'HEADS', commitment: 'e5f6...9d2b', verified: true },\n   998→  ];\n   999→\n  1000→  // Mock active seeds\n  1001→  const activeSeeds = [\n  1002→    { game: 'Crash', tier: 'All', commitment: 'f1e2d3c4b5a6978...', status: 'Active', expiresIn: '2:34' },\n  1003→    { game: 'Lord of the RNGs', tier: 'Gold', commitment: '9a8b7c6d5e4f321...', status: 'Betting', expiresIn: '0:45' },\n  1004→    { game: 'Close Call', tier: 'All', commitment: '1a2b3c4d5e6f789...', status: 'Active', expiresIn: '0:12' },\n  1005→  ];\n  1006→\n  1007→  return (\n  1008→    <div className=\"fairness-page\">\n  1009→      <div className=\"fairness-header\">\n  1010→        <h2>Provably Fair Verification</h2>\n  1011→        <p className=\"fairness-subtitle\">Every outcome is cryptographically verifiable</p>\n  1012→      </div>\n  1013→\n  1014→      {/* Tab Navigation */}\n  1015→      <div className=\"fairness-tabs\">\n  1016→        <button\n  1017→          className={`fairness-tab ${activeTab === 'how' ? 'active' : ''}`}\n  1018→          onClick={() => setActiveTab('how')}\n  1019→        >\n  1020→          How It Works\n  1021→        </button>\n  1022→        <button\n  1023→          className={`fairness-tab ${activeTab === 'verify' ? 'active' : ''}`}\n  1024→          onClick={() => setActiveTab('verify')}\n  1025→        >\n  1026→          Verify Round\n  1027→        </button>\n  1028→        <button\n  1029→          className={`fairness-tab ${activeTab === 'seeds' ? 'active' : ''}`}\n  1030→          onClick={() => setActiveTab('seeds')}\n  1031→        >\n  1032→          Active Seeds\n  1033→        </button>\n  1034→        <button\n  1035→          className={`fairness-tab ${activeTab === 'history' ? 'active' : ''}`}\n  1036→          onClick={() => setActiveTab('history')}\n  1037→        >\n  1038→          History\n  1039→        </button>\n  1040→      </div>\n  1041→\n  1042→      {/* Tab Content */}\n  1043→      <div className=\"fairness-content\">\n  1044→        {activeTab === 'how' && (\n  1045→          <div className=\"fairness-how\">\n  1046→            <div className=\"fairness-section\">\n  1047→              <h3>Why Provably Fair?</h3>\n  1048→              <p>\n  1049→                Traditional online games require you to trust that the house isn't cheating.\n  1050→                Provably fair systems eliminate this trust requirement by using cryptographic\n  1051→                commitments that can be independently verified by anyone.\n  1052→              </p>\n  1053→            </div>\n  1054→\n  1055→            <div className=\"fairness-section\">\n  1056→              <h3>Pattern 1: Commit-Reveal + Blockhash</h3>\n  1057→              <p className=\"pattern-label\">Used by: Crash, Close Call, Game of Trades</p>\n  1058→              <div className=\"fairness-steps\">\n  1059→                <div className=\"step\">\n  1060→                  <span className=\"step-num\">1</span>\n  1061→                  <div className=\"step-content\">\n  1062→                    <strong>Before Betting Opens</strong>\n  1063→                    <p>Server generates a random seed and publishes its SHA-256 hash (commitment)</p>\n  1064→                  </div>\n  1065→                </div>\n  1066→                <div className=\"step\">\n  1067→                  <span className=\"step-num\">2</span>\n  1068→                  <div className=\"step-content\">\n  1069→                    <strong>During Betting</strong>\n  1070→                    <p>Players place bets. The server cannot change its seed (hash is already public)</p>\n  1071→                  </div>\n  1072→                </div>\n  1073→                <div className=\"step\">\n  1074→                  <span className=\"step-num\">3</span>\n  1075→                  <div className=\"step-content\">\n  1076→                    <strong>At Round Start</strong>\n  1077→                    <p>A future Solana blockhash becomes the public seed (unpredictable by server)</p>\n  1078→                  </div>\n  1079→                </div>\n  1080→                <div className=\"step\">\n  1081→                  <span className=\"step-num\">4</span>\n  1082→                  <div className=\"step-content\">\n  1083→                    <strong>After Round</strong>\n  1084→                    <p>Server reveals its seed. Anyone can verify: SHA-256(seed) = commitment</p>\n  1085→                  </div>\n  1086→                </div>\n  1087→              </div>\n  1088→              <div className=\"formula-box\">\n  1089→                <code>outcome = HMAC-SHA256(serverSeed, publicSeed || roundId || gameId)</code>\n  1090→              </div>\n  1091→            </div>\n  1092→\n  1093→            <div className=\"fairness-section\">\n  1094→              <h3>Pattern 2: On-Chain VRF</h3>\n  1095→              <p className=\"pattern-label\">Used by: Lord of the RNGs, Coinflip, Tug of Earn</p>\n  1096→              <div className=\"fairness-steps\">\n  1097→                <div className=\"step\">\n  1098→                  <span className=\"step-num\">1</span>\n  1099→                  <div className=\"step-content\">\n  1100→                    <strong>Round Enters Resolution</strong>\n  1101→                    <p>The on-chain program requests randomness from a VRF provider</p>\n  1102→                  </div>\n  1103→                </div>\n  1104→                <div className=\"step\">\n  1105→                  <span className=\"step-num\">2</span>\n  1106→                  <div className=\"step-content\">\n  1107→                    <strong>VRF Fulfillment</strong>\n  1108→                    <p>Provider generates verifiable random bytes with a cryptographic proof</p>\n  1109→                  </div>\n  1110→                </div>\n  1111→                <div className=\"step\">\n  1112→                  <span className=\"step-num\">3</span>\n  1113→                  <div className=\"step-content\">\n  1114→                    <strong>On-Chain Verification</strong>\n  1115→                    <p>Program verifies the proof and uses the result for winner selection</p>\n  1116→                  </div>\n  1117→                </div>\n  1118→                <div className=\"step\">\n  1119→                  <span className=\"step-num\">4</span>\n  1120→                  <div className=\"step-content\">\n  1121→                    <strong>Permanent Record</strong>\n  1122→                    <p>Result and proof stored on-chain forever - viewable on Solana explorer</p>\n  1123→                  </div>\n  1124→                </div>\n  1125→              </div>\n  1126→            </div>\n  1127→\n  1128→            <div className=\"fairness-section\">\n  1129→              <h3>What Can't Be Manipulated</h3>\n  1130→              <div className=\"guarantees\">\n  1131→                <div className=\"guarantee\">\n  1132→                  <span className=\"check-icon\">✓</span>\n  1133→                  <span>Server cannot predict the blockhash used as public seed</span>\n  1134→                </div>\n  1135→                <div className=\"guarantee\">\n  1136→                  <span className=\"check-icon\">✓</span>\n  1137→                  <span>Server cannot change its seed after publishing the commitment</span>\n  1138→                </div>\n  1139→                <div className=\"guarantee\">\n  1140→                  <span className=\"check-icon\">✓</span>\n  1141→                  <span>VRF proofs are mathematically verifiable - forgery is impossible</span>\n  1142→                </div>\n  1143→                <div className=\"guarantee\">\n  1144→                  <span className=\"check-icon\">✓</span>\n  1145→                  <span>All settlement happens on-chain with public transaction history</span>\n  1146→                </div>\n  1147→              </div>\n  1148→            </div>\n  1149→          </div>\n  1150→        )}\n  1151→\n  1152→        {activeTab === 'verify' && (\n  1153→          <div className=\"fairness-verify\">\n  1154→            <div className=\"verify-section\">\n  1155→              <h3>Verify a Round</h3>\n  1156→              <p>Enter the seeds from a completed round to independently verify the outcome.</p>\n  1157→\n  1158→              <div className=\"verify-form\">\n  1159→                <div className=\"form-group\">\n  1160→                  <label>Game</label>\n  1161→                  <select\n  1162→                    value={gameId}\n  1163→                    onChange={(e) => setGameId(e.target.value)}\n  1164→                    className=\"verify-select\"\n  1165→                  >\n  1166→                    <option value=\"crash\">Crypto Crash Simulator</option>\n  1167→                    <option value=\"close-call\">Close Call</option>\n  1168→                    <option value=\"lord-of-rngs\">Lord of the RNGs</option>\n  1169→                    <option value=\"coinflip\">Coinflip</option>\n  1170→                    <option value=\"game-of-trades\">Game of Trades</option>\n  1171→                  </select>\n  1172→                </div>\n  1173→\n  1174→                <div className=\"form-group\">\n  1175→                  <label>Server Seed (revealed after round)</label>\n  1176→                  <input\n  1177→                    type=\"text\"\n  1178→                    value={serverSeed}\n  1179→                    onChange={(e) => setServerSeed(e.target.value)}\n  1180→                    placeholder=\"e.g., a1b2c3d4e5f6...\"\n  1181→                    className=\"verify-input\"\n  1182→                  />\n  1183→                </div>\n  1184→\n  1185→                <div className=\"form-group\">\n  1186→                  <label>Public Seed (Solana blockhash)</label>\n  1187→                  <input\n  1188→                    type=\"text\"\n  1189→                    value={publicSeed}\n  1190→                    onChange={(e) => setPublicSeed(e.target.value)}\n  1191→                    placeholder=\"e.g., 5eykt4UsFv8P8NJdTREpY1vzqKqZKvdpKuc147dw2N9d\"\n  1192→                    className=\"verify-input\"\n  1193→                  />\n  1194→                </div>\n  1195→\n  1196→                <div className=\"form-row\">\n  1197→                  <div className=\"form-group\">\n  1198→                    <label>Round ID</label>\n  1199→                    <input\n  1200→                      type=\"text\"\n  1201→                      value={roundId}\n  1202→                      onChange={(e) => setRoundId(e.target.value)}\n  1203→                      placeholder=\"e.g., 847291\"\n  1204→                      className=\"verify-input\"\n  1205→                    />\n  1206→                  </div>\n  1207→\n  1208→                  <div className=\"form-group\">\n  1209→                    <label>Commitment Hash (optional)</label>\n  1210→                    <input\n  1211→                      type=\"text\"\n  1212→                      value={commitmentHash}\n  1213→                      onChange={(e) => setCommitmentHash(e.target.value)}\n  1214→                      placeholder=\"SHA-256 hash to verify against\"\n  1215→                      className=\"verify-input\"\n  1216→                    />\n  1217→                  </div>\n  1218→                </div>\n  1219→\n  1220→                <div className=\"verify-buttons\">\n  1221→                  <button onClick={verifyCommitment} className=\"verify-action-btn\">\n  1222→                    Verify Commitment\n  1223→                  </button>\n  1224→                  <button onClick={calculateCrashPoint} className=\"verify-action-btn primary\">\n  1225→                    Calculate Outcome\n  1226→                  </button>\n  1227→                </div>\n  1228→\n  1229→                {verificationResult && (\n  1230→                  <div className={`verification-result ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n  1231→                    <div className=\"result-status\">\n  1232→                      <span className={`status-icon ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n  1233→                        {verificationResult.valid ? '✓' : '✗'}\n  1234→                      </span>\n  1235→                      <span className=\"status-text\">{verificationResult.message}</span>\n  1236→                    </div>\n  1237→                    {verificationResult.crashPoint && (\n  1238→                      <div className=\"result-value\">\n  1239→                        <span className=\"result-label\">Crash Point:</span>\n  1240→                        <span className=\"crash-point\">{verificationResult.crashPoint}x</span>\n  1241→                      </div>\n  1242→                    )}\n  1243→                  </div>\n  1244→                )}\n  1245→              </div>\n  1246→            </div>\n  1247→\n  1248→            <div className=\"verify-section\">\n  1249→              <h3>Quick Lookup</h3>\n  1250→              <p>Enter a round ID to fetch its verification data automatically.</p>\n  1251→              <div className=\"quick-lookup\">\n  1252→                <input\n  1253→                  type=\"text\"\n  1254→                  placeholder=\"Enter Round ID...\"\n  1255→                  className=\"verify-input\"\n  1256→                />\n  1257→                <button className=\"lookup-btn\">Lookup</button>\n  1258→              </div>\n  1259→            </div>\n  1260→          </div>\n  1261→        )}\n  1262→\n  1263→        {activeTab === 'seeds' && (\n  1264→          <div className=\"fairness-seeds\">\n  1265→            <h3>Active Commitments</h3>\n  1266→            <p>These are the current seed commitments for ongoing rounds. The actual seeds will be revealed after each round completes.</p>\n  1267→\n  1268→            <div className=\"seeds-table\">\n  1269→              <div className=\"seeds-header\">\n  1270→                <span>Game</span>\n  1271→                <span>Tier</span>\n  1272→                <span>Commitment Hash</span>\n  1273→                <span>Status</span>\n  1274→                <span>Time</span>\n  1275→              </div>\n  1276→              {activeSeeds.map((seed, i) => (\n  1277→                <div className=\"seed-row\" key={i}>\n  1278→                  <span className=\"seed-game\">{seed.game}</span>\n  1279→                  <span className=\"seed-tier\">{seed.tier}</span>\n  1280→                  <span className=\"seed-hash\">{seed.commitment}</span>\n  1281→                  <span className={`seed-status ${seed.status.toLowerCase()}`}>{seed.status}</span>\n  1282→                  <span className=\"seed-time\">{seed.expiresIn}</span>\n  1283→                </div>\n  1284→              ))}\n  1285→            </div>\n  1286→\n  1287→            <div className=\"seeds-info\">\n  1288→              <h4>Understanding Commitments</h4>\n  1289→              <p>\n  1290→                A commitment is the SHA-256 hash of the server's secret seed. It's published before\n  1291→                betting opens, ensuring the server cannot change its seed after seeing player bets.\n  1292→                After the round, you can verify that SHA-256(revealed_seed) equals the commitment.\n  1293→              </p>\n  1294→            </div>\n  1295→          </div>\n  1296→        )}\n  1297→\n  1298→        {activeTab === 'history' && (\n  1299→          <div className=\"fairness-history\">\n  1300→            <h3>Recent Verified Rounds</h3>\n  1301→            <p>All completed rounds with their verification status.</p>\n  1302→\n  1303→            <div className=\"history-table\">\n  1304→              <div className=\"history-header\">\n  1305→                <span>Round</span>\n  1306→                <span>Game</span>\n  1307→                <span>Result</span>\n  1308→                <span>Commitment</span>\n  1309→                <span>Status</span>\n  1310→                <span>Action</span>\n  1311→              </div>\n  1312→              {recentRounds.map((round) => (\n  1313→                <div className=\"history-row\" key={round.id}>\n  1314→                  <span className=\"round-id\">#{round.id}</span>\n  1315→                  <span className=\"round-game\">{round.game}</span>\n  1316→                  <span className=\"round-result\">{round.result}</span>\n  1317→                  <span className=\"round-commitment\">{round.commitment}</span>\n  1318→                  <span className={`round-status ${round.verified ? 'verified' : 'pending'}`}>\n  1319→                    {round.verified ? 'Verified' : 'Pending'}\n  1320→                  </span>\n  1321→                  <button className=\"round-verify-btn\">Verify</button>\n  1322→                </div>\n  1323→              ))}\n  1324→            </div>\n  1325→\n  1326→            <div className=\"history-pagination\">\n  1327→              <button className=\"page-btn\" disabled>Previous</button>\n  1328→              <span className=\"page-info\">Page 1 of 1</span>\n  1329→              <button className=\"page-btn\" disabled>Next</button>\n  1330→            </div>\n  1331→          </div>\n  1332→        )}\n  1333→      </div>\n  1334→    </div>\n  1335→  );\n  1336→}\n  1337→\n  1338→function NotFoundPage() {\n  1339→  return (\n  1340→    <div className=\"not-found\">\n  1341→      <div className=\"error-code\">\n  1342→        <span className=\"digit\">4</span>\n  1343→        <span className=\"digit zero\">0</span>\n  1344→        <span className=\"digit\">4</span>\n  1345→      </div>\n  1346→      <h2>Game Over</h2>\n  1347→      <p>The level you're looking for doesn't exist.</p>\n  1348→      <p className=\"hint\">Maybe try a different warp pipe?</p>\n  1349→      <Link to=\"/\" className=\"continue-btn\">\n  1350→        Continue?\n  1351→      </Link>\n  1352→    </div>\n  1353→  );\n  1354→}\n  1355→"}]},"parent_tool_use_id":"toolu_01NAU6d4sgWxDaAFvf13a18q","session_id":"dcb8cfea-3149-4f02-a81d-4deae733513a","uuid":"ba1ab93e-6b55-4580-8e31-0f126a79eafc"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01K4zqjSZJPRnY8wUruB1oEW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Gn4LjMcA5LEnb1DANe6TES","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":3012,"cache_read_input_tokens":20786,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3012},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01NAU6d4sgWxDaAFvf13a18q","session_id":"dcb8cfea-3149-4f02-a81d-4deae733513a","uuid":"2af374e2-3068-425c-a83a-77a47a2cec22"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gn4LjMcA5LEnb1DANe6TES","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useMemo,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { Connection, PublicKey } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchMatchByCreator,\n    16→  fetchMatch,\n    17→  buildCreateMatchTx,\n    18→  buildJoinMatchTx,\n    19→  buildCancelMatchTx,\n    20→  buildClaimPayoutTx,\n    21→} from \"../utils/chain\";\n    22→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    23→\n    24→// RPC endpoint — defaults to localhost for development\n    25→const RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    26→  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n    27→\n    28→/** Parse Solana/wallet errors into user-friendly messages */\n    29→function parseTransactionError(err: unknown): string {\n    30→  const msg = err instanceof Error ? err.message : String(err);\n    31→\n    32→  // Wallet not connected\n    33→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    34→    return \"Wallet not connected. Please connect your wallet first.\";\n    35→  }\n    36→\n    37→  // User rejected\n    38→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    39→    return \"Transaction cancelled by user.\";\n    40→  }\n    41→\n    42→  // Insufficient funds (Solana runtime error)\n    43→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    44→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    45→  }\n    46→\n    47→  // Account already in use (match already exists)\n    48→  if (msg.includes(\"already in use\")) {\n    49→    return \"You already have an active match. Cancel it before creating a new one.\";\n    50→  }\n    51→\n    52→  // Network / RPC errors\n    53→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    54→    return \"Network error. Please check your connection and try again.\";\n    55→  }\n    56→\n    57→  // Anchor program errors\n    58→  if (msg.includes(\"InvalidPhase\")) {\n    59→    return \"This match is no longer available.\";\n    60→  }\n    61→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    62→    return \"You cannot join your own match.\";\n    63→  }\n    64→\n    65→  // Generic fallback\n    66→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    67→}\n    68→\n    69→interface CoinflipContextValue {\n    70→  // State\n    71→  activeMatch: UIMatch | null;\n    72→  openMatches: UIMatch[];\n    73→  userHistory: UIMatch[];\n    74→  selectedTier: Tier | null;\n    75→  selectedSide: CoinSide | null;\n    76→\n    77→  // Loading states\n    78→  loading: boolean;\n    79→  creating: boolean;\n    80→  joining: boolean;\n    81→  claiming: boolean;\n    82→  joiningMatchId: string | null;\n    83→\n    84→  // Error state\n    85→  error: string | null;\n    86→  clearError: () => void;\n    87→\n    88→  // Actions\n    89→  setSelectedTier: (tier: Tier | null) => void;\n    90→  setSelectedSide: (side: CoinSide | null) => void;\n    91→  createMatch: () => Promise<void>;\n    92→  joinMatch: (matchId: string) => Promise<void>;\n    93→  cancelMatch: () => Promise<void>;\n    94→  claimPayout: () => Promise<void>;\n    95→  clearActiveMatch: () => void;\n    96→  refreshMatches: () => void;\n    97→}\n    98→\n    99→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n   100→\n   101→export function CoinflipProvider({ children }: { children: ReactNode }) {\n   102→  const { connected, publicKey, sendTransaction } = useWallet();\n   103→\n   104→  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n   105→\n   106→  // Selection state\n   107→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   108→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   109→\n   110→  // Match state\n   111→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   112→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   113→  const [userHistory] = useState<UIMatch[]>([]);\n   114→\n   115→  // Loading states\n   116→  const [loading, setLoading] = useState(true);\n   117→  const [creating, setCreating] = useState(false);\n   118→  const [joining, setJoining] = useState(false);\n   119→  const [claiming, setClaiming] = useState(false);\n   120→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   121→\n   122→  // Error state\n   123→  const [error, setError] = useState<string | null>(null);\n   124→  const clearError = useCallback(() => setError(null), []);\n   125→\n   126→  // Fetch open matches from on-chain\n   127→  const refreshMatches = useCallback(() => {\n   128→    fetchAllOpenMatches(connection)\n   129→      .then((matches) => {\n   130→        setOpenMatches(matches);\n   131→        setLoading(false);\n   132→      })\n   133→      .catch(() => {\n   134→        setLoading(false);\n   135→      });\n   136→  }, [connection]);\n   137→\n   138→  // Initial load\n   139→  useEffect(() => {\n   140→    setLoading(true);\n   141→    refreshMatches();\n   142→  }, [refreshMatches]);\n   143→\n   144→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   145→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   146→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   147→\n   148→  useEffect(() => {\n   149→    const interval = setInterval(() => {\n   150→      refreshMatches();\n   151→\n   152→      // If there's an active match, refresh it too\n   153→      if (activeMatch) {\n   154→        const matchPda = new PublicKey(activeMatch.id);\n   155→        fetchMatch(connection, matchPda)\n   156→          .then((updated) => {\n   157→            if (updated) {\n   158→              setActiveMatch(updated);\n   159→            } else {\n   160→              // Match account closed (claimed or cancelled)\n   161→              setActiveMatch(null);\n   162→            }\n   163→          })\n   164→          .catch(() => {\n   165→            // Ignore polling errors\n   166→          });\n   167→      }\n   168→    }, pollInterval);\n   169→    return () => clearInterval(interval);\n   170→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   171→\n   172→  const createMatch = useCallback(async () => {\n   173→    if (!connected || !publicKey) {\n   174→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   175→      return;\n   176→    }\n   177→    if (!selectedTier || !selectedSide) {\n   178→      setError(\"Select tier and side first.\");\n   179→      return;\n   180→    }\n   181→\n   182→    setCreating(true);\n   183→    setError(null);\n   184→    try {\n   185→      const { transaction, matchPda } = await buildCreateMatchTx(\n   186→        connection,\n   187→        publicKey,\n   188→        selectedTier,\n   189→        selectedSide\n   190→      );\n   191→\n   192→      await sendTransaction(transaction);\n   193→\n   194→      // Fetch the created match from on-chain\n   195→      const match = await fetchMatch(connection, matchPda);\n   196→      if (match) {\n   197→        setActiveMatch(match);\n   198→      }\n   199→\n   200→      setSelectedSide(null);\n   201→      refreshMatches();\n   202→    } catch (err) {\n   203→      setError(parseTransactionError(err));\n   204→    } finally {\n   205→      setCreating(false);\n   206→    }\n   207→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n   208→\n   209→  const joinMatch = useCallback(\n   210→    async (matchId: string) => {\n   211→      if (!connected || !publicKey) {\n   212→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   213→        return;\n   214→      }\n   215→\n   216→      setJoining(true);\n   217→      setJoiningMatchId(matchId);\n   218→      setError(null);\n   219→      try {\n   220→        // matchId is the match PDA base58 — fetch to get the creator\n   221→        const matchPda = new PublicKey(matchId);\n   222→        const existingMatch = await fetchMatch(connection, matchPda);\n   223→        if (!existingMatch) {\n   224→          setError(\"Match not found. It may have been cancelled.\");\n   225→          return;\n   226→        }\n   227→\n   228→        const matchCreator = new PublicKey(existingMatch.player1);\n   229→        const transaction = await buildJoinMatchTx(\n   230→          connection,\n   231→          publicKey,\n   232→          matchCreator\n   233→        );\n   234→\n   235→        await sendTransaction(transaction);\n   236→\n   237→        // Fetch updated match\n   238→        const updated = await fetchMatch(connection, matchPda);\n   239→        if (updated) {\n   240→          setActiveMatch(updated);\n   241→        }\n   242→\n   243→        refreshMatches();\n   244→      } catch (err) {\n   245→        setError(parseTransactionError(err));\n   246→      } finally {\n   247→        setJoining(false);\n   248→        setJoiningMatchId(null);\n   249→      }\n   250→    },\n   251→    [connected, publicKey, connection, sendTransaction, refreshMatches]\n   252→  );\n   253→\n   254→  const cancelMatch = useCallback(async () => {\n   255→    if (!connected || !publicKey || !activeMatch) {\n   256→      setError(\"No active match to cancel.\");\n   257→      return;\n   258→    }\n   259→\n   260→    setError(null);\n   261→    try {\n   262→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   263→      await sendTransaction(transaction);\n   264→      setActiveMatch(null);\n   265→      refreshMatches();\n   266→    } catch (err) {\n   267→      setError(parseTransactionError(err));\n   268→    }\n   269→  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n   270→\n   271→  const claimPayout = useCallback(async () => {\n   272→    if (!connected || !publicKey || !activeMatch) {\n   273→      setError(\"No active match to claim.\");\n   274→      return;\n   275→    }\n   276→\n   277→    setClaiming(true);\n   278→    setError(null);\n   279→    try {\n   280→      const matchCreator = new PublicKey(activeMatch.player1);\n   281→      const opponent = activeMatch.player2\n   282→        ? new PublicKey(activeMatch.player2)\n   283→        : PublicKey.default;\n   284→\n   285→      const transaction = await buildClaimPayoutTx(\n   286→        connection,\n   287→        publicKey,\n   288→        matchCreator,\n   289→        opponent\n   290→      );\n   291→\n   292→      await sendTransaction(transaction);\n   293→\n   294→      // Update local state\n   295→      setActiveMatch({ ...activeMatch, claimed: true });\n   296→    } catch (err) {\n   297→      setError(parseTransactionError(err));\n   298→    } finally {\n   299→      setClaiming(false);\n   300→    }\n   301→  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n   302→\n   303→  // Track if user explicitly cleared the match\n   304→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   305→\n   306→  const clearActiveMatch = useCallback(() => {\n   307→    setActiveMatch(null);\n   308→    setUserClearedMatch(true);\n   309→    setError(null);\n   310→    refreshMatches();\n   311→  }, [refreshMatches]);\n   312→\n   313→  // Check for existing active match on wallet connect\n   314→  useEffect(() => {\n   315→    if (publicKey && !activeMatch && !userClearedMatch) {\n   316→      fetchMatchByCreator(connection, publicKey)\n   317→        .then((match) => {\n   318→          if (match) {\n   319→            setActiveMatch(match);\n   320→          }\n   321→        })\n   322→        .catch(() => {\n   323→          // No active match found\n   324→        });\n   325→    }\n   326→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   327→\n   328→  // Reset userClearedMatch when creating or joining a new match\n   329→  useEffect(() => {\n   330→    if (activeMatch) {\n   331→      setUserClearedMatch(false);\n   332→    }\n   333→  }, [activeMatch]);\n   334→\n   335→  const value: CoinflipContextValue = {\n   336→    activeMatch,\n   337→    openMatches,\n   338→    userHistory,\n   339→    selectedTier,\n   340→    selectedSide,\n   341→    loading,\n   342→    creating,\n   343→    joining,\n   344→    claiming,\n   345→    joiningMatchId,\n   346→    error,\n   347→    clearError,\n   348→    setSelectedTier,\n   349→    setSelectedSide,\n   350→    createMatch,\n   351→    joinMatch,\n   352→    cancelMatch,\n   353→    claimPayout,\n   354→    clearActiveMatch,\n   355→    refreshMatches,\n   356→  };\n   357→\n   358→  return (\n   359→    <CoinflipContext.Provider value={value}>\n   360→      {children}\n   361→    </CoinflipContext.Provider>\n   362→  );\n   363→}\n   364→\n   365→export function useCoinflip(): CoinflipContextValue {\n   366→  const context = useContext(CoinflipContext);\n   367→  if (!context) {\n   368→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   369→  }\n   370→  return context;\n   371→}\n   372→"}]},"parent_tool_use_id":"toolu_01NAU6d4sgWxDaAFvf13a18q","session_id":"dcb8cfea-3149-4f02-a81d-4deae733513a","uuid":"c2007c4d-acb7-47d0-b475-26064f66331b"}
