{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012itGBmth2heS3DmAV8Sq6Q","type":"tool_result","content":"/**\n * Database client module — typed query functions for `rounds` and `operator_events`.\n *\n * Phase transitions are unidirectional: created → locked → settling → settled,\n * or created → expired. The application layer rejects backward transitions.\n */\n\nimport postgres from \"postgres\";\nimport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n\nexport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\nexport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n\nexport interface CloseCallRound {\n  round_id: string;\n  pda: string;\n  server_key: string;\n  phase: CloseCallPhase;\n  open_price: number;\n  open_price_expo: number;\n  close_price: number | null;\n  outcome: CloseCallOutcome;\n  green_pool: number;\n  red_pool: number;\n  total_fee: number;\n  green_entries: Array<{ player: string; amountLamports: number }>; // populated via JOIN on game_entries\n  red_entries: Array<{ player: string; amountLamports: number }>;   // populated via JOIN on game_entries\n  settle_tx: string | null;\n  created_at: Date;\n  settled_at: Date | null;\n}\n\nexport interface InsertCloseCallRoundParams {\n  roundId: string;\n  pda: string;\n  serverKey: string;\n  openPrice: number;\n  openPriceExpo: number;\n}\n\nexport type OperatorEventType =\n  | \"secret_generated\"\n  | \"tx_built\"\n  | \"match_detected\"\n  | \"settle_submitted\"\n  | \"settle_confirmed\"\n  | \"settle_failed\"\n  | \"settle_retried\"\n  | \"timeout_detected\";\n\nexport interface Round {\n  pda: string;\n  game: string;\n  creator: string;\n  server_key: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amount_lamports: number;\n  side: number;\n  match_id: string;\n  phase: RoundPhase;\n  target_slot: string | null;\n  settle_tx: string | null;\n  settle_attempts: number;\n  result_hash: Buffer | null;\n  result_side: number | null;\n  winner: string | null;\n  entries: Array<{ player: string; amountLamports: number }> | null; // populated via JOIN on game_entries\n  created_at: Date;\n  updated_at: Date;\n  settled_at: Date | null;\n}\n\nexport interface InsertRoundParams {\n  pda: string;\n  game: string;\n  creator: string;\n  serverKey: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amountLamports: number;\n  side: number;\n  matchId: string;\n  phase: RoundPhase;\n}\n\nexport interface OperatorEvent {\n  id: string;\n  pda: string | null;\n  event_type: OperatorEventType;\n  payload: unknown;\n  created_at: Date;\n}","is_error":false}]},"parent_tool_use_id":"toolu_011FEtT5pmcUxxcCPKx2ap8f","session_id":"c9711a7e-4153-4e8b-be5f-32a94d4f2fda","uuid":"8bf00502-903b-4fec-b450-59835d374ee5","timestamp":"2026-04-03T19:19:03.745Z"}
