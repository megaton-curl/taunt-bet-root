{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ek7pN3eNHAnUGk4fmN6xfr","type":"tool_result","content":"1\t-- 004_closecall_rounds.sql — Close Call pari-mutuel rounds (oracle-resolved, Pyth price).\n2\t\n3\tCREATE TABLE closecall_rounds (\n4\t  round_id        TEXT         PRIMARY KEY,\n5\t  pda             TEXT         UNIQUE NOT NULL,\n6\t  server_key      TEXT         NOT NULL,\n7\t  phase           TEXT         NOT NULL DEFAULT 'open' CHECK (phase IN ('open', 'settled', 'refunded')),\n8\t  open_price      BIGINT       NOT NULL,\n9\t  open_price_expo INT          NOT NULL,\n10\t  close_price     BIGINT,\n11\t  outcome         TEXT         NOT NULL DEFAULT 'pending' CHECK (outcome IN ('pending', 'green', 'red', 'refund')),\n12\t  green_pool      BIGINT       NOT NULL DEFAULT 0,\n13\t  red_pool        BIGINT       NOT NULL DEFAULT 0,\n14\t  total_fee       BIGINT       NOT NULL DEFAULT 0,\n15\t  settle_tx       TEXT,\n16\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n17\t  settled_at      TIMESTAMPTZ\n18\t);\n19\t\n20\tCREATE INDEX idx_closecall_rounds_phase ON closecall_rounds (phase);\n21\tCREATE INDEX idx_closecall_rounds_settled_at ON closecall_rounds (settled_at DESC);\n22\tCREATE INDEX idx_cc_rounds_settled ON closecall_rounds (settled_at DESC) WHERE phase = 'settled';\n23\t"}]},"parent_tool_use_id":"toolu_011FEtT5pmcUxxcCPKx2ap8f","session_id":"c9711a7e-4153-4e8b-be5f-32a94d4f2fda","uuid":"7838a551-6ba0-43e2-a302-062bc9af92a6","timestamp":"2026-04-03T19:18:53.988Z"}
