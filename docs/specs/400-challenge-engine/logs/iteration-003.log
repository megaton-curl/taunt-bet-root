{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ph4Ub4GruWjvF3GGpxBBwn","type":"tool_result","content":"1\t-- 003_auth.sql — JWT challenge-response + refresh tokens.\n2\t\n3\tCREATE TABLE auth_challenges (\n4\t  nonce       TEXT         PRIMARY KEY,\n5\t  wallet      TEXT         NOT NULL,\n6\t  cluster     TEXT         NOT NULL DEFAULT 'devnet',\n7\t  message     TEXT         NOT NULL,\n8\t  expires_at  TIMESTAMPTZ  NOT NULL,\n9\t  used        BOOLEAN      NOT NULL DEFAULT FALSE,\n10\t  created_at  TIMESTAMPTZ  NOT NULL DEFAULT now()\n11\t);\n12\t\n13\tCREATE TABLE refresh_tokens (\n14\t  id          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n15\t  user_id     TEXT         NOT NULL,\n16\t  wallet      TEXT         NOT NULL,\n17\t  token_hash  BYTEA        NOT NULL UNIQUE,\n18\t  family_id   TEXT         NOT NULL,\n19\t  expires_at  TIMESTAMPTZ  NOT NULL,\n20\t  revoked     BOOLEAN      NOT NULL DEFAULT FALSE,\n21\t  created_at  TIMESTAMPTZ  NOT NULL DEFAULT now()\n22\t);\n23\t\n24\tCREATE INDEX idx_refresh_tokens_user_id ON refresh_tokens (user_id);\n25\tCREATE INDEX idx_refresh_tokens_wallet ON refresh_tokens (wallet);\n26\tCREATE INDEX idx_refresh_tokens_family ON refresh_tokens (family_id);\n27\t"}]},"parent_tool_use_id":"toolu_011FEtT5pmcUxxcCPKx2ap8f","session_id":"c9711a7e-4153-4e8b-be5f-32a94d4f2fda","uuid":"3624466a-aa38-49ff-b36a-9fa4d6147f9e","timestamp":"2026-04-03T19:18:53.487Z"}
