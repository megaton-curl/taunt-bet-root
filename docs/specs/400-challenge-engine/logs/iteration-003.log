{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016dG9NsdvgUqWnLcfRGCThG","type":"tool_result","content":"1\t-- 006_player_profiles.sql — Player identity & profile.\n2\t--\n3\t-- Auto-created on first JWT auth. Wallet is internal only — all public\n4\t-- lookups use user_id or username.\n5\t\n6\tCREATE TABLE player_profiles (\n7\t  id                   BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n8\t  user_id              TEXT         UNIQUE NOT NULL,\n9\t  wallet               TEXT         UNIQUE NOT NULL,\n10\t  username             TEXT         UNIQUE NOT NULL,\n11\t  username_updated_at  TIMESTAMPTZ,\n12\t  avatar_url           TEXT,\n13\t  heat_multiplier      NUMERIC      NOT NULL DEFAULT 1.0,\n14\t  points_balance       BIGINT       NOT NULL DEFAULT 0,\n15\t  created_at           TIMESTAMPTZ  NOT NULL DEFAULT now()\n16\t);\n17\t\n18\tCREATE UNIQUE INDEX idx_player_profiles_username_lower ON player_profiles (LOWER(username));\n19\t"}]},"parent_tool_use_id":"toolu_011FEtT5pmcUxxcCPKx2ap8f","session_id":"c9711a7e-4153-4e8b-be5f-32a94d4f2fda","uuid":"96a50106-ae0f-4bc9-9bfc-7917471ecd0b","timestamp":"2026-04-03T19:19:26.274Z"}
