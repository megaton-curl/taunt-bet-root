}\n259\t\n260\t/**\n261\t * Build PlatformConfig account data matching the on-chain layout.\n262\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n263\t */\n264\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n265\t  const buf = Buffer.alloc(74);\n266\t  // discriminator (8 bytes) — zeroed is fine for mock\n267\t  // authority at offset 8 — use default\n268\t  PublicKey.default.toBuffer().copy(buf, 8);\n269\t  // treasury at offset 40\n270\t  treasury.toBuffer().copy(buf, 40);\n271\t  // fee_bps at offset 72\n272\t  buf.writeUInt16LE(feeBps, 72);\n273\t  return buf;\n274\t}\n275\t\n276\t// ---------------------------------------------------------------------------\n277\t// Test suite\n278\t// ---------------------------------------------------------------------------\n279\t\n280\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n281\t  let db: Db;\n282\t  let rawSql: ReturnType<typeof postgres>;\n283\t  let mockConn: MockConnection;\n284\t  let app: Hono;\n285\t\n286\t  const serverKeypair = Keypair.generate();\n287\t  const creatorKeypair = Keypair.generate();\n288\t  const opponentKeypair = Keypair.generate();\n289\t  const treasuryKeypair = Keypair.generate();\n290\t  const entropyKeypair = Keypair.generate();\n291\t  const entropyAccount = entropyKeypair.publicKey;\n292\t\n293\t  const entropyData = Buffer.alloc(32);\n294\t  entropyData[0] = 0xab;\n295\t  entropyData[1] = 0xcd;\n296\t  entropyData[15] = 0x42;\n297\t\n298\t  beforeAll(async () => {\n299\t    rawSql = makeSql();"}]},"parent_tool_use_id":null,"session_id":"c9711a7e-4153-4e8b-be5f-32a94d4f2fda","uuid":"d379e948-6d09-4a63-a3bd-303852a465bd","timestamp":"2026-04-03T19:25:28.348Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"\n  async confirmTransaction() {\n    return { value: { err: null }, context: { slot: this._slot } };\n  }\n\n  async getBlockTime(_slot: number) {\n    return Math.floor(Date.now() / 1000);\n  }\n\n  async getBalance() {\n    return 2 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Account data builders\n// ---------------------------------------------------------------------------\n\nasync function buildMatchAccountData(params: {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: Buffer;\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  matchId: Buffer;\n}): Promise<Buffer> {\n  return encodeCoinflipMatch({\n    creator: params.creator,\n    opponent: params.opponent,\n    server: params.server,\n    entryAmount: params.entryAmount,\n    creatorSide: params.creatorSide,\n    phase: params.phase,\n    commitment: [...params.commitment],\n    algorithmVer: params.algorithmVer,\n    targetSlot: params.targetSlot,\n    resolveDeadline: params.resolveDeadline,\n    resultHash: new Array(32).fill(0),\n    result: 0,\n    winner: PublicKey.default,\n    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n    matchId: [...params.matchId],\n    bump: 0,\n  });\n}\n\nasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n  return encodeCoinflipConfig({\n    authority: PublicKey.default,\n    treasury,\n    paused: false,\n    bump: 0,\n  });\n}\n\n/**\n * Build PlatformConfig account data matching the on-chain layout.\n * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n */\nfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n  const buf = Buffer.alloc(74);\n  // discriminator (8 bytes) — zeroed is fine for mock\n  // authority at offset 8 — use default\n  PublicKey.default.toBuffer().copy(buf, 8);\n  // treasury at offset 40\n  treasury.toBuffer().copy(buf, 40);\n  // fee_bps at offset 72\n  buf.writeUInt16LE(feeBps, 72);\n  return buf;\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Integration: create → join → settle lifecycle\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    rawSql = makeSql();","numLines":100,"startLine":200,"totalLines":1269}}}
