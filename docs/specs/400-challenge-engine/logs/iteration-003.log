s', 200,  3),\n  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Play 5 Games',      'Complete 5 games of any type',           'game_completed', 'any',       'count', 5, 'points', 250,  4),\n  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Win 3 Games',       'Win 3 games of any type',                'game_won',       'any',       'count', 3, 'points', 300,  5),\n  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Try Close Call',    'Play a Close Call round',                'game_completed', 'closecall', 'count', 1, 'points', 150,  6);\n\n-- Weekly challenge templates (~4, top 2 by sort_order assigned each week)\nINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, sort_order) VALUES\n  ((SELECT id FROM campaigns WHERE name = 'Weekly Challenges'), 'Play 20 Games',         'Complete 20 games of any type',      'game_completed', 'any', 'count',             20, 'points', 1000, 1),\n  ((SELECT id FROM campaigns WHERE name = 'Weekly Challenges'), 'Win 10 Games',          'Win 10 games of any type',           'game_won',       'any', 'count',             10, 'points', 1500, 2),\n  ((SELECT id FROM campaigns WHERE name = 'Weekly Challenges'), 'Play Every Game Type',  'Play at least one of each game type','game_completed', 'any', 'unique_game_types',  3, 'points', 2000, 3),\n  ((SELECT id FROM campaigns WHERE name = 'Weekly Challenges'), 'Fill 5 Lobbies',        'Create 5 games that get filled',     'lobby_filled',   'any', 'count',              5, 'points', 1200, 4);\n\n-- Onboarding challenge templates (3-step chain via prerequisite_id)\n-- Step 1: no prerequisite\nINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order) VALUES\n  ((SELECT id FROM campaigns WHERE name = 'Onboarding'), 'Play Your First Game', 'Complete any game to get started', 'game_completed', 'any', 'count', 1, 'points', 1000, NULL, 1);\n\n-- Step 2: prerequisite = step 1\nINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order) VALUES\n  ((SELECT id FROM campaigns WHERE name = 'Onboarding'), 'Win a Game', 'Win any game', 'game_won', 'any', 'count', 1, 'points', 1500,\n   (SELECT id FROM challenges WHERE campaign_id = (SELECT id FROM campaigns WHERE name = 'Onboarding') AND sort_order = 1), 2);\n\n-- Step 3: prerequisite = step 2\nINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order) VALUES\n  ((SELECT id FROM campaigns WHERE name = 'Onboarding'), 'Try All 3 Game Types', 'Play coinflip, jackpot, and close call', 'game_completed', 'any', 'unique_game_types', 3, 'points', 2500,\n   (SELECT id FROM challenges WHERE campaign_id = (SELECT id FROM campaigns WHERE name = 'Onboarding') AND sort_order = 2), 3);\n\n-- Daily completion bonus (complete all 3 daily challenges -> bonus crate)\nINSERT INTO completion_bonuses (campaign_id, title, description, required_count, reward_type) VALUES\n  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Daily Bonus Crate', 'Complete all daily challenges for a bonus crate', 3, 'crate');\n","structuredPatch":[],"originalFile":null}}
