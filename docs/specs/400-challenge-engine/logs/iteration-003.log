{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SiBKbGGy36oS7i8atnwNPK","type":"tool_result","content":"{\n  \"name\": \"@taunt-bet/backend\",\n  \"version\": \"0.1.0\",\n  \"private\": true,\n  \"type\": \"module\",\n  \"main\": \"./src/index.ts\",\n  \"types\": \"./src/index.ts\",\n  \"exports\": {\n    \".\": \"./src/index.ts\"\n  },\n  \"scripts\": {\n    \"dev\": \"tsx watch --env-file=.env src/index.ts\",\n    \"start\": \"tsx src/migrate.ts && tsx src/index.ts\",\n    \"lint\": \"eslint .\",\n    \"lint:fix\": \"eslint . --fix\",\n    \"typecheck\": \"tsc --noEmit\",\n    \"migrate\": \"tsx --env-file=.env src/migrate.ts\",\n    \"migrate:status\": \"tsx --env-file=.env src/migrate.ts status\",\n    \"test\": \"vitest --passWithNoTests\"\n  },\n  \"dependencies\": {\n    \"@coral-xyz/anchor\": \"^0.32.1\",\n    \"@hono/node-server\": \"^1.19.11\",\n    \"@hono/swagger-ui\": \"^0.6.1\",\n    \"@pythnetwork/hermes-client\": \"^3.1.0\",\n    \"@taunt-bet/anchor-client\": \"workspace:*\",\n    \"@solana/web3.js\": \"^1.98.0\",\n    \"bs58\": \"^6.0.0\",\n    \"hono\": \"^4.6.0\",\n    \"jose\": \"^6.0.0\",\n    \"postgres\": \"^3.4.0\",\n    \"tweetnacl\": \"^1.0.3\"\n  },\n  \"devDependencies\": {\n    \"@taunt-bet/config\": \"workspace:*\",\n    \"@types/node\": \"^22.10.0\",\n    \"tsx\": \"^4.7.0\",\n    \"typescript\": \"^5.7.0\",\n    \"vitest\": \"^2.1.0\"\n  }","is_error":false}]},"parent_tool_use_id":"toolu_011FEtT5pmcUxxcCPKx2ap8f","session_id":"c9711a7e-4153-4e8b-be5f-32a94d4f2fda","uuid":"5ca44904-57a3-407b-9e4f-0950cc8aa6d8","timestamp":"2026-04-03T19:20:28.552Z"}
