{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LdrwyMhFoccvVBEPQJGNk4","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n31\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n32\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n33\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n34\t\n35\t// ---------------------------------------------------------------------------\n36\t// Constants\n37\t// ---------------------------------------------------------------------------\n38\t\n39\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n40\t\n41\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n42\tfunction makeSql() {\n43\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n44\t  // Dev container: postgres listens on Unix socket only\n45\t  return postgres({\n46\t    host: \"/var/run/postgresql\",\n47\t    user: \"vscode\",\n48\t    database: \"rng_utopia_dev\",\n49\t  });\n50\t}\n51\t\n52\tconst AMOUNT_LAMPORTS = 5_000_000;\n53\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n54\tconst SIDE_HEADS = 0;\n55\tconst PHASE_LOCKED = 1;\n56\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n57\t\n58\t// ---------------------------------------------------------------------------\n59\t// JWT helper\n60\t// ---------------------------------------------------------------------------\n61\t\n62\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n63\t  const now = Math.floor(Date.now() / 1000);\n64\t  return new SignJWT({ wallet })\n65\t    .setProtectedHeader({ alg: \"HS256\" })\n66\t    .setSubject(userId)\n67\t    .setIssuedAt(now)\n68\t    .setExpirationTime(now + 3600)\n69\t    .sign(JWT_SECRET);\n70\t}\n71\t\n72\tfunction userIdFromWallet(wallet: string) {\n73\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n74\t}\n75\t\n76\t// ---------------------------------------------------------------------------\n77\t// Mock Connection\n78\t// ---------------------------------------------------------------------------\n79\t\n80\t/**\n81\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n82\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n83\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n84\t */\n85\tclass MockConnection {\n86\t  private _slot = 200;\n87\t  private _accounts = new Map<\n88\t    string,\n89\t    {\n90\t      data: Buffer;\n91\t      lamports: number;\n92\t      owner: PublicKey;\n93\t      executable: boolean;\n94\t    }\n95\t  >();\n96\t  lastRawTx: Buffer | null = null;\n97\t\n98\t  set slot(s: number) {\n99\t    this._slot = s;\n100\t  }"}]},"parent_tool_use_id":"toolu_014YfCnAqEH2k1MF6gv677Nm","session_id":"c9711a7e-4153-4e8b-be5f-32a94d4f2fda","uuid":"6f8f5c56-fc75-4804-aab4-07e9b696c2da","timestamp":"2026-04-03T19:18:42.010Z"}
