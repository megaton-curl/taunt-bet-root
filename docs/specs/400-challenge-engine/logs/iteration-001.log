{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DjVKDSkP7jeFrWkttSz7ua","type":"tool_result","content":"1\t/**\n2\t * Handler registry — maps event type strings to handler functions.\n3\t *\n4\t * One handler per event type (no pub/sub fan-out for v1).\n5\t * Handlers must be idempotent — re-processing is a safe no-op.\n6\t */\n7\t\n8\timport type { EventType } from \"./event-types.js\";\n9\t\n10\texport type EventHandler = (\n11\t  payload: Record<string, unknown>,\n12\t) => Promise<void>;\n13\t\n14\tconst handlers = new Map<string, EventHandler>();\n15\t\n16\texport function registerHandler(\n17\t  eventType: EventType,\n18\t  handler: EventHandler,\n19\t): void {\n20\t  handlers.set(eventType, handler);\n21\t}\n22\t\n23\texport function getHandler(eventType: string): EventHandler | undefined {\n24\t  return handlers.get(eventType);\n25\t}\n26\t\n27\t/** Remove all registered handlers. Used by tests for isolation. */\n28\texport function clearHandlers(): void {\n29\t  handlers.clear();\n30\t}\n31\t"}]},"parent_tool_use_id":"toolu_01QAPPUhUjLzckYrk1KWaFEw","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"297e671a-d184-4253-bc8f-36eff2b0c59c","timestamp":"2026-04-03T18:48:26.851Z"}
