{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NwymX9u8KH5TnkP4iv1h65","type":"tool_result","content":"800\t *\n801\t * Two signers: player (pays bet) + server (pays rent on first call).\n802\t * Price + bet info passed as instruction args.\n803\t * Uses init_if_needed — works for both round creation and joining.\n804\t */\n805\texport function buildCloseCallBetIx(\n806\t  serverPubkey: PublicKey,\n807\t  playerPubkey: PublicKey,\n808\t  minuteTs: bigint,\n809\t  side: number,\n810\t  amountLamports: bigint,\n811\t  openPrice: bigint,\n812\t  openPriceExpo: number,\n813\t): TransactionInstruction {\n814\t  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n815\t  const [configPda] = deriveCloseCallConfigPda();\n816\t  const data = encodeCcBetData(\n817\t    CC_BET_DISCRIMINATOR,\n818\t    minuteTs,\n819\t    side,\n820\t    amountLamports,\n821\t    openPrice,\n822\t    openPriceExpo,\n823\t  );\n824\t\n825\t  return new TransactionInstruction({\n826\t    keys: [\n827\t      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n828\t      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n829\t      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n830\t      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n831\t      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n832\t    ],\n833\t    programId: CLOSECALL_PROGRAM_ID,\n834\t    data,\n835\t  });\n836\t}\n837\t\n838\t/**\n839\t * Build a `settle_round` instruction (no transaction wrapping).\n840\t * Price is passed as instruction args (no on-chain Pyth account).\n841\t */\n842\texport function buildCloseCallSettleRoundIx(\n843\t  serverPubkey: PublicKey,\n844\t  minuteTs: bigint,\n845\t  closePrice: bigint,\n846\t  closePriceExpo: number,\n847\t  treasury: PublicKey,\n848\t  winnerAccounts: PublicKey[],\n849\t): TransactionInstruction {\n850\t  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n851\t  const [platformConfigPda] = derivePlatformConfigPda();\n852\t  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n853\t\n854\t  return new TransactionInstruction({\n855\t    keys: [\n856\t      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n857\t      { pubkey: roundPda, isSigner: false, isWritable: true },\n858\t      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n859\t      { pubkey: treasury, isSigner: false, isWritable: true },\n860\t      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n861\t      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n862\t    ],\n863\t    programId: CLOSECALL_PROGRAM_ID,\n864\t    data,\n865\t  });\n866\t}\n867\t\n868\t/**\n869\t * Build a partially-signed `bet` transaction for the Close Call program.\n870\t *\n871\t * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n872\t * Server signs immediately; the frontend must add the player signature before submitting.\n873\t * Works for both round creation (first bet) and joining (subsequent bets).\n874\t */\n875\texport async function buildCloseCallBetTx(\n876\t  deps: CloseCallTxDeps,\n877\t  playerPubkey: PublicKey,\n878\t  minuteTs: bigint,\n879\t  side: number,\n880\t  amountLamports: bigint,\n881\t  openPrice: bigint,\n882\t  openPriceExpo: number,\n883\t): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n884\t  const { connection, serverKeypair } = deps;\n885\t\n886\t  const instruction = buildCloseCallBetIx(\n887\t    serverKeypair.publicKey,\n888\t    playerPubkey,\n889\t    minuteTs,\n890\t    side,\n891\t    amountLamports,\n892\t    openPrice,\n893\t    openPriceExpo,\n894\t  );\n895\t\n896\t  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n897\t\n898\t  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n899\t  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n900\t  tx.add(instruction);\n901\t  tx.partialSign(serverKeypair);\n902\t\n903\t  return { tx, roundPda };\n904\t}\n905\t\n906\t/**\n907\t * Build a signed `settle_round` transaction for the Close Call program.\n908\t *\n909\t * Price is passed as instruction args. Winners (or all players for refund)\n910\t * are passed as remaining accounts for auto-payout.\n911\t */\n912\texport async function buildCloseCallSettleRoundTx(\n913\t  deps: CloseCallTxDeps,\n914\t  minuteTs: bigint,\n915\t  closePrice: bigint,\n916\t  closePriceExpo: number,\n917\t  treasury: PublicKey,\n918\t  winnerAccounts: PublicKey[],\n919\t): Promise<Transaction> {\n920\t  const { connection, serverKeypair } = deps;\n921\t\n922\t  const instruction = buildCloseCallSettleRoundIx(\n923\t    serverKeypair.publicKey,\n924\t    minuteTs,\n925\t    closePrice,\n926\t    closePriceExpo,\n927\t    treasury,\n928\t    winnerAccounts,\n929\t  );\n930\t\n931\t  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n932\t  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n933\t  tx.add(instruction);\n934\t  tx.sign(serverKeypair);\n935\t\n936\t  return tx;\n937\t}\n938\t\n939\t/**\n940\t * Build a signed `timeout_refund` transaction for the Close Call program.\n941\t *\n942\t * Permissionless after the resolve deadline. Refunds all players their exact\n943\t * deposit via remaining accounts.\n944\t */\n945\texport async function buildCloseCallTimeoutRefundTx(\n946\t  deps: CloseCallTxDeps,\n947\t  minuteTs: bigint,\n948\t  playerAccounts: PublicKey[],\n949\t): Promise<Transaction> {\n950\t  const { connection, serverKeypair } = deps;\n951\t\n952\t  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n953\t  const [configPda] = deriveCloseCallConfigPda();\n954\t  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n955\t\n956\t  const keys = [\n957\t    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n958\t    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n959\t    { pubkey: configPda, isSigner: false, isWritable: false },               // closecall_config\n960\t    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n961\t    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n962\t  ];\n963\t\n964\t  const instruction = new TransactionInstruction({\n965\t    keys,\n966\t    programId: CLOSECALL_PROGRAM_ID,\n967\t    data,\n968\t  });\n969\t\n970\t  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n971\t  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n972\t  tx.add(instruction);\n973\t  tx.sign(serverKeypair);\n974\t\n975\t  return tx;\n976\t}\n977\t\n978\t// ---------------------------------------------------------------------------\n979\t// Error types\n980\t// ---------------------------------------------------------------------------\n981\t\n982\t/** Permanent failure — should not be retried. */\n983\texport class PermanentSettleError extends Error {\n984\t  readonly permanent = true;\n985\t  constructor(message: string) {\n986\t    super(message);\n987\t    this.name = \"PermanentSettleError\";\n988\t  }\n989\t}\n990\t\n991\t/** Transient failure — safe to retry. */\n992\texport class TransientSettleError extends Error {\n993\t  readonly permanent = false;\n994\t  constructor(message: string) {\n995\t    super(message);\n996\t    this.name = \"TransientSettleError\";\n997\t  }\n998\t}\n999\t"}]},"parent_tool_use_id":"toolu_01TqiXb6r2UeRy5smFR983XZ","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"925297a1-4dc6-4f38-8f12-0041f2fd14f2","timestamp":"2026-04-03T18:48:22.217Z"}
