{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Ve18gsmSKjD1JfiSvpRkb","type":"tool_result","content":"1\t/**\n2\t * Simple SQL migration runner with version tracking.\n3\t *\n4\t * Reads numbered `.sql` files from `../migrations/`, applies them in order,\n5\t * and tracks which have been applied in a `_migrations` table. Each migration\n6\t * runs inside a transaction so partial application is impossible.\n7\t *\n8\t * Migrations are idempotent: re-running skips already-applied files.\n9\t *\n10\t * Usage:  tsx src/migrate.ts          (uses DATABASE_URL from env)\n11\t *         tsx src/migrate.ts status   (shows applied migrations)\n12\t */\n13\t\n14\timport { readdir, readFile } from \"node:fs/promises\";\n15\timport { join, dirname } from \"node:path\";\n16\timport { fileURLToPath } from \"node:url\";\n17\timport postgres from \"postgres\";\n18\timport { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n19\t\n20\tconst __dirname = dirname(fileURLToPath(import.meta.url));\n21\tconst MIGRATIONS_DIR = join(__dirname, \"..\", \"migrations\");\n22\t\n23\tinterface MigrationFile {\n24\t  version: number;\n25\t  name: string;\n26\t  path: string;\n27\t}\n28\t\n29\tfunction quoteIdentifier(identifier: string): string {\n30\t  if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(identifier)) {\n31\t    throw new Error(`Invalid schema name: ${identifier}`);\n32\t  }\n33\t  return `\"${identifier}\"`;\n34\t}\n35\t\n36\tasync function loadMigrationFiles(): Promise<MigrationFile[]> {\n37\t  const entries = await readdir(MIGRATIONS_DIR);\n38\t  const sqlFiles = entries\n39\t    .filter((f) => f.endsWith(\".sql\"))\n40\t    .sort();\n41\t\n42\t  return sqlFiles.map((name) => {\n43\t    const version = parseInt(name.split(\"_\")[0]!, 10);\n44\t    if (Number.isNaN(version)) {\n45\t      throw new Error(`Migration file ${name} does not start with a numeric version`);\n46\t    }\n47\t    return { version, name, path: join(MIGRATIONS_DIR, name) };\n48\t  });\n49\t}\n50\t\n51\tasync function ensureMigrationsTable(sql: postgres.Sql): Promise<void> {\n52\t  await sql`\n53\t    CREATE TABLE IF NOT EXISTS _migrations (\n54\t      version   INT PRIMARY KEY,\n55\t      name      TEXT NOT NULL,\n56\t      applied_at TIMESTAMPTZ DEFAULT now()\n57\t    )\n58\t  `;\n59\t}\n60\t\n61\tasync function ensureSchema(sql: postgres.Sql, schema: string): Promise<void> {\n62\t  if (schema === \"public\") {\n63\t    return;\n64\t  }\n65\t\n66\t  await sql.unsafe(`CREATE SCHEMA IF NOT EXISTS ${quoteIdentifier(schema)}`);\n67\t}\n68\t\n69\tasync function getAppliedVersions(sql: postgres.Sql): Promise<Set<number>> {\n70\t  const rows = await sql<{ version: number }[]>`\n71\t    SELECT version FROM _migrations ORDER BY version\n72\t  `;\n73\t  return new Set(rows.map((r) => r.version));\n74\t}\n75\t\n76\tasync function applyMigration(\n77\t  sql: postgres.Sql,\n78\t  migration: MigrationFile,\n79\t): Promise<void> {\n80\t  const content = await readFile(migration.path, \"utf-8\");\n81\t\n82\t  // Run migration SQL (idempotent via IF NOT EXISTS), then record it.\n83\t  // Using sql.begin with unsafe for both statements to stay in one transaction.\n84\t  await sql.begin(async (tx) => {\n85\t    await tx.unsafe(content);\n86\t    await tx.unsafe(\n87\t      \"INSERT INTO _migrations (version, name) VALUES ($1, $2)\",\n88\t      [migration.version, migration.name],\n89\t    );\n90\t  });\n91\t}\n92\t\n93\texport async function runMigrations(databaseUrl: string): Promise<void> {\n94\t  const sql = postgres(databaseUrl);\n95\t\n96\t  try {\n97\t    await ensureSchema(sql, dbSchema);\n98\t    await ensureMigrationsTable(sql);\n99\t\n100\t    const applied = await getAppliedVersions(sql);\n101\t    const files = await loadMigrationFiles();\n102\t    const pending = files.filter((f) => !applied.has(f.version));\n103\t\n104\t    if (pending.length === 0) {\n105\t      console.log(\"All migrations are up to date.\");\n106\t      return;\n107\t    }\n108\t\n109\t    for (const migration of pending) {\n110\t      console.log(`Applying migration ${migration.name}...`);\n111\t      await applyMigration(sql, migration);\n112\t      console.log(`  ✓ ${migration.name} applied.`);\n113\t    }\n114\t\n115\t    console.log(`${pending.length} migration(s) applied successfully.`);\n116\t  } finally {\n117\t    await sql.end();\n118\t  }\n119\t}\n120\t\n121\tasync function showStatus(databaseUrl: string): Promise<void> {\n122\t  const sql = postgres(databaseUrl);\n123\t\n124\t  try {\n125\t    await ensureSchema(sql, dbSchema);\n126\t    await ensureMigrationsTable(sql);\n127\t\n128\t    const applied = await getAppliedVersions(sql);\n129\t    const files = await loadMigrationFiles();\n130\t\n131\t    console.log(\"Migration status:\");\n132\t    for (const file of files) {\n133\t      const status = applied.has(file.version) ? \"[applied]\" : \"[pending]\";\n134\t      console.log(`  ${status} ${file.name}`);\n135\t    }\n136\t  } finally {\n137\t    await sql.end();\n138\t  }\n139\t}\n140\t\n141\t// CLI entry point\n142\tconst command = process.argv[2];\n143\tconst rawDatabaseUrl = process.env.DATABASE_URL;\n144\tconst dbSchema = loadDbSchemaFromEnv();\n145\t\n146\tif (!rawDatabaseUrl) {\n147\t  console.error(\"DATABASE_URL environment variable is required\");\n148\t  process.exit(1);\n149\t}\n150\t\n151\tconst databaseUrl = applyDbSchemaToUrl(rawDatabaseUrl, dbSchema);\n152\t\n153\tif (command === \"status\") {\n154\t  await showStatus(databaseUrl);\n155\t} else {\n156\t  await runMigrations(databaseUrl);\n157\t}\n158\t"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"80cc11c7-bbbf-4239-9273-c284a1706dea","timestamp":"2026-04-03T18:49:12.174Z"}
