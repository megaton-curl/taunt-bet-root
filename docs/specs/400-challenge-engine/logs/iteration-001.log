{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0161auuXMkp5QuJnHy2ibPoT","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n31\t\n32\t// ---------------------------------------------------------------------------\n33\t// Constants\n34\t// ---------------------------------------------------------------------------\n35\t\n36\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n37\t\n38\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n39\tfunction makeSql() {\n40\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n41\t  // Dev container: postgres listens on Unix socket only\n42\t  return postgres({\n43\t    host: \"/var/run/postgresql\",\n44\t    user: \"vscode\",\n45\t    database: \"rng_utopia_dev\",\n46\t  });\n47\t}\n48\t\n49\tconst AMOUNT_LAMPORTS = 5_000_000;\n50\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n51\tconst SIDE_HEADS = 0;\n52\tconst PHASE_LOCKED = 1;\n53\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n54\t\n55\t// ---------------------------------------------------------------------------\n56\t// JWT helper\n57\t// ---------------------------------------------------------------------------\n58\t\n59\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n60\t  const now = Math.floor(Date.now() / 1000);\n61\t  return new SignJWT({ wallet })\n62\t    .setProtectedHeader({ alg: \"HS256\" })\n63\t    .setSubject(userId)\n64\t    .setIssuedAt(now)\n65\t    .setExpirationTime(now + 3600)\n66\t    .sign(JWT_SECRET);\n67\t}\n68\t\n69\tfunction userIdFromWallet(wallet: string) {\n70\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n71\t}\n72\t\n73\t// ---------------------------------------------------------------------------\n74\t// Mock Connection\n75\t// ---------------------------------------------------------------------------\n76\t\n77\t/**\n78\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n79\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n80\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n81\t */\n82\tclass MockConnection {\n83\t  private _slot = 200;\n84\t  private _accounts = new Map<\n85\t    string,\n86\t    {\n87\t      data: Buffer;\n88\t      lamports: number;\n89\t      owner: PublicKey;\n90\t      executable: boolean;\n91\t    }\n92\t  >();\n93\t  lastRawTx: Buffer | null = null;\n94\t\n95\t  set slot(s: number) {\n96\t    this._slot = s;\n97\t  }\n98\t  get slot() {\n99\t    return this._slot;\n100\t  }\n101\t\n102\t  setAccount(\n103\t    pubkey: PublicKey,\n104\t    data: Buffer,\n105\t    opts?: { lamports?: number; owner?: PublicKey },\n106\t  ) {\n107\t    this._accounts.set(pubkey.toBase58(), {\n108\t      data,\n109\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n110\t      owner: opts?.owner ?? SystemProgram.programId,\n111\t      executable: false,\n112\t    });\n113\t  }\n114\t\n115\t  removeAccount(pubkey: PublicKey) {\n116\t    this._accounts.delete(pubkey.toBase58());\n117\t  }\n118\t\n119\t  async getLatestBlockhash() {\n120\t    return {\n121\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n122\t      lastValidBlockHeight: 999_999,\n123\t    };\n124\t  }\n125\t\n126\t  async getSlot() {\n127\t    return this._slot;\n128\t  }\n129\t\n130\t  async getAccountInfo(pubkey: PublicKey) {\n131\t    const acc = this._accounts.get(pubkey.toBase58());\n132\t    if (!acc) return null;\n133\t    return { ...acc, rentEpoch: 0 };\n134\t  }\n135\t\n136\t  async getProgramAccounts(\n137\t    programId: PublicKey,\n138\t    config?: {\n139\t      filters?: Array<\n140\t        | { dataSize: number }\n141\t        | { memcmp: { offset: number; bytes: string } }\n142\t      >;\n143\t    },\n144\t  ) {\n145\t    const results: Array<{\n146\t      pubkey: PublicKey;\n147\t      account: {\n148\t        data: Buffer;\n149\t        lamports: number;\n150\t        owner: PublicKey;"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"a8e83548-8ed6-4f3a-b6ea-ad4f94d47e8d","timestamp":"2026-04-03T18:49:09.374Z"}
