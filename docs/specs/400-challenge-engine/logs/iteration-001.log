{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QvJGssMTbtonk97ZUEx3Ym","type":"tool_result","content":"80\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n81\t */\n82\tclass MockConnection {\n83\t  private _slot = 200;\n84\t  private _accounts = new Map<\n85\t    string,\n86\t    {\n87\t      data: Buffer;\n88\t      lamports: number;\n89\t      owner: PublicKey;\n90\t      executable: boolean;\n91\t    }\n92\t  >();\n93\t  lastRawTx: Buffer | null = null;\n94\t\n95\t  set slot(s: number) {\n96\t    this._slot = s;\n97\t  }\n98\t  get slot() {\n99\t    return this._slot;\n100\t  }\n101\t\n102\t  setAccount(\n103\t    pubkey: PublicKey,\n104\t    data: Buffer,\n105\t    opts?: { lamports?: number; owner?: PublicKey },\n106\t  ) {\n107\t    this._accounts.set(pubkey.toBase58(), {\n108\t      data,\n109\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n110\t      owner: opts?.owner ?? SystemProgram.programId,\n111\t      executable: false,\n112\t    });\n113\t  }\n114\t\n115\t  removeAccount(pubkey: PublicKey) {\n116\t    this._accounts.delete(pubkey.toBase58());\n117\t  }\n118\t\n119\t  async getLatestBlockhash() {\n120\t    return {\n121\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n122\t      lastValidBlockHeight: 999_999,\n123\t    };\n124\t  }\n125\t\n126\t  async getSlot() {\n127\t    return this._slot;\n128\t  }\n129\t\n130\t  async getAccountInfo(pubkey: PublicKey) {\n131\t    const acc = this._accounts.get(pubkey.toBase58());\n132\t    if (!acc) return null;\n133\t    return { ...acc, rentEpoch: 0 };\n134\t  }\n135\t\n136\t  async getProgramAccounts(\n137\t    programId: PublicKey,\n138\t    config?: {\n139\t      filters?: Array<\n140\t        | { dataSize: number }\n141\t        | { memcmp: { offset: number; bytes: string } }\n142\t      >;\n143\t    },\n144\t  ) {\n145\t    const results: Array<{\n146\t      pubkey: PublicKey;\n147\t      account: {\n148\t        data: Buffer;\n149\t        lamports: number;\n150\t        owner: PublicKey;\n151\t        executable: boolean;\n152\t        rentEpoch: number;\n153\t      };\n154\t    }> = [];\n155\t\n156\t    for (const [key, acc] of this._accounts) {\n157\t      if (!acc.owner.equals(programId)) continue;\n158\t\n159\t      let matches = true;\n160\t      if (config?.filters) {\n161\t        for (const filter of config.filters) {\n162\t          if (\"dataSize\" in filter) {\n163\t            if (acc.data.length !== filter.dataSize) {\n164\t              matches = false;\n165\t              break;\n166\t            }\n167\t          }\n168\t          if (\"memcmp\" in filter) {\n169\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n170\t            const actual = acc.data.subarray(\n171\t              filter.memcmp.offset,\n172\t              filter.memcmp.offset + expected.length,\n173\t            );\n174\t            if (Buffer.compare(actual, expected) !== 0) {\n175\t              matches = false;\n176\t              break;\n177\t            }\n178\t          }\n179\t        }\n180\t      }\n181\t\n182\t      if (matches) {\n183\t        results.push({\n184\t          pubkey: new PublicKey(key),\n185\t          account: { ...acc, rentEpoch: 0 },\n186\t        });\n187\t      }\n188\t    }\n189\t    return results;\n190\t  }\n191\t\n192\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n193\t    this.lastRawTx = Buffer.from(rawTx);\n194\t    // Return a deterministic fake signature\n195\t    return bs58.encode(Buffer.alloc(64, 0x01));\n196\t  }\n197\t\n198\t  async confirmTransaction() {\n199\t    return { value: { err: null }, context: { slot: this._slot } };"}]},"parent_tool_use_id":null,"session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"70514752-36ba-45fe-91bb-47c3eb5f9478","timestamp":"2026-04-03T18:52:16.429Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":" * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n */\nclass MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getSlot() {\n    return this._slot;\n  }\n\n  async getAccountInfo(pubkey: PublicKey) {\n    const acc = this._accounts.get(pubkey.toBase58());\n    if (!acc) return null;\n    return { ...acc, rentEpoch: 0 };\n  }\n\n  async getProgramAccounts(\n    programId: PublicKey,\n    config?: {\n      filters?: Array<\n        | { dataSize: number }\n        | { memcmp: { offset: number; bytes: string } }\n      >;\n    },\n  ) {\n    const results: Array<{\n      pubkey: PublicKey;\n      account: {\n        data: Buffer;\n        lamports: number;\n        owner: PublicKey;\n        executable: boolean;\n        rentEpoch: number;\n      };\n    }> = [];\n\n    for (const [key, acc] of this._accounts) {\n      if (!acc.owner.equals(programId)) continue;\n\n      let matches = true;\n      if (config?.filters) {\n        for (const filter of config.filters) {\n          if (\"dataSize\" in filter) {\n            if (acc.data.length !== filter.dataSize) {\n              matches = false;\n              break;\n            }\n          }\n          if (\"memcmp\" in filter) {\n            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n            const actual = acc.data.subarray(\n              filter.memcmp.offset,\n              filter.memcmp.offset + expected.length,\n            );\n            if (Buffer.compare(actual, expected) !== 0) {\n              matches = false;\n              break;\n            }\n          }\n        }\n      }\n\n      if (matches) {\n        results.push({\n          pubkey: new PublicKey(key),\n          account: { ...acc, rentEpoch: 0 },\n        });\n      }\n    }\n    return results;\n  }\n\n  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n    this.lastRawTx = Buffer.from(rawTx);\n    // Return a deterministic fake signature\n    return bs58.encode(Buffer.alloc(64, 0x01));\n  }\n\n  async confirmTransaction() {\n    return { value: { err: null }, context: { slot: this._slot } };","numLines":120,"startLine":80,"totalLines":939}}}
