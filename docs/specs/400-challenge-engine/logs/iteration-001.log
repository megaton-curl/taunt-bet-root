{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0118AWdwGa6wz6kSd8T5piLF","type":"tool_result","content":"600\t\n601\t  await db.withTransaction(async (txDb) => {\n602\t    await txDb.updateRoundPhase(pda, \"settled\", {\n603\t      settle_tx: txSignature,\n604\t      result_hash: resultHash,\n605\t      result_side: winnerEntryIndex,\n606\t      winner: winner.toBase58(),\n607\t      settle_attempts: round.settle_attempts + 1,\n608\t    });\n609\t\n610\t    // Game entries — aggregate per player, resolve profiles for user_id\n611\t    const playerTotals = new Map<string, number>();\n612\t    for (const e of serializedEntries) {\n613\t      playerTotals.set(e.player, (playerTotals.get(e.player) ?? 0) + e.amountLamports);\n614\t    }\n615\t    const winnerKey = winner.toBase58();\n616\t    const profileResults = await Promise.all(\n617\t      [...playerTotals.keys()].map(async (wallet) => {\n618\t        const profile = await txDb.getProfileByWallet(wallet);\n619\t        return [wallet, profile] as const;\n620\t      }),\n621\t    );\n622\t    const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);\n623\t    if (missingWallets.length > 0) {\n624\t      logger.warn(\"lord settle: missing profiles for participants — skipping their game entries\", {\n625\t        pda,\n626\t        missingWallets,\n627\t      });\n628\t    }\n629\t    const profileMap = new Map(\n630\t      profileResults.filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1]),\n631\t    );\n632\t    const entriesToUpsert = [...playerTotals.entries()]\n633\t      .filter(([wallet]) => profileMap.has(wallet))\n634\t      .map(([wallet, amount]) => ({\n635\t        userId: profileMap.get(wallet)!.user_id,\n636\t        wallet,\n637\t        game: \"lord\",\n638\t        roundPda: pda,\n639\t        matchId: round.match_id,\n640\t        amountLamports: amount,\n641\t        isWinner: wallet === winnerKey,\n642\t        payoutLamports: wallet === winnerKey ? payoutAmount : 0,\n643\t        settledAt: new Date(),\n644\t      }));\n645\t    if (entriesToUpsert.length > 0) {\n646\t      await txDb.upsertGameEntries(entriesToUpsert);\n647\t    }\n648\t\n649\t    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n650\t      txSignature,\n651\t      winner: winner.toBase58(),\n652\t      winningEntryIndex: winnerEntryIndex,\n653\t      game: \"lord\",\n654\t      entropy: entropy.toString(\"hex\"),\n655\t      winningOffset: winningOffset.toString(),\n656\t      totalAmountLamports: Number(roundData.totalAmountLamports),\n657\t      payoutAmount,\n658\t      feeAmount,\n659\t      rentRefund,\n660\t      entries: serializedEntries,\n661\t    });\n662\t\n663\t    // Write payout transaction for the winner\n664\t    await txDb.insertTransaction({\n665\t      userId: profileMap.get(winnerKey)?.user_id,\n666\t      wallet: winner.toBase58(),\n667\t      game: \"lord\",\n668\t      matchId: round.match_id,\n669\t      txType: \"payout\",\n670\t      amountLamports: payoutAmount,\n671\t      txSig: txSignature,\n672\t    });\n673\t\n674\t    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n675\t    await recordReferralEarnings(txDb, {\n676\t      roundId: round.match_id,\n677\t      gameType: \"lord\",\n678\t      feeBps,\n679\t      referralDefaultRateBps: deps.referralDefaultRateBps,\n680\t      players: serializedEntries.map((e) => ({\n681\t        wallet: e.player,\n682\t        wagerLamports: e.amountLamports,\n683\t      })),\n684\t    });\n685\t  });\n686\t\n687\t  const tDone = performance.now();\n688\t  logger.info(\"lord settlement transaction confirmed\", {\n689\t    pda,\n690\t    txSignature,\n691\t    winner: winner.toBase58(),\n692\t    winningEntryIndex: winnerEntryIndex,\n693\t    timing: {\n694\t      dbMs: Math.round(tDb - t0),\n695\t      fetchMs: Math.round(tFetch - tDb),\n696\t      buildMs: Math.round(tBuild - tFetch),\n697\t      sendMs: Math.round(tSend - tBuild),\n698\t      confirmMs: Math.round(tConfirm - tSend),\n699\t      dbWriteMs: Math.round(tDone - tConfirm),\n700\t      totalMs: Math.round(tDone - t0),\n701\t    },\n702\t  });\n703\t\n704\t  return {\n705\t    txSignature,\n706\t    resultHash,\n707\t    winningEntryIndex: winnerEntryIndex,\n708\t    winner: winner.toBase58(),\n709\t  };\n710\t}\n711\t\n712\texport async function settleRound(\n713\t  deps: SettleTxDeps,\n714\t  pda: string,\n715\t): Promise<SettleResult> {\n716\t  const round = await deps.db.getRoundByPda(pda);\n717\t  if (!round) {\n718\t    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n719\t  }\n720\t\n721\t  if (round.game === \"lord\") {\n722\t    return settleLordRound(deps, pda);\n723\t  }\n724\t\n725\t  return settleMatch(deps, pda);\n726\t}\n727\t\n728\t// ---------------------------------------------------------------------------\n729\t// Close Call — transaction builders\n730\t// ---------------------------------------------------------------------------\n731\t\n732\tfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n733\t  return PublicKey.findProgramAddressSync(\n734\t    [Buffer.from(\"closecall_config\")],\n735\t    CLOSECALL_PROGRAM_ID,\n736\t  );\n737\t}\n738\t\n739\t\n740\tfunction minuteTsToBuffer(ts: bigint): Buffer {\n741\t  const buf = Buffer.alloc(8);\n742\t  buf.writeBigInt64LE(ts);\n743\t  return buf;\n744\t}\n745\t\n746\tfunction deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n747\t  return PublicKey.findProgramAddressSync(\n748\t    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n749\t    CLOSECALL_PROGRAM_ID,\n750\t  );\n751\t}\n752\t\n753\t/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n754\tfunction encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n755\t  const buf = Buffer.alloc(16);\n756\t  discriminator.copy(buf, 0);\n757\t  buf.writeBigInt64LE(minuteTs, 8);\n758\t  return buf;\n759\t}\n760\t\n761\t/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n762\tfunction encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n763\t  const buf = Buffer.alloc(28);\n764\t  discriminator.copy(buf, 0);\n765\t  buf.writeBigInt64LE(minuteTs, 8);\n766\t  buf.writeBigInt64LE(price, 16);\n767\t  buf.writeInt32LE(expo, 24);\n768\t  return buf;\n769\t}\n770\t\n771\t/**\n772\t * Encode closecall bet data:\n773\t * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n774\t */\n775\tfunction encodeCcBetData(\n776\t  discriminator: Buffer,\n777\t  minuteTs: bigint,\n778\t  side: number,\n779\t  amount: bigint,\n780\t  openPrice: bigint,\n781\t  openPriceExpo: number,\n782\t): Buffer {\n783\t  const buf = Buffer.alloc(37);\n784\t  discriminator.copy(buf, 0);\n785\t  buf.writeBigInt64LE(minuteTs, 8);\n786\t  buf.writeUInt8(side, 16);\n787\t  buf.writeBigUInt64LE(amount, 17);\n788\t  buf.writeBigInt64LE(openPrice, 25);\n789\t  buf.writeInt32LE(openPriceExpo, 33);\n790\t  return buf;\n791\t}\n792\t\n793\texport interface CloseCallTxDeps {\n794\t  connection: Connection;\n795\t  serverKeypair: Keypair;\n796\t}\n797\t\n798\t/**\n799\t * Build a `bet` instruction (no transaction wrapping)."}]},"parent_tool_use_id":"toolu_01TqiXb6r2UeRy5smFR983XZ","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"8815a1cd-4394-4e74-99bd-8f40422cbbdd","timestamp":"2026-04-03T18:48:19.778Z"}
