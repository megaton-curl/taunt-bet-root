es (user_id, wallet, username)\n186\t      VALUES (${referrerUserId}, ${referrer}, ${\"ref-er-\" + Date.now()}),\n187\t             (${refereeUserId}, ${referee}, ${\"ref-ee-\" + Date.now()})\n188\t    `;\n189\t\n190\t    db = createDb(DATABASE_URL, rawSql);\n191\t\n192\t    app = new Hono();\n193\t    app.use(\n194\t      \"/referral/*\",\n195\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n196\t    );\n197\t    app.route(\n198\t      \"/referral\",\n199\t      createReferralRoutes({ db, sql: rawSql, config: testConfig }),\n200\t    );\n201\t  });\n202\t\n203\t  // -----------------------------------------------------------------------\n204\t  // POST /referral/code — set custom code\n205\t  // -----------------------------------------------------------------------\n206\t\n207\t  describe(\"POST /referral/code\", () => {\n208\t    it(\"sets a valid custom code and returns code + url\", async () => {\n209\t      const token = await makeJwt(referrer);\n210\t      const res = await app.request(\"/referral/code\", {\n211\t        method: \"POST\",\n212\t        ...json({ code: \"my-code-123\" }),\n213\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n214\t      });\n215\t\n216\t      expect(res.status).toBe(200);\n217\t      const body = (await res.json()) as { code: string };\n218\t      expect(body.code).toBe(\"my-code-123\");\n219\t    });\n220\t\n221\t    it(\"rejects code shorter than 3 chars\", async () => {\n222\t      const token = await makeJwt(referrer);\n223\t      const res = await app.request(\"/referral/code\", {\n224\t        method: \"POST\",\n225\t        ...json({ code: \"ab\" }),\n226\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n227\t      });\n228\t\n229\t      expect(res.status).toBe(400);\n230\t      const body = (await res.json()) as { error: { code: string } };\n231\t      expect(body.error.code).toBe(\"INVALID_CODE\");\n232\t    });\n233\t\n234\t    it(\"rejects code longer than 16 chars\", async () => {\n235\t      const token = await makeJwt(referrer);\n236\t      const res = await app.request(\"/referral/code\", {\n237\t        method: \"POST\",\n238\t        ...json({ code: \"abcdefghijklmnopq\" }), // 17 chars\n239\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n240\t      });\n241\t\n242\t      expect(res.status).toBe(400);\n243\t    });\n244\t\n245\t    it(\"rejects code with uppercase or special chars\", async () => {\n246\t      const token = await makeJwt(referrer);\n247\t      const res = await app.request(\"/referral/code\", {\n248\t        method: \"POST\",\n249\t        ...json({ code: \"My_Code!\" }),"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"8cf59854-021c-4ff5-a643-e2bca0c3df29","timestamp":"2026-04-03T18:48:29.131Z"}
