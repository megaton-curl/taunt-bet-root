{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U8ug5oDq8GkYBpQF5fxNyJ","type":"tool_result","content":"200\t  }\n201\t\n202\t  async getBlockTime(_slot: number) {\n203\t    return Math.floor(Date.now() / 1000);\n204\t  }\n205\t\n206\t  async getBalance() {\n207\t    return 2 * LAMPORTS_PER_SOL;\n208\t  }\n209\t}\n210\t\n211\t// ---------------------------------------------------------------------------\n212\t// Account data builders\n213\t// ---------------------------------------------------------------------------\n214\t\n215\tasync function buildMatchAccountData(params: {\n216\t  creator: PublicKey;\n217\t  opponent: PublicKey;\n218\t  server: PublicKey;\n219\t  entryAmount: bigint;\n220\t  creatorSide: number;\n221\t  phase: number;\n222\t  commitment: Buffer;\n223\t  algorithmVer: number;\n224\t  targetSlot: bigint;\n225\t  resolveDeadline: bigint;\n226\t  matchId: Buffer;\n227\t}): Promise<Buffer> {\n228\t  return encodeCoinflipMatch({\n229\t    creator: params.creator,\n230\t    opponent: params.opponent,\n231\t    server: params.server,\n232\t    entryAmount: params.entryAmount,\n233\t    creatorSide: params.creatorSide,\n234\t    phase: params.phase,\n235\t    commitment: [...params.commitment],\n236\t    algorithmVer: params.algorithmVer,\n237\t    targetSlot: params.targetSlot,\n238\t    resolveDeadline: params.resolveDeadline,\n239\t    resultHash: new Array(32).fill(0),\n240\t    result: 0,\n241\t    winner: PublicKey.default,\n242\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n243\t    matchId: [...params.matchId],\n244\t    bump: 0,\n245\t  });\n246\t}\n247\t\n248\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n249\t  return encodeCoinflipConfig({\n250\t    authority: PublicKey.default,\n251\t    treasury,\n252\t    paused: false,\n253\t    bump: 0,\n254\t  });\n255\t}\n256\t\n257\t/**\n258\t * Build PlatformConfig account data matching the on-chain layout.\n259\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n260\t */\n261\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n262\t  const buf = Buffer.alloc(74);\n263\t  // discriminator (8 bytes) — zeroed is fine for mock\n264\t  // authority at offset 8 — use default\n265\t  PublicKey.default.toBuffer().copy(buf, 8);\n266\t  // treasury at offset 40\n267\t  treasury.toBuffer().copy(buf, 40);\n268\t  // fee_bps at offset 72\n269\t  buf.writeUInt16LE(feeBps, 72);\n270\t  return buf;\n271\t}\n272\t\n273\t// ---------------------------------------------------------------------------\n274\t// Test suite\n275\t// ---------------------------------------------------------------------------\n276\t\n277\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n278\t  let db: Db;\n279\t  let rawSql: ReturnType<typeof postgres>;\n280\t  let mockConn: MockConnection;\n281\t  let app: Hono;\n282\t\n283\t  const serverKeypair = Keypair.generate();\n284\t  const creatorKeypair = Keypair.generate();\n285\t  const opponentKeypair = Keypair.generate();\n286\t  const treasuryKeypair = Keypair.generate();\n287\t  const entropyKeypair = Keypair.generate();\n288\t  const entropyAccount = entropyKeypair.publicKey;\n289\t\n290\t  const entropyData = Buffer.alloc(32);\n291\t  entropyData[0] = 0xab;\n292\t  entropyData[1] = 0xcd;\n293\t  entropyData[15] = 0x42;\n294\t\n295\t  beforeAll(async () => {\n296\t    rawSql = makeSql();\n297\t    await rawSql`\n298\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n299\t    `;"}]},"parent_tool_use_id":null,"session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"83785a5e-47f3-4ac7-b700-3468cba994b2","timestamp":"2026-04-03T18:52:23.357Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"  }\n\n  async getBlockTime(_slot: number) {\n    return Math.floor(Date.now() / 1000);\n  }\n\n  async getBalance() {\n    return 2 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Account data builders\n// ---------------------------------------------------------------------------\n\nasync function buildMatchAccountData(params: {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: Buffer;\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  matchId: Buffer;\n}): Promise<Buffer> {\n  return encodeCoinflipMatch({\n    creator: params.creator,\n    opponent: params.opponent,\n    server: params.server,\n    entryAmount: params.entryAmount,\n    creatorSide: params.creatorSide,\n    phase: params.phase,\n    commitment: [...params.commitment],\n    algorithmVer: params.algorithmVer,\n    targetSlot: params.targetSlot,\n    resolveDeadline: params.resolveDeadline,\n    resultHash: new Array(32).fill(0),\n    result: 0,\n    winner: PublicKey.default,\n    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n    matchId: [...params.matchId],\n    bump: 0,\n  });\n}\n\nasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n  return encodeCoinflipConfig({\n    authority: PublicKey.default,\n    treasury,\n    paused: false,\n    bump: 0,\n  });\n}\n\n/**\n * Build PlatformConfig account data matching the on-chain layout.\n * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n */\nfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n  const buf = Buffer.alloc(74);\n  // discriminator (8 bytes) — zeroed is fine for mock\n  // authority at offset 8 — use default\n  PublicKey.default.toBuffer().copy(buf, 8);\n  // treasury at offset 40\n  treasury.toBuffer().copy(buf, 40);\n  // fee_bps at offset 72\n  buf.writeUInt16LE(feeBps, 72);\n  return buf;\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Integration: create → join → settle lifecycle\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    await rawSql`\n      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n    `;","numLines":100,"startLine":200,"totalLines":939}}}
