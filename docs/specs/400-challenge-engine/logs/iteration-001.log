{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PTXsvJRtmQurQa6o9bcBDM","type":"tool_result","content":"100\t    isWinner: boolean | null; // null = refund\n101\t    payoutLamports: string;\n102\t    isCreator: boolean;\n103\t  }>;\n104\t  feeLamports: string;\n105\t  settledAt: string;        // ISO 8601\n106\t}\n107\t```\n108\t\n109\tThe event MUST be emitted within the same DB transaction as the settlement write (same pattern as referral earnings recording).\n110\t\n111\t**Acceptance Criteria:**\n112\t- [ ] `game.settled` event type added to `EventTypes` in `event-types.ts`\n113\t- [ ] `settle-tx.ts` emits `game.settled` within the settlement transaction for coinflip rounds\n114\t- [ ] `settle-tx.ts` emits `game.settled` within the settlement transaction for lord (jackpot) rounds\n115\t- [ ] `closecall-clock.ts` emits `game.settled` within the settlement transaction for closecall rounds\n116\t- [ ] Event payload matches the schema above (all fields present, amounts as string-encoded lamports)\n117\t- [ ] Existing settlement latency is not measurably affected (event is a single INSERT, no blocking)\n118\t- [ ] Duplicate settlement retries may enqueue duplicate `game.settled` rows safely because downstream handlers dedupe on domain keys, not `event_queue.id`\n119\t\n120\t---\n121\t\n122\t### FR-2: Challenge Engine Data Model\n123\t\n124\tDatabase schema for challenges, assignments, and progress tracking.\n125\t\n126\t**Tables:**\n127\t\n128\t```sql\n129\t-- Operator-tunable reward/economy parameters\n130\tCREATE TABLE reward_config (\n131\t  key         TEXT PRIMARY KEY,\n132\t  value       TEXT NOT NULL,           -- JSON-encoded value\n133\t  updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()\n134\t);\n135\t\n136\t-- Player point balances and lifetime stats\n137\tCREATE TABLE player_points (\n138\t  user_id             TEXT PRIMARY KEY,\n139\t  wallet              TEXT NOT NULL UNIQUE,\n140\t  balance             BIGINT NOT NULL DEFAULT 0,        -- current spendable\n141\t  lifetime_earned     BIGINT NOT NULL DEFAULT 0,        -- monotonic, never decreases\n142\t  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n143\t);\n144\t\n145\t-- Immutable point grant ledger (source of truth for history + idempotency)\n146\tCREATE TABLE point_grants (\n147\t  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n148\t  user_id             TEXT NOT NULL,\n149\t  wallet              TEXT NOT NULL,\n150\t  source_type         TEXT NOT NULL CHECK (source_type IN ('wager', 'challenge_completed', 'bonus_completed', 'crate_points')),\n151\t  source_id           TEXT NOT NULL,                    -- round_id, assignment_id, bonus_completion_id, crate_drop_id\n152\t  amount              BIGINT NOT NULL,\n153\t  metadata            JSONB NOT NULL DEFAULT '{}',\n154\t  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),\n155\t  UNIQUE (user_id, source_type, source_id)\n156\t);\n157\t\n158\tCREATE INDEX idx_point_grants_user_created ON point_grants (user_id, created_at DESC);\n159\t\n160\t-- Reward pool accounting (single row, updated atomically)\n161\tCREATE TABLE reward_pool (\n162\t  id                  INT PRIMARY KEY DEFAULT 1 CHECK (id = 1),  -- singleton, accounting-only ledger\n163\t  balance_lamports    BIGINT NOT NULL DEFAULT 0,\n164\t  lifetime_funded     BIGINT NOT NULL DEFAULT 0,    -- total fees -> pool\n165\t  lifetime_paid       BIGINT NOT NULL DEFAULT 0,    -- total crate payouts\n166\t  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n167\t);\n168\t\n169\t-- Append-only pool funding ledger for idempotent reward_pool_fund handling\n170\tCREATE TABLE reward_pool_fundings (\n171\t  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n172\t  round_id            TEXT NOT NULL UNIQUE,         -- one funding record per settled round\n173\t  fee_lamports        BIGINT NOT NULL,\n174\t  funded_lamports     BIGINT NOT NULL,\n175\t  created_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n176\t);\n177\t\n178\t-- Campaign container (Daily, Weekly, Onboarding, Dogpile)\n179\tCREATE TABLE campaigns (\n180\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n181\t  name            TEXT NOT NULL UNIQUE,\n182\t  campaign_type   TEXT NOT NULL CHECK (campaign_type IN ('daily', 'weekly', 'onboarding', 'dogpile')),\n183\t  starts_at       TIMESTAMPTZ,                  -- NULL = always active\n184\t  ends_at         TIMESTAMPTZ,                  -- NULL = no end\n185\t  is_active       BOOLEAN NOT NULL DEFAULT true,\n186\t  config          JSONB NOT NULL DEFAULT '{}',  -- type-specific config (e.g., dogpile multiplier)\n187\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n188\t);\n189\t\n190\t-- Challenge template definitions (data, not code)\n191\tCREATE TABLE challenges (\n192\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n193\t  campaign_id     BIGINT NOT NULL REFERENCES campaigns(id),\n194\t  title           TEXT NOT NULL,\n195\t  description     TEXT,\n196\t  action          TEXT NOT NULL,                 -- M1 adapter type: game_won, game_completed, lobby_filled\n197\t  scope           TEXT NOT NULL DEFAULT 'any' CHECK (scope IN ('any', 'coinflip', 'lord', 'closecall')),\n198\t  condition       TEXT NOT NULL DEFAULT 'count', -- M1: count, unique_game_types\n199\t  threshold       INT NOT NULL,                  -- target value"}]},"parent_tool_use_id":null,"session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"418df767-57cf-4dcc-99e2-f8057be67cf0","timestamp":"2026-04-03T18:46:23.157Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/docs/specs/400-challenge-engine/spec.md","content":"    isWinner: boolean | null; // null = refund\n    payoutLamports: string;\n    isCreator: boolean;\n  }>;\n  feeLamports: string;\n  settledAt: string;        // ISO 8601\n}\n```\n\nThe event MUST be emitted within the same DB transaction as the settlement write (same pattern as referral earnings recording).\n\n**Acceptance Criteria:**\n- [ ] `game.settled` event type added to `EventTypes` in `event-types.ts`\n- [ ] `settle-tx.ts` emits `game.settled` within the settlement transaction for coinflip rounds\n- [ ] `settle-tx.ts` emits `game.settled` within the settlement transaction for lord (jackpot) rounds\n- [ ] `closecall-clock.ts` emits `game.settled` within the settlement transaction for closecall rounds\n- [ ] Event payload matches the schema above (all fields present, amounts as string-encoded lamports)\n- [ ] Existing settlement latency is not measurably affected (event is a single INSERT, no blocking)\n- [ ] Duplicate settlement retries may enqueue duplicate `game.settled` rows safely because downstream handlers dedupe on domain keys, not `event_queue.id`\n\n---\n\n### FR-2: Challenge Engine Data Model\n\nDatabase schema for challenges, assignments, and progress tracking.\n\n**Tables:**\n\n```sql\n-- Operator-tunable reward/economy parameters\nCREATE TABLE reward_config (\n  key         TEXT PRIMARY KEY,\n  value       TEXT NOT NULL,           -- JSON-encoded value\n  updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Player point balances and lifetime stats\nCREATE TABLE player_points (\n  user_id             TEXT PRIMARY KEY,\n  wallet              TEXT NOT NULL UNIQUE,\n  balance             BIGINT NOT NULL DEFAULT 0,        -- current spendable\n  lifetime_earned     BIGINT NOT NULL DEFAULT 0,        -- monotonic, never decreases\n  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Immutable point grant ledger (source of truth for history + idempotency)\nCREATE TABLE point_grants (\n  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id             TEXT NOT NULL,\n  wallet              TEXT NOT NULL,\n  source_type         TEXT NOT NULL CHECK (source_type IN ('wager', 'challenge_completed', 'bonus_completed', 'crate_points')),\n  source_id           TEXT NOT NULL,                    -- round_id, assignment_id, bonus_completion_id, crate_drop_id\n  amount              BIGINT NOT NULL,\n  metadata            JSONB NOT NULL DEFAULT '{}',\n  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),\n  UNIQUE (user_id, source_type, source_id)\n);\n\nCREATE INDEX idx_point_grants_user_created ON point_grants (user_id, created_at DESC);\n\n-- Reward pool accounting (single row, updated atomically)\nCREATE TABLE reward_pool (\n  id                  INT PRIMARY KEY DEFAULT 1 CHECK (id = 1),  -- singleton, accounting-only ledger\n  balance_lamports    BIGINT NOT NULL DEFAULT 0,\n  lifetime_funded     BIGINT NOT NULL DEFAULT 0,    -- total fees -> pool\n  lifetime_paid       BIGINT NOT NULL DEFAULT 0,    -- total crate payouts\n  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Append-only pool funding ledger for idempotent reward_pool_fund handling\nCREATE TABLE reward_pool_fundings (\n  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  round_id            TEXT NOT NULL UNIQUE,         -- one funding record per settled round\n  fee_lamports        BIGINT NOT NULL,\n  funded_lamports     BIGINT NOT NULL,\n  created_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Campaign container (Daily, Weekly, Onboarding, Dogpile)\nCREATE TABLE campaigns (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  name            TEXT NOT NULL UNIQUE,\n  campaign_type   TEXT NOT NULL CHECK (campaign_type IN ('daily', 'weekly', 'onboarding', 'dogpile')),\n  starts_at       TIMESTAMPTZ,                  -- NULL = always active\n  ends_at         TIMESTAMPTZ,                  -- NULL = no end\n  is_active       BOOLEAN NOT NULL DEFAULT true,\n  config          JSONB NOT NULL DEFAULT '{}',  -- type-specific config (e.g., dogpile multiplier)\n  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Challenge template definitions (data, not code)\nCREATE TABLE challenges (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  campaign_id     BIGINT NOT NULL REFERENCES campaigns(id),\n  title           TEXT NOT NULL,\n  description     TEXT,\n  action          TEXT NOT NULL,                 -- M1 adapter type: game_won, game_completed, lobby_filled\n  scope           TEXT NOT NULL DEFAULT 'any' CHECK (scope IN ('any', 'coinflip', 'lord', 'closecall')),\n  condition       TEXT NOT NULL DEFAULT 'count', -- M1: count, unique_game_types\n  threshold       INT NOT NULL,                  -- target value","numLines":100,"startLine":100,"totalLines":926}}}
