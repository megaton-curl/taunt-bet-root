{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HL8MFcua9CfM2L8Xfhh2te","type":"tool_result","content":"1\t/**\n2\t * Async event queue — Postgres-backed infrastructure for decoupling\n3\t * side-effects from the game settlement hot path.\n4\t */\n5\t\n6\texport { emitEvent } from \"./emit-event.js\";\n7\texport type { EmitEventOptions, SqlOrTransaction } from \"./emit-event.js\";\n8\t\n9\texport { EventTypes } from \"./event-types.js\";\n10\texport type { EventType } from \"./event-types.js\";\n11\t\n12\texport { registerHandler, getHandler, clearHandlers } from \"./handler-registry.js\";\n13\texport type { EventHandler } from \"./handler-registry.js\";\n14\t\n15\texport { createEventWorker, getBackoffSeconds } from \"./worker.js\";\n16\texport type { EventWorker, EventWorkerOptions } from \"./worker.js\";\n17\t\n18\texport { getQueueDepth } from \"./health.js\";\n19\texport type { QueueDepth } from \"./health.js\";\n20\t"}]},"parent_tool_use_id":"toolu_01QAPPUhUjLzckYrk1KWaFEw","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"dc6fbe01-5d35-40cc-87bc-2720a20276f6","timestamp":"2026-04-03T18:48:29.035Z"}
