{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XeTh9BWjUcdWsKYxXXxT3s","type":"tool_result","content":"1\t/**\n2\t * Unit tests for the async event queue module.\n3\t *\n4\t * Covers:\n5\t * 1. emitEvent — inserts with correct fields, returns eventId\n6\t * 2. emitEvent — rolled-back transaction does NOT persist\n7\t * 3. Handler registry — register/get, unknown returns undefined\n8\t * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n9\t *\n10\t * Requires a running Postgres database (same as backend).\n11\t */\n12\t\n13\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n14\timport postgres from \"postgres\";\n15\timport { emitEvent } from \"../emit-event.js\";\n16\timport { registerHandler, getHandler } from \"../handler-registry.js\";\n17\timport { EventTypes } from \"../event-types.js\";\n18\timport { getBackoffSeconds } from \"../worker.js\";\n19\t\n20\tdescribe(\"event queue unit tests\", () => {\n21\t  let sql: ReturnType<typeof postgres>;\n22\t\n23\t  beforeAll(async () => {\n24\t    sql = process.env.DATABASE_URL\n25\t      ? postgres(process.env.DATABASE_URL)\n26\t      : postgres({\n27\t          host: \"/var/run/postgresql\",\n28\t          database: \"rng_utopia_dev\",\n29\t          username: \"vscode\",\n30\t        });\n31\t  });\n32\t\n33\t  afterAll(async () => {\n34\t    await sql.end();\n35\t  });\n36\t\n37\t  beforeEach(async () => {\n38\t    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n39\t  });\n40\t\n41\t  // -------------------------------------------------------------------------\n42\t  // emitEvent\n43\t  // -------------------------------------------------------------------------\n44\t\n45\t  describe(\"emitEvent\", () => {\n46\t    it(\"inserts a row with correct fields and returns eventId\", async () => {\n47\t      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n48\t\n49\t      const result = await sql.begin(async (tx) => {\n50\t        return emitEvent(\n51\t          tx as unknown as postgres.Sql,\n52\t          EventTypes.REFERRAL_GAME_SETTLED,\n53\t          payload,\n54\t        );\n55\t      });\n56\t\n57\t      expect(result.eventId).toBeTypeOf(\"bigint\");\n58\t      expect(result.eventId).toBeGreaterThan(0n);\n59\t\n60\t      // Verify the persisted row\n61\t      const rows = await sql`\n62\t        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n63\t      `;\n64\t      expect(rows).toHaveLength(1);\n65\t\n66\t      const row = rows[0]!;\n67\t      expect(row.event_type).toBe(\"referral.game_settled\");\n68\t      expect(row.payload).toEqual(payload);\n69\t      expect(row.status).toBe(\"pending\");\n70\t      expect(row.attempts).toBe(0);\n71\t      expect(row.max_attempts).toBe(3);\n72\t      expect(row.scheduled_at).toBeInstanceOf(Date);\n73\t      expect(row.created_at).toBeInstanceOf(Date);\n74\t    });\n75\t\n76\t    it(\"does NOT persist when transaction is rolled back\", async () => {\n77\t      let capturedId: bigint | undefined;\n78\t\n79\t      try {\n80\t        await sql.begin(async (tx) => {"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"8abba53f-4526-49e8-879f-7d9b2f8d3024","timestamp":"2026-04-03T18:48:34.474Z"}
