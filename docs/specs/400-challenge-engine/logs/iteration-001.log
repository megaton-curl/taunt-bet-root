{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JLgrodmh42j5sneHfiJD2V","type":"tool_result","content":"1\t/**\n2\t * Settle transaction builder + submission.\n3\t *\n4\t * Retrieves the stored secret, reads on-chain match + config data to resolve\n5\t * all accounts, builds the `settle` instruction, submits it, and updates the\n6\t * DB on confirmation.\n7\t */\n8\t\n9\timport { createHash } from \"node:crypto\";\n10\timport { performance } from \"node:perf_hooks\";\n11\timport {\n12\t  Connection,\n13\t  Keypair,\n14\t  PublicKey,\n15\t  SystemProgram,\n16\t  Transaction,\n17\t  TransactionInstruction,\n18\t} from \"@solana/web3.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n22\timport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n23\timport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@taunt-bet/anchor-client\";\n24\timport {\n25\t  decodeCoinflipMatch,\n26\t  decodeLordRound,\n27\t  type DecodedJackpotRound,\n28\t} from \"./account-decoder.js\";\n29\t\n30\t// ---------------------------------------------------------------------------\n31\t// Instruction discriminators (from IDL — no hardcoded byte arrays)\n32\t// ---------------------------------------------------------------------------\n33\t\n34\tfunction getInstructionDiscriminator(\n35\t  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n36\t  instructionName: string,\n37\t): Buffer {\n38\t  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n39\t  if (!instruction) {\n40\t    throw new Error(`Instruction ${instructionName} not found in IDL`);\n41\t  }\n42\t  return Buffer.from(instruction.discriminator);\n43\t}\n44\t\n45\tconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n46\tconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n47\t  lordIdl,\n48\t  \"claim_payout\",\n49\t);\n50\tconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n51\tconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n52\tconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n53\t\n54\t// ---------------------------------------------------------------------------\n55\t// Types\n56\t// ---------------------------------------------------------------------------\n57\t\n58\texport interface SettleTxDeps {\n59\t  db: Db;\n60\t  connection: Connection;\n61\t  serverKeypair: Keypair;\n62\t  entropyAccount: PublicKey;\n63\t  referralDefaultRateBps: number;\n64\t}\n65\t\n66\texport interface SettleResult {\n67\t  txSignature: string;\n68\t  resultHash: Buffer;\n69\t  resultSide?: number;\n70\t  winningEntryIndex?: number;\n71\t  winner: string;\n72\t}\n73\t\n74\t// ---------------------------------------------------------------------------\n75\t// Instruction encoding\n76\t// ---------------------------------------------------------------------------\n77\t\n78\t/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n79\tfunction encodeSettleData(secret: Buffer): Buffer {\n80\t  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n81\t}\n82\t\n83\tfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n84\t  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n85\t}\n86\t\n87\t// ---------------------------------------------------------------------------\n88\t// Result derivation (mirrors on-chain derive_result)\n89\t// ---------------------------------------------------------------------------\n90\t\n91\t/**\n92\t * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n93\t * Must match shared/src/fairness.rs `derive_result()`.\n94\t */\n95\tfunction deriveResult(\n96\t  secret: Buffer,\n97\t  entropy: Buffer,\n98\t  matchPdaBytes: Buffer,\n99\t  algoVer: number,\n100\t): Buffer {\n101\t  return createHash(\"sha256\")\n102\t    .update(secret)\n103\t    .update(entropy)\n104\t    .update(matchPdaBytes)\n105\t    .update(Buffer.from([algoVer]))\n106\t    .digest();\n107\t}\n108\t\n109\t// ---------------------------------------------------------------------------\n110\t// Referral earnings hook\n111\t// ---------------------------------------------------------------------------\n112\t\n113\t/**\n114\t * After a game settles, check each player for a referrer and record\n115\t * referral earnings if applicable.\n116\t *\n117\t * For each unique player: look up referral link → if referrer exists,\n118\t * calculate referrer earning + referee rebate → insert into referral_earnings.\n119\t *\n120\t * Errors are logged but never bubble — referral recording must not fail settlement.\n121\t * The UNIQUE(referee_user_id, round_id) constraint provides idempotency on retries.\n122\t */\n123\tasync function recordReferralEarnings(\n124\t  db: Db,\n125\t  params: {\n126\t    roundId: string;\n127\t    gameType: string;\n128\t    feeBps: number;\n129\t    referralDefaultRateBps: number;\n130\t    players: Array<{ wallet: string; wagerLamports: number }>;\n131\t  },\n132\t): Promise<void> {\n133\t  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n134\t\n135\t  // Deduplicate players (Lord of RNGs can have multiple entries per player)\n136\t  const playerWagers = new Map<string, number>();\n137\t  for (const p of players) {\n138\t    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n139\t  }\n140\t\n141\t  for (const [wallet, wagerLamports] of playerWagers) {\n142\t    try {\n143\t      const refereeProfile = await db.getProfileByWallet(wallet);\n144\t      if (!refereeProfile) continue; // no profile = no referral link possible\n145\t      const link = await db.getReferralLinkByRefereeUserId(refereeProfile.user_id);\n146\t      if (!link) continue;\n147\t\n148\t      const referrerWallet = link.referrer_wallet;\n149\t      const referrerRateBps = await db.getReferrerRate(\n150\t        link.referrer_user_id,"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"d6e3bb71-3d39-4a41-ab87-bb5164774617","timestamp":"2026-04-03T18:48:52.585Z"}
