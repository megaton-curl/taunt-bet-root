{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LjkQ4N61jptqYiiggbxQXs","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/db.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"a2d38d00-ff6d-4b5f-9224-7a6fcd322eb5","timestamp":"2026-04-03T18:51:12.177Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/db.ts","oldString":"  return {\n    async insertRound(params) {\n      const rows = await sql<Round[]>`","newString":"  return {\n    rawSql: sql,\n\n    async insertRound(params) {\n      const rows = await sql<Round[]>`","originalFile":"/**\n * Database client module — typed query functions for `rounds` and `operator_events`.\n *\n * Phase transitions are unidirectional: created → locked → settling → settled,\n * or created → expired. The application layer rejects backward transitions.\n */\n\nimport postgres from \"postgres\";\nimport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n\nexport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\nexport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n\nexport interface CloseCallRound {\n  round_id: string;\n  pda: string;\n  server_key: string;\n  phase: CloseCallPhase;\n  open_price: number;\n  open_price_expo: number;\n  close_price: number | null;\n  outcome: CloseCallOutcome;\n  green_pool: number;\n  red_pool: number;\n  total_fee: number;\n  green_entries: Array<{ player: string; amountLamports: number }>; // populated via JOIN on game_entries\n  red_entries: Array<{ player: string; amountLamports: number }>;   // populated via JOIN on game_entries\n  settle_tx: string | null;\n  created_at: Date;\n  settled_at: Date | null;\n}\n\nexport interface InsertCloseCallRoundParams {\n  roundId: string;\n  pda: string;\n  serverKey: string;\n  openPrice: number;\n  openPriceExpo: number;\n}\n\nexport type OperatorEventType =\n  | \"secret_generated\"\n  | \"tx_built\"\n  | \"match_detected\"\n  | \"settle_submitted\"\n  | \"settle_confirmed\"\n  | \"settle_failed\"\n  | \"settle_retried\"\n  | \"timeout_detected\";\n\nexport interface Round {\n  pda: string;\n  game: string;\n  creator: string;\n  server_key: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amount_lamports: number;\n  side: number;\n  match_id: string;\n  phase: RoundPhase;\n  target_slot: string | null;\n  settle_tx: string | null;\n  settle_attempts: number;\n  result_hash: Buffer | null;\n  result_side: number | null;\n  winner: string | null;\n  entries: Array<{ player: string; amountLamports: number }> | null; // populated via JOIN on game_entries\n  created_at: Date;\n  updated_at: Date;\n  settled_at: Date | null;\n}\n\nexport interface InsertRoundParams {\n  pda: string;\n  game: string;\n  creator: string;\n  serverKey: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amountLamports: number;\n  side: number;\n  matchId: string;\n  phase: RoundPhase;\n}\n\nexport interface OperatorEvent {\n  id: string;\n  pda: string | null;\n  event_type: OperatorEventType;\n  payload: unknown;\n  created_at: Date;\n}\n\n// ---------------------------------------------------------------------------\n// Transaction types\n// ---------------------------------------------------------------------------\n\nexport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n\nexport interface Transaction {\n  id: string;\n  wallet: string;\n  game: string;\n  match_id: string;\n  tx_type: TransactionType;\n  amount_lamports: number;\n  tx_sig: string;\n  created_at: Date;\n}\n\nexport interface InsertTransactionParams {\n  userId?: string;\n  wallet: string;\n  game: string;\n  matchId: string;\n  txType: TransactionType;\n  amountLamports: number;\n  txSig: string;\n}\n\n// ---------------------------------------------------------------------------\n// Referral types\n// ---------------------------------------------------------------------------\n\nexport interface ReferralCode {\n  id: number;\n  user_id: string;\n  wallet: string;\n  code: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface ReferralLink {\n  id: number;\n  referrer_user_id: string;\n  referee_user_id: string;\n  referrer_wallet: string;\n  referee_wallet: string;\n  created_at: Date;\n}\n\nexport interface ReferralEarning {\n  id: number;\n  referrer_user_id: string;\n  referee_user_id: string;\n  referrer_wallet: string;\n  referee_wallet: string;\n  round_id: string;\n  game_type: string;\n  wager_lamports: number;\n  fee_lamports: number;\n  referrer_earned_lamports: number;\n  referrer_rate_bps: number;\n  referee_rebate_lamports: number;\n  referee_rebate_rate_bps: number;\n  created_at: Date;\n}\n\nexport interface ReferralStats {\n  referred_count: number;\n  active_count: number;\n  total_volume_lamports: string;\n  total_earned_lamports: string;\n  total_rebate_lamports: string;\n  pending_lamports: string;\n}\n\nexport interface ReferralClaim {\n  id: string;\n  user_id: string;\n  wallet: string;\n  amount_lamports: string;\n  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n  retry_count: number;\n  tx_signature: string | null;\n  error: string | null;\n  requested_at: Date;\n  processed_at: Date | null;\n}\n\n// ---------------------------------------------------------------------------\n// Player profile types\n// ---------------------------------------------------------------------------\n\nexport interface PlayerProfile {\n  id: number;\n  user_id: string;\n  wallet: string;\n  username: string;\n  username_updated_at: Date | null;\n  avatar_url: string | null;\n  heat_multiplier: number;\n  points_balance: number;\n  created_at: Date;\n}\n\nexport interface PlayerStats {\n  gamesPlayed: number;\n  totalWagered: bigint;\n  totalWins: number;\n  winRate: number;\n  netPnl: bigint;\n}\n\nexport interface PublicPlayerStats {\n  gamesPlayed: number;\n  totalWins: number;\n  winRate: number;\n}\n\nexport interface WinStreaks {\n  current: number;\n  best: number;\n}\n\nexport interface GameBreakdownStats {\n  gamesPlayed: number;\n  totalWagered: bigint;\n  totalWins: number;\n  winRate: number;\n  netPnl: bigint;\n}\n\n// ---------------------------------------------------------------------------\n// Game entries — single source of truth for participation + stats + leaderboard\n// Written at participation time (create/bet), updated at settlement via UPSERT.\n// ---------------------------------------------------------------------------\n\nexport interface GameEntryUpsert {\n  userId: string;\n  wallet: string;\n  game: string;\n  roundPda: string;\n  matchId: string;\n  amountLamports: number;\n  side?: string;\n  isWinner?: boolean;       // null at participation time, null for refunds\n  payoutLamports?: number;\n  settledAt?: Date;\n}\n\n/** @deprecated Use GameEntryUpsert instead */\nexport type GameEntryInsert = GameEntryUpsert;\n\nexport interface GameEntry {\n  id: number;\n  userId: string;\n  wallet: string;\n  game: string;\n  roundPda: string;\n  matchId: string;\n  amountLamports: number;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: number;\n  createdAt: Date;\n  settledAt: Date | null;\n}\n\nexport interface CloseCallCandle {\n  minuteTs: number;\n  price: bigint;\n  expo: number;\n  priceHuman: number;\n}\n\nexport interface LeaderboardEntry {\n  rank: number;\n  userId: string;\n  username: string;\n  avatarUrl: string | null;\n  totalWagered: bigint;\n  gamesPlayed: number;\n  totalWins: number;\n  winRate: number;\n  netPnl: bigint;\n}\n\nexport interface LeaderboardResult {\n  entries: LeaderboardEntry[];\n  weekStart: string; // ISO date string (Monday 00:00 UTC)\n  weekEnd: string;   // ISO date string (next Monday 00:00 UTC)\n}\n\n// ---------------------------------------------------------------------------\n// Phase transition guard\n// ---------------------------------------------------------------------------\n\n/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\nconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n  created: [\"locked\", \"expired\"],\n  locked: [\"settling\"],\n  settling: [\"settled\"],\n  settled: [],\n  expired: [],\n};\n\nfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n  const allowed = VALID_TRANSITIONS[from];\n  if (!allowed.includes(to)) {\n    throw new Error(\n      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    );\n  }\n}\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db {\n  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n  insertRound(params: InsertRoundParams): Promise<Round>;\n\n  /** Delete a round by PDA. Returns true if a row was removed. */\n  deleteRoundByPda(pda: string): Promise<boolean>;\n\n  /** Transition a round's phase. Enforces unidirectional state machine.\n   *  Optional `updates` can set additional columns alongside the phase change. */\n  updateRoundPhase(\n    pda: string,\n    newPhase: RoundPhase,\n    updates?: Partial<\n      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n    >,\n  ): Promise<Round>;\n\n  /** Get a single round by its PDA. Returns `undefined` if not found. */\n  getRoundByPda(pda: string): Promise<Round | undefined>;\n\n  /** Get all rounds matching a given phase. */\n  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n\n  /** Append an operator event to the audit log. */\n  insertOperatorEvent(\n    pda: string | null,\n    eventType: OperatorEventType,\n    payload?: unknown,\n  ): Promise<OperatorEvent>;\n\n  /** Get the latest operator event for a PDA + type. */\n  getLatestOperatorEvent(\n    pda: string,\n    eventType: OperatorEventType,\n  ): Promise<OperatorEvent | undefined>;\n\n  /** Get a single round by its match_id. Returns `undefined` if not found. */\n  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n\n  /** Batch-fetch the latest operator event per PDA for a given event type. */\n  getLatestOperatorEventsForPdas(\n    pdas: string[],\n    eventType: OperatorEventType,\n  ): Promise<Map<string, OperatorEvent>>;\n\n  /** Get recently settled rounds for a game, ordered newest first. */\n  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n\n  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n\n  // -------------------------------------------------------------------------\n  // Close Call rounds\n  // -------------------------------------------------------------------------\n\n  /** Insert a new Close Call round. */\n  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n\n  /** Get a Close Call round by round_id (16-char hex). */\n  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n\n  /** Get the current active (open) Close Call round. */\n  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n\n  /** Get the most recent settled/refunded Close Call rounds. */\n  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n\n  /** Update a Close Call round after settlement. */\n  settleCloseCallRound(\n    roundId: string,\n    updates: {\n      phase: CloseCallPhase;\n      outcome: CloseCallOutcome;\n      closePrice?: number;\n      greenPool?: number;\n      redPool?: number;\n      totalFee?: number;\n      settleTx?: string;\n    },\n  ): Promise<CloseCallRound>;\n\n  // -------------------------------------------------------------------------\n  // Transactions\n  // -------------------------------------------------------------------------\n\n  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n  insertTransaction(params: InsertTransactionParams): Promise<void>;\n\n  /** Insert multiple transactions in a single batch. */\n  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n\n  /** Get paginated transactions for a wallet, newest first. */\n  getTransactions(\n    wallet: string,\n    cursor?: string,\n    limit?: number,\n    game?: string,\n  ): Promise<Transaction[]>;\n\n  /** Get paginated transactions for an authenticated user_id, newest first. */\n  getTransactionsByUserId(\n    userId: string,\n    cursor?: string,\n    limit?: number,\n    game?: string,\n  ): Promise<Transaction[]>;\n\n  // -------------------------------------------------------------------------\n  // Referral — codes\n  // -------------------------------------------------------------------------\n\n  /** Insert a new referral code for a user. Throws on duplicate user, wallet, or code. */\n  insertReferralCode(\n    userId: string,\n    wallet: string,\n    code: string,\n  ): Promise<ReferralCode>;\n\n  /** Get a user's referral code. Returns `undefined` if none set. */\n  getReferralCodeByUserId(userId: string): Promise<ReferralCode | undefined>;\n\n  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n\n  // -------------------------------------------------------------------------\n  // Referral — links\n  // -------------------------------------------------------------------------\n\n  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n  insertReferralLink(params: {\n    referrerUserId: string;\n    refereeUserId: string;\n    referrerWallet: string;\n    refereeWallet: string;\n  }): Promise<ReferralLink>;\n\n  /** Get the referral link for a referee user. Returns `undefined` if not referred. */\n  getReferralLinkByRefereeUserId(\n    refereeUserId: string,\n  ): Promise<ReferralLink | undefined>;\n\n  /** Get all referral links where the given user is the referrer. */\n  getReferralLinksByReferrerUserId(referrerUserId: string): Promise<ReferralLink[]>;\n\n  // -------------------------------------------------------------------------\n  // Referral — earnings & stats\n  // -------------------------------------------------------------------------\n\n  /** Insert a referral earning row. Throws on duplicate (referee_user_id, round_id). */\n  insertReferralEarning(params: {\n    referrerUserId: string;\n    refereeUserId: string;\n    referrerWallet: string;\n    refereeWallet: string;\n    roundId: string;\n    gameType: string;\n    wagerLamports: number;\n    feeLamports: number;\n    referrerEarnedLamports: number;\n    referrerRateBps: number;\n    refereeRebateLamports: number;\n    refereeRebateRateBps: number;\n  }): Promise<ReferralEarning>;\n\n  /**\n   * Get the pending (unclaimed) balance for a user.\n   * Sum of referrer_earned where user_id=referrer + sum of referee_rebate where\n   * user_id=referee, minus sum of claims for that user.\n   * Returns a lamport string.\n   */\n  getPendingBalanceByUserId(userId: string): Promise<string>;\n\n  /** Get paginated per-game earnings for a user (as referrer). Newest first. */\n  getReferralEarningsByUserId(\n    userId: string,\n    page: number,\n    limit: number,\n  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n\n  /** Get referral summary stats for a user. */\n  getReferralStatsByUserId(userId: string): Promise<ReferralStats>;\n\n  // -------------------------------------------------------------------------\n  // Referral — claims & rates\n  // -------------------------------------------------------------------------\n\n  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n  insertReferralClaim(\n    userId: string,\n    wallet: string,\n    amountLamports: string,\n  ): Promise<ReferralClaim>;\n\n  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n\n  /**\n   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n   * Returns the updated claim.\n   */\n  updateClaimStatus(\n    claimId: string,\n    status: ReferralClaim[\"status\"],\n    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n  ): Promise<ReferralClaim>;\n\n  /**\n   * Get the effective referrer rate for a user in bps.\n   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n   */\n  getReferrerRate(\n    userId: string,\n    defaultRateBps: number,\n  ): Promise<number>;\n\n  // -------------------------------------------------------------------------\n  // Player profiles\n  // -------------------------------------------------------------------------\n\n  /**\n   * Create a new player profile with auto-generated user_id and username.\n   * Retries up to 5 times on username collision, then falls back to `user-{random8}`.\n   */\n  createPlayerProfile(wallet: string): Promise<PlayerProfile>;\n\n  /** Get a player profile by wallet address. Returns `null` if not found. */\n  getProfileByWallet(wallet: string): Promise<PlayerProfile | null>;\n\n  /** Get a player profile by user_id. Returns `null` if not found. */\n  getProfileByUserId(userId: string): Promise<PlayerProfile | null>;\n\n  /**\n   * Get a player profile by public identifier.\n   * If identifier starts with `usr_`, looks up by `user_id`.\n   * Otherwise looks up by username (case-insensitive).\n   */\n  getProfileByIdentifier(identifier: string): Promise<PlayerProfile | null>;\n\n  /**\n   * Update a player's username. Validates 30-day cooldown (first edit is free).\n   * Throws on cooldown violation or UNIQUE conflict.\n   */\n  updateUsername(wallet: string, newUsername: string): Promise<PlayerProfile>;\n\n  /** Update a player's username by canonical user_id. */\n  updateUsernameByUserId(userId: string, newUsername: string): Promise<PlayerProfile>;\n\n  /**\n   * Compute aggregate stats from the transactions table for a wallet.\n   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n   */\n  getPlayerStats(wallet: string): Promise<PlayerStats>;\n\n  /** Compute aggregate stats from game_entries for a canonical user_id. */\n  getPlayerStatsByUserId(userId: string): Promise<PlayerStats>;\n\n  /**\n   * Get public-safe subset of player stats (no wagered, no PnL).\n   */\n  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n\n  /** Get public-safe subset of player stats by canonical user_id. */\n  getPublicPlayerStatsByUserId(userId: string): Promise<PublicPlayerStats>;\n\n  /**\n   * Compute per-game aggregate stats from the transactions table.\n   * Returns a record keyed by frontend game name (coinflip, lord-of-rngs, close-call).\n   * Games with zero activity are omitted.\n   */\n  getGameBreakdown(wallet: string): Promise<Record<string, GameBreakdownStats>>;\n\n  /** Compute per-game aggregate stats for a canonical user_id. */\n  getGameBreakdownByUserId(userId: string): Promise<Record<string, GameBreakdownStats>>;\n\n  /**\n   * Compute win streaks from the transactions table.\n   * Returns current (consecutive wins from most recent) and best (longest ever).\n   * Refund-only matches are excluded from streak calculation.\n   */\n  getWinStreaks(wallet: string): Promise<WinStreaks>;\n\n  /** Compute win streaks for a canonical user_id. */\n  getWinStreaksByUserId(userId: string): Promise<WinStreaks>;\n\n  // -------------------------------------------------------------------------\n  // Game entries\n  // -------------------------------------------------------------------------\n\n  /**\n   * Upsert a single game entry. Inserts at participation time; updates at settlement.\n   * ON CONFLICT (wallet, round_pda) DO UPDATE for settlement UPSERT pattern.\n   */\n  upsertGameEntry(entry: GameEntryUpsert): Promise<void>;\n\n  /**\n   * Batch-upsert game entries. Used at settlement to update existing entries\n   * and insert new ones (joiners) in one pass.\n   */\n  upsertGameEntries(entries: GameEntryUpsert[]): Promise<void>;\n\n  /**\n   * Get all game entries for a round. Used by settlement to read participant list.\n   */\n  getEntriesByRound(roundPda: string): Promise<GameEntry[]>;\n\n  /**\n   * @deprecated Use upsertGameEntries instead.\n   */\n  insertGameEntries(entries: GameEntryInsert[]): Promise<void>;\n\n  // -------------------------------------------------------------------------\n  // Close Call candles\n  // -------------------------------------------------------------------------\n\n  /** Insert a Close Call candle price. ON CONFLICT DO NOTHING. */\n  insertCloseCallCandle(\n    minuteTs: number,\n    price: bigint,\n    expo: number,\n    priceHuman: number,\n    hermesVaa: string | null,\n  ): Promise<void>;\n\n  /** Get the most recent Close Call candle. */\n  getLatestCloseCallCandle(): Promise<CloseCallCandle | null>;\n\n  /** Get recent Close Call candles, ordered by minute_ts DESC. */\n  getCloseCallCandles(limit: number): Promise<CloseCallCandle[]>;\n\n  // -------------------------------------------------------------------------\n  // Profile helpers\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get or create a player profile for a wallet.\n   * INSERT ON CONFLICT DO NOTHING + SELECT. Used at settlement for joiners.\n   */\n  getOrCreateProfile(wallet: string): Promise<PlayerProfile>;\n\n  /**\n   * Get the weekly leaderboard ranked by total wagered volume.\n   * Week boundary: Monday 00:00 UTC to next Monday 00:00 UTC.\n   * Optional game filter (db name: \"coinflip\", \"lord\", \"closecall\").\n   */\n  getWeeklyLeaderboard(\n    game?: string,\n    limit?: number,\n    offset?: number,\n  ): Promise<LeaderboardResult>;\n\n  /**\n   * Execute a function within a database transaction.\n   * All db methods called on the transactional Db share the same transaction.\n   * Rolls back on error, commits on success.\n   */\n  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n\n  /** Expose the underlying SQL/transaction handle for use with emitEvent(). */\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  readonly rawSql: any;\n\n  /** Gracefully close the connection pool. */\n  close(): Promise<void>;\n}\n\nfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n  return {\n    ...row,\n    open_price: Number(row.open_price),\n    open_price_expo: Number(row.open_price_expo),\n    close_price: row.close_price === null ? null : Number(row.close_price),\n    green_pool: Number(row.green_pool),\n    red_pool: Number(row.red_pool),\n    total_fee: Number(row.total_fee),\n    // Entries come from JOIN on game_entries, already parsed\n    green_entries: Array.isArray(row.green_entries)\n      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n      : [],\n    red_entries: Array.isArray(row.red_entries)\n      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n      : [],\n  };\n}\n\nfunction normalizeTransaction(row: Transaction): Transaction {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n  };\n}\n\nfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n  return {\n    ...row,\n    wager_lamports: Number(row.wager_lamports),\n    fee_lamports: Number(row.fee_lamports),\n    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n    referrer_rate_bps: Number(row.referrer_rate_bps),\n    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n  };\n}\n\nfunction normalizePlayerProfile(row: PlayerProfile): PlayerProfile {\n  return {\n    ...row,\n    id: Number(row.id),\n    heat_multiplier: Number(row.heat_multiplier),\n    points_balance: Number(row.points_balance),\n  };\n}\n\nfunction normalizeRound(row: Round): Round {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n    side: Number(row.side),\n    settle_attempts: Number(row.settle_attempts),\n    result_side: row.result_side === null ? null : Number(row.result_side),\n    // Entries come from JOIN on game_entries, already parsed\n    entries: Array.isArray(row.entries)\n      ? row.entries.map((e) => ({\n          player: e.player,\n          amountLamports: Number(e.amountLamports),\n        }))\n      : null,\n  };\n}\n\nfunction normalizeGameEntry(row: Record<string, unknown>): GameEntry {\n  return {\n    id: Number(row.id),\n    userId: row.user_id as string,\n    wallet: row.wallet as string,\n    game: row.game as string,\n    roundPda: row.round_pda as string,\n    matchId: row.match_id as string,\n    amountLamports: Number(row.amount_lamports),\n    side: (row.side as string) ?? null,\n    isWinner: row.is_winner === null ? null : Boolean(row.is_winner),\n    payoutLamports: Number(row.payout_lamports ?? 0),\n    createdAt: row.created_at as Date,\n    settledAt: (row.settled_at as Date) ?? null,\n  };\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nexport function createDb(databaseUrl: string, _txSql?: any): Db {\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const sql: any = _txSql ?? postgres(databaseUrl);\n  const _isOwner = !_txSql;\n\n  return {\n    async insertRound(params) {\n      const rows = await sql<Round[]>`\n        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)\n        VALUES (\n          ${params.pda},\n          ${params.game},\n          ${params.creator},\n          ${params.serverKey},\n          ${params.secret},\n          ${params.commitment},\n          ${params.amountLamports},\n          ${params.side},\n          ${params.matchId},\n          ${params.phase}\n        )\n        RETURNING *, NULL::jsonb AS entries\n      `;\n      return normalizeRound(rows[0]!);\n    },\n\n    async deleteRoundByPda(pda) {\n      const rows = await sql<{ pda: string }[]>`\n        DELETE FROM rounds WHERE pda = ${pda}\n        RETURNING pda\n      `;\n      return rows.length > 0;\n    },\n\n    async updateRoundPhase(pda, newPhase, updates) {\n      // Fetch current phase to validate transition\n      const current = await sql<Pick<Round, \"phase\">[]>`\n        SELECT phase FROM rounds WHERE pda = ${pda}\n      `;\n\n      if (current.length === 0) {\n        throw new Error(`Round not found: ${pda}`);\n      }\n\n      const currentPhase = current[0]!.phase as RoundPhase;\n      assertPhaseTransition(currentPhase, newPhase);\n\n      // Build the update — always set phase + updated_at, set settled_at on settlement\n      const rows = await sql<Round[]>`\n        UPDATE rounds SET\n          phase = ${newPhase},\n          updated_at = now(),\n          settled_at = ${newPhase === \"settled\" ? sql`now()` : sql`settled_at`},\n          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n          winner = COALESCE(${updates?.winner ?? null}, winner)\n        WHERE pda = ${pda}\n        RETURNING *, NULL::jsonb AS entries\n      `;\n\n      return normalizeRound(rows[0]!);\n    },\n\n    async getRoundByPda(pda) {\n      const rows = await sql<Round[]>`\n        SELECT r.*,\n          COALESCE(\n            json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports))\n            FILTER (WHERE ge.id IS NOT NULL), '[]'\n          ) AS entries\n        FROM rounds r\n        LEFT JOIN game_entries ge ON ge.round_pda = r.pda\n        WHERE r.pda = ${pda}\n        GROUP BY r.pda\n      `;\n      return rows[0] ? normalizeRound(rows[0]) : undefined;\n    },\n\n    async getRoundByMatchId(matchId) {\n      const rows = await sql<Round[]>`\n        SELECT r.*,\n          COALESCE(\n            json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports))\n            FILTER (WHERE ge.id IS NOT NULL), '[]'\n          ) AS entries\n        FROM rounds r\n        LEFT JOIN game_entries ge ON ge.round_pda = r.pda\n        WHERE r.match_id = ${matchId}\n        GROUP BY r.pda\n      `;\n      return rows[0] ? normalizeRound(rows[0]) : undefined;\n    },\n\n    async getRoundsByPhase(phase) {\n      const rows = await sql<Round[]>`\n        SELECT *, NULL::jsonb AS entries FROM rounds WHERE phase = ${phase}\n      `;\n      return rows.map(normalizeRound);\n    },\n\n    async insertOperatorEvent(pda, eventType, payload) {\n      const rows = await sql<OperatorEvent[]>`\n        INSERT INTO operator_events (pda, event_type, payload)\n        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getLatestOperatorEvent(pda, eventType) {\n      const rows = await sql<OperatorEvent[]>`\n        SELECT * FROM operator_events\n        WHERE pda = ${pda} AND event_type = ${eventType}\n        ORDER BY id DESC\n        LIMIT 1\n      `;\n      return rows[0];\n    },\n\n    async getLatestOperatorEventsForPdas(pdas, eventType) {\n      if (pdas.length === 0) return new Map();\n      const rows = await sql<OperatorEvent[]>`\n        SELECT DISTINCT ON (pda) *\n        FROM operator_events\n        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n        ORDER BY pda, id DESC\n      `;\n      const map = new Map<string, OperatorEvent>();\n      for (const row of rows) {\n        if (row.pda) map.set(row.pda, row);\n      }\n      return map;\n    },\n\n    async getRecentSettledRounds(game, limit) {\n      const rows = await sql<Round[]>`\n        SELECT r.*,\n          COALESCE(\n            json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports))\n            FILTER (WHERE ge.id IS NOT NULL), '[]'\n          ) AS entries\n        FROM rounds r\n        LEFT JOIN game_entries ge ON ge.round_pda = r.pda\n        WHERE r.game = ${game} AND r.phase = 'settled'\n        GROUP BY r.pda\n        ORDER BY r.updated_at DESC\n        LIMIT ${limit}\n      `;\n      return rows.map(normalizeRound);\n    },\n\n    async getUnsettledStats() {\n      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n        SELECT\n          COUNT(*)::text AS count,\n          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n        FROM rounds\n        WHERE phase NOT IN ('settled', 'expired')\n      `;\n      const row = rows[0]!;\n      return {\n        count: parseInt(row.count, 10),\n        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n      };\n    },\n\n    // -----------------------------------------------------------------------\n    // Close Call rounds\n    // -----------------------------------------------------------------------\n\n    async insertCloseCallRound(params) {\n      const rows = await sql<CloseCallRound[]>`\n        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n        VALUES (\n          ${params.roundId},\n          ${params.pda},\n          ${params.serverKey},\n          ${params.openPrice},\n          ${params.openPriceExpo}\n        )\n        ON CONFLICT (round_id) DO NOTHING\n        RETURNING *\n      `;\n      // If conflict (already exists), fetch the existing row\n      if (rows.length === 0) {\n        const existing = await sql<CloseCallRound[]>`\n          SELECT cr.*,\n            '[]'::json AS green_entries,\n            '[]'::json AS red_entries\n          FROM closecall_rounds cr WHERE cr.round_id = ${params.roundId}\n        `;\n        return normalizeCloseCallRound(existing[0]!);\n      }\n      return normalizeCloseCallRound({ ...rows[0]!, green_entries: [], red_entries: [] });\n    },\n\n    async getCloseCallRound(roundId) {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT cr.*,\n          COALESCE(json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports)) FILTER (WHERE ge.side = 'green'), '[]') AS green_entries,\n          COALESCE(json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports)) FILTER (WHERE ge.side = 'red'), '[]') AS red_entries\n        FROM closecall_rounds cr\n        LEFT JOIN game_entries ge ON ge.round_pda = cr.pda\n        WHERE cr.round_id = ${roundId}\n        GROUP BY cr.round_id\n      `;\n      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n    },\n\n    async getCloseCallCurrentRound() {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT cr.*,\n          COALESCE(json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports)) FILTER (WHERE ge.side = 'green'), '[]') AS green_entries,\n          COALESCE(json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports)) FILTER (WHERE ge.side = 'red'), '[]') AS red_entries\n        FROM closecall_rounds cr\n        LEFT JOIN game_entries ge ON ge.round_pda = cr.pda\n        WHERE cr.phase = 'open'\n        GROUP BY cr.round_id\n        ORDER BY cr.created_at DESC\n        LIMIT 1\n      `;\n      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n    },\n\n    async getCloseCallHistory(limit) {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT cr.*,\n          COALESCE(json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports)) FILTER (WHERE ge.side = 'green'), '[]') AS green_entries,\n          COALESCE(json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports)) FILTER (WHERE ge.side = 'red'), '[]') AS red_entries\n        FROM closecall_rounds cr\n        LEFT JOIN game_entries ge ON ge.round_pda = cr.pda\n        WHERE cr.phase IN ('settled', 'refunded')\n        GROUP BY cr.round_id\n        ORDER BY cr.settled_at DESC\n        LIMIT ${limit}\n      `;\n      return rows.map(normalizeCloseCallRound);\n    },\n\n    async settleCloseCallRound(roundId, updates) {\n      const rows = await sql<CloseCallRound[]>`\n        UPDATE closecall_rounds SET\n          phase = ${updates.phase},\n          outcome = ${updates.outcome},\n          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n          settled_at = now()\n        WHERE round_id = ${roundId}\n        RETURNING *, '[]'::json AS green_entries, '[]'::json AS red_entries\n      `;\n      if (rows.length === 0) {\n        throw new Error(`Close Call round not found: ${roundId}`);\n      }\n      return normalizeCloseCallRound(rows[0]!);\n    },\n\n    // -----------------------------------------------------------------------\n    // Transactions\n    // -----------------------------------------------------------------------\n\n    async insertTransaction(params) {\n      await sql`\n        INSERT INTO transactions (user_id, wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n        VALUES (\n          ${params.userId ?? null},\n          ${params.wallet},\n          ${params.game},\n          ${params.matchId},\n          ${params.txType},\n          ${params.amountLamports},\n          ${params.txSig}\n        )\n        ON CONFLICT DO NOTHING\n      `;\n    },\n\n    async insertTransactions(params) {\n      if (params.length === 0) return;\n      const values = params.map((p) => ({\n        user_id: p.userId ?? null,\n        wallet: p.wallet,\n        game: p.game,\n        match_id: p.matchId,\n        tx_type: p.txType,\n        amount_lamports: p.amountLamports,\n        tx_sig: p.txSig,\n      }));\n      await sql`\n        INSERT INTO transactions ${sql(values, \"user_id\", \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n        ON CONFLICT DO NOTHING\n      `;\n    },\n\n    async upsertGameEntry(entry) {\n      await sql`\n        INSERT INTO game_entries (user_id, wallet, game, round_pda, match_id, amount_lamports, side, is_winner, payout_lamports, settled_at)\n        VALUES (\n          ${entry.userId},\n          ${entry.wallet},\n          ${entry.game},\n          ${entry.roundPda},\n          ${entry.matchId},\n          ${entry.amountLamports},\n          ${entry.side ?? null},\n          ${entry.isWinner ?? null},\n          ${entry.payoutLamports ?? 0},\n          ${entry.settledAt ?? null}\n        )\n        ON CONFLICT (wallet, round_pda) DO UPDATE SET\n          amount_lamports = EXCLUDED.amount_lamports,\n          is_winner = EXCLUDED.is_winner,\n          payout_lamports = EXCLUDED.payout_lamports,\n          settled_at = EXCLUDED.settled_at\n      `;\n    },\n\n    async upsertGameEntries(entries) {\n      if (entries.length === 0) return;\n      for (const entry of entries) {\n        await this.upsertGameEntry(entry);\n      }\n    },\n\n    async getEntriesByRound(roundPda) {\n      const rows = await sql<Record<string, unknown>[]>`\n        SELECT * FROM game_entries WHERE round_pda = ${roundPda}\n      `;\n      return rows.map(normalizeGameEntry);\n    },\n\n    async insertGameEntries(entries) {\n      if (entries.length === 0) return;\n      // Delegate to upsertGameEntries for backward compat\n      await this.upsertGameEntries(entries);\n    },\n\n    // -----------------------------------------------------------------------\n    // Close Call candles\n    // -----------------------------------------------------------------------\n\n    async insertCloseCallCandle(minuteTs, price, expo, priceHuman, hermesVaa) {\n      await sql`\n        INSERT INTO closecall_candles (minute_ts, price, expo, price_human, hermes_vaa)\n        VALUES (${minuteTs}, ${price}, ${expo}, ${priceHuman}, ${hermesVaa})\n        ON CONFLICT (minute_ts) DO NOTHING\n      `;\n    },\n\n    async getLatestCloseCallCandle() {\n      const rows = await sql<Array<{ minute_ts: string; price: string; expo: number; price_human: number }>>`\n        SELECT minute_ts, price, expo, price_human\n        FROM closecall_candles\n        ORDER BY minute_ts DESC\n        LIMIT 1\n      `;\n      if (rows.length === 0) return null;\n      const row = rows[0]!;\n      return {\n        minuteTs: Number(row.minute_ts),\n        price: BigInt(row.price),\n        expo: Number(row.expo),\n        priceHuman: Number(row.price_human),\n      };\n    },\n\n    async getCloseCallCandles(limit) {\n      const rows = await sql<Array<{ minute_ts: string; price: string; expo: number; price_human: number }>>`\n        SELECT minute_ts, price, expo, price_human\n        FROM closecall_candles\n        ORDER BY minute_ts DESC\n        LIMIT ${limit}\n      `;\n      return rows.map((row: (typeof rows)[number]) => ({\n        minuteTs: Number(row.minute_ts),\n        price: BigInt(row.price),\n        expo: Number(row.expo),\n        priceHuman: Number(row.price_human),\n      }));\n    },\n\n    // -----------------------------------------------------------------------\n    // Profile helpers\n    // -----------------------------------------------------------------------\n\n    async getOrCreateProfile(wallet) {\n      // Try to get existing profile first (fast path)\n      const existing = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE wallet = ${wallet}\n      `;\n      if (existing[0]) return normalizePlayerProfile(existing[0]);\n\n      // Create new profile if not found\n      return this.createPlayerProfile(wallet);\n    },\n\n    async getTransactions(wallet, cursor, limit = 20, game) {\n      const effectiveLimit = Math.min(limit, 50);\n      if (cursor && game) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      if (cursor) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND id < ${cursor}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      if (game) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND game = ${game}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      const rows = await sql<Transaction[]>`\n        SELECT * FROM transactions\n        WHERE wallet = ${wallet}\n        ORDER BY id DESC\n        LIMIT ${effectiveLimit}\n      `;\n      return rows.map(normalizeTransaction);\n    },\n\n    async getTransactionsByUserId(userId, cursor, limit = 20, game) {\n      const effectiveLimit = Math.min(limit, 50);\n      const cursorFilter = cursor ? sql`AND t.id < ${cursor}` : sql``;\n      const gameFilter = game ? sql`AND t.game = ${game}` : sql``;\n      const rows = await sql<Transaction[]>`\n        SELECT t.*\n        FROM transactions t\n        JOIN player_profiles p ON p.wallet = t.wallet\n        WHERE p.user_id = ${userId}\n          ${cursorFilter}\n          ${gameFilter}\n        ORDER BY t.id DESC\n        LIMIT ${effectiveLimit}\n      `;\n      return rows.map(normalizeTransaction);\n    },\n\n    // -----------------------------------------------------------------------\n    // Referral — codes\n    // -----------------------------------------------------------------------\n\n    async insertReferralCode(userId, wallet, code) {\n      const rows = await sql<ReferralCode[]>`\n        INSERT INTO referral_codes (user_id, wallet, code)\n        VALUES (${userId}, ${wallet}, ${code})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralCodeByUserId(userId) {\n      const rows = await sql<ReferralCode[]>`\n        SELECT * FROM referral_codes WHERE user_id = ${userId}\n      `;\n      return rows[0];\n    },\n\n    async getReferralCodeByCode(code) {\n      const rows = await sql<ReferralCode[]>`\n        SELECT * FROM referral_codes WHERE code = ${code}\n      `;\n      return rows[0];\n    },\n\n    // -- Referral links -------------------------------------------------------\n\n    async insertReferralLink(params) {\n      const rows = await sql<ReferralLink[]>`\n        INSERT INTO referral_links (\n          referrer_user_id,\n          referee_user_id,\n          referrer_wallet,\n          referee_wallet\n        )\n        VALUES (\n          ${params.referrerUserId},\n          ${params.refereeUserId},\n          ${params.referrerWallet},\n          ${params.refereeWallet}\n        )\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralLinkByRefereeUserId(refereeUserId) {\n      const rows = await sql<ReferralLink[]>`\n        SELECT * FROM referral_links WHERE referee_user_id = ${refereeUserId}\n      `;\n      return rows[0];\n    },\n\n    async getReferralLinksByReferrerUserId(referrerUserId) {\n      const rows = await sql<ReferralLink[]>`\n        SELECT * FROM referral_links WHERE referrer_user_id = ${referrerUserId}\n        ORDER BY created_at DESC\n      `;\n      return rows;\n    },\n\n    // -- Referral earnings & stats --------------------------------------------\n\n    async insertReferralEarning(params) {\n      const rows = await sql<ReferralEarning[]>`\n        INSERT INTO referral_earnings (\n          referrer_user_id, referee_user_id,\n          referrer_wallet, referee_wallet, round_id, game_type,\n          wager_lamports, fee_lamports,\n          referrer_earned_lamports, referrer_rate_bps,\n          referee_rebate_lamports, referee_rebate_rate_bps\n        ) VALUES (\n          ${params.referrerUserId}, ${params.refereeUserId},\n          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n          ${params.wagerLamports}, ${params.feeLamports},\n          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n        )\n        RETURNING *\n      `;\n      return normalizeReferralEarning(rows[0]!);\n    },\n\n    async getPendingBalanceByUserId(userId) {\n      const rows = await sql<{ pending: string }[]>`\n        SELECT COALESCE(\n          (\n            SELECT SUM(referrer_earned_lamports)\n            FROM referral_earnings WHERE referrer_user_id = ${userId}\n          ), 0\n        ) + COALESCE(\n          (\n            SELECT SUM(referee_rebate_lamports)\n            FROM referral_earnings WHERE referee_user_id = ${userId}\n          ), 0\n        ) - COALESCE(\n          (\n            SELECT SUM(amount_lamports)\n            FROM referral_claims WHERE user_id = ${userId} AND status IN ('pending', 'processing', 'error', 'completed')\n          ), 0\n        ) AS pending\n      `;\n      return rows[0]!.pending;\n    },\n\n    async getReferralEarningsByUserId(userId, page, limit) {\n      const offset = (page - 1) * limit;\n      const [countRows, rows] = await Promise.all([\n        sql<{ count: string }[]>`\n          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n          WHERE referrer_user_id = ${userId}\n        `,\n        sql<ReferralEarning[]>`\n          SELECT * FROM referral_earnings\n          WHERE referrer_user_id = ${userId}\n          ORDER BY created_at DESC\n          LIMIT ${limit} OFFSET ${offset}\n        `,\n      ]);\n      const total = Number(countRows[0]!.count);\n      const totalPages = Math.max(1, Math.ceil(total / limit));\n      return { items: rows.map(normalizeReferralEarning), totalPages };\n    },\n\n    async getReferralStatsByUserId(userId) {\n      const rows = await sql<ReferralStats[]>`\n        SELECT\n          (SELECT COUNT(*) FROM referral_links WHERE referrer_user_id = ${userId})::INT\n            AS referred_count,\n          (\n            SELECT COUNT(DISTINCT re.referee_user_id)\n            FROM referral_earnings re\n            JOIN referral_links rl\n              ON rl.referee_user_id = re.referee_user_id\n             AND rl.referrer_user_id = ${userId}\n            WHERE re.created_at > now() - INTERVAL '7 days'\n          )::INT AS active_count,\n          COALESCE(\n            (\n              SELECT SUM(re.wager_lamports)::TEXT\n              FROM referral_earnings re\n              JOIN referral_links rl\n                ON rl.referee_user_id = re.referee_user_id\n               AND rl.referrer_user_id = ${userId}\n            ), '0'\n          ) AS total_volume_lamports,\n          COALESCE(\n            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_user_id = ${userId}),\n            '0'\n          ) AS total_earned_lamports,\n          COALESCE(\n            (SELECT SUM(referee_rebate_lamports)::TEXT FROM referral_earnings WHERE referee_user_id = ${userId}),\n            '0'\n          ) AS total_rebate_lamports,\n          (\n            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_user_id = ${userId}), 0)\n            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_user_id = ${userId}), 0)\n            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE user_id = ${userId} AND status IN ('pending','processing','error','completed')), 0)\n          )::TEXT AS pending_lamports\n      `;\n      return rows[0]!;\n    },\n\n    // -----------------------------------------------------------------------\n    // Referral — claims & rates\n    // -----------------------------------------------------------------------\n\n    async insertReferralClaim(userId, wallet, amountLamports) {\n      const rows = await sql<ReferralClaim[]>`\n        INSERT INTO referral_claims (user_id, wallet, amount_lamports, status)\n        VALUES (${userId}, ${wallet}, ${amountLamports}, 'pending')\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralClaim(claimId) {\n      const rows = await sql<ReferralClaim[]>`\n        SELECT * FROM referral_claims WHERE id = ${claimId}\n      `;\n      return rows[0];\n    },\n\n    async updateClaimStatus(claimId, status, meta) {\n      const rows = await sql<ReferralClaim[]>`\n        UPDATE referral_claims\n        SET\n          status = ${status},\n          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n          error = COALESCE(${meta?.error ?? null}, error),\n          retry_count = ${meta?.incrementRetry ? sql`retry_count + 1` : sql`retry_count`},\n          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n        WHERE id = ${claimId}\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferrerRate(userId, defaultRateBps) {\n      const rows = await sql<{ rate_bps: number }[]>`\n        SELECT rate_bps FROM referral_kol_rates WHERE user_id = ${userId}\n      `;\n      return rows[0]?.rate_bps ?? defaultRateBps;\n    },\n\n    // -----------------------------------------------------------------------\n    // Player profiles\n    // -----------------------------------------------------------------------\n\n    async createPlayerProfile(wallet) {\n      const userId = generateUserId();\n      const MAX_RETRIES = 5;\n\n      for (let attempt = 0; attempt <= MAX_RETRIES; attempt++) {\n        const username =\n          attempt < MAX_RETRIES\n            ? generateUsername()\n            : `user-${generateUserId().slice(4)}`; // fallback: user-{random8}\n\n        try {\n          const rows = await sql<PlayerProfile[]>`\n            INSERT INTO player_profiles (user_id, wallet, username)\n            VALUES (${userId}, ${wallet}, ${username})\n            RETURNING *\n          `;\n          return normalizePlayerProfile(rows[0]!);\n        } catch (err: unknown) {\n          const pgErr = err as { code?: string; constraint_name?: string };\n          // 23505 = unique_violation — retry only on username collision\n          if (pgErr.code === \"23505\" && attempt < MAX_RETRIES) {\n            continue;\n          }\n          throw err;\n        }\n      }\n\n      // Unreachable — final attempt either succeeds or throws\n      throw new Error(\"createPlayerProfile: exhausted retries\");\n    },\n\n    async getProfileByWallet(wallet) {\n      const rows = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE wallet = ${wallet}\n      `;\n      return rows[0] ? normalizePlayerProfile(rows[0]) : null;\n    },\n\n    async getProfileByUserId(userId) {\n      const rows = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE user_id = ${userId}\n      `;\n      return rows[0] ? normalizePlayerProfile(rows[0]) : null;\n    },\n\n    async getProfileByIdentifier(identifier) {\n      if (identifier.startsWith(\"usr_\")) {\n        const rows = await sql<PlayerProfile[]>`\n          SELECT * FROM player_profiles WHERE user_id = ${identifier}\n        `;\n        return rows[0] ? normalizePlayerProfile(rows[0]) : null;\n      }\n      const rows = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE LOWER(username) = LOWER(${identifier})\n      `;\n      return rows[0] ? normalizePlayerProfile(rows[0]) : null;\n    },\n\n    async updateUsername(wallet, newUsername) {\n      // Fetch current profile to check cooldown\n      const current = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE wallet = ${wallet}\n      `;\n      if (current.length === 0) {\n        throw new Error(\"Profile not found\");\n      }\n\n      const profile = current[0]!;\n      if (profile.username_updated_at) {\n        const cooldownMs = 30 * 24 * 60 * 60 * 1000; // 30 days\n        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n        if (elapsed < cooldownMs) {\n          const nextEditAt = new Date(\n            new Date(profile.username_updated_at).getTime() + cooldownMs,\n          );\n          const err = new Error(\"Username cooldown active\") as Error & {\n            cooldown: true;\n            nextEditAvailableAt: Date;\n          };\n          err.cooldown = true;\n          err.nextEditAvailableAt = nextEditAt;\n          throw err;\n        }\n      }\n\n      const rows = await sql<PlayerProfile[]>`\n        UPDATE player_profiles\n        SET username = ${newUsername}, username_updated_at = now()\n        WHERE wallet = ${wallet}\n        RETURNING *\n      `;\n      return normalizePlayerProfile(rows[0]!);\n    },\n\n    async updateUsernameByUserId(userId, newUsername) {\n      const current = await sql<PlayerProfile[]>`\n        SELECT * FROM player_profiles WHERE user_id = ${userId}\n      `;\n      if (current.length === 0) {\n        throw new Error(\"Profile not found\");\n      }\n\n      const profile = current[0]!;\n      if (profile.username_updated_at) {\n        const cooldownMs = 30 * 24 * 60 * 60 * 1000;\n        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n        if (elapsed < cooldownMs) {\n          const nextEditAt = new Date(\n            new Date(profile.username_updated_at).getTime() + cooldownMs,\n          );\n          const err = new Error(\"Username cooldown active\") as Error & {\n            cooldown: true;\n            nextEditAvailableAt: Date;\n          };\n          err.cooldown = true;\n          err.nextEditAvailableAt = nextEditAt;\n          throw err;\n        }\n      }\n\n      const rows = await sql<PlayerProfile[]>`\n        UPDATE player_profiles\n        SET username = ${newUsername}, username_updated_at = now()\n        WHERE user_id = ${userId}\n        RETURNING *\n      `;\n      return normalizePlayerProfile(rows[0]!);\n    },\n\n    async getPlayerStats(wallet) {\n      const rows = await sql<\n        Array<{\n          games_played: string;\n          total_wagered: string;\n          total_wins: string;\n          net_pnl: string;\n        }>\n      >`\n        SELECT\n          COUNT(*)::text AS games_played,\n          COALESCE(SUM(amount_lamports), 0)::text AS total_wagered,\n          SUM(CASE WHEN is_winner = true THEN 1 ELSE 0 END)::text AS total_wins,\n          COALESCE(SUM(payout_lamports - amount_lamports), 0)::text AS net_pnl\n        FROM game_entries\n        WHERE wallet = ${wallet} AND settled_at IS NOT NULL\n      `;\n      const row = rows[0]!;\n      const gamesPlayed = Number(row.games_played);\n      const totalWins = Number(row.total_wins);\n      return {\n        gamesPlayed,\n        totalWagered: BigInt(row.total_wagered),\n        totalWins,\n        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n        netPnl: BigInt(row.net_pnl),\n      };\n    },\n\n    async getPlayerStatsByUserId(userId) {\n      const rows = await sql<\n        Array<{\n          games_played: string;\n          total_wagered: string;\n          total_wins: string;\n          net_pnl: string;\n        }>\n      >`\n        SELECT\n          COUNT(*)::text AS games_played,\n          COALESCE(SUM(amount_lamports), 0)::text AS total_wagered,\n          SUM(CASE WHEN is_winner = true THEN 1 ELSE 0 END)::text AS total_wins,\n          COALESCE(SUM(payout_lamports - amount_lamports), 0)::text AS net_pnl\n        FROM game_entries\n        WHERE user_id = ${userId} AND settled_at IS NOT NULL\n      `;\n      const row = rows[0]!;\n      const gamesPlayed = Number(row.games_played);\n      const totalWins = Number(row.total_wins);\n      return {\n        gamesPlayed,\n        totalWagered: BigInt(row.total_wagered),\n        totalWins,\n        winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n        netPnl: BigInt(row.net_pnl),\n      };\n    },\n\n    async getPublicPlayerStats(wallet) {\n      const full = await this.getPlayerStats(wallet);\n      return {\n        gamesPlayed: full.gamesPlayed,\n        totalWins: full.totalWins,\n        winRate: full.winRate,\n      };\n    },\n\n    async getPublicPlayerStatsByUserId(userId) {\n      const full = await this.getPlayerStatsByUserId(userId);\n      return {\n        gamesPlayed: full.gamesPlayed,\n        totalWins: full.totalWins,\n        winRate: full.winRate,\n      };\n    },\n\n    async getGameBreakdown(wallet) {\n      const DB_TO_FRONTEND: Record<string, string> = {\n        coinflip: \"coinflip\",\n        lord: \"lord-of-rngs\",\n        closecall: \"close-call\",\n      };\n\n      const rows = await sql<\n        Array<{\n          game: string;\n          games_played: string;\n          total_wagered: string;\n          total_wins: string;\n          net_pnl: string;\n        }>\n      >`\n        SELECT\n          game,\n          COUNT(*)::text AS games_played,\n          COALESCE(SUM(amount_lamports), 0)::text AS total_wagered,\n          SUM(CASE WHEN is_winner = true THEN 1 ELSE 0 END)::text AS total_wins,\n          COALESCE(SUM(payout_lamports - amount_lamports), 0)::text AS net_pnl\n        FROM game_entries\n        WHERE wallet = ${wallet} AND settled_at IS NOT NULL\n        GROUP BY game\n      `;\n\n      const result: Record<string, GameBreakdownStats> = {};\n      for (const row of rows) {\n        const gamesPlayed = Number(row.games_played);\n        if (gamesPlayed === 0) continue;\n        const totalWins = Number(row.total_wins);\n        const frontendName = DB_TO_FRONTEND[row.game] ?? row.game;\n        result[frontendName] = {\n          gamesPlayed,\n          totalWagered: BigInt(row.total_wagered),\n          totalWins,\n          winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n          netPnl: BigInt(row.net_pnl),\n        };\n      }\n      return result;\n    },\n\n    async getGameBreakdownByUserId(userId) {\n      const DB_TO_FRONTEND: Record<string, string> = {\n        coinflip: \"coinflip\",\n        lord: \"lord-of-rngs\",\n        closecall: \"close-call\",\n      };\n\n      const rows = await sql<\n        Array<{\n          game: string;\n          games_played: string;\n          total_wagered: string;\n          total_wins: string;\n          net_pnl: string;\n        }>\n      >`\n        SELECT\n          game,\n          COUNT(*)::text AS games_played,\n          COALESCE(SUM(amount_lamports), 0)::text AS total_wagered,\n          SUM(CASE WHEN is_winner = true THEN 1 ELSE 0 END)::text AS total_wins,\n          COALESCE(SUM(payout_lamports - amount_lamports), 0)::text AS net_pnl\n        FROM game_entries\n        WHERE user_id = ${userId} AND settled_at IS NOT NULL\n        GROUP BY game\n      `;\n\n      const result: Record<string, GameBreakdownStats> = {};\n      for (const row of rows) {\n        const gamesPlayed = Number(row.games_played);\n        if (gamesPlayed === 0) continue;\n        const totalWins = Number(row.total_wins);\n        const frontendName = DB_TO_FRONTEND[row.game] ?? row.game;\n        result[frontendName] = {\n          gamesPlayed,\n          totalWagered: BigInt(row.total_wagered),\n          totalWins,\n          winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n          netPnl: BigInt(row.net_pnl),\n        };\n      }\n      return result;\n    },\n\n    async getWinStreaks(wallet) {\n      // Get settled game entries ordered by most recent first.\n      // Skip refund entries (is_winner IS NULL) — they don't affect streaks.\n      const rows = await sql<\n        Array<{ is_winner: boolean }>\n      >`\n        SELECT is_winner\n        FROM game_entries\n        WHERE wallet = ${wallet}\n          AND settled_at IS NOT NULL\n          AND is_winner IS NOT NULL\n        ORDER BY settled_at DESC\n      `;\n\n      let current = 0;\n      let best = 0;\n      let streak = 0;\n      let currentSet = false;\n\n      for (const row of rows) {\n        if (row.is_winner) {\n          streak++;\n          if (streak > best) best = streak;\n        } else {\n          if (!currentSet) {\n            current = streak;\n            currentSet = true;\n          }\n          streak = 0;\n        }\n      }\n      // If we never hit a loss, current streak = total streak\n      if (!currentSet) current = streak;\n\n      return { current, best };\n    },\n\n    async getWinStreaksByUserId(userId) {\n      const rows = await sql<Array<{ is_winner: boolean }>>`\n        SELECT is_winner\n        FROM game_entries\n        WHERE user_id = ${userId}\n          AND settled_at IS NOT NULL\n          AND is_winner IS NOT NULL\n        ORDER BY settled_at DESC\n      `;\n\n      let current = 0;\n      let best = 0;\n      let streak = 0;\n      let currentSet = false;\n\n      for (const row of rows) {\n        if (row.is_winner) {\n          streak++;\n          if (streak > best) best = streak;\n        } else {\n          if (!currentSet) {\n            current = streak;\n            currentSet = true;\n          }\n          streak = 0;\n        }\n      }\n      if (!currentSet) current = streak;\n\n      return { current, best };\n    },\n\n    async getWeeklyLeaderboard(game, limit = 20, offset = 0) {\n      const effectiveLimit = Math.min(limit, 100);\n      const gameFilter = game ? sql`AND ge.game = ${game}` : sql``;\n\n      const rows = await sql<\n        Array<{\n          user_id: string;\n          username: string;\n          avatar_url: string | null;\n          total_wagered: string;\n          games_played: string;\n          total_wins: string;\n          net_pnl: string;\n        }>\n      >`\n        SELECT\n          ge.user_id,\n          COALESCE(p.username, LEFT(ge.user_id, 8)) AS username,\n          p.avatar_url,\n          SUM(ge.amount_lamports)::text               AS total_wagered,\n          COUNT(*)::text                               AS games_played,\n          SUM(CASE WHEN ge.is_winner = true THEN 1 ELSE 0 END)::text AS total_wins,\n          SUM(ge.payout_lamports - ge.amount_lamports)::text   AS net_pnl\n        FROM game_entries ge\n        JOIN player_profiles p ON p.user_id = ge.user_id\n        WHERE ge.settled_at IS NOT NULL\n          AND ge.settled_at >= date_trunc('week', now())\n          ${gameFilter}\n        GROUP BY ge.user_id, p.username, p.avatar_url\n        ORDER BY SUM(ge.amount_lamports) DESC\n        LIMIT ${effectiveLimit}\n        OFFSET ${offset}\n      `;\n\n      const entries: LeaderboardEntry[] = rows.map((row: (typeof rows)[number], i: number) => {\n        const gamesPlayed = Number(row.games_played);\n        const totalWins = Number(row.total_wins);\n        return {\n          rank: offset + i + 1,\n          userId: row.user_id,\n          username: row.username,\n          avatarUrl: row.avatar_url,\n          totalWagered: BigInt(row.total_wagered),\n          gamesPlayed,\n          totalWins,\n          winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n          netPnl: BigInt(row.net_pnl),\n        };\n      });\n\n      // Week boundaries: ISO week (Monday start)\n      const now = new Date();\n      const day = now.getUTCDay();\n      const diff = day === 0 ? 6 : day - 1;\n      const ws = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - diff));\n      const we = new Date(ws.getTime() + 7 * 24 * 60 * 60 * 1000);\n\n      return {\n        entries,\n        weekStart: ws.toISOString(),\n        weekEnd: we.toISOString(),\n      };\n    },\n\n    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n    },\n\n    async close() {\n      if (_isOwner) await sql.end();\n    },\n  };\n}\n","structuredPatch":[{"oldStart":769,"oldLines":6,"newStart":769,"newLines":8,"lines":["   const _isOwner = !_txSql;"," ","   return {","+    rawSql: sql,","+","     async insertRound(params) {","       const rows = await sql<Round[]>`","         INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)"]}],"userModified":false,"replaceAll":false}}
