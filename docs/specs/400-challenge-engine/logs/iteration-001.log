CRATE_DROP: \"crate.drop\",","+  CRATE_SOL_PAYOUT: \"crate.sol_payout\","," } as const;"," "," export type EventType = (typeof EventTypes)[keyof typeof EventTypes];"]}],"userModified":false,"replaceAll":false}}
