{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016npW1xYUdBh821QBWtPs7t","type":"tool_result","content":"400\t    }\n401\t\n402\t    // Log settle_confirmed\n403\t    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n404\t      txSignature,\n405\t      resultSide,\n406\t      winner: winner.toBase58(),\n407\t      entropy: entropy.toString(\"hex\"),\n408\t      payoutAmount,\n409\t      feeAmount,\n410\t      entries: coinflipEntries,\n411\t    });\n412\t\n413\t    // Write payout transaction for the winner\n414\t    await txDb.insertTransaction({\n415\t      userId: winnerProfile?.user_id,\n416\t      wallet: winner.toBase58(),\n417\t      game: \"coinflip\",\n418\t      matchId: round.match_id,\n419\t      txType: \"payout\",\n420\t      amountLamports: payoutAmount,\n421\t      txSig: txSignature,\n422\t    });\n423\t\n424\t    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n425\t    await recordReferralEarnings(txDb, {\n426\t      roundId: round.match_id,\n427\t      gameType: \"coinflip\",\n428\t      feeBps,\n429\t      referralDefaultRateBps: deps.referralDefaultRateBps,\n430\t      players: [\n431\t        { wallet: creator.toBase58(), wagerLamports: Number(entryAmount) },\n432\t        { wallet: opponent.toBase58(), wagerLamports: Number(entryAmount) },\n433\t      ],\n434\t    });\n435\t  });\n436\t\n437\t  const tDone = performance.now();\n438\t  logger.info(\"settlement transaction confirmed\", {\n439\t    pda,\n440\t    txSignature,\n441\t    resultSide,\n442\t    winner: winner.toBase58(),\n443\t    timing: {\n444\t      dbMs: Math.round(tDb - t0),\n445\t      fetchMs: Math.round(tFetch - tDb),\n446\t      buildMs: Math.round(tBuild - tFetch),\n447\t      sendMs: Math.round(tSend - tBuild),\n448\t      confirmMs: Math.round(tConfirm - tSend),\n449\t      dbWriteMs: Math.round(tDone - tConfirm),\n450\t      totalMs: Math.round(tDone - t0),\n451\t    },\n452\t  });\n453\t\n454\t  return {\n455\t    txSignature,\n456\t    resultHash,\n457\t    resultSide,\n458\t    winner: winner.toBase58(),\n459\t  };\n460\t}\n461\t\n462\texport async function settleLordRound(\n463\t  deps: SettleTxDeps,\n464\t  pda: string,\n465\t): Promise<SettleResult> {\n466\t  const t0 = performance.now();\n467\t  const { db, connection, serverKeypair, entropyAccount } = deps;\n468\t  const roundPubkey = new PublicKey(pda);\n469\t\n470\t  const round = await db.getRoundByPda(pda);\n471\t  const tDb = performance.now();\n472\t  if (!round) {\n473\t    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n474\t  }\n475\t  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n476\t    throw new PermanentSettleError(\n477\t      `Round ${pda} in unexpected phase: ${round.phase}`,\n478\t    );\n479\t  }\n480\t\n481\t  const secret = Buffer.from(round.secret);\n482\t\n483\t  if (round.phase === \"locked\") {\n484\t    await db.updateRoundPhase(pda, \"settling\");\n485\t  }\n486\t\n487\t  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n488\t    attempt: round.settle_attempts + 1,\n489\t    game: \"lord\",\n490\t  });\n491\t\n492\t  const [platformConfigPda] = derivePlatformConfigPda();\n493\t  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n494\t    await Promise.all([\n495\t      connection.getAccountInfo(roundPubkey),\n496\t      getPlatformConfig(connection),\n497\t      connection.getAccountInfo(entropyAccount),\n498\t      connection.getLatestBlockhash(),\n499\t    ]);\n500\t\n501\t  const tFetch = performance.now();\n502\t\n503\t  if (!roundAccountInfo) {\n504\t    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n505\t  }\n506\t  if (!entropyInfo) {\n507\t    throw new TransientSettleError(\"Entropy account not available yet\");\n508\t  }\n509\t\n510\t  // IDL-driven decode — no manual byte offsets or parseLordRound()\n511\t  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n512\t  const { feeBps, treasury } = platformConfig;\n513\t\n514\t  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n515\t  const resultHash = deriveResult(\n516\t    secret,\n517\t    entropy,\n518\t    roundPubkey.toBuffer(),\n519\t    roundData.algorithmVer,\n520\t  );\n521\t  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n522\t  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n523\t  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n524\t\n525\t  const raw = resultHash.readBigUInt64LE(0);\n526\t  const winningOffset = raw % roundData.totalAmountLamports;\n527\t\n528\t  let cumulative = 0n;\n529\t  let winnerEntryIndex = -1;\n530\t  let winner = roundData.entries[0]?.player;\n531\t  for (const [index, entry] of roundData.entries.entries()) {\n532\t    cumulative += entry.amountLamports;\n533\t    if (winningOffset < cumulative) {\n534\t      winnerEntryIndex = index;\n535\t      winner = entry.player;\n536\t      break;\n537\t    }\n538\t  }\n539\t\n540\t  if (!winner || winnerEntryIndex < 0) {\n541\t    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n542\t  }\n543\t\n544\t  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n545\t  const instruction = new TransactionInstruction({\n546\t    keys: [\n547\t      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n548\t      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n549\t      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n550\t      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n551\t      { pubkey: treasury, isSigner: false, isWritable: true },\n552\t      { pubkey: winner, isSigner: false, isWritable: true },\n553\t      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n554\t    ],\n555\t    programId: LORDOFRNGS_PROGRAM_ID,\n556\t    data: encodeClaimPayoutData(matchIdBuf, secret),\n557\t  });\n558\t\n559\t  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n560\t  const tx = new Transaction({\n561\t    feePayer: serverKeypair.publicKey,\n562\t    blockhash,\n563\t    lastValidBlockHeight,\n564\t  });\n565\t  tx.add(instruction);\n566\t  tx.sign(serverKeypair);\n567\t\n568\t  const tBuild = performance.now();\n569\t  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n570\t    skipPreflight: false,\n571\t  });\n572\t  const tSend = performance.now();\n573\t\n574\t  logger.info(\"lord settlement transaction submitted\", {\n575\t    pda,\n576\t    txSignature,\n577\t    attempt: round.settle_attempts + 1,\n578\t    winningEntryIndex: winnerEntryIndex,\n579\t    dbMs: Math.round(tDb - t0),\n580\t    fetchMs: Math.round(tFetch - tDb),\n581\t    buildMs: Math.round(tBuild - tFetch),\n582\t    sendMs: Math.round(tSend - tBuild),\n583\t  });\n584\t\n585\t  const confirmation = await connection.confirmTransaction(\n586\t    { signature: txSignature, blockhash, lastValidBlockHeight },\n587\t    \"confirmed\",\n588\t  );\n589\t  const tConfirm = performance.now();\n590\t  if (confirmation.value.err) {\n591\t    throw new TransientSettleError(\n592\t      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n593\t    );\n594\t  }\n595\t\n596\t  const serializedEntries = roundData.entries.map((e) => ({\n597\t    player: e.player.toBase58(),\n598\t    amountLamports: Number(e.amountLamports),\n599\t  }));"}]},"parent_tool_use_id":"toolu_01TqiXb6r2UeRy5smFR983XZ","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"d45b9cc5-ad5f-4d89-abfc-e66ee9383aaf","timestamp":"2026-04-03T18:48:17.572Z"}
