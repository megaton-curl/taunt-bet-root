{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LXwTBMfCLVwdXjXTp5vWNA","type":"tool_result","content":"1\t/**\n2\t * Referral route tests — set code, apply, stats, earnings, claim flows.\n3\t *\n4\t * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n5\t * between tests for isolation.\n6\t */\n7\t\n8\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n9\timport { Hono } from \"hono\";\n10\timport { Keypair } from \"@solana/web3.js\";\n11\timport { SignJWT } from \"jose\";\n12\timport postgres from \"postgres\";\n13\timport { createDb, type Db } from \"../db.js\";\n14\timport { createReferralRoutes } from \"../routes/referral.js\";\n15\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n16\timport type { Config } from \"../config.js\";\n17\t\n18\t// ---------------------------------------------------------------------------\n19\t// Constants\n20\t// ---------------------------------------------------------------------------\n21\t\n22\tconst DATABASE_URL =\n23\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n24\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n25\t\n26\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n27\tfunction makeSql() {\n28\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n29\t  // Dev container: postgres listens on Unix socket only\n30\t  return postgres({\n31\t    host: \"/var/run/postgresql\",\n32\t    user: \"vscode\",\n33\t    database: \"rng_utopia_dev\",\n34\t  });\n35\t}\n36\t\n37\t// ---------------------------------------------------------------------------\n38\t// Helpers\n39\t// ---------------------------------------------------------------------------\n40\t\n41\tasync function makeJwt(wallet: string): Promise<string> {\n42\t  const now = Math.floor(Date.now() / 1000);\n43\t  return new SignJWT({})\n44\t    .setProtectedHeader({ alg: \"HS256\" })\n45\t    .setSubject(userIdFromWallet(wallet))\n46\t    .setIssuedAt(now)\n47\t    .setExpirationTime(now + 3600)\n48\t    .sign(JWT_SECRET);\n49\t}\n50\t\n51\tfunction json(body: Record<string, unknown>) {\n52\t  return {\n53\t    headers: { \"Content-Type\": \"application/json\" },\n54\t    body: JSON.stringify(body),\n55\t  };\n56\t}\n57\t\n58\tfunction userIdFromWallet(wallet: string) {\n59\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n60\t}\n61\t\n62\t// ---------------------------------------------------------------------------\n63\t// Test suite\n64\t// ---------------------------------------------------------------------------\n65\t\n66\tdescribe(\"Referral routes\", () => {\n67\t  let rawSql: ReturnType<typeof postgres>;\n68\t  let db: Db;\n69\t  let app: Hono;\n70\t\n71\t  const referrerKp = Keypair.generate();\n72\t  const refereeKp = Keypair.generate();\n73\t  const referrer = referrerKp.publicKey.toBase58();\n74\t  const referee = refereeKp.publicKey.toBase58();\n75\t  const referrerUserId = userIdFromWallet(referrer);\n76\t  const refereeUserId = userIdFromWallet(referee);\n77\t\n78\t  const testConfig = {\n79\t    referralDefaultRateBps: 1000,\n80\t    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n81\t  } as Config;\n82\t\n83\t  beforeAll(async () => {\n84\t    rawSql = makeSql();\n85\t    await rawSql`\n86\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n87\t    `;\n88\t    await rawSql`\n89\t      CREATE TABLE referral_codes (\n90\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n91\t        user_id TEXT NOT NULL UNIQUE,\n92\t        wallet TEXT NOT NULL UNIQUE,\n93\t        code TEXT NOT NULL UNIQUE,\n94\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n95\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n96\t      )\n97\t    `;\n98\t    await rawSql`\n99\t      CREATE TABLE referral_links (\n100\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"87bb5e59-043f-4214-b4c1-5fd1ba135a19","timestamp":"2026-04-03T18:48:24.178Z"}
