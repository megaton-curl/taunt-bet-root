{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019TN7ZtootHDQLQmY4Ku1tz","type":"tool_result","content":"150\t      pda,\n151\t    ),\n152\t});\n153\t\n154\t// PDA watcher — WebSocket-based instant join detection\n155\tconst pdaWatcher = createPdaWatcher({\n156\t  connection,\n157\t  serverKey: config.serverKeypair.publicKey,\n158\t  db,\n159\t  onJoinDetected: async (pda, targetSlot) => {\n160\t    // Update DB phase if still in 'created'\n161\t    const round = await db.getRoundByPda(pda);\n162\t    if (round && round.phase === \"created\") {\n163\t      await db.updateRoundPhase(pda, \"locked\", {\n164\t        target_slot: targetSlot.toString(),\n165\t      });\n166\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n167\t        targetSlot: targetSlot.toString(),\n168\t        source: \"pda-watcher\",\n169\t        game: round.game,\n170\t      });\n171\t    }\n172\t\n173\t    // Check if target slot already passed — settle immediately if so\n174\t    const currentSlot = await connection.getSlot();\n175\t    if (BigInt(currentSlot) >= targetSlot) {\n176\t      await retrySettler.attemptSettle(pda);\n177\t      pdaWatcher.unwatch(pda);\n178\t    }\n179\t    // If target slot not reached yet, poll worker will pick it up next cycle\n180\t  },\n181\t});\n182\t\n183\tconst worker = createSettlementWorker({\n184\t  db,\n185\t  connection,\n186\t  serverKey: config.serverKeypair.publicKey,\n187\t  pollIntervalMs: config.workerPollIntervalMs,\n188\t  onSettleReady: async (pda) => {\n189\t    await retrySettler.attemptSettle(pda);\n190\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n191\t  },\n192\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n193\t});\n194\tworker.start();\n195\t\n196\t// Close Call clock worker — fetches boundary prices + settles open rounds\n197\t// Rounds are created on-demand by players via /closecall/bet\n198\tconst closeCallClock = createCloseCallClockWorker({\n199\t  connection,\n200\t  serverKeypair: config.serverKeypair,\n201\t  db,\n202\t});\n203\tcloseCallClock.start();\n204\t\n205\t// Register event handlers before starting the worker\n206\tregisterHandler(\n207\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n208\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n209\t);\n210\t\n211\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n212\tconst eventWorker = createEventWorker(sql, {\n213\t  pollIntervalMs: config.eventQueuePollMs,\n214\t});\n215\teventWorker.start();\n216\tlogger.info(\"Event queue worker started\", {\n217\t  pollIntervalMs: config.eventQueuePollMs,\n218\t});\n219\t\n220\t// Game-specific routes\n221\tapp.route(\n222\t  \"/coinflip\",\n223\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n224\t);\n225\tapp.route(\n226\t  \"/lord\",\n227\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n228\t);\n229\t\n230\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n231\tapp.use(\n232\t  \"/closecall/bet\",\n233\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n234\t);\n235\tapp.use(\n236\t  \"/closecall/bet\",\n237\t  createRateLimitMiddleware({\n238\t    perWallet: config.rateLimitPerWallet,\n239\t    global: config.rateLimitGlobal,\n240\t    windowMs: 60_000,\n241\t  }),\n242\t);\n243\t\n244\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n245\tapp.route(\"/closecall\", createCloseCallRoutes({\n246\t  db,\n247\t  connection,\n248\t  serverKeypair: config.serverKeypair,\n249\t  clockWorker: closeCallClock,"}]},"parent_tool_use_id":"toolu_01QAPPUhUjLzckYrk1KWaFEw","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"6f4bc44e-8f7b-4693-990f-1b4749eb3355","timestamp":"2026-04-03T18:48:40.927Z"}
