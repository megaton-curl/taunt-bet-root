{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bix6JJrqTot5nRjGerthF8","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n31\t\n32\t// ---------------------------------------------------------------------------\n33\t// Constants\n34\t// ---------------------------------------------------------------------------\n35\t\n36\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n37\t\n38\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n39\tfunction makeSql() {\n40\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n41\t  // Dev container: postgres listens on Unix socket only\n42\t  return postgres({\n43\t    host: \"/var/run/postgresql\",\n44\t    user: \"vscode\",\n45\t    database: \"rng_utopia_dev\",\n46\t  });\n47\t}\n48\t\n49\tconst AMOUNT_LAMPORTS = 5_000_000;\n50\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n51\tconst SIDE_HEADS = 0;\n52\tconst PHASE_LOCKED = 1;\n53\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n54\t\n55\t// ---------------------------------------------------------------------------\n56\t// JWT helper\n57\t// ---------------------------------------------------------------------------\n58\t\n59\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n60\t  const now = Math.floor(Date.now() / 1000);\n61\t  return new SignJWT({ wallet })\n62\t    .setProtectedHeader({ alg: \"HS256\" })\n63\t    .setSubject(userId)\n64\t    .setIssuedAt(now)\n65\t    .setExpirationTime(now + 3600)\n66\t    .sign(JWT_SECRET);\n67\t}\n68\t\n69\tfunction userIdFromWallet(wallet: string) {\n70\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n71\t}\n72\t\n73\t// ---------------------------------------------------------------------------\n74\t// Mock Connection\n75\t// ---------------------------------------------------------------------------\n76\t\n77\t/**\n78\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n79\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n80\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance."}]},"parent_tool_use_id":null,"session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"956fcee5-bf29-44d2-89ce-16ac791d5045","timestamp":"2026-04-03T18:52:12.772Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"/**\n * Integration test: full create → join → settle lifecycle.\n *\n * Uses a mock Solana Connection to simulate on-chain state while exercising\n * the real HTTP endpoints, database, settlement worker, and retry logic\n * end-to-end. Auth uses JWT Bearer tokens (HS256).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"rng_utopia_dev\",\n  });\n}\n\nconst AMOUNT_LAMPORTS = 5_000_000;\nconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\nconst SIDE_HEADS = 0;\nconst PHASE_LOCKED = 1;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n\n// ---------------------------------------------------------------------------\n// JWT helper\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n// ---------------------------------------------------------------------------\n// Mock Connection\n// ---------------------------------------------------------------------------\n\n/**\n * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.","numLines":80,"startLine":1,"totalLines":939}}}
