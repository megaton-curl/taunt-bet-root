{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0163zNvepx46mJR5Qr9xzPxY","type":"tool_result","content":"1\t-- 010_referral.sql — Referral system (codes, links, earnings, claims, KOL rates).\n2\t\n3\tCREATE TABLE referral_codes (\n4\t  id          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n5\t  user_id     TEXT         NOT NULL UNIQUE,\n6\t  wallet      TEXT         NOT NULL UNIQUE,\n7\t  code        TEXT         NOT NULL UNIQUE,\n8\t  created_at  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n9\t  updated_at  TIMESTAMPTZ  NOT NULL DEFAULT now()\n10\t);\n11\t\n12\tCREATE TABLE referral_links (\n13\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n14\t  referrer_user_id TEXT        NOT NULL,\n15\t  referee_user_id  TEXT        NOT NULL UNIQUE,\n16\t  referrer_wallet  TEXT        NOT NULL,\n17\t  referee_wallet   TEXT        NOT NULL,\n18\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n19\t);\n20\t\n21\tCREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id);\n22\t\n23\tCREATE TABLE referral_earnings (\n24\t  id                        BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n25\t  referrer_user_id          TEXT         NOT NULL,\n26\t  referee_user_id           TEXT         NOT NULL,\n27\t  referrer_wallet           TEXT         NOT NULL,\n28\t  referee_wallet            TEXT         NOT NULL,\n29\t  round_id                  TEXT         NOT NULL,\n30\t  game_type                 TEXT         NOT NULL,\n31\t  wager_lamports            BIGINT       NOT NULL,\n32\t  fee_lamports              BIGINT       NOT NULL,\n33\t  referrer_earned_lamports  BIGINT       NOT NULL,\n34\t  referrer_rate_bps         INTEGER      NOT NULL,\n35\t  referee_rebate_lamports   BIGINT       NOT NULL,\n36\t  referee_rebate_rate_bps   INTEGER      NOT NULL,\n37\t  created_at                TIMESTAMPTZ  NOT NULL DEFAULT now(),\n38\t\n39\t  CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n40\t);\n41\t\n42\tCREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at);\n43\tCREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at);\n44\tCREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id);\n45\t\n46\tCREATE TABLE referral_claims (\n47\t  id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),\n48\t  user_id         TEXT         NOT NULL,\n49\t  wallet          TEXT         NOT NULL,\n50\t  amount_lamports BIGINT       NOT NULL,\n51\t  status          TEXT         NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n52\t  retry_count     INTEGER      NOT NULL DEFAULT 0,\n53\t  tx_signature    TEXT,\n54\t  error           TEXT,\n55\t  requested_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n56\t  processed_at    TIMESTAMPTZ\n57\t);\n58\t\n59\tCREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at);\n60\tCREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing');\n61\tCREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error');\n62\t\n63\tCREATE TABLE referral_kol_rates (\n64\t  user_id     TEXT         PRIMARY KEY,\n65\t  wallet      TEXT         NOT NULL UNIQUE,\n66\t  rate_bps    INTEGER      NOT NULL,\n67\t  set_by      TEXT         NOT NULL,\n68\t  created_at  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n69\t  updated_at  TIMESTAMPTZ  NOT NULL DEFAULT now()\n70\t);\n71\t"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"828d2341-2639-4df3-977e-2721bf6afcde","timestamp":"2026-04-03T18:49:17.552Z"}
