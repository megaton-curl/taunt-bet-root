{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XqksVFLceCsZ5mA5pQRqVv","type":"tool_result","content":"150\t        link.referrer_user_id,\n151\t        referralDefaultRateBps,\n152\t      );\n153\t\n154\t      const feeLamports = Math.floor((wagerLamports * feeBps) / 10_000);\n155\t      const referrerEarnedLamports = Math.floor(\n156\t        (feeLamports * referrerRateBps) / 10_000,\n157\t      );\n158\t      const refereeRebateLamports = Math.floor((feeLamports * 1000) / 10_000);\n159\t\n160\t      await db.insertReferralEarning({\n161\t        referrerUserId: link.referrer_user_id,\n162\t        refereeUserId: refereeProfile.user_id,\n163\t        referrerWallet,\n164\t        refereeWallet: wallet,\n165\t        roundId,\n166\t        gameType,\n167\t        wagerLamports,\n168\t        feeLamports,\n169\t        referrerEarnedLamports,\n170\t        referrerRateBps,\n171\t        refereeRebateLamports,\n172\t        refereeRebateRateBps: 1000, // fixed 10% for v1\n173\t      });\n174\t\n175\t      logger.info(\"referral earning recorded\", {\n176\t        roundId,\n177\t        gameType,\n178\t        referrerUserId: link.referrer_user_id,\n179\t        refereeUserId: refereeProfile.user_id,\n180\t        referrerEarnedLamports,\n181\t        refereeRebateLamports,\n182\t      });\n183\t    } catch (err: unknown) {\n184\t      const msg = err instanceof Error ? err.message : String(err);\n185\t      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n186\t        logger.info(\"referral earning already recorded (idempotent skip)\", {\n187\t          roundId,\n188\t          wallet,\n189\t        });\n190\t      } else {\n191\t        logger.error(\"failed to record referral earning\", {\n192\t          roundId,\n193\t          wallet,\n194\t          error: msg,\n195\t        });\n196\t      }\n197\t    }\n198\t  }\n199\t}\n200\t\n201\t// ---------------------------------------------------------------------------\n202\t// Core settle function\n203\t// ---------------------------------------------------------------------------\n204\t\n205\t/**\n206\t * Build, submit, and confirm a settle transaction for a locked match.\n207\t *\n208\t * Steps:\n209\t * 1. Retrieve secret from DB\n210\t * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n211\t * 3. Fetch config account data (treasury)\n212\t * 4. Read entropy from the entropy account\n213\t * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n214\t * 6. Build + submit settle tx\n215\t * 7. Update DB on confirmation\n216\t */\n217\texport async function settleMatch(\n218\t  deps: SettleTxDeps,\n219\t  pda: string,\n220\t): Promise<SettleResult> {\n221\t  const t0 = performance.now();\n222\t  const { db, connection, serverKeypair, entropyAccount } = deps;\n223\t  const matchPubkey = new PublicKey(pda);\n224\t\n225\t  // 1. Retrieve secret from DB\n226\t  const round = await db.getRoundByPda(pda);\n227\t  const tDb = performance.now();\n228\t  if (!round) {\n229\t    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n230\t  }\n231\t  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n232\t    throw new PermanentSettleError(\n233\t      `Round ${pda} in unexpected phase: ${round.phase}`,\n234\t    );\n235\t  }\n236\t\n237\t  const secret = Buffer.from(round.secret);\n238\t\n239\t  // Transition to settling (locked → settling)\n240\t  if (round.phase === \"locked\") {\n241\t    await db.updateRoundPhase(pda, \"settling\");\n242\t  }\n243\t\n244\t  // Log settle_submitted\n245\t  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n246\t    attempt: round.settle_attempts + 1,\n247\t  });\n248\t\n249\t  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n250\t  const [platformConfigPda] = derivePlatformConfigPda();\n251\t  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n252\t    await Promise.all([\n253\t      connection.getAccountInfo(matchPubkey),\n254\t      getPlatformConfig(connection),\n255\t      connection.getAccountInfo(entropyAccount),\n256\t      connection.getLatestBlockhash(),\n257\t    ]);\n258\t  const tFetch = performance.now();\n259\t\n260\t  if (!matchAccountInfo) {\n261\t    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n262\t  }\n263\t  if (!entropyInfo) {\n264\t    throw new TransientSettleError(\"Entropy account not available yet\");\n265\t  }\n266\t\n267\t  // IDL-driven decode — no manual byte offsets\n268\t  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n269\t  const { feeBps, treasury } = platformConfig;\n270\t\n271\t  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n272\t\n273\t  const pool = entryAmount * 2n;\n274\t  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n275\t  const payoutAmount = Number(pool) - feeAmount;\n276\t\n277\t  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n278\t\n279\t  // 5. Pre-compute result\n280\t  const matchPdaBytes = matchPubkey.toBuffer();\n281\t  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n282\t  const resultSide = resultHash[0]! % 2;\n283\t  const winner = resultSide === creatorSide ? creator : opponent;\n284\t\n285\t  // 6. Build settle instruction (8 accounts, no profile CPI)\n286\t  const data = encodeSettleData(secret);\n287\t\n288\t  const instruction = new TransactionInstruction({\n289\t    keys: [\n290\t      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n291\t      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n292\t      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n293\t      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n294\t      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n295\t      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n296\t      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n297\t      {\n298\t        pubkey: SystemProgram.programId,\n299\t        isSigner: false,"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"6fa2a46a-9d93-49a6-86ee-c3dbe9047b51","timestamp":"2026-04-03T18:48:58.026Z"}
