{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01HFvvmZNZGC5NTwNYZhbghn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TJB4EzbXeQRvjSTUiLMG33","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/services/backend/src/worker/settle-tx.ts","old_string":"import type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";","new_string":"import type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1197,"cache_read_input_tokens":74151,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1197},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"9a1d4f16-ade5-4b55-a583-4ce3df57fe68"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TJB4EzbXeQRvjSTUiLMG33","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/worker/settle-tx.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"9afbcc36-5619-41b5-9e64-6c3070277165","timestamp":"2026-04-03T18:51:31.662Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/worker/settle-tx.ts","oldString":"import type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";","newString":"import type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";","originalFile":"/**\n * Settle transaction builder + submission.\n *\n * Retrieves the stored secret, reads on-chain match + config data to resolve\n * all accounts, builds the `settle` instruction, submits it, and updates the\n * DB on confirmation.\n */\n\nimport { createHash } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\nimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@taunt-bet/anchor-client\";\nimport {\n  decodeCoinflipMatch,\n  decodeLordRound,\n  type DecodedJackpotRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Instruction discriminators (from IDL — no hardcoded byte arrays)\n// ---------------------------------------------------------------------------\n\nfunction getInstructionDiscriminator(\n  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n  instructionName: string,\n): Buffer {\n  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n  if (!instruction) {\n    throw new Error(`Instruction ${instructionName} not found in IDL`);\n  }\n  return Buffer.from(instruction.discriminator);\n}\n\nconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\nconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n  lordIdl,\n  \"claim_payout\",\n);\nconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\nconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\nconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface SettleTxDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  entropyAccount: PublicKey;\n  referralDefaultRateBps: number;\n}\n\nexport interface SettleResult {\n  txSignature: string;\n  resultHash: Buffer;\n  resultSide?: number;\n  winningEntryIndex?: number;\n  winner: string;\n}\n\n// ---------------------------------------------------------------------------\n// Instruction encoding\n// ---------------------------------------------------------------------------\n\n/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\nfunction encodeSettleData(secret: Buffer): Buffer {\n  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n}\n\nfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n}\n\n// ---------------------------------------------------------------------------\n// Result derivation (mirrors on-chain derive_result)\n// ---------------------------------------------------------------------------\n\n/**\n * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n * Must match shared/src/fairness.rs `derive_result()`.\n */\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")\n    .update(secret)\n    .update(entropy)\n    .update(matchPdaBytes)\n    .update(Buffer.from([algoVer]))\n    .digest();\n}\n\n// ---------------------------------------------------------------------------\n// Referral earnings hook\n// ---------------------------------------------------------------------------\n\n/**\n * After a game settles, check each player for a referrer and record\n * referral earnings if applicable.\n *\n * For each unique player: look up referral link → if referrer exists,\n * calculate referrer earning + referee rebate → insert into referral_earnings.\n *\n * Errors are logged but never bubble — referral recording must not fail settlement.\n * The UNIQUE(referee_user_id, round_id) constraint provides idempotency on retries.\n */\nasync function recordReferralEarnings(\n  db: Db,\n  params: {\n    roundId: string;\n    gameType: string;\n    feeBps: number;\n    referralDefaultRateBps: number;\n    players: Array<{ wallet: string; wagerLamports: number }>;\n  },\n): Promise<void> {\n  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n\n  // Deduplicate players (Lord of RNGs can have multiple entries per player)\n  const playerWagers = new Map<string, number>();\n  for (const p of players) {\n    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n  }\n\n  for (const [wallet, wagerLamports] of playerWagers) {\n    try {\n      const refereeProfile = await db.getProfileByWallet(wallet);\n      if (!refereeProfile) continue; // no profile = no referral link possible\n      const link = await db.getReferralLinkByRefereeUserId(refereeProfile.user_id);\n      if (!link) continue;\n\n      const referrerWallet = link.referrer_wallet;\n      const referrerRateBps = await db.getReferrerRate(\n        link.referrer_user_id,\n        referralDefaultRateBps,\n      );\n\n      const feeLamports = Math.floor((wagerLamports * feeBps) / 10_000);\n      const referrerEarnedLamports = Math.floor(\n        (feeLamports * referrerRateBps) / 10_000,\n      );\n      const refereeRebateLamports = Math.floor((feeLamports * 1000) / 10_000);\n\n      await db.insertReferralEarning({\n        referrerUserId: link.referrer_user_id,\n        refereeUserId: refereeProfile.user_id,\n        referrerWallet,\n        refereeWallet: wallet,\n        roundId,\n        gameType,\n        wagerLamports,\n        feeLamports,\n        referrerEarnedLamports,\n        referrerRateBps,\n        refereeRebateLamports,\n        refereeRebateRateBps: 1000, // fixed 10% for v1\n      });\n\n      logger.info(\"referral earning recorded\", {\n        roundId,\n        gameType,\n        referrerUserId: link.referrer_user_id,\n        refereeUserId: refereeProfile.user_id,\n        referrerEarnedLamports,\n        refereeRebateLamports,\n      });\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n        logger.info(\"referral earning already recorded (idempotent skip)\", {\n          roundId,\n          wallet,\n        });\n      } else {\n        logger.error(\"failed to record referral earning\", {\n          roundId,\n          wallet,\n          error: msg,\n        });\n      }\n    }\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on confirmation\n */\nexport async function settleMatch(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const matchPubkey = new PublicKey(pda);\n\n  // 1. Retrieve secret from DB\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  // Transition to settling (locked → settling)\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  // Log settle_submitted\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n  });\n\n  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n  const [platformConfigPda] = derivePlatformConfigPda();\n  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(matchPubkey),\n      getPlatformConfig(connection),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n  const tFetch = performance.now();\n\n  if (!matchAccountInfo) {\n    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets\n  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n  const { feeBps, treasury } = platformConfig;\n\n  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n\n  const pool = entryAmount * 2n;\n  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n  const payoutAmount = Number(pool) - feeAmount;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n\n  // 5. Pre-compute result\n  const matchPdaBytes = matchPubkey.toBuffer();\n  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n  const resultSide = resultHash[0]! % 2;\n  const winner = resultSide === creatorSide ? creator : opponent;\n\n  // 6. Build settle instruction (8 accounts, no profile CPI)\n  const data = encodeSettleData(secret);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      }, // system_program\n    ],\n    programId: COINFLIP_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  // 7. Submit and confirm\n  const rawTx = tx.serialize();\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(rawTx, {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  // 8. Update DB — phase settling → settled (atomic transaction)\n  const coinflipEntries = [\n    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n  ];\n\n  await db.withTransaction(async (txDb) => {\n    await txDb.updateRoundPhase(pda, \"settled\", {\n      settle_tx: txSignature,\n      result_hash: resultHash,\n      result_side: resultSide,\n      winner: winner.toBase58(),\n      settle_attempts: round.settle_attempts + 1,\n    });\n\n    // Game entries for leaderboard/stats — UPSERT updates existing (creator) and inserts new (joiner)\n    const loser = winner.equals(creator) ? opponent : creator;\n    const [winnerProfile, loserProfile] = await Promise.all([\n      txDb.getProfileByWallet(winner.toBase58()),\n      txDb.getProfileByWallet(loser.toBase58()),\n    ]);\n    if (!winnerProfile || !loserProfile) {\n      logger.warn(\"coinflip settle: missing profile for participant — skipping game entries\", {\n        pda,\n        winnerWallet: winner.toBase58(),\n        loserWallet: loser.toBase58(),\n        winnerProfileExists: !!winnerProfile,\n        loserProfileExists: !!loserProfile,\n      });\n    } else {\n      await txDb.upsertGameEntries([\n        {\n          userId: winnerProfile.user_id,\n          wallet: winner.toBase58(),\n          game: \"coinflip\",\n          roundPda: pda,\n          matchId: round.match_id,\n          amountLamports: Number(entryAmount),\n          isWinner: true,\n          payoutLamports: payoutAmount,\n          settledAt: new Date(),\n        },\n        {\n          userId: loserProfile.user_id,\n          wallet: loser.toBase58(),\n          game: \"coinflip\",\n          roundPda: pda,\n          matchId: round.match_id,\n          amountLamports: Number(entryAmount),\n          isWinner: false,\n          payoutLamports: 0,\n          settledAt: new Date(),\n        },\n      ]);\n    }\n\n    // Log settle_confirmed\n    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n      txSignature,\n      resultSide,\n      winner: winner.toBase58(),\n      entropy: entropy.toString(\"hex\"),\n      payoutAmount,\n      feeAmount,\n      entries: coinflipEntries,\n    });\n\n    // Write payout transaction for the winner\n    await txDb.insertTransaction({\n      userId: winnerProfile?.user_id,\n      wallet: winner.toBase58(),\n      game: \"coinflip\",\n      matchId: round.match_id,\n      txType: \"payout\",\n      amountLamports: payoutAmount,\n      txSig: txSignature,\n    });\n\n    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n    await recordReferralEarnings(txDb, {\n      roundId: round.match_id,\n      gameType: \"coinflip\",\n      feeBps,\n      referralDefaultRateBps: deps.referralDefaultRateBps,\n      players: [\n        { wallet: creator.toBase58(), wagerLamports: Number(entryAmount) },\n        { wallet: opponent.toBase58(), wagerLamports: Number(entryAmount) },\n      ],\n    });\n  });\n\n  const tDone = performance.now();\n  logger.info(\"settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    resultSide,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleLordRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const roundPubkey = new PublicKey(pda);\n\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n    game: \"lord\",\n  });\n\n  const [platformConfigPda] = derivePlatformConfigPda();\n  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(roundPubkey),\n      getPlatformConfig(connection),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n\n  const tFetch = performance.now();\n\n  if (!roundAccountInfo) {\n    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets or parseLordRound()\n  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n  const { feeBps, treasury } = platformConfig;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n  const resultHash = deriveResult(\n    secret,\n    entropy,\n    roundPubkey.toBuffer(),\n    roundData.algorithmVer,\n  );\n  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n\n  const raw = resultHash.readBigUInt64LE(0);\n  const winningOffset = raw % roundData.totalAmountLamports;\n\n  let cumulative = 0n;\n  let winnerEntryIndex = -1;\n  let winner = roundData.entries[0]?.player;\n  for (const [index, entry] of roundData.entries.entries()) {\n    cumulative += entry.amountLamports;\n    if (winningOffset < cumulative) {\n      winnerEntryIndex = index;\n      winner = entry.player;\n      break;\n    }\n  }\n\n  if (!winner || winnerEntryIndex < 0) {\n    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n  }\n\n  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: winner, isSigner: false, isWritable: true },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: LORDOFRNGS_PROGRAM_ID,\n    data: encodeClaimPayoutData(matchIdBuf, secret),\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"lord settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    winningEntryIndex: winnerEntryIndex,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  const serializedEntries = roundData.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  await db.withTransaction(async (txDb) => {\n    await txDb.updateRoundPhase(pda, \"settled\", {\n      settle_tx: txSignature,\n      result_hash: resultHash,\n      result_side: winnerEntryIndex,\n      winner: winner.toBase58(),\n      settle_attempts: round.settle_attempts + 1,\n    });\n\n    // Game entries — aggregate per player, resolve profiles for user_id\n    const playerTotals = new Map<string, number>();\n    for (const e of serializedEntries) {\n      playerTotals.set(e.player, (playerTotals.get(e.player) ?? 0) + e.amountLamports)