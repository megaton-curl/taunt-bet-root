ds Error {\n  readonly permanent = true;\n  constructor(message: string) {\n    super(message);\n    this.name = \"PermanentSettleError\";\n  }\n}\n\n/** Transient failure — safe to retry. */\nexport class TransientSettleError extends Error {\n  readonly permanent = false;\n  constructor(message: string) {\n    super(message);\n    this.name = \"TransientSettleError\";\n  }\n}\n","structuredPatch":[{"oldStart":18,"oldLines":6,"newStart":18,"newLines":8,"lines":[" } from \"@solana/web3.js\";"," import type { Db } from \"../db.js\";"," import { logger } from \"../logger.js\";","+import { emitEvent } from \"../queue/emit-event.js\";","+import { EventTypes } from \"../queue/event-types.js\";"," import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";"," import { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";"," import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@taunt-bet/anchor-client\";"]}],"userModified":false,"replaceAll":false}}
