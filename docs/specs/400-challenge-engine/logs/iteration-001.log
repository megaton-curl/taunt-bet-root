{ createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n32\timport { logger } from \"./logger.js\";\n33\t\n34\tconst config = loadConfig();\n35\t\n36\t// Single postgres pool shared by game DB, auth DB, and all workers\n37\tconst sql = postgres(config.databaseUrl);\n38\tconst db = createDb(config.databaseUrl, sql);\n39\tconst authDb = createAuthDb(sql);\n40\t\n41\tconst connection = new Connection(config.rpcUrl, {\n42\t  commitment: \"confirmed\",\n43\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n44\t});\n45\t\n46\tconst app = new Hono();\n47\t\n48\tapp.use(\n49\t  \"*\",\n50\t  cors({\n51\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n52\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n53\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n54\t  }),\n55\t);\n56\t\n57\t// Request logging — correlate frontend fetch timing with server-side processing\n58\tapp.use(\"*\", async (c, next) => {\n59\t  const start = Date.now();\n60\t  await next();\n61\t  const ms = Date.now() - start;\n62\t  const method = c.req.method;\n63\t  const path = c.req.path;\n64\t  // Skip noisy health checks and OPTIONS preflight\n65\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n66\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n67\t});\n68\t\n69\t// API docs — Swagger UI + raw OpenAPI spec\n70\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n71\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n72\t\n73\t// Auth routes — no JWT middleware (these are the login endpoints)\n74\t// Lighter rate limiting by IP for auth endpoints\n75\tapp.use(\n76\t  \"/auth/*\",\n77\t  createRateLimitMiddleware({\n78\t    perWallet: 20,\n79\t    global: config.rateLimitGlobal,\n80\t    windowMs: 60_000,\n81\t  }),\n82\t);\n83\t\n84\tapp.route(\n85\t  \"/auth\",\n86\t  createAuthRoutes({\n87\t    authDb,\n88\t    db,\n89\t    jwtSecret: config.jwtSecret,\n90\t    cluster: config.cluster,\n91\t    challengeTtlSeconds: config.challengeTtlSeconds,\n92\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n93\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n94\t  }),\n95\t);\n96\t\n97\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n98\tapp.use(\n99\t  \"/profile/*\",\n100\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n101\t);\n102\tapp.route(\"/profile\", createProfileRoutes({ db }));\n103\t\n104\t// Public profile routes — no auth required\n105\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n106\t\n107\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n108\tapp.use(\n109\t  \"/referral/*\",\n110\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n111\t);\n112\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n113\t\n114\t// JWT auth middleware for game endpoints\n115\tapp.use(\n116\t  \"/coinflip/*\",\n117\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n118\t);\n119\tapp.use(\n120\t  \"/lord/*\",\n121\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n122\t);\n123\t\n124\t// Rate limiting — per-wallet and global limits on POST requests\n125\tapp.use(\n126\t  \"/coinflip/*\",\n127\t  createRateLimitMiddleware({\n128\t    perWallet: config.rateLimitPerWallet,\n129\t    global: config.rateLimitGlobal,\n130\t    windowMs: 60_000,\n131\t  }),\n132\t);\n133\tapp.use(\n134\t  \"/lord/*\",\n135\t  createRateLimitMiddleware({\n136\t    perWallet: config.rateLimitPerWallet,\n137\t    global: config.rateLimitGlobal,\n138\t    windowMs: 60_000,\n139\t  }),\n140\t);\n141\t\n142\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n143\tconst entropyAccount = new PublicKey(config.entropyAccount);\n144\tconst retrySettler = createRetrySettler({\n145\t  db,\n146\t  connection,\n147\t  settleRound: (pda) =>\n148\t    settleRound(\n149\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n150\t      pda,"}]},"parent_tool_use_id":"toolu_01QAPPUhUjLzckYrk1KWaFEw","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"251c0108-ad6e-4b7d-8f73-b754693286c6","timestamp":"2026-04-03T18:48:39.052Z"}
