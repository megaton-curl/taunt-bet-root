{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EiENad6oDwh77HtdueUD88","type":"tool_result","content":"1\t/**\n2\t * Known event type constants for the async event queue.\n3\t *\n4\t * Using a const object + derived union makes typos a compile error\n5\t * instead of a dead event at runtime.\n6\t */\n7\t\n8\texport const EventTypes = {\n9\t  REFERRAL_CODE_APPLIED: \"referral.code_applied\",\n10\t  REFERRAL_GAME_SETTLED: \"referral.game_settled\",\n11\t  REFERRAL_CLAIM_REQUESTED: \"referral.claim_requested\",\n12\t} as const;\n13\t\n14\texport type EventType = (typeof EventTypes)[keyof typeof EventTypes];\n15\t"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"41bacda1-69f3-4537-b750-a8060b4f9cb8","timestamp":"2026-04-03T18:48:42.489Z"}
