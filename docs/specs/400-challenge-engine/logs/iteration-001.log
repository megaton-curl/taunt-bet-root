{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FhuyzeLmtHvEC6fDzzxxcL","type":"tool_result","content":"550\t  /**\n551\t   * Get a player profile by public identifier.\n552\t   * If identifier starts with `usr_`, looks up by `user_id`.\n553\t   * Otherwise looks up by username (case-insensitive).\n554\t   */\n555\t  getProfileByIdentifier(identifier: string): Promise<PlayerProfile | null>;\n556\t\n557\t  /**\n558\t   * Update a player's username. Validates 30-day cooldown (first edit is free).\n559\t   * Throws on cooldown violation or UNIQUE conflict.\n560\t   */\n561\t  updateUsername(wallet: string, newUsername: string): Promise<PlayerProfile>;\n562\t\n563\t  /** Update a player's username by canonical user_id. */\n564\t  updateUsernameByUserId(userId: string, newUsername: string): Promise<PlayerProfile>;\n565\t\n566\t  /**\n567\t   * Compute aggregate stats from the transactions table for a wallet.\n568\t   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n569\t   */\n570\t  getPlayerStats(wallet: string): Promise<PlayerStats>;\n571\t\n572\t  /** Compute aggregate stats from game_entries for a canonical user_id. */\n573\t  getPlayerStatsByUserId(userId: string): Promise<PlayerStats>;\n574\t\n575\t  /**\n576\t   * Get public-safe subset of player stats (no wagered, no PnL).\n577\t   */\n578\t  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n579\t\n580\t  /** Get public-safe subset of player stats by canonical user_id. */\n581\t  getPublicPlayerStatsByUserId(userId: string): Promise<PublicPlayerStats>;\n582\t\n583\t  /**\n584\t   * Compute per-game aggregate stats from the transactions table.\n585\t   * Returns a record keyed by frontend game name (coinflip, lord-of-rngs, close-call).\n586\t   * Games with zero activity are omitted.\n587\t   */\n588\t  getGameBreakdown(wallet: string): Promise<Record<string, GameBreakdownStats>>;\n589\t\n590\t  /** Compute per-game aggregate stats for a canonical user_id. */\n591\t  getGameBreakdownByUserId(userId: string): Promise<Record<string, GameBreakdownStats>>;\n592\t\n593\t  /**\n594\t   * Compute win streaks from the transactions table.\n595\t   * Returns current (consecutive wins from most recent) and best (longest ever).\n596\t   * Refund-only matches are excluded from streak calculation.\n597\t   */\n598\t  getWinStreaks(wallet: string): Promise<WinStreaks>;\n599\t\n600\t  /** Compute win streaks for a canonical user_id. */\n601\t  getWinStreaksByUserId(userId: string): Promise<WinStreaks>;\n602\t\n603\t  // -------------------------------------------------------------------------\n604\t  // Game entries\n605\t  // -------------------------------------------------------------------------\n606\t\n607\t  /**\n608\t   * Upsert a single game entry. Inserts at participation time; updates at settlement.\n609\t   * ON CONFLICT (wallet, round_pda) DO UPDATE for settlement UPSERT pattern.\n610\t   */\n611\t  upsertGameEntry(entry: GameEntryUpsert): Promise<void>;\n612\t\n613\t  /**\n614\t   * Batch-upsert game entries. Used at settlement to update existing entries\n615\t   * and insert new ones (joiners) in one pass.\n616\t   */\n617\t  upsertGameEntries(entries: GameEntryUpsert[]): Promise<void>;\n618\t\n619\t  /**\n620\t   * Get all game entries for a round. Used by settlement to read participant list.\n621\t   */\n622\t  getEntriesByRound(roundPda: string): Promise<GameEntry[]>;\n623\t\n624\t  /**\n625\t   * @deprecated Use upsertGameEntries instead.\n626\t   */\n627\t  insertGameEntries(entries: GameEntryInsert[]): Promise<void>;\n628\t\n629\t  // -------------------------------------------------------------------------\n630\t  // Close Call candles\n631\t  // -------------------------------------------------------------------------\n632\t\n633\t  /** Insert a Close Call candle price. ON CONFLICT DO NOTHING. */\n634\t  insertCloseCallCandle(\n635\t    minuteTs: number,\n636\t    price: bigint,\n637\t    expo: number,\n638\t    priceHuman: number,\n639\t    hermesVaa: string | null,\n640\t  ): Promise<void>;\n641\t\n642\t  /** Get the most recent Close Call candle. */\n643\t  getLatestCloseCallCandle(): Promise<CloseCallCandle | null>;\n644\t\n645\t  /** Get recent Close Call candles, ordered by minute_ts DESC. */\n646\t  getCloseCallCandles(limit: number): Promise<CloseCallCandle[]>;\n647\t\n648\t  // -------------------------------------------------------------------------\n649\t  // Profile helpers"}]},"parent_tool_use_id":"toolu_016scoUcPM5KH77BcCREy8fE","session_id":"ee923df0-ca95-4460-8036-5b0289591b86","uuid":"cb54dc9c-48a2-4d79-ba78-84db083bdc87","timestamp":"2026-04-03T18:49:09.790Z"}
