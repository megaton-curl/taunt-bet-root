{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LW5Zpku6JQWMMPSF8njw7x","type":"tool_result","content":"1\t/**\n2\t * JWT Bearer token authentication middleware.\n3\t *\n4\t * Verifies HS256 JWT access tokens on POST requests.\n5\t * Sets c.set(\"userId\", payload.sub) for downstream handlers.\n6\t * Wallet is NOT in the JWT — routes that need wallet resolve it from the profile.\n7\t * GET requests pass through without authentication.\n8\t */\n9\t\n10\timport { createMiddleware } from \"hono/factory\";\n11\timport { jwtVerify } from \"jose\";\n12\timport { logger } from \"../logger.js\";\n13\timport type { AppEnv } from \"../hono-env.js\";\n14\t\n15\texport interface JwtAuthConfig {\n16\t  jwtSecret: Uint8Array;\n17\t  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n18\t  requireAllMethods?: boolean;\n19\t}\n20\t\n21\texport function createJwtAuthMiddleware(config: JwtAuthConfig) {\n22\t  return createMiddleware<AppEnv>(async (c, next) => {\n23\t    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n24\t    // unless requireAllMethods is set (e.g., profile endpoints)\n25\t    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n26\t      return next();\n27\t    }\n28\t\n29\t    const authHeader = c.req.header(\"Authorization\");\n30\t    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n31\t      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n32\t        path: c.req.path,\n33\t      });\n34\t      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n35\t    }\n36\t\n37\t    const token = authHeader.slice(7);\n38\t    try {\n39\t      const { payload } = await jwtVerify(token, config.jwtSecret, {\n40\t        algorithms: [\"HS256\"],\n41\t      });\n42\t\n43\t      if (typeof payload.sub !== \"string\") {\n44\t        logger.warn(\"jwt auth rejected: missing sub claim\", {\n45\t          path: c.req.path,\n46\t        });\n47\t        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n48\t      }\n49\t\n50\t      c.set(\"userId\", payload.sub);\n51\t      return next();\n52\t    } catch (err) {\n53\t      logger.warn(\"jwt auth rejected: token verification failed\", {\n54\t        path: c.req.path,\n55\t        error: err instanceof Error ? err.message : \"Unknown error\",\n56\t      });\n57\t      return c.json({ error: \"Invalid or expired token\" }, 401);\n58\t    }\n59\t  });\n60\t}\n61\t"}]},"parent_tool_use_id":"toolu_01C2Pn5rKeJTogFTCp3dWYsS","session_id":"2e700c10-4389-4a9a-beb2-50db732591da","uuid":"d44ec5ce-3562-403f-8051-91e594cd7891","timestamp":"2026-04-03T20:51:27.859Z"}
