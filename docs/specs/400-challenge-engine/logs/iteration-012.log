{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y6zdjZXfCnBtjFuQ32xU5U","type":"tool_result","content":"1\t/**\n2\t * Leaderboard routes — public weekly volume-based leaderboards.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport type { AppEnv } from \"../hono-env.js\";\n7\timport type { Db } from \"../db.js\";\n8\timport { logger } from \"../logger.js\";\n9\t\n10\t/** Map frontend/DB game names to canonical DB names */\n11\tconst TO_DB_GAME: Record<string, string> = {\n12\t  coinflip: \"coinflip\",\n13\t  lord: \"lord\",\n14\t  closecall: \"closecall\",\n15\t  \"lord-of-rngs\": \"lord\",\n16\t  \"close-call\": \"closecall\",\n17\t};\n18\t\n19\t/** Map DB game names to frontend game IDs */\n20\tconst GAME_TO_FRONTEND: Record<string, string> = {\n21\t  coinflip: \"coinflip\",\n22\t  lord: \"lord-of-rngs\",\n23\t  closecall: \"close-call\",\n24\t};\n25\t\n26\tconst VALID_GAMES = new Set(Object.keys(TO_DB_GAME));\n27\t\n28\texport interface LeaderboardRoutesDeps {\n29\t  db: Db;\n30\t}\n31\t\n32\texport function createLeaderboardRoutes(deps: LeaderboardRoutesDeps) {\n33\t  const { db } = deps;\n34\t  const app = new Hono<AppEnv>();\n35\t\n36\t  // GET /weekly — weekly leaderboard ranked by wagered volume\n37\t  // Query params: ?game=coinflip|lord-of-rngs|close-call&limit=20&offset=0\n38\t  app.get(\"/weekly\", async (c) => {\n39\t    const gameParam = c.req.query(\"game\") || undefined;\n40\t    const limitParam = c.req.query(\"limit\");\n41\t    const offsetParam = c.req.query(\"offset\");\n42\t\n43\t    // Validate game filter\n44\t    let dbGame: string | undefined;\n45\t    if (gameParam) {\n46\t      if (!VALID_GAMES.has(gameParam)) {\n47\t        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n48\t      }\n49\t      dbGame = TO_DB_GAME[gameParam];\n50\t    }\n51\t\n52\t    // Parse limit (default 20, max 100)\n53\t    let limit = 20;\n54\t    if (limitParam) {\n55\t      const parsed = parseInt(limitParam, 10);\n56\t      if (!isNaN(parsed) && parsed > 0) {\n57\t        limit = Math.min(parsed, 100);\n58\t      }\n59\t    }\n60\t\n61\t    // Parse offset (default 0)\n62\t    let offset = 0;\n63\t    if (offsetParam) {\n64\t      const parsed = parseInt(offsetParam, 10);\n65\t      if (!isNaN(parsed) && parsed >= 0) {\n66\t        offset = parsed;\n67\t      }\n68\t    }\n69\t\n70\t    try {\n71\t      const result = await db.getWeeklyLeaderboard(dbGame, limit, offset);\n72\t\n73\t      return c.json({\n74\t        game: gameParam ? (GAME_TO_FRONTEND[dbGame!] ?? gameParam) : \"all\",\n75\t        weekStart: result.weekStart,\n76\t        weekEnd: result.weekEnd,\n77\t        entries: result.entries.map((e) => ({\n78\t          rank: e.rank,\n79\t          userId: e.userId,\n80\t          username: e.username,\n81\t          avatarUrl: e.avatarUrl,\n82\t          totalWagered: String(e.totalWagered),\n83\t          gamesPlayed: e.gamesPlayed,\n84\t          totalWins: e.totalWins,\n85\t          winRate: e.winRate,\n86\t          netPnl: String(e.netPnl),\n87\t        })),\n88\t      });\n89\t    } catch (err) {\n90\t      logger.error(\"leaderboard/weekly failed\", {\n91\t        error: err instanceof Error ? err.message : \"Unknown error\",\n92\t      });\n93\t      return c.json({ error: \"Failed to fetch leaderboard\" }, 500);\n94\t    }\n95\t  });\n96\t\n97\t  return app;\n98\t}\n99\t"}]},"parent_tool_use_id":"toolu_01C2Pn5rKeJTogFTCp3dWYsS","session_id":"2e700c10-4389-4a9a-beb2-50db732591da","uuid":"e498ad8f-3468-4960-9d57-ed10ee12ded6","timestamp":"2026-04-03T20:51:42.330Z"}
