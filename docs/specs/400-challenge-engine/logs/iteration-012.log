{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012W4W35LAfLWPbVKJv4pVHc","type":"tool_result","content":"360\t  });\n361\t\n362\t  // GET /earnings — paginated per-game earnings log\n363\t  app.get(\"/earnings\", async (c) => {\n364\t    const userId = c.get(\"userId\");\n365\t    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n366\t\n367\t    const pageParam = c.req.query(\"page\");\n368\t    const limitParam = c.req.query(\"limit\");\n369\t    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n370\t    const limit = limitParam\n371\t      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n372\t      : 20;\n373\t\n374\t    if (Number.isNaN(page) || Number.isNaN(limit)) {\n375\t      return c.json(\n376\t        {\n377\t          error: {\n378\t            code: \"INVALID_PARAMS\",\n379\t            message: \"page and limit must be positive integers\",\n380\t          },\n381\t        },\n382\t        400,\n383\t      );\n384\t    }\n385\t\n386\t    try {\n387\t      const result = await db.getReferralEarningsByUserId(userId, page, limit);\n388\t      // Resolve usernames for referees (batch-dedup by userId)\n389\t      const uniqueRefereeIds = [...new Set(result.items.map((e) => e.referee_user_id))];\n390\t      const refereeProfiles = await Promise.all(\n391\t        uniqueRefereeIds.map((id) => db.getProfileByUserId(id)),\n392\t      );\n393\t      const usernameMap = new Map(\n394\t        uniqueRefereeIds.map((id, i) => [id, refereeProfiles[i]?.username ?? id]),\n395\t      );\n396\t      return c.json({\n397\t        items: result.items.map((e) => ({\n398\t          roundId: e.round_id,\n399\t          gameType: e.game_type,\n400\t          refereeUserId: e.referee_user_id,\n401\t          refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,\n402\t          wagerLamports: String(e.wager_lamports),\n403\t          earnedLamports: String(e.referrer_earned_lamports),\n404\t          createdAt: e.created_at.toISOString(),\n405\t        })),\n406\t        pagination: {\n407\t          page,\n408\t          totalPages: result.totalPages,\n409\t        },\n410\t      });\n411\t    } catch (err) {\n412\t      logger.error(\"Failed to fetch referral earnings\", {\n413\t        err: String(err),\n414\t        userId,\n415\t      });\n416\t      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n417\t    }\n418\t  });\n419\t"}]},"parent_tool_use_id":"toolu_01C2Pn5rKeJTogFTCp3dWYsS","session_id":"2e700c10-4389-4a9a-beb2-50db732591da","uuid":"331321f4-c94d-4b03-81a0-4f4421f6751d","timestamp":"2026-04-03T20:51:31.904Z"}
