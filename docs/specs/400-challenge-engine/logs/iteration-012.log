{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DYCbZobS1B2DzbKePHJcwg","type":"tool_result","content":"Found 21 files\nbackend/services/backend/src/__tests__/integration.test.ts\nbackend/services/backend/src/index.ts\nbackend/services/backend/src/routes/challenges.ts\nbackend/services/backend/src/worker/account-decoder.ts\nbackend/services/backend/src/worker/closecall-clock.ts\nbackend/services/backend/src/worker/settle-tx.ts\nbackend/services/backend/src/db.ts\nbackend/services/backend/src/__tests__/endpoints.test.ts\nbackend/services/backend/src/__tests__/referral-routes.test.ts\nbackend/services/backend/src/routes/referral.ts\nbackend/services/backend/src/openapi.ts\nbackend/services/backend/src/middleware/rate-limit.ts\nbackend/services/backend/src/routes/profile.ts\nbackend/services/backend/src/__tests__/leaderboard.test.ts\nbackend/services/backend/src/routes/leaderboard.ts\nbackend/services/backend/src/__tests__/profile.test.ts\nbackend/services/backend/src/routes/rounds.ts\nbackend/services/backend/src/routes/closecall.ts\nbackend/services/backend/src/__tests__/rate-limit.test.ts\nbackend/services/backend/src/platform-config.ts\nbackend/services/backend/src/tx-builder.ts"}]},"parent_tool_use_id":"toolu_01C2Pn5rKeJTogFTCp3dWYsS","session_id":"2e700c10-4389-4a9a-beb2-50db732591da","uuid":"577e6115-d71b-4b7d-8861-46d6caa965fb","timestamp":"2026-04-03T20:51:25.774Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J6qn7jAE15sfWYZNuivmg2","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createChallengeRoutes } from \"./routes/challenges.js\";\n21\timport { createInternalRoutes } from \"./routes/internal.js\";\n22\timport { swaggerUI } from \"@hono/swagger-ui\";\n23\timport { spec } from \"./openapi.js\";\n24\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n25\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n26\timport { createSettlementWorker } from \"./worker/settlement.js\";\n27\timport { settleRound } from \"./worker/settle-tx.js\";\n28\timport { createRetrySettler } from \"./worker/retry.js\";\n29\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n30\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n31\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n32\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n33\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n34\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n35\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n36\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n37\timport { fetchSolPrice } from \"./routes/price.js\";\n38\timport { logger } from \"./logger.js\";\n39\t\n40\tconst config = loadConfig();\n41\t\n42\t// Single postgres pool shared by game DB, auth DB, and all workers\n43\tconst sql = postgres(config.databaseUrl);\n44\tconst db = createDb(config.databaseUrl, sql);\n45\tconst authDb = createAuthDb(sql);\n46\t\n47\tconst connection = new Connection(config.rpcUrl, {\n48\t  commitment: \"confirmed\",\n49\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n50\t});\n51\t\n52\tconst app = new Hono();\n53\t\n54\tapp.use(\n55\t  \"*\",\n56\t  cors({\n57\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n58\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n59\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n60\t  }),\n61\t);\n62\t\n63\t// Request logging — correlate frontend fetch timing with server-side processing\n64\tapp.use(\"*\", async (c, next) => {\n65\t  const start = Date.now();\n66\t  await next();\n67\t  const ms = Date.now() - start;\n68\t  const method = c.req.method;\n69\t  const path = c.req.path;\n70\t  // Skip noisy health checks and OPTIONS preflight\n71\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n72\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n73\t});\n74\t\n75\t// API docs — Swagger UI + raw OpenAPI spec\n76\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n77\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n78\t\n79\t// Auth routes — no JWT middleware (these are the login endpoints)\n80\t// Lighter rate limiting by IP for auth endpoints\n81\tapp.use(\n82\t  \"/auth/*\",\n83\t  createRateLimitMiddleware({\n84\t    perWallet: 20,\n85\t    global: config.rateLimitGlobal,\n86\t    windowMs: 60_000,\n87\t  }),\n88\t);\n89\t\n90\tapp.route(\n91\t  \"/auth\",\n92\t  createAuthRoutes({\n93\t    authDb,\n94\t    db,\n95\t    jwtSecret: config.jwtSecret,\n96\t    cluster: config.cluster,\n97\t    challengeTtlSeconds: config.challengeTtlSeconds,\n98\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n99\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n100\t  }),\n101\t);\n102\t\n103\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n104\tapp.use(\n105\t  \"/profile/*\",\n106\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n107\t);\n108\tapp.route(\"/profile\", createProfileRoutes({ db }));\n109\t\n110\t// Public profile routes — no auth required\n111\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n112\t\n113\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n114\tapp.use(\n115\t  \"/referral/*\",\n116\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n117\t);\n118\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n119\t\n120\t// JWT auth middleware for game endpoints\n121\tapp.use(\n122\t  \"/coinflip/*\",\n123\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n124\t);\n125\tapp.use(\n126\t  \"/lord/*\",\n127\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n128\t);\n129\t\n130\t// Rate limiting — per-wallet and global limits on POST requests\n131\tapp.use(\n132\t  \"/coinflip/*\",\n133\t  createRateLimitMiddleware({\n134\t    perWallet: config.rateLimitPerWallet,\n135\t    global: config.rateLimitGlobal,\n136\t    windowMs: 60_000,\n137\t  }),\n138\t);\n139\tapp.use(\n140\t  \"/lord/*\",\n141\t  createRateLimitMiddleware({\n142\t    perWallet: config.rateLimitPerWallet,\n143\t    global: config.rateLimitGlobal,\n144\t    windowMs: 60_000,\n145\t  }),\n146\t);\n147\t\n148\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n149\tconst entropyAccount = new PublicKey(config.entropyAccount);\n150\tconst retrySettler = createRetrySettler({\n151\t  db,\n152\t  connection,\n153\t  settleRound: (pda) =>\n154\t    settleRound(\n155\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n156\t      pda,\n157\t    ),\n158\t});\n159\t\n160\t// PDA watcher — WebSocket-based instant join detection\n161\tconst pdaWatcher = createPdaWatcher({\n162\t  connection,\n163\t  serverKey: config.serverKeypair.publicKey,\n164\t  db,\n165\t  onJoinDetected: async (pda, targetSlot) => {\n166\t    // Update DB phase if still in 'created'\n167\t    const round = await db.getRoundByPda(pda);\n168\t    if (round && round.phase === \"created\") {\n169\t      await db.updateRoundPhase(pda, \"locked\", {\n170\t        target_slot: targetSlot.toString(),\n171\t      });\n172\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n173\t        targetSlot: targetSlot.toString(),\n174\t        source: \"pda-watcher\",\n175\t        game: round.game,\n176\t      });\n177\t    }\n178\t\n179\t    // Check if target slot already passed — settle immediately if so\n180\t    const currentSlot = await connection.getSlot();\n181\t    if (BigInt(currentSlot) >= targetSlot) {\n182\t      await retrySettler.attemptSettle(pda);\n183\t      pdaWatcher.unwatch(pda);\n184\t    }\n185\t    // If target slot not reached yet, poll worker will pick it up next cycle\n186\t  },\n187\t});\n188\t\n189\tconst worker = createSettlementWorker({\n190\t  db,\n191\t  connection,\n192\t  serverKey: config.serverKeypair.publicKey,\n193\t  pollIntervalMs: config.workerPollIntervalMs,\n194\t  onSettleReady: async (pda) => {\n195\t    await retrySettler.attemptSettle(pda);\n196\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n197\t  },\n198\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n199\t});\n200\tworker.start();\n201\t\n202\t// Close Call clock worker — fetches boundary prices + settles open rounds\n203\t// Rounds are created on-demand by players via /closecall/bet\n204\tconst closeCallClock = createCloseCallClockWorker({\n205\t  connection,\n206\t  serverKeypair: config.serverKeypair,\n207\t  db,\n208\t});\n209\tcloseCallClock.start();\n210\t\n211\t// Register event handlers before starting the worker\n212\tregisterHandler(\n213\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n214\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n215\t);\n216\tregisterHandler(\n217\t  EventTypes.GAME_SETTLED,\n218\t  createGameSettledHandler({ db }),\n219\t);\n220\tregisterHandler(\n221\t  EventTypes.REWARD_POOL_FUND,\n222\t  createRewardPoolFundHandler({ db }),\n223\t);\n224\tregisterHandler(\n225\t  EventTypes.POINTS_GRANT,\n226\t  createPointsGrantHandler({\n227\t    db,\n228\t    getSolPrice: async () => {\n229\t      const result = await fetchSolPrice();\n230\t      return result?.price ?? null;\n231\t    },\n232\t  }),\n233\t);\n234\tregisterHandler(\n235\t  EventTypes.CRATE_DROP,\n236\t  createCrateDropHandler({ db }),\n237\t);\n238\t\n239\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n240\tconst eventWorker = createEventWorker(sql, {\n241\t  pollIntervalMs: config.eventQueuePollMs,\n242\t});\n243\teventWorker.start();\n244\tlogger.info(\"Event queue worker started\", {\n245\t  pollIntervalMs: config.eventQueuePollMs,\n246\t});\n247\t\n248\t// Game-specific routes\n249\tapp.route(\n250\t  \"/coinflip\",\n251\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n252\t);\n253\tapp.route(\n254\t  \"/lord\",\n255\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n256\t);\n257\t\n258\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n259\tapp.use(\n260\t  \"/closecall/bet\",\n261\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n262\t);\n263\tapp.use(\n264\t  \"/closecall/bet\",\n265\t  createRateLimitMiddleware({\n266\t    perWallet: config.rateLimitPerWallet,\n267\t    global: config.rateLimitGlobal,\n268\t    windowMs: 60_000,\n269\t  }),\n270\t);\n271\t\n272\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n273\tapp.route(\"/closecall\", createCloseCallRoutes({\n274\t  db,\n275\t  connection,\n276\t  serverKeypair: config.serverKeypair,\n277\t  clockWorker: closeCallClock,\n278\t}));\n279\t\n280\t// Challenge routes — authenticated GET endpoints (require JWT on all methods)\n281\tapp.use(\n282\t  \"/challenges/*\",\n283\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n284\t);\n285\tapp.route(\"/challenges\", createChallengeRoutes({ db }));\n286\t\n287\t// Leaderboard routes — public, no auth\n288\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n289\t\n290\t// Price routes — public, no auth\n291\tapp.route(\"/price\", createPriceRoutes());\n292\t\n293\t// Round verification routes\n294\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n295\t\n296\t// Health endpoint — wired after worker exists so we can query its status\n297\tapp.route(\n298\t  \"/health\",\n299\t  createHealthRoutes({\n300\t    db,\n301\t    sql,\n302\t    isWorkerRunning: () => worker.isRunning,\n303\t  }),\n304\t);\n305\t\n306\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n307\tif (config.adminToken) {\n308\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n309\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production