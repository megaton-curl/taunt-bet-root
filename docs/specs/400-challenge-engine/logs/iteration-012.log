{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CiLVBGFquQ5N9wRBdfZsUm","type":"tool_result","content":"1325\t          ), 0\n1326\t        ) AS pending\n1327\t      `;\n1328\t      return rows[0]!.pending;\n1329\t    },\n1330\t\n1331\t    async getReferralEarningsByUserId(userId, page, limit) {\n1332\t      const offset = (page - 1) * limit;\n1333\t      const [countRows, rows] = await Promise.all([\n1334\t        sql<{ count: string }[]>`\n1335\t          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n1336\t          WHERE referrer_user_id = ${userId}\n1337\t        `,\n1338\t        sql<ReferralEarning[]>`\n1339\t          SELECT * FROM referral_earnings\n1340\t          WHERE referrer_user_id = ${userId}\n1341\t          ORDER BY created_at DESC\n1342\t          LIMIT ${limit} OFFSET ${offset}\n1343\t        `,\n1344\t      ]);\n1345\t      const total = Number(countRows[0]!.count);\n1346\t      const totalPages = Math.max(1, Math.ceil(total / limit));\n1347\t      return { items: rows.map(normalizeReferralEarning), totalPages };\n1348\t    },\n1349\t"}]},"parent_tool_use_id":"toolu_01C2Pn5rKeJTogFTCp3dWYsS","session_id":"2e700c10-4389-4a9a-beb2-50db732591da","uuid":"55f675ce-0f7c-4d9b-9488-988dbddaffeb","timestamp":"2026-04-03T20:51:31.993Z"}
