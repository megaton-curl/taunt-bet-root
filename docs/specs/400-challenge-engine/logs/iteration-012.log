{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B2mjGEmSS5Y6YT4WGXZi1r","type":"tool_result","content":"1\t/**\n2\t * Challenge routes — player-facing challenge/quest endpoints.\n3\t *\n4\t * GET /mine — returns active daily, weekly, and onboarding challenges\n5\t * with lazy assignment on first call per period.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { AppEnv } from \"../hono-env.js\";\n10\timport type { Db } from \"../db.js\";\n11\timport { logger } from \"../logger.js\";\n12\timport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n13\t\n14\t// ---------------------------------------------------------------------------\n15\t// Types\n16\t// ---------------------------------------------------------------------------\n17\t\n18\texport interface ChallengeRoutesDeps {\n19\t  db: Db;\n20\t}\n21\t\n22\tinterface ChallengeRow {\n23\t  id: string;\n24\t  campaign_id: string;\n25\t  title: string;\n26\t  description: string;\n27\t  action: string;\n28\t  scope: string;\n29\t  condition: string;\n30\t  threshold: number;\n31\t  reward_type: string;\n32\t  reward_amount: number | null;\n33\t  sort_order: number;\n34\t  prerequisite_id: string | null;\n35\t}\n36\t\n37\tinterface AssignmentRow {\n38\t  id: string;\n39\t  challenge_id: string;\n40\t  period_key: string;\n41\t  status: string;\n42\t  progress: number;\n43\t  target: number;\n44\t  expires_at: string | null;\n45\t  completed_at: string | null;\n46\t  title: string;\n47\t  description: string;\n48\t  reward_type: string;\n49\t  reward_amount: number | null;\n50\t  campaign_type: string;\n51\t}\n52\t\n53\tinterface CompletionBonusRow {\n54\t  id: string;\n55\t  title: string;\n56\t  required_count: number;\n57\t  reward_type: string;\n58\t  reward_amount: number | null;\n59\t}\n60\t\n61\tinterface BonusCompletionRow {\n62\t  id: string;\n63\t}\n64\t\n65\t// ---------------------------------------------------------------------------\n66\t// Period key helpers\n67\t// ---------------------------------------------------------------------------\n68\t\n69\t/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\n70\texport function dailyPeriodKey(now?: Date): string {\n71\t  const d = now ?? new Date();\n72\t  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n73\t}\n74\t\n75\t/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\n76\texport function weeklyPeriodKey(now?: Date): string {\n77\t  const d = now ?? new Date();\n78\t  // ISO week calculation\n79\t  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n80\t  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n81\t  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n82\t  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n83\t  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n84\t}\n85\t\n86\t/** Returns midnight UTC of the next day (daily reset). */\n87\texport function dailyResetsAt(now?: Date): string {\n88\t  const d = now ?? new Date();\n89\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n90\t  return next.toISOString();\n91\t}\n92\t\n93\t/** Returns midnight UTC of next Monday (weekly reset). */\n94\texport function weeklyResetsAt(now?: Date): string {\n95\t  const d = now ?? new Date();\n96\t  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n97\t  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n98\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n99\t  return next.toISOString();\n100\t}\n101\t\n102\t// ---------------------------------------------------------------------------\n103\t// DB helpers\n104\t// ---------------------------------------------------------------------------\n105\t\n106\t/** Expire stale assignments (expires_at < now AND status='active'). */\n107\tasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n108\t  await db.rawSql`\n109\t    UPDATE challenge_assignments\n110\t    SET status = 'expired'\n111\t    WHERE user_id = ${userId}\n112\t      AND status = 'active'\n113\t      AND expires_at IS NOT NULL\n114\t      AND expires_at < now()\n115\t  `;\n116\t}\n117\t\n118\t/** Get assignments for a user in a given period, joined with challenge metadata. */\n119\tasync function getAssignmentsForPeriod(\n120\t  db: Db,\n121\t  userId: string,\n122\t  periodKey: string,\n123\t): Promise<AssignmentRow[]> {\n124\t  return db.rawSql<AssignmentRow[]>`\n125\t    SELECT\n126\t      ca.id,\n127\t      ca.challenge_id,\n128\t      ca.period_key,\n129\t      ca.status,\n130\t      ca.progress,\n131\t      ca.target,\n132\t      ca.expires_at,\n133\t      ca.completed_at,\n134\t      c.title,\n135\t      c.description,\n136\t      c.reward_type,\n137\t      c.reward_amount,\n138\t      camp.campaign_type\n139\t    FROM challenge_assignments ca\n140\t    JOIN challenges c ON c.id = ca.challenge_id\n141\t    JOIN campaigns camp ON camp.id = c.campaign_id\n142\t    WHERE ca.user_id = ${userId}\n143\t      AND ca.period_key = ${periodKey}\n144\t    ORDER BY c.sort_order ASC\n145\t  `;\n146\t}\n147\t\n148\t/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\n149\tasync function getActiveChallengesBySort(\n150\t  db: Db,\n151\t  campaignId: string,\n152\t  limit: number,\n153\t): Promise<ChallengeRow[]> {\n154\t  return db.rawSql<ChallengeRow[]>`\n155\t    SELECT id, campaign_id, title, description, action, scope, condition,\n156\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n157\t    FROM challenges\n158\t    WHERE campaign_id = ${campaignId}\n159\t      AND is_active = true\n160\t    ORDER BY sort_order ASC\n161\t    LIMIT ${limit}\n162\t  `;\n163\t}\n164\t\n165\t/** Get the campaign ID for a given campaign type. */\n166\tasync function getCampaignByType(\n167\t  db: Db,\n168\t  campaignType: string,\n169\t): Promise<{ id: string } | null> {\n170\t  const rows = await db.rawSql<{ id: string }[]>`\n171\t    SELECT id FROM campaigns\n172\t    WHERE campaign_type = ${campaignType}\n173\t      AND is_active = true\n174\t    LIMIT 1\n175\t  `;\n176\t  return rows[0] ?? null;\n177\t}\n178\t\n179\t/** Get all onboarding assignments for a user (any status). */\n180\tasync function getOnboardingAssignments(\n181\t  db: Db,\n182\t  userId: string,\n183\t): Promise<AssignmentRow[]> {\n184\t  return db.rawSql<AssignmentRow[]>`\n185\t    SELECT\n186\t      ca.id,\n187\t      ca.challenge_id,\n188\t      ca.period_key,\n189\t      ca.status,\n190\t      ca.progress,\n191\t      ca.target,\n192\t      ca.expires_at,\n193\t      ca.completed_at,\n194\t      c.title,\n195\t      c.description,\n196\t      c.reward_type,\n197\t      c.reward_amount,\n198\t      camp.campaign_type\n199\t    FROM challenge_assignments ca\n200\t    JOIN challenges c ON c.id = ca.challenge_id\n201\t    JOIN campaigns camp ON camp.id = c.campaign_id\n202\t    WHERE ca.user_id = ${userId}\n203\t      AND ca.period_key = 'onboarding'\n204\t    ORDER BY c.sort_order ASC\n205\t  `;\n206\t}\n207\t\n208\t/** Get all onboarding challenge templates (ordered by chain). */\n209\tasync function getOnboardingChallenges(\n210\t  db: Db,\n211\t  campaignId: string,\n212\t): Promise<ChallengeRow[]> {\n213\t  return db.rawSql<ChallengeRow[]>`\n214\t    SELECT id, campaign_id, title, description, action, scope, condition,\n215\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n216\t    FROM challenges\n217\t    WHERE campaign_id = ${campaignId}\n218\t      AND is_active = true\n219\t    ORDER BY sort_order ASC\n220\t  `;\n221\t}\n222\t\n223\t/** Get completion bonuses for a campaign. */\n224\tasync function getCompletionBonusesForCampaign(\n225\t  db: Db,\n226\t  campaignId: string,\n227\t): Promise<CompletionBonusRow[]> {\n228\t  return db.rawSql<CompletionBonusRow[]>`\n229\t    SELECT id, title, required_count, reward_type, reward_amount\n230\t    FROM completion_bonuses\n231\t    WHERE campaign_id = ${campaignId}\n232\t      AND is_active = true\n233\t  `;\n234\t}\n235\t\n236\t/** Check if a bonus was completed for a user in a given period. */\n237\tasync function getBonusCompletion(\n238\t  db: Db,\n239\t  userId: string,\n240\t  bonusId: string,\n241\t  periodKey: string,\n242\t): Promise<BonusCompletionRow | null> {\n243\t  const rows = await db.rawSql<BonusCompletionRow[]>`\n244\t    SELECT id FROM bonus_completions\n245\t    WHERE user_id = ${userId}\n246\t      AND bonus_id = ${bonusId}\n247\t      AND period_key = ${periodKey}\n248\t    LIMIT 1\n249\t  `;\n250\t  return rows[0] ?? null;\n251\t}\n252\t\n253\t/** Count completed assignments for a user in a period+campaign. */\n254\tasync function countCompleted(\n255\t  db: Db,\n256\t  userId: string,\n257\t  periodKey: string,\n258\t  campaignId: string,\n259\t): Promise<number> {\n260\t  const rows = await db.rawSql<{ count: string }[]>`\n261\t    SELECT COUNT(*)::TEXT AS count\n262\t    FROM challenge_assignments ca\n263\t    JOIN challenges c ON c.id = ca.challenge_id\n264\t    WHERE ca.user_id = ${userId}\n265\t      AND ca.period_key = ${periodKey}\n266\t      AND ca.status = 'completed'\n267\t      AND c.campaign_id = ${campaignId}\n268\t  `;\n269\t  return Number(rows[0]!.count);\n270\t}\n271\t\n272\t/** Create an assignment (idempotent via UNIQUE). */\n273\tasync function createAssignment(\n274\t  db: Db,\n275\t  userId: string,\n276\t  challengeId: string,\n277\t  periodKey: string,\n278\t  target: number,\n279\t  expiresAt: string | null,\n280\t): Promise<void> {\n281\t  await db.rawSql`\n282\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n283\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n284\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n285\t  `;\n286\t}\n287\t\n288\t// ---------------------------------------------------------------------------\n289\t// Route factory\n290\t// ---------------------------------------------------------------------------\n291\t\n292\texport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n293\t  const { db } = deps;\n294\t  const app = new Hono<AppEnv>();\n295\t\n296\t  app.get(\"/mine\", async (c) => {\n297\t    const userId = c.get(\"userId\");\n298\t    if (!userId) {\n299\t      return c.json({ error: \"Authentication required\" }, 401);\n300\t    }\n301\t\n302\t    try {\n303\t      const now = new Date();\n304\t\n305\t      // 1. Expire stale assignments\n306\t      await expireStaleAssignments(db, userId);\n307\t\n308\t      // 2. Compute current period keys\n309\t      const dailyKey = dailyPeriodKey(now);\n310\t      const weeklyKey = weeklyPeriodKey(now);\n311\t\n312\t      // 3. Read config for challenge counts\n313\t      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n314\t      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n315\t      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n316\t      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n317\t\n318\t      // 4. Look up campaign IDs\n319\t      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n320\t        getCampaignByType(db, \"daily\"),\n321\t        getCampaignByType(db, \"weekly\"),\n322\t        getCampaignByType(db, \"onboarding\"),\n323\t      ]);\n324\t\n325\t      // 5. Lazy assignment — daily\n326\t      let dailyAssignments = dailyCampaign\n327\t        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n328\t        : [];\n329\t\n330\t      if (dailyAssignments.length === 0 && dailyCampaign) {\n331\t        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n332\t        const dailyExpires = dailyResetsAt(now);\n333\t        for (const t of templates) {\n334\t          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n335\t        }\n336\t        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n337\t      }\n338\t\n339\t      // 6. Lazy assignment — weekly\n340\t      let weeklyAssignments = weeklyCampaign\n341\t        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n342\t        : [];\n343\t\n344\t      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n345\t        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n346\t        const weeklyExpires = weeklyResetsAt(now);\n347\t        for (const t of templates) {\n348\t          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n349\t        }\n350\t        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n351\t      }\n352\t\n353\t      // 7. Lazy assignment — onboarding\n354\t      let onboardingAssignments = onboardingCampaign\n355\t        ? await getOnboardingAssignments(db, userId)\n356\t        : [];\n357\t\n358\t      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n359\t        // Assign first step (prerequisite_id IS NULL)\n360\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n361\t        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n362\t        if (firstStep) {\n363\t          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n364\t          onboardingAssignments = await getOnboardingAssignments(db, userId);\n365\t        }\n366\t      }\n367\t\n368\t      // 8. Build bonus status for daily\n369\t      let dailyBonus: object | null = null;\n370\t      if (dailyCampaign) {\n371\t        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n372\t        if (bonuses.length > 0) {\n373\t          const bonus = bonuses[0]!;\n374\t          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n375\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n376\t          dailyBonus = {\n377\t            title: bonus.title,\n378\t            required: bonus.required_count,\n379\t            completed: completedCount,\n380\t            status: bonusCompletion ? \"completed\" : \"active\",\n381\t            reward: {\n382\t              type: bonus.reward_type,\n383\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n384\t            },\n385\t          };\n386\t        }\n387\t      }\n388\t\n389\t      // 9. Build bonus status for weekly\n390\t      let weeklyBonus: object | null = null;\n391\t      if (weeklyCampaign) {\n392\t        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n393\t        if (bonuses.length > 0) {\n394\t          const bonus = bonuses[0]!;\n395\t          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n396\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n397\t          weeklyBonus = {\n398\t            title: bonus.title,\n399\t            required: bonus.required_count,\n400\t            completed: completedCount,\n401\t            status: bonusCompletion ? \"completed\" : \"active\",\n402\t            reward: {\n403\t              type: bonus.reward_type,\n404\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n405\t            },\n406\t          };\n407\t        }\n408\t      }\n409\t\n410\t      // 10. Build onboarding section\n411\t      let onboarding: object | null = null;\n412\t      if (onboardingCampaign) {\n413\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n414\t        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n415\t        const completedIds = new Set(\n416\t          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n417\t        );\n418\t        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n419\t\n420\t        if (allCompleted) {\n421\t          onboarding = null;\n422\t        } else {\n423\t          const steps = allSteps.map((step) => {\n424\t            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n425\t            const isAssigned = assignedIds.has(step.id);\n426\t            const locked = !isAssigned;\n427\t            return {\n428\t              id: Number(step.id),\n429\t              title: step.title,\n430\t              description: step.description,\n431\t              progress: assignment ? assignment.progress : 0,\n432\t              target: step.threshold,\n433\t              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n434\t              reward: {\n435\t                type: step.reward_type,\n436\t                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n437\t              },\n438\t              completedAt: assignment?.completed_at ?? null,\n439\t              locked,\n440\t            };\n441\t          });\n442\t          onboarding = { steps, completed: false };\n443\t        }\n444\t      }\n445\t\n446\t      // 11. Format response\n447\t      const formatChallenge = (a: AssignmentRow) => ({\n448\t        id: Number(a.id),\n449\t        title: a.title,\n450\t        description: a.description,\n451\t        progress: a.progress,\n452\t        target: a.target,\n453\t        status: a.status as \"active\" | \"completed\" | \"expired\",\n454\t        reward: {\n455\t          type: a.reward_type,\n456\t          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n457\t        },\n458\t        completedAt: a.completed_at ?? null,\n459\t      });\n460\t\n461\t      return c.json({\n462\t        daily: {\n463\t          challenges: dailyAssignments.map(formatChallenge),\n464\t          bonus: dailyBonus,\n465\t          resetsAt: dailyResetsAt(now),\n466\t        },\n467\t        weekly: {\n468\t          challenges: weeklyAssignments.map(formatChallenge),\n469\t          bonus: weeklyBonus,\n470\t          resetsAt: weeklyResetsAt(now),\n471\t        },\n472\t        onboarding,\n473\t      });\n474\t    } catch (err) {\n475\t      logger.error(\"challenges/mine failed\", {\n476\t        userId,\n477\t        error: err instanceof Error ? err.message : String(err),\n478\t      });\n479\t      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n480\t    }\n481\t  });\n482\t\n483\t  return app;\n484\t}\n485\t"}]},"parent_tool_use_id":"toolu_01C2Pn5rKeJTogFTCp3dWYsS","session_id":"2e700c10-4389-4a9a-beb2-50db732591da","uuid":"6413097b-b1b7-4ca5-939b-4480d4ef7ba5","timestamp":"2026-04-03T20:51:25.483Z"}
