{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TZzWXHqXNmsXRrskQfCriK","type":"tool_result","content":"160\t      });\n161\t      return c.json({ error: \"Failed to update username\" }, 500);\n162\t    }\n163\t  });\n164\t\n165\t  app.get(\"/transactions\", async (c) => {\n166\t    const userId = c.get(\"userId\");\n167\t    if (!userId) {\n168\t      return c.json({ error: \"Authentication required\" }, 401);\n169\t    }\n170\t\n171\t    // Parse query params\n172\t    const cursor = c.req.query(\"cursor\") || undefined;\n173\t    const limitParam = c.req.query(\"limit\");\n174\t    const gameParam = c.req.query(\"game\") || undefined;\n175\t\n176\t    // Validate & clamp limit\n177\t    let limit = 20;\n178\t    if (limitParam) {\n179\t      const parsed = parseInt(limitParam, 10);\n180\t      if (!isNaN(parsed) && parsed > 0) {\n181\t        limit = Math.min(parsed, 50);\n182\t      }\n183\t    }\n184\t\n185\t    // Map game filter to DB name (accept both DB and frontend names)\n186\t    let dbGame: string | undefined;\n187\t    if (gameParam) {\n188\t      dbGame = TO_DB_GAME[gameParam];\n189\t      if (!dbGame) {\n190\t        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n191\t      }\n192\t    }\n193\t\n194\t    try {\n195\t      const rows = await db.getTransactionsByUserId(userId, cursor, limit, dbGame);\n196\t\n197\t      const transactions = rows.map((row) => ({\n198\t        id: row.id,\n199\t        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n200\t        matchId: row.match_id,\n201\t        txType: row.tx_type,\n202\t        amountLamports: String(row.amount_lamports),\n203\t        txSig: row.tx_sig,\n204\t        createdAt: row.created_at.toISOString(),\n205\t      }));\n206\t\n207\t      const nextCursor =\n208\t        transactions.length === limit\n209\t          ? String(transactions[transactions.length - 1]!.id)"}]},"parent_tool_use_id":"toolu_01C2Pn5rKeJTogFTCp3dWYsS","session_id":"2e700c10-4