{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B1R3j471XQrnMuZYCr4WKn","type":"tool_result","content":"2387\t    const step1After = await rawSql<{ progress: number; status: string }[]>`\n2388\t      SELECT progress, status FROM challenge_assignments\n2389\t      WHERE user_id = ${userId} AND challenge_id = ${step1.id}\n2390\t    `;\n2391\t    expect(step1After[0]!.progress).toBe(1);\n2392\t    expect(step1After[0]!.status).toBe(\"completed\");\n2393\t\n2394\t    // Step 2 should be assigned exactly once (UNIQUE constraint)\n2395\t    const step2Assignments = await rawSql<{ id: string }[]>`\n2396\t      SELECT id FROM challenge_assignments\n2397\t      WHERE user_id = ${userId} AND challenge_id = ${step2.id} AND period_key = 'onboarding'\n2398\t    `;\n2399\t    expect(step2Assignments.length).toBe(1);\n2400\t\n2401\t    // Re-process the same event — step 1 progress_event UNIQUE prevents double progress\n2402\t    await handler(settledPayload);\n2403\t\n2404\t    // Step 1 progress should still be 1 (idempotent via progress_events UNIQUE on assignment_id + round_id)\n2405\t    const step1AfterRetry = await rawSql<{ progress: number }[]>`\n2406\t      SELECT progress FROM challenge_assignments\n2407\t      WHERE user_id = ${userId} AND challenge_id = ${step1.id}\n2408\t    `;\n2409\t    expect(step1AfterRetry[0]!.progress).toBe(1);\n2410\t\n2411\t    // Step 2 still assigned exactly once (createAssignment's ON CONFLICT DO NOTHING)\n2412\t    const step2AfterRetry = await rawSql<{ id: string }[]>`\n2413\t      SELECT id FROM challenge_assignments\n2414\t      WHERE user_id = ${userId} AND challenge_id = ${step2.id} AND period_key = 'onboarding'\n2415\t    `;\n2416\t    expect(step2AfterRetry.length).toBe(1);\n2417\t  });\n2418\t});\n2419\t\n2420\t// ---------------------------------------------------------------------------\n2421\t// GET /challenges/mine — lazy assignment + response shape\n2422\t// ---------------------------------------------------------------------------\n2423\t\n2424\tdescribe(\"GET /challenges/mine\", () => {\n2425\t  let rawSql: ReturnType<typeof makeSql>;\n2426\t  let db: Db;\n2427\t  let challengeApp: InstanceType<typeof Hono>;\n2428\t\n2429\t  const testWallet = Keypair.generate().publicKey.toBase58();\n2430\t  const testUserId = userIdFromWallet(testWallet);\n2431\t\n2432\t  beforeAll(async () => {\n2433\t    rawSql = makeSql();\n2434\t    db = createDb(DATABASE_URL, rawSql);\n2435\t  });\n2436\t\n2437\t  afterAll(async () => {\n2438\t    await db.close();\n2439\t    await rawSql.end();\n2440\t  });\n2441\t\n2442\t  beforeEach(async () => {\n2443\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n2444\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n2445\t\n2446\t    challengeApp = new Hono();\n2447\t    challengeApp.use(\n2448\t      \"/challenges/*\",\n2449\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n2450\t    );\n2451\t    challengeApp.route(\"/challenges\", createChallengeRoutes({ db }));\n2452\t  });\n2453\t\n2454\t  it(\"first call creates 3 daily + 2 weekly + 1 onboarding assignment, returns correct shape\", async () => {\n2455\t    const token = await makeJwt(testWallet, testUserId);\n2456\t\n2457\t    const res = await challengeApp.request(\"/challenges/mine\", {\n2458\t      method: \"GET\",\n2459\t      headers: { Authorization: `Bearer ${token}` },\n2460\t    });\n2461\t\n2462\t    expect(res.status).toBe(200);\n2463\t    const body = (await res.json()) as Record<string, any>;\n2464\t\n2465\t    // Daily section\n2466\t    expect(body.daily).toBeDefined();\n2467\t    expect(body.daily.challenges).toHaveLength(3);\n2468\t    expect(body.daily.resetsAt).toBeDefined();\n2469\t    for (const ch of body.daily.challenges) {\n2470\t      expect(ch).toHaveProperty(\"id\");\n2471\t      expect(ch).toHaveProperty(\"title\");\n2472\t      expect(ch).toHaveProperty(\"description\");\n2473\t      expect(ch).toHaveProperty(\"progress\");\n2474\t      expect(ch).toHaveProperty(\"target\");\n2475\t      expect(ch).toHaveProperty(\"status\");\n2476\t      expect(ch).toHaveProperty(\"reward\");\n2477\t      expect(ch.reward).toHaveProperty(\"type\");\n2478\t      expect(ch).toHaveProperty(\"completedAt\");\n2479\t      expect(ch.status).toBe(\"active\");\n2480\t      expect(ch.progress).toBe(0);\n2481\t    }\n2482\t\n2483\t    // Daily bonus\n2484\t    expect(body.daily.bonus).toBeDefined();\n2485\t    expect(body.daily.bonus.required).toBe(3);\n2486\t    expect(body.daily.bonus.completed).toBe(0);\n2487\t    expect(body.daily.bonus.status).toBe(\"active\");\n2488\t    expect(body.daily.bonus.reward).toHaveProperty(\"type\");\n2489\t\n2490\t    // Weekly section\n2491\t    expect(body.weekly).toBeDefined();\n2492\t    expect(body.weekly.challenges).toHaveLength(2);\n2493\t    expect(body.weekly.resetsAt).toBeDefined();\n2494\t    for (const ch of body.weekly.challenges) {\n2495\t      expect(ch.status).toBe(\"active\");\n2496\t      expect(ch.progress).toBe(0);\n2497\t    }\n2498\t\n2499\t    // Onboarding section\n2500\t    expect(body.onboarding).toBeDefined();\n2501\t    expect(body.onboarding).not.toBeNull();\n2502\t    expect(body.onboarding.completed).toBe(false);\n2503\t    expect(body.onboarding.steps).toBeDefined();\n2504\t    expect(body.onboarding.steps.length).toBeGreaterThanOrEqual(1);\n2505\t\n2506\t    // First step should be unlocked, rest locked\n2507\t    const steps = body.onboarding.steps;\n2508\t    expect(steps[0].locked).toBe(false);\n2509\t    if (steps.length > 1) {\n2510\t      expect(steps[1].locked).toBe(true);\n2511\t    }\n2512\t\n2513\t    // Verify DB: 3 daily + 2 weekly + 1 onboarding = 6 total assignments\n2514\t    const assignments = await rawSql<{ period_key: string }[]>`\n2515\t      SELECT period_key FROM challenge_assignments WHERE user_id = ${testUserId}\n2516\t    `;\n2517\t    const dailyKey = dailyPeriodKey();\n2518\t    const weeklyKey = weeklyPeriodKey();\n2519\t    const dailyCount = assignments.filter((a) => a.period_key === dailyKey).length;\n2520\t    const weeklyCount = assignments.filter((a) => a.period_key === weeklyKey).length;\n2521\t    const onboardingCount = assignments.filter((a) => a.period_key === \"onboarding\").length;\n2522\t    expect(dailyCount).toBe(3);\n2523\t    expect(weeklyCount).toBe(2);\n2524\t    expect(onboardingCount).toBe(1);\n2525\t  });\n2526\t\n2527\t  it(\"second call returns same assignments (no duplicates)\", async () => {\n2528\t    const token = await makeJwt(testWallet, testUserId);\n2529\t\n2530\t    // First call — creates assignments\n2531\t    await challengeApp.request(\"/challenges/mine\", {\n2532\t      method: \"GET\",\n2533\t      headers: { Authorization: `Bearer ${token}` },\n2534\t    });\n2535\t\n2536\t    // Second call — should return same data\n2537\t    const res = await challengeApp.request(\"/challenges/mine\", {\n2538\t      method: \"GET\",\n2539\t      headers: { Authorization: `Bearer ${token}` },\n2540\t    });\n2541\t\n2542\t    expect(res.status).toBe(200);\n2543\t    const body = (await res.json()) as Record<string, any>;\n2544\t    expect(body.daily.challenges).toHaveLength(3);\n2545\t    expect(body.weekly.challenges).toHaveLength(2);\n2546\t\n2547\t    // Total assignments unchanged\n2548\t    const assignments = await rawSql<{ id: string }[]>`\n2549\t      SELECT id FROM challenge_assignments WHERE user_id = ${testUserId}\n2550\t    `;\n2551\t    expect(assignments.length).toBe(6); // 3 daily + 2 weekly + 1 onboarding\n2552\t  });\n2553\t\n2554\t  it(\"expired assignments are marked expired\", async () => {\n2555\t    const token = await makeJwt(testWallet, testUserId);\n2556\t\n2557\t    // Insert an assignment that's already expired\n2558\t    const dailyCampaign = await rawSql<{ id: string }[]>`\n2559\t      SELECT id FROM campaigns WHERE campaign_type = 'daily' LIMIT 1\n2560\t    `;\n2561\t    const challenges = await rawSql<{ id: string; threshold: number }[]>`\n2562\t      SELECT id, threshold FROM challenges WHERE campaign_id = ${dailyCampaign[0]!.id} AND is_active = true ORDER BY sort_order ASC LIMIT 1\n2563\t    `;\n2564\t    await rawSql`\n2565\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n2566\t      VALUES (${testUserId}, ${challenges[0]!.id}, 'daily:2020-01-01', ${challenges[0]!.threshold}, '2020-01-02T00:00:00Z')\n2567\t    `;\n2568\t\n2569\t    // Verify it's active\n2570\t    const before = await rawSql<{ status: string }[]>`\n2571\t      SELECT status FROM challenge_assignments WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n2572\t    `;\n2573\t    expect(before[0]!.status).toBe(\"active\");\n2574\t\n2575\t    // Call /mine — should expire the stale assignment\n2576\t    await challengeApp.request(\"/challenges/mine\", {\n2577\t      method: \"GET\",\n2578\t      headers: { Authorization: `Bearer ${token}` },\n2579\t    });\n2580\t\n2581\t    // Verify it's now expired\n2582\t    const after = await rawSql<{ status: string }[]>`\n2583\t      SELECT status FROM challenge_assignments WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n2584\t    `;\n2585\t    expect(after[0]!.status).toBe(\"expired\");\n2586\t  });"}]},"parent_tool_use_id":"toolu_01TLRvQa8LiFx2Z5CcFD9NBy","session_id":"2e700c10-4389-4a9a-beb2-50db732591da","uuid":"e245b2d7-c88d-47cc-a035-ffe6a2ef1ecb","timestamp":"2026-04-03T20:51:47.042Z"}
