{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hu2qnCtRDreEoBMdXzfACF","type":"tool_result","content":"3100\t// Admin Campaign + Challenge CRUD Tests\n3101\t// ---------------------------------------------------------------------------\n3102\t\n3103\tdescribe(\"Admin API: campaign + challenge CRUD\", () => {\n3104\t  let db: Db;\n3105\t  let rawSql: ReturnType<typeof postgres>;\n3106\t  let adminApp: Hono;\n3107\t\n3108\t  const ADMIN_KEY = \"test-admin-key-secret\";\n3109\t\n3110\t  beforeAll(async () => {\n3111\t    rawSql = makeSql();\n3112\t    db = createDb(DATABASE_URL, rawSql);\n3113\t  });\n3114\t\n3115\t  afterAll(async () => {\n3116\t    await db.close();\n3117\t    await rawSql.end();\n3118\t  });\n3119\t\n3120\t  let testSuffix: string;\n3121\t\n3122\t  beforeEach(async () => {\n3123\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n3124\t    // Use unique suffix per test run to avoid name collision with seeded data\n3125\t    testSuffix = Date.now().toString(36) + Math.random().toString(36).slice(2, 6);\n3126\t\n3127\t    adminApp = new Hono();\n3128\t    adminApp.route(\"/admin\", createAdminRoutes({ db, adminApiKey: ADMIN_KEY }));\n3129\t  });\n3130\t\n3131\t  it(\"POST /admin/campaigns creates a campaign and returns it\", async () => {\n3132\t    const campName = `test-campaign-${testSuffix}`;\n3133\t    const res = await adminApp.request(\"/admin/campaigns\", {\n3134\t      method: \"POST\",\n3135\t      headers: {\n3136\t        \"X-Admin-Key\": ADMIN_KEY,\n3137\t        \"Content-Type\": \"application/json\",\n3138\t      },\n3139\t      body: JSON.stringify({\n3140\t        name: campName,\n3141\t        campaignType: \"daily\",\n3142\t        config: { maxAssignments: 5 },\n3143\t      }),\n3144\t    });\n3145\t    expect(res.status).toBe(201);\n3146\t    const body = (await res.json()) as Record<string, any>;\n3147\t    expect(body.name).toBe(campName);\n3148\t    expect(body.campaignType).toBe(\"daily\");\n3149\t    expect(body.isActive).toBe(true);\n3150\t    expect(body.config).toEqual({ maxAssignments: 5 });\n3151\t    expect(body).toHaveProperty(\"id\");\n3152\t    expect(body).toHaveProperty(\"createdAt\");\n3153\t  });\n3154\t\n3155\t  it(\"POST /admin/campaigns rejects invalid campaign_type\", async () => {\n3156\t    const res = await adminApp.request(\"/admin/campaigns\", {\n3157\t      method: \"POST\",\n3158\t      headers: {\n3159\t        \"X-Admin-Key\": ADMIN_KEY,\n3160\t        \"Content-Type\": \"application/json\",\n3161\t      },\n3162\t      body: JSON.stringify({\n3163\t        name: `bad-type-${testSuffix}`,\n3164\t        campaignType: \"invalid_type\",\n3165\t      }),\n3166\t    });\n3167\t    expect(res.status).toBe(400);\n3168\t    const body = (await res.json()) as Record<string, any>;\n3169\t    expect(body.error).toBe(\"INVALID_CAMPAIGN_TYPE\");\n3170\t  });\n3171\t\n3172\t  it(\"PUT /admin/campaigns/:id updates campaign and toggles is_active\", async () => {\n3173\t    const campName = `update-camp-${testSuffix}`;\n3174\t    // Create a campaign first\n3175\t    const createRes = await adminApp.request(\"/admin/campaigns\", {\n3176\t      method: \"POST\",\n3177\t      headers: {\n3178\t        \"X-Admin-Key\": ADMIN_KEY,\n3179\t        \"Content-Type\": \"application/json\",\n3180\t      },\n3181\t      body: JSON.stringify({ name: campName, campaignType: \"weekly\" }),\n3182\t    });\n3183\t    const created = (await createRes.json()) as Record<string, any>;\n3184\t\n3185\t    const updatedName = `updated-camp-${testSuffix}`;\n3186\t    // Update: rename + deactivate\n3187\t    const res = await adminApp.request(`/admin/campaigns/${created.id}`, {\n3188\t      method: \"PUT\",\n3189\t      headers: {\n3190\t        \"X-Admin-Key\": ADMIN_KEY,\n3191\t        \"Content-Type\": \"application/json\",\n3192\t      },\n3193\t      body: JSON.stringify({ name: updatedName, isActive: false }),\n3194\t    });\n3195\t    expect(res.status).toBe(200);\n3196\t    const body = (await res.json()) as Record<string, any>;\n3197\t    expect(body.name).toBe(updatedName);\n3198\t    expect(body.isActive).toBe(false);\n3199\t    expect(body.campaignType).toBe(\"weekly\"); // unchanged"}]},"parent_tool_use_id":"toolu_01X5MGk2evkgm4qCC3F7gqR6","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"1c14cfa0-632b-40f4-9410-d86a4d1c59c8","timestamp":"2026-04-04T07:58:25.031Z"}
