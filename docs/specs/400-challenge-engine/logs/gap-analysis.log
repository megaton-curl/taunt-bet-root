{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0148HoogtWuTKgAQndycgYMM","type":"tool_result","content":"1\t/**\n2\t * CRATE_SOL_PAYOUT handler — sends SOL to player wallet for a SOL crate drop.\n3\t *\n4\t * Flow: load crate_drops row by ID → verify status='pending' → SOL transfer\n5\t * from server keypair → update status to 'granted' (or 'failed' on error).\n6\t *\n7\t * Follows the same transfer pattern as the referral-claim handler.\n8\t * Idempotent: skips if crate is already granted or failed.\n9\t */\n10\t\n11\timport {\n12\t  Connection,\n13\t  Keypair,\n14\t  PublicKey,\n15\t  SystemProgram,\n16\t  Transaction,\n17\t} from \"@solana/web3.js\";\n18\timport type { Db } from \"../../db.js\";\n19\timport { logger } from \"../../logger.js\";\n20\t\n21\t// ---------------------------------------------------------------------------\n22\t// DB helpers\n23\t// ---------------------------------------------------------------------------\n24\t\n25\tinterface CrateDropRow {\n26\t  id: string;\n27\t  user_id: string;\n28\t  crate_type: string;\n29\t  contents_amount: string;\n30\t  status: string;\n31\t}\n32\t\n33\tasync function loadCrateDropById(\n34\t  db: Db,\n35\t  crateDropId: string,\n36\t): Promise<CrateDropRow | null> {\n37\t  const rows = await db.rawSql<CrateDropRow[]>`\n38\t    SELECT id, user_id, crate_type, contents_amount, status\n39\t    FROM crate_drops\n40\t    WHERE id = ${crateDropId}\n41\t  `;\n42\t  return rows[0] ?? null;\n43\t}\n44\t\n45\tasync function updateCrateStatus(\n46\t  db: Db,\n47\t  crateDropId: string,\n48\t  status: string,\n49\t): Promise<void> {\n50\t  await db.rawSql`\n51\t    UPDATE crate_drops\n52\t    SET status     = ${status},\n53\t        granted_at = CASE WHEN ${status} = 'granted' THEN now() ELSE granted_at END\n54\t    WHERE id = ${crateDropId}\n55\t  `;\n56\t}\n57\t\n58\t// ---------------------------------------------------------------------------\n59\t// Handler factory\n60\t// ---------------------------------------------------------------------------\n61\t\n62\texport interface CrateSolPayoutDeps {\n63\t  db: Db;\n64\t  connection: Connection;\n65\t  serverKeypair: Keypair;\n66\t}\n67\t\n68\texport function createCrateSolPayoutHandler(deps: CrateSolPayoutDeps) {\n69\t  const { db, connection, serverKeypair } = deps;\n70\t\n71\t  return async (payload: Record<string, unknown>): Promise<void> => {\n72\t    const crateDropId = payload.crateDropId as string;\n73\t    const userId = payload.userId as string;\n74\t    const wallet = payload.wallet as string;\n75\t    const payoutLamports = payload.payoutLamports as string;\n76\t\n77\t    if (!crateDropId || !userId || !wallet || !payoutLamports) {\n78\t      throw new Error(\n79\t        \"crate.sol_payout: malformed payload — missing crateDropId, userId, wallet, or payoutLamports\",\n80\t      );\n81\t    }\n82\t\n83\t    // 1. Load crate row and check idempotency\n84\t    const crate = await loadCrateDropById(db, crateDropId);\n85\t    if (!crate) {\n86\t      logger.warn(\"crate.sol_payout: crate drop not found\", { crateDropId });\n87\t      return;\n88\t    }\n89\t\n90\t    if (crate.status === \"granted\") {\n91\t      logger.info(\"crate.sol_payout: already granted, skipping\", {\n92\t        crateDropId,\n93\t      });\n94\t      return;\n95\t    }\n96\t\n97\t    if (crate.status === \"failed\") {\n98\t      logger.info(\"crate.sol_payout: permanently failed, skipping\", {\n99\t        crateDropId,\n100\t      });\n101\t      return;\n102\t    }\n103\t\n104\t    // 2. Execute SOL transfer from server keypair to player wallet\n105\t    try {\n106\t      const recipient = new PublicKey(wallet);\n107\t      const lamports = Number(BigInt(payoutLamports));\n108\t\n109\t      const { blockhash, lastValidBlockHeight } =\n110\t        await connection.getLatestBlockhash(\"confirmed\");\n111\t\n112\t      const tx = new Transaction({\n113\t        feePayer: serverKeypair.publicKey,\n114\t        blockhash,\n115\t        lastValidBlockHeight,\n116\t      });\n117\t\n118\t      tx.add(\n119\t        SystemProgram.transfer({\n120\t          fromPubkey: serverKeypair.publicKey,\n121\t          toPubkey: recipient,\n122\t          lamports,\n123\t        }),\n124\t      );\n125\t\n126\t      tx.sign(serverKeypair);\n127\t\n128\t      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n129\t        skipPreflight: false,\n130\t      });\n131\t\n132\t      const confirmation = await connection.confirmTransaction(\n133\t        { signature: txSignature, blockhash, lastValidBlockHeight },\n134\t        \"confirmed\",\n135\t      );\n136\t\n137\t      if (confirmation.value.err) {\n138\t        throw new Error(\n139\t          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n140\t        );\n141\t      }\n142\t\n143\t      // 3. Mark as granted\n144\t      await updateCrateStatus(db, crateDropId, \"granted\");\n145\t      logger.info(\"crate.sol_payout: transfer completed\", {\n146\t        crateDropId,\n147\t        userId,\n148\t        wallet,\n149\t        payoutLamports,\n150\t        txSignature,\n151\t      });\n152\t    } catch (err) {\n153\t      // 4. Transfer failed — mark as failed\n154\t      const errorMsg =\n155\t        err instanceof Error ? err.message : \"Unknown transfer error\";\n156\t      await updateCrateStatus(db, crateDropId, \"failed\");\n157\t      logger.error(\"crate.sol_payout: transfer failed\", {\n158\t        crateDropId,\n159\t        userId,\n160\t        wallet,\n161\t        payoutLamports,\n162\t        error: errorMsg,\n163\t      });\n164\t      // Don't rethrow — failed is a terminal status for M1\n165\t    }\n166\t  };\n167\t}\n168\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"6bc2280c-a53f-43a6-962b-68cad1c02476","timestamp":"2026-04-04T07:58:20.674Z"}
