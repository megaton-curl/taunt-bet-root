{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AgXdLxaLhtom1tFugYJwgS","type":"tool_result","content":"1\t/**\n2\t * GAME_SETTLED handler — the orchestrator for the challenge engine.\n3\t *\n4\t * Processes each player in a settled game event:\n5\t *   1. Quest eligibility check (skip refunded games)\n6\t *   2. Challenge progress evaluation via adapters\n7\t *   3. Reward intent emission on challenge completion\n8\t *   4. Wager-based points grant\n9\t *   5. Crate drop roll\n10\t *\n11\t * Once per round: reward pool funding.\n12\t *\n13\t * Per-player try/catch ensures one player's error doesn't block others.\n14\t * Idempotent via UNIQUE constraints on progress_events, point_grants,\n15\t * crate_drops, and reward_pool_fundings.\n16\t */\n17\t\n18\timport type { Db } from \"../../db.js\";\n19\timport { logger } from \"../../logger.js\";\n20\timport { emitEvent } from \"../emit-event.js\";\n21\timport { EventTypes } from \"../event-types.js\";\n22\timport {\n23\t  questEligible,\n24\t  getAdapter,\n25\t  type GameSettledPayload,\n26\t  type GameSettledPlayer,\n27\t  type ChallengeAssignment,\n28\t} from \"./challenge-adapters.js\";\n29\timport { checkCompletionBonus } from \"./completion-bonus.js\";\n30\timport { advanceOnboardingChain } from \"./onboarding-chain.js\";\n31\t\n32\t// ---------------------------------------------------------------------------\n33\t// DB helpers\n34\t// ---------------------------------------------------------------------------\n35\t\n36\t/** Row shape from the active-assignments + challenges JOIN. */\n37\tinterface AssignmentWithChallenge {\n38\t  id: string;\n39\t  challenge_id: string;\n40\t  action: string;\n41\t  scope: string;\n42\t  condition: string;\n43\t  target: number;\n44\t  progress: number;\n45\t  status: string;\n46\t  period_key: string;\n47\t  campaign_id: string;\n48\t  reward_type: string;\n49\t  reward_amount: number | null;\n50\t}\n51\t\n52\t/**\n53\t * Load active challenge assignments for a user, joined with their challenge\n54\t * definitions. Uses the partial index on (user_id, status) WHERE status='active'.\n55\t */\n56\texport async function getActiveAssignmentsWithChallenge(\n57\t  db: Db,\n58\t  userId: string,\n59\t): Promise<AssignmentWithChallenge[]> {\n60\t  return db.rawSql<AssignmentWithChallenge[]>`\n61\t    SELECT\n62\t      ca.id,\n63\t      ca.challenge_id,\n64\t      c.action,\n65\t      c.scope,\n66\t      c.condition,\n67\t      ca.target,\n68\t      ca.progress,\n69\t      ca.status,\n70\t      ca.period_key,\n71\t      c.campaign_id,\n72\t      c.reward_type,\n73\t      c.reward_amount\n74\t    FROM challenge_assignments ca\n75\t    JOIN challenges c ON c.id = ca.challenge_id\n76\t    WHERE ca.user_id = ${userId}\n77\t      AND ca.status = 'active'\n78\t  `;\n79\t}\n80\t\n81\t/**\n82\t * Insert a progress event. Returns false if a row for this\n83\t * (assignment_id, round_id) already exists (idempotency guard).\n84\t */\n85\texport async function insertProgressEvent(\n86\t  db: Db,\n87\t  assignmentId: string,\n88\t  roundId: string,\n89\t  userId: string,\n90\t  delta: number,\n91\t  metadata: Record<string, unknown>,\n92\t): Promise<boolean> {\n93\t  const rows = await db.rawSql<{ id: string }[]>`\n94\t    INSERT INTO progress_events (assignment_id, round_id, user_id, progress_delta, metadata)\n95\t    VALUES (${assignmentId}, ${roundId}, ${userId}, ${delta}, ${JSON.stringify(metadata)})\n96\t    ON CONFLICT (assignment_id, round_id) DO NOTHING\n97\t    RETURNING id\n98\t  `;\n99\t  return rows.length > 0;\n100\t}\n101\t\n102\t/**\n103\t * Atomically increment an assignment's progress by delta.\n104\t * Returns the new progress value.\n105\t */\n106\texport async function incrementAssignmentProgress(\n107\t  db: Db,\n108\t  assignmentId: string,\n109\t  delta: number,\n110\t): Promise<number> {\n111\t  const rows = await db.rawSql<{ progress: number }[]>`\n112\t    UPDATE challenge_assignments\n113\t    SET progress = progress + ${delta}\n114\t    WHERE id = ${assignmentId}\n115\t    RETURNING progress\n116\t  `;\n117\t  return rows[0]!.progress;\n118\t}\n119\t\n120\t/**\n121\t * Mark an assignment as completed with a timestamp.\n122\t */\n123\texport async function markAssignmentCompleted(\n124\t  db: Db,\n125\t  assignmentId: string,\n126\t): Promise<void> {\n127\t  await db.rawSql`\n128\t    UPDATE challenge_assignments\n129\t    SET status = 'completed', completed_at = now()\n130\t    WHERE id = ${assignmentId}\n131\t  `;\n132\t}\n133\t\n134\t// ---------------------------------------------------------------------------\n135\t// Handler factory\n136\t// ---------------------------------------------------------------------------\n137\t\n138\texport interface GameSettledDeps {\n139\t  db: Db;\n140\t}\n141\t\n142\texport function createGameSettledHandler(deps: GameSettledDeps) {\n143\t  const { db } = deps;\n144\t\n145\t  return async (payload: Record<string, unknown>): Promise<void> => {\n146\t    // Validate and cast payload\n147\t    const roundId = payload.roundId as string;\n148\t    const game = payload.game as string;\n149\t    const players = payload.players as GameSettledPlayer[] | undefined;\n150\t    const feeLamports = payload.feeLamports as string;\n151\t    const settledAt = payload.settledAt as string;\n152\t    const roundPda = payload.roundPda as string;\n153\t\n154\t    if (!roundId || !game || !players || !feeLamports || !settledAt) {\n155\t      throw new Error(\n156\t        \"game.settled: malformed payload — missing roundId, game, players, feeLamports, or settledAt\",\n157\t      );\n158\t    }\n159\t\n160\t    // --- Once per round: emit reward.pool_fund ---\n161\t    await emitEvent(db.rawSql, EventTypes.REWARD_POOL_FUND, {\n162\t      roundId,\n163\t      roundPda,\n164\t      feeLamports,\n165\t    });\n166\t\n167\t    // --- Per-player processing ---\n168\t    for (const player of players) {\n169\t      try {\n170\t        // Quest eligibility gate — skip refunded games\n171\t        if (!questEligible(player)) {\n172\t          logger.debug(\"game.settled: player ineligible (refund)\", {\n173\t            userId: player.userId,\n174\t            roundId,\n175\t          });\n176\t          continue;\n177\t        }\n178\t\n179\t        // ---- Challenge progress evaluation ----\n180\t        const assignments = await getActiveAssignmentsWithChallenge(\n181\t          db,\n182\t          player.userId,\n183\t        );\n184\t\n185\t        for (const assignment of assignments) {\n186\t          const adapter = getAdapter(assignment.action);\n187\t          const challengeAssignment: ChallengeAssignment = {\n188\t            id: Number(assignment.id),\n189\t            challengeId: Number(assignment.challenge_id),\n190\t            action: assignment.action,\n191\t            scope: assignment.scope,\n192\t            condition: assignment.condition,\n193\t            target: assignment.target,\n194\t            progress: assignment.progress,\n195\t            status: assignment.status,\n196\t          };\n197\t\n198\t          const result = adapter(\n199\t            payload as unknown as GameSettledPayload,\n200\t            player,\n201\t            challengeAssignment,\n202\t          );\n203\t\n204\t          if (!result.shouldProgress) continue;\n205\t\n206\t          // Atomic: insert progress event + increment progress\n207\t          await db.withTransaction(async (txDb) => {\n208\t            const inserted = await insertProgressEvent(\n209\t              txDb,\n210\t              assignment.id,\n211\t              roundId,\n212\t              player.userId,\n213\t              result.progressDelta,\n214\t              { game },\n215\t            );\n216\t            if (!inserted) {\n217\t              // Duplicate round for this assignment — skip\n218\t              return;\n219\t            }\n220\t\n221\t            const newProgress = await incrementAssignmentProgress(\n222\t              txDb,\n223\t              assignment.id,\n224\t              result.progressDelta,\n225\t            );\n226\t\n227\t            // Check completion\n228\t            if (newProgress >= assignment.target) {\n229\t              await markAssignmentCompleted(txDb, assignment.id);\n230\t\n231\t              // Emit reward intent based on challenge's reward_type\n232\t              if (assignment.reward_type === \"points\" && assignment.reward_amount) {\n233\t                await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n234\t                  userId: player.userId,\n235\t                  wallet: player.wallet,\n236\t                  sourceType: \"challenge_completed\",\n237\t                  sourceId: `challenge-${assignment.id}`,\n238\t                  amount: assignment.reward_amount.toString(),\n239\t                });\n240\t              } else if (assignment.reward_type === \"crate\") {\n241\t                await emitEvent(txDb.rawSql, EventTypes.CRATE_DROP, {\n242\t                  userId: player.userId,\n243\t                  wallet: player.wallet,\n244\t                  triggerType: \"challenge_completed\",\n245\t                  triggerId: `challenge-${assignment.id}`,\n246\t                });\n247\t              }\n248\t\n249\t              logger.info(\"game.settled: challenge completed\", {\n250\t                userId: player.userId,\n251\t                assignmentId: assignment.id,\n252\t                challengeId: assignment.challenge_id,\n253\t                rewardType: assignment.reward_type,\n254\t              });\n255\t\n256\t              // Check completion bonus (e.g., all daily challenges done → bonus crate)\n257\t              await checkCompletionBonus(\n258\t                txDb,\n259\t                player.userId,\n260\t                player.wallet,\n261\t                assignment.period_key,\n262\t                assignment.campaign_id,\n263\t              );\n264\t\n265\t              // Advance onboarding chain (auto-assign next step)\n266\t              await advanceOnboardingChain(\n267\t                txDb,\n268\t                player.userId,\n269\t                assignment.challenge_id,\n270\t                assignment.period_key,\n271\t              );\n272\t            }\n273\t          });\n274\t        }\n275\t\n276\t        // ---- Wager-based points grant ----\n277\t        await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n278\t          userId: player.userId,\n279\t          wallet: player.wallet,\n280\t          sourceType: \"wager\",\n281\t          sourceId: roundId,\n282\t          amountLamports: player.amountLamports,\n283\t          settledAt,\n284\t        });\n285\t\n286\t        // ---- Crate drop ----\n287\t        await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n288\t          userId: player.userId,\n289\t          wallet: player.wallet,\n290\t          triggerType: \"game_settled\",\n291\t          triggerId: roundId,\n292\t        });\n293\t      } catch (err) {\n294\t        // Per-player try/catch — don't let one player's error block others\n295\t        logger.error(\"game.settled: error processing player\", {\n296\t          userId: player.userId,\n297\t          roundId,\n298\t          error: err instanceof Error ? err.message : String(err),\n299\t        });\n300\t      }\n301\t    }\n302\t\n303\t    logger.info(\"game.settled: processed\", {\n304\t      roundId,\n305\t      game,\n306\t      playerCount: players.length,\n307\t    });\n308\t  };\n309\t}\n310\t"}]},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"96ad433c-23f8-4f48-bc3f-0cb83c5ebcb5","timestamp":"2026-04-04T07:59:29.348Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012UkYyF4gFsBmkyrW1NZB8K","type":"tool_result","content":"1\t/**\n2\t * Close Call clock worker — precise minute-boundary price capture + settlement.\n3\t *\n4\t * Scheduling:\n5\t *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n6\t *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n7\t *   - Caches the boundary price (both close of old candle, open of next)\n8\t *   - Settles any open rounds whose candle has closed\n9\t *   - Schedules next tick at (next minute + 1s)\n10\t *\n11\t * Rounds are created on-demand by the first bettor (via /closecall/bet).\n12\t * On start, loads the latest boundary price from DB to seed the cache.\n13\t */\n14\t\n15\timport { performance } from \"node:perf_hooks\";\n16\timport {\n17\t  Connection,\n18\t  Keypair,\n19\t  PublicKey,\n20\t  Transaction,\n21\t} from \"@solana/web3.js\";\n22\timport type { Db } from \"../db.js\";\n23\timport { logger } from \"../logger.js\";\n24\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n25\timport { getPlatformConfig } from \"../platform-config.js\";\n26\timport {\n27\t  buildCloseCallSettleRoundIx,\n28\t} from \"./settle-tx.js\";\n29\timport { emitEvent } from \"../queue/emit-event.js\";\n30\timport { EventTypes } from \"../queue/event-types.js\";\n31\timport {\n32\t  closeCallRoundDiscriminatorFilter,\n33\t  decodeCloseCallRound,\n34\t} from \"./account-decoder.js\";\n35\timport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n36\t\n37\t/** Close Call on-chain phase values */\n38\tconst PHASE_OPEN = 0;\n39\t\n40\t/** How long to wait after minute boundary before first Hermes poll (ms). */\n41\tconst BOUNDARY_OFFSET_MS = 1_000;\n42\t\n43\t/** Poll Hermes every 1s when waiting for boundary price. */\n44\tconst HERMES_POLL_INTERVAL_MS = 1_000;\n45\t\n46\t/** Max attempts to fetch a fresh boundary price (10s total). */\n47\tconst HERMES_MAX_RETRIES = 10;\n48\t\n49\t/** Maximum retry attempts for a single tx submission. */\n50\tconst MAX_TX_RETRIES = 3;\n51\tconst TX_RETRY_DELAY_MS = 2_000;\n52\t\n53\t// ---------------------------------------------------------------------------\n54\t// Types\n55\t// ---------------------------------------------------------------------------\n56\t\n57\texport interface BoundaryPrice {\n58\t  price: bigint;\n59\t  expo: number;\n60\t  minuteTs: number;\n61\t  priceHuman: number;\n62\t}\n63\t\n64\texport interface CloseCallClockDeps {\n65\t  connection: Connection;\n66\t  serverKeypair: Keypair;\n67\t  /** Typed database client. */\n68\t  db: Db;\n69\t  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n70\t  hermesEndpoint?: string;\n71\t  /** Optional injectable HermesFetcher (for testing). */\n72\t  hermesFetcher?: HermesFetcher;\n73\t}\n74\t\n75\texport interface CloseCallClockWorker {\n76\t  start(): void;\n77\t  stop(): void;\n78\t  readonly isRunning: boolean;\n79\t  /** Run a single tick (exposed for testing). */\n80\t  tick(): Promise<void>;\n81\t  /** Get the most recent minute-boundary price (from cache). */\n82\t  getLatestBoundaryPrice(): BoundaryPrice | null;\n83\t}\n84\t\n85\t// ---------------------------------------------------------------------------\n86\t// Factory\n87\t// ---------------------------------------------------------------------------\n88\t\n89\texport function createCloseCallClockWorker(\n90\t  deps: CloseCallClockDeps,\n91\t): CloseCallClockWorker {\n92\t  const { connection, serverKeypair, hermesEndpoint, db } = deps;\n93\t\n94\t  const hermes: HermesFetcher = deps.hermesFetcher ?? createHermesFetcher(hermesEndpoint);\n95\t\n96\t  let running = false;\n97\t  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n98\t\n99\t  /** Cached latest boundary price (in-memory). */\n100\t  let cachedBoundaryPrice: BoundaryPrice | null = null;\n101\t\n102\t  // -----------------------------------------------------------------------\n103\t  // Scheduling\n104\t  // -----------------------------------------------------------------------\n105\t\n106\t  /** Milliseconds until the next minute boundary + offset. */\n107\t  function msUntilNextBoundary(): number {\n108\t    const now = Date.now();\n109\t    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n110\t    return nextMinute - now + BOUNDARY_OFFSET_MS;\n111\t  }\n112\t\n113\t  // -----------------------------------------------------------------------\n114\t  // Helpers\n115\t  // -----------------------------------------------------------------------\n116\t\n117\t  /** Send a legacy Transaction with retry. Uses the tx's original blockhash for confirmation. */\n118\t  async function sendAndConfirm(\n119\t    tx: Transaction,\n120\t    label: string,\n121\t    txBlockhash: string,\n122\t    txLastValidBlockHeight: number,\n123\t  ): Promise<string> {\n124\t    let lastError: unknown;\n125\t\n126\t    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n127\t      try {\n128\t        const sig = await connection.sendRawTransaction(tx.serialize(), {\n129\t          skipPreflight: false,\n130\t        });\n131\t        const confirmation = await connection.confirmTransaction(\n132\t          { signature: sig, blockhash: txBlockhash, lastValidBlockHeight: txLastValidBlockHeight },\n133\t          \"confirmed\",\n134\t        );\n135\t        if (confirmation.value.err) {\n136\t          throw new Error(\n137\t            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n138\t          );\n139\t        }\n140\t        return sig;\n141\t      } catch (err) {\n142\t        lastError = err;\n143\t        if (attempt < MAX_TX_RETRIES - 1) {\n144\t          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n145\t            error: err instanceof Error ? err.message : String(err),\n146\t          });\n147\t          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n148\t        }\n149\t      }\n150\t    }\n151\t\n152\t    throw lastError;\n153\t  }\n154\t\n155\t  /** Read treasury and feeBps from the shared PlatformConfig account. */\n156\t  async function readPlatformConfig(): Promise<{ treasury: PublicKey; feeBps: number } | null> {\n157\t    try {\n158\t      return await getPlatformConfig(connection);\n159\t    } catch {\n160\t      return null;\n161\t    }\n162\t  }\n163\t\n164\t  // -----------------------------------------------------------------------\n165\t  // Candle DB operations\n166\t  // -----------------------------------------------------------------------\n167\t\n168\t  /** Save a boundary price to the closecall_candles table (upsert). */\n169\t  async function saveBoundaryPrice(\n170\t    minuteTs: number,\n171\t    price: bigint,\n172\t    expo: number,\n173\t    priceHuman: number,\n174\t    hermesVaa: string | null,\n175\t  ): Promise<void> {\n176\t    try {\n177\t      await db.insertCloseCallCandle(minuteTs, price, expo, priceHuman, hermesVaa);\n178\t    } catch (err) {\n179\t      logger.error(\"closecall clock: failed to save boundary price\", {\n180\t        minuteTs,\n181\t        error: err instanceof Error ? err.message : String(err),\n182\t      });\n183\t    }\n184\t  }\n185\t\n186\t  /** Load the latest boundary price from DB (for startup cache seeding). */\n187\t  async function loadLatestBoundaryFromDb(): Promise<void> {\n188\t    try {\n189\t      const candle = await db.getLatestCloseCallCandle();\n190\t      if (candle) {\n191\t        cachedBoundaryPrice = {\n192\t          price: candle.price,\n193\t          expo: candle.expo,\n194\t          minuteTs: candle.minuteTs,\n195\t          priceHuman: candle.priceHuman,\n196\t        };\n197\t        logger.info(\"closecall clock: loaded boundary price from DB\", {\n198\t          minuteTs: cachedBoundaryPrice.minuteTs,\n199\t          priceHuman: cachedBoundaryPrice.priceHuman,\n200\t        });\n201\t      }\n202\t    } catch (err) {\n203\t      logger.warn(\"closecall clock: failed to load boundary price from DB\", {\n204\t        error: err instanceof Error ? err.message : String(err),\n205\t      });\n206\t    }\n207\t  }\n208\t\n209\t  // -----------------------------------------------------------------------\n210\t  // Boundary price capture — poll Hermes until fresh price arrives\n211\t  // -----------------------------------------------------------------------\n212\t\n213\t  /**\n214\t   * Poll Hermes every 1s until we get a price with publishTime >= boundaryTs.\n215\t   * Returns the captured price or null if max retries exceeded.\n216\t   */\n217\t  async function captureBoundaryPrice(\n218\t    boundaryTs: number,\n219\t  ): Promise<BoundaryPrice | null> {\n220\t    for (let attempt = 0; attempt < HERMES_MAX_RETRIES; attempt++) {\n221\t      try {\n222\t        const result = await hermes.fetchLatestBtcPrice();\n223\t        if (result && result.publishTime >= boundaryTs) {\n224\t          const bp: BoundaryPrice = {\n225\t            price: result.price,\n226\t            expo: result.expo,\n227\t            minuteTs: boundaryTs,\n228\t            priceHuman: result.priceHuman,\n229\t          };\n230\t\n231\t          // Save to DB with VAA proof\n232\t          await saveBoundaryPrice(\n233\t            boundaryTs,\n234\t            result.price,\n235\t            result.expo,\n236\t            result.priceHuman,\n237\t            result.vaaBase64,\n238\t          );\n239\t\n240\t          cachedBoundaryPrice = bp;\n241\t\n242\t          logger.info(\"closecall clock: boundary price captured\", {\n243\t            minuteTs: boundaryTs,\n244\t            priceHuman: result.priceHuman,\n245\t            publishTime: result.publishTime,\n246\t            attempts: attempt + 1,\n247\t          });\n248\t\n249\t          return bp;\n250\t        }\n251\t\n252\t        if (result) {\n253\t          logger.debug(\"closecall clock: Hermes price not yet at boundary\", {\n254\t            publishTime: result.publishTime,\n255\t            boundaryTs,\n256\t            attempt: attempt + 1,\n257\t          });\n258\t        }\n259\t      } catch (err) {\n260\t        logger.warn(\"closecall clock: Hermes poll failed\", {\n261\t          attempt: attempt + 1,\n262\t          error: err instanceof Error ? err.message : String(err),\n263\t        });\n264\t      }\n265\t\n266\t      // Wait 1s before next attempt\n267\t      if (attempt < HERMES_MAX_RETRIES - 1) {\n268\t        await new Promise((r) => setTimeout(r, HERMES_POLL_INTERVAL_MS));\n269\t      }\n270\t    }\n271\t\n272\t    logger.warn(\"closecall clock: failed to capture boundary price after max retries\", {\n273\t      boundaryTs,\n274\t    });\n275\t    return null;\n276\t  }\n277\t\n278\t  // -----------------------------------------------------------------------\n279\t  // Round discovery\n280\t  // -----------------------------------------------------------------------\n281\t\n282\t  /**\n283\t   * Discover ALL existing open rounds owned by this server.\n284\t   */\n285\t  async function discoverOpenRounds(): Promise<\n286\t    Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }>\n287\t  > {\n288\t    const results: Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }> = [];\n289\t    try {\n290\t      const accounts = await connection.getProgramAccounts(\n291\t        CLOSECALL_PROGRAM_ID,\n292\t        { filters: [closeCallRoundDiscriminatorFilter()] },\n293\t      );\n294\t\n295\t      const now = Math.floor(Date.now() / 1000);\n296\t\n297\t      for (const { pubkey, account } of accounts) {\n298\t        try {\n299\t          const round = decodeCloseCallRound(Buffer.from(account.data));\n300\t\n301\t          // Skip rounds with garbage minuteTs (old format / random bytes)\n302\t          const ts = Number(round.minuteTs);\n303\t          if (ts < 1700000000 || ts > now + 120) continue;\n304\t\n305\t          if (\n306\t            round.phase === PHASE_OPEN &&\n307\t            round.server.equals(serverKeypair.publicKey)\n308\t          ) {\n309\t            results.push({ pda: pubkey, minuteTs: round.minuteTs, round });\n310\t          }\n311\t        } catch {\n312\t          // Skip undecodeable accounts\n313\t        }\n314\t      }\n315\t    } catch (err) {\n316\t      logger.warn(\"closecall clock: discovery scan failed\", {\n317\t        error: err instanceof Error ? err.message : String(err),\n318\t      });\n319\t    }\n320\t    return results;\n321\t  }\n322\t\n323\t  // -----------------------------------------------------------------------\n324\t  // Settlement\n325\t  // -----------------------------------------------------------------------\n326\t\n327\t  /**\n328\t   * Settle a single round. Returns true on success.\n329\t   */\n330\t  async function settleRound(\n331\t    roundPda: PublicKey,\n332\t    minuteTs: bigint,\n333\t    round: ReturnType<typeof decodeCloseCallRound>,\n334\t  ): Promise<boolean> {\n335\t    try {\n336\t      const nowSec = Math.floor(Date.now() / 1000);\n337\t      const candleCloseTime = Number(minuteTs) + 60;\n338\t\n339\t      if (nowSec < candleCloseTime) {\n340\t        logger.debug(\"closecall clock: candle not closed yet\", {\n341\t          pda: roundPda.toBase58(),\n342\t          secondsRemaining: candleCloseTime - nowSec,\n343\t        });\n344\t        return false;\n345\t      }\n346\t\n347\t      const greenCount = round.greenEntries.length;\n348\t      const redCount = round.redEntries.length;\n349\t      const totalCount = greenCount + redCount;\n350\t\n351\t      // Fetch platform config (treasury + feeBps) + close price\n352\t      const [platformConfig, hermesPrice] = await Promise.all([\n353\t        readPlatformConfig(),\n354\t        hermes.fetchLatestBtcPrice(),\n355\t      ]);\n356\t\n357\t      if (!platformConfig) {\n358\t        logger.error(\"closecall clock: cannot read platform config treasury\");\n359\t        return false;\n360\t      }\n361\t      const { treasury, feeBps } = platformConfig;\n362\t      if (!hermesPrice) {\n363\t        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n364\t        return false;\n365\t      }\n366\t\n367\t      if (totalCount === 0) {\n368\t        logger.info(\"closecall clock: settling empty round\", {\n369\t          pda: roundPda.toBase58(),\n370\t        });\n371\t      }\n372\t\n373\t      // Pre-determine outcome\n374\t      const hasBothSides = greenCount > 0 && redCount > 0;\n375\t      const isRefund =\n376\t        totalCount === 0 ||\n377\t        !hasBothSides ||\n378\t        totalCount === 1 ||\n379\t        hermesPrice.price === round.openPrice;\n380\t\n381\t      let remainingAccounts: PublicKey[];\n382\t      if (isRefund) {\n383\t        remainingAccounts = [\n384\t          ...round.greenEntries.map((e) => e.player),\n385\t          ...round.redEntries.map((e) => e.player),\n386\t        ];\n387\t      } else if (hermesPrice.price > round.openPrice) {\n388\t        remainingAccounts = round.greenEntries.map((e) => e.player);\n389\t      } else {\n390\t        remainingAccounts = round.redEntries.map((e) => e.player);\n391\t      }\n392\t\n393\t      const ix = buildCloseCallSettleRoundIx(\n394\t        serverKeypair.publicKey,\n395\t        minuteTs,\n396\t        hermesPrice.price,\n397\t        hermesPrice.expo,\n398\t        treasury,\n399\t        remainingAccounts,\n400\t      );\n401\t\n402\t      const { blockhash, lastValidBlockHeight } =\n403\t        await connection.getLatestBlockhash();\n404\t      const tx = new Transaction({\n405\t        feePayer: serverKeypair.publicKey,\n406\t        blockhash,\n407\t        lastValidBlockHeight,\n408\t      });\n409\t      tx.add(ix);\n410\t      tx.sign(serverKeypair);\n411\t\n412\t      const sig = await sendAndConfirm(tx, \"settle\", blockhash, lastValidBlockHeight);\n413\t\n414\t      const outcomeStr = isRefund\n415\t        ? \"refund\"\n416\t        : hermesPrice.price > round.openPrice\n417\t          ? \"green\"\n418\t          : \"red\";\n419\t\n420\t      logger.info(\"closecall clock: round settled\", {\n421\t        pda: roundPda.toBase58(),\n422\t        tx: sig,\n423\t        totalEntries: totalCount,\n424\t        outcome: outcomeStr,\n425\t      });\n426\t\n427\t      // Persist settlement to DB (atomic transaction)\n428\t      try {\n429\t        const greenEntries = round.greenEntries.map((e) => ({\n430\t          player: e.player.toBase58(),\n431\t          amountLamports: Number(e.amountLamports),\n432\t        }));\n433\t        const redEntries = round.redEntries.map((e) => ({\n434\t          player: e.player.toBase58(),\n435\t          amountLamports: Number(e.amountLamports),\n436\t        }));\n437\t\n438\t        const totalPool = Number(round.greenPool) + Number(round.redPool);\n439\t        const computedFee = isRefund ? 0 : Math.floor(totalPool * feeBps / 10_000);\n440\t        const netPool = totalPool - computedFee;\n441\t        const roundId = String(Number(minuteTs));\n442\t        const pdaStr = roundPda.toBase58();\n443\t\n444\t        await db.withTransaction(async (txDb) => {\n445\t          // Ensure round record exists\n446\t          await txDb.insertCloseCallRound({\n447\t            roundId,\n448\t            pda: pdaStr,\n449\t            serverKey: serverKeypair.publicKey.toBase58(),\n450\t            openPrice: Number(round.openPrice),\n451\t            openPriceExpo: round.openPriceExpo,\n452\t          });\n453\t\n454\t          // Settle round\n455\t          await txDb.settleCloseCallRound(roundId, {\n456\t            phase: isRefund ? \"refunded\" : \"settled\",\n457\t            outcome: outcomeStr as \"green\" | \"red\" | \"refund\",\n458\t            closePrice: Number(hermesPrice.price),\n459\t            greenPool: Number(round.greenPool),\n460\t            redPool: Number(round.redPool),\n461\t            totalFee: computedFee,\n462\t            settleTx: sig,\n463\t          });\n464\t\n465\t          // Resolve profiles for all participants (used by both tx inserts and game entries)\n466\t          const allEntries = [\n467\t            ...greenEntries.map((e) => ({ ...e, side: \"green\" as const })),\n468\t            ...redEntries.map((e) => ({ ...e, side: \"red\" as const })),\n469\t          ];\n470\t\n471\t          const profileResults = allEntries.length > 0\n472\t            ? await Promise.all(\n473\t                allEntries.map(async (e) => {\n474\t                  const profile = await txDb.getProfileByWallet(e.player);\n475\t                  return [e.player, profile] as const;\n476\t                }),\n477\t              )\n478\t            : [];\n479\t          const profileMap = new Map(\n480\t            profileResults.filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1]),\n481\t          );\n482\t\n483\t          // Transaction rows — real SOL movements\n484\t          const txParams: Array<{\n485\t            userId?: string;\n486\t            wallet: string;\n487\t            game: string;\n488\t            matchId: string;\n489\t            txType: \"deposit\" | \"payout\" | \"refund\";\n490\t            amountLamports: number;\n491\t            txSig: string;\n492\t          }> = [];\n493\t\n494\t          for (const entry of greenEntries) {\n495\t            const userId = profileMap.get(entry.player)?.user_id;\n496\t            if (isRefund) {\n497\t              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n498\t            } else if (outcomeStr === \"green\") {\n499\t              const greenPool = Number(round.greenPool);\n500\t              const payout = greenPool > 0 ? Math.floor((entry.amountLamports / greenPool) * netPool) : 0;\n501\t              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n502\t            }\n503\t          }\n504\t          for (const entry of redEntries) {\n505\t            const userId = profileMap.get(entry.player)?.user_id;\n506\t            if (isRefund) {\n507\t              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n508\t            } else if (outcomeStr === \"red\") {\n509\t              const redPool = Number(round.redPool);\n510\t              const payout = redPool > 0 ? Math.floor((entry.amountLamports / redPool) * netPool) : 0;\n511\t              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n512\t            }\n513\t          }\n514\t\n515\t          if (txParams.length > 0) {\n516\t            await txDb.insertTransactions(txParams);\n517\t          }\n518\t\n519\t          // Game entries — UPSERT with settlement result\n520\t          if (allEntries.length > 0) {\n521\t            const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);\n522\t            if (missingWallets.length > 0) {\n523\t              logger.warn(\"closecall settle: missing profiles for participants — skipping their game entries\", {\n524\t                pda: pdaStr,\n525\t                missingWallets,\n526\t              });\n527\t            }\n528\t            const profileMap = new Map(\n529\t              profileResults\n530\t                .filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1])\n531\t                .map(([w, p]) => [w, p.user_id]),\n532\t            );\n533\t\n534\t            const gameEntries = allEntries\n535\t              .filter((e) => profileMap.has(e.player))\n536\t              .map((e) => {\n537\t                let entryIsWinner: boolean | undefined;\n538\t                let entryPayout: number;\n539\t\n540\t                if (isRefund) {\n541\t                  entryIsWinner = undefined; // null = refund, no winner/loser\n542\t                  entryPayout = e.amountLamports;\n543\t                } else {\n544\t                  const isWinningSide = e.side === outcomeStr;\n545\t                  entryIsWinner = isWinningSide;\n546\t                  if (isWinningSide) {\n547\t                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n548\t                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n549\t                  } else {\n550\t                    entryPayout = 0;\n551\t                  }\n552\t                }\n553\t\n554\t                return {\n555\t                  userId: profileMap.get(e.player)!,\n556\t                  wallet: e.player,\n557\t                  game: \"closecall\",\n558\t                  roundPda: pdaStr,\n559\t                  matchId: roundId,\n560\t                  amountLamports: e.amountLamports,\n561\t                  side: e.side,\n562\t                  isWinner: entryIsWinner,\n563\t                  payoutLamports: entryPayout,\n564\t                  settledAt: new Date(),\n565\t                };\n566\t              });\n567\t\n568\t            if (gameEntries.length > 0) {\n569\t              await txDb.upsertGameEntries(gameEntries);\n570\t            }\n571\t          }\n572\t\n573\t          // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n574\t          if (allEntries.length > 0) {\n575\t            const settledAt = new Date().toISOString();\n576\t            // Build per-player entries; for closecall, no single \"creator\" — first entry is treated as creator\n577\t            const firstPlayer = allEntries[0]?.player;\n578\t\n579\t            const players = allEntries\n580\t              .filter((e) => profileMap.has(e.player))\n581\t              .map((e) => {\n582\t                const userId = profileMap.get(e.player)!.user_id;\n583\t                let entryIsWinner: boolean | null;\n584\t                let entryPayout: number;\n585\t\n586\t                if (isRefund) {\n587\t                  entryIsWinner = null; // null = refund\n588\t                  entryPayout = e.amountLamports;\n589\t                } else {\n590\t                  const isWinningSide = e.side === outcomeStr;\n591\t                  entryIsWinner = isWinningSide;\n592\t                  if (isWinningSide) {\n593\t                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n594\t                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n595\t                  } else {\n596\t                    entryPayout = 0;\n597\t                  }\n598\t                }\n599\t\n600\t                return {\n601\t                  userId,\n602\t                  wallet: e.player,\n603\t                  amountLamports: String(e.amountLamports),\n604\t                  isWinner: entryIsWinner,\n605\t                  payoutLamports: String(entryPayout),\n606\t                  isCreator: e.player === firstPlayer,\n607\t                };\n608\t              });\n609\t\n610\t            if (players.length > 0) {\n611\t              await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n612\t                roundId,\n613\t                roundPda: pdaStr,\n614\t                game: \"closecall\",\n615\t                players,\n616\t                feeLamports: String(computedFee),\n617\t                settledAt,\n618\t              });\n619\t            }\n620\t          }\n621\t        });\n622\t      } catch (dbErr) {\n623\t        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n624\t          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n625\t        });\n626\t      }\n627\t\n628\t      return true;\n629\t    } catch (err) {\n630\t      logger.error(\"closecall clock: settlement failed\", {\n631\t        pda: roundPda.toBase58(),\n632\t        error: err instanceof Error ? err.message : String(err),\n633\t      });\n634\t      return false;\n635\t    }\n636\t  }\n637\t\n638\t  // -----------------------------------------------------------------------\n639\t  // Tick — fires at minute boundary + 1s\n640\t  // -----------------------------------------------------------------------\n641\t\n642\t  async function tick(): Promise<void> {\n643\t    const t0 = performance.now();\n644\t    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n645\t\n646\t    // Step 1: Capture boundary price (poll Hermes until fresh)\n647\t    await captureBoundaryPrice(boundaryTs);\n648\t\n649\t    // Step 2: Discover + settle all open rounds whose candle has closed\n650\t    const openRounds = await discoverOpenRounds();\n651\t\n652\t    for (const { pda, minuteTs, round } of openRounds) {\n653\t      await settleRound(pda, minuteTs, round);\n654\t    }\n655\t\n656\t    const elapsed = Math.round(performance.now() - t0);\n657\t    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n658\t  }\n659\t\n660\t  async function loop(): Promise<void> {\n661\t    if (!running) return;\n662\t    try {\n663\t      await tick();\n664\t    } catch (err) {\n665\t      logger.error(\"closecall clock loop error\", {\n666\t        error: err instanceof Error ? err.message : String(err),\n667\t      });\n668\t    }\n669\t    if (running) {\n670\t      const delay = msUntilNextBoundary();\n671\t      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n672\t      timeoutId = setTimeout(loop, delay);\n673\t    }\n674\t  }\n675\t\n676\t  // -----------------------------------------------------------------------\n677\t  // Public interface\n678\t  // -----------------------------------------------------------------------\n679\t\n680\t  return {\n681\t    start() {\n682\t      if (running) return;\n683\t      running = true;\n684\t\n685\t      logger.info(\"closecall clock started\", {\n686\t        serverKey: serverKeypair.publicKey.toBase58(),\n687\t        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n688\t      });\n689\t\n690\t      // Load latest boundary price from DB, then schedule first tick\n691\t      loadLatestBoundaryFromDb()\n692\t        .then(() => {\n693\t          if (!running) return;\n694\t          const delay = msUntilNextBoundary();\n695\t          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n696\t          timeoutId = setTimeout(loop, delay);\n697\t        })\n698\t        .catch((err) => {\n699\t          logger.error(\"closecall clock: startup init failed\", {\n700\t            error: err instanceof Error ? err.message : String(err),\n701\t          });\n702\t          if (running) {\n703\t            const delay = msUntilNextBoundary();\n704\t            timeoutId = setTimeout(loop, delay);\n705\t          }\n706\t        });\n707\t    },\n708\t\n709\t    stop() {\n710\t      running = false;\n711\t      if (timeoutId) {\n712\t        clearTimeout(timeoutId);\n713\t        timeoutId = null;\n714\t      }\n715\t      logger.info(\"closecall clock stopped\");\n716\t    },\n717\t\n718\t    get isRunning() {\n719\t      return running;\n720\t    },\n721\t\n722\t    tick,\n723\t\n724\t    getLatestBoundaryPrice(): BoundaryPrice | null {\n725\t      return cachedBoundaryPrice;\n726\t    },\n727\t  };\n728\t}\n729\t"}]},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"76ddb535-79d7-4fed-ace8-e81355980dd9","timestamp":"2026-04-04T07:59:29.476Z"}
