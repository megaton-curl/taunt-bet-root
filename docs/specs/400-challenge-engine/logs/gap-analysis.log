etime_earned` = 0 |\n| `point_grants` | 20-30 | PRIMARY KEY: `id` (BIGINT IDENTITY), UNIQUE: `(user_id, source_type, source_id)`, CHECK `source_type` IN (...), INDEX: `idx_point_grants_user_created` |\n| `reward_pool` | 35-41 | PRIMARY KEY: `id` (1 singleton), CHECK `id = 1`, DEFAULT `balance_lamports` = 0, DEFAULT `lifetime_funded` = 0 |\n| `reward_pool_fundings` | 44-50 | PRIMARY KEY: `id` (BIGINT IDENTITY), UNIQUE: `round_id` |\n| `campaigns` | 53-62 | PRIMARY KEY: `id` (BIGINT IDENTITY), UNIQUE: `name`, CHECK `campaign_type` IN ('daily', 'weekly', 'onboarding', 'dogpile'), DEFAULT `is_active` = true |\n| `challenges` | 65-81 | PRIMARY KEY: `id` (BIGINT IDENTITY), FOREIGN KEY: `campaign_id`, FOREIGN KEY: `prerequisite_id` (self-ref), CHECK `scope` IN ('any', 'coinflip', 'lord', 'closecall'), CHECK `reward_type` IN ('points', 'crate'), DEFAULT `is_active` = true |\n| `challenge_assignments` | 84-96 | PRIMARY KEY: `id` (BIGINT IDENTITY), FOREIGN KEY: `challenge_id`, UNIQUE: `(user_id, challenge_id, period_key)`, CHECK `status` IN ('active', 'completed', 'expired'), INDEX: `idx_assignments_active` (WHERE status='active'), INDEX: `idx_assignments_period` |\n| `progress_events` | 102-111 | PRIMARY KEY: `id` (BIGINT IDENTITY), FOREIGN KEY: `assignment_id`, UNIQUE: `(assignment_id, round_id)` |\n| `completion_bonuses` | 114-124 | PRIMARY KEY: `id` (BIGINT IDENTITY), FOREIGN KEY: `campaign_id`, CHECK `reward_type` IN ('points', 'crate') |\n| `bonus_completions` | 127-134 | PRIMARY KEY: `id` (BIGINT IDENTITY), FOREIGN KEY: `bonus_id`, UNIQUE: `(user_id, bonus_id, period_key)` |\n| `crate_drops` | 137-148 | PRIMARY KEY: `id` (BIGINT IDENTITY), CHECK `trigger_type` IN (...), CHECK `crate_type` IN ('points', 'sol'), CHECK `status` IN ('pending', 'granted', 'failed'), UNIQUE: `(user_id, trigger_type, trigger_id)`, INDEX: `idx_crate_drops_user`, INDEX: `idx_crate_drops_pending` |\n| `fraud_flags` | 154-163 | PRIMARY KEY: `id` (BIGINT IDENTITY), DEFAULT `status` = 'open', CHECK