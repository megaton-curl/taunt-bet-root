{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vq5sdXS2GCMot4vASdaJ44","type":"tool_result","content":"1\t/**\n2\t * Admin API routes — reward config, reward pool, campaign/challenge CRUD,\n3\t * and admin-level management.\n4\t *\n5\t * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { Db } from \"../db.js\";\n10\t\n11\t// ---------------------------------------------------------------------------\n12\t// Known config keys — reject unknown keys with 400\n13\t// ---------------------------------------------------------------------------\n14\t\n15\tconst VALID_CONFIG_KEYS = new Set([\n16\t  \"points_per_dollar\",\n17\t  \"dogpile_default_multiplier\",\n18\t  \"reward_pool_fee_share\",\n19\t  \"points_crate_drop_rate\",\n20\t  \"sol_crate_drop_rate\",\n21\t  \"sol_crate_pool_pct\",\n22\t  \"sol_crate_min_value\",\n23\t  \"points_crate_min\",\n24\t  \"points_crate_max\",\n25\t  \"daily_challenge_count\",\n26\t  \"weekly_challenge_count\",\n27\t]);\n28\t\n29\t// ---------------------------------------------------------------------------\n30\t// Route factory\n31\t// ---------------------------------------------------------------------------\n32\t\n33\texport interface AdminRoutesDeps {\n34\t  db: Db;\n35\t  adminApiKey: string;\n36\t}\n37\t\n38\texport function createAdminRoutes(deps: AdminRoutesDeps) {\n39\t  const { db, adminApiKey } = deps;\n40\t  const app = new Hono();\n41\t\n42\t  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n43\t  app.use(\"*\", async (c, next) => {\n44\t    const key = c.req.header(\"X-Admin-Key\");\n45\t    if (!key || key !== adminApiKey) {\n46\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n47\t    }\n48\t    await next();\n49\t  });\n50\t\n51\t  // GET /reward-config — all config key-value pairs\n52\t  app.get(\"/reward-config\", async (c) => {\n53\t    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n54\t      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n55\t    `;\n56\t    const config: Record<string, { value: string; updatedAt: string }> = {};\n57\t    for (const row of rows) {\n58\t      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n59\t    }\n60\t    return c.json(config);\n61\t  });\n62\t\n63\t  // PUT /reward-config/:key — update a single config value\n64\t  app.put(\"/reward-config/:key\", async (c) => {\n65\t    const key = c.req.param(\"key\");\n66\t\n67\t    if (!VALID_CONFIG_KEYS.has(key)) {\n68\t      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n69\t    }\n70\t\n71\t    const body = await c.req.json<{ value?: string }>();\n72\t    if (body.value === undefined || body.value === null) {\n73\t      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n74\t    }\n75\t\n76\t    await db.rawSql`\n77\t      UPDATE reward_config\n78\t      SET value = ${String(body.value)}, updated_at = now()\n79\t      WHERE key = ${key}\n80\t    `;\n81\t\n82\t    return c.json({ key, value: String(body.value) });\n83\t  });\n84\t\n85\t  // GET /reward-pool — current pool state\n86\t  app.get(\"/reward-pool\", async (c) => {\n87\t    const rows = await db.rawSql<{\n88\t      balance_lamports: string;\n89\t      lifetime_funded: string;\n90\t      lifetime_paid: string;\n91\t      updated_at: string;\n92\t    }[]>`\n93\t      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n94\t      FROM reward_pool WHERE id = 1\n95\t    `;\n96\t    if (rows.length === 0) {\n97\t      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n98\t    }\n99\t    const pool = rows[0]!;\n100\t    return c.json({\n101\t      balanceLamports: pool.balance_lamports,\n102\t      lifetimeFunded: pool.lifetime_funded,\n103\t      lifetimePaid: pool.lifetime_paid,\n104\t      updatedAt: pool.updated_at,\n105\t    });\n106\t  });\n107\t\n108\t  // -------------------------------------------------------------------------\n109\t  // Campaign CRUD\n110\t  // -------------------------------------------------------------------------\n111\t\n112\t  const VALID_CAMPAIGN_TYPES = new Set([\"daily\", \"weekly\", \"onboarding\", \"dogpile\"]);\n113\t\n114\t  // POST /campaigns — create a campaign\n115\t  app.post(\"/campaigns\", async (c) => {\n116\t    const body = await c.req.json<{\n117\t      name?: string;\n118\t      campaignType?: string;\n119\t      startsAt?: string | null;\n120\t      endsAt?: string | null;\n121\t      config?: Record<string, unknown>;\n122\t    }>();\n123\t\n124\t    if (!body.name || typeof body.name !== \"string\") {\n125\t      return c.json({ error: \"MISSING_FIELD\", message: \"name is required\" }, 400);\n126\t    }\n127\t    if (!body.campaignType || !VALID_CAMPAIGN_TYPES.has(body.campaignType)) {\n128\t      return c.json(\n129\t        { error: \"INVALID_CAMPAIGN_TYPE\", message: `campaign_type must be one of: ${[...VALID_CAMPAIGN_TYPES].join(\", \")}` },\n130\t        400,\n131\t      );\n132\t    }\n133\t\n134\t    const startsAt = body.startsAt ?? null;\n135\t    const endsAt = body.endsAt ?? null;\n136\t    const config = JSON.stringify(body.config ?? {});\n137\t\n138\t    const rows = await db.rawSql<{ id: string; name: string; campaign_type: string; starts_at: string | null; ends_at: string | null; is_active: boolean; config: string; created_at: string }[]>`\n139\t      INSERT INTO campaigns (name, campaign_type, starts_at, ends_at, config)\n140\t      VALUES (${body.name}, ${body.campaignType}, ${startsAt}, ${endsAt}, ${config}::jsonb)\n141\t      RETURNING id, name, campaign_type, starts_at, ends_at, is_active, config, created_at\n142\t    `;\n143\t\n144\t    const row = rows[0]!;\n145\t    return c.json({\n146\t      id: row.id,\n147\t      name: row.name,\n148\t      campaignType: row.campaign_type,\n149\t      startsAt: row.starts_at,\n150\t      endsAt: row.ends_at,"}]},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"2743d662-a59e-4359-964b-790b1665463a","timestamp":"2026-04-04T07:59:34.050Z"}
{"type":"user","message":{"role":"user","content":[{"type":"text","text":"I need to check if any fraud flag logic is implemented in the challenge engine. This is RESEARCH only — do not write files.\n\nSearch the backend codebase for:\n1. Any reference to `fraud_flags` table beyond the migration CREATE TABLE\n2. Any code that inserts into `fraud_flags`\n3. Any velocity checking or repeated opponent detection logic\n4. Any code referencing `fraud` or `advisory` signals\n\nAlso check:\n5. Does the `unique_game_types` condition work in the challenge adapters? How does the game_completed adapter handle this condition type? Look in `backend/services/backend/src/queue/handlers/challenge-adapters.ts` and `backend/services/backend/src/queue/handlers/game-settled.ts`.\n\n6. Are there any references to `unique_game_types` or `condition` field in the challenge evaluation logic?\n\nReport findings with file paths and line numbers."}]},"parent_tool_use_id":"toolu_01Xu4dck7eSJFViD8bAUTcD5","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"490799c4-bdd2-414d-a4ce-390b827e3ced","timestamp":"2026-04-04T07:59:33.986Z"}
