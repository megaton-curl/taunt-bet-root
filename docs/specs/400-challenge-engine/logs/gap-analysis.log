{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WSaaGeXfkY2gdzaNpQfRRp","type":"tool_result","content":"230\t  app.post(\"/challenges\", async (c) => {\n231\t    const body = await c.req.json<{\n232\t      campaignId?: number;\n233\t      title?: string;\n234\t      description?: string;\n235\t      action?: string;\n236\t      scope?: string;\n237\t      condition?: string;\n238\t      threshold?: number;\n239\t      rewardType?: string;\n240\t      rewardAmount?: number | null;\n241\t      prerequisiteId?: number | null;\n242\t      sortOrder?: number;\n243\t    }>();\n244\t\n245\t    if (!body.campaignId) {\n246\t      return c.json({ error: \"MISSING_FIELD\", message: \"campaignId is required\" }, 400);\n247\t    }\n248\t    if (!body.title || typeof body.title !== \"string\") {\n249\t      return c.json({ error: \"MISSING_FIELD\", message: \"title is required\" }, 400);\n250\t    }\n251\t    if (!body.action || typeof body.action !== \"string\") {\n252\t      return c.json({ error: \"MISSING_FIELD\", message: \"action is required\" }, 400);\n253\t    }\n254\t    if (!body.threshold || typeof body.threshold !== \"number\") {\n255\t      return c.json({ error: \"MISSING_FIELD\", message: \"threshold is required\" }, 400);\n256\t    }\n257\t    if (!body.rewardType || !VALID_REWARD_TYPES.has(body.rewardType)) {\n258\t      return c.json({ error: \"INVALID_REWARD_TYPE\", message: `reward_type must be one of: ${[...VALID_REWARD_TYPES].join(\", \")}` }, 400);\n259\t    }\n260\t    if (body.scope && !VALID_SCOPES.has(body.scope)) {\n261\t      return c.json({ error: \"INVALID_SCOPE\", message: `scope must be one of: ${[...VALID_SCOPES].join(\", \")}` }, 400);\n262\t    }\n263\t\n264\t    // Validate campaign exists\n265\t    const campRows = await db.rawSql<{ id: string }[]>`SELECT id FROM campaigns WHERE id = ${body.campaignId}`;\n266\t    if (campRows.length === 0) {\n267\t      return c.json({ error: \"CAMPAIGN_NOT_FOUND\", message: `Campaign ${body.campaignId} not found` }, 400);\n268\t    }\n269\t\n270\t    const scope = body.scope ?? \"any\";\n271\t    const condition = body.condition ?? \"count\";\n272\t    const description = body.description ?? null;\n273\t    const rewardAmount = body.rewardAmount ?? null;\n274\t    const prerequisiteId = body.prerequisiteId ?? null;\n275\t    const sortOrder = body.sortOrder ?? 0;\n276\t\n277\t    const rows = await db.rawSql<{\n278\t      id: string; campaign_id: string; title: string; description: string | null;\n279\t      action: string; scope: string; condition: string; threshold: number;\n280\t      reward_type: string; reward_amount: number | null; prerequisite_id: string | null;\n281\t      sort_order: number; is_active: boolean; created_at: string;\n282\t    }[]>`\n283\t      INSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order)\n284\t      VALUES (${body.campaignId}, ${body.title}, ${description}, ${body.action}, ${scope}, ${condition}, ${body.threshold}, ${body.rewardType}, ${rewardAmount}, ${prerequisiteId}, ${sortOrder})\n285\t      RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order, is_active, created_at\n286\t    `;\n287\t\n288\t    const row = rows[0]!;\n289\t    return c.json({\n290\t      id: row.id,\n291\t      campaignId: row.campaign_id,\n292\t      title: row.title,\n293\t      description: row.description,\n294\t      action: row.action,\n295\t      scope: row.scope,\n296\t      condition: row.condition,\n297\t      threshold: row.threshold,\n298\t      rewardType: row.reward_type,\n299\t      rewardAmount: row.reward_amount,\n300\t      prerequisiteId: row.prerequisite_id,\n301\t      sortOrder: row.sort_order,\n302\t      isActive: row.is_active,\n303\t      createdAt: row.created_at,\n304\t    }, 201);\n305\t  });\n306\t\n307\t  // PUT /challenges/:id — update a challenge (toggle is_active, update fields)\n308\t  app.put(\"/challenges/:id\", async (c) => {\n309\t    const id = c.req.param(\"id\");\n310\t\n311\t    const body = await c.req.json<{\n312\t      title?: string;\n313\t      description?: string | null;\n314\t      action?: string;\n315\t      scope?: string;\n316\t      condition?: string;\n317\t      threshold?: number;\n318\t      rewardType?: string;\n319\t      rewardAmount?: number | null;\n320\t      sortOrder?: number;\n321\t      isActive?: boolean;\n322\t    }>();\n323\t\n324\t    // Validate scope if provided\n325\t    if (body.scope !== undefined && !VALID_SCOPES.has(body.scope)) {\n326\t      return c.json({ error: \"INVALID_SCOPE\", message: `scope must be one of: ${[...VALID_SCOPES].join(\", \")}` }, 400);\n327\t    }\n328\t    // Validate rewardType if provided\n329\t    if (body.rewardType !== undefined && !VALID_REWARD_TYPES.has(body.rewardType)) {\n330\t      return c.json({ error: \"INVALID_REWARD_TYPE\", message: `reward_type must be one of: ${[...VALID_REWARD_TYPES].join(\", \")}` }, 400);\n331\t    }\n332\t\n333\t    const setClauses: string[] = [];\n334\t    const values: unknown[] = [];\n335\t\n336\t    if (body.title !== undefined) {\n337\t      values.push(body.title);\n338\t      setClauses.push(`title = $${values.length}`);\n339\t    }\n340\t    if (body.description !== undefined) {\n341\t      values.push(body.description);\n342\t      setClauses.push(`description = $${values.length}`);\n343\t    }\n344\t    if (body.action !== undefined) {\n345\t      values.push(body.action);\n346\t      setClauses.push(`action = $${values.length}`);\n347\t    }\n348\t    if (body.scope !== undefined) {\n349\t      values.push(body.scope);\n350\t      setClauses.push(`scope = $${values.length}`);\n351\t    }\n352\t    if (body.condition !== undefined) {\n353\t      values.push(body.condition);\n354\t      setClauses.push(`condition = $${values.length}`);\n355\t    }\n356\t    if (body.threshold !== undefined) {\n357\t      values.push(body.threshold);\n358\t      setClauses.push(`threshold = $${values.length}`);\n359\t    }\n360\t    if (body.rewardType !== undefined) {\n361\t      values.push(body.rewardType);\n362\t      setClauses.push(`reward_type = $${values.length}`);\n363\t    }\n364\t    if (body.rewardAmount !== undefined) {\n365\t      values.push(body.rewardAmount);\n366\t      setClauses.push(`reward_amount = $${values.length}`);\n367\t    }\n368\t    if (body.sortOrder !== undefined) {\n369\t      values.push(body.sortOrder);\n370\t      setClauses.push(`sort_order = $${values.length}`);\n371\t    }\n372\t    if (body.isActive !== undefined) {\n373\t      values.push(body.isActive);\n374\t      setClauses.push(`is_active = $${values.length}`);\n375\t    }\n376\t\n377\t    if (setClauses.length === 0) {\n378\t      return c.json({ error: \"NO_FIELDS\", message: \"No fields to update\" }, 400);\n379\t    }"}]},"parent_tool_use_id":"toolu_01Xu4dck7eSJFViD8bAUTcD5","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"c4196979-8861-496f-9c3b-0c4ab1108777","timestamp":"2026-04-04T08:00:19.045Z"}
