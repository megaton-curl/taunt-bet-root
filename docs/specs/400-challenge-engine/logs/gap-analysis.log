points\");\n3245\t    expect(body.rewardAmount).toBe(500);\n3246\t    expect(body.isActive).toBe(true);\n3247\t    expect(body.campaignId).toBe(String(camp.id));\n3248\t  });\n3249\t\n3250\t  it(\"POST /admin/challenges rejects invalid scope\", async () => {\n3251\t    // Use an existing seeded campaign (daily)\n3252\t    const camps = await rawSql`SELECT id FROM campaigns WHERE campaign_type = 'daily' LIMIT 1`;\n3253\t    const campId = camps[0]!.id;\n3254\t\n3255\t    const res = await adminApp.request(\"/admin/challenges\", {\n3256\t      method: \"POST\",\n3257\t      headers: {\n3258\t        \"X-Admin-Key\": ADMIN_KEY,\n3259\t        \"Content-Type\": \"application/json\",\n3260\t      },\n3261\t      body: JSON.stringify({\n3262\t        campaignId: Number(campId),\n3263\t        title: \"Bad scope challenge\",\n3264\t        action: \"game_completed\",\n3265\t        scope: \"poker\",\n3266\t        threshold: 1,\n3267\t        rewardType: \"points\",\n3268\t      }),\n3269\t    });\n3270\t    expect(res.status).toBe(400);\n3271\t    const body = (await res.json()) as Record<string, any>;\n3272\t    expect(body.error).toBe(\"INVALID_SCOPE\");\n3273\t  });\n3274\t\n3275\t  it(\"POST /admin/challenges rejects nonexistent campaign\", async () => {\n3276\t    const res = await adminApp.request(\"/admin/challenges\", {\n3277\t      method: \"POST\",\n3278\t      headers: {\n3279\t        \"X-Admin-Key\": ADMIN_KEY,\n3280\t        \"Content-Type\": \"application/json\",\n3281\t      },\n3282\t      body: JSON.stringify({\n3283\t        campaignId: 99999,\n3284\t        title: \"Orphan challenge\",\n3285\t        action: \"game_completed\",\n3286\t        threshold: 1,\n3287\t        rewardType: \"points\",\n3288\t      }),\n3289\t    });\n3290\t    expect(res.status).toBe(400);\n3291\t    const body = (await res.json()) as Record<string, any>;\n3292\t    expect(body.error).toBe(\"CAMPAIGN_NOT_FOUND\");\n3293\t  });\n3294\t\n3295\t  it(\"PUT /admin/challenges/:id updates challenge fields\", async () => {\n3296\t    // Create campaign + challenge\n3297\t    const campRes = await adminApp.request(\"/admin/campaigns\", {\n3298\t      method: \"POST\",\n3299\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },"}]},"parent_tool_use_id":"toolu_01X5MGk2evkgm4qCC3F7gqR6","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"1a43a9bc-4ad0-479b-b40f-5c6a68c81a61","timestamp":"2026-04-04T07:58:27.205Z"}
