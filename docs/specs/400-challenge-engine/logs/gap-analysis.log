{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018pMETMmjWwuKqySG4Zci7f","type":"tool_result","content":"1\t/**\n2\t * Integration tests for the event queue worker.\n3\t *\n4\t * Tests the full lifecycle: emit → worker poll → handler dispatch → status transitions.\n5\t * Requires a running Postgres database (same as backend).\n6\t *\n7\t * Covers:\n8\t * 1. Happy path — handler called, event status = completed\n9\t * 2. Failure → retry → dead — attempts increment, backoff applied, final status = dead\n10\t * 3. Concurrent safety — two workers, SKIP LOCKED, each event processed exactly once\n11\t */\n12\t\n13\timport {\n14\t  describe,\n15\t  it,\n16\t  beforeAll,\n17\t  afterAll,\n18\t  beforeEach,\n19\t  expect,\n20\t} from \"vitest\";\n21\timport postgres from \"postgres\";\n22\timport { emitEvent } from \"../emit-event.js\";\n23\timport {\n24\t  registerHandler,\n25\t  clearHandlers,\n26\t} from \"../handler-registry.js\";\n27\timport { EventTypes } from \"../event-types.js\";\n28\timport { createEventWorker } from \"../worker.js\";\n29\t\n30\t/** Poll until condition is true or timeout. */\n31\tasync function waitFor(\n32\t  condition: () => boolean,\n33\t  timeoutMs: number,\n34\t): Promise<void> {\n35\t  const start = Date.now();\n36\t  while (!condition()) {\n37\t    if (Date.now() - start > timeoutMs) {\n38\t      throw new Error(`waitFor timed out after ${timeoutMs}ms`);\n39\t    }\n40\t    await new Promise((r) => setTimeout(r, 50));\n41\t  }\n42\t}\n43\t\n44\tdescribe(\"event queue integration tests\", () => {\n45\t  let sql: ReturnType<typeof postgres>;\n46\t\n47\t  beforeAll(async () => {\n48\t    sql = process.env.DATABASE_URL\n49\t      ? postgres(process.env.DATABASE_URL)\n50\t      : postgres({\n51\t          host: \"/var/run/postgresql\",\n52\t          database: \"rng_utopia_dev\",\n53\t          username: \"vscode\",\n54\t        });\n55\t  });\n56\t\n57\t  afterAll(async () => {\n58\t    await sql.end();\n59\t  });\n60\t\n61\t  beforeEach(async () => {\n62\t    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n63\t    clearHandlers();\n64\t  });\n65\t\n66\t  // -------------------------------------------------------------------------\n67\t  // 1. Happy path\n68\t  // -------------------------------------------------------------------------\n69\t\n70\t  it(\"happy path: handler called and event status = completed\", async () => {\n71\t    let handlerCalled = false;\n72\t    let capturedPayload: Record<string, unknown> | null = null;\n73\t\n74\t    registerHandler(EventTypes.REFERRAL_GAME_SETTLED, async (payload) => {\n75\t      handlerCalled = true;\n76\t      capturedPayload = payload;\n77\t    });\n78\t\n79\t    const payload = { referrerWallet: \"abc\", roundId: \"test-round\" };\n80\t    await sql.begin(async (tx) => {\n81\t      await emitEvent(\n82\t        tx as unknown as postgres.Sql,\n83\t        EventTypes.REFERRAL_GAME_SETTLED,\n84\t        payload,\n85\t      );\n86\t    });\n87\t\n88\t    const worker = createEventWorker(sql, { pollIntervalMs: 100 });\n89\t    worker.start();\n90\t\n91\t    // Wait for handler to be called (up to 3s)\n92\t    await waitFor(() => handlerCalled, 3000);\n93\t    worker.stop();\n94\t\n95\t    expect(handlerCalled).toBe(true);\n96\t    expect(capturedPayload).toEqual(payload);\n97\t\n98\t    // Verify DB status\n99\t    const rows = await sql`SELECT * FROM event_queue WHERE status = 'completed'`;\n100\t    expect(rows).toHaveLength(1);\n101\t    expect(rows[0]!.event_type).toBe(\"referral.game_settled\");\n102\t    expect(rows[0]!.completed_at).toBeInstanceOf(Date);\n103\t  });\n104\t\n105\t  // -------------------------------------------------------------------------\n106\t  // 2. Failure → retry → dead\n107\t  // -------------------------------------------------------------------------\n108\t\n109\t  it(\"failure → retry → dead after max_attempts\", async () => {\n110\t    let callCount = 0;\n111\t\n112\t    registerHandler(EventTypes.REFERRAL_CODE_APPLIED, async () => {\n113\t      callCount++;\n114\t      throw new Error(\"simulated failure\");\n115\t    });\n116\t\n117\t    await sql.begin(async (tx) => {\n118\t      await emitEvent(\n119\t        tx as unknown as postgres.Sql,\n120\t        EventTypes.REFERRAL_CODE_APPLIED,\n121\t        { test: true },\n122\t        { maxAttempts: 3 },\n123\t      );\n124\t    });\n125\t\n126\t    const worker = createEventWorker(sql);\n127\t\n128\t    // Attempt 1 — fails → pending with backoff\n129\t    await worker.poll();\n130\t    expect(callCount).toBe(1);\n131\t    let rows = await sql`SELECT * FROM event_queue`;\n132\t    expect(rows[0]!.status).toBe(\"pending\");\n133\t    expect(rows[0]!.attempts).toBe(1);\n134\t    expect(rows[0]!.error).toBe(\"simulated failure\");\n135\t\n136\t    // Reset scheduled_at so next poll picks it up immediately\n137\t    await sql`UPDATE event_queue SET scheduled_at = now()`;\n138\t\n139\t    // Attempt 2 — fails → pending with backoff\n140\t    await worker.poll();\n141\t    expect(callCount).toBe(2);\n142\t    rows = await sql`SELECT * FROM event_queue`;\n143\t    expect(rows[0]!.status).toBe(\"pending\");\n144\t    expect(rows[0]!.attempts).toBe(2);\n145\t\n146\t    // Reset scheduled_at for final attempt\n147\t    await sql`UPDATE event_queue SET scheduled_at = now()`;\n148\t\n149\t    // Attempt 3 — fails → dead (max_attempts reached)\n150\t    await worker.poll();\n151\t    expect(callCount).toBe(3);\n152\t    rows = await sql`SELECT * FROM event_queue`;\n153\t    expect(rows[0]!.status).toBe(\"dead\");\n154\t    expect(rows[0]!.attempts).toBe(3);\n155\t    expect(rows[0]!.error).toBe(\"simulated failure\");\n156\t    expect(rows[0]!.completed_at).toBeInstanceOf(Date);\n157\t  });\n158\t\n159\t  // -------------------------------------------------------------------------\n160\t  // 3. Concurrent safety — SKIP LOCKED\n161\t  // -------------------------------------------------------------------------\n162\t\n163\t  it(\"concurrent safety: two workers, each event processed exactly once\", async () => {\n164\t    let callCount = 0;\n165\t\n166\t    registerHandler(EventTypes.REFERRAL_CLAIM_REQUESTED, async () => {\n167\t      // Small delay to simulate real work and increase overlap window\n168\t      await new Promise((r) => setTimeout(r, 50));\n169\t      callCount++;\n170\t    });\n171\t\n172\t    // Emit 5 events\n173\t    for (let i = 0; i < 5; i++) {\n174\t      await sql.begin(async (tx) => {\n175\t        await emitEvent(\n176\t          tx as unknown as postgres.Sql,\n177\t          EventTypes.REFERRAL_CLAIM_REQUESTED,\n178\t          { index: i },\n179\t        );\n180\t      });\n181\t    }\n182\t\n183\t    const worker1 = createEventWorker(sql, { batchSize: 5 });\n184\t    const worker2 = createEventWorker(sql, { batchSize: 5 });\n185\t\n186\t    // Both poll simultaneously — SKIP LOCKED ensures no double-processing\n187\t    await Promise.all([worker1.poll(), worker2.poll()]);\n188\t\n189\t    expect(callCount).toBe(5);\n190\t\n191\t    const completed = await sql`SELECT * FROM event_queue WHERE status = 'completed'`;\n192\t    expect(completed).toHaveLength(5);\n193\t  });\n194\t});\n195\t"}]},"parent_tool_use_id":"toolu_01X5MGk2evkgm4qCC3F7gqR6","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"925920d4-643c-47e7-b580-5f1c2cb4ee1f","timestamp":"2026-04-04T07:58:18.944Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T9TiqcAvCoW2Y95VsMenCg","type":"tool_result","content":"1\t/**\n2\t * REWARD_POOL_FUND handler — allocates a share of game fees to the reward pool.\n3\t *\n4\t * Emitted once per settled round. Calculates `floor(feeLamports * reward_pool_fee_share)`\n5\t * and credits the reward pool accounting ledger. Idempotent via UNIQUE(round_id)\n6\t * on reward_pool_fundings.\n7\t */\n8\t\n9\timport type { Db } from \"../../db.js\";\n10\timport { logger } from \"../../logger.js\";\n11\t\n12\t// ---------------------------------------------------------------------------\n13\t// DB helpers\n14\t// ---------------------------------------------------------------------------\n15\t\n16\t/** Read a single reward_config value by key. */\n17\texport async function readRewardConfig(\n18\t  db: Db,\n19\t  key: string,\n20\t): Promise<string | null> {\n21\t  const rows = await db.rawSql<{ value: string }[]>`\n22\t    SELECT value FROM reward_config WHERE key = ${key}\n23\t  `;\n24\t  return rows.length > 0 ? rows[0]!.value : null;\n25\t}\n26\t\n27\t/**\n28\t * Insert a pool funding record. Returns false if a row for this round_id\n29\t * already exists (idempotency guard).\n30\t */\n31\texport async function insertPoolFunding(\n32\t  db: Db,\n33\t  roundId: string,\n34\t  feeLamports: bigint,\n35\t  fundedLamports: bigint,\n36\t): Promise<boolean> {\n37\t  const rows = await db.rawSql<{ id: string }[]>`\n38\t    INSERT INTO reward_pool_fundings (round_id, fee_lamports, funded_lamports)\n39\t    VALUES (${roundId}, ${feeLamports}, ${fundedLamports})\n40\t    ON CONFLICT (round_id) DO NOTHING\n41\t    RETURNING id\n42\t  `;\n43\t  return rows.length > 0;\n44\t}\n45\t\n46\t/**\n47\t * Atomically increment reward_pool.balance_lamports and lifetime_funded.\n48\t */\n49\texport async function incrementRewardPool(\n50\t  db: Db,\n51\t  deltaLamports: bigint,\n52\t): Promise<void> {\n53\t  await db.rawSql`\n54\t    UPDATE reward_pool\n55\t    SET balance_lamports = balance_lamports + ${deltaLamports},\n56\t        lifetime_funded  = lifetime_funded + ${deltaLamports},\n57\t        updated_at       = now()\n58\t    WHERE id = 1\n59\t  `;\n60\t}\n61\t\n62\t// ---------------------------------------------------------------------------\n63\t// Handler factory\n64\t// ---------------------------------------------------------------------------\n65\t\n66\texport interface RewardPoolFundDeps {\n67\t  db: Db;\n68\t}\n69\t\n70\texport function createRewardPoolFundHandler(deps: RewardPoolFundDeps) {\n71\t  const { db } = deps;\n72\t\n73\t  return async (payload: Record<string, unknown>): Promise<void> => {\n74\t    const roundId = payload.roundId as string;\n75\t    const feeLamportsStr = payload.feeLamports as string;\n76\t\n77\t    if (!roundId || !feeLamportsStr) {\n78\t      throw new Error(\n79\t        \"reward.pool_fund: malformed payload — missing roundId or feeLamports\",\n80\t      );\n81\t    }\n82\t\n83\t    const feeLamports = BigInt(feeLamportsStr);\n84\t\n85\t    // Read fee share from config\n86\t    const shareStr = await readRewardConfig(db, \"reward_pool_fee_share\");\n87\t    if (!shareStr) {\n88\t      logger.warn(\"reward.pool_fund: reward_pool_fee_share not configured, skipping\", { roundId });\n89\t      return;\n90\t    }\n91\t    const share = parseFloat(shareStr);\n92\t    if (Number.isNaN(share) || share <= 0) {\n93\t      logger.warn(\"reward.pool_fund: invalid reward_pool_fee_share\", { roundId, shareStr });\n94\t      return;\n95\t    }\n96\t\n97\t    // Calculate funded amount: floor(feeLamports * share)\n98\t    // Use Number for the multiplication since share is a float, then BigInt the floor\n99\t    const fundedLamports = BigInt(Math.floor(Number(feeLamports) * share));\n100\t\n101\t    if (fundedLamports <= 0n) {\n102\t      logger.debug(\"reward.pool_fund: funded amount is zero, skipping\", { roundId, feeLamports: feeLamportsStr });\n103\t      return;\n104\t    }\n105\t\n106\t    // Run within a transaction for atomicity\n107\t    await db.withTransaction(async (txDb) => {\n108\t      // Insert funding record (idempotency guard)\n109\t      const inserted = await insertPoolFunding(txDb, roundId, feeLamports, fundedLamports);\n110\t      if (!inserted) {\n111\t        logger.info(\"reward.pool_fund: duplicate round_id, skipping\", { roundId });\n112\t        return;\n113\t      }\n114\t\n115\t      // Increment pool balance\n116\t      await incrementRewardPool(txDb, fundedLamports);\n117\t\n118\t      logger.info(\"reward.pool_fund: pool funded\", {\n119\t        roundId,\n120\t        feeLamports: feeLamportsStr,\n121\t        fundedLamports: fundedLamports.toString(),\n122\t        share,\n123\t      });\n124\t    });\n125\t  };\n126\t}\n127\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"41a40bab-265e-4574-96d1-2caf2e979d41","timestamp":"2026-04-04T07:58:18.858Z"}
{"type":"system","subtype":"task_progress","task_id":"a16ed38eec1467800","tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","description":"Reading backend/services/backend/src/queue/handlers/points-grant.ts","usage":{"total_tokens":32440,"tool_uses":10,"duration_ms":22517},"last_tool_name":"Read","uuid":"9a64fef7-1902-4fbf-a0d2-25ac1ffb729b","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01EAEvrAx25BeKcTLeBh2HrR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MvwSfi9NK5e7oZdx2XsdKC","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/points-grant.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":418,"cache_creation_input_tokens":1713,"cache_read_input_tokens":30282,"cache_creation":{"ephemeral_5m_input_tokens":1713,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"a8966cba-c10d-4443-8cf0-edc4ffeb9f83"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MvwSfi9NK5e7oZdx2XsdKC","type":"tool_result","content":"1\t/**\n2\t * POINTS_GRANT handler — awards points to a player.\n3\t *\n4\t * For wager-based grants: converts lamports → USD → points using config rate\n5\t * and applies any active Dogpile multiplier.\n6\t * For pre-calculated grants (crate_points, challenge_completed, bonus_completed):\n7\t * uses the `amount` field directly.\n8\t *\n9\t * Idempotent via UNIQUE(user_id, source_type, source_id) on point_grants.\n10\t */\n11\t\n12\timport type { Db } from \"../../db.js\";\n13\timport { logger } from \"../../logger.js\";\n14\timport { readRewardConfig } from \"./reward-pool-fund.js\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// DB helpers\n18\t// ---------------------------------------------------------------------------\n19\t\n20\t/**\n21\t * Insert a point grant ledger row. Returns false if a row for this\n22\t * (user_id, source_type, source_id) already exists (idempotency guard).\n23\t */\n24\texport async function insertPointGrant(\n25\t  db: Db,\n26\t  userId: string,\n27\t  wallet: string,\n28\t  sourceType: string,\n29\t  sourceId: string,\n30\t  amount: bigint,\n31\t  metadata: Record<string, unknown>,\n32\t): Promise<boolean> {\n33\t  const rows = await db.rawSql<{ id: string }[]>`\n34\t    INSERT INTO point_grants (user_id, wallet, source_type, source_id, amount, metadata)\n35\t    VALUES (${userId}, ${wallet}, ${sourceType}, ${sourceId}, ${amount}, ${JSON.stringify(metadata)})\n36\t    ON CONFLICT (user_id, source_type, source_id) DO NOTHING\n37\t    RETURNING id\n38\t  `;\n39\t  return rows.length > 0;\n40\t}\n41\t\n42\t/**\n43\t * Create or increment player_points. Uses upsert pattern so the first\n44\t * grant for a user creates the row.\n45\t */\n46\texport async function upsertPlayerPoints(\n47\t  db: Db,\n48\t  userId: string,\n49\t  wallet: string,\n50\t  amount: bigint,\n51\t): Promise<void> {\n52\t  await db.rawSql`\n53\t    INSERT INTO player_points (user_id, wallet, balance, lifetime_earned, updated_at)\n54\t    VALUES (${userId}, ${wallet}, ${amount}, ${amount}, now())\n55\t    ON CONFLICT (user_id) DO UPDATE SET\n56\t      balance         = player_points.balance + ${amount},\n57\t      lifetime_earned = player_points.lifetime_earned + ${amount},\n58\t      updated_at      = now()\n59\t  `;\n60\t}\n61\t\n62\t/**\n63\t * Returns the multiplier for the currently active Dogpile event, or 1 if\n64\t * none is active.\n65\t */\n66\texport async function getActiveDogpileMultiplier(\n67\t  db: Db,\n68\t  timestamp: Date,\n69\t): Promise<number> {\n70\t  const rows = await db.rawSql<{ multiplier: string }[]>`\n71\t    SELECT multiplier FROM dogpile_events\n72\t    WHERE status = 'active'\n73\t      AND ${timestamp} BETWEEN starts_at AND ends_at\n74\t    LIMIT 1\n75\t  `;\n76\t  return rows.length > 0 ? parseFloat(rows[0]!.multiplier) : 1;\n77\t}\n78\t\n79\t// ---------------------------------------------------------------------------\n80\t// Handler factory\n81\t// ---------------------------------------------------------------------------\n82\t\n83\texport interface PointsGrantDeps {\n84\t  db: Db;\n85\t  /** Returns current SOL/USD price, or null if unavailable. */\n86\t  getSolPrice: () => Promise<number | null>;\n87\t}\n88\t\n89\texport function createPointsGrantHandler(deps: PointsGrantDeps) {\n90\t  const { db, getSolPrice } = deps;\n91\t\n92\t  return async (payload: Record<string, unknown>): Promise<void> => {\n93\t    const userId = payload.userId as string;\n94\t    const wallet = payload.wallet as string;\n95\t    const sourceType = payload.sourceType as string;\n96\t    const sourceId = payload.sourceId as string;\n97\t\n98\t    if (!userId || !wallet || !sourceType || !sourceId) {\n99\t      throw new Error(\n100\t        \"points.grant: malformed payload — missing userId, wallet, sourceType, or sourceId\",\n101\t      );\n102\t    }\n103\t\n104\t    let pointsAmount: bigint;\n105\t    const metadata: Record<string, unknown> = (payload.metadata as Record<string, unknown>) ?? {};\n106\t\n107\t    if (sourceType === \"wager\") {\n108\t      // Wager-based: calculate from lamports → USD → points\n109\t      const amountLamportsStr = payload.amountLamports as string;\n110\t      if (!amountLamportsStr) {\n111\t        throw new Error(\"points.grant: wager grant missing amountLamports\");\n112\t      }\n113\t\n114\t      const pointsPerDollarStr = await readRewardConfig(db, \"points_per_dollar\");\n115\t      if (!pointsPerDollarStr) {\n116\t        logger.warn(\"points.grant: points_per_dollar not configured, skipping\", { userId, sourceId });\n117\t        return;\n118\t      }\n119\t      const pointsPerDollar = parseFloat(pointsPerDollarStr);\n120\t\n121\t      const solPrice = await getSolPrice();\n122\t      if (solPrice === null || solPrice <= 0) {\n123\t        logger.warn(\"points.grant: SOL/USD price unavailable, skipping\", { userId, sourceId });\n124\t        return;\n125\t      }\n126\t\n127\t      const amountLamports = Number(amountLamportsStr);\n128\t      const wagerSol = amountLamports / 1e9;\n129\t      const wagerUsd = wagerSol * solPrice;\n130\t\n131\t      // Check for active Dogpile multiplier\n132\t      const settledAt = payload.settledAt\n133\t        ? new Date(payload.settledAt as string)\n134\t        : new Date();\n135\t      const multiplier = await getActiveDogpileMultiplier(db, settledAt);\n136\t\n137\t      pointsAmount = BigInt(Math.floor(wagerUsd * pointsPerDollar * multiplier));\n138\t\n139\t      metadata.solPrice = solPrice;\n140\t      metadata.wagerUsd = wagerUsd;\n141\t      metadata.pointsPerDollar = pointsPerDollar;\n142\t      metadata.multiplier = multiplier;\n143\t    } else {\n144\t      // Pre-calculated: crate_points, challenge_completed, bonus_completed\n145\t      const amount = payload.amount as string | number;\n146\t      if (amount === undefined || amount === null) {\n147\t        throw new Error(\"points.grant: non-wager grant missing amount\");\n148\t      }\n149\t      pointsAmount = BigInt(amount);\n150\t    }\n151\t\n152\t    if (pointsAmount <= 0n) {\n153\t      logger.debug(\"points.grant: calculated amount is zero, skipping\", { userId, sourceId, sourceType });\n154\t      return;\n155\t    }\n156\t\n157\t    // Run within a transaction for atomicity\n158\t    await db.withTransaction(async (txDb) => {\n159\t      // Insert ledger row (idempotency guard)\n160\t      const inserted = await insertPointGrant(\n161\t        txDb, userId, wallet, sourceType, sourceId, pointsAmount, metadata,\n162\t      );\n163\t      if (!inserted) {\n164\t        logger.info(\"points.grant: duplicate grant, skipping\", { userId, sourceType, sourceId });\n165\t        return;\n166\t      }\n167\t\n168\t      // Upsert player_points\n169\t      await upsertPlayerPoints(txDb, userId, wallet, pointsAmount);\n170\t\n171\t      logger.info(\"points.grant: points awarded\", {\n172\t        userId,\n173\t        sourceType,\n174\t        sourceId,\n175\t        amount: pointsAmount.toString(),\n176\t      });\n177\t    });\n178\t  };\n179\t}\n180\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"0043037a-85db-452f-827d-e7364119c3b2","timestamp":"2026-04-04T07:58:19.103Z"}
