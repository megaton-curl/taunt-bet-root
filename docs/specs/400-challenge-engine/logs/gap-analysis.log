{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X3fCsv4Hg4iB53opsuRNJU","type":"tool_result","content":"1750\t    const crates = await rawSql<{ id: string }[]>`\n1751\t      SELECT id FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1752\t    `;\n1753\t    expect(crates.length).toBe(1);\n1754\t\n1755\t    // Verify pool not decremented again\n1756\t    const poolAfterSecond = await rawSql<{ balance_lamports: string }[]>`\n1757\t      SELECT balance_lamports FROM reward_pool WHERE id = 1\n1758\t    `;\n1759\t    expect(BigInt(poolAfterSecond[0]!.balance_lamports)).toBe(balanceAfterFirst);\n1760\t  });\n1761\t\n1762\t  // =====================================================================\n1763\t  // GAME_SETTLED handler (orchestrator)\n1764\t  // =====================================================================\n1765\t\n1766\t  it(\"game.settled handler: processes challenge progress + emits reward events\", async () => {\n1767\t    const handler = createGameSettledHandler({ db });\n1768\t    const userId = \"usr_gs_progress1\";\n1769\t    const wallet = \"GsProgressWallet1111111111111111111111\";\n1770\t\n1771\t    // Look up the 'Play 3 Games' daily challenge (game_completed, scope=any, threshold=3)\n1772\t    const challenges = await rawSql<{ id: string }[]>`\n1773\t      SELECT id FROM challenges WHERE title = 'Play 3 Games' LIMIT 1\n1774\t    `;\n1775\t    expect(challenges.length).toBe(1);\n1776\t    const challengeId = challenges[0]!.id;\n1777\t\n1778\t    // Create an active assignment for this user\n1779\t    await rawSql`\n1780\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n1781\t      VALUES (${userId}, ${challengeId}, 'daily:2026-04-03', 3)\n1782\t    `;\n1783\t\n1784\t    // Emit a game.settled event\n1785\t    await handler({\n1786\t      roundId: \"test-gs-round-001\",\n1787\t      roundPda: \"GsRoundPda111111111111111111111111111\",\n1788\t      game: \"coinflip\",\n1789\t      players: [\n1790\t        {\n1791\t          userId,\n1792\t          wallet,\n1793\t          amountLamports: \"5000000\",\n1794\t          isWinner: true,\n1795\t          payoutLamports: \"9500000\",\n1796\t          isCreator: true,\n1797\t        },\n1798\t      ],\n1799\t      feeLamports: \"500000\",\n1800\t      settledAt: new Date().toISOString(),\n1801\t    });\n1802\t\n1803\t    // Verify progress incremented to 1\n1804\t    const assignments = await rawSql<{ progress: number; status: string }[]>`\n1805\t      SELECT progress, status FROM challenge_assignments WHERE user_id = ${userId}\n1806\t    `;\n1807\t    expect(assignments[0]!.progress).toBe(1);\n1808\t    expect(assignments[0]!.status).toBe(\"active\");\n1809\t\n1810\t    // Verify progress_events row\n1811\t    const progressEvents = await rawSql<{ round_id: string; progress_delta: number }[]>`\n1812\t      SELECT round_id, progress_delta FROM progress_events WHERE user_id = ${userId}\n1813\t    `;\n1814\t    expect(progressEvents.length).toBe(1);\n1815\t    expect(progressEvents[0]!.round_id).toBe(\"test-gs-round-001\");\n1816\t    expect(progressEvents[0]!.progress_delta).toBe(1);\n1817\t\n1818\t    // Verify reward events emitted: reward.pool_fund, points.grant (wager), crate.drop\n1819\t    const events = await rawSql<{ event_type: string }[]>`\n1820\t      SELECT event_type FROM event_queue ORDER BY id\n1821\t    `;\n1822\t    const types = events.map((e) => e.event_type);\n1823\t    expect(types).toContain(\"reward.pool_fund\");\n1824\t    expect(types).toContain(\"points.grant\");\n1825\t    expect(types).toContain(\"crate.drop\");\n1826\t  });\n1827\t\n1828\t  it(\"game.settled handler: completes challenge + emits reward intent when target reached\", async () => {\n1829\t    const handler = createGameSettledHandler({ db });\n1830\t    const userId = \"usr_gs_complete1\";\n1831\t    const wallet = \"GsCompleteWallet11111111111111111111\";\n1832\t\n1833\t    // Look up 'Win a Coinflip' daily challenge (game_won, scope=coinflip, threshold=1, reward=150 points)\n1834\t    const challenges = await rawSql<{ id: string }[]>`\n1835\t      SELECT id FROM challenges WHERE title = 'Win a Coinflip' LIMIT 1\n1836\t    `;\n1837\t    const challengeId = challenges[0]!.id;\n1838\t\n1839\t    // Create assignment at 0 progress, target 1\n1840\t    await rawSql`\n1841\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n1842\t      VALUES (${userId}, ${challengeId}, 'daily:2026-04-03', 1)\n1843\t    `;\n1844\t\n1845\t    // Win a coinflip — should complete the challenge\n1846\t    await handler({\n1847\t      roundId: \"test-gs-complete-001\",\n1848\t      roundPda: \"GsCompletePda1111111111111111111111111\",\n1849\t      game: \"coinflip\","}]},"parent_tool_use_id":"toolu_01X5MGk2evkgm4qCC3F7gqR6","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"244dcbab-3e68-4a25-8856-eebd73a0e06a","timestamp":"2026-04-04T07:58:23.701Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LYa5vReCfhsVmzjVvzrkDv","type":"tool_result","content":"1\t/**\n2\t * Dogpile routes — public endpoints for dogpile event status and schedule.\n3\t *\n4\t * GET /current   — active dogpile event, or next scheduled, or null\n5\t * GET /schedule  — upcoming dogpile events ordered by starts_at\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { AppEnv } from \"../hono-env.js\";\n10\timport type { Db } from \"../db.js\";\n11\timport { logger } from \"../logger.js\";\n12\t\n13\t// ---------------------------------------------------------------------------\n14\t// Types\n15\t// ---------------------------------------------------------------------------\n16\t\n17\texport interface DogpileRoutesDeps {\n18\t  db: Db;\n19\t}\n20\t\n21\tinterface DogpileEventRow {\n22\t  id: string;\n23\t  multiplier: string;\n24\t  starts_at: Date;\n25\t  ends_at: Date;\n26\t  status: string;\n27\t  campaign_id: string | null;\n28\t}\n29\t\n30\t// ---------------------------------------------------------------------------\n31\t// Route factory\n32\t// ---------------------------------------------------------------------------\n33\t\n34\texport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n35\t  const { db } = deps;\n36\t  const app = new Hono<AppEnv>();\n37\t\n38\t  // GET /current — active event > next scheduled > null\n39\t  app.get(\"/current\", async (c) => {\n40\t    try {\n41\t      // Try active first\n42\t      const active = await db.rawSql<DogpileEventRow[]>`\n43\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n44\t        FROM dogpile_events\n45\t        WHERE status = 'active'\n46\t        ORDER BY starts_at ASC\n47\t        LIMIT 1\n48\t      `;\n49\t\n50\t      if (active.length > 0) {\n51\t        const e = active[0]!;\n52\t        return c.json({\n53\t          id: Number(e.id),\n54\t          multiplier: Number(e.multiplier),\n55\t          startsAt: e.starts_at.toISOString(),\n56\t          endsAt: e.ends_at.toISOString(),\n57\t          status: \"active\",\n58\t          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n59\t        });\n60\t      }\n61\t\n62\t      // Try next scheduled\n63\t      const scheduled = await db.rawSql<DogpileEventRow[]>`\n64\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n65\t        FROM dogpile_events\n66\t        WHERE status = 'scheduled'\n67\t          AND starts_at > now()\n68\t        ORDER BY starts_at ASC\n69\t        LIMIT 1\n70\t      `;\n71\t\n72\t      if (scheduled.length > 0) {\n73\t        const e = scheduled[0]!;\n74\t        return c.json({\n75\t          id: Number(e.id),\n76\t          multiplier: Number(e.multiplier),\n77\t          startsAt: e.starts_at.toISOString(),\n78\t          endsAt: e.ends_at.toISOString(),\n79\t          status: \"scheduled\",\n80\t          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n81\t        });\n82\t      }\n83\t\n84\t      return c.json(null);\n85\t    } catch (err) {\n86\t      logger.error(\"dogpile/current failed\", {\n87\t        error: err instanceof Error ? err.message : String(err),\n88\t      });\n89\t      return c.json({ error: \"Failed to fetch dogpile status\" }, 500);\n90\t    }\n91\t  });\n92\t\n93\t  // GET /schedule — upcoming events ordered by starts_at\n94\t  app.get(\"/schedule\", async (c) => {\n95\t    try {\n96\t      const rows = await db.rawSql<DogpileEventRow[]>`\n97\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n98\t        FROM dogpile_events\n99\t        WHERE status IN ('scheduled', 'active')\n100\t        ORDER BY starts_at ASC\n101\t      `;\n102\t\n103\t      const items = rows.map((e: DogpileEventRow) => ({\n104\t        id: Number(e.id),\n105\t        multiplier: Number(e.multiplier),\n106\t        startsAt: e.starts_at.toISOString(),\n107\t        endsAt: e.ends_at.toISOString(),\n108\t        status: e.status,\n109\t      }));\n110\t\n111\t      return c.json({ items });\n112\t    } catch (err) {\n113\t      logger.error(\"dogpile/schedule failed\", {\n114\t        error: err instanceof Error ? err.message : String(err),\n115\t      });\n116\t      return c.json({ error: \"Failed to fetch dogpile schedule\" }, 500);\n117\t    }\n118\t  });\n119\t\n120\t  return app;\n121\t}\n122\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"d3da2fd8-707c-4436-bc7d-c71588f10f6b","timestamp":"2026-04-04T07:58:24.020Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013TMmNmXi97MFr6mqiNE1SS","type":"tool_result","content":"1\t/**\n2\t * Points & Crate routes — player-facing endpoints for points balance,\n3\t * points history, and crate drop history.\n4\t *\n5\t * GET /mine           — current point balance + lifetime earned\n6\t * GET /mine/history   — paginated point_grants ledger\n7\t * GET /crates/mine    — paginated crate_drops history\n8\t */\n9\t\n10\timport { Hono } from \"hono\";\n11\timport type { AppEnv } from \"../hono-env.js\";\n12\timport type { Db } from \"../db.js\";\n13\timport { logger } from \"../logger.js\";\n14\t\n15\t// ---------------------------------------------------------------------------\n16\t// Types\n17\t// ---------------------------------------------------------------------------\n18\t\n19\texport interface PointsRoutesDeps {\n20\t  db: Db;\n21\t}\n22\t\n23\t// ---------------------------------------------------------------------------\n24\t// Helpers\n25\t// ---------------------------------------------------------------------------\n26\t\n27\t/** Parse and clamp a numeric query param. Returns `defaultVal` if missing/invalid. */\n28\tfunction parseIntParam(raw: string | undefined, defaultVal: number, max: number): number {\n29\t  if (!raw) return defaultVal;\n30\t  const parsed = parseInt(raw, 10);\n31\t  if (isNaN(parsed) || parsed < 1) return defaultVal;\n32\t  return Math.min(parsed, max);\n33\t}\n34\t\n35\t// ---------------------------------------------------------------------------\n36\t// Route factory\n37\t// ---------------------------------------------------------------------------\n38\t\n39\texport function createPointsRoutes(deps: PointsRoutesDeps) {\n40\t  const { db } = deps;\n41\t  const app = new Hono<AppEnv>();\n42\t\n43\t  // GET /mine — point balance\n44\t  app.get(\"/mine\", async (c) => {\n45\t    const userId = c.get(\"userId\");\n46\t    if (!userId) {\n47\t      return c.json({ error: \"Authentication required\" }, 401);\n48\t    }\n49\t\n50\t    try {\n51\t      const rows = await db.rawSql<{ balance: string; lifetime_earned: string }[]>`\n52\t        SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n53\t      `;\n54\t      if (rows.length === 0) {\n55\t        return c.json({ balance: 0, lifetimeEarned: 0 });\n56\t      }\n57\t      return c.json({\n58\t        balance: Number(rows[0]!.balance),\n59\t        lifetimeEarned: Number(rows[0]!.lifetime_earned),\n60\t      });\n61\t    } catch (err) {\n62\t      logger.error(\"GET /points/mine failed\", {\n63\t        userId,\n64\t        error: err instanceof Error ? err.message : \"Unknown error\",\n65\t      });\n66\t      return c.json({ error: \"Failed to fetch points\" }, 500);\n67\t    }\n68\t  });\n69\t\n70\t  // GET /mine/history — paginated point_grants\n71\t  app.get(\"/mine/history\", async (c) => {\n72\t    const userId = c.get(\"userId\");\n73\t    if (!userId) {\n74\t      return c.json({ error: \"Authentication required\" }, 401);\n75\t    }\n76\t\n77\t    const cursor = c.req.query(\"cursor\") || undefined;\n78\t    const limit = parseIntParam(c.req.query(\"limit\"), 20, 50);\n79\t\n80\t    try {\n81\t      const cursorFilter = cursor\n82\t        ? db.rawSql`AND id < ${cursor}`\n83\t        : db.rawSql``;\n84\t\n85\t      const rows = await db.rawSql<\n86\t        {\n87\t          id: string;\n88\t          source_type: string;\n89\t          source_id: string;\n90\t          amount: string;\n91\t          metadata: Record<string, unknown>;\n92\t          created_at: Date;\n93\t        }[]\n94\t      >`\n95\t        SELECT id, source_type, source_id, amount, metadata, created_at\n96\t        FROM point_grants\n97\t        WHERE user_id = ${userId} ${cursorFilter}\n98\t        ORDER BY id DESC\n99\t        LIMIT ${limit}\n100\t      `;\n101\t\n102\t      const items = rows.map((r: { id: string; source_type: string; source_id: string; amount: string; metadata: Record<string, unknown>; created_at: Date }) => ({\n103\t        id: Number(r.id),\n104\t        sourceType: r.source_type,\n105\t        sourceId: r.source_id,\n106\t        amount: Number(r.amount),\n107\t        metadata: r.metadata,\n108\t        createdAt: r.created_at.toISOString(),\n109\t      }));\n110\t\n111\t      const nextCursor =\n112\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n113\t\n114\t      return c.json({ items, nextCursor });\n115\t    } catch (err) {\n116\t      logger.error(\"GET /points/mine/history failed\", {\n117\t        userId,\n118\t        error: err instanceof Error ? err.message : \"Unknown error\",\n119\t      });\n120\t      return c.json({ error: \"Failed to fetch points history\" }, 500);\n121\t    }\n122\t  });\n123\t\n124\t  return app;\n125\t}\n126\t\n127\t// ---------------------------------------------------------------------------\n128\t// Crate routes factory\n129\t// ---------------------------------------------------------------------------\n130\t\n131\texport function createCrateRoutes(deps: PointsRoutesDeps) {\n132\t  const { db } = deps;\n133\t  const app = new Hono<AppEnv>();\n134\t\n135\t  // GET /mine — paginated crate_drops\n136\t  app.get(\"/mine\", async (c) => {\n137\t    const userId = c.get(\"userId\");\n138\t    if (!userId) {\n139\t      return c.json({ error: \"Authentication required\" }, 401);\n140\t    }\n141\t\n142\t    const cursor = c.req.query(\"cursor\") || undefined;\n143\t    const limit = parseIntParam(c.req.query(\"limit\"), 20, 50);\n144\t\n145\t    try {\n146\t      const cursorFilter = cursor\n147\t        ? db.rawSql`AND id < ${cursor}`\n148\t        : db.rawSql``;\n149\t\n150\t      const rows = await db.rawSql<\n151\t        {\n152\t          id: string;\n153\t          crate_type: string;\n154\t          contents_amount: string;\n155\t          status: string;\n156\t          created_at: Date;\n157\t          granted_at: Date | null;\n158\t        }[]\n159\t      >`\n160\t        SELECT id, crate_type, contents_amount, status, created_at, granted_at\n161\t        FROM crate_drops\n162\t        WHERE user_id = ${userId} ${cursorFilter}\n163\t        ORDER BY id DESC\n164\t        LIMIT ${limit}\n165\t      `;\n166\t\n167\t      const items = rows.map((r: { id: string; crate_type: string; contents_amount: string; status: string; created_at: Date; granted_at: Date | null }) => ({\n168\t        id: Number(r.id),\n169\t        crateType: r.crate_type,\n170\t        contentsAmount: r.contents_amount,\n171\t        status: r.status,\n172\t        createdAt: r.created_at.toISOString(),\n173\t        grantedAt: r.granted_at ? r.granted_at.toISOString() : null,\n174\t      }));\n175\t\n176\t      const nextCursor =\n177\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n178\t\n179\t      return c.json({ items, nextCursor });\n180\t    } catch (err) {\n181\t      logger.error(\"GET /crates/mine failed\", {\n182\t        userId,\n183\t        error: err instanceof Error ? err.message : \"Unknown error\",\n184\t      });\n185\t      return c.json({ error: \"Failed to fetch crate history\" }, 500);\n186\t    }\n187\t  });\n188\t\n189\t  return app;\n190\t}\n191\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"77306e85-a834-473d-81b3-69ed2c522945","timestamp":"2026-04-04T07:58:24.004Z"}
