{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015Dmc3kfr6V67NwfuKFj8e5","type":"tool_result","content":"1\t/**\n2\t * Dogpile status worker — periodic poll that transitions dogpile_events:\n3\t *   scheduled → active  when now() >= starts_at\n4\t *   active   → ended    when now() >= ends_at\n5\t */\n6\t\n7\timport type { Db } from \"../db.js\";\n8\timport { logger } from \"../logger.js\";\n9\t\n10\texport interface DogpileWorkerDeps {\n11\t  db: Db;\n12\t  pollIntervalMs?: number;\n13\t}\n14\t\n15\texport interface DogpileWorker {\n16\t  start(): void;\n17\t  stop(): void;\n18\t  /** Run a single tick (exposed for testing). */\n19\t  tick(): Promise<{ activated: number; ended: number }>;\n20\t}\n21\t\n22\texport function createDogpileWorker(deps: DogpileWorkerDeps): DogpileWorker {\n23\t  const { db, pollIntervalMs = 10_000 } = deps;\n24\t  let intervalId: ReturnType<typeof setInterval> | null = null;\n25\t\n26\t  async function tick(): Promise<{ activated: number; ended: number }> {\n27\t    // Transition scheduled → active\n28\t    const activated = await db.rawSql<{ id: string }[]>`\n29\t      UPDATE dogpile_events\n30\t      SET status = 'active'\n31\t      WHERE status = 'scheduled' AND starts_at <= now()\n32\t      RETURNING id\n33\t    `;\n34\t\n35\t    // Transition active → ended\n36\t    const ended = await db.rawSql<{ id: string }[]>`\n37\t      UPDATE dogpile_events\n38\t      SET status = 'ended'\n39\t      WHERE status = 'active' AND ends_at <= now()\n40\t      RETURNING id\n41\t    `;\n42\t\n43\t    if (activated.length > 0) {\n44\t      logger.info(\"dogpile: activated events\", { ids: activated.map((r: { id: string }) => r.id) });\n45\t    }\n46\t    if (ended.length > 0) {\n47\t      logger.info(\"dogpile: ended events\", { ids: ended.map((r: { id: string }) => r.id) });\n48\t    }\n49\t\n50\t    return { activated: activated.length, ended: ended.length };\n51\t  }\n52\t\n53\t  return {\n54\t    start() {\n55\t      if (intervalId) return;\n56\t      logger.info(\"Dogpile worker started\", { pollIntervalMs });\n57\t      intervalId = setInterval(() => {\n58\t        tick().catch((err) => {\n59\t          logger.error(\"dogpile worker tick failed\", {\n60\t            error: err instanceof Error ? err.message : String(err),\n61\t          });\n62\t        });\n63\t      }, pollIntervalMs);\n64\t    },\n65\t    stop() {\n66\t      if (intervalId) {\n67\t        clearInterval(intervalId);\n68\t        intervalId = null;\n69\t      }\n70\t    },\n71\t    tick,\n72\t  };\n73\t}\n74\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"48a58e20-020e-4588-be2e-67bc04f1b2dc","timestamp":"2026-04-04T07:58:26.516Z"}
