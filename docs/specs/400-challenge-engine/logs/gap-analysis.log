{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PJjjE2K5vpFtKGAxBkzdNj","type":"tool_result","content":"350\t    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n351\t    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n352\t  ];\n353\t\n354\t  await db.withTransaction(async (txDb) => {\n355\t    await txDb.updateRoundPhase(pda, \"settled\", {\n356\t      settle_tx: txSignature,\n357\t      result_hash: resultHash,\n358\t      result_side: resultSide,\n359\t      winner: winner.toBase58(),\n360\t      settle_attempts: round.settle_attempts + 1,\n361\t    });\n362\t\n363\t    // Game entries for leaderboard/stats — UPSERT updates existing (creator) and inserts new (joiner)\n364\t    const loser = winner.equals(creator) ? opponent : creator;\n365\t    const [winnerProfile, loserProfile] = await Promise.all([\n366\t      txDb.getProfileByWallet(winner.toBase58()),\n367\t      txDb.getProfileByWallet(loser.toBase58()),\n368\t    ]);\n369\t    if (!winnerProfile || !loserProfile) {\n370\t      logger.warn(\"coinflip settle: missing profile for participant — skipping game entries\", {\n371\t        pda,\n372\t        winnerWallet: winner.toBase58(),\n373\t        loserWallet: loser.toBase58(),\n374\t        winnerProfileExists: !!winnerProfile,\n375\t        loserProfileExists: !!loserProfile,\n376\t      });\n377\t    } else {\n378\t      await txDb.upsertGameEntries([\n379\t        {\n380\t          userId: winnerProfile.user_id,\n381\t          wallet: winner.toBase58(),\n382\t          game: \"coinflip\",\n383\t          roundPda: pda,\n384\t          matchId: round.match_id,\n385\t          amountLamports: Number(entryAmount),\n386\t          isWinner: true,\n387\t          payoutLamports: payoutAmount,\n388\t          settledAt: new Date(),\n389\t        },\n390\t        {\n391\t          userId: loserProfile.user_id,\n392\t          wallet: loser.toBase58(),\n393\t          game: \"coinflip\",\n3