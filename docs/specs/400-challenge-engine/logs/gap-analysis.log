{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WuLvfaQZqSswRAApwq149W","type":"tool_result","content":"1\t/**\n2\t * Handler for `referral.claim_requested` events.\n3\t *\n4\t * Flow: load claim → verify pending → update to processing → re-verify balance\n5\t * → SOL transfer from server keypair → record tx_signature → completed.\n6\t *\n7\t * Idempotent: skips if claim is already completed or permanently failed.\n8\t * Transient errors set status to 'error' (retryable); only marks 'failed'\n9\t * after MAX_CLAIM_RETRIES attempts.\n10\t */\n11\t\n12\timport {\n13\t  Connection,\n14\t  Keypair,\n15\t  PublicKey,\n16\t  SystemProgram,\n17\t  Transaction,\n18\t} from \"@solana/web3.js\";\n19\timport type { Db } from \"../../db.js\";\n20\timport { logger } from \"../../logger.js\";\n21\t\n22\t/** Max retry attempts before a claim is permanently marked failed. */\n23\tconst MAX_CLAIM_RETRIES = 5;\n24\t\n25\texport interface ClaimHandlerDeps {\n26\t  db: Db;\n27\t  connection: Connection;\n28\t  serverKeypair: Keypair;\n29\t}\n30\t\n31\texport function createClaimHandler(deps: ClaimHandlerDeps) {\n32\t  const { db, connection, serverKeypair } = deps;\n33\t\n34\t  return async (payload: Record<string, unknown>): Promise<void> => {\n35\t    const claimId = payload.claimId as string;\n36\t    const userId = payload.userId as string;\n37\t    const wallet = payload.wallet as string;\n38\t    const amountLamports = payload.amountLamports as string;\n39\t\n40\t    if (!claimId || !userId || !wallet || !amountLamports) {\n41\t      throw new Error(\n42\t        `referral.claim_requested: malformed payload — missing claimId, userId, wallet, or amountLamports`,\n43\t      );\n44\t    }\n45\t\n46\t    // 1. Load claim and check idempotency\n47\t    const claim = await db.getReferralClaim(claimId);\n48\t    if (!claim) {\n49\t      logger.warn(\"referral claim handler: claim not found\", { claimId });\n50\t      return; // no-op — event may reference a deleted/invalid claim\n51\t    }\n52\t\n53\t    if (claim.status === \"completed\") {\n54\t      logger.info(\"referral claim handler: already completed, skipping\", {\n55\t        claimId,\n56\t      });\n57\t      return;\n58\t    }\n59\t\n60\t    if (claim.status === \"failed\") {\n61\t      logger.info(\"referral claim handler: permanently failed, skipping\", {\n62\t        claimId,\n63\t      });\n64\t      return;\n65\t    }\n66\t\n67\t    // 2. Update status to processing (from pending or error)\n68\t    await db.updateClaimStatus(claimId, \"processing\");\n69\t\n70\t    try {\n71\t      // 3. Re-verify available balance >= claim amount (prevents overpay on concurrent claims)\n72\t      const pendingStr = await db.getPendingBalanceByUserId(userId);\n73\t      const pending = BigInt(pendingStr);\n74\t      const amount = BigInt(amountLamports);\n75\t\n76\t      if (pending < amount) {\n77\t        // Insufficient balance is a permanent failure — no retry will help\n78\t        await db.updateClaimStatus(claimId, \"failed\", {\n79\t          error: `Insufficient balance: pending=${pendingStr}, claim=${amountLamports}`,\n80\t        });\n81\t        logger.warn(\"referral claim handler: insufficient balance\", {\n82\t          claimId,\n83\t          userId,\n84\t          wallet,\n85\t          pending: pendingStr,\n86\t          amount: amountLamports,\n87\t        });\n88\t        return;\n89\t      }\n90\t\n91\t      // 4. Execute SOL transfer from server keypair to player wallet\n92\t      const recipient = new PublicKey(wallet);\n93\t      const lamports = Number(amount);\n94\t\n95\t      const { blockhash, lastValidBlockHeight } =\n96\t        await connection.getLatestBlockhash(\"confirmed\");\n97\t\n98\t      const tx = new Transaction({\n99\t        feePayer: serverKeypair.publicKey,\n100\t        blockhash,\n101\t        lastValidBlockHeight,\n102\t      });\n103\t\n104\t      tx.add(\n105\t        SystemProgram.transfer({\n106\t          fromPubkey: serverKeypair.publicKey,\n107\t          toPubkey: recipient,\n108\t          lamports,\n109\t        }),\n110\t      );\n111\t\n112\t      tx.sign(serverKeypair);\n113\t\n114\t      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n115\t        skipPreflight: false,\n116\t      });\n117\t\n118\t      // Wait for confirmation\n119\t      const confirmation = await connection.confirmTransaction(\n120\t        { signature: txSignature, blockhash, lastValidBlockHeight },\n121\t        \"confirmed\",\n122\t      );\n123\t\n124\t      if (confirmation.value.err) {\n125\t        throw new Error(\n126\t          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n127\t        );\n128\t      }\n129\t\n130\t      // 5. Record success\n131\t      await db.updateClaimStatus(claimId, \"completed\", { txSignature });\n132\t      logger.info(\"referral claim handler: transfer completed\", {\n133\t        claimId,\n134\t        userId,\n135\t        wallet,\n136\t        amountLamports,\n137\t        txSignature,\n138\t      });\n139\t    } catch (err) {\n140\t      // 6. Transient failure — increment retry count, mark as 'error' (retryable)\n141\t      //    or 'failed' (permanent) if max retries exceeded.\n142\t      const errorMsg =\n143\t        err instanceof Error ? err.message : \"Unknown transfer error\";\n144\t      const nextRetry = claim.retry_count + 1;\n145\t      const isFinal = nextRetry >= MAX_CLAIM_RETRIES;\n146\t      const nextStatus = isFinal ? \"failed\" : \"error\";\n147\t\n148\t      await db.updateClaimStatus(claimId, nextStatus, {\n149\t        error: errorMsg,\n150\t        incrementRetry: true,\n151\t      });\n152\t\n153\t      if (isFinal) {\n154\t        logger.error(\n155\t          \"referral claim handler: max retries exceeded, permanently failed\",\n156\t          {\n157\t            claimId,\n158\t            userId,\n159\t            wallet,\n160\t            amountLamports,\n161\t            retries: nextRetry,\n162\t            error: errorMsg,\n163\t          },\n164\t        );\n165\t        return; // Don't rethrow — claim is permanently dead\n166\t      }\n167\t\n168\t      logger.warn(\n169\t        \"referral claim handler: transient error, will retry\",\n170\t        {\n171\t          claimId,\n172\t          userId,\n173\t          wallet,\n174\t          amountLamports,\n175\t          retry: nextRetry,\n176\t          error: errorMsg,\n177\t        },\n178\t      );\n179\t      // Re-throw so the queue worker retries with exponential backoff\n180\t      throw err;\n181\t    }\n182\t  };\n183\t}\n184\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"227fbc43-7f46-4066-9f56-3ca4945ee64f","timestamp":"2026-04-04T07:58:18.185Z"}
