{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014vNk8FHHVZrFPM4mvoEtjy","type":"tool_result","content":"1\t/**\n2\t * Settle transaction builder + submission.\n3\t *\n4\t * Retrieves the stored secret, reads on-chain match + config data to resolve\n5\t * all accounts, builds the `settle` instruction, submits it, and updates the\n6\t * DB on confirmation.\n7\t */\n8\t\n9\timport { createHash } from \"node:crypto\";\n10\timport { performance } from \"node:perf_hooks\";\n11\timport {\n12\t  Connection,\n13\t  Keypair,\n14\t  PublicKey,\n15\t  SystemProgram,\n16\t  Transaction,\n17\t  TransactionInstruction,\n18\t} from \"@solana/web3.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport { emitEvent } from \"../queue/emit-event.js\";\n22\timport { EventTypes } from \"../queue/event-types.js\";\n23\timport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n24\timport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n25\timport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@taunt-bet/anchor-client\";\n26\timport {\n27\t  decodeCoinflipMatch,\n28\t  decodeLordRound,\n29\t  type DecodedJackpotRound,\n30\t} from \"./account-decoder.js\";\n31\t\n32\t// ---------------------------------------------------------------------------\n33\t// Instruction discriminators (from IDL — no hardcoded byte arrays)\n34\t// ---------------------------------------------------------------------------\n35\t\n36\tfunction getInstructionDiscriminator(\n37\t  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n38\t  instructionName: string,\n39\t): Buffer {\n40\t  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n41\t  if (!instruction) {\n42\t    throw new Error(`Instruction ${instructionName} not found in IDL`);\n43\t  }\n44\t  return Buffer.from(instruction.discriminator);\n45\t}\n46\t\n47\tconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n48\tconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n49\t  lordIdl,\n50\t  \"claim_payout\",\n51\t);\n52\tconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n53\tconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n54\tconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n55\t\n56\t// ---------------------------------------------------------------------------\n57\t// Types\n58\t// ---------------------------------------------------------------------------\n59\t\n60\texport interface SettleTxDeps {\n61\t  db: Db;\n62\t  connection: Connection;\n63\t  serverKeypair: Keypair;\n64\t  entropyAccount: PublicKey;\n65\t  referralDefaultRateBps: number;\n66\t}\n67\t\n68\texport interface SettleResult {\n69\t  txSignature: string;\n70\t  resultHash: Buffer;\n71\t  resultSide?: number;\n72\t  winningEntryIndex?: number;\n73\t  winner: string;\n74\t}\n75\t\n76\t// ---------------------------------------------------------------------------\n77\t// Instruction encoding\n78\t// ---------------------------------------------------------------------------\n79\t\n80\t/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n81\tfunction encodeSettleData(secret: Buffer): Buffer {\n82\t  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n83\t}\n84\t\n85\tfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n86\t  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n87\t}\n88\t\n89\t// ---------------------------------------------------------------------------\n90\t// Result derivation (mirrors on-chain derive_result)\n91\t// ---------------------------------------------------------------------------\n92\t\n93\t/**\n94\t * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n95\t * Must match shared/src/fairness.rs `derive_result()`.\n96\t */\n97\tfunction deriveResult(\n98\t  secret: Buffer,\n99\t  entropy: Buffer,\n100\t  matchPdaBytes: Buffer,\n101\t  algoVer: number,\n102\t): Buffer {\n103\t  return createHash(\"sha256\")\n104\t    .update(secret)\n105\t    .update(entropy)\n106\t    .update(matchPdaBytes)\n107\t    .update(Buffer.from([algoVer]))\n108\t    .digest();\n109\t}\n110\t\n111\t// ---------------------------------------------------------------------------\n112\t// Referral earnings hook\n113\t// ---------------------------------------------------------------------------\n114\t\n115\t/**\n116\t * After a game settles, check each player for a referrer and record\n117\t * referral earnings if applicable.\n118\t *\n119\t * For each unique player: look up referral link → if referrer exists,\n120\t * calculate referrer earning + referee rebate → insert into referral_earnings.\n121\t *\n122\t * Errors are logged but never bubble — referral recording must not fail settlement.\n123\t * The UNIQUE(referee_user_id, round_id) constraint provides idempotency on retries.\n124\t */\n125\tasync function recordReferralEarnings(\n126\t  db: Db,\n127\t  params: {\n128\t    roundId: string;\n129\t    gameType: string;\n130\t    feeBps: number;\n131\t    referralDefaultRateBps: number;\n132\t    players: Array<{ wallet: string; wagerLamports: number }>;\n133\t  },\n134\t): Promise<void> {\n135\t  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n136\t\n137\t  // Deduplicate players (Lord of RNGs can have multiple entries per player)\n138\t  const playerWagers = new Map<string, number>();\n139\t  for (const p of players) {\n140\t    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n141\t  }\n142\t\n143\t  for (const [wallet, wagerLamports] of playerWagers) {\n144\t    try {\n145\t      const refereeProfile = await db.getProfileByWallet(wallet);\n146\t      if (!refereeProfile) continue; // no profile = no referral link possible\n147\t      const link = await db.getReferralLinkByRefereeUserId(refereeProfile.user_id);\n148\t      if (!link) continue;\n149\t\n150\t      const referrerWallet = link.referrer_wallet;"}]},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"c356f1d4-8ea6-4f2f-8d23-a66812b52f83","timestamp":"2026-04-04T07:59:31.766Z"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01GcwRnRX3vzp3pPBwzfifhD","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01U7W8cXc3qv2yF39JX29gfb","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/points-grant.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":3244,"cache_creation_input_tokens":12639,"cache_read_input_tokens":27256,"cache_creation":{"ephemeral_5m_input_tokens":12639,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"34d504af-22c9-4752-9091-d012d5847927"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U7W8cXc3qv2yF39JX29gfb","type":"tool_result","content":"1\t/**\n2\t * POINTS_GRANT handler — awards points to a player.\n3\t *\n4\t * For wager-based grants: converts lamports → USD → points using config rate\n5\t * and applies any active Dogpile multiplier.\n6\t * For pre-calculated grants (crate_points, challenge_completed, bonus_completed):\n7\t * uses the `amount` field directly.\n8\t *\n9\t * Idempotent via UNIQUE(user_id, source_type, source_id) on point_grants.\n10\t */\n11\t\n12\timport type { Db } from \"../../db.js\";\n13\timport { logger } from \"../../logger.js\";\n14\timport { readRewardConfig } from \"./reward-pool-fund.js\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// DB helpers\n18\t// ---------------------------------------------------------------------------\n19\t\n20\t/**\n21\t * Insert a point grant ledger row. Returns false if a row for this\n22\t * (user_id, source_type, source_id) already exists (idempotency guard).\n23\t */\n24\texport async function insertPointGrant(\n25\t  db: Db,\n26\t  userId: string,\n27\t  wallet: string,\n28\t  sourceType: string,\n29\t  sourceId: string,\n30\t  amount: bigint,\n31\t  metadata: Record<string, unknown>,\n32\t): Promise<boolean> {\n33\t  const rows = await db.rawSql<{ id: string }[]>`\n34\t    INSERT INTO point_grants (user_id, wallet, source_type, source_id, amount, metadata)\n35\t    VALUES (${userId}, ${wallet}, ${sourceType}, ${sourceId}, ${amount}, ${JSON.stringify(metadata)})\n36\t    ON CONFLICT (user_id, source_type, source_id) DO NOTHING\n37\t    RETURNING id\n38\t  `;\n39\t  return rows.length > 0;\n40\t}\n41\t\n42\t/**\n43\t * Create or increment player_points. Uses upsert pattern so the first\n44\t * grant for a user creates the row.\n45\t */\n46\texport async function upsertPlayerPoints(\n47\t  db: Db,\n48\t  userId: string,\n49\t  wallet: string,\n50\t  amount: bigint,\n51\t): Promise<void> {\n52\t  await db.rawSql`\n53\t    INSERT INTO player_points (user_id, wallet, balance, lifetime_earned, updated_at)\n54\t    VALUES (${userId}, ${wallet}, ${amount}, ${amount}, now())\n55\t    ON CONFLICT (user_id) DO UPDATE SET\n56\t      balance         = player_points.balance + ${amount},\n57\t      lifetime_earned = player_points.lifetime_earned + ${amount},\n58\t      updated_at      = now()\n59\t  `;\n60\t}\n61\t\n62\t/**\n63\t * Returns the multiplier for the currently active Dogpile event, or 1 if\n64\t * none is active.\n65\t */\n66\texport async function getActiveDogpileMultiplier(\n67\t  db: Db,\n68\t  timestamp: Date,\n69\t): Promise<number> {\n70\t  const rows = await db.rawSql<{ multiplier: string }[]>`\n71\t    SELECT multiplier FROM dogpile_events\n72\t    WHERE status = 'active'\n73\t      AND ${timestamp} BETWEEN starts_at AND ends_at\n74\t    LIMIT 1\n75\t  `;\n76\t  return rows.length > 0 ? parseFloat(rows[0]!.multiplier) : 1;\n77\t}\n78\t\n79\t// ---------------------------------------------------------------------------\n80\t// Handler factory\n81\t// ---------------------------------------------------------------------------\n82\t\n83\texport interface PointsGrantDeps {\n84\t  db: Db;\n85\t  /** Returns current SOL/USD price, or null if unavailable. */\n86\t  getSolPrice: () => Promise<number | null>;\n87\t}\n88\t\n89\texport function createPointsGrantHandler(deps: PointsGrantDeps) {\n90\t  const { db, getSolPrice } = deps;\n91\t\n92\t  return async (payload: Record<string, unknown>): Promise<void> => {\n93\t    const userId = payload.userId as string;\n94\t    const wallet = payload.wallet as string;\n95\t    const sourceType = payload.sourceType as string;\n96\t    const sourceId = payload.sourceId as string;\n97\t\n98\t    if (!userId || !wallet || !sourceType || !sourceId) {\n99\t      throw new Error(\n100\t        \"points.grant: malformed payload — missing userId, wallet, sourceType, or sourceId\",\n101\t      );\n102\t    }\n103\t\n104\t    let pointsAmount: bigint;\n105\t    const metadata: Record<string, unknown> = (payload.metadata as Record<string, unknown>) ?? {};\n106\t\n107\t    if (sourceType === \"wager\") {\n108\t      // Wager-based: calculate from lamports → USD → points\n109\t      const amountLamportsStr = payload.amountLamports as string;\n110\t      if (!amountLamportsStr) {\n111\t        throw new Error(\"points.grant: wager grant missing amountLamports\");\n112\t      }\n113\t\n114\t      const pointsPerDollarStr = await readRewardConfig(db, \"points_per_dollar\");\n115\t      if (!pointsPerDollarStr) {\n116\t        logger.warn(\"points.grant: points_per_dollar not configured, skipping\", { userId, sourceId });\n117\t        return;\n118\t      }\n119\t      const pointsPerDollar = parseFloat(pointsPerDollarStr);\n120\t\n121\t      const solPrice = await getSolPrice();\n122\t      if (solPrice === null || solPrice <= 0) {\n123\t        logger.warn(\"points.grant: SOL/USD price unavailable, skipping\", { userId, sourceId });\n124\t        return;\n125\t      }\n126\t\n127\t      const amountLamports = Number(amountLamportsStr);\n128\t      const wagerSol = amountLamports / 1e9;\n129\t      const wagerUsd = wagerSol * solPrice;\n130\t\n131\t      // Check for active Dogpile multiplier\n132\t      const settledAt = payload.settledAt\n133\t        ? new Date(payload.settledAt as string)\n134\t        : new Date();\n135\t      const multiplier = await getActiveDogpileMultiplier(db, settledAt);\n136\t\n137\t      pointsAmount = BigInt(Math.floor(wagerUsd * pointsPerDollar * multiplier));\n138\t\n139\t      metadata.solPrice = solPrice;\n140\t      metadata.wagerUsd = wagerUsd;\n141\t      metadata.pointsPerDollar = pointsPerDollar;\n142\t      metadata.multiplier = multiplier;\n143\t    } else {\n144\t      // Pre-calculated: crate_points, challenge_completed, bonus_completed\n145\t      const amount = payload.amount as string | number;\n146\t      if (amount === undefined || amount === null) {\n147\t        throw new Error(\"points.grant: non-wager grant missing amount\");\n148\t      }\n149\t      pointsAmount = BigInt(amount);\n150\t    }\n151\t\n152\t    if (pointsAmount <= 0n) {\n153\t      logger.debug(\"points.grant: calculated amount is zero, skipping\", { userId, sourceId, sourceType });\n154\t      return;\n155\t    }\n156\t\n157\t    // Run within a transaction for atomicity\n158\t    await db.withTransaction(async (txDb) => {\n159\t      // Insert ledger row (idempotency guard)\n160\t      const inserted = await insertPointGrant(\n161\t        txDb, userId, wallet, sourceType, sourceId, pointsAmount, metadata,\n162\t      );\n163\t      if (!inserted) {\n164\t        logger.info(\"points.grant: duplicate grant, skipping\", { userId, sourceType, sourceId });\n165\t        return;\n166\t      }\n167\t\n168\t      // Upsert player_points\n169\t      await upsertPlayerPoints(txDb, userId, wallet, pointsAmount);\n170\t\n171\t      logger.info(\"points.grant: points awarded\", {\n172\t        userId,\n173\t        sourceType,\n174\t        sourceId,\n175\t        amount: pointsAmount.toString(),\n176\t      });\n177\t    });\n178\t  };\n179\t}\n180\t"}]},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"92d3e02f-a37a-4c0c-98d9-4993006504a6","timestamp":"2026-04-04T07:59:31.854Z"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01GcwRnRX3vzp3pPBwzfifhD","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BtPqwucosnBYSSdU1GbYtN","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/crate-drop.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":3244,"cache_creation_input_tokens":12639,"cache_read_input_tokens":27256,"cache_creation":{"ephemeral_5m_input_tokens":12639,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"f9770df6-aced-4332-b4d8-abde8f98928f"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BtPqwucosnBYSSdU1GbYtN","type":"tool_result","content":"1\t/**\n2\t * CRATE_DROP handler — rolls for a loot crate drop after a settled game.\n3\t *\n4\t * Drop logic per player per settled game:\n5\t *   roll = random()\n6\t *   if roll < sol_crate_drop_rate AND pool can fund:  → SOL crate\n7\t *   elif roll < sol_crate_drop_rate + points_crate_drop_rate:  → Points crate\n8\t *   else: no drop\n9\t *\n10\t * SOL crate is checked first (higher value, lower probability). If pool can't\n11\t * fund it, the roll is wasted (no fallback to points crate).\n12\t *\n13\t * Idempotent via UNIQUE(user_id, trigger_type, trigger_id) on crate_drops.\n14\t */\n15\t\n16\timport type { Db } from \"../../db.js\";\n17\timport { logger } from \"../../logger.js\";\n18\timport { readRewardConfig } from \"./reward-pool-fund.js\";\n19\timport { emitEvent } from \"../emit-event.js\";\n20\timport { EventTypes } from \"../event-types.js\";\n21\t\n22\t// ---------------------------------------------------------------------------\n23\t// DB helpers\n24\t// ---------------------------------------------------------------------------\n25\t\n26\texport interface RewardPoolRow {\n27\t  balance_lamports: string;\n28\t  lifetime_paid: string;\n29\t}\n30\t\n31\t/**\n32\t * Lock the reward_pool singleton row for update and return its current state.\n33\t * Must be called within a transaction.\n34\t */\n35\texport async function lockAndReadRewardPool(\n36\t  db: Db,\n37\t): Promise<RewardPoolRow> {\n38\t  const rows = await db.rawSql<RewardPoolRow[]>`\n39\t    SELECT balance_lamports, lifetime_paid\n40\t    FROM reward_pool\n41\t    WHERE id = 1\n42\t    FOR UPDATE\n43\t  `;\n44\t  if (rows.length === 0) {\n45\t    throw new Error(\"crate.drop: reward_pool singleton row missing\");\n46\t  }\n47\t  return rows[0]!;\n48\t}\n49\t\n50\t/**\n51\t * Atomically decrement reward_pool.balance_lamports and increment lifetime_paid.\n52\t * Must be called within a transaction after locking the row.\n53\t */\n54\texport async function decrementRewardPool(\n55\t  db: Db,\n56\t  payoutLamports: bigint,\n57\t): Promise<void> {\n58\t  await db.rawSql`\n59\t    UPDATE reward_pool\n60\t    SET balance_lamports = balance_lamports - ${payoutLamports},\n61\t        lifetime_paid    = lifetime_paid + ${payoutLamports},\n62\t        updated_at       = now()\n63\t    WHERE id = 1\n64\t  `;\n65\t}\n66\t\n67\t/**\n68\t * Insert a crate drop record. Returns false if a row for this\n69\t * (user_id, trigger_type, trigger_id) already exists (idempotency guard).\n70\t */\n71\texport async function insertCrateDrop(\n72\t  db: Db,\n73\t  userId: string,\n74\t  triggerType: string,\n75\t  triggerId: string,\n76\t  crateType: string,\n77\t  contentsAmount: string,\n78\t): Promise<string | null> {\n79\t  const rows = await db.rawSql<{ id: string }[]>`\n80\t    INSERT INTO crate_drops (user_id, trigger_type, trigger_id, crate_type, contents_amount)\n81\t    VALUES (${userId}, ${triggerType}, ${triggerId}, ${crateType}, ${contentsAmount})\n82\t    ON CONFLICT (user_id, trigger_type, trigger_id) DO NOTHING\n83\t    RETURNING id\n84\t  `;\n85\t  return rows[0]?.id ?? null;\n86\t}\n87\t\n88\t// ---------------------------------------------------------------------------\n89\t// Handler factory\n90\t// ---------------------------------------------------------------------------\n91\t\n92\texport interface CrateDropDeps {\n93\t  db: Db;\n94\t  /** Injectable RNG for deterministic testing. Returns a number in [0, 1). */\n95\t  rollRng?: () => number;\n96\t}\n97\t\n98\texport function createCrateDropHandler(deps: CrateDropDeps) {\n99\t  const { db, rollRng = Math.random } = deps;\n100\t\n101\t  return async (payload: Record<string, unknown>): Promise<void> => {\n102\t    const userId = payload.userId as string;\n103\t    const wallet = payload.wallet as string;\n104\t    const triggerType = payload.triggerType as string;\n105\t    const triggerId = payload.triggerId as string;\n106\t\n107\t    if (!userId || !wallet || !triggerType || !triggerId) {\n108\t      throw new Error(\n109\t        \"crate.drop: malformed payload — missing userId, wallet, triggerType, or triggerId\",\n110\t      );\n111\t    }\n112\t\n113\t    // Read all config values upfront (outside transaction to minimise lock time)\n114\t    const [\n115\t      solDropRateStr,\n116\t      pointsDropRateStr,\n117\t      solPoolPctStr,\n118\t      solMinValueStr,\n119\t      pointsCrateMinStr,\n120\t      pointsCrateMaxStr,\n121\t    ] = await Promise.all([\n122\t      readRewardConfig(db, \"sol_crate_drop_rate\"),\n123\t      readRewardConfig(db, \"points_crate_drop_rate\"),\n124\t      readRewardConfig(db, \"sol_crate_pool_pct\"),\n125\t      readRewardConfig(db, \"sol_crate_min_value\"),\n126\t      readRewardConfig(db, \"points_crate_min\"),\n127\t      readRewardConfig(db, \"points_crate_max\"),\n128\t    ]);\n129\t\n130\t    const solDropRate = parseFloat(solDropRateStr ?? \"0\");\n131\t    const pointsDropRate = parseFloat(pointsDropRateStr ?? \"0\");\n132\t    const solPoolPct = parseFloat(solPoolPctStr ?? \"0\");\n133\t    const solMinValue = BigInt(solMinValueStr ?? \"0\");\n134\t    const pointsCrateMin = parseInt(pointsCrateMinStr ?? \"0\", 10);\n135\t    const pointsCrateMax = parseInt(pointsCrateMaxStr ?? \"0\", 10);\n136\t\n137\t    // Roll RNG\n138\t    const roll = rollRng();\n139\t\n140\t    if (roll < solDropRate) {\n141\t      // --- SOL crate path ---\n142\t      await db.withTransaction(async (txDb) => {\n143\t        // Lock pool row\n144\t        const pool = await lockAndReadRewardPool(txDb);\n145\t        const poolBalance = BigInt(pool.balance_lamports);\n146\t\n147\t        // Calculate payout: floor(balance * sol_crate_pool_pct)\n148\t        const payoutLamports = BigInt(\n149\t          Math.floor(Number(poolBalance) * solPoolPct),\n150\t        );\n151\t\n152\t        // Suppress if payout < min_value\n153\t        if (payoutLamports < solMinValue) {\n154\t          logger.info(\"crate.drop: SOL crate suppressed — pool below min\", {\n155\t            userId,\n156\t            triggerId,\n157\t            poolBalance: poolBalance.toString(),\n158\t            payoutLamports: payoutLamports.toString(),\n159\t            solMinValue: solMinValue.toString(),\n160\t          });\n161\t          return;\n162\t        }\n163\t\n164\t        // Insert crate record (idempotency guard)\n165\t        const crateId = await insertCrateDrop(\n166\t          txDb,\n167\t          userId,\n168\t          triggerType,\n169\t          triggerId,\n170\t          \"sol\",\n171\t          payoutLamports.toString(),\n172\t        );\n173\t        if (!crateId) {\n174\t          logger.info(\"crate.drop: duplicate crate, skipping\", {\n175\t            userId,\n176\t            triggerType,\n177\t            triggerId,\n178\t          });\n179\t          return;\n180\t        }\n181\t\n182\t        // Decrement pool\n183\t        await decrementRewardPool(txDb, payoutLamports);\n184\t\n185\t        // Emit CRATE_SOL_PAYOUT for async SOL transfer\n186\t        await emitEvent(txDb.rawSql, EventTypes.CRATE_SOL_PAYOUT, {\n187\t          crateDropId: crateId,\n188\t          userId,\n189\t          wallet,\n190\t          payoutLamports: payoutLamports.toString(),\n191\t          triggerId,\n192\t        });\n193\t\n194\t        logger.info(\"crate.drop: SOL crate dropped\", {\n195\t          userId,\n196\t          triggerId,\n197\t          payoutLamports: payoutLamports.toString(),\n198\t        });\n199\t      });\n200\t    } else if (roll < solDropRate + pointsDropRate) {\n201\t      // --- Points crate path ---\n202\t      const range = pointsCrateMax - pointsCrateMin;\n203\t      const pointsAmount =\n204\t        range > 0\n205\t          ? pointsCrateMin + Math.floor(rollRng() * (range + 1))\n206\t          : pointsCrateMin;\n207\t\n208\t      await db.withTransaction(async (txDb) => {\n209\t        // Insert crate record (idempotency guard)\n210\t        const crateId = await insertCrateDrop(\n211\t          txDb,\n212\t          userId,\n213\t          triggerType,\n214\t          triggerId,\n215\t          \"points\",\n216\t          pointsAmount.toString(),\n217\t        );\n218\t        if (!crateId) {\n219\t          logger.info(\"crate.drop: duplicate crate, skipping\", {\n220\t            userId,\n221\t            triggerType,\n222\t            triggerId,\n223\t          });\n224\t          return;\n225\t        }\n226\t\n227\t        // Emit POINTS_GRANT with source_type='crate_points'\n228\t        await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n229\t          userId,\n230\t          wallet,\n231\t          sourceType: \"crate_points\",\n232\t          sourceId: `crate-${triggerId}`,\n233\t          amount: pointsAmount.toString(),\n234\t        });\n235\t\n236\t        logger.info(\"crate.drop: points crate dropped\", {\n237\t          userId,\n238\t          triggerId,\n239\t          pointsAmount,\n240\t        });\n241\t      });\n242\t    } else {\n243\t      // --- Miss: no drop ---\n244\t      logger.debug(\"crate.drop: no drop\", { userId, triggerId, roll });\n245\t    }\n246\t  };\n247\t}\n248\t"}]},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"1f52143f-54e8-46fd-9afa-3c73cfe25313","timestamp":"2026-04-04T07:59:31.949Z"}
