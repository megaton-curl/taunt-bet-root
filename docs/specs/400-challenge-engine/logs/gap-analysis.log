{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018FHUWaLjC78vbNUq3A9BJh","type":"tool_result","content":"3330\t    const dbRows = await rawSql`SELECT is_active FROM challenges WHERE id = ${chal.id}`;\n3331\t    expect(dbRows[0]!.is_active).toBe(false);\n3332\t  });\n3333\t});\n3334\t\n3335\t// ===========================================================================\n3336\t// Admin Dogpile + Dogpile Worker\n3337\t// ===========================================================================\n3338\t\n3339\tdescribe(\"Admin API: dogpile endpoints + status worker\", () => {\n3340\t  let db: Db;\n3341\t  let rawSql: ReturnType<typeof postgres>;\n3342\t  let adminApp: Hono;\n3343\t\n3344\t  const ADMIN_KEY = \"test-admin-key-secret\";\n3345\t\n3346\t  beforeAll(async () => {\n3347\t    rawSql = makeSql();\n3348\t    db = createDb(DATABASE_URL, rawSql);\n3349\t  });\n3350\t\n3351\t  afterAll(async () => {\n3352\t    await db.close();\n3353\t    await rawSql.end();\n3354\t  });\n3355\t\n3356\t  beforeEach(async () => {\n3357\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n3358\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n3359\t\n3360\t    adminApp = new Hono();\n3361\t    adminApp.route(\"/admin\", createAdminRoutes({ db, adminApiKey: ADMIN_KEY }));\n3362\t  });\n3363\t\n3364\t  it(\"POST /admin/dogpile schedules an event\", async () => {\n3365\t    const startsAt = new Date(Date.now() + 3600_000).toISOString(); // +1h\n3366\t    const endsAt = new Date(Date.now() + 7200_000).toISOString();   // +2h\n3367\t\n3368\t    const res = await adminApp.request(\"/admin/dogpile\", {\n3369\t      method: \"POST\",\n3370\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n3371\t      body: JSON.stringify({ startsAt, endsAt, multiplier: 3.0 }),\n3372\t    });\n3373\t    expect(res.status).toBe(201);\n3374\t    const body = (await res.json()) as Record<string, any>;\n3375\t    expect(body.status).toBe(\"scheduled\");\n3376\t    expect(Number(body.multiplier)).toBe(3.0);\n3377\t    expect(body).toHaveProperty(\"id\");\n3378\t    expect(body).toHaveProperty(\"createdAt\");\n3379\t  });\n3380\t\n3381\t  it(\"POST /admin/dogpile rejects overlapping events\", async () => {\n3382\t    const startsAt = new Date(Date.now() + 3600_000).toISOString();\n3383\t    const endsAt = new Date(Date.now() + 7200_000).toISOString();\n3384\t\n3385\t    // Create first event\n3386\t    const res1 = await adminApp.request(\"/admin/dogpile\", {\n3387\t      method: \"POST\",\n3388\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n3389\t      body: JSON.stringify({ startsAt, endsAt }),\n3390\t    });\n3391\t    expect(res1.status).toBe(201);\n3392\t\n3393\t    // Attempt overlapping event\n3394\t    const overlapStart = new Date(Date.now() + 5400_000).toISOString(); // +1.5h (overlaps)\n3395\t    const overlapEnd = new Date(Date.now() + 9000_000).toISOString();\n3396\t    const res2 = await adminApp.request(\"/admin/dogpile\", {\n3397\t      method: \"POST\",\n3398\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n3399\t      body: JSON.stringify({ startsAt: overlapStart, endsAt: overlapEnd }),\n3400\t    });\n3401\t    expect(res2.status).toBe(409);\n3402\t    const body = (await res2.json()) as Record<string, any>;\n3403\t    expect(body.error).toBe(\"OVERLAP\");\n3404\t  });\n3405\t\n3406\t  it(\"PUT /admin/dogpile/:id cancels a scheduled event\", async () => {\n3407\t    const startsAt = new Date(Date.now() + 3600_000).toISOString();\n3408\t    const endsAt = new Date(Date.now() + 7200_000).toISOString();\n3409\t\n3410\t    const createRes = await adminApp.request(\"/admin/dogpile\", {\n3411\t      method: \"POST\",\n3412\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n3413\t      body: JSON.stringify({ startsAt, endsAt }),\n3414\t    });\n3415\t    const created = (await createRes.json()) as Record<string, any>;\n3416\t\n3417\t    const res = await adminApp.request(`/admin/dogpile/${created.id}`, {\n3418\t      method: \"PUT\",\n3419\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n3420\t      body: JSON.stringify({ status: \"cancelled\" }),\n3421\t    });\n3422\t    expect(res.status).toBe(200);\n3423\t    const body = (await res.json()) as Record<string, any>;\n3424\t    expect(body.status).toBe(\"cancelled\");\n3425\t\n3426\t    // Verify in DB\n3427\t    const dbRows = await rawSql`SELECT status FROM dogpile_events WHERE id = ${created.id}`;\n3428\t    expect(dbRows[0]!.status).toBe(\"cancelled\");\n3429\t  });"}]},"parent_tool_use_id":"toolu_01X5MGk2evkgm4qCC3F7gqR6","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"efa747a8-d3d4-48a5-863b-113e028ba558","timestamp":"2026-04-04T07:58:27.377Z"}
