{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T69rDFzfmmninW4ZiUGaCY","type":"tool_result","content":"200\t});\n201\tworker.start();\n202\t\n203\t// Close Call clock worker — fetches boundary prices + settles open rounds\n204\t// Rounds are created on-demand by players via /closecall/bet\n205\tconst closeCallClock = createCloseCallClockWorker({\n206\t  connection,\n207\t  serverKeypair: config.serverKeypair,\n208\t  db,\n209\t});\n210\tcloseCallClock.start();\n211\t\n212\t// Register event handlers before starting the worker\n213\tregisterHandler(\n214\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n215\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n216\t);\n217\tregisterHandler(\n218\t  EventTypes.GAME_SETTLED,\n219\t  createGameSettledHandler({ db }),\n220\t);\n221\tregisterHandler(\n222\t  EventTypes.REWARD_POOL_FUND,\n223\t  createRewardPoolFundHandler({ db }),\n224\t);\n225\tregisterHandler(\n226\t  EventTypes.POINTS_GRANT,\n227\t  createPointsGrantHandler({\n228\t    db,\n229\t    getSolPrice: async () => {\n230\t      const result = await fetchSolPrice();\n231\t      return result?.price ?? null;\n232\t    },\n233\t  }),\n234\t);\n235\tregisterHandler(\n236\t  EventTypes.CRATE_DROP,\n237\t  createCrateDropHandler({ db }),\n238\t);\n239\tregisterHandler(\n240\t  EventTypes.CRATE_SOL_PAYOUT,\n241\t  createCrateSolPayoutHandler({ db, connection, serverKeypair: config.serverKeypair }),\n242\t);\n243\t\n244\t// Dogpile status worker — transitions scheduled→active→ended\n245\tconst dogpileWorker = createDogpileWorker({ db, pollIntervalMs: 10_000 });\n246\tdogpileWorker.start();\n247\tlogger.info(\"Dogpile worker started\");\n248\t\n249\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n250\tconst eventWorker = createEventWorker(sql, {\n251\t  pollIntervalMs: config.eventQueuePollMs,\n252\t});\n253\teventWorker.start();\n254\tlogger.info(\"Event queue worker started\", {\n255\t  pollIntervalMs: config.eventQueuePollMs,\n256\t});\n257\t\n258\t// Game-specific routes\n259\tapp.route(\n260\t  \"/coinflip\",\n261\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n262\t);\n263\tapp.route(\n264\t  \"/lord\",\n265\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n266\t);\n267\t\n268\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n269\tapp.use(\n270\t  \"/closecall/bet\",\n271\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n272\t);\n273\tapp.use(\n274\t  \"/closecall/bet\",\n275\t  createRateLimitMiddleware({\n276\t    perWallet: config.rateLimitPerWallet,\n277\t    global: config.rateLimitGlobal,\n278\t    windowMs: 60_000,\n279\t  }),\n280\t);\n281\t\n282\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n283\tapp.route(\"/closecall\", createCloseCallRoutes({\n284\t  db,\n285\t  connection,\n286\t  serverKeypair: config.serverKeypair,\n287\t  clockWorker: closeCallClock,\n288\t}));\n289\t\n290\t// Challenge routes — authenticated GET endpoints (require JWT on all methods)\n291\tapp.use(\n292\t  \"/challenges/*\",\n293\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n294\t);\n295\tapp.route(\"/challenges\", createChallengeRoutes({ db }));\n296\t\n297\t// Points routes — authenticated GET endpoints (require JWT on all methods)\n298\tapp.use(\n299\t  \"/points/*\",\n300\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n301\t);\n302\tapp.route(\"/points\", createPointsRoutes({ db }));\n303\t\n304\t// Crate routes — authenticated GET endpoints (require JWT on all methods)\n305\tapp.use(\n306\t  \"/crates/*\",\n307\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n308\t);\n309\tapp.route(\"/crates\", createCrateRoutes({ db }));\n310\t\n311\t// Dogpile routes — public, no auth\n312\tapp.route(\"/dogpile\", createDogpileRoutes({ db }));\n313\t\n314\t// Admin API routes — requires ADMIN_API_KEY env var\n315\tif (config.adminApiKey) {\n316\t  app.route(\"/admin\", createAdminRoutes({ db, adminApiKey: config.adminApiKey }));\n317\t  logger.info(\"Admin API routes enabled at /admin\");\n318\t}\n319\t\n320\t// Leaderboard routes — public, no auth\n321\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n322\t\n323\t// Price routes — public, no auth\n324\tapp.route(\"/price\", createPriceRoutes());\n325\t\n326\t// Round verification routes\n327\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n328\t\n329\t// Health endpoint — wired after worker exists so we can query its status\n330\tapp.route(\n331\t  \"/health\",\n332\t  createHealthRoutes({\n333\t    db,\n334\t    sql,\n335\t    isWorkerRunning: () => worker.isRunning,\n336\t  }),\n337\t);\n338\t\n339\t// OpenAPI docs + internal admin routes — only when ADMIN_TOKEN is set (dev/devnet only)\n340\tif (config.adminToken) {\n341\t  app.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n342\t  app.get(\"/openapi.json\", (c) => c.json(spec));\n343\t  logger.info(\"OpenAPI docs enabled at /docs and /openapi.json\");\n344\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n345\t  logger.warn(\"Internal admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n346\t}\n347\t\n348\tconst port = config.port;\n349\tlogger.info(\"fairness-backend started\", { port });\n350\t\n351\tserve({\n352\t  fetch: app.fetch,\n353\t  port,\n354\t  hostname: \"0.0.0.0\",\n355\t});\n356\t\n357\texport default {\n358\t  port,\n359\t  fetch: app.fetch,\n360\t};\n361\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"55d46df9-a09a-4be7-b5c7-283f50e0f85f","timestamp":"2026-04-04T07:58:30.726Z"}
