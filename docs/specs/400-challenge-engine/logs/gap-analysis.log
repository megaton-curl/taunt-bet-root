ns SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, name, campaign_type, starts_at, ends_at, is_active, config, created_at`;\n202\t\n203\t    const rows = await db.rawSql.unsafe(query, values) as { id: string; name: string; campaign_type: string; starts_at: string | null; ends_at: string | null; is_active: boolean; config: string; created_at: string }[];\n204\t\n205\t    if (rows.length === 0) {\n206\t      return c.json({ error: \"NOT_FOUND\", message: `Campaign ${id} not found` }, 404);\n207\t    }\n208\t\n209\t    const row = rows[0]!;\n210\t    return c.json({\n211\t      id: row.id,\n212\t      name: row.name,\n213\t      campaignType: row.campaign_type,\n214\t      startsAt: row.starts_at,\n215\t      endsAt: row.ends_at,\n216\t      isActive: row.is_active,\n217\t      config: typeof row.config === \"string\" ? JSON.parse(row.config) : row.config,\n218\t      createdAt: row.created_at,\n219\t    });\n220\t  });\n221\t\n222\t  // -------------------------------------------------------------------------\n223\t  // Challenge CRUD\n224\t  // -------------------------------------------------------------------------\n225\t\n226\t  const VALID_SCOPES = new Set([\"any\", \"coinflip\", \"lord\", \"closecall\"]);\n227\t  const VALID_REWARD_TYPES = new Set([\"points\", \"crate\"]);\n228\t\n229\t  // POST /challenges — create a challenge in a campaign\n230\t  app.post(\"/challenges\", async (c) => {\n231\t    const body = await c.req.json<{\n232\t      campaignId?: number;\n233\t      title?: string;\n234\t      description?: string;\n235\t      action?: string;\n236\t      scope?: string;\n237\t      condition?: string;\n238\t      threshold?: number;\n239\t      rewardType?: string;\n240\t      rewardAmount?: number | null;\n241\t      prerequisiteId?: number | null;\n242\t      sortOrder?: number;\n243\t    }>();\n244\t\n245\t    if (!body.campaignId) {\n246\t      return c.json({ error: \"MISSING_FIELD\", message: \"campaignId is required\" },