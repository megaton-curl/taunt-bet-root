{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N9zUKYPh4WsFgbWQUqWTFZ","type":"tool_result","content":"1\t/**\n2\t * GAME_SETTLED handler — the orchestrator for the challenge engine.\n3\t *\n4\t * Processes each player in a settled game event:\n5\t *   1. Quest eligibility check (skip refunded games)\n6\t *   2. Challenge progress evaluation via adapters\n7\t *   3. Reward intent emission on challenge completion\n8\t *   4. Wager-based points grant\n9\t *   5. Crate drop roll\n10\t *\n11\t * Once per round: reward pool funding.\n12\t *\n13\t * Per-player try/catch ensures one player's error doesn't block others.\n14\t * Idempotent via UNIQUE constraints on progress_events, point_grants,\n15\t * crate_drops, and reward_pool_fundings.\n16\t */\n17\t\n18\timport type { Db } from \"../../db.js\";\n19\timport { logger } from \"../../logger.js\";\n20\timport { emitEvent } from \"../emit-event.js\";\n21\timport { EventTypes } from \"../event-types.js\";\n22\timport {\n23\t  questEligible,\n24\t  getAdapter,\n25\t  type GameSettledPayload,\n26\t  type GameSettledPlayer,\n27\t  type ChallengeAssignment,\n28\t} from \"./challenge-adapters.js\";\n29\timport { checkCompletionBonus } from \"./completion-bonus.js\";\n30\timport { advanceOnboardingChain } from \"./onboarding-chain.js\";\n31\t\n32\t// ---------------------------------------------------------------------------\n33\t// DB helpers\n34\t// ---------------------------------------------------------------------------\n35\t\n36\t/** Row shape from the active-assignments + challenges JOIN. */\n37\tinterface AssignmentWithChallenge {\n38\t  id: string;\n39\t  challenge_id: string;\n40\t  action: string;\n41\t  scope: string;\n42\t  condition: string;\n43\t  target: number;\n44\t  progress: number;\n45\t  status: string;\n46\t  period_key: string;\n47\t  campaign_id: string;\n48\t  reward_type: string;\n49\t  reward_amount: number | null;\n50\t}\n51\t\n52\t/**\n53\t * Load active challenge assignments for a user, joined with their challenge\n54\t * definitions. Uses the partial index on (user_id, status) WHERE status='active'.\n55\t */\n56\texport async function getActiveAssignmentsWithChallenge(\n57\t  db: Db,\n58\t  userId: string,\n59\t): Promise<AssignmentWithChallenge[]> {\n60\t  return db.rawSql<AssignmentWithChallenge[]>`\n61\t    SELECT\n62\t      ca.id,\n63\t      ca.challenge_id,\n64\t      c.action,\n65\t      c.scope,\n66\t      c.condition,\n67\t      ca.target,\n68\t      ca.progress,\n69\t      ca.status,\n70\t      ca.period_key,\n71\t      c.campaign_id,\n72\t      c.reward_type,\n73\t      c.reward_amount\n74\t    FROM challenge_assignments ca\n75\t    JOIN challenges c ON c.id = ca.challenge_id\n76\t    WHERE ca.user_id = ${userId}\n77\t      AND ca.status = 'active'\n78\t  `;\n79\t}\n80\t\n81\t/**\n82\t * Insert a progress event. Returns false if a row for this\n83\t * (assignment_id, round_id) already exists (idempotency guard).\n84\t */\n85\texport async function insertProgressEvent(\n86\t  db: Db,\n87\t  assignmentId: string,\n88\t  roundId: string,\n89\t  userId: string,\n90\t  delta: number,\n91\t  metadata: Record<string, unknown>,\n92\t): Promise<boolean> {\n93\t  const rows = await db.rawSql<{ id: string }[]>`\n94\t    INSERT INTO progress_events (assignment_id, round_id, user_id, progress_delta, metadata)\n95\t    VALUES (${assignmentId}, ${roundId}, ${userId}, ${delta}, ${JSON.stringify(metadata)})\n96\t    ON CONFLICT (assignment_id, round_id) DO NOTHING\n97\t    RETURNING id\n98\t  `;\n99\t  return rows.length > 0;\n100\t}\n101\t\n102\t/**\n103\t * Atomically increment an assignment's progress by delta.\n104\t * Returns the new progress value.\n105\t */\n106\texport async function incrementAssignmentProgress(\n107\t  db: Db,\n108\t  assignmentId: string,\n109\t  delta: number,\n110\t): Promise<number> {\n111\t  const rows = await db.rawSql<{ progress: number }[]>`\n112\t    UPDATE challenge_assignments\n113\t    SET progress = progress + ${delta}\n114\t    WHERE id = ${assignmentId}\n115\t    RETURNING progress\n116\t  `;\n117\t  return rows[0]!.progress;\n118\t}\n119\t\n120\t/**\n121\t * Mark an assignment as completed with a timestamp.\n122\t */\n123\texport async function markAssignmentCompleted(\n124\t  db: Db,\n125\t  assignmentId: string,\n126\t): Promise<void> {\n127\t  await db.rawSql`\n128\t    UPDATE challenge_assignments\n129\t    SET status = 'completed', completed_at = now()\n130\t    WHERE id = ${assignmentId}\n131\t  `;\n132\t}\n133\t\n134\t// ---------------------------------------------------------------------------\n135\t// Handler factory\n136\t// ---------------------------------------------------------------------------\n137\t\n138\texport interface GameSettledDeps {\n139\t  db: Db;\n140\t}\n141\t\n142\texport function createGameSettledHandler(deps: GameSettledDeps) {\n143\t  const { db } = deps;\n144\t\n145\t  return async (payload: Record<string, unknown>): Promise<void> => {\n146\t    // Validate and cast payload\n147\t    const roundId = payload.roundId as string;\n148\t    const game = payload.game as string;\n149\t    const players = payload.players as GameSettledPlayer[] | undefined;\n150\t    const feeLamports = payload.feeLamports as string;\n151\t    const settledAt = payload.settledAt as string;\n152\t    const roundPda = payload.roundPda as string;\n153\t\n154\t    if (!roundId || !game || !players || !feeLamports || !settledAt) {\n155\t      throw new Error(\n156\t        \"game.settled: malformed payload — missing roundId, game, players, feeLamports, or settledAt\",\n157\t      );\n158\t    }\n159\t\n160\t    // --- Once per round: emit reward.pool_fund ---\n161\t    await emitEvent(db.rawSql, EventTypes.REWARD_POOL_FUND, {\n162\t      roundId,\n163\t      roundPda,\n164\t      feeLamports,\n165\t    });\n166\t\n167\t    // --- Per-player processing ---\n168\t    for (const player of players) {\n169\t      try {\n170\t        // Quest eligibility gate — skip refunded games\n171\t        if (!questEligible(player)) {\n172\t          logger.debug(\"game.settled: player ineligible (refund)\", {\n173\t            userId: player.userId,\n174\t            roundId,\n175\t          });\n176\t          continue;\n177\t        }\n178\t\n179\t        // ---- Challenge progress evaluation ----\n180\t        const assignments = await getActiveAssignmentsWithChallenge(\n181\t          db,\n182\t          player.userId,\n183\t        );\n184\t\n185\t        for (const assignment of assignments) {\n186\t          const adapter = getAdapter(assignment.action);\n187\t          const challengeAssignment: ChallengeAssignment = {\n188\t            id: Number(assignment.id),\n189\t            challengeId: Number(assignment.challenge_id),\n190\t            action: assignment.action,\n191\t            scope: assignment.scope,\n192\t            condition: assignment.condition,\n193\t            target: assignment.target,\n194\t            progress: assignment.progress,\n195\t            status: assignment.status,\n196\t          };\n197\t\n198\t          const result = adapter(\n199\t            payload as unknown as GameSettledPayload,\n200\t            player,\n201\t            challengeAssignment,\n202\t          );\n203\t\n204\t          if (!result.shouldProgress) continue;\n205\t\n206\t          // Atomic: insert progress event + increment progress\n207\t          await db.withTransaction(async (txDb) => {\n208\t            const inserted = await insertProgressEvent(\n209\t              txDb,\n210\t              assignment.id,\n211\t              roundId,\n212\t              player.userId,\n213\t              result.progressDelta,\n214\t              { game },\n215\t            );\n216\t            if (!inserted) {\n217\t              // Duplicate round for this assignment — skip\n218\t              return;\n219\t            }\n220\t\n221\t            const newProgress = await incrementAssignmentProgress(\n222\t              txDb,\n223\t              assignment.id,\n224\t              result.progressDelta,\n225\t            );\n226\t\n227\t            // Check completion\n228\t            if (newProgress >= assignment.target) {\n229\t              await markAssignmentCompleted(txDb, assignment.id);\n230\t\n231\t              // Emit reward intent based on challenge's reward_type\n232\t              if (assignment.reward_type === \"points\" && assignment.reward_amount) {\n233\t                await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n234\t                  userId: player.userId,\n235\t                  wallet: player.wallet,\n236\t                  sourceType: \"challenge_completed\",\n237\t                  sourceId: `challenge-${assignment.id}`,\n238\t                  amount: assignment.reward_amount.toString(),\n239\t                });\n240\t              } else if (assignment.reward_type === \"crate\") {\n241\t                await emitEvent(txDb.rawSql, EventTypes.CRATE_DROP, {\n242\t                  userId: player.userId,\n243\t                  wallet: player.wallet,\n244\t                  triggerType: \"challenge_completed\",\n245\t                  triggerId: `challenge-${assignment.id}`,\n246\t                });\n247\t              }\n248\t\n249\t              logger.info(\"game.settled: challenge completed\", {\n250\t                userId: player.userId,\n251\t                assignmentId: assignment.id,\n252\t                challengeId: assignment.challenge_id,\n253\t                rewardType: assignment.reward_type,\n254\t              });\n255\t\n256\t              // Check completion bonus (e.g., all daily challenges done → bonus crate)\n257\t              await checkCompletionBonus(\n258\t                txDb,\n259\t                player.userId,\n260\t                player.wallet,\n261\t                assignment.period_key,\n262\t                assignment.campaign_id,\n263\t              );\n264\t\n265\t              // Advance onboarding chain (auto-assign next step)\n266\t              await advanceOnboardingChain(\n267\t                txDb,\n268\t                player.userId,\n269\t                assignment.challenge_id,\n270\t                assignment.period_key,\n271\t              );\n272\t            }\n273\t          });\n274\t        }\n275\t\n276\t        // ---- Wager-based points grant ----\n277\t        await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n278\t          userId: player.userId,\n279\t          wallet: player.wallet,\n280\t          sourceType: \"wager\",\n281\t          sourceId: roundId,\n282\t          amountLamports: player.amountLamports,\n283\t          settledAt,\n284\t        });\n285\t\n286\t        // ---- Crate drop ----\n287\t        await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n288\t          userId: player.userId,\n289\t          wallet: player.wallet,\n290\t          triggerType: \"game_settled\",\n291\t          triggerId: roundId,\n292\t        });\n293\t      } catch (err) {\n294\t        // Per-player try/catch — don't let one player's error block others\n295\t        logger.error(\"game.settled: error processing player\", {\n296\t          userId: player.userId,\n297\t          roundId,\n298\t          error: err instanceof Error ? err.message : String(err),\n299\t        });\n300\t      }\n301\t    }\n302\t\n303\t    logger.info(\"game.settled: processed\", {\n304\t      roundId,\n305\t      game,\n306\t      playerCount: players.length,\n307\t    });\n308\t  };\n309\t}\n310\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"4a3fc7c9-a9a8-4b2d-a0f3-692f83d14938","timestamp":"2026-04-04T07:58:17.948Z"}
