{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019PwTALkwHJN3Js2kTLPuvm","type":"tool_result","content":"200\t    FROM challenge_assignments ca\n201\t    JOIN challenges c ON c.id = ca.challenge_id\n202\t    JOIN campaigns camp ON camp.id = c.campaign_id\n203\t    WHERE ca.user_id = ${userId}\n204\t      AND ca.period_key = 'onboarding'\n205\t    ORDER BY c.sort_order ASC\n206\t  `;\n207\t}\n208\t\n209\t/** Get all onboarding challenge templates (ordered by chain). */\n210\tasync function getOnboardingChallenges(\n211\t  db: Db,\n212\t  campaignId: string,\n213\t): Promise<ChallengeRow[]> {\n214\t  return db.rawSql<ChallengeRow[]>`\n215\t    SELECT id, campaign_id, title, description, action, scope, condition,\n216\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n217\t    FROM challenges\n218\t    WHERE campaign_id = ${campaignId}\n219\t      AND is_active = true\n220\t    ORDER BY sort_order ASC\n221\t  `;\n222\t}\n223\t\n224\t/** Get completion bonuses for a campaign. */\n225\tasync function getCompletionBonusesForCampaign(\n226\t  db: Db,\n227\t  campaignId: string,\n228\t): Promise<CompletionBonusRow[]> {\n229\t  return db.rawSql<CompletionBonusRow[]>`\n230\t    SELECT id, title, required_count, reward_type, reward_amount\n231\t    FROM completion_bonuses\n232\t    WHERE campaign_id = ${campaignId}\n233\t      AND is_active = true\n234\t  `;\n235\t}\n236\t\n237\t/** Check if a bonus was completed for a user in a given period. */\n238\tasync function getBonusCompletion(\n239\t  db: Db,\n240\t  userId: string,\n241\t  bonusId: string,\n242\t  periodKey: string,\n243\t): Promise<BonusCompletionRow | null> {\n244\t  const rows = await db.rawSql<BonusCompletionRow[]>`\n245\t    SELECT id FROM bonus_completions\n246\t    WHERE user_id = ${userId}\n247\t      AND bonus_id = ${bonusId}\n248\t      AND period_key = ${periodKey}\n249\t    LIMIT 1\n250\t  `;\n251\t  return rows[0] ?? null;\n252\t}\n253\t\n254\t/** Count completed assignments for a user in a period+campaign. */\n255\tasync function countCompleted(\n256\t  db: Db,\n257\t  userId: string,\n258\t  periodKey: string,\n259\t  campaignId: string,\n260\t): Promise<number> {\n261\t  const rows = await db.rawSql<{ count: string }[]>`\n262\t    SELECT COUNT(*)::TEXT AS count\n263\t    FROM challenge_assignments ca\n264\t    JOIN challenges c ON c.id = ca.challenge_id\n265\t    WHERE ca.user_id = ${userId}\n266\t      AND ca.period_key = ${periodKey}\n267\t      AND ca.status = 'completed'\n268\t      AND c.campaign_id = ${campaignId}\n269\t  `;\n270\t  return Number(rows[0]!.count);\n271\t}\n272\t\n273\t/** Create an assignment (idempotent via UNIQUE). */\n274\tasync function createAssignment(\n275\t  db: Db,\n276\t  userId: string,\n277\t  challengeId: string,\n278\t  periodKey: string,\n279\t  target: number,\n280\t  expiresAt: string | null,\n281\t): Promise<void> {\n282\t  await db.rawSql`\n283\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n284\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n285\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n286\t  `;\n287\t}\n288\t\n289\t// ---------------------------------------------------------------------------\n290\t// Helpers\n291\t// ---------------------------------------------------------------------------\n292\t\n293\t/** Parse and clamp a numeric query param. Returns `defaultVal` if missing/invalid. */\n294\tfunction parseIntParam(raw: string | undefined, defaultVal: number, max: number): number {\n295\t  if (!raw) return defaultVal;\n296\t  const parsed = parseInt(raw, 10);\n297\t  if (isNaN(parsed) || parsed < 1) return defaultVal;\n298\t  return Math.min(parsed, max);\n299\t}\n300\t\n301\t// ---------------------------------------------------------------------------\n302\t// Route factory\n303\t// ---------------------------------------------------------------------------\n304\t\n305\texport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n306\t  const { db } = deps;\n307\t  const app = new Hono<AppEnv>();\n308\t\n309\t  app.get(\"/mine\", async (c) => {\n310\t    const userId = c.get(\"userId\");\n311\t    if (!userId) {\n312\t      return c.json({ error: \"Authentication required\" }, 401);\n313\t    }\n314\t\n315\t    try {\n316\t      const now = new Date();\n317\t\n318\t      // 1. Expire stale assignments\n319\t      await expireStaleAssignments(db, userId);\n320\t\n321\t      // 2. Compute current period keys\n322\t      const dailyKey = dailyPeriodKey(now);\n323\t      const weeklyKey = weeklyPeriodKey(now);\n324\t\n325\t      // 3. Read config for challenge counts\n326\t      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n327\t      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n328\t      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n329\t      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n330\t\n331\t      // 4. Look up campaign IDs\n332\t      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n333\t        getCampaignByType(db, \"daily\"),\n334\t        getCampaignByType(db, \"weekly\"),\n335\t        getCampaignByType(db, \"onboarding\"),\n336\t      ]);\n337\t\n338\t      // 5. Lazy assignment — daily\n339\t      let dailyAssignments = dailyCampaign\n340\t        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n341\t        : [];\n342\t\n343\t      if (dailyAssignments.length === 0 && dailyCampaign) {\n344\t        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n345\t        const dailyExpires = dailyResetsAt(now);\n346\t        for (const t of templates) {\n347\t          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n348\t        }\n349\t        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n350\t      }\n351\t\n352\t      // 6. Lazy assignment — weekly\n353\t      let weeklyAssignments = weeklyCampaign\n354\t        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n355\t        : [];\n356\t\n357\t      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n358\t        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n359\t        const weeklyExpires = weeklyResetsAt(now);\n360\t        for (const t of templates) {\n361\t          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n362\t        }\n363\t        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n364\t      }\n365\t\n366\t      // 7. Lazy assignment — onboarding\n367\t      let onboardingAssignments = onboardingCampaign\n368\t        ? await getOnboardingAssignments(db, userId)\n369\t        : [];\n370\t\n371\t      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n372\t        // Assign first step (prerequisite_id IS NULL)\n373\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n374\t        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n375\t        if (firstStep) {\n376\t          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n377\t          onboardingAssignments = await getOnboardingAssignments(db, userId);\n378\t        }\n379\t      }\n380\t\n381\t      // 8. Build bonus status for daily\n382\t      let dailyBonus: object | null = null;\n383\t      if (dailyCampaign) {\n384\t        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n385\t        if (bonuses.length > 0) {\n386\t          const bonus = bonuses[0]!;\n387\t          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n388\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n389\t          dailyBonus = {\n390\t            title: bonus.title,\n391\t            required: bonus.required_count,\n392\t            completed: completedCount,\n393\t            status: bonusCompletion ? \"completed\" : \"active\",\n394\t            reward: {\n395\t              type: bonus.reward_type,\n396\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n397\t            },\n398\t          };\n399\t        }"}]},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"c0e4e8ed-e6de-446e-b423-305c15e49db5","timestamp":"2026-04-04T07:59:36.524Z"}
