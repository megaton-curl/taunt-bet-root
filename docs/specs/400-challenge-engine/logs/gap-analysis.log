db }));\n2817\t\n2818\t    dogpileApp = new Hono();\n2819\t    dogpileApp.route(\"/dogpile\", createDogpileRoutes({ db }));\n2820\t  });\n2821\t\n2822\t  // -- /challenges/mine/history tests --\n2823\t\n2824\t  it(\"GET /challenges/mine/history returns paginated completed assignments\", async () => {\n2825\t    // Seed 3 completed challenge assignments\n2826\t    const challenges = await rawSql<{ id: string; threshold: number; }[]>`\n2827\t      SELECT id, threshold FROM challenges WHERE is_active = true ORDER BY sort_order ASC LIMIT 3\n2828\t    `;\n2829\t\n2830\t    for (let i = 0; i < 3; i++) {\n2831\t      await rawSql`\n2832\t        INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, status, progress, completed_at)\n2833\t        VALUES (${testUserId}, ${challenges[i]!.id}, ${\"daily:2026-01-0\" + (i + 1)}, ${challenges[i]!.threshold}, 'completed', ${challenges[i]!.threshold}, ${new Date(Date.UTC(2026, 0, i + 1)).toISOString()})\n2834\t      `;\n2835\t    }\n2836\t\n2837\t    const token = await makeJwt(testWallet, testUserId);\n2838\t\n2839\t    // Fetch first page with limit=2\n2840\t    const res1 = await challengeApp.request(\"/challenges/mine/history?limit=2\", {\n2841\t      method: \"GET\",\n2842\t      headers: { Authorization: `Bearer ${token}` },\n2843\t    });\n2844\t    expect(res1.status).toBe(200);\n2845\t    const body1 = (await res1.json()) as Record<string, any>;\n2846\t    expect(body1.items).toHaveLength(2);\n2847\t    // DESC order by id: most recently inserted first\n2848\t    expect(body1.items[0]).toHaveProperty(\"id\");\n2849\t    expect(body1.items[0]).toHaveProperty(\"title\");\n2850\t    expect(body1.items[0]).toHaveProperty(\"description\");\n2851\t    expect(body1.items[0]).toHaveProperty(\"completedAt\");\n2852\t    expect(body1.items[0]).toHaveProperty(\"reward\");\n2853\t    expect(body1.items[0].reward).toHaveProperty(\"type\");\n2854\t    expect(body1.nextCursor).not.toBeNull();\n2855\t\n2856\t    // Fetch second page\n2857\t    const res2 = await challengeApp.request(`/challenges/mine/history?limit=2&cursor=${body1.nextCursor}`, {\n2858\t      method: \"GET\",\n2859\t      headers: { Authorization: `Bearer ${token}` },\n2860\t    });\n2861\t    expect(res2.status).toBe(200);\n2862\t    const body2 = (await res2.json()) as Record<string, any>;\n2863\t    expect(body2.items).toHaveLength(1);\n2864\t    expect(body2.nextCursor).toBeNull();\n2865\t  });\n2866\t\n2867\t  it(\"GET /challenges/mine/history returns empty when no completed assignments\", async () => {\n2868\t    // Insert active (not completed) assignment\n2869\t    const challenges = await rawSql<{ id: string; threshold: number }[]>`\n2870\t      SELECT id, threshold FROM challenges WHERE is_active = true ORDER BY sort_order ASC LIMIT 1\n2871\t    `;\n2872\t    await rawSql`\n2873\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, status)\n2874\t      VALUES (${testUserId}, ${challenges[0]!.id}, 'daily:2026-01-01', ${challenges[0]!.threshold}, 'active')\n2875\t    `;\n2876\t\n2877\t    const token = await makeJwt(testWallet, testUserId);\n2878\t    const res = await challengeApp.request(\"/challenges/mine/history\", {\n2879\t      method: \"GET\","}]},"parent_tool_use_id":"toolu_01X5MGk2evkgm4qCC3F7gqR6","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"26181e48-e487-4061-a8c2-87f1a4890737","timestamp":"2026-04-04T07:58:24.547Z"}
