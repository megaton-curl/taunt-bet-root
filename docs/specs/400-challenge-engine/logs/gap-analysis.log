{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019C2K9e9h6fpYfCxzQSxtNC","type":"tool_result","content":"2980\t// Admin API Tests\n2981\t// ---------------------------------------------------------------------------\n2982\t\n2983\tdescribe(\"Admin API: reward-config + reward-pool\", () => {\n2984\t  let db: Db;\n2985\t  let rawSql: ReturnType<typeof postgres>;\n2986\t  let adminApp: Hono;\n2987\t\n2988\t  const ADMIN_KEY = \"test-admin-key-secret\";\n2989\t\n2990\t  beforeAll(async () => {\n2991\t    rawSql = makeSql();\n2992\t    db = createDb(DATABASE_URL, rawSql);\n2993\t  });\n2994\t\n2995\t  afterAll(async () => {\n2996\t    await db.close();\n2997\t    await rawSql.end();\n2998\t  });\n2999\t\n3000\t  beforeEach(async () => {\n3001\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n3002\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n3003\t    // Reset reward_config to defaults\n3004\t    await rawSql`UPDATE reward_config SET value = '500' WHERE key = 'points_per_dollar'`;\n3005\t\n3006\t    adminApp = new Hono();\n3007\t    adminApp.route(\"/admin\", createAdminRoutes({ db, adminApiKey: ADMIN_KEY }));\n3008\t  });\n3009\t\n3010\t  it(\"request without X-Admin-Key returns 401\", async () => {\n3011\t    const res = await adminApp.request(\"/admin/reward-config\", { method: \"GET\" });\n3012\t    expect(res.status).toBe(401);\n3013\t    const body = (await res.json()) as Record<string, any>;\n3014\t    expect(body.error).toBe(\"UNAUTHORIZED\");\n3015\t  });\n3016\t\n3017\t  it(\"request with wrong X-Admin-Key returns 401\", async () => {\n3018\t    const res = await adminApp.request(\"/admin/reward-config\", {\n3019\t      method: \"GET\",\n3020\t      headers: { \"X-Admin-Key\": \"wrong-key\" },\n3021\t    });\n3022\t    expect(res.status).toBe(401);\n3023\t    const body = (await res.json()) as Record<string, any>;\n3024\t    expect(body.error).toBe(\"UNAUTHORIZED\");\n3025\t  });\n3026\t\n3027\t  it(\"GET /admin/reward-config returns all seeded defaults\", async () => {\n3028\t    const res = await adminApp.request(\"/admin/reward-config\", {\n3029\t      method: \"GET\",\n3030\t      headers: { \"X-Admin-Key\": ADMIN_KEY },\n3031\t    });\n3032\t    expect(res.status).toBe(200);\n3033\t    const body = (await res.json()) as Record<string, any>;\n3034\t\n3035\t    // Verify all 11 seeded keys present\n3036\t    expect(Object.keys(body)).toHaveLength(11);\n3037\t    expect(body.points_per_dollar.value).toBe(\"500\");\n3038\t    expect(body.reward_pool_fee_share.value).toBe(\"0.20\");\n3039\t    expect(body.sol_crate_drop_rate.value).toBe(\"0.01\");\n3040\t    expect(body.daily_challenge_count.value).toBe(\"3\");\n3041\t    // Each entry has updatedAt\n3042\t    expect(body.points_per_dollar).toHaveProperty(\"updatedAt\");\n3043\t  });\n3044\t\n3045\t  it(\"PUT /admin/reward-config/:key updates value\", async () => {\n3046\t    const res = await adminApp.request(\"/admin/reward-config/points_per_dollar\", {\n3047\t      method: \"PUT\",\n3048\t      headers: {\n3049\t        \"X-Admin-Key\": ADMIN_KEY,\n3050\t        \"Content-Type\": \"application/json\",\n3051\t      },\n3052\t      body: JSON.stringify({ value: \"1000\" }),\n3053\t    });\n3054\t    expect(res.status).toBe(200);\n3055\t    const body = (await res.json()) as Record<string, any>;\n3056\t    expect(body.key).toBe(\"points_per_dollar\");\n3057\t    expect(body.value).toBe(\"1000\");\n3058\t\n3059\t    // Verify persisted\n3060\t    const verify = await adminApp.request(\"/admin/reward-config\", {\n3061\t      method: \"GET\",\n3062\t      headers: { \"X-Admin-Key\": ADMIN_KEY },\n3063\t    });\n3064\t    const verifyBody = (await verify.json()) as Record<string, any>;\n3065\t    expect(verifyBody.points_per_dollar.value).toBe(\"1000\");\n3066\t  });\n3067\t\n3068\t  it(\"PUT /admin/reward-config/:key rejects unknown key with 400\", async () => {\n3069\t    const res = await adminApp.request(\"/admin/reward-config/nonexistent_key\", {\n3070\t      method: \"PUT\",\n3071\t      headers: {\n3072\t        \"X-Admin-Key\": ADMIN_KEY,\n3073\t        \"Content-Type\": \"application/json\",\n3074\t      },\n3075\t      body: JSON.stringify({ value: \"123\" }),\n3076\t    });\n3077\t    expect(res.status).toBe(400);\n3078\t    const body = (await res.json()) as Record<string, any>;\n3079\t    expect(body.error).toBe(\"INVALID_KEY\");"}]},"parent_tool_use_id":"toolu_01X5MGk2evkgm4qCC3F7gqR6","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"6a89b330-1547-4b97-b3da-ce1a1d41a21a","timestamp":"2026-04-04T07:58:24.744Z"}
