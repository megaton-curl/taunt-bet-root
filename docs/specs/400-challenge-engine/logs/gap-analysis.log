{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DfKhCA6vthcgD8A89Dsxsm","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createChallengeRoutes } from \"./routes/challenges.js\";\n21\timport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\n22\timport { createDogpileRoutes } from \"./routes/dogpile.js\";\n23\timport { createAdminRoutes } from \"./routes/admin.js\";\n24\timport { createInternalRoutes } from \"./routes/internal.js\";\n25\timport { swaggerUI } from \"@hono/swagger-ui\";\n26\timport { spec } from \"./openapi.js\";\n27\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n28\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n29\timport { createSettlementWorker } from \"./worker/settlement.js\";\n30\timport { settleRound } from \"./worker/settle-tx.js\";\n31\timport { createRetrySettler } from \"./worker/retry.js\";\n32\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n33\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n34\timport { createDogpileWorker } from \"./worker/dogpile-worker.js\";\n35\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n36\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n37\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n38\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n39\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n40\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n41\timport { createCrateSolPayoutHandler } from \"./queue/handlers/crate-sol-payout.js\";\n42\timport { fetchSolPrice } from \"./routes/price.js\";\n43\timport { logger } from \"./logger.js\";\n44\t\n45\tconst config = loadConfig();\n46\t\n47\t// Single postgres pool shared by game DB, auth DB, and all workers\n48\tconst sql = postgres(config.databaseUrl);\n49\tconst db = createDb(config.databaseUrl, sql);\n50\tconst authDb = createAuthDb(sql);\n51\t\n52\tconst connection = new Connection(config.rpcUrl, {\n53\t  commitment: \"confirmed\",\n54\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n55\t});\n56\t\n57\tconst app = new Hono();\n58\t\n59\tapp.use(\n60\t  \"*\",\n61\t  cors({\n62\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n63\t    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n64\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\", \"X-Admin-Key\"],\n65\t  }),\n66\t);\n67\t\n68\t// Request logging — correlate frontend fetch timing with server-side processing\n69\tapp.use(\"*\", async (c, next) => {\n70\t  const start = Date.now();\n71\t  await next();\n72\t  const ms = Date.now() - start;\n73\t  const method = c.req.method;\n74\t  const path = c.req.path;\n75\t  // Skip noisy health checks and OPTIONS preflight\n76\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n77\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n78\t});\n79\t\n80\t// Auth routes — no JWT middleware (these are the login endpoints)\n81\t// Lighter rate limiting by IP for auth endpoints\n82\tapp.use(\n83\t  \"/auth/*\",\n84\t  createRateLimitMiddleware({\n85\t    perWallet: 20,\n86\t    global: config.rateLimitGlobal,\n87\t    windowMs: 60_000,\n88\t  }),\n89\t);\n90\t\n91\tapp.route(\n92\t  \"/auth\",\n93\t  createAuthRoutes({\n94\t    authDb,\n95\t    db,\n96\t    jwtSecret: config.jwtSecret,\n97\t    cluster: config.cluster,\n98\t    challengeTtlSeconds: config.challengeTtlSeconds,\n99\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n100\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n101\t  }),\n102\t);\n103\t\n104\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n105\tapp.use(\n106\t  \"/profile/*\",\n107\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n108\t);\n109\tapp.route(\"/profile\", createProfileRoutes({ db }));\n110\t\n111\t// Public profile routes — no auth required\n112\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n113\t\n114\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n115\tapp.use(\n116\t  \"/referral/*\",\n117\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n118\t);\n119\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n120\t\n121\t// JWT auth middleware for game endpoints\n122\tapp.use(\n123\t  \"/coinflip/*\",\n124\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n125\t);\n126\tapp.use(\n127\t  \"/lord/*\",\n128\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n129\t);\n130\t\n131\t// Rate limiting — per-wallet and global limits on POST requests\n132\tapp.use(\n133\t  \"/coinflip/*\",\n134\t  createRateLimitMiddleware({\n135\t    perWallet: config.rateLimitPerWallet,\n136\t    global: config.rateLimitGlobal,\n137\t    windowMs: 60_000,\n138\t  }),\n139\t);\n140\tapp.use(\n141\t  \"/lord/*\",\n142\t  createRateLimitMiddleware({\n143\t    perWallet: config.rateLimitPerWallet,\n144\t    global: config.rateLimitGlobal,\n145\t    windowMs: 60_000,\n146\t  }),\n147\t);\n148\t\n149\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n150\tconst entropyAccount = new PublicKey(config.entropyAccount);\n151\tconst retrySettler = createRetrySettler({\n152\t  db,\n153\t  connection,\n154\t  settleRound: (pda) =>\n155\t    settleRound(\n156\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n157\t      pda,\n158\t    ),\n159\t});\n160\t\n161\t// PDA watcher — WebSocket-based instant join detection\n162\tconst pdaWatcher = createPdaWatcher({\n163\t  connection,\n164\t  serverKey: config.serverKeypair.publicKey,\n165\t  db,\n166\t  onJoinDetected: async (pda, targetSlot) => {\n167\t    // Update DB phase if still in 'created'\n168\t    const round = await db.getRoundByPda(pda);\n169\t    if (round && round.phase === \"created\") {\n170\t      await db.updateRoundPhase(pda, \"locked\", {\n171\t        target_slot: targetSlot.toString(),\n172\t      });\n173\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n174\t        targetSlot: targetSlot.toString(),\n175\t        source: \"pda-watcher\",\n176\t        game: round.game,\n177\t      });\n178\t    }\n179\t\n180\t    // Check if target slot already passed — settle immediately if so\n181\t    const currentSlot = await connection.getSlot();\n182\t    if (BigInt(currentSlot) >= targetSlot) {\n183\t      await retrySettler.attemptSettle(pda);\n184\t      pdaWatcher.unwatch(pda);\n185\t    }\n186\t    // If target slot not reached yet, poll worker will pick it up next cycle\n187\t  },\n188\t});\n189\t\n190\tconst worker = createSettlementWorker({\n191\t  db,\n192\t  connection,\n193\t  serverKey: config.serverKeypair.publicKey,\n194\t  pollIntervalMs: config.workerPollIntervalMs,\n195\t  onSettleReady: async (pda) => {\n196\t    await retrySettler.attemptSettle(pda);\n197\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n198\t  },\n199\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n200\t});"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"ab6f8bbc-3b1a-42bb-b31e-03a3e0967c39","timestamp":"2026-04-04T07:58:29.075Z"}
