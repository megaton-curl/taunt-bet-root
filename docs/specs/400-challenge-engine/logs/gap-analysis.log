etClauses.push(`is_active = $${values.length}`);\n375\t    }\n376\t\n377\t    if (setClauses.length === 0) {\n378\t      return c.json({ error: \"NO_FIELDS\", message: \"No fields to update\" }, 400);\n379\t    }\n380\t\n381\t    values.push(id);\n382\t    const idPlaceholder = `$${values.length}`;\n383\t\n384\t    const query = `UPDATE challenges SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order, is_active, created_at`;\n385\t\n386\t    const rows = await db.rawSql.unsafe(query, values) as {\n387\t      id: string; campaign_id: string; title: string; description: string | null;\n388\t      action: string; scope: string; condition: string; threshold: number;\n389\t      reward_type: string; reward_amount: number | null; prerequisite_id: string | null;\n390\t      sort_order: number; is_active: boolean; created_at: string;\n391\t    }[];\n392\t\n393\t    if (rows.length === 0) {\n394\t      return c.json({ error: \"NOT_FOUND\", message: `Challenge ${id} not found` }, 404);\n395\t    }\n396\t\n397\t    const row = rows[0]!;\n398\t    return c.json({\n399\t      id: row.id,"}]},"parent_tool_use_id":"toolu_019CPHdDURRQi3EMkADzuhYS","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"f0b9fb88-6794-4461-9d35-dcef98581c0a","timestamp":"2026-04-04T07:59:36.840Z"}
