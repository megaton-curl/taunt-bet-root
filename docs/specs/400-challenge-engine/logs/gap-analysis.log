{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QhQyBt9LQsYG14ZEUKXagy","type":"tool_result","content":"/**\n * Internal admin routes — dev/devnet only.\n *\n * POST /reset-db — drop all tables, re-run migrations, then exit the process.\n * Only registered when ADMIN_TOKEN env var is set.\n */\n\nimport { Hono } from \"hono\";\nimport type postgres from \"postgres\";\nimport type { Config } from \"../config.js\";\nimport { runMigrations } from \"../migrate.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface InternalRoutesDeps {\n  config: Config;\n  sql: postgres.Sql;\n}\n\nfunction quoteIdentifier(identifier: string): string {\n  if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(identifier)) {\n    throw new Error(`Invalid schema name: ${identifier}`);\n  }\n  return `\"${identifier}\"`;\n}\n\nexport function createInternalRoutes(deps: InternalRoutesDeps) {\n  const { config, sql } = deps;\n  const app = new Hono();\n\n  app.post(\"/reset-db\", async (c) => {\n    const token = c.req.header(\"X-Admin-Token\");\n    if (!token || token !== config.adminToken) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n\n    logger.warn(\"reset-db: dropping all tables and re-running migrations\");\n\n    try {\n      const schema = config.dbSchema;\n      const quoted = quoteIdentifier(schema);\n\n      if (schema === \"public\") {\n        await sql.unsafe(`DROP SCHEMA public CASCADE`);\n        await sql.unsafe(`CREATE SCHEMA public`);\n      } else {\n        await sql.unsafe(`DROP SCHEMA IF EXISTS ${quoted} CASCADE`);\n        await sql.unsafe(`CREATE SCHEMA ${quoted}`);\n      }\n\n      await runMigrations(config.databaseUrl);","is_error":false}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"d6ccbc98-ed1a-4196-8682-8dd0f5874178","timestamp":"2026-04-04T07:58:39.396Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AnBDim6PNT4cqzLvd6tkH5","type":"tool_result","content":"/**\n * GET /health — operational health endpoint.\n *\n * Returns service version, server pubkey, SOL balance, DB connectivity,\n * worker running status, unsettled round count, and oldest unsettled age.\n */\n\nimport { Hono } from \"hono\";\nimport type postgres from \"postgres\";\nimport type { Db } from \"../db.js\";\nimport { getQueueDepth } from \"../queue/health.js\";\n\nexport interface HealthDeps {\n  db: Db;\n  sql: postgres.Sql;\n  isWorkerRunning: () => boolean;\n}\n\nexport function createHealthRoutes(deps: HealthDeps): Hono {\n  const { db, sql, isWorkerRunning } = deps;\n  const app = new Hono();\n\n  app.get(\"/\", async (c) => {\n    // Optional flags — extended queries are opt-in so unauthenticated\n    // polling (load balancers, uptime bots) doesn't hit the DB unnecessarily.\n    const verbose = c.req.query(\"verbose\") === \"1\";\n\n    let dbConnected = false;\n    let unsettledCount = 0;\n    let oldestUnsettledAge = 0;\n\n    // Check DB connectivity + query unsettled stats\n    try {\n      const stats = await db.getUnsettledStats();\n      dbConnected = true;\n      unsettledCount = stats.count;\n      oldestUnsettledAge = stats.oldestAgeSeconds;\n    } catch {\n      dbConnected = false;\n    }\n\n    const response: Record<string, unknown> = {\n      status: \"ok\",\n      version: \"0.1.0\",\n      dbConnected,\n      workerRunning: isWorkerRunning(),\n      unsettledCount,\n      oldestUnsettledAge,\n    };","is_error":false}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"f1e5eac6-1227-41e5-a25a-eb706c70bf13","timestamp":"2026-04-04T07:58:39.407Z"}
