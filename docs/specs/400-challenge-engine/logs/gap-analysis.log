{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0164pCSN6zVcLYRAoqyTugiS","type":"tool_result","content":"1\t/**\n2\t * Unit tests for challenge verification adapters and quest eligibility.\n3\t *\n4\t * Covers:\n5\t * 1. questEligible — excludes refunded games (isWinner === null)\n6\t * 2. game_completed adapter — scope filtering\n7\t * 3. game_won adapter — scope + isWinner check\n8\t * 4. lobby_filled adapter — scope + isCreator check\n9\t * 5. Unknown adapter type — logs warning, returns shouldProgress: false\n10\t */\n11\t\n12\timport { describe, it, expect } from \"vitest\";\n13\timport {\n14\t  questEligible,\n15\t  getAdapter,\n16\t  type GameSettledPayload,\n17\t  type GameSettledPlayer,\n18\t  type ChallengeAssignment,\n19\t} from \"../handlers/challenge-adapters.js\";\n20\t\n21\t// ---------------------------------------------------------------------------\n22\t// Test helpers\n23\t// ---------------------------------------------------------------------------\n24\t\n25\tfunction makePlayer(overrides: Partial<GameSettledPlayer> = {}): GameSettledPlayer {\n26\t  return {\n27\t    userId: \"user-1\",\n28\t    wallet: \"WaLLet111111111111111111111111111111111111111\",\n29\t    amountLamports: \"1000000000\",\n30\t    isWinner: true,\n31\t    payoutLamports: \"1900000000\",\n32\t    isCreator: false,\n33\t    ...overrides,\n34\t  };\n35\t}\n36\t\n37\tfunction makeEvent(overrides: Partial<GameSettledPayload> = {}): GameSettledPayload {\n38\t  return {\n39\t    roundId: \"abc123\",\n40\t    roundPda: \"PDA111111111111111111111111111111111111111111\",\n41\t    game: \"coinflip\",\n42\t    players: [makePlayer()],\n43\t    feeLamports: \"100000000\",\n44\t    settledAt: new Date().toISOString(),\n45\t    ...overrides,\n46\t  };\n47\t}\n48\t\n49\tfunction makeAssignment(overrides: Partial<ChallengeAssignment> = {}): ChallengeAssignment {\n50\t  return {\n51\t    id: 1,\n52\t    challengeId: 10,\n53\t    action: \"game_completed\",\n54\t    scope: \"any\",\n55\t    condition: \"count\",\n56\t    target: 5,\n57\t    progress: 0,\n58\t    status: \"active\",\n59\t    ...overrides,\n60\t  };\n61\t}\n62\t\n63\t// ---------------------------------------------------------------------------\n64\t// questEligible\n65\t// ---------------------------------------------------------------------------\n66\t\n67\tdescribe(\"questEligible\", () => {\n68\t  it(\"returns true for a winning player\", () => {\n69\t    expect(questEligible(makePlayer({ isWinner: true }))).toBe(true);\n70\t  });\n71\t\n72\t  it(\"returns true for a losing player\", () => {\n73\t    expect(questEligible(makePlayer({ isWinner: false }))).toBe(true);\n74\t  });\n75\t\n76\t  it(\"returns false for a refunded player (isWinner === null)\", () => {\n77\t    expect(questEligible(makePlayer({ isWinner: null }))).toBe(false);\n78\t  });\n79\t});\n80\t\n81\t// ---------------------------------------------------------------------------\n82\t// game_completed adapter\n83\t// ---------------------------------------------------------------------------\n84\t\n85\tdescribe(\"game_completed adapter\", () => {\n86\t  const adapter = getAdapter(\"game_completed\");\n87\t\n88\t  it(\"returns shouldProgress: true when scope is 'any'\", () => {\n89\t    const result = adapter(makeEvent(), makePlayer(), makeAssignment({ scope: \"any\" }));\n90\t    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n91\t  });\n92\t\n93\t  it(\"returns shouldProgress: true when scope matches game\", () => {\n94\t    const result = adapter(\n95\t      makeEvent({ game: \"coinflip\" }),\n96\t      makePlayer(),\n97\t      makeAssignment({ scope: \"coinflip\" }),\n98\t    );\n99\t    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n100\t  });\n101\t\n102\t  it(\"returns shouldProgress: false when scope does not match game\", () => {\n103\t    const result = adapter(\n104\t      makeEvent({ game: \"coinflip\" }),\n105\t      makePlayer(),\n106\t      makeAssignment({ scope: \"lord\" }),\n107\t    );\n108\t    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n109\t  });\n110\t\n111\t  it(\"works for closecall scope\", () => {\n112\t    const result = adapter(\n113\t      makeEvent({ game: \"closecall\" }),\n114\t      makePlayer(),\n115\t      makeAssignment({ scope: \"closecall\" }),\n116\t    );\n117\t    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n118\t  });\n119\t\n120\t  it(\"does not check isWinner (losers count too)\", () => {\n121\t    const result = adapter(\n122\t      makeEvent(),\n123\t      makePlayer({ isWinner: false }),\n124\t      makeAssignment({ scope: \"any\" }),\n125\t    );\n126\t    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n127\t  });\n128\t});\n129\t\n130\t// ---------------------------------------------------------------------------\n131\t// game_won adapter\n132\t// ---------------------------------------------------------------------------\n133\t\n134\tdescribe(\"game_won adapter\", () => {\n135\t  const adapter = getAdapter(\"game_won\");\n136\t\n137\t  it(\"returns shouldProgress: true when player won and scope matches\", () => {\n138\t    const result = adapter(\n139\t      makeEvent({ game: \"coinflip\" }),\n140\t      makePlayer({ isWinner: true }),\n141\t      makeAssignment({ action: \"game_won\", scope: \"any\" }),\n142\t    );\n143\t    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n144\t  });\n145\t\n146\t  it(\"returns shouldProgress: false when player lost\", () => {\n147\t    const result = adapter(\n148\t      makeEvent(),\n149\t      makePlayer({ isWinner: false }),\n150\t      makeAssignment({ action: \"game_won\", scope: \"any\" }),\n151\t    );\n152\t    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n153\t  });\n154\t\n155\t  it(\"returns shouldProgress: false when scope does not match\", () => {\n156\t    const result = adapter(\n157\t      makeEvent({ game: \"lord\" }),\n158\t      makePlayer({ isWinner: true }),\n159\t      makeAssignment({ action: \"game_won\", scope: \"coinflip\" }),\n160\t    );\n161\t    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n162\t  });\n163\t\n164\t  it(\"returns shouldProgress: true for scope-specific win\", () => {\n165\t    const result = adapter(\n166\t      makeEvent({ game: \"lord\" }),\n167\t      makePlayer({ isWinner: true }),\n168\t      makeAssignment({ action: \"game_won\", scope: \"lord\" }),\n169\t    );\n170\t    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n171\t  });\n172\t});\n173\t\n174\t// ---------------------------------------------------------------------------\n175\t// lobby_filled adapter\n176\t// ---------------------------------------------------------------------------\n177\t\n178\tdescribe(\"lobby_filled adapter\", () => {\n179\t  const adapter = getAdapter(\"lobby_filled\");\n180\t\n181\t  it(\"returns shouldProgress: true when player is creator and scope matches\", () => {\n182\t    const result = adapter(\n183\t      makeEvent({ game: \"coinflip\" }),\n184\t      makePlayer({ isCreator: true }),\n185\t      makeAssignment({ action: \"lobby_filled\", scope: \"any\" }),\n186\t    );\n187\t    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n188\t  });\n189\t\n190\t  it(\"returns shouldProgress: false when player is not creator\", () => {\n191\t    const result = adapter(\n192\t      makeEvent(),\n193\t      makePlayer({ isCreator: false }),\n194\t      makeAssignment({ action: \"lobby_filled\", scope: \"any\" }),\n195\t    );\n196\t    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n197\t  });\n198\t\n199\t  it(\"returns shouldProgress: false when scope does not match\", () => {\n200\t    const result = adapter(\n201\t      makeEvent({ game: \"closecall\" }),\n202\t      makePlayer({ isCreator: true }),\n203\t      makeAssignment({ action: \"lobby_filled\", scope: \"coinflip\" }),\n204\t    );\n205\t    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n206\t  });\n207\t\n208\t  it(\"returns shouldProgress: true for scope-specific lobby fill\", () => {\n209\t    const result = adapter(\n210\t      makeEvent({ game: \"closecall\" }),\n211\t      makePlayer({ isCreator: true }),\n212\t      makeAssignment({ action: \"lobby_filled\", scope: \"closecall\" }),\n213\t    );\n214\t    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n215\t  });\n216\t});\n217\t\n218\t// ---------------------------------------------------------------------------\n219\t// Unknown adapter type\n220\t// ---------------------------------------------------------------------------\n221\t\n222\tdescribe(\"unknown adapter type\", () => {\n223\t  it(\"returns shouldProgress: false for unknown action\", () => {\n224\t    const adapter = getAdapter(\"nonexistent_action\");\n225\t    const result = adapter(makeEvent(), makePlayer(), makeAssignment({ action: \"nonexistent_action\" }));\n226\t    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n227\t  });\n228\t\n229\t  it(\"returns a function (not undefined)\", () => {\n230\t    const adapter = getAdapter(\"totally_made_up\");\n231\t    expect(typeof adapter).toBe(\"function\");\n232\t  });\n233\t});\n234\t"}]},"parent_tool_use_id":"toolu_01Xu4dck7eSJFViD8bAUTcD5","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"76be2705-6d8b-47e1-ad79-e7c4167d892a","timestamp":"2026-04-04T07:59:55.261Z"}
