{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rx8XPCRgv1a2Z8kRNzSyAj","type":"tool_result","content":"1\t/**\n2\t * Onboarding chain progression — auto-assigns the next onboarding step\n3\t * when a player completes an onboarding challenge.\n4\t *\n5\t * Onboarding challenges are linked via `prerequisite_id`. Completing step N\n6\t * triggers assignment of step N+1 (if it exists and hasn't been assigned yet).\n7\t */\n8\t\n9\timport type { Db } from \"../../db.js\";\n10\timport { logger } from \"../../logger.js\";\n11\t\n12\t// ---------------------------------------------------------------------------\n13\t// Types\n14\t// ---------------------------------------------------------------------------\n15\t\n16\tinterface NextStep {\n17\t  id: string;\n18\t  threshold: number;\n19\t}\n20\t\n21\t// ---------------------------------------------------------------------------\n22\t// DB helpers\n23\t// ---------------------------------------------------------------------------\n24\t\n25\t/**\n26\t * Find the next onboarding challenge whose `prerequisite_id` matches\n27\t * the just-completed challenge.\n28\t */\n29\texport async function getNextOnboardingStep(\n30\t  db: Db,\n31\t  completedChallengeId: string,\n32\t): Promise<NextStep | null> {\n33\t  const rows = await db.rawSql<NextStep[]>`\n34\t    SELECT id, threshold\n35\t    FROM challenges\n36\t    WHERE prerequisite_id = ${completedChallengeId}\n37\t      AND is_active = true\n38\t    LIMIT 1\n39\t  `;\n40\t  return rows[0] ?? null;\n41\t}\n42\t\n43\t/**\n44\t * Create a challenge assignment. Returns false if a row for this\n45\t * (user_id, challenge_id, period_key) already exists (idempotency via UNIQUE).\n46\t */\n47\texport async function createAssignment(\n48\t  db: Db,\n49\t  userId: string,\n50\t  challengeId: string,\n51\t  periodKey: string,\n52\t  target: number,\n53\t  expiresAt: string | null,\n54\t): Promise<boolean> {\n55\t  const rows = await db.rawSql<{ id: string }[]>`\n56\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n57\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n58\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n59\t    RETURNING id\n60\t  `;\n61\t  return rows.length > 0;\n62\t}\n63\t\n64\t// ---------------------------------------------------------------------------\n65\t// Main\n66\t// ---------------------------------------------------------------------------\n67\t\n68\t/**\n69\t * After an onboarding assignment is completed, check if there's a next step\n70\t * in the chain and auto-assign it.\n71\t *\n72\t * Called from game-settled handler within the completion transaction.\n73\t */\n74\texport async function advanceOnboardingChain(\n75\t  db: Db,\n76\t  userId: string,\n77\t  completedChallengeId: string,\n78\t  periodKey: string,\n79\t): Promise<void> {\n80\t  // Only process onboarding assignments\n81\t  if (periodKey !== \"onboarding\") return;\n82\t\n83\t  const nextStep = await getNextOnboardingStep(db, completedChallengeId);\n84\t  if (!nextStep) {\n85\t    logger.debug(\"onboarding: no next step (chain complete)\", {\n86\t      userId,\n87\t      completedChallengeId,\n88\t    });\n89\t    return;\n90\t  }\n91\t\n92\t  const created = await createAssignment(\n93\t    db,\n94\t    userId,\n95\t    nextStep.id,\n96\t    \"onboarding\",\n97\t    nextStep.threshold,\n98\t    null,\n99\t  );\n100\t\n101\t  if (created) {\n102\t    logger.info(\"onboarding: next step assigned\", {\n103\t      userId,\n104\t      completedChallengeId,\n105\t      nextChallengeId: nextStep.id,\n106\t    });\n107\t  } else {\n108\t    logger.debug(\"onboarding: next step already assigned (idempotent)\", {\n109\t      userId,\n110\t      nextChallengeId: nextStep.id,\n111\t    });\n112\t  }\n113\t}\n114\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"69823fd5-1e21-4a94-b227-ce7e00b34882","timestamp":"2026-04-04T07:58:19.796Z"}
