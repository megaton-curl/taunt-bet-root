{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JAHDxCRgZ32xA9y8nwhqBe","type":"tool_result","content":"2420\t    `;\n2421\t    expect(step2AfterRetry.length).toBe(1);\n2422\t  });\n2423\t});\n2424\t\n2425\t// ---------------------------------------------------------------------------\n2426\t// GET /challenges/mine — lazy assignment + response shape\n2427\t// ---------------------------------------------------------------------------\n2428\t\n2429\tdescribe(\"GET /challenges/mine\", () => {\n2430\t  let rawSql: ReturnType<typeof makeSql>;\n2431\t  let db: Db;\n2432\t  let challengeApp: InstanceType<typeof Hono>;\n2433\t\n2434\t  const testWallet = Keypair.generate().publicKey.toBase58();\n2435\t  const testUserId = userIdFromWallet(testWallet);\n2436\t\n2437\t  beforeAll(async () => {\n2438\t    rawSql = makeSql();\n2439\t    db = createDb(DATABASE_URL, rawSql);\n2440\t  });\n2441\t\n2442\t  afterAll(async () => {\n2443\t    await db.close();\n2444\t    await rawSql.end();\n2445\t  });\n2446\t\n2447\t  beforeEach(async () => {\n2448\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n2449\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n2450\t\n2451\t    challengeApp = new Hono();\n2452\t    challengeApp.use(\n2453\t      \"/challenges/*\",\n2454\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n2455\t    );\n2456\t    challengeApp.route(\"/challenges\", createChallengeRoutes({ db }));\n2457\t  });\n2458\t\n2459\t  it(\"first call creates 3 daily + 2 weekly + 1 onboarding assignment, returns correct shape\", async () => {\n2460\t    const token = await makeJwt(testWallet, testUserId);\n2461\t\n2462\t    const res = await challengeApp.request(\"/challenges/mine\", {\n2463\t      method: \"GET\",\n2464\t      headers: { Authorization: `Bearer ${token}` },\n2465\t    });\n2466\t\n2467\t    expect(res.status).toBe(200);\n2468\t    const body = (await res.json()) as Record<string, any>;\n2469\t"}]},"parent_tool_use_id":"toolu_01X5MGk2evkgm4qCC3F7gqR6","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"23195c61-a2f6-43e0-93c2-c89600d13755","timestamp":"2026-04-04T07:58:24.122Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SWR711n3CtD1jooadJtkaG","type":"tool_result","content":"1\t/**\n2\t * Admin API routes — reward config, reward pool, campaign/challenge CRUD,\n3\t * and admin-level management.\n4\t *\n5\t * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { Db } from \"../db.js\";\n10\t\n11\t// ---------------------------------------------------------------------------\n12\t// Known config keys — reject unknown keys with 400\n13\t// ---------------------------------------------------------------------------\n14\t\n15\tconst VALID_CONFIG_KEYS = new Set([\n16\t  \"points_per_dollar\",\n17\t  \"dogpile_default_multiplier\",\n18\t  \"reward_pool_fee_share\",\n19\t  \"points_crate_drop_rate\",\n20\t  \"sol_crate_drop_rate\",\n21\t  \"sol_crate_pool_pct\",\n22\t  \"sol_crate_min_value\",\n23\t  \"points_crate_min\",\n24\t  \"points_crate_max\",\n25\t  \"daily_challenge_count\",\n26\t  \"weekly_challenge_count\",\n27\t]);\n28\t\n29\t// ---------------------------------------------------------------------------\n30\t// Route factory\n31\t// ---------------------------------------------------------------------------\n32\t\n33\texport interface AdminRoutesDeps {\n34\t  db: Db;\n35\t  adminApiKey: string;\n36\t}\n37\t\n38\texport function createAdminRoutes(deps: AdminRoutesDeps) {\n39\t  const { db, adminApiKey } = deps;\n40\t  const app = new Hono();\n41\t\n42\t  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n43\t  app.use(\"*\", async (c, next) => {\n44\t    const key = c.req.header(\"X-Admin-Key\");\n45\t    if (!key || key !== adminApiKey) {\n46\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n47\t    }\n48\t    await next();\n49\t  });\n50\t\n51\t  // GET /reward-config — all config key-value pairs\n52\t  app.get(\"/reward-config\", async (c) => {\n53\t    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n54\t      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n55\t    `;\n56\t    const config: Record<string, { value: string; updatedAt: string }> = {};\n57\t    for (const row of rows) {\n58\t      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n59\t    }\n60\t    return c.json(config);\n61\t  });\n62\t\n63\t  // PUT /reward-config/:key — update a single config value\n64\t  app.put(\"/reward-config/:key\", async (c) => {\n65\t    const key = c.req.param(\"key\");\n66\t\n67\t    if (!VALID_CONFIG_KEYS.has(key)) {\n68\t      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n69\t    }\n70\t\n71\t    const body = await c.req.json<{ value?: string }>();\n72\t    if (body.value === undefined || body.value === null) {\n73\t      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n74\t    }\n75\t\n76\t    await db.rawSql`\n77\t      UPDATE reward_config\n78\t      SET value = ${String(body.value)}, updated_at = now()\n79\t      WHERE key = ${key}\n80\t    `;\n81\t\n82\t    return c.json({ key, value: String(body.value) });\n83\t  });\n84\t\n85\t  // GET /reward-pool — current pool state\n86\t  app.get(\"/reward-pool\", async (c) => {\n87\t    const rows = await db.rawSql<{\n88\t      balance_lamports: string;\n89\t      lifetime_funded: string;\n90\t      lifetime_paid: string;\n91\t      updated_at: string;\n92\t    }[]>`\n93\t      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n94\t      FROM reward_pool WHERE id = 1\n95\t    `;\n96\t    if (rows.length === 0) {\n97\t      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n98\t    }\n99\t    const pool = rows[0]!;\n100\t    return c.json({\n101\t      balanceLamports: pool.balance_lamports,\n102\t      lifetimeFunded: pool.lifetime_funded,\n103\t      lifetimePaid: pool.lifetime_paid,\n104\t      updatedAt: pool.updated_at,\n105\t    });\n106\t  });\n107\t\n108\t  // -------------------------------------------------------------------------\n109\t  // Campaign CRUD\n110\t  // -------------------------------------------------------------------------\n111\t\n112\t  const VALID_CAMPAIGN_TYPES = new Set([\"daily\", \"weekly\", \"onboarding\", \"dogpile\"]);\n113\t\n114\t  // POST /campaigns — create a campaign\n115\t  app.post(\"/campaigns\", async (c) => {\n116\t    const body = await c.req.json<{\n117\t      name?: string;\n118\t      campaignType?: string;\n119\t      startsAt?: string | null;\n120\t      endsAt?: string | null;\n121\t      config?: Record<string, unknown>;\n122\t    }>();\n123\t\n124\t    if (!body.name || typeof body.name !== \"string\") {\n125\t      return c.json({ error: \"MISSING_FIELD\", message: \"name is required\" }, 400);\n126\t    }\n127\t    if (!body.campaignType || !VALID_CAMPAIGN_TYPES.has(body.campaignType)) {\n128\t      return c.json(\n129\t        { error: \"INVALID_CAMPAIGN_TYPE\", message: `campaign_type must be one of: ${[...VALID_CAMPAIGN_TYPES].join(\", \")}` },\n130\t        400,\n131\t      );\n132\t    }\n133\t\n134\t    const startsAt = body.startsAt ?? null;\n135\t    const endsAt = body.endsAt ?? null;\n136\t    const config = JSON.stringify(body.config ?? {});\n137\t\n138\t    const rows = await db.rawSql<{ id: string; name: string; campaign_type: string; starts_at: string | null; ends_at: string | null; is_active: boolean; config: string; created_at: string }[]>`\n139\t      INSERT INTO campaigns (name, campaign_type, starts_at, ends_at, config)\n140\t      VALUES (${body.name}, ${body.campaignType}, ${startsAt}, ${endsAt}, ${config}::jsonb)\n141\t      RETURNING id, name, campaign_type, starts_at, ends_at, is_active, config, created_at\n142\t    `;\n143\t\n144\t    const row = rows[0]!;\n145\t    return c.json({\n146\t      id: row.id,\n147\t      name: row.name,\n148\t      campaignType: row.campaign_type,\n149\t      startsAt: row.starts_at,\n150\t      endsAt: row.ends_at,\n151\t      isActive: row.is_active,\n152\t      config: typeof row.config === \"string\" ? JSON.parse(row.config) : row.config,\n153\t      createdAt: row.created_at,\n154\t    }, 201);\n155\t  });\n156\t\n157\t  // PUT /campaigns/:id — update a campaign (soft-disable only, no delete)\n158\t  app.put(\"/campaigns/:id\", async (c) => {\n159\t    const id = c.req.param(\"id\");\n160\t\n161\t    const body = await c.req.json<{\n162\t      name?: string;\n163\t      startsAt?: string | null;\n164\t      endsAt?: string | null;\n165\t      isActive?: boolean;\n166\t      config?: Record<string, unknown>;\n167\t    }>();\n168\t\n169\t    // Build dynamic SET clauses\n170\t    const setClauses: string[] = [];\n171\t    const values: unknown[] = [];\n172\t\n173\t    if (body.name !== undefined) {\n174\t      values.push(body.name);\n175\t      setClauses.push(`name = $${values.length}`);\n176\t    }\n177\t    if (body.startsAt !== undefined) {\n178\t      values.push(body.startsAt);\n179\t      setClauses.push(`starts_at = $${values.length}`);\n180\t    }\n181\t    if (body.endsAt !== undefined) {\n182\t      values.push(body.endsAt);\n183\t      setClauses.push(`ends_at = $${values.length}`);\n184\t    }\n185\t    if (body.isActive !== undefined) {\n186\t      values.push(body.isActive);\n187\t      setClauses.push(`is_active = $${values.length}`);\n188\t    }\n189\t    if (body.config !== undefined) {\n190\t      values.push(JSON.stringify(body.config));\n191\t      setClauses.push(`config = $${values.length}::jsonb`);\n192\t    }\n193\t\n194\t    if (setClauses.length === 0) {\n195\t      return c.json({ error: \"NO_FIELDS\", message: \"No fields to update\" }, 400);\n196\t    }\n197\t\n198\t    values.push(id);\n199\t    const idPlaceholder = `$${values.length}`;\n200\t\n201\t    const query = `UPDATE campaigns SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, name, campaign_type, starts_at, ends_at, is_active, config, created_at`;\n202\t\n203\t    const rows = await db.rawSql.unsafe(query, values) as { id: string; name: string; campaign_type: string; starts_at: string | null; ends_at: string | null; is_active: boolean; config: string; created_at: string }[];\n204\t\n205\t    if (rows.length === 0) {\n206\t      return c.json({ error: \"NOT_FOUND\", message: `Campaign ${id} not found` }, 404);\n207\t    }\n208\t\n209\t    const row = rows[0]!;\n210\t    return c.json({\n211\t      id: row.id,\n212\t      name: row.name,\n213\t      campaignType: row.campaign_type,\n214\t      startsAt: row.starts_at,\n215\t      endsAt: row.ends_at,\n216\t      isActive: row.is_active,\n217\t      config: typeof row.config === \"string\" ? JSON.parse(row.config) : row.config,\n218\t      createdAt: row.created_at,\n219\t    });\n220\t  });\n221\t\n222\t  // -------------------------------------------------------------------------\n223\t  // Challenge CRUD\n224\t  // -------------------------------------------------------------------------\n225\t\n226\t  const VALID_SCOPES = new Set([\"any\", \"coinflip\", \"lord\", \"closecall\"]);\n227\t  const VALID_REWARD_TYPES = new Set([\"points\", \"crate\"]);\n228\t\n229\t  // POST /challenges — create a challenge in a campaign\n230\t  app.post(\"/challenges\", async (c) => {\n231\t    const body = await c.req.json<{\n232\t      campaignId?: number;\n233\t      title?: string;\n234\t      description?: string;\n235\t      action?: string;\n236\t      scope?: string;\n237\t      condition?: string;\n238\t      threshold?: number;\n239\t      rewardType?: string;\n240\t      rewardAmount?: number | null;\n241\t      prerequisiteId?: number | null;\n242\t      sortOrder?: number;\n243\t    }>();\n244\t\n245\t    if (!body.campaignId) {\n246\t      return c.json({ error: \"MISSING_FIELD\", message: \"campaignId is required\" }, 400);\n247\t    }\n248\t    if (!body.title || typeof body.title !== \"string\") {\n249\t      return c.json({ error: \"MISSING_FIELD\", message: \"title is required\" }, 400);\n250\t    }\n251\t    if (!body.action || typeof body.action !== \"string\") {\n252\t      return c.json({ error: \"MISSING_FIELD\", message: \"action is required\" }, 400);\n253\t    }\n254\t    if (!body.threshold || typeof body.threshold !== \"number\") {\n255\t      return c.json({ error: \"MISSING_FIELD\", message: \"threshold is required\" }, 400);\n256\t    }\n257\t    if (!body.rewardType || !VALID_REWARD_TYPES.has(body.rewardType)) {\n258\t      return c.json({ error: \"INVALID_REWARD_TYPE\", message: `reward_type must be one of: ${[...VALID_REWARD_TYPES].join(\", \")}` }, 400);\n259\t    }\n260\t    if (body.scope && !VALID_SCOPES.has(body.scope)) {\n261\t      return c.json({ error: \"INVALID_SCOPE\", message: `scope must be one of: ${[...VALID_SCOPES].join(\", \")}` }, 400);\n262\t    }\n263\t\n264\t    // Validate campaign exists\n265\t    const campRows = await db.rawSql<{ id: string }[]>`SELECT id FROM campaigns WHERE id = ${body.campaignId}`;\n266\t    if (campRows.length === 0) {\n267\t      return c.json({ error: \"CAMPAIGN_NOT_FOUND\", message: `Campaign ${body.campaignId} not found` }, 400);\n268\t    }\n269\t\n270\t    const scope = body.scope ?? \"any\";\n271\t    const condition = body.condition ?? \"count\";\n272\t    const description = body.description ?? null;\n273\t    const rewardAmount = body.rewardAmount ?? null;\n274\t    const prerequisiteId = body.prerequisiteId ?? null;\n275\t    const sortOrder = body.sortOrder ?? 0;\n276\t\n277\t    const rows = await db.rawSql<{\n278\t      id: string; campaign_id: string; title: string; description: string | null;\n279\t      action: string; scope: string; condition: string; threshold: number;\n280\t      reward_type: string; reward_amount: number | null; prerequisite_id: string | null;\n281\t      sort_order: number; is_active: boolean; created_at: string;\n282\t    }[]>`\n283\t      INSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order)\n284\t      VALUES (${body.campaignId}, ${body.title}, ${description}, ${body.action}, ${scope}, ${condition}, ${body.threshold}, ${body.rewardType}, ${rewardAmount}, ${prerequisiteId}, ${sortOrder})\n285\t      RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order, is_active, created_at\n286\t    `;\n287\t\n288\t    const row = rows[0]!;\n289\t    return c.json({\n290\t      id: row.id,\n291\t      campaignId: row.campaign_id,\n292\t      title: row.title,\n293\t      description: row.description,\n294\t      action: row.action,\n295\t      scope: row.scope,\n296\t      condition: row.condition,\n297\t      threshold: row.threshold,\n298\t      rewardType: row.reward_type,\n299\t      rewardAmount: row.reward_amount,\n300\t      prerequisiteId: row.prerequisite_id,\n301\t      sortOrder: row.sort_order,\n302\t      isActive: row.is_active,\n303\t      createdAt: row.created_at,\n304\t    }, 201);\n305\t  });\n306\t\n307\t  // PUT /challenges/:id — update a challenge (toggle is_active, update fields)\n308\t  app.put(\"/challenges/:id\", async (c) => {\n309\t    const id = c.req.param(\"id\");\n310\t\n311\t    const body = await c.req.json<{\n312\t      title?: string;\n313\t      description?: string | null;\n314\t      action?: string;\n315\t      scope?: string;\n316\t      condition?: string;\n317\t      threshold?: number;\n318\t      rewardType?: string;\n319\t      rewardAmount?: number | null;\n320\t      sortOrder?: number;\n321\t      isActive?: boolean;\n322\t    }>();\n323\t\n324\t    // Validate scope if provided\n325\t    if (body.scope !== undefined && !VALID_SCOPES.has(body.scope)) {\n326\t      return c.json({ error: \"INVALID_SCOPE\", message: `scope must be one of: ${[...VALID_SCOPES].join(\", \")}` }, 400);\n327\t    }\n328\t    // Validate rewardType if provided\n329\t    if (body.rewardType !== undefined && !VALID_REWARD_TYPES.has(body.rewardType)) {\n330\t      return c.json({ error: \"INVALID_REWARD_TYPE\", message: `reward_type must be one of: ${[...VALID_REWARD_TYPES].join(\", \")}` }, 400);\n331\t    }\n332\t\n333\t    const setClauses: string[] = [];\n334\t    const values: unknown[] = [];\n335\t\n336\t    if (body.title !== undefined) {\n337\t      values.push(body.title);\n338\t      setClauses.push(`title = $${values.length}`);\n339\t    }\n340\t    if (body.description !== undefined) {\n341\t      values.push(body.description);\n342\t      setClauses.push(`description = $${values.length}`);\n343\t    }\n344\t    if (body.action !== undefined) {\n345\t      values.push(body.action);\n346\t      setClauses.push(`action = $${values.length}`);\n347\t    }\n348\t    if (body.scope !== undefined) {\n349\t      values.push(body.scope);\n350\t      setClauses.push(`scope = $${values.length}`);\n351\t    }\n352\t    if (body.condition !== undefined) {\n353\t      values.push(body.condition);\n354\t      setClauses.push(`condition = $${values.length}`);\n355\t    }\n356\t    if (body.threshold !== undefined) {\n357\t      values.push(body.threshold);\n358\t      setClauses.push(`threshold = $${values.length}`);\n359\t    }\n360\t    if (body.rewardType !== undefined) {\n361\t      values.push(body.rewardType);\n362\t      setClauses.push(`reward_type = $${values.length}`);\n363\t    }\n364\t    if (body.rewardAmount !== undefined) {\n365\t      values.push(body.rewardAmount);\n366\t      setClauses.push(`reward_amount = $${values.length}`);\n367\t    }\n368\t    if (body.sortOrder !== undefined) {\n369\t      values.push(body.sortOrder);\n370\t      setClauses.push(`sort_order = $${values.length}`);\n371\t    }\n372\t    if (body.isActive !== undefined) {\n373\t      values.push(body.isActive);\n374\t      setClauses.push(`is_active = $${values.length}`);\n375\t    }\n376\t\n377\t    if (setClauses.length === 0) {\n378\t      return c.json({ error: \"NO_FIELDS\", message: \"No fields to update\" }, 400);\n379\t    }\n380\t\n381\t    values.push(id);\n382\t    const idPlaceholder = `$${values.length}`;\n383\t\n384\t    const query = `UPDATE challenges SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order, is_active, created_at`;\n385\t\n386\t    const rows = await db.rawSql.unsafe(query, values) as {\n387\t      id: string; campaign_id: string; title: string; description: string | null;\n388\t      action: string; scope: string; condition: string; threshold: number;\n389\t      reward_type: string; reward_amount: number | null; prerequisite_id: string | null;\n390\t      sort_order: number; is_active: boolean; created_at: string;\n391\t    }[];\n392\t\n393\t    if (rows.length === 0) {\n394\t      return c.json({ error: \"NOT_FOUND\", message: `Challenge ${id} not found` }, 404);\n395\t    }\n396\t\n397\t    const row = rows[0]!;\n398\t    return c.json({\n399\t      id: row.id,\n400\t      campaignId: row.campaign_id,\n401\t      title: row.title,\n402\t      description: row.description,\n403\t      action: row.action,\n404\t      scope: row.scope,\n405\t      condition: row.condition,\n406\t      threshold: row.threshold,\n407\t      rewardType: row.reward_type,\n408\t      rewardAmount: row.reward_amount,\n409\t      prerequisiteId: row.prerequisite_id,\n410\t      sortOrder: row.sort_order,\n411\t      isActive: row.is_active,\n412\t      createdAt: row.created_at,\n413\t    });\n414\t  });\n415\t\n416\t  // -------------------------------------------------------------------------\n417\t  // Dogpile Scheduling\n418\t  // -------------------------------------------------------------------------\n419\t\n420\t  // POST /dogpile — schedule a new dogpile event\n421\t  app.post(\"/dogpile\", async (c) => {\n422\t    const body = await c.req.json<{\n423\t      startsAt?: string;\n424\t      endsAt?: string;\n425\t      multiplier?: number;\n426\t      campaignId?: number | null;\n427\t    }>();\n428\t\n429\t    if (!body.startsAt || typeof body.startsAt !== \"string\") {\n430\t      return c.json({ error: \"MISSING_FIELD\", message: \"startsAt is required\" }, 400);\n431\t    }\n432\t    if (!body.endsAt || typeof body.endsAt !== \"string\") {\n433\t      return c.json({ error: \"MISSING_FIELD\", message: \"endsAt is required\" }, 400);\n434\t    }\n435\t\n436\t    const startsAt = new Date(body.startsAt);\n437\t    const endsAt = new Date(body.endsAt);\n438\t\n439\t    if (isNaN(startsAt.getTime()) || isNaN(endsAt.getTime())) {\n440\t      return c.json({ error: \"INVALID_DATES\", message: \"startsAt and endsAt must be valid ISO 8601 dates\" }, 400);\n441\t    }\n442\t    if (endsAt <= startsAt) {\n443\t      return c.json({ error: \"INVALID_DATES\", message: \"endsAt must be after startsAt\" }, 400);\n444\t    }\n445\t\n446\t    const multiplier = body.multiplier ?? 2.0;\n447\t    const campaignId = body.campaignId ?? null;\n448\t\n449\t    // Check for overlap with existing non-cancelled events\n450\t    const overlapping = await db.rawSql<{ id: string }[]>`\n451\t      SELECT id FROM dogpile_events\n452\t      WHERE status NOT IN ('cancelled', 'ended')\n453\t        AND starts_at < ${endsAt.toISOString()}\n454\t        AND ends_at > ${startsAt.toISOString()}\n455\t      LIMIT 1\n456\t    `;\n457\t\n458\t    if (overlapping.length > 0) {\n459\t      return c.json(\n460\t        { error: \"OVERLAP\", message: `Overlaps with existing dogpile event ${overlapping[0]!.id}` },\n461\t        409,\n462\t      );\n463\t    }\n464\t\n465\t    const rows = await db.rawSql<{\n466\t      id: string; starts_at: string; ends_at: string;\n467\t      multiplier: string; status: string; campaign_id: string | null; created_at: string;\n468\t    }[]>`\n469\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, campaign_id)\n470\t      VALUES (${startsAt.toISOString()}, ${endsAt.toISOString()}, ${multiplier}, ${campaignId})\n471\t      RETURNING id, starts_at, ends_at, multiplier, status, campaign_id, created_at\n472\t    `;\n473\t\n474\t    const row = rows[0]!;\n475\t    return c.json({\n476\t      id: row.id,\n477\t      startsAt: row.starts_at,\n478\t      endsAt: row.ends_at,\n479\t      multiplier: Number(row.multiplier),\n480\t      status: row.status,\n481\t      campaignId: row.campaign_id,\n482\t      createdAt: row.created_at,\n483\t    }, 201);\n484\t  });\n485\t\n486\t  // PUT /dogpile/:id — cancel a scheduled/future event (cannot modify active events)\n487\t  app.put(\"/dogpile/:id\", async (c) => {\n488\t    const id = c.req.param(\"id\");\n489\t\n490\t    const body = await c.req.json<{ status?: string }>();\n491\t\n492\t    if (!body.status || body.status !== \"cancelled\") {\n493\t      return c.json(\n494\t        { error: \"INVALID_ACTION\", message: \"Only status: 'cancelled' is supported\" },\n495\t        400,\n496\t      );\n497\t    }\n498\t\n499\t    // Check current status\n500\t    const existing = await db.rawSql<{ id: string; status: string }[]>`\n501\t      SELECT id, status FROM dogpile_events WHERE id = ${id}\n502\t    `;\n503\t\n504\t    if (existing.length === 0) {\n505\t      return c.json({ error: \"NOT_FOUND\", message: `Dogpile event ${id} not found` }, 404);\n506\t    }\n507\t\n508\t    const current = existing[0]!;\n509\t    if (current.status === \"active\") {\n510\t      return c.json(\n511\t        { error: \"CANNOT_MODIFY_ACTIVE\", message: \"Cannot cancel an active dogpile event\" },\n512\t        409,\n513\t      );\n514\t    }\n515\t    if (current.status === \"ended\" || current.status === \"cancelled\") {\n516\t      return c.json(\n517\t        { error: \"ALREADY_TERMINAL\", message: `Event is already ${current.status}` },\n518\t        409,\n519\t      );\n520\t    }\n521\t\n522\t    const rows = await db.rawSql<{\n523\t      id: string; starts_at: string; ends_at: string;\n524\t      multiplier: string; status: string; campaign_id: string | null; created_at: string;\n525\t    }[]>`\n526\t      UPDATE dogpile_events SET status = 'cancelled'\n527\t      WHERE id = ${id}\n528\t      RETURNING id, starts_at, ends_at, multiplier, status, campaign_id, created_at\n529\t    `;\n530\t\n531\t    const row = rows[0]!;\n532\t    return c.json({\n533\t      id: row.id,\n534\t      startsAt: row.starts_at,\n535\t      endsAt: row.ends_at,\n536\t      multiplier: Number(row.multiplier),\n537\t      status: row.status,\n538\t      campaignId: row.campaign_id,\n539\t      createdAt: row.created_at,\n540\t    });\n541\t  });\n542\t\n543\t  // GET /dogpile — list all dogpile events (optional status filter)\n544\t  app.get(\"/dogpile\", async (c) => {\n545\t    const statusFilter = c.req.query(\"status\");\n546\t\n547\t    let rows: {\n548\t      id: string; starts_at: string; ends_at: string;\n549\t      multiplier: string; status: string; campaign_id: string | null; created_at: string;\n550\t    }[];\n551\t\n552\t    if (statusFilter) {\n553\t      rows = await db.rawSql`\n554\t        SELECT id, starts_at, ends_at, multiplier, status, campaign_id, created_at\n555\t        FROM dogpile_events\n556\t        WHERE status = ${statusFilter}\n557\t        ORDER BY starts_at DESC\n558\t      `;\n559\t    } else {\n560\t      rows = await db.rawSql`\n561\t        SELECT id, starts_at, ends_at, multiplier, status, campaign_id, created_at\n562\t        FROM dogpile_events\n563\t        ORDER BY starts_at DESC\n564\t      `;\n565\t    }\n566\t\n567\t    const items = rows.map((row) => ({\n568\t      id: row.id,\n569\t      startsAt: row.starts_at,\n570\t      endsAt: row.ends_at,\n571\t      multiplier: Number(row.multiplier),\n572\t      status: row.status,\n573\t      campaignId: row.campaign_id,\n574\t      createdAt: row.created_at,\n575\t    }));\n576\t\n577\t    return c.json({ items });\n578\t  });\n579\t\n580\t  return app;\n581\t}\n582\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"773e8642-9866-4a3d-befd-b3c1387d6bd7","timestamp":"2026-04-04T07:58:24.371Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NWEzmzctri8gGSu8dCTpRg","type":"tool_result","content":"1\t/**\n2\t * Challenge routes — player-facing challenge/quest endpoints.\n3\t *\n4\t * GET /mine           — returns active daily, weekly, and onboarding challenges\n5\t *                       with lazy assignment on first call per period.\n6\t * GET /mine/history   — paginated completed challenge assignments.\n7\t */\n8\t\n9\timport { Hono } from \"hono\";\n10\timport type { AppEnv } from \"../hono-env.js\";\n11\timport type { Db } from \"../db.js\";\n12\timport { logger } from \"../logger.js\";\n13\timport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n14\t\n15\t// ---------------------------------------------------------------------------\n16\t// Types\n17\t// ---------------------------------------------------------------------------\n18\t\n19\texport interface ChallengeRoutesDeps {\n20\t  db: Db;\n21\t}\n22\t\n23\tinterface ChallengeRow {\n24\t  id: string;\n25\t  campaign_id: string;\n26\t  title: string;\n27\t  description: string;\n28\t  action: string;\n29\t  scope: string;\n30\t  condition: string;\n31\t  threshold: number;\n32\t  reward_type: string;\n33\t  reward_amount: number | null;\n34\t  sort_order: number;\n35\t  prerequisite_id: string | null;\n36\t}\n37\t\n38\tinterface AssignmentRow {\n39\t  id: string;\n40\t  challenge_id: string;\n41\t  period_key: string;\n42\t  status: string;\n43\t  progress: number;\n44\t  target: number;\n45\t  expires_at: string | null;\n46\t  completed_at: string | null;\n47\t  title: string;\n48\t  description: string;\n49\t  reward_type: string;\n50\t  reward_amount: number | null;\n51\t  campaign_type: string;\n52\t}\n53\t\n54\tinterface CompletionBonusRow {\n55\t  id: string;\n56\t  title: string;\n57\t  required_count: number;\n58\t  reward_type: string;\n59\t  reward_amount: number | null;\n60\t}\n61\t\n62\tinterface BonusCompletionRow {\n63\t  id: string;\n64\t}\n65\t\n66\t// ---------------------------------------------------------------------------\n67\t// Period key helpers\n68\t// ---------------------------------------------------------------------------\n69\t\n70\t/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\n71\texport function dailyPeriodKey(now?: Date): string {\n72\t  const d = now ?? new Date();\n73\t  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n74\t}\n75\t\n76\t/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\n77\texport function weeklyPeriodKey(now?: Date): string {\n78\t  const d = now ?? new Date();\n79\t  // ISO week calculation\n80\t  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n81\t  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n82\t  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n83\t  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n84\t  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n85\t}\n86\t\n87\t/** Returns midnight UTC of the next day (daily reset). */\n88\texport function dailyResetsAt(now?: Date): string {\n89\t  const d = now ?? new Date();\n90\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n91\t  return next.toISOString();\n92\t}\n93\t\n94\t/** Returns midnight UTC of next Monday (weekly reset). */\n95\texport function weeklyResetsAt(now?: Date): string {\n96\t  const d = now ?? new Date();\n97\t  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n98\t  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n99\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n100\t  return next.toISOString();\n101\t}\n102\t\n103\t// ---------------------------------------------------------------------------\n104\t// DB helpers\n105\t// ---------------------------------------------------------------------------\n106\t\n107\t/** Expire stale assignments (expires_at < now AND status='active'). */\n108\tasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n109\t  await db.rawSql`\n110\t    UPDATE challenge_assignments\n111\t    SET status = 'expired'\n112\t    WHERE user_id = ${userId}\n113\t      AND status = 'active'\n114\t      AND expires_at IS NOT NULL\n115\t      AND expires_at < now()\n116\t  `;\n117\t}\n118\t\n119\t/** Get assignments for a user in a given period, joined with challenge metadata. */\n120\tasync function getAssignmentsForPeriod(\n121\t  db: Db,\n122\t  userId: string,\n123\t  periodKey: string,\n124\t): Promise<AssignmentRow[]> {\n125\t  return db.rawSql<AssignmentRow[]>`\n126\t    SELECT\n127\t      ca.id,\n128\t      ca.challenge_id,\n129\t      ca.period_key,\n130\t      ca.status,\n131\t      ca.progress,\n132\t      ca.target,\n133\t      ca.expires_at,\n134\t      ca.completed_at,\n135\t      c.title,\n136\t      c.description,\n137\t      c.reward_type,\n138\t      c.reward_amount,\n139\t      camp.campaign_type\n140\t    FROM challenge_assignments ca\n141\t    JOIN challenges c ON c.id = ca.challenge_id\n142\t    JOIN campaigns camp ON camp.id = c.campaign_id\n143\t    WHERE ca.user_id = ${userId}\n144\t      AND ca.period_key = ${periodKey}\n145\t    ORDER BY c.sort_order ASC\n146\t  `;\n147\t}\n148\t\n149\t/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\n150\tasync function getActiveChallengesBySort(\n151\t  db: Db,\n152\t  campaignId: string,\n153\t  limit: number,\n154\t): Promise<ChallengeRow[]> {\n155\t  return db.rawSql<ChallengeRow[]>`\n156\t    SELECT id, campaign_id, title, description, action, scope, condition,\n157\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n158\t    FROM challenges\n159\t    WHERE campaign_id = ${campaignId}\n160\t      AND is_active = true\n161\t    ORDER BY sort_order ASC\n162\t    LIMIT ${limit}\n163\t  `;\n164\t}\n165\t\n166\t/** Get the campaign ID for a given campaign type. */\n167\tasync function getCampaignByType(\n168\t  db: Db,\n169\t  campaignType: string,\n170\t): Promise<{ id: string } | null> {\n171\t  const rows = await db.rawSql<{ id: string }[]>`\n172\t    SELECT id FROM campaigns\n173\t    WHERE campaign_type = ${campaignType}\n174\t      AND is_active = true\n175\t    LIMIT 1\n176\t  `;\n177\t  return rows[0] ?? null;\n178\t}\n179\t\n180\t/** Get all onboarding assignments for a user (any status). */\n181\tasync function getOnboardingAssignments(\n182\t  db: Db,\n183\t  userId: string,\n184\t): Promise<AssignmentRow[]> {\n185\t  return db.rawSql<AssignmentRow[]>`\n186\t    SELECT\n187\t      ca.id,\n188\t      ca.challenge_id,\n189\t      ca.period_key,\n190\t      ca.status,\n191\t      ca.progress,\n192\t      ca.target,\n193\t      ca.expires_at,\n194\t      ca.completed_at,\n195\t      c.title,\n196\t      c.description,\n197\t      c.reward_type,\n198\t      c.reward_amount,\n199\t      camp.campaign_type\n200\t    FROM challenge_assignments ca\n201\t    JOIN challenges c ON c.id = ca.challenge_id\n202\t    JOIN campaigns camp ON camp.id = c.campaign_id\n203\t    WHERE ca.user_id = ${userId}\n204\t      AND ca.period_key = 'onboarding'\n205\t    ORDER BY c.sort_order ASC\n206\t  `;\n207\t}\n208\t\n209\t/** Get all onboarding challenge templates (ordered by chain). */\n210\tasync function getOnboardingChallenges(\n211\t  db: Db,\n212\t  campaignId: string,\n213\t): Promise<ChallengeRow[]> {\n214\t  return db.rawSql<ChallengeRow[]>`\n215\t    SELECT id, campaign_id, title, description, action, scope, condition,\n216\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n217\t    FROM challenges\n218\t    WHERE campaign_id = ${campaignId}\n219\t      AND is_active = true\n220\t    ORDER BY sort_order ASC\n221\t  `;\n222\t}\n223\t\n224\t/** Get completion bonuses for a campaign. */\n225\tasync function getCompletionBonusesForCampaign(\n226\t  db: Db,\n227\t  campaignId: string,\n228\t): Promise<CompletionBonusRow[]> {\n229\t  return db.rawSql<CompletionBonusRow[]>`\n230\t    SELECT id, title, required_count, reward_type, reward_amount\n231\t    FROM completion_bonuses\n232\t    WHERE campaign_id = ${campaignId}\n233\t      AND is_active = true\n234\t  `;\n235\t}\n236\t\n237\t/** Check if a bonus was completed for a user in a given period. */\n238\tasync function getBonusCompletion(\n239\t  db: Db,\n240\t  userId: string,\n241\t  bonusId: string,\n242\t  periodKey: string,\n243\t): Promise<BonusCompletionRow | null> {\n244\t  const rows = await db.rawSql<BonusCompletionRow[]>`\n245\t    SELECT id FROM bonus_completions\n246\t    WHERE user_id = ${userId}\n247\t      AND bonus_id = ${bonusId}\n248\t      AND period_key = ${periodKey}\n249\t    LIMIT 1\n250\t  `;\n251\t  return rows[0] ?? null;\n252\t}\n253\t\n254\t/** Count completed assignments for a user in a period+campaign. */\n255\tasync function countCompleted(\n256\t  db: Db,\n257\t  userId: string,\n258\t  periodKey: string,\n259\t  campaignId: string,\n260\t): Promise<number> {\n261\t  const rows = await db.rawSql<{ count: string }[]>`\n262\t    SELECT COUNT(*)::TEXT AS count\n263\t    FROM challenge_assignments ca\n264\t    JOIN challenges c ON c.id = ca.challenge_id\n265\t    WHERE ca.user_id = ${userId}\n266\t      AND ca.period_key = ${periodKey}\n267\t      AND ca.status = 'completed'\n268\t      AND c.campaign_id = ${campaignId}\n269\t  `;\n270\t  return Number(rows[0]!.count);\n271\t}\n272\t\n273\t/** Create an assignment (idempotent via UNIQUE). */\n274\tasync function createAssignment(\n275\t  db: Db,\n276\t  userId: string,\n277\t  challengeId: string,\n278\t  periodKey: string,\n279\t  target: number,\n280\t  expiresAt: string | null,\n281\t): Promise<void> {\n282\t  await db.rawSql`\n283\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n284\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n285\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n286\t  `;\n287\t}\n288\t\n289\t// ---------------------------------------------------------------------------\n290\t// Helpers\n291\t// ---------------------------------------------------------------------------\n292\t\n293\t/** Parse and clamp a numeric query param. Returns `defaultVal` if missing/invalid. */\n294\tfunction parseIntParam(raw: string | undefined, defaultVal: number, max: number): number {\n295\t  if (!raw) return defaultVal;\n296\t  const parsed = parseInt(raw, 10);\n297\t  if (isNaN(parsed) || parsed < 1) return defaultVal;\n298\t  return Math.min(parsed, max);\n299\t}\n300\t\n301\t// ---------------------------------------------------------------------------\n302\t// Route factory\n303\t// ---------------------------------------------------------------------------\n304\t\n305\texport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n306\t  const { db } = deps;\n307\t  const app = new Hono<AppEnv>();\n308\t\n309\t  app.get(\"/mine\", async (c) => {\n310\t    const userId = c.get(\"userId\");\n311\t    if (!userId) {\n312\t      return c.json({ error: \"Authentication required\" }, 401);\n313\t    }\n314\t\n315\t    try {\n316\t      const now = new Date();\n317\t\n318\t      // 1. Expire stale assignments\n319\t      await expireStaleAssignments(db, userId);\n320\t\n321\t      // 2. Compute current period keys\n322\t      const dailyKey = dailyPeriodKey(now);\n323\t      const weeklyKey = weeklyPeriodKey(now);\n324\t\n325\t      // 3. Read config for challenge counts\n326\t      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n327\t      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n328\t      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n329\t      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n330\t\n331\t      // 4. Look up campaign IDs\n332\t      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n333\t        getCampaignByType(db, \"daily\"),\n334\t        getCampaignByType(db, \"weekly\"),\n335\t        getCampaignByType(db, \"onboarding\"),\n336\t      ]);\n337\t\n338\t      // 5. Lazy assignment — daily\n339\t      let dailyAssignments = dailyCampaign\n340\t        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n341\t        : [];\n342\t\n343\t      if (dailyAssignments.length === 0 && dailyCampaign) {\n344\t        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n345\t        const dailyExpires = dailyResetsAt(now);\n346\t        for (const t of templates) {\n347\t          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n348\t        }\n349\t        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n350\t      }\n351\t\n352\t      // 6. Lazy assignment — weekly\n353\t      let weeklyAssignments = weeklyCampaign\n354\t        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n355\t        : [];\n356\t\n357\t      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n358\t        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n359\t        const weeklyExpires = weeklyResetsAt(now);\n360\t        for (const t of templates) {\n361\t          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n362\t        }\n363\t        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n364\t      }\n365\t\n366\t      // 7. Lazy assignment — onboarding\n367\t      let onboardingAssignments = onboardingCampaign\n368\t        ? await getOnboardingAssignments(db, userId)\n369\t        : [];\n370\t\n371\t      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n372\t        // Assign first step (prerequisite_id IS NULL)\n373\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n374\t        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n375\t        if (firstStep) {\n376\t          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n377\t          onboardingAssignments = await getOnboardingAssignments(db, userId);\n378\t        }\n379\t      }\n380\t\n381\t      // 8. Build bonus status for daily\n382\t      let dailyBonus: object | null = null;\n383\t      if (dailyCampaign) {\n384\t        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n385\t        if (bonuses.length > 0) {\n386\t          const bonus = bonuses[0]!;\n387\t          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n388\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n389\t          dailyBonus = {\n390\t            title: bonus.title,\n391\t            required: bonus.required_count,\n392\t            completed: completedCount,\n393\t            status: bonusCompletion ? \"completed\" : \"active\",\n394\t            reward: {\n395\t              type: bonus.reward_type,\n396\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n397\t            },\n398\t          };\n399\t        }\n400\t      }\n401\t\n402\t      // 9. Build bonus status for weekly\n403\t      let weeklyBonus: object | null = null;\n404\t      if (weeklyCampaign) {\n405\t        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n406\t        if (bonuses.length > 0) {\n407\t          const bonus = bonuses[0]!;\n408\t          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n409\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n410\t          weeklyBonus = {\n411\t            title: bonus.title,\n412\t            required: bonus.required_count,\n413\t            completed: completedCount,\n414\t            status: bonusCompletion ? \"completed\" : \"active\",\n415\t            reward: {\n416\t              type: bonus.reward_type,\n417\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n418\t            },\n419\t          };\n420\t        }\n421\t      }\n422\t\n423\t      // 10. Build onboarding section\n424\t      let onboarding: object | null = null;\n425\t      if (onboardingCampaign) {\n426\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n427\t        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n428\t        const completedIds = new Set(\n429\t          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n430\t        );\n431\t        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n432\t\n433\t        if (allCompleted) {\n434\t          onboarding = null;\n435\t        } else {\n436\t          const steps = allSteps.map((step) => {\n437\t            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n438\t            const isAssigned = assignedIds.has(step.id);\n439\t            const locked = !isAssigned;\n440\t            return {\n441\t              id: Number(step.id),\n442\t              title: step.title,\n443\t              description: step.description,\n444\t              progress: assignment ? assignment.progress : 0,\n445\t              target: step.threshold,\n446\t              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n447\t              reward: {\n448\t                type: step.reward_type,\n449\t                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n450\t              },\n451\t              completedAt: assignment?.completed_at ?? null,\n452\t              locked,\n453\t            };\n454\t          });\n455\t          onboarding = { steps, completed: false };\n456\t        }\n457\t      }\n458\t\n459\t      // 11. Format response\n460\t      const formatChallenge = (a: AssignmentRow) => ({\n461\t        id: Number(a.id),\n462\t        title: a.title,\n463\t        description: a.description,\n464\t        progress: a.progress,\n465\t        target: a.target,\n466\t        status: a.status as \"active\" | \"completed\" | \"expired\",\n467\t        reward: {\n468\t          type: a.reward_type,\n469\t          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n470\t        },\n471\t        completedAt: a.completed_at ?? null,\n472\t      });\n473\t\n474\t      return c.json({\n475\t        daily: {\n476\t          challenges: dailyAssignments.map(formatChallenge),\n477\t          bonus: dailyBonus,\n478\t          resetsAt: dailyResetsAt(now),\n479\t        },\n480\t        weekly: {\n481\t          challenges: weeklyAssignments.map(formatChallenge),\n482\t          bonus: weeklyBonus,\n483\t          resetsAt: weeklyResetsAt(now),\n484\t        },\n485\t        onboarding,\n486\t      });\n487\t    } catch (err) {\n488\t      logger.error(\"challenges/mine failed\", {\n489\t        userId,\n490\t        error: err instanceof Error ? err.message : String(err),\n491\t      });\n492\t      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n493\t    }\n494\t  });\n495\t\n496\t  // GET /mine/history — paginated completed challenge assignments\n497\t  app.get(\"/mine/history\", async (c) => {\n498\t    const userId = c.get(\"userId\");\n499\t    if (!userId) {\n500\t      return c.json({ error: \"Authentication required\" }, 401);\n501\t    }\n502\t\n503\t    const cursor = c.req.query(\"cursor\") || undefined;\n504\t    const limit = parseIntParam(c.req.query(\"limit\"), 20, 50);\n505\t\n506\t    try {\n507\t      const cursorFilter = cursor\n508\t        ? db.rawSql`AND ca.id < ${cursor}`\n509\t        : db.rawSql``;\n510\t\n511\t      const rows = await db.rawSql<\n512\t        {\n513\t          id: string;\n514\t          title: string;\n515\t          description: string;\n516\t          completed_at: Date;\n517\t          reward_type: string;\n518\t          reward_amount: number | null;\n519\t        }[]\n520\t      >`\n521\t        SELECT\n522\t          ca.id,\n523\t          c.title,\n524\t          c.description,\n525\t          ca.completed_at,\n526\t          c.reward_type,\n527\t          c.reward_amount\n528\t        FROM challenge_assignments ca\n529\t        JOIN challenges c ON c.id = ca.challenge_id\n530\t        WHERE ca.user_id = ${userId}\n531\t          AND ca.status = 'completed'\n532\t          ${cursorFilter}\n533\t        ORDER BY ca.id DESC\n534\t        LIMIT ${limit}\n535\t      `;\n536\t\n537\t      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n538\t        id: Number(r.id),\n539\t        title: r.title,\n540\t        description: r.description,\n541\t        completedAt: r.completed_at.toISOString(),\n542\t        reward: {\n543\t          type: r.reward_type,\n544\t          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n545\t        },\n546\t      }));\n547\t\n548\t      const nextCursor =\n549\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n550\t\n551\t      return c.json({ items, nextCursor });\n552\t    } catch (err) {\n553\t      logger.error(\"challenges/mine/history failed\", {\n554\t        userId,\n555\t        error: err instanceof Error ? err.message : String(err),\n556\t      });\n557\t      return c.json({ error: \"Failed to fetch challenge history\" }, 500);\n558\t    }\n559\t  });\n560\t\n561\t  return app;\n562\t}\n563\t"}]},"parent_tool_use_id":"toolu_01D33K1LeLe4fFqTtZMyCSCg","session_id":"b2d95d4b-db07-48d6-a5bf-2a0c1dc6d3ff","uuid":"49aad711-529a-474c-9384-a5236b72a81f","timestamp":"2026-04-04T07:58:24.405Z"}
