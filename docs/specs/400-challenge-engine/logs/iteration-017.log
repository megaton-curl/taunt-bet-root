r } from \"./worker/retry.js\";\n32\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n33\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n34\timport { createDogpileWorker } from \"./worker/dogpile-worker.js\";\n35\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n36\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n37\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n38\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n39\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n40\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n41\timport { fetchSolPrice } from \"./routes/price.js\";\n42\timport { logger } from \"./logger.js\";\n43\t\n44\tconst config = loadConfig();\n45\t\n46\t// Single postgres pool shared by game DB, auth DB, and all workers\n47\tconst sql = postgres(config.databaseUrl);\n48\tconst db = createDb(config.databaseUrl, sql);\n49\tconst authDb = createAuthDb(sql);\n50\t\n51\tconst connection = new Connection(config.rpcUrl, {\n52\t  commitment: \"confirmed\",\n53\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n54\t});\n55\t\n56\tconst app = new Hono();\n57\t\n58\tapp.use(\n59\t  \"*\",\n60\t  cors({\n61\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n62\t    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n63\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\", \"X-Admin-Key\"],\n64\t  }),\n65\t);\n66\t\n67\t// Request logging — correlate frontend fetch timing with server-side processing\n68\tapp.use(\"*\", async (c, next) => {\n69\t  const start = Date.now();\n70\t  await next();\n71\t  const ms = Date.now() - start;\n72\t  const method = c.req.method;\n73\t  const path = c.req.path;\n74\t  // Skip noisy health checks and OPTIONS preflight\n75\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n76\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n77\t});\n78\t\n79\t// API docs — Swagger UI + raw OpenAPI spec\n80\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n81\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n82\t\n83\t// Auth routes — no JWT middleware (these are the login endpoints)\n84\t// Lighter rate limiting by IP for auth endpoints\n85\tapp.use(\n86\t  \"/auth/*\",\n87\t  createRateLimitMiddleware({\n88\t    perWallet: 20,\n89\t    global: config.rateLimitGlobal,\n90\t    windowMs: 60_000,\n91\t  }),\n92\t);\n93\t\n94\tapp.route(\n95\t  \"/auth\",\n96\t  createAuthRoutes({\n97\t    authDb,\n98\t    db,\n99\t    jwtSecret: config.jwtSecret,\n100\t    cluster: config.cluster,\n101\t    challengeTtlSeconds: config.challengeTtlSeconds,\n102\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n103\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n104\t  }),\n105\t);\n106\t\n107\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n108\tapp.use(\n109\t  \"/profile/*\",\n110\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n111\t);\n112\tapp.route(\"/profile\", createProfileRoutes({ db }));\n113\t\n114\t// Public profile routes — no auth required\n115\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n116\t\n117\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n118\tapp.use(\n119\t  \"/referral/*\",\n120\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n121\t);\n122\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n123\t\n124\t// JWT auth middleware for game endpoints\n125\tapp.use(\n126\t  \"/coinflip/*\",\n127\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n128\t);\n129\tapp.use(\n130\t  \"/lord/*\",\n131\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n132\t);\n133\t\n134\t// Rate limiting — per-wallet and global limits on POST requests\n135\tapp.use(\n136\t  \"/coinflip/*\",\n137\t  createRateLimitMiddleware({\n138\t    perWallet: config.rateLimitPerWallet,\n139\t    global: config.rateLimitGlobal,\n140\t    windowMs: 60_000,\n141\t  }),\n142\t);\n143\tapp.use(\n144\t  \"/lord/*\",\n145\t  createRateLimitMiddleware({\n146\t    perWallet: config.rateLimitPerWallet,\n147\t    global: config.rateLimitGlobal,\n148\t    windowMs: 60_000,\n149\t  }),\n150\t);"}]},"parent_tool_use_id":"toolu_01RoQxTEdAdP9h7dahh799eR","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"08435401-dcd7-4302-8148-7a3ac13137a2","timestamp":"2026-04-03T21:51:10.576Z"}
