{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_012B4qa1TZikpyQ4f3R4mtKR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WPkhDtXVCGNcEPWKCL62pk","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/crate-sol-payout.ts","content":"/**\n * CRATE_SOL_PAYOUT handler — sends SOL to player wallet for a SOL crate drop.\n *\n * Flow: load crate_drops row by ID → verify status='pending' → SOL transfer\n * from server keypair → update status to 'granted' (or 'failed' on error).\n *\n * Follows the same transfer pattern as the referral-claim handler.\n * Idempotent: skips if crate is already granted or failed.\n */\n\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\ninterface CrateDropRow {\n  id: string;\n  user_id: string;\n  crate_type: string;\n  contents_amount: string;\n  status: string;\n}\n\nasync function loadCrateDropById(\n  db: Db,\n  crateDropId: string,\n): Promise<CrateDropRow | null> {\n  const rows = await db.rawSql<CrateDropRow[]>`\n    SELECT id, user_id, crate_type, contents_amount, status\n    FROM crate_drops\n    WHERE id = ${crateDropId}\n  `;\n  return rows[0] ?? null;\n}\n\nasync function updateCrateStatus(\n  db: Db,\n  crateDropId: string,\n  status: string,\n): Promise<void> {\n  await db.rawSql`\n    UPDATE crate_drops\n    SET status     = ${status},\n        granted_at = CASE WHEN ${status} = 'granted' THEN now() ELSE granted_at END\n    WHERE id = ${crateDropId}\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Handler factory\n// ---------------------------------------------------------------------------\n\nexport interface CrateSolPayoutDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\nexport function createCrateSolPayoutHandler(deps: CrateSolPayoutDeps) {\n  const { db, connection, serverKeypair } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const crateDropId = payload.crateDropId as string;\n    const userId = payload.userId as string;\n    const wallet = payload.wallet as string;\n    const payoutLamports = payload.payoutLamports as string;\n\n    if (!crateDropId || !userId || !wallet || !payoutLamports) {\n      throw new Error(\n        \"crate.sol_payout: malformed payload — missing crateDropId, userId, wallet, or payoutLamports\",\n      );\n    }\n\n    // 1. Load crate row and check idempotency\n    const crate = await loadCrateDropById(db, crateDropId);\n    if (!crate) {\n      logger.warn(\"crate.sol_payout: crate drop not found\", { crateDropId });\n      return;\n    }\n\n    if (crate.status === \"granted\") {\n      logger.info(\"crate.sol_payout: already granted, skipping\", {\n        crateDropId,\n      });\n      return;\n    }\n\n    if (crate.status === \"failed\") {\n      logger.info(\"crate.sol_payout: permanently failed, skipping\", {\n        crateDropId,\n      });\n      return;\n    }\n\n    // 2. Execute SOL transfer from server keypair to player wallet\n    try {\n      const recipient = new PublicKey(wallet);\n      const lamports = Number(BigInt(payoutLamports));\n\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n\n      const tx = new Transaction({\n        feePayer: serverKeypair.publicKey,\n        blockhash,\n        lastValidBlockHeight,\n      });\n\n      tx.add(\n        SystemProgram.transfer({\n          fromPubkey: serverKeypair.publicKey,\n          toPubkey: recipient,\n          lamports,\n        }),\n      );\n\n      tx.sign(serverKeypair);\n\n      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n        skipPreflight: false,\n      });\n\n      const confirmation = await connection.confirmTransaction(\n        { signature: txSignature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n\n      if (confirmation.value.err) {\n        throw new Error(\n          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n        );\n      }\n\n      // 3. Mark as granted\n      await updateCrateStatus(db, crateDropId, \"granted\");\n      logger.info(\"crate.sol_payout: transfer completed\", {\n        crateDropId,\n        userId,\n        wallet,\n        payoutLamports,\n        txSignature,\n      });\n    } catch (err) {\n      // 4. Transfer failed — mark as failed\n      const errorMsg =\n        err instanceof Error ? err.message : \"Unknown transfer error\";\n      await updateCrateStatus(db, crateDropId, \"failed\");\n      logger.error(\"crate.sol_payout: transfer failed\", {\n        crateDropId,\n        userId,\n        wallet,\n        payoutLamports,\n        error: errorMsg,\n      });\n      // Don't rethrow — failed is a terminal status for M1\n    }\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":360,"cache_read_input_tokens":76214,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":360},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"2ad0f58e-b235-4691-adc0-3011503f06a1"}
