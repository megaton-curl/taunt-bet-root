{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HNn2KD4A7Tp2zzoMB6BbRq","type":"tool_result","content":"1538\t  it(\"crate.drop handler: SOL crate hit — decrements pool, creates crate row, emits sol_payout\", async () => {\n1539\t    // Fund the reward pool so a SOL crate can be funded\n1540\t    // sol_crate_min_value is 10_000_000 (10M lamports = 0.01 SOL)\n1541\t    // sol_crate_pool_pct is 0.10 → need pool >= 100_000_000 to get payout >= 10M\n1542\t    await rawSql`UPDATE reward_pool SET balance_lamports = 200000000, lifetime_funded = 200000000 WHERE id = 1`;\n1543\t\n1544\t    // Roll = 0.005, which is < sol_crate_drop_rate (0.01) → SOL crate hit\n1545\t    const handler = createCrateDropHandler({\n1546\t      db,\n1547\t      rollRng: () => 0.005,\n1548\t    });\n1549\t\n1550\t    const userId = \"usr_cratesol1\";\n1551\t    const wallet = \"CrateSolWallet1111111111111111111111111\";\n1552\t    const triggerId = \"test-round-crate-sol-001\";\n1553\t\n1554\t    await handler({\n1555\t      userId,\n1556\t      wallet,\n1557\t      triggerType: \"game_settled\",\n1558\t      triggerId,\n1559\t    });\n1560\t\n1561\t    // Expected payout: floor(200_000_000 * 0.10) = 20_000_000\n1562\t    const expectedPayout = 20_000_000n;\n1563\t\n1564\t    // Verify crate_drops row\n1565\t    const crates = await rawSql<{\n1566\t      user_id: string;\n1567\t      trigger_type: string;\n1568\t      trigger_id: string;\n1569\t      crate_type: string;\n1570\t      contents_amount: string;\n1571\t      status: string;\n1572\t    }[]>`\n1573\t      SELECT user_id, trigger_type, trigger_id, crate_type, contents_amount, status\n1574\t      FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1575\t    `;\n1576\t    expect(crates.length).toBe(1);\n1577\t    expect(crates[0]!.crate_type).toBe(\"sol\");\n1578\t    expect(BigInt(crates[0]!.contents_amount)).toBe(expectedPayout);\n1579\t    expect(crates[0]!.status).toBe(\"pending\");\n1580\t\n1581\t    // Verify pool decremented\n1582\t    const pool = await rawSql<{ balance_lamports: string; lifetime_paid: string }[]>`\n1583\t      SELECT balance_lamports, lifetime_paid FROM reward_pool WHERE id = 1\n1584\t    `;\n1585\t    expect(BigInt(pool[0]!.balance_lamports)).toBe(200_000_000n - expectedPayout);\n1586\t    expect(BigInt(pool[0]!.lifetime_paid)).toBe(expectedPayout);\n1587\t\n1588\t    // Verify CRATE_SOL_PAYOUT event emitted\n1589\t    const events = await rawSql<{ event_type: string; payload: string }[]>`\n1590\t      SELECT event_type, payload FROM event_queue WHERE event_type = 'crate.sol_payout'\n1591\t    `;\n1592\t    expect(events.length).toBe(1);\n1593\t    const eventPayload = typeof events[0]!.payload === \"string\"\n1594\t      ? JSON.parse(events[0]!.payload) : events[0]!.payload;\n1595\t    expect(eventPayload.userId).toBe(userId);\n1596\t    expect(eventPayload.wallet).toBe(wallet);\n1597\t    expect(eventPayload.payoutLamports).toBe(expectedPayout.toString());\n1598\t  });\n1599\t\n1600\t  it(\"crate.drop handler: points crate hit — creates crate row, emits points.grant\", async () => {\n1601\t    // Roll = 0.02, which is >= sol_crate_drop_rate (0.01) but < 0.01 + 0.05 = 0.06 → points crate\n1602\t    // Second roll for points amount: 0.5 → min + floor(0.5 * (max - min + 1)) = 500 + floor(0.5 * 4501) = 500 + 2250 = 2750\n1603\t    const rolls = [0.02, 0.5];\n1604\t    let rollIdx = 0;\n1605\t    const handler = createCrateDropHandler({\n1606\t      db,\n1607\t      rollRng: () => rolls[rollIdx++]!,\n1608\t    });\n1609\t\n1610\t    const userId = \"usr_cratepoints2\";\n1611\t    const wallet = \"CratePointsWallet2111111111111111111111\";\n1612\t    const triggerId = \"test-round-crate-pts-001\";\n1613\t\n1614\t    await handler({\n1615\t      userId,\n1616\t      wallet,\n1617\t      triggerType: \"game_settled\",\n1618\t      triggerId,\n1619\t    });\n1620\t\n1621\t    // Expected points: 500 + floor(0.5 * (5000 - 500 + 1)) = 500 + 2250 = 2750\n1622\t    const expectedPoints = 2750;\n1623\t\n1624\t    // Verify crate_drops row\n1625\t    const crates = await rawSql<{\n1626\t      crate_type: string;\n1627\t      contents_amount: string;\n1628\t    }[]>`\n1629\t      SELECT crate_type, contents_amount\n1630\t      FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1631\t    `;\n1632\t    expect(crates.length).toBe(1);\n1633\t    expect(crates[0]!.crate_type).toBe(\"points\");\n1634\t    expect(parseInt(crates[0]!.contents_amount, 10)).toBe(expectedPoints);\n1635\t\n1636\t    // Verify POINTS_GRANT event emitted\n1637\t    const events = await rawSql<{ event_type: string; payload: string }[]>`\n1638\t      SELECT event_type, payload FROM event_queue WHERE event_type = 'points.grant'\n1639\t    `;\n1640\t    expect(events.length).toBe(1);\n1641\t    const eventPayload = typeof events[0]!.payload === \"string\"\n1642\t      ? JSON.parse(events[0]!.payload) : events[0]!.payload;\n1643\t    expect(eventPayload.userId).toBe(userId);\n1644\t    expect(eventPayload.sourceType).toBe(\"crate_points\");\n1645\t    expect(eventPayload.sourceId).toBe(`crate-${triggerId}`);\n1646\t    expect(eventPayload.amount).toBe(expectedPoints.toString());\n1647\t  });\n1648\t\n1649\t  it(\"crate.drop handler: miss — no crate row created\", async () => {\n1650\t    // Roll = 0.50, which is >= sol_crate_drop_rate + points_crate_drop_rate (0.06) → miss\n1651\t    const handler = createCrateDropHandler({\n1652\t      db,\n1653\t      rollRng: () => 0.50,\n1654\t    });\n1655\t\n1656\t    const userId = \"usr_cratemiss1\";\n1657\t    const wallet = \"CrateMissWallet1111111111111111111111111\";\n1658\t    const triggerId = \"test-round-crate-miss-001\";\n1659\t\n1660\t    await handler({\n1661\t      userId,\n1662\t      wallet,\n1663\t      triggerType: \"game_settled\",\n1664\t      triggerId,\n1665\t    });\n1666\t\n1667\t    // Verify no crate_drops row\n1668\t    const crates = await rawSql<{ id: string }[]>`\n1669\t      SELECT id FROM crate_drops WHERE user_id = ${userId}\n1670\t    `;\n1671\t    expect(crates.length).toBe(0);\n1672\t\n1673\t    // Verify no events emitted\n1674\t    const events = await rawSql<{ id: string }[]>`\n1675\t      SELECT id FROM event_queue WHERE event_type IN ('crate.sol_payout', 'points.grant')\n1676\t    `;\n1677\t    expect(events.length).toBe(0);\n1678\t  });\n1679\t\n1680\t  it(\"crate.drop handler: SOL crate suppressed when pool below min_value\", async () => {\n1681\t    // Pool balance too low: 50_000_000 * 0.10 = 5_000_000 < 10_000_000 min\n1682\t    await rawSql`UPDATE reward_pool SET balance_lamports = 50000000, lifetime_funded = 50000000 WHERE id = 1`;\n1683\t\n1684\t    // Roll = 0.005 → would be SOL crate, but pool can't fund it\n1685\t    const handler = createCrateDropHandler({\n1686\t      db,\n1687\t      rollRng: () => 0.005,\n1688\t    });\n1689\t\n1690\t    const userId = \"usr_cratesuppress1\";\n1691\t    const wallet = \"CrateSuppressWallet11111111111111111111\";\n1692\t    const triggerId = \"test-round-crate-suppress-001\";\n1693\t\n1694\t    await handler({\n1695\t      userId,\n1696\t      wallet,\n1697\t      triggerType: \"game_settled\",\n1698\t      triggerId,\n1699\t    });\n1700\t\n1701\t    // Verify no crate_drops row (suppressed, not even recorded)\n1702\t    const crates = await rawSql<{ id: string }[]>`\n1703\t      SELECT id FROM crate_drops WHERE user_id = ${userId}\n1704\t    `;\n1705\t    expect(crates.length).toBe(0);\n1706\t\n1707\t    // Verify pool balance unchanged\n1708\t    const pool = await rawSql<{ balance_lamports: string }[]>`\n1709\t      SELECT balance_lamports FROM reward_pool WHERE id = 1\n1710\t    `;\n1711\t    expect(BigInt(pool[0]!.balance_lamports)).toBe(50_000_000n);\n1712\t  });\n1713\t\n1714\t  it(\"crate.drop handler: idempotent — duplicate trigger skips\", async () => {\n1715\t    // Fund pool for SOL crate\n1716\t    await rawSql`UPDATE reward_pool SET balance_lamports = 200000000, lifetime_funded = 200000000 WHERE id = 1`;\n1717\t\n1718\t    const handler = createCrateDropHandler({\n1719\t      db,\n1720\t      rollRng: () => 0.005, // SOL crate hit\n1721\t    });\n1722\t\n1723\t    const userId = \"usr_cratededup1\";\n1724\t    const wallet = \"CrateDedupWallet1111111111111111111111\";\n1725\t    const triggerId = \"test-round-crate-dedup-001\";\n1726\t\n1727\t    // First call\n1728\t    await handler({\n1729\t      userId,\n1730\t      wallet,\n1731\t      triggerType: \"game_settled\",\n1732\t      triggerId,\n1733\t    });\n1734\t\n1735\t    const poolAfterFirst = await rawSql<{ balance_lamports: string }[]>`\n1736\t      SELECT balance_lamports FROM reward_pool WHERE id = 1\n1737\t    `;\n1738\t    const balanceAfterFirst = BigInt(poolAfterFirst[0]!.balance_lamports);\n1739\t\n1740\t    // Second call with same trigger — should be idempotent\n1741\t    await handler({\n1742\t      userId,\n1743\t      wallet,\n1744\t      triggerType: \"game_settled\",\n1745\t      triggerId,\n1746\t    });\n1747\t\n1748\t    // Verify still only one crate row\n1749\t    const crates = await rawSql<{ id: string }[]>`\n1750\t      SELECT id FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1751\t    `;\n1752\t    expect(crates.length).toBe(1);\n1753\t\n1754\t    // Verify pool not decremented again\n1755\t    const poolAfterSecond = await rawSql<{ balance_lamports: string }[]>`\n1756\t      SELECT balance_lamports FROM reward_pool WHERE id = 1\n1757\t    `;\n1758\t    expect(BigInt(poolAfterSecond[0]!.balance_lamports)).toBe(balanceAfterFirst);\n1759\t  });\n1760\t\n1761\t  // =====================================================================\n1762\t  // GAME_SETTLED handler (orchestrator)\n1763\t  // =====================================================================\n1764\t\n1765\t  it(\"game.settled handler: processes challenge progress + emits reward events\", async () => {\n1766\t    const handler = createGameSettledHandler({ db });\n1767\t    const userId = \"usr_gs_progress1\";\n1768\t    const wallet = \"GsProgressWallet1111111111111111111111\";\n1769\t\n1770\t    // Look up the 'Play 3 Games' daily challenge (game_completed, scope=any, threshold=3)\n1771\t    const challenges = await rawSql<{ id: string }[]>`\n1772\t      SELECT id FROM challenges WHERE title = 'Play 3 Games' LIMIT 1\n1773\t    `;\n1774\t    expect(challenges.length).toBe(1);\n1775\t    const challengeId = challenges[0]!.id;\n1776\t\n1777\t    // Create an active assignment for this user\n1778\t    await rawSql`\n1779\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n1780\t      VALUES (${userId}, ${challengeId}, 'daily:2026-04-03', 3)\n1781\t    `;\n1782\t\n1783\t    // Emit a game.settled event\n1784\t    await handler({\n1785\t      roundId: \"test-gs-round-001\",\n1786\t      roundPda: \"GsRoundPda111111111111111111111111111\",\n1787\t      game: \"coinflip\",\n1788\t      players: [\n1789\t        {\n1790\t          userId,\n1791\t          wallet,\n1792\t          amountLamports: \"5000000\",\n1793\t          isWinner: true,\n1794\t          payoutLamports: \"9500000\",\n1795\t          isCreator: true,\n1796\t        },\n1797\t      ],\n1798\t      feeLamports: \"500000\",\n1799\t      settledAt: new Date().toISOString(),\n1800\t    });\n1801\t\n1802\t    // Verify progress incremented to 1\n1803\t    const assignments = await rawSql<{ progress: number; status: string }[]>`\n1804\t      SELECT progress, status FROM challenge_assignments WHERE user_id = ${userId}\n1805\t    `;\n1806\t    expect(assignments[0]!.progress).toBe(1);\n1807\t    expect(assignments[0]!.status).toBe(\"active\");\n1808\t\n1809\t    // Verify progress_events row\n1810\t    const progressEvents = await rawSql<{ round_id: string; progress_delta: number }[]>`\n1811\t      SELECT round_id, progress_delta FROM progress_events WHERE user_id = ${userId}\n1812\t    `;\n1813\t    expect(progressEvents.length).toBe(1);\n1814\t    expect(progressEvents[0]!.round_id).toBe(\"test-gs-round-001\");\n1815\t    expect(progressEvents[0]!.progress_delta).toBe(1);\n1816\t\n1817\t    // Verify reward events emitted: reward.pool_fund, points.grant (wager), crate.drop\n1818\t    const events = await rawSql<{ event_type: string }[]>`\n1819\t      SELECT event_type FROM event_queue ORDER BY id\n1820\t    `;\n1821\t    const types = events.map((e) => e.event_type);\n1822\t    expect(types).toContain(\"reward.pool_fund\");\n1823\t    expect(types).toContain(\"points.grant\");\n1824\t    expect(types).toContain(\"crate.drop\");\n1825\t  });\n1826\t\n1827\t  it(\"game.settled handler: completes challenge + emits reward intent when target reached\", async () => {\n1828\t    const handler = createGameSettledHandler({ db });\n1829\t    const userId = \"usr_gs_complete1\";\n1830\t    const wallet = \"GsCompleteWallet11111111111111111111\";\n1831\t\n1832\t    // Look up 'Win a Coinflip' daily challenge (game_won, scope=coinflip, threshold=1, reward=150 points)\n1833\t    const challenges = await rawSql<{ id: string }[]>`\n1834\t      SELECT id FROM challenges WHERE title = 'Win a Coinflip' LIMIT 1\n1835\t    `;\n1836\t    const challengeId = challenges[0]!.id;\n1837\t\n1838\t    // Create assignment at 0 progress, target 1\n1839\t    await rawSql`\n1840\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n1841\t      VALUES (${userId}, ${challengeId}, 'daily:2026-04-03', 1)\n1842\t    `;\n1843\t\n1844\t    // Win a coinflip — should complete the challenge\n1845\t    await handler({\n1846\t      roundId: \"test-gs-complete-001\",\n1847\t      roundPda: \"GsCompletePda1111111111111111111111111\",\n1848\t      game: \"coinflip\",\n1849\t      players: [\n1850\t        {\n1851\t          userId,\n1852\t          wallet,\n1853\t          amountLamports: \"5000000\",\n1854\t          isWinner: true,\n1855\t          payoutLamports: \"9500000\",\n1856\t          isCreator: false,\n1857\t        },\n1858\t      ],\n1859\t      feeLamports: \"500000\",\n1860\t      settledAt: new Date().toISOString(),\n1861\t    });\n1862\t\n1863\t    // Verify assignment completed\n1864\t    const assignments = await rawSql<{ progress: number; status: string; completed_at: string | null }[]>`\n1865\t      SELECT progress, status, completed_at FROM challenge_assignments WHERE user_id = ${userId}\n1866\t    `;\n1867\t    expect(assignments[0]!.progress).toBe(1);\n1868\t    expect(assignments[0]!.status).toBe(\"completed\");\n1869\t    expect(assignments[0]!.completed_at).not.toBeNull();\n1870\t\n1871\t    // Verify challenge completion reward intent emitted (points.grant with source_type=challenge_completed)\n1872\t    const events = await rawSql<{ event_type: string; payload: Record<string, unknown> }[]>`\n1873\t      SELECT event_type, payload FROM event_queue ORDER BY id\n1874\t    `;\n1875\t    const challengeRewards = events.filter(\n1876\t      (e) =>\n1877\t        e.event_type === \"points.grant\" &&\n1878\t        (e.payload as Record<string, unknown>).sourceType === \"challenge_completed\",\n1879\t    );\n1880\t    expect(challengeRewards.length).toBe(1);\n1881\t    const rewardPayload = challengeRewards[0]!.payload as Record<string, unknown>;\n1882\t    expect(rewardPayload.userId).toBe(userId);\n1883\t    expect(rewardPayload.amount).toBe(\"150\");\n1884\t  });\n1885\t\n1886\t  it(\"game.settled handler: skips refunded game (isWinner === null)\", async () => {\n1887\t    const handler = createGameSettledHandler({ db });"}]},"parent_tool_use_id":"toolu_013Cq4thG3nF9u3oQyBCmhx8","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"3163d8da-a751-48af-a143-eed1ca5f06fc","timestamp":"2026-04-03T21:51:03.816Z"}
