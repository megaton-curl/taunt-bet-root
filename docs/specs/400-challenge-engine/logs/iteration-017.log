{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A9dWjj7sZgTDrm8AofskcB","type":"tool_result","content":"1\t#!/bin/bash\n2\tset -e\n3\texport CI=true\n4\t\n5\t# =============================================================================\n6\t# verify — End-to-end verification for Taunt Bet\n7\t#\n8\t# Usage:\n9\t#   ./scripts/verify              Full verification (all steps)\n10\t#   ./scripts/verify --anchor     Anchor programs only (build + test)\n11\t#   ./scripts/verify --ts         TypeScript only (lint + typecheck + test)\n12\t#   ./scripts/verify --devnet     Devnet E2E tests (non-blocking, skips if env vars missing)\n13\t#\n14\t# Note:\n15\t#   Chat verification currently lives in the `chat/` submodule as `pnpm verify`.\n16\t#   Root verify intentionally remains limited to `backend/` and `solana/` until\n17\t#   the chat service contract stabilizes.\n18\t# =============================================================================\n19\t\n20\t# Color codes\n21\tGREEN='\\033[0;32m'\n22\tRED='\\033[0;31m'\n23\tYELLOW='\\033[0;33m'\n24\tNC='\\033[0m'\n25\t\n26\tMODE=\"${1:-full}\"\n27\t\n28\t# Normalize flags\n29\tcase \"$MODE\" in\n30\t    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n31\t    --ts|--ts-only|ts) MODE=\"ts\" ;;\n32\t    --devnet|devnet) MODE=\"devnet\" ;;\n33\t    --full|full|\"\") MODE=\"full\" ;;\n34\t    *)\n35\t        echo \"Usage: ./scripts/verify [--anchor|--ts|--devnet|--full]\"\n36\t        exit 1\n37\t        ;;\n38\tesac\n39\t\n40\tROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\n41\t\n42\techo -e \"${GREEN}=== Taunt Bet Verification ($MODE) ===${NC}\"\n43\t\n44\t# Check for submodules\n45\tif [ ! -f \"$ROOT/backend/package.json\" ]; then\n46\t    echo -e \"${RED}[FAIL] Backend submodule not initialized.${NC}\"\n47\t    echo \"Run: git submodule update --init --recursive\"\n48\t    exit 1\n49\tfi\n50\t\n51\t# ---------------------------------------------------------------------------\n52\t# TypeScript steps (lint, typecheck, test)\n53\t# ---------------------------------------------------------------------------\n54\trun_ts() {\n55\t    cd \"$ROOT/backend\"\n56\t\n57\t    # Install dependencies if missing\n58\t    if [ ! -d \"node_modules\" ]; then\n59\t        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n60\t        pnpm install\n61\t    fi\n62\t\n63\t    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n64\t    pnpm lint\n65\t\n66\t    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n67\t    pnpm typecheck\n68\t\n69\t    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n70\t    pnpm test\n71\t\n72\t    cd \"$ROOT\"\n73\t}\n74\t\n75\t# ---------------------------------------------------------------------------\n76\t# Anchor steps (build + test)\n77\t# ---------------------------------------------------------------------------\n78\trun_anchor() {\n79\t    if ! command -v anchor &>/dev/null; then\n80\t        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n81\t        return 0\n82\t    fi\n83\t\n84\t    cd \"$ROOT/solana\"\n85\t\n86\t    if [ ! -d \"node_modules\" ]; then\n87\t        pnpm install --ignore-workspace\n88\t    fi\n89\t\n90\t    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n91\t    anchor build\n92\t\n93\t    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n94\t    pnpm exec mocha --require tsx/cjs -t 1000000 --exit tests/closecall.ts tests/coinflip.ts tests/lordofrngs.ts tests/platform.ts\n95\t\n96\t    cd \"$ROOT\"\n97\t}\n98\t\n99\t# ---------------------------------------------------------------------------\n100\t# Devnet E2E tests (non-blocking)\n101\t# ---------------------------------------------------------------------------\n102\trun_devnet_e2e() {\n103\t    if [ -z \"${VITE_COINFLIP_PROGRAM_ID:-}\" ]; then\n104\t        echo -e \"${YELLOW}[SKIP] Devnet E2E (VITE_COINFLIP_PROGRAM_ID not set)${NC}\"\n105\t        return 0\n106\t    fi\n107\t\n108\t    if [ ! -d \"$ROOT/e2e/node_modules\" ]; then\n109\t        echo -e \"${GREEN}[INFO] Installing E2E dependencies...${NC}\"\n110\t        cd \"$ROOT/e2e\" && pnpm install && cd \"$ROOT\"\n111\t    fi\n112\t\n113\t    echo -e \"${GREEN}[STEP] Running devnet E2E tests...${NC}\"\n114\t    if cd \"$ROOT/e2e\" && pnpm exec playwright test; then\n115\t        echo -e \"${GREEN}[PASS] Devnet E2E tests passed${NC}\"\n116\t    else\n117\t        echo -e \"${YELLOW}[WARN] Devnet E2E tests failed (non-blocking)${NC}\"\n118\t    fi\n119\t\n120\t    cd \"$ROOT\"\n121\t    return 0\n122\t}\n123\t\n124\t# ---------------------------------------------------------------------------\n125\t# Fee constant consistency check (always runs)\n126\t# ---------------------------------------------------------------------------\n127\techo -e \"${GREEN}[STEP] Checking fee constant consistency...${NC}\"\n128\t\"$ROOT/scripts/check-fees.sh\"\n129\t\n130\t# ---------------------------------------------------------------------------\n131\t# Run based on mode\n132\t# ---------------------------------------------------------------------------\n133\tcase \"$MODE\" in\n134\t    full)\n135\t        run_ts\n136\t        run_anchor\n137\t        ;;\n138\t    ts)\n139\t        run_ts\n140\t        ;;\n141\t    anchor)\n142\t        run_anchor\n143\t        ;;\n144\t    devnet)\n145\t        run_devnet_e2e\n146\t        ;;\n147\tesac\n148\t\n149\techo -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\n150\texit 0\n151\t"}]},"parent_tool_use_id":null,"session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"54d04798-e925-4a30-872b-67cf50cb28b4","timestamp":"2026-04-03T22:12:34.928Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/scripts/verify","content":"#!/bin/bash\nset -e\nexport CI=true\n\n# =============================================================================\n# verify — End-to-end verification for Taunt Bet\n#\n# Usage:\n#   ./scripts/verify              Full verification (all steps)\n#   ./scripts/verify --anchor     Anchor programs only (build + test)\n#   ./scripts/verify --ts         TypeScript only (lint + typecheck + test)\n#   ./scripts/verify --devnet     Devnet E2E tests (non-blocking, skips if env vars missing)\n#\n# Note:\n#   Chat verification currently lives in the `chat/` submodule as `pnpm verify`.\n#   Root verify intentionally remains limited to `backend/` and `solana/` until\n#   the chat service contract stabilizes.\n# =============================================================================\n\n# Color codes\nGREEN='\\033[0;32m'\nRED='\\033[0;31m'\nYELLOW='\\033[0;33m'\nNC='\\033[0m'\n\nMODE=\"${1:-full}\"\n\n# Normalize flags\ncase \"$MODE\" in\n    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n    --ts|--ts-only|ts) MODE=\"ts\" ;;\n    --devnet|devnet) MODE=\"devnet\" ;;\n    --full|full|\"\") MODE=\"full\" ;;\n    *)\n        echo \"Usage: ./scripts/verify [--anchor|--ts|--devnet|--full]\"\n        exit 1\n        ;;\nesac\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\n\necho -e \"${GREEN}=== Taunt Bet Verification ($MODE) ===${NC}\"\n\n# Check for submodules\nif [ ! -f \"$ROOT/backend/package.json\" ]; then\n    echo -e \"${RED}[FAIL] Backend submodule not initialized.${NC}\"\n    echo \"Run: git submodule update --init --recursive\"\n    exit 1\nfi\n\n# ---------------------------------------------------------------------------\n# TypeScript steps (lint, typecheck, test)\n# ---------------------------------------------------------------------------\nrun_ts() {\n    cd \"$ROOT/backend\"\n\n    # Install dependencies if missing\n    if [ ! -d \"node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n        pnpm install\n    fi\n\n    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n    pnpm lint\n\n    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n    pnpm typecheck\n\n    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n    pnpm test\n\n    cd \"$ROOT\"\n}\n\n# ---------------------------------------------------------------------------\n# Anchor steps (build + test)\n# ---------------------------------------------------------------------------\nrun_anchor() {\n    if ! command -v anchor &>/dev/null; then\n        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n        return 0\n    fi\n\n    cd \"$ROOT/solana\"\n\n    if [ ! -d \"node_modules\" ]; then\n        pnpm install --ignore-workspace\n    fi\n\n    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n    anchor build\n\n    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n    pnpm exec mocha --require tsx/cjs -t 1000000 --exit tests/closecall.ts tests/coinflip.ts tests/lordofrngs.ts tests/platform.ts\n\n    cd \"$ROOT\"\n}\n\n# ---------------------------------------------------------------------------\n# Devnet E2E tests (non-blocking)\n# ---------------------------------------------------------------------------\nrun_devnet_e2e() {\n    if [ -z \"${VITE_COINFLIP_PROGRAM_ID:-}\" ]; then\n        echo -e \"${YELLOW}[SKIP] Devnet E2E (VITE_COINFLIP_PROGRAM_ID not set)${NC}\"\n        return 0\n    fi\n\n    if [ ! -d \"$ROOT/e2e/node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing E2E dependencies...${NC}\"\n        cd \"$ROOT/e2e\" && pnpm install && cd \"$ROOT\"\n    fi\n\n    echo -e \"${GREEN}[STEP] Running devnet E2E tests...${NC}\"\n    if cd \"$ROOT/e2e\" && pnpm exec playwright test; then\n        echo -e \"${GREEN}[PASS] Devnet E2E tests passed${NC}\"\n    else\n        echo -e \"${YELLOW}[WARN] Devnet E2E tests failed (non-blocking)${NC}\"\n    fi\n\n    cd \"$ROOT\"\n    return 0\n}\n\n# ---------------------------------------------------------------------------\n# Fee constant consistency check (always runs)\n# ---------------------------------------------------------------------------\necho -e \"${GREEN}[STEP] Checking fee constant consistency...${NC}\"\n\"$ROOT/scripts/check-fees.sh\"\n\n# ---------------------------------------------------------------------------\n# Run based on mode\n# ---------------------------------------------------------------------------\ncase \"$MODE\" in\n    full)\n        run_ts\n        run_anchor\n        ;;\n    ts)\n        run_ts\n        ;;\n    anchor)\n        run_anchor\n        ;;\n    devnet)\n        run_devnet_e2e\n        ;;\nesac\n\necho -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\nexit 0\n","numLines":151,"startLine":1,"totalLines":151}}}
