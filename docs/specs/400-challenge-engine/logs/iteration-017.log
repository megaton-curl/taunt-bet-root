{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015j4u56SMxbirWorCYcJH48","type":"tool_result","content":"1\t/**\n2\t * Known event type constants for the async event queue.\n3\t *\n4\t * Using a const object + derived union makes typos a compile error\n5\t * instead of a dead event at runtime.\n6\t */\n7\t\n8\texport const EventTypes = {\n9\t  REFERRAL_CODE_APPLIED: \"referral.code_applied\",\n10\t  REFERRAL_GAME_SETTLED: \"referral.game_settled\",\n11\t  REFERRAL_CLAIM_REQUESTED: \"referral.claim_requested\",\n12\t  GAME_SETTLED: \"game.settled\",\n13\t  REWARD_POOL_FUND: \"reward.pool_fund\",\n14\t  POINTS_GRANT: \"points.grant\",\n15\t  CRATE_DROP: \"crate.drop\",\n16\t  CRATE_SOL_PAYOUT: \"crate.sol_payout\",\n17\t} as const;\n18\t\n19\texport type EventType = (typeof EventTypes)[keyof typeof EventTypes];\n20\t"}]},"parent_tool_use_id":"toolu_01DVFAq7wNTUZPjttWVufQSx","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"fdd1ee5c-bfc5-4b5b-891c-c3115434962f","timestamp":"2026-04-03T21:50:48.419Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0148ppwbwfFHWGBVH8sgDc8b","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createChallengeRoutes } from \"./routes/challenges.js\";\n21\timport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\n22\timport { createDogpileRoutes } from \"./routes/dogpile.js\";\n23\timport { createAdminRoutes } from \"./routes/admin.js\";\n24\timport { createInternalRoutes } from \"./routes/internal.js\";\n25\timport { swaggerUI } from \"@hono/swagger-ui\";\n26\timport { spec } from \"./openapi.js\";\n27\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n28\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n29\timport { createSettlementWorker } from \"./worker/settlement.js\";\n30\timport { settleRound } from \"./worker/settle-tx.js\";\n31\timport { createRetrySettler } from \"./worker/retry.js\";\n32\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n33\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n34\timport { createDogpileWorker } from \"./worker/dogpile-worker.js\";\n35\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n36\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n37\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n38\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n39\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n40\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n41\timport { fetchSolPrice } from \"./routes/price.js\";\n42\timport { logger } from \"./logger.js\";\n43\t\n44\tconst config = loadConfig();\n45\t\n46\t// Single postgres pool shared by game DB, auth DB, and all workers\n47\tconst sql = postgres(config.databaseUrl);\n48\tconst db = createDb(config.databaseUrl, sql);\n49\tconst authDb = createAuthDb(sql);\n50\t\n51\tconst connection = new Connection(config.rpcUrl, {\n52\t  commitment: \"confirmed\",\n53\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n54\t});\n55\t\n56\tconst app = new Hono();\n57\t\n58\tapp.use(\n59\t  \"*\",\n60\t  cors({\n61\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n62\t    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n63\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\", \"X-Admin-Key\"],\n64\t  }),\n65\t);\n66\t\n67\t// Request logging — correlate frontend fetch timing with server-side processing\n68\tapp.use(\"*\", async (c, next) => {\n69\t  const start = Date.now();\n70\t  await next();\n71\t  const ms = Date.now() - start;\n72\t  const method = c.req.method;\n73\t  const path = c.req.path;\n74\t  // Skip noisy health checks and OPTIONS preflight\n75\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n76\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n77\t});\n78\t\n79\t// API docs — Swagger UI + raw OpenAPI spec\n80\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n81\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n82\t\n83\t// Auth routes — no JWT middleware (these are the login endpoints)\n84\t// Lighter rate limiting by IP for auth endpoints\n85\tapp.use(\n86\t  \"/auth/*\",\n87\t  createRateLimitMiddleware({\n88\t    perWallet: 20,\n89\t    global: config.rateLimitGlobal,\n90\t    windowMs: 60_000,\n91\t  }),\n92\t);\n93\t\n94\tapp.route(\n95\t  \"/auth\",\n96\t  createAuthRoutes({\n97\t    authDb,\n98\t    db,\n99\t    jwtSecret: config.jwtSecret,\n100\t    cluster: config.cluster,\n101\t    challengeTtlSeconds: config.challengeTtlSeconds,\n102\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n103\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n104\t  }),\n105\t);\n106\t\n107\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n108\tapp.use(\n109\t  \"/profile/*\",\n110\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n111\t);\n112\tapp.route(\"/profile\", createProfileRoutes({ db }));\n113\t\n114\t// Public profile routes — no auth required\n115\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n116\t\n117\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n118\tapp.use(\n119\t  \"/referral/*\",\n120\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n121\t);\n122\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n123\t\n124\t// JWT auth middleware for game endpoints\n125\tapp.use(\n126\t  \"/coinflip/*\",\n127\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n128\t);\n129\tapp.use(\n130\t  \"/lord/*\",\n131\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n132\t);\n133\t\n134\t// Rate limiting — per-wallet and global limits on POST requests\n135\tapp.use(\n136\t  \"/coinflip/*\",\n137\t  createRateLimitMiddleware({\n138\t    perWallet: config.rateLimitPerWallet,\n139\t    global: config.rateLimitGlobal,\n140\t    windowMs: 60_000,\n141\t  }),\n142\t);\n143\tapp.use(\n144\t  \"/lord/*\",\n145\t  createRateLimitMiddleware({\n146\t    perWallet: config.rateLimitPerWallet,\n147\t    global: config.rateLimitGlobal,\n148\t    windowMs: 60_000,\n149\t  }),\n150\t);\n151\t\n152\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n153\tconst entropyAccount = new PublicKey(config.entropyAccount);\n154\tconst retrySettler = createRetrySettler({\n155\t  db,\n156\t  connection,\n157\t  settleRound: (pda) =>\n158\t    settleRound(\n159\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n160\t      pda,\n161\t    ),\n162\t});\n163\t\n164\t// PDA watcher — WebSocket-based instant join detection\n165\tconst pdaWatcher = createPdaWatcher({\n166\t  connection,\n167\t  serverKey: config.serverKeypair.publicKey,\n168\t  db,\n169\t  onJoinDetected: async (pda, targetSlot) => {\n170\t    // Update DB phase if still in 'created'\n171\t    const round = await db.getRoundByPda(pda);\n172\t    if (round && round.phase === \"created\") {\n173\t      await db.updateRoundPhase(pda, \"locked\", {\n174\t        target_slot: targetSlot.toString(),\n175\t      });\n176\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n177\t        targetSlot: targetSlot.toString(),\n178\t        source: \"pda-watcher\",\n179\t        game: round.game,\n180\t      });\n181\t    }\n182\t\n183\t    // Check if target slot already passed — settle immediately if so\n184\t    const currentSlot = await connection.getSlot();\n185\t    if (BigInt(currentSlot) >= targetSlot) {\n186\t      await retrySettler.attemptSettle(pda);\n187\t      pdaWatcher.unwatch(pda);\n188\t    }\n189\t    // If target slot not reached yet, poll worker will pick it up next cycle\n190\t  },\n191\t});\n192\t\n193\tconst worker = createSettlementWorker({\n194\t  db,\n195\t  connection,\n196\t  serverKey: config.serverKeypair.publicKey,\n197\t  pollIntervalMs: config.workerPollIntervalMs,\n198\t  onSettleReady: async (pda) => {\n199\t    await retrySettler.attemptSettle(pda);\n200\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n201\t  },\n202\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n203\t});\n204\tworker.start();\n205\t\n206\t// Close Call clock worker — fetches boundary prices + settles open rounds\n207\t// Rounds are created on-demand by players via /closecall/bet\n208\tconst closeCallClock = createCloseCallClockWorker({\n209\t  connection,\n210\t  serverKeypair: config.serverKeypair,\n211\t  db,\n212\t});\n213\tcloseCallClock.start();\n214\t\n215\t// Register event handlers before starting the worker\n216\tregisterHandler(\n217\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n218\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n219\t);\n220\tregisterHandler(\n221\t  EventTypes.GAME_SETTLED,\n222\t  createGameSettledHandler({ db }),\n223\t);\n224\tregisterHandler(\n225\t  EventTypes.REWARD_POOL_FUND,\n226\t  createRewardPoolFundHandler({ db }),\n227\t);\n228\tregisterHandler(\n229\t  EventTypes.POINTS_GRANT,\n230\t  createPointsGrantHandler({\n231\t    db,\n232\t    getSolPrice: async () => {\n233\t      const result = await fetchSolPrice();\n234\t      return result?.price ?? null;\n235\t    },\n236\t  }),\n237\t);\n238\tregisterHandler(\n239\t  EventTypes.CRATE_DROP,\n240\t  createCrateDropHandler({ db }),\n241\t);\n242\t\n243\t// Dogpile status worker — transitions scheduled→active→ended\n244\tconst dogpileWorker = createDogpileWorker({ db, pollIntervalMs: 10_000 });\n245\tdogpileWorker.start();\n246\tlogger.info(\"Dogpile worker started\");\n247\t\n248\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n249\tconst eventWorker = createEventWorker(sql, {\n250\t  pollIntervalMs: config.eventQueuePollMs,\n251\t});\n252\teventWorker.start();\n253\tlogger.info(\"Event queue worker started\", {\n254\t  pollIntervalMs: config.eventQueuePollMs,\n255\t});\n256\t\n257\t// Game-specific routes\n258\tapp.route(\n259\t  \"/coinflip\",\n260\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n261\t);\n262\tapp.route(\n263\t  \"/lord\",\n264\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n265\t);\n266\t\n267\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n268\tapp.use(\n269\t  \"/closecall/bet\",\n270\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n271\t);\n272\tapp.use(\n273\t  \"/closecall/bet\",\n274\t  createRateLimitMiddleware({\n275\t    perWallet: config.rateLimitPerWallet,\n276\t    global: config.rateLimitGlobal,\n277\t    windowMs: 60_000,\n278\t  }),\n279\t);\n280\t\n281\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n282\tapp.route(\"/closecall\", createCloseCallRoutes({\n283\t  db,\n284\t  connection,\n285\t  serverKeypair: config.serverKeypair,\n286\t  clockWorker: closeCallClock,\n287\t}));\n288\t\n289\t// Challenge routes — authenticated GET endpoints (require JWT on all methods)\n290\tapp.use(\n291\t  \"/challenges/*\",\n292\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n293\t);\n294\tapp.route(\"/challenges\", createChallengeRoutes({ db }));\n295\t\n296\t// Points routes — authenticated GET endpoints (require JWT on all methods)\n297\tapp.use(\n298\t  \"/points/*\",\n299\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n300\t);\n301\tapp.route(\"/points\", createPointsRoutes({ db }));\n302\t\n303\t// Crate routes — authenticated GET endpoints (require JWT on all methods)\n304\tapp.use(\n305\t  \"/crates/*\",\n306\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n307\t);\n308\tapp.route(\"/crates\", createCrateRoutes({ db }));\n309\t\n310\t// Dogpile routes — public, no auth\n311\tapp.route(\"/dogpile\", createDogpileRoutes({ db }));\n312\t\n313\t// Admin API routes — requires ADMIN_API_KEY env var\n314\tif (config.adminApiKey) {\n315\t  app.route(\"/admin\", createAdminRoutes({ db, adminApiKey: config.adminApiKey }));\n316\t  logger.info(\"Admin API routes enabled at /admin\");\n317\t}\n318\t\n319\t// Leaderboard routes — public, no auth\n320\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n321\t\n322\t// Price routes — public, no auth\n323\tapp.route(\"/price\", createPriceRoutes());\n324\t\n325\t// Round verification routes\n326\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n327\t\n328\t// Health endpoint — wired after worker exists so we can query its status\n329\tapp.route(\n330\t  \"/health\",\n331\t  createHealthRoutes({\n332\t    db,\n333\t    sql,\n334\t    isWorkerRunning: () => worker.isRunning,\n335\t  }),\n336\t);\n337\t\n338\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n339\tif (config.adminToken) {\n340\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n341\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n342\t}\n343\t\n344\tconst port = config.port;\n345\tlogger.info(\"fairness-backend started\", { port });\n346\t\n347\tserve({\n348\t  fetch: app.fetch,\n349\t  port,\n350\t  hostname: \"0.0.0.0\",\n351\t});\n352\t\n353\texport default {\n354\t  port,\n355\t  fetch: app.fetch,\n356\t};\n357\t"}]},"parent_tool_use_id":"toolu_01DVFAq7wNTUZPjttWVufQSx","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"d62311ae-27f3-40bc-9fae-cd915d0754a1","timestamp":"2026-04-03T21:50:48.515Z"}
