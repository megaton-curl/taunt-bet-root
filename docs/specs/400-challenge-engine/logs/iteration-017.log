{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TqagBVgcF2JygYMdMAnjMF","type":"tool_result","content":"1284\t  it(\"reward.pool_fund handler: funds pool from fee and dedupes on round_id\", async () => {\n1285\t    // Ensure reward_config has the fee share (seeded by migration, but verify)\n1286\t    const configRows = await rawSql<{ value: string }[]>`\n1287\t      SELECT value FROM reward_config WHERE key = 'reward_pool_fee_share'\n1288\t    `;\n1289\t    if (configRows.length === 0) {\n1290\t      // Re-seed if TRUNCATE removed it\n1291\t      await rawSql`INSERT INTO reward_config (key, value) VALUES ('reward_pool_fee_share', '0.20')`;\n1292\t    }\n1293\t\n1294\t    // Verify pool starts at zero\n1295\t    const poolBefore = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1296\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1297\t    `;\n1298\t    expect(poolBefore.length).toBe(1);\n1299\t    expect(BigInt(poolBefore[0]!.balance_lamports)).toBe(0n);\n1300\t    expect(BigInt(poolBefore[0]!.lifetime_funded)).toBe(0n);\n1301\t\n1302\t    // Create handler and call it directly\n1303\t    const handler = createRewardPoolFundHandler({ db });\n1304\t\n1305\t    const feeLamports = \"500000\"; // 500_000 lamports fee\n1306\t    const roundId = \"test-round-pool-fund-001\";\n1307\t\n1308\t    await handler({\n1309\t      roundId,\n1310\t      feeLamports,\n1311\t    });\n1312\t\n1313\t    // Expected funded = floor(500_000 * 0.20) = 100_000\n1314\t    const expectedFunded = 100_000n;\n1315\t\n1316\t    // Verify reward_pool_fundings row\n1317\t    const fundings = await rawSql<{\n1318\t      round_id: string;\n1319\t      fee_lamports: string;\n1320\t      funded_lamports: string;\n1321\t    }[]>`\n1322\t      SELECT round_id, fee_lamports, funded_lamports FROM reward_pool_fundings WHERE round_id = ${roundId}\n1323\t    `;\n1324\t    expect(fundings.length).toBe(1);\n1325\t    expect(fundings[0]!.round_id).toBe(roundId);\n1326\t    expect(BigInt(fundings[0]!.fee_lamports)).toBe(500_000n);\n1327\t    expect(BigInt(fundings[0]!.funded_lamports)).toBe(expectedFunded);\n1328\t\n1329\t    // Verify pool balance incremented\n1330\t    const poolAfter = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1331\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1332\t    `;\n1333\t    expect(BigInt(poolAfter[0]!.balance_lamports)).toBe(expectedFunded);\n1334\t    expect(BigInt(poolAfter[0]!.lifetime_funded)).toBe(expectedFunded);\n1335\t\n1336\t    // --- Idempotency: re-emit same round_id ---\n1337\t    await handler({\n1338\t      roundId,\n1339\t      feeLamports,\n1340\t    });\n1341\t\n1342\t    // Verify no duplicate funding row\n1343\t    const fundingsAfterDupe = await rawSql<{ id: string }[]>`\n1344\t      SELECT id FROM reward_pool_fundings WHERE round_id = ${roundId}\n1345\t    `;\n1346\t    expect(fundingsAfterDupe.length).toBe(1);\n1347\t\n1348\t    // Verify pool balance unchanged\n1349\t    const poolAfterDupe = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1350\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1351\t    `;\n1352\t    expect(BigInt(poolAfterDupe[0]!.balance_lamports)).toBe(expectedFunded);\n1353\t    expect(BigInt(poolAfterDupe[0]!.lifetime_funded)).toBe(expectedFunded);\n1354\t  });\n1355\t\n1356\t  // ---------------------------------------------------------------------------\n1357\t  // POINTS_GRANT handler\n1358\t  // ---------------------------------------------------------------------------\n1359\t\n1360\t  it(\"points.grant handler: awards wager-based points and dedupes\", async () => {\n1361\t    // Ensure reward_config has points_per_dollar\n1362\t    const configRows = await rawSql<{ value: string }[]>`\n1363\t      SELECT value FROM reward_config WHERE key = 'points_per_dollar'\n1364\t    `;\n1365\t    if (configRows.length === 0) {\n1366\t      await rawSql`INSERT INTO reward_config (key, value) VALUES ('points_per_dollar', '500')`;\n1367\t    }\n1368\t\n1369\t    // Mock SOL/USD price at $100\n1370\t    const mockSolPrice = 100;\n1371\t    const handler = createPointsGrantHandler({\n1372\t      db,\n1373\t      getSolPrice: async () => mockSolPrice,\n1374\t    });\n1375\t\n1376\t    const userId = \"usr_pointstest1\";\n1377\t    const wallet = \"PointsTestWallet1111111111111111111111111\";\n1378\t    const sourceId = \"test-round-points-001\";\n1379\t    const amountLamports = \"50000000\"; // 0.05 SOL\n1380\t\n1381\t    await handler({\n1382\t      userId,\n1383\t      wallet,\n1384\t      sourceType: \"wager\",\n1385\t      sourceId,\n1386\t      amountLamports,\n1387\t      settledAt: new Date().toISOString(),\n1388\t    });\n1389\t\n1390\t    // Expected: 0.05 SOL * $100 = $5.00 * 500 points/dollar = 2500 points\n1391\t    const expectedPoints = 2500n;\n1392\t\n1393\t    // Verify point_grants row\n1394\t    const grants = await rawSql<{\n1395\t      user_id: string;\n1396\t      wallet: string;\n1397\t      source_type: string;\n1398\t      source_id: string;\n1399\t      amount: string;\n1400\t      metadata: string;\n1401\t    }[]>`\n1402\t      SELECT user_id, wallet, source_type, source_id, amount, metadata\n1403\t      FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n1404\t    `;\n1405\t    expect(grants.length).toBe(1);\n1406\t    expect(grants[0]!.source_type).toBe(\"wager\");\n1407\t    expect(BigInt(grants[0]!.amount)).toBe(expectedPoints);\n1408\t    const meta = typeof grants[0]!.metadata === \"string\"\n1409\t      ? JSON.parse(grants[0]!.metadata) : grants[0]!.metadata;\n1410\t    expect(meta).toMatchObject({\n1411\t      solPrice: mockSolPrice,\n1412\t      pointsPerDollar: 500,\n1413\t      multiplier: 1,\n1414\t    });\n1415\t\n1416\t    // Verify player_points upserted\n1417\t    const pp = await rawSql<{ balance: string; lifetime_earned: string }[]>`\n1418\t      SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n1419\t    `;\n1420\t    expect(pp.length).toBe(1);\n1421\t    expect(BigInt(pp[0]!.balance)).toBe(expectedPoints);\n1422\t    expect(BigInt(pp[0]!.lifetime_earned)).toBe(expectedPoints);\n1423\t\n1424\t    // --- Idempotency: re-emit same grant ---\n1425\t    await handler({\n1426\t      userId,\n1427\t      wallet,\n1428\t      sourceType: \"wager\",\n1429\t      sourceId,\n1430\t      amountLamports,\n1431\t      settledAt: new Date().toISOString(),\n1432\t    });\n1433\t"}]},"parent_tool_use_id":"toolu_013Cq4thG3nF9u3oQyBCmhx8","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"2b9e388d-f86f-41d2-8343-c10f304d671f","timestamp":"2026-04-03T21:51:10.751Z"}
