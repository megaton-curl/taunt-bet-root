{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012gCrMRLRkBsYunQMMbfJFu","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n31\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n32\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n33\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n34\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n35\timport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\n36\timport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\n37\timport { createGameSettledHandler } from \"../queue/handlers/game-settled.js\";\n38\timport { createChallengeRoutes, dailyPeriodKey, weeklyPeriodKey } from \"../routes/challenges.js\";\n39\timport { createPointsRoutes, createCrateRoutes } from \"../routes/points.js\";\n40\timport { createDogpileRoutes } from \"../routes/dogpile.js\";\n41\timport { createAdminRoutes } from \"../routes/admin.js\";\n42\timport { createDogpileWorker } from \"../worker/dogpile-worker.js\";\n43\t\n44\t// ---------------------------------------------------------------------------\n45\t// Constants\n46\t// ---------------------------------------------------------------------------\n47\t\n48\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n49\t\n50\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n51\tfunction makeSql() {\n52\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n53\t  // Dev container: postgres listens on Unix socket only\n54\t  return postgres({\n55\t    host: \"/var/run/postgresql\",\n56\t    user: \"vscode\",\n57\t    database: \"rng_utopia_dev\",\n58\t  });\n59\t}\n60\t\n61\tconst AMOUNT_LAMPORTS = 5_000_000;\n62\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n63\tconst SIDE_HEADS = 0;\n64\tconst PHASE_LOCKED = 1;\n65\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n66\t\n67\t// ---------------------------------------------------------------------------\n68\t// JWT helper\n69\t// ---------------------------------------------------------------------------\n70\t\n71\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n72\t  const now = Math.floor(Date.now() / 1000);\n73\t  return new SignJWT({ wallet })\n74\t    .setProtectedHeader({ alg: \"HS256\" })\n75\t    .setSubject(userId)\n76\t    .setIssuedAt(now)\n77\t    .setExpirationTime(now + 3600)\n78\t    .sign(JWT_SECRET);\n79\t}\n80\t\n81\tfunction userIdFromWallet(wallet: string) {\n82\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n83\t}\n84\t\n85\t// ---------------------------------------------------------------------------\n86\t// Mock Connection\n87\t// ---------------------------------------------------------------------------\n88\t\n89\t/**\n90\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n91\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n92\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n93\t */\n94\tclass MockConnection {\n95\t  private _slot = 200;\n96\t  private _accounts = new Map<\n97\t    string,\n98\t    {\n99\t      data: Buffer;\n100\t      lamports: number;\n101\t      owner: PublicKey;\n102\t      executable: boolean;\n103\t    }\n104\t  >();\n105\t  lastRawTx: Buffer | null = null;\n106\t\n107\t  set slot(s: number) {\n108\t    this._slot = s;\n109\t  }\n110\t  get slot() {\n111\t    return this._slot;\n112\t  }\n113\t\n114\t  setAccount(\n115\t    pubkey: PublicKey,\n116\t    data: Buffer,\n117\t    opts?: { lamports?: number; owner?: PublicKey },\n118\t  ) {\n119\t    this._accounts.set(pubkey.toBase58(), {\n120\t      data,\n121\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n122\t      owner: opts?.owner ?? SystemProgram.programId,\n123\t      executable: false,\n124\t    });\n125\t  }\n126\t\n127\t  removeAccount(pubkey: PublicKey) {\n128\t    this._accounts.delete(pubkey.toBase58());\n129\t  }\n130\t\n131\t  async getLatestBlockhash() {\n132\t    return {\n133\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n134\t      lastValidBlockHeight: 999_999,\n135\t    };\n136\t  }\n137\t\n138\t  async getSlot() {\n139\t    return this._slot;\n140\t  }\n141\t\n142\t  async getAccountInfo(pubkey: PublicKey) {\n143\t    const acc = this._accounts.get(pubkey.toBase58());\n144\t    if (!acc) return null;\n145\t    return { ...acc, rentEpoch: 0 };\n146\t  }\n147\t\n148\t  async getProgramAccounts(\n149\t    programId: PublicKey,\n150\t    config?: {\n151\t      filters?: Array<\n152\t        | { dataSize: number }\n153\t        | { memcmp: { offset: number; bytes: string } }\n154\t      >;\n155\t    },\n156\t  ) {\n157\t    const results: Array<{\n158\t      pubkey: PublicKey;\n159\t      account: {\n160\t        data: Buffer;\n161\t        lamports: number;\n162\t        owner: PublicKey;\n163\t        executable: boolean;\n164\t        rentEpoch: number;\n165\t      };\n166\t    }> = [];\n167\t\n168\t    for (const [key, acc] of this._accounts) {\n169\t      if (!acc.owner.equals(programId)) continue;\n170\t\n171\t      let matches = true;\n172\t      if (config?.filters) {\n173\t        for (const filter of config.filters) {\n174\t          if (\"dataSize\" in filter) {\n175\t            if (acc.data.length !== filter.dataSize) {\n176\t              matches = false;\n177\t              break;\n178\t            }\n179\t          }\n180\t          if (\"memcmp\" in filter) {\n181\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n182\t            const actual = acc.data.subarray(\n183\t              filter.memcmp.offset,\n184\t              filter.memcmp.offset + expected.length,\n185\t            );\n186\t            if (Buffer.compare(actual, expected) !== 0) {\n187\t              matches = false;\n188\t              break;\n189\t            }\n190\t          }\n191\t        }\n192\t      }\n193\t\n194\t      if (matches) {\n195\t        results.push({\n196\t          pubkey: new PublicKey(key),\n197\t          account: { ...acc, rentEpoch: 0 },\n198\t        });\n199\t      }\n200\t    }\n201\t    return results;\n202\t  }\n203\t\n204\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n205\t    this.lastRawTx = Buffer.from(rawTx);\n206\t    // Return a deterministic fake signature\n207\t    return bs58.encode(Buffer.alloc(64, 0x01));\n208\t  }\n209\t\n210\t  async confirmTransaction() {\n211\t    return { value: { err: null }, context: { slot: this._slot } };\n212\t  }\n213\t\n214\t  async getBlockTime(_slot: number) {\n215\t    return Math.floor(Date.now() / 1000);\n216\t  }\n217\t\n218\t  async getBalance() {\n219\t    return 2 * LAMPORTS_PER_SOL;\n220\t  }\n221\t}\n222\t\n223\t// ---------------------------------------------------------------------------\n224\t// Account data builders\n225\t// ---------------------------------------------------------------------------\n226\t\n227\tasync function buildMatchAccountData(params: {\n228\t  creator: PublicKey;\n229\t  opponent: PublicKey;\n230\t  server: PublicKey;\n231\t  entryAmount: bigint;\n232\t  creatorSide: number;\n233\t  phase: number;\n234\t  commitment: Buffer;\n235\t  algorithmVer: number;\n236\t  targetSlot: bigint;\n237\t  resolveDeadline: bigint;\n238\t  matchId: Buffer;\n239\t}): Promise<Buffer> {\n240\t  return encodeCoinflipMatch({\n241\t    creator: params.creator,\n242\t    opponent: params.opponent,\n243\t    server: params.server,\n244\t    entryAmount: params.entryAmount,\n245\t    creatorSide: params.creatorSide,\n246\t    phase: params.phase,\n247\t    commitment: [...params.commitment],\n248\t    algorithmVer: params.algorithmVer,\n249\t    targetSlot: params.targetSlot,\n250\t    resolveDeadline: params.resolveDeadline,\n251\t    resultHash: new Array(32).fill(0),\n252\t    result: 0,\n253\t    winner: PublicKey.default,\n254\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n255\t    matchId: [...params.matchId],\n256\t    bump: 0,\n257\t  });\n258\t}\n259\t\n260\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n261\t  return encodeCoinflipConfig({\n262\t    authority: PublicKey.default,\n263\t    treasury,\n264\t    paused: false,\n265\t    bump: 0,\n266\t  });\n267\t}\n268\t\n269\t/**\n270\t * Build PlatformConfig account data matching the on-chain layout.\n271\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n272\t */\n273\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n274\t  const buf = Buffer.alloc(74);\n275\t  // discriminator (8 bytes) — zeroed is fine for mock\n276\t  // authority at offset 8 — use default\n277\t  PublicKey.default.toBuffer().copy(buf, 8);\n278\t  // treasury at offset 40\n279\t  treasury.toBuffer().copy(buf, 40);\n280\t  // fee_bps at offset 72\n281\t  buf.writeUInt16LE(feeBps, 72);\n282\t  return buf;\n283\t}\n284\t\n285\t// ---------------------------------------------------------------------------\n286\t// Test suite\n287\t// ---------------------------------------------------------------------------\n288\t\n289\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n290\t  let db: Db;\n291\t  let rawSql: ReturnType<typeof postgres>;\n292\t  let mockConn: MockConnection;\n293\t  let app: Hono;\n294\t\n295\t  const serverKeypair = Keypair.generate();\n296\t  const creatorKeypair = Keypair.generate();\n297\t  const opponentKeypair = Keypair.generate();\n298\t  const treasuryKeypair = Keypair.generate();\n299\t  const entropyKeypair = Keypair.generate();\n300\t  const entropyAccount = entropyKeypair.publicKey;\n301\t\n302\t  const entropyData = Buffer.alloc(32);\n303\t  entropyData[0] = 0xab;\n304\t  entropyData[1] = 0xcd;\n305\t  entropyData[15] = 0x42;\n306\t\n307\t  beforeAll(async () => {\n308\t    rawSql = makeSql();\n309\t    await rawSql`\n310\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n311\t    `;\n312\t    await rawSql`\n313\t      CREATE TABLE referral_codes (\n314\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n315\t        user_id TEXT NOT NULL UNIQUE,\n316\t        wallet TEXT NOT NULL UNIQUE,\n317\t        code TEXT NOT NULL UNIQUE,\n318\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n319\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n320\t      )\n321\t    `;\n322\t    await rawSql`\n323\t      CREATE TABLE referral_links (\n324\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n325\t        referrer_user_id TEXT NOT NULL,\n326\t        referee_user_id TEXT NOT NULL UNIQUE,\n327\t        referrer_wallet TEXT NOT NULL,\n328\t        referee_wallet TEXT NOT NULL,\n329\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n330\t      )\n331\t    `;\n332\t    await rawSql`\n333\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n334\t    `;\n335\t    await rawSql`\n336\t      CREATE TABLE referral_earnings (\n337\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n338\t        referrer_user_id TEXT NOT NULL,\n339\t        referee_user_id TEXT NOT NULL,\n340\t        referrer_wallet TEXT NOT NULL,\n341\t        referee_wallet TEXT NOT NULL,\n342\t        round_id TEXT NOT NULL,\n343\t        game_type TEXT NOT NULL,\n344\t        wager_lamports BIGINT NOT NULL,\n345\t        fee_lamports BIGINT NOT NULL,\n346\t        referrer_earned_lamports BIGINT NOT NULL,\n347\t        referrer_rate_bps INTEGER NOT NULL,\n348\t        referee_rebate_lamports BIGINT NOT NULL,\n349\t        referee_rebate_rate_bps INTEGER NOT NULL,\n350\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n351\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n352\t      )\n353\t    `;\n354\t    await rawSql`\n355\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n356\t    `;\n357\t    await rawSql`\n358\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n359\t    `;\n360\t    await rawSql`\n361\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n362\t    `;\n363\t    await rawSql`\n364\t      CREATE TABLE referral_claims (\n365\t        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n366\t        user_id TEXT NOT NULL,\n367\t        wallet TEXT NOT NULL,\n368\t        amount_lamports BIGINT NOT NULL,\n369\t        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n370\t        retry_count INTEGER NOT NULL DEFAULT 0,\n371\t        tx_signature TEXT,\n372\t        error TEXT,\n373\t        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n374\t        processed_at TIMESTAMPTZ\n375\t      )\n376\t    `;\n377\t    await rawSql`\n378\t      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n379\t    `;\n380\t    await rawSql`\n381\t      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n382\t    `;\n383\t    await rawSql`\n384\t      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n385\t    `;\n386\t    await rawSql`\n387\t      CREATE TABLE referral_kol_rates (\n388\t        user_id TEXT PRIMARY KEY,\n389\t        wallet TEXT NOT NULL UNIQUE,\n390\t        rate_bps INTEGER NOT NULL,\n391\t        set_by TEXT NOT NULL,\n392\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n393\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n394\t      )\n395\t    `;\n396\t    db = createDb(DATABASE_URL, rawSql);\n397\t  });\n398\t\n399\t  afterAll(async () => {\n400\t    await db.close();\n401\t    await rawSql.end();\n402\t  });\n403\t\n404\t  beforeEach(async () => {\n405\t    // Clean tables for isolation\n406\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n407\t    // Reset reward_pool balance to zero (keep singleton row from migration seed)\n408\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n409\t\n410\t    // Reset PlatformConfig cache so each test reads from its own mock\n411\t    resetPlatformConfigCache();\n412\t\n413\t    // Fresh mock Connection\n414\t    mockConn = new MockConnection();\n415\t\n416\t    // Pre-populate mock with entropy and config accounts\n417\t    mockConn.setAccount(entropyAccount, entropyData);\n418\t\n419\t    const [configPda] = PublicKey.findProgramAddressSync(\n420\t      [Buffer.from(\"coinflip_config\")],\n421\t      COINFLIP_PROGRAM_ID,\n422\t    );\n423\t    mockConn.setAccount(\n424\t      configPda,\n425\t      await buildConfigAccountData(treasuryKeypair.publicKey),\n426\t      { owner: COINFLIP_PROGRAM_ID },\n427\t    );\n428\t\n429\t    // PlatformConfig account — settlement reads fee_bps from here\n430\t    const [platformConfigPda] = derivePlatformConfigPda();\n431\t    mockConn.setAccount(\n432\t      platformConfigPda,\n433\t      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n434\t      { owner: PLATFORM_PROGRAM_ID },\n435\t    );\n436\t\n437\t    // Build the Hono app (no rate limiting for tests)\n438\t    app = new Hono();\n439\t\n440\t    app.use(\n441\t      \"/coinflip/*\",\n442\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n443\t    );\n444\t\n445\t    app.route(\n446\t      \"/coinflip\",\n447\t      createCoinflipRoutes({\n448\t        db,\n449\t        connection: mockConn as unknown as Connection,\n450\t        serverKeypair,"}]},"parent_tool_use_id":"toolu_013Cq4thG3nF9u3oQyBCmhx8","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"5a9ced68-0f12-451f-b39c-29c21bedd396","timestamp":"2026-04-03T21:50:58.968Z"}
