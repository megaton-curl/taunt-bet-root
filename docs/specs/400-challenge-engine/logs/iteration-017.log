{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013pHuziGPcDeyRKHc6MjPBY","type":"tool_result","content":"1480\t      settledAt: now.toISOString(),\n1481\t    });\n1482\t\n1483\t    // Expected: 0.05 SOL * $100 = $5.00 * 500 * 2.0 dogpile = 5000 points\n1484\t    const expectedPoints = 5000n;\n1485\t\n1486\t    const grants = await rawSql<{ amount: string; metadata: string }[]>`\n1487\t      SELECT amount, metadata FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n1488\t    `;\n1489\t    expect(grants.length).toBe(1);\n1490\t    expect(BigInt(grants[0]!.amount)).toBe(expectedPoints);\n1491\t    const dogpileMeta = typeof grants[0]!.metadata === \"string\"\n1492\t      ? JSON.parse(grants[0]!.metadata) : grants[0]!.metadata;\n1493\t    expect(dogpileMeta).toMatchObject({ multiplier: 2 });\n1494\t\n1495\t    const pp = await rawSql<{ balance: string }[]>`\n1496\t      SELECT balance FROM player_points WHERE user_id = ${userId}\n1497\t    `;\n1498\t    expect(BigInt(pp[0]!.balance)).toBe(expectedPoints);\n1499\t  });\n1500\t\n1501\t  it(\"points.grant handler: handles pre-calculated crate_points grant\", async () => {\n1502\t    const handler = createPointsGrantHandler({\n1503\t      db,\n1504\t      getSolPrice: async () => 100,\n1505\t    });\n1506\t\n1507\t    const userId = \"usr_cratepoints1\";\n1508\t    const wallet = \"CratePointsWallet11111111111111111111111\";\n1509\t    const sourceId = \"crate-drop-001\";\n1510\t\n1511\t    await handler({\n1512\t      userId,\n1513\t      wallet,\n1514\t      sourceType: \"crate_points\",\n1515\t      sourceId,\n1516\t      amount: \"3000\",\n1517\t    });\n1518\t\n1519\t    const grants = await rawSql<{ amount: string; source_type: string }[]>`\n1520\t      SELECT amount, source_type FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n1521\t    `;\n1522\t    expect(grants.length).toBe(1);\n1523\t    expect(grants[0]!.source_type).toBe(\"crate_points\");\n1524\t    expect(BigInt(grants[0]!.amount)).toBe(3000n);\n1525\t\n1526\t    const pp = await rawSql<{ balance: string; lifetime_earned: string }[]>`\n1527\t      SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n1528\t    `;\n1529\t    expect(pp.length).toBe(1);\n1530\t    expect(BigInt(pp[0]!.balance)).toBe(3000n);\n1531\t    expect(BigInt(pp[0]!.lifetime_earned)).toBe(3000n);\n1532\t  });\n1533\t\n1534\t  // -----------------------------------------------------------------------\n1535\t  // CRATE_DROP handler tests\n1536\t  // -----------------------------------------------------------------------\n1537\t\n1538\t  it(\"crate.drop handler: SOL crate hit — decrements pool, creates crate row, emits sol_payout\", async () => {\n1539\t    // Fund the reward pool so a SOL crate can be funded\n1540\t    // sol_crate_min_value is 10_000_000 (10M lamports = 0.01 SOL)\n1541\t    // sol_crate_pool_pct is 0.10 → need pool >= 100_000_000 to get payout >= 10M\n1542\t    await rawSql`UPDATE reward_pool SET balance_lamports = 200000000, lifetime_funded = 200000000 WHERE id = 1`;\n1543\t\n1544\t    // Roll = 0.005, which is < sol_crate_drop_rate (0.01) → SOL crate hit\n1545\t    const handler = createCrateDropHandler({\n1546\t      db,\n1547\t      rollRng: () => 0.005,\n1548\t    });\n1549\t\n1550\t    const userId = \"usr_cratesol1\";\n1551\t    const wallet = \"CrateSolWallet1111111111111111111111111\";\n1552\t    const triggerId = \"test-round-crate-sol-001\";\n1553\t\n1554\t    await handler({\n1555\t      userId,\n1556\t      wallet,\n1557\t      triggerType: \"game_settled\",\n1558\t      triggerId,\n1559\t    });\n1560\t\n1561\t    // Expected payout: floor(200_000_000 * 0.10) = 20_000_000\n1562\t    const expectedPayout = 20_000_000n;\n1563\t\n1564\t    // Verify crate_drops row\n1565\t    const crates = await rawSql<{\n1566\t      user_id: string;\n1567\t      trigger_type: string;\n1568\t      trigger_id: string;\n1569\t      crate_type: string;\n1570\t      contents_amount: string;\n1571\t      status: string;\n1572\t    }[]>`\n1573\t      SELECT user_id, trigger_type, trigger_id, crate_type, contents_amount, status\n1574\t      FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1575\t    `;\n1576\t    expect(crates.length).toBe(1);\n1577\t    expect(crates[0]!.crate_type).toBe(\"sol\");\n1578\t    expect(BigInt(crates[0]!.contents_amount)).toBe(expectedPayout);\n1579\t    expect(crates[0]!.status).toBe(\"pending\");\n1580\t\n1581\t    // Verify pool decremented\n1582\t    const pool = await rawSql<{ balance_lamports: string; lifetime_paid: string }[]>`\n1583\t      SELECT balance_lamports, lifetime_paid FROM reward_pool WHERE id = 1\n1584\t    `;\n1585\t    expect(BigInt(pool[0]!.balance_lamports)).toBe(200_000_000n - expectedPayout);\n1586\t    expect(BigInt(pool[0]!.lifetime_paid)).toBe(expectedPayout);\n1587\t\n1588\t    // Verify CRATE_SOL_PAYOUT event emitted\n1589\t    const events = await rawSql<{ event_type: string; payload: string }[]>`\n1590\t      SELECT event_type, payload FROM event_queue WHERE event_type = 'crate.sol_payout'\n1591\t    `;\n1592\t    expect(events.length).toBe(1);\n1593\t    const eventPayload = typeof events[0]!.payload === \"string\"\n1594\t      ? JSON.parse(events[0]!.payload) : events[0]!.payload;\n1595\t    expect(eventPayload.userId).toBe(userId);\n1596\t    expect(eventPayload.wallet).toBe(wallet);\n1597\t    expect(eventPayload.payoutLamports).toBe(expectedPayout.toString());\n1598\t  });\n1599\t\n1600\t  it(\"crate.drop handler: points crate hit — creates crate row, emits points.grant\", async () => {\n1601\t    // Roll = 0.02, which is >= sol_crate_drop_rate (0.01) but < 0.01 + 0.05 = 0.06 → points crate\n1602\t    // Second roll for points amount: 0.5 → min + floor(0.5 * (max - min + 1)) = 500 + floor(0.5 * 4501) = 500 + 2250 = 2750\n1603\t    const rolls = [0.02, 0.5];\n1604\t    let rollIdx = 0;\n1605\t    const handler = createCrateDropHandler({\n1606\t      db,\n1607\t      rollRng: () => rolls[rollIdx++]!,\n1608\t    });\n1609\t\n1610\t    const userId = \"usr_cratepoints2\";\n1611\t    const wallet = \"CratePointsWallet2111111111111111111111\";\n1612\t    const triggerId = \"test-round-crate-pts-001\";\n1613\t\n1614\t    await handler({\n1615\t      userId,\n1616\t      wallet,\n1617\t      triggerType: \"game_settled\",\n1618\t      triggerId,\n1619\t    });\n1620\t\n1621\t    // Expected points: 500 + floor(0.5 * (5000 - 500 + 1)) = 500 + 2250 = 2750\n1622\t    const expectedPoints = 2750;\n1623\t\n1624\t    // Verify crate_drops row\n1625\t    const crates = await rawSql<{\n1626\t      crate_type: string;\n1627\t      contents_amount: string;\n1628\t    }[]>`\n1629\t      SELECT crate_type, contents_amount"}]},"parent_tool_use_id":"toolu_013Cq4thG3nF9u3oQyBCmhx8","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"3d096e09-62a0-41e0-9ba6-60f82d33c10e","timestamp":"2026-04-03T21:51:06.287Z"}
