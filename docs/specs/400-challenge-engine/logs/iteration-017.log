{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K4zoEYLKBo6UsohZPFY7hY","type":"tool_result","content":"1\t/**\n2\t * Known event type constants for the async event queue.\n3\t *\n4\t * Using a const object + derived union makes typos a compile error\n5\t * instead of a dead event at runtime.\n6\t */\n7\t\n8\texport const EventTypes = {\n9\t  REFERRAL_CODE_APPLIED: \"referral.code_applied\",\n10\t  REFERRAL_GAME_SETTLED: \"referral.game_settled\",\n11\t  REFERRAL_CLAIM_REQUESTED: \"referral.claim_requested\",\n12\t  GAME_SETTLED: \"game.settled\",\n13\t  REWARD_POOL_FUND: \"reward.pool_fund\",\n14\t  POINTS_GRANT: \"points.grant\",\n15\t  CRATE_DROP: \"crate.drop\",\n16\t  CRATE_SOL_PAYOUT: \"crate.sol_payout\",\n17\t} as const;\n18\t\n19\texport type EventType = (typeof EventTypes)[keyof typeof EventTypes];\n20\t"}]},"parent_tool_use_id":"toolu_01RoQxTEdAdP9h7dahh799eR","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"f6928891-aa81-4df8-9819-047eea0d3740","timestamp":"2026-04-03T21:51:23.992Z"}
