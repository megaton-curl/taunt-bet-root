{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MqTj4dTNsBM45BpMJsdoj8","type":"tool_result","content":"450\t        serverKeypair,\n451\t      }),\n452\t    );\n453\t\n454\t    app.route(\"/rounds\", createRoundsRoutes({ db }));\n455\t  });\n456\t\n457\t  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n458\t    const wallet = creatorKeypair.publicKey.toBase58();\n459\t    const token = await makeJwt(wallet);\n460\t\n461\t    // ------------------------------------------------------------------\n462\t    // 1. POST /coinflip/create\n463\t    // ------------------------------------------------------------------\n464\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n465\t\n466\t    const createRes = await app.request(\"/coinflip/create\", {\n467\t      method: \"POST\",\n468\t      headers: {\n469\t        \"Content-Type\": \"application/json\",\n470\t        \"Authorization\": `Bearer ${token}`,\n471\t      },\n472\t      body: JSON.stringify(body),\n473\t    });\n474\t\n475\t    expect(createRes.status).toBe(200);\n476\t    const createJson = (await createRes.json()) as {\n477\t      transaction: string;\n478\t      matchPda: string;\n479\t      matchId: string;\n480\t      commitment: string;\n481\t      lastValidBlockHeight: number;\n482\t    };\n483\t    expect(createJson.transaction).toBeDefined();\n484\t    expect(createJson.matchPda).toBeDefined();\n485\t    expect(createJson.commitment).toBeDefined();\n486\t    expect(createJson.lastValidBlockHeight).toBeDefined();\n487\t\n488\t    const matchPda = createJson.matchPda;\n489\t    const commitmentHex = createJson.commitment;\n490\t    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n491\t\n492\t    // ------------------------------------------------------------------\n493\t    // 2. Verify DB state — round in \"created\" phase\n494\t    // ------------------------------------------------------------------\n495\t    const round = await db.getRoundByPda(matchPda);\n496\t    expect(round).toBeDefined();\n497\t    expect(round!.phase).toBe(\"created\");\n498\t    expect(round!.game).toBe(\"coinflip\");\n499\t    expect(round!.creator).toBe(wallet);\n500\t    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n501\t    expect(round!.side).toBe(SIDE_HEADS);\n502\t    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n503\t    expect(round!.secret).toBeDefined();\n504\t    expect(round!.secret.length).toBe(32);\n505\t\n506\t    // Verify operator event was logged\n507\t    const events =\n508\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n509\t    expect(events.length).toBe(1);\n510\t    expect(events[0]!.event_type).toBe(\"secret_generated\");\n511\t\n512\t    // ------------------------------------------------------------------\n513\t    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n514\t    // ------------------------------------------------------------------\n515\t    const matchPubkey = new PublicKey(matchPda);\n516\t    const targetSlot = 150n;\n517\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n518\t\n519\t    const matchAccountData = await buildMatchAccountData({\n520\t      creator: creatorKeypair.publicKey,\n521\t      opponent: opponentKeypair.publicKey,\n522\t      server: serverKeypair.publicKey,\n523\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n524\t      creatorSide: SIDE_HEADS,\n525\t      phase: PHASE_LOCKED,\n526\t      commitment: commitmentBuf,\n527\t      algorithmVer: 1,\n528\t      targetSlot,\n529\t      resolveDeadline,\n530\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n531\t    });\n532\t\n533\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n534\t      owner: COINFLIP_PROGRAM_ID,\n535\t    });\n536\t\n537\t    // Set current slot past target_slot so settlement triggers immediately\n538\t    mockConn.slot = 200;\n539\t\n540\t    // ------------------------------------------------------------------\n541\t    // 4. Create worker + retry settler, trigger poll\n542\t    // ------------------------------------------------------------------\n543\t    let settlePromise: Promise<void> | null = null;\n544\t\n545\t    const retrySettler = createRetrySettler({\n546\t      db,\n547\t      connection: mockConn as unknown as Connection,\n548\t      settleRound: (pda) =>\n549\t        settleMatch(\n550\t          {\n551\t            db,\n552\t            connection: mockConn as unknown as Connection,\n553\t            serverKeypair,\n554\t            entropyAccount,\n555\t            referralDefaultRateBps: 1000,\n556\t          },\n557\t          pda,\n558\t        ),\n559\t    });\n560\t\n561\t    const worker = createSettlementWorker({\n562\t      db,\n563\t      connection: mockConn as unknown as Connection,\n564\t      serverKey: serverKeypair.publicKey,\n565\t      pollIntervalMs: 60_000, // won't auto-poll\n566\t      onSettleReady: (pda) => {\n567\t        settlePromise = retrySettler.attemptSettle(pda);\n568\t        return settlePromise;\n569\t      },\n570\t    });\n571\t\n572\t    // Single poll cycle — should discover locked match and settle it\n573\t    await worker.poll();\n574\t    if (settlePromise) await settlePromise;\n575\t\n576\t    // ------------------------------------------------------------------\n577\t    // 5. Verify DB updated to \"settled\" with result data\n578\t    // ------------------------------------------------------------------\n579\t    const settled = await db.getRoundByPda(matchPda);\n580\t    expect(settled).toBeDefined();\n581\t    expect(settled!.phase).toBe(\"settled\");\n582\t    expect(settled!.settle_tx).toBeDefined();\n583\t    expect(settled!.result_hash).toBeDefined();\n584\t    expect(settled!.result_hash!.length).toBe(32);\n585\t    expect(settled!.result_side).toBeDefined();\n586\t    expect([0, 1]).toContain(settled!.result_side);\n587\t    expect(settled!.winner).toBeDefined();\n588\t\n589\t    // Winner should be one of the two players\n590\t    expect([\n591\t      creatorKeypair.publicKey.toBase58(),\n592\t      opponentKeypair.publicKey.toBase58(),\n593\t    ]).toContain(settled!.winner);\n594\t\n595\t    // Verify operator events trail\n596\t    const allEvents =\n597\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n598\t    const eventTypes = allEvents.map(\n599\t      (e) => (e as Record<string, unknown>).event_type,\n600\t    );\n601\t    expect(eventTypes).toContain(\"secret_generated\");\n602\t    expect(eventTypes).toContain(\"match_detected\");\n603\t    expect(eventTypes).toContain(\"settle_submitted\");\n604\t    expect(eventTypes).toContain(\"settle_confirmed\");\n605\t\n606\t    // ------------------------------------------------------------------\n607\t    // 6. GET /rounds/:pda — verify response includes secret\n608\t    // ------------------------------------------------------------------\n609\t    const roundsRes = await app.request(`/rounds/${matchPda}`);\n610\t    expect(roundsRes.status).toBe(200);\n611\t\n612\t    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n613\t    expect(roundsJson.pda).toBe(matchPda);\n614\t    expect(roundsJson.phase).toBe(\"settled\");\n615\t    expect(roundsJson.game).toBe(\"coinflip\");\n616\t    expect(roundsJson.creator).toBe(wallet);\n617\t    expect(roundsJson.commitment).toBe(commitmentHex);\n618\t\n619\t    // Settled round should include secret + verification payload\n620\t    expect(roundsJson.secret).toBeDefined();\n621\t    expect(typeof roundsJson.secret).toBe(\"string\");\n622\t    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n623\t    expect(roundsJson.resultHash).toBeDefined();\n624\t    expect(roundsJson.resultSide).toBeDefined();\n625\t    expect(roundsJson.winner).toBeDefined();\n626\t    expect(roundsJson.settleTx).toBeDefined();\n627\t\n628\t    // Verification object\n629\t    const verification = roundsJson.verification as Record<string, string>;\n630\t    expect(verification).toBeDefined();\n631\t    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n632\t    expect(verification.resultFormula).toContain(\"sha256(secret\");\n633\t    expect(verification.entropySource).toContain(\"SlotHashes\");\n634\t  });\n635\t\n636\t  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n637\t    const unknownPda = Keypair.generate().publicKey.toBase58();\n638\t    const res = await app.request(`/rounds/${unknownPda}`);\n639\t    expect(res.status).toBe(404);\n640\t  });\n641\t\n642\t  it(\"unsettled round does not expose secret\", async () => {\n643\t    const wallet = creatorKeypair.publicKey.toBase58();\n644\t    const token = await makeJwt(wallet);\n645\t\n646\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n647\t\n648\t    const res = await app.request(\"/coinflip/create\", {\n649\t      method: \"POST\","}]},"parent_tool_use_id":"toolu_013Cq4thG3nF9u3oQyBCmhx8","session_id":"66853f72-53c0-44d3-9075-63fb5cc11dbe","uuid":"a7e2698a-a5dc-4e6b-9502-493ca24544b3","timestamp":"2026-04-03T21:51:12.795Z"}
