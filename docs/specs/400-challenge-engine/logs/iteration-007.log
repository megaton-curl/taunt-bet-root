ng, OperatorEvent>>;\n363\t\n364\t  /** Get recently settled rounds for a game, ordered newest first. */\n365\t  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n366\t\n367\t  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n368\t  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n369\t\n370\t  // -------------------------------------------------------------------------\n371\t  // Close Call rounds\n372\t  // -------------------------------------------------------------------------\n373\t\n374\t  /** Insert a new Close Call round. */\n375\t  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n376\t\n377\t  /** Get a Close Call round by round_id (16-char hex). */\n378\t  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n379\t\n380\t  /** Get the current active (open) Close Call round. */\n381\t  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n382\t\n383\t  /** Get the most recent settled/refunded Close Call rounds. */\n384\t  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n385\t\n386\t  /** Update a Close Call round after settlement. */\n387\t  settleCloseCallRound(\n388\t    roundId: string,\n389\t    updates: {\n390\t      phase: CloseCallPhase;\n391\t      outcome: CloseCallOutcome;\n392\t      closePrice?: number;\n393\t      greenPool?: number;\n394\t      redPool?: number;\n395\t      totalFee?: number;\n396\t      settleTx?: string;\n397\t    },\n398\t  ): Promise<CloseCallRound>;\n399\t\n400\t  // -------------------------------------------------------------------------\n401\t  // Transactions\n402\t  // -------------------------------------------------------------------------\n403\t\n404\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n405\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n406\t\n407\t  /** Insert multiple transactions in a single batc