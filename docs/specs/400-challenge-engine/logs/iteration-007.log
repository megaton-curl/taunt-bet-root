{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ag3pzA8wM2hEFypRgKRbjn","type":"tool_result","content":"1\t/**\n2\t * POINTS_GRANT handler — awards points to a player.\n3\t *\n4\t * For wager-based grants: converts lamports → USD → points using config rate\n5\t * and applies any active Dogpile multiplier.\n6\t * For pre-calculated grants (crate_points, challenge_completed, bonus_completed):\n7\t * uses the `amount` field directly.\n8\t *\n9\t * Idempotent via UNIQUE(user_id, source_type, source_id) on point_grants.\n10\t */\n11\t\n12\timport type { Db } from \"../../db.js\";\n13\timport { logger } from \"../../logger.js\";\n14\timport { readRewardConfig } from \"./reward-pool-fund.js\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// DB helpers\n18\t// ---------------------------------------------------------------------------\n19\t\n20\t/**\n21\t * Insert a point grant ledger row. Returns false if a row for this\n22\t * (user_id, source_type, source_id) already exists (idempotency guard).\n23\t */\n24\texport async function insertPointGrant(\n25\t  db: Db,\n26\t  userId: string,\n27\t  wallet: string,\n28\t  sourceType: string,\n29\t  sourceId: string,\n30\t  amount: bigint,\n31\t  metadata: Record<string, unknown>,\n32\t): Promise<boolean> {\n33\t  const rows = await db.rawSql<{ id: string }[]>`\n34\t    INSERT INTO point_grants (user_id, wallet, source_type, source_id, amount, metadata)\n35\t    VALUES (${userId}, ${wallet}, ${sourceType}, ${sourceId}, ${amount}, ${JSON.stringify(metadata)})\n36\t    ON CONFLICT (user_id, source_type, source_id) DO NOTHING\n37\t    RETURNING id\n38\t  `;\n39\t  return rows.length > 0;\n40\t}\n41\t\n42\t/**\n43\t * Create or increment player_points. Uses upsert pattern so the first\n44\t * grant for a user creates the row.\n45\t */\n46\texport async function upsertPlayerPoints(\n47\t  db: Db,\n48\t  userId: string,\n49\t  wallet: string,\n50\t  amount: bigint,\n51\t): Promise<void> {\n52\t  await db.rawSql`\n53\t    INSERT INTO player_points (user_id, wallet, balance, lifetime_earned, updated_at)\n54\t    VALUES (${userId}, ${wallet}, ${amount}, ${amount}, now())\n55\t    ON CONFLICT (user_id) DO UPDATE SET\n56\t      balance         = player_points.balance + ${amount},\n57\t      lifetime_earned = player_points.lifetime_earned + ${amount},\n58\t      updated_at      = now()\n59\t  `;\n60\t}\n61\t\n62\t/**\n63\t * Returns the multiplier for the currently active Dogpile event, or 1 if\n64\t * none is active.\n65\t */\n66\texport async function getActiveDogpileMultiplier(\n67\t  db: Db,\n68\t  timestamp: Date,\n69\t): Promise<number> {\n70\t  const rows = await db.rawSql<{ multiplier: string }[]>`\n71\t    SELECT multiplier FROM dogpile_events\n72\t    WHERE status = 'active'\n73\t      AND ${timestamp} BETWEEN starts_at AND ends_at\n74\t    LIMIT 1\n75\t  `;\n76\t  return rows.length > 0 ? parseFloat(rows[0]!.multiplier) : 1;\n77\t}\n78\t\n79\t// ---------------------------------------------------------------------------\n80\t// Handler factory\n81\t// ---------------------------------------------------------------------------\n82\t\n83\texport interface PointsGrantDeps {\n84\t  db: Db;\n85\t  /** Returns current SOL/USD price, or null if unavailable. */\n86\t  getSolPrice: () => Promise<number | null>;\n87\t}\n88\t\n89\texport function createPointsGrantHandler(deps: PointsGrantDeps) {\n90\t  const { db, getSolPrice } = deps;\n91\t\n92\t  return async (payload: Record<string, unknown>): Promise<void> => {\n93\t    const userId = payload.userId as string;\n94\t    const wallet = payload.wallet as string;\n95\t    const sourceType = payload.sourceType as string;\n96\t    const sourceId = payload.sourceId as string;\n97\t\n98\t    if (!userId || !wallet || !sourceType || !sourceId) {\n99\t      throw new Error(\n100\t        \"points.grant: malformed payload — missing userId, wallet, sourceType, or sourceId\",\n101\t      );\n102\t    }\n103\t\n104\t    let pointsAmount: bigint;\n105\t    const metadata: Record<string, unknown> = (payload.metadata as Record<string, unknown>) ?? {};\n106\t\n107\t    if (sourceType === \"wager\") {\n108\t      // Wager-based: calculate from lamports → USD → points\n109\t      const amountLamportsStr = payload.amountLamports as string;\n110\t      if (!amountLamportsStr) {\n111\t        throw new Error(\"points.grant: wager grant missing amountLamports\");\n112\t      }\n113\t\n114\t      const pointsPerDollarStr = await readRewardConfig(db, \"points_per_dollar\");\n115\t      if (!pointsPerDollarStr) {\n116\t        logger.warn(\"points.grant: points_per_dollar not configured, skipping\", { userId, sourceId });\n117\t        return;\n118\t      }\n119\t      const pointsPerDollar = parseFloat(pointsPerDollarStr);\n120\t\n121\t      const solPrice = await getSolPrice();\n122\t      if (solPrice === null || solPrice <= 0) {\n123\t        logger.warn(\"points.grant: SOL/USD price unavailable, skipping\", { userId, sourceId });\n124\t        return;\n125\t      }\n126\t\n127\t      const amountLamports = Number(amountLamportsStr);\n128\t      const wagerSol = amountLamports / 1e9;\n129\t      const wagerUsd = wagerSol * solPrice;\n130\t\n131\t      // Check for active Dogpile multiplier\n132\t      const settledAt = payload.settledAt\n133\t        ? new Date(payload.settledAt as string)\n134\t        : new Date();\n135\t      const multiplier = await getActiveDogpileMultiplier(db, settledAt);\n136\t\n137\t      pointsAmount = BigInt(Math.floor(wagerUsd * pointsPerDollar * multiplier));\n138\t\n139\t      metadata.solPrice = solPrice;\n140\t      metadata.wagerUsd = wagerUsd;\n141\t      metadata.pointsPerDollar = pointsPerDollar;\n142\t      metadata.multiplier = multiplier;\n143\t    } else {\n144\t      // Pre-calculated: crate_points, challenge_completed, bonus_completed\n145\t      const amount = payload.amount as string | number;\n146\t      if (amount === undefined || amount === null) {\n147\t        throw new Error(\"points.grant: non-wager grant missing amount\");\n148\t      }\n149\t      pointsAmount = BigInt(amount);\n150\t    }\n151\t\n152\t    if (pointsAmount <= 0n) {\n153\t      logger.debug(\"points.grant: calculated amount is zero, skipping\", { userId, sourceId, sourceType });\n154\t      return;\n155\t    }\n156\t\n157\t    // Run within a transaction for atomicity\n158\t    await db.withTransaction(async (txDb) => {\n159\t      // Insert ledger row (idempotency guard)\n160\t      const inserted = await insertPointGrant(\n161\t        txDb, userId, wallet, sourceType, sourceId, pointsAmount, metadata,\n162\t      );\n163\t      if (!inserted) {\n164\t        logger.info(\"points.grant: duplicate grant, skipping\", { userId, sourceType, sourceId });\n165\t        return;\n166\t      }\n167\t\n168\t      // Upsert player_points\n169\t      await upsertPlayerPoints(txDb, userId, wallet, pointsAmount);\n170\t\n171\t      logger.info(\"points.grant: points awarded\", {\n172\t        userId,\n173\t        sourceType,\n174\t        sourceId,\n175\t        amount: pointsAmount.toString(),\n176\t      });\n177\t    });\n178\t  };\n179\t}\n180\t"}]},"parent_tool_use_id":"toolu_0175Ae251JxZGR2wkN3wnxJN","session_id":"76dd357f-8d88-4f6f-a9bf-260ee83a7c97","uuid":"8ff1a04c-5605-4a9e-8ffa-61c04a3a185b","timestamp":"2026-04-03T20:01:47.485Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015S13nw83e2hMPmkw7RTRuc","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createInternalRoutes } from \"./routes/internal.js\";\n21\timport { swaggerUI } from \"@hono/swagger-ui\";\n22\timport { spec } from \"./openapi.js\";\n23\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n24\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n25\timport { createSettlementWorker } from \"./worker/settlement.js\";\n26\timport { settleRound } from \"./worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"./worker/retry.js\";\n28\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n29\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n30\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n31\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n32\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n33\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n34\timport { fetchSolPrice } from \"./routes/price.js\";\n35\timport { logger } from \"./logger.js\";\n36\t\n37\tconst config = loadConfig();\n38\t\n39\t// Single postgres pool shared by game DB, auth DB, and all workers\n40\tconst sql = postgres(config.databaseUrl);\n41\tconst db = createDb(config.databaseUrl, sql);\n42\tconst authDb = createAuthDb(sql);\n43\t\n44\tconst connection = new Connection(config.rpcUrl, {\n45\t  commitment: \"confirmed\",\n46\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n47\t});\n48\t\n49\tconst app = new Hono();\n50\t\n51\tapp.use(\n52\t  \"*\",\n53\t  cors({\n54\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n55\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n56\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n57\t  }),\n58\t);\n59\t\n60\t// Request logging — correlate frontend fetch timing with server-side processing\n61\tapp.use(\"*\", async (c, next) => {\n62\t  const start = Date.now();\n63\t  await next();\n64\t  const ms = Date.now() - start;\n65\t  const method = c.req.method;\n66\t  const path = c.req.path;\n67\t  // Skip noisy health checks and OPTIONS preflight\n68\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n69\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n70\t});\n71\t\n72\t// API docs — Swagger UI + raw OpenAPI spec\n73\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n74\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n75\t\n76\t// Auth routes — no JWT middleware (these are the login endpoints)\n77\t// Lighter rate limiting by IP for auth endpoints\n78\tapp.use(\n79\t  \"/auth/*\",\n80\t  createRateLimitMiddleware({\n81\t    perWallet: 20,\n82\t    global: config.rateLimitGlobal,\n83\t    windowMs: 60_000,\n84\t  }),\n85\t);\n86\t\n87\tapp.route(\n88\t  \"/auth\",\n89\t  createAuthRoutes({\n90\t    authDb,\n91\t    db,\n92\t    jwtSecret: config.jwtSecret,\n93\t    cluster: config.cluster,\n94\t    challengeTtlSeconds: config.challengeTtlSeconds,\n95\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n96\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n97\t  }),\n98\t);\n99\t\n100\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n101\tapp.use(\n102\t  \"/profile/*\",\n103\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n104\t);\n105\tapp.route(\"/profile\", createProfileRoutes({ db }));\n106\t\n107\t// Public profile routes — no auth required\n108\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n109\t\n110\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n111\tapp.use(\n112\t  \"/referral/*\",\n113\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n114\t);\n115\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n116\t\n117\t// JWT auth middleware for game endpoints\n118\tapp.use(\n119\t  \"/coinflip/*\",\n120\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n121\t);\n122\tapp.use(\n123\t  \"/lord/*\",\n124\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n125\t);\n126\t\n127\t// Rate limiting — per-wallet and global limits on POST requests\n128\tapp.use(\n129\t  \"/coinflip/*\",\n130\t  createRateLimitMiddleware({\n131\t    perWallet: config.rateLimitPerWallet,\n132\t    global: config.rateLimitGlobal,\n133\t    windowMs: 60_000,\n134\t  }),\n135\t);\n136\tapp.use(\n137\t  \"/lord/*\",\n138\t  createRateLimitMiddleware({\n139\t    perWallet: config.rateLimitPerWallet,\n140\t    global: config.rateLimitGlobal,\n141\t    windowMs: 60_000,\n142\t  }),\n143\t);\n144\t\n145\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n146\tconst entropyAccount = new PublicKey(config.entropyAccount);\n147\tconst retrySettler = createRetrySettler({\n148\t  db,\n149\t  connection,\n150\t  settleRound: (pda) =>\n151\t    settleRound(\n152\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n153\t      pda,\n154\t    ),\n155\t});\n156\t\n157\t// PDA watcher — WebSocket-based instant join detection\n158\tconst pdaWatcher = createPdaWatcher({\n159\t  connection,\n160\t  serverKey: config.serverKeypair.publicKey,\n161\t  db,\n162\t  onJoinDetected: async (pda, targetSlot) => {\n163\t    // Update DB phase if still in 'created'\n164\t    const round = await db.getRoundByPda(pda);\n165\t    if (round && round.phase === \"created\") {\n166\t      await db.updateRoundPhase(pda, \"locked\", {\n167\t        target_slot: targetSlot.toString(),\n168\t      });\n169\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n170\t        targetSlot: targetSlot.toString(),\n171\t        source: \"pda-watcher\",\n172\t        game: round.game,\n173\t      });\n174\t    }\n175\t\n176\t    // Check if target slot already passed — settle immediately if so\n177\t    const currentSlot = await connection.getSlot();\n178\t    if (BigInt(currentSlot) >= targetSlot) {\n179\t      await retrySettler.attemptSettle(pda);\n180\t      pdaWatcher.unwatch(pda);\n181\t    }\n182\t    // If target slot not reached yet, poll worker will pick it up next cycle\n183\t  },\n184\t});\n185\t\n186\tconst worker = createSettlementWorker({\n187\t  db,\n188\t  connection,\n189\t  serverKey: config.serverKeypair.publicKey,\n190\t  pollIntervalMs: config.workerPollIntervalMs,\n191\t  onSettleReady: async (pda) => {\n192\t    await retrySettler.attemptSettle(pda);\n193\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n194\t  },\n195\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n196\t});\n197\tworker.start();\n198\t\n199\t// Close Call clock worker — fetches boundary prices + settles open rounds\n200\t// Rounds are created on-demand by players via /closecall/bet\n201\tconst closeCallClock = createCloseCallClockWorker({\n202\t  connection,\n203\t  serverKeypair: config.serverKeypair,\n204\t  db,\n205\t});\n206\tcloseCallClock.start();\n207\t\n208\t// Register event handlers before starting the worker\n209\tregisterHandler(\n210\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n211\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n212\t);\n213\tregisterHandler(\n214\t  EventTypes.REWARD_POOL_FUND,\n215\t  createRewardPoolFundHandler({ db }),\n216\t);\n217\tregisterHandler(\n218\t  EventTypes.POINTS_GRANT,\n219\t  createPointsGrantHandler({\n220\t    db,\n221\t    getSolPrice: async () => {\n222\t      const result = await fetchSolPrice();\n223\t      return result?.price ?? null;\n224\t    },\n225\t  }),\n226\t);\n227\t\n228\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n229\tconst eventWorker = createEventWorker(sql, {\n230\t  pollIntervalMs: config.eventQueuePollMs,\n231\t});\n232\teventWorker.start();\n233\tlogger.info(\"Event queue worker started\", {\n234\t  pollIntervalMs: config.eventQueuePollMs,\n235\t});\n236\t\n237\t// Game-specific routes\n238\tapp.route(\n239\t  \"/coinflip\",\n240\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n241\t);\n242\tapp.route(\n243\t  \"/lord\",\n244\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n245\t);\n246\t\n247\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n248\tapp.use(\n249\t  \"/closecall/bet\",\n250\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n251\t);\n252\tapp.use(\n253\t  \"/closecall/bet\",\n254\t  createRateLimitMiddleware({\n255\t    perWallet: config.rateLimitPerWallet,\n256\t    global: config.rateLimitGlobal,\n257\t    windowMs: 60_000,\n258\t  }),\n259\t);\n260\t\n261\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n262\tapp.route(\"/closecall\", createCloseCallRoutes({\n263\t  db,\n264\t  connection,\n265\t  serverKeypair: config.serverKeypair,\n266\t  clockWorker: closeCallClock,\n267\t}));\n268\t\n269\t// Leaderboard routes — public, no auth\n270\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n271\t\n272\t// Price routes — public, no auth\n273\tapp.route(\"/price\", createPriceRoutes());\n274\t\n275\t// Round verification routes\n276\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n277\t\n278\t// Health endpoint — wired after worker exists so we can query its status\n279\tapp.route(\n280\t  \"/health\",\n281\t  createHealthRoutes({\n282\t    db,\n283\t    sql,\n284\t    isWorkerRunning: () => worker.isRunning,\n285\t  }),\n286\t);\n287\t\n288\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n289\tif (config.adminToken) {\n290\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n291\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n292\t}\n293\t\n294\tconst port = config.port;\n295\tlogger.info(\"fairness-backend started\", { port });\n296\t\n297\tserve({\n298\t  fetch: app.fetch,\n299\t  port,\n300\t  hostname: \"0.0.0.0\",\n301\t});\n302\t\n303\texport default {\n304\t  port,\n305\t  fetch: app.fetch,\n306\t};\n307\t"}]},"parent_tool_use_id":"toolu_0175Ae251JxZGR2wkN3wnxJN","session_id":"76dd357f-8d88-4f6f-a9bf-260ee83a7c97","uuid":"61f63316-b0c9-4812-899a-ca41b336d325","timestamp":"2026-04-03T20:01:47.481Z"}
