{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HHvCj5eigPodR5hfBeUdu4","type":"tool_result","content":"0\t/**\n1\t * Integration test: full create → join → settle lifecycle.\n2\t *\n3\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n4\t * the real HTTP endpoints, database, settlement worker, and retry logic\n5\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n6\t */\n7\t\n8\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n9\timport { Hono } from \"hono\";\n10\timport {\n11\t  Keypair,\n12\t  PublicKey,\n13\t  SystemProgram,\n14\t  LAMPORTS_PER_SOL,\n15\t} from \"@solana/web3.js\";\n16\timport type { Connection } from \"@solana/web3.js\";\n17\timport bs58 from \"bs58\";\n18\timport { SignJWT } from \"jose\";\n19\timport postgres from \"postgres\";\n20\timport { createDb, type Db } from \"../db.js\";\n21\timport { createCoinflipRoutes } from \"../routes/create.js\";\n22\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n23\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n24\timport { createSettlementWorker } from \"../worker/settlement.js\";\n25\timport { settleMatch } from \"../worker/settle-tx.js\";\n26\timport { createRetrySettler } from \"../worker/retry.js\";\n27\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n28\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n29\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n30\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n31\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n32\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n33\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n34\timport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\n35\t\n36\t// ---------------------------------------------------------------------------\n37\t// Constants\n38\t// ---------------------------------------------------------------------------\n39\t\n40\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n41\t\n42\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n43\tfunction makeSql() {\n44\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n45\t  // Dev container: postgres listens on Unix socket only\n46\t  return postgres({\n47\t    host: \"/var/run/postgresql\",\n48\t    user: \"vscode\",\n49\t    database: \"rng_utopia_dev\","}]},"parent_tool_use_id":null,"session_id":"76dd357f-8d88-4f6f-a9bf-260ee83a7c97","uuid":"644ab0e7-bb6e-403f-ab5b-0ddfe5bb0adc","timestamp":"2026-04-03T20:04:16.481Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"/**\n * Integration test: full create → join → settle lifecycle.\n *\n * Uses a mock Solana Connection to simulate on-chain state while exercising\n * the real HTTP endpoints, database, settlement worker, and retry logic\n * end-to-end. Auth uses JWT Bearer tokens (HS256).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\