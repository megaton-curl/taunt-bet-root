{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QvUAM6mPQnutLcu3muuHfn","type":"tool_result","content":"1\t/**\n2\t * POINTS_GRANT handler — awards points to a player.\n3\t *\n4\t * For wager-based grants: converts lamports → USD → points using config rate\n5\t * and applies any active Dogpile multiplier.\n6\t * For pre-calculated grants (crate_points, challenge_completed, bonus_completed):\n7\t * uses the `amount` field directly.\n8\t *\n9\t * Idempotent via UNIQUE(user_id, source_type, source_id) on point_grants.\n10\t */\n11\t\n12\timport type { Db } from \"../../db.js\";\n13\timport { logger } from \"../../logger.js\";\n14\timport { readRewardConfig } from \"./reward-pool-fund.js\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// DB helpers\n18\t// ---------------------------------------------------------------------------\n19\t\n20\t/**\n21\t * Insert a point grant ledger row. Returns false if a row for this\n22\t * (user_id, source_type, source_id) already exists (idempotency guard).\n23\t */\n24\texport async function insertPointGrant(\n25\t  db: Db,\n26\t  userId: string,\n27\t  wallet: string,\n28\t  sourceType: string,\n29\t  sourceId: string,\n30\t  amount: bigint,\n31\t  metadata: Record<string, unknown>,\n32\t): Promise<boolean> {\n33\t  const rows = await db.rawSql<{ id: string }[]>`\n34\t    INSERT INTO point_grants (user_id, wallet, source_type, source_id, amount, metadata)\n35\t    VALUES (${userId}, ${wallet}, ${sourceType}, ${sourceId}, ${amount}, ${JSON.stringify(metadata)})\n36\t    ON CONFLICT (user_id, source_type, source_id) DO NOTHING\n37\t    RETURNING id\n38\t  `;\n39\t  return rows.length > 0;\n40\t}\n41\t\n42\t/**\n43\t * Create or increment player_points. Uses upsert pattern so the first\n44\t * grant for a user creates the row.\n45\t */\n46\texport async function upsertPlayerPoints(\n47\t  db: Db,\n48\t  userId: string,\n49\t  wallet: string,\n50\t  amount: bigint,\n51\t): Promise<void> {\n52\t  await db.rawSql`\n53\t    INSERT INTO player_points (user_id, wallet, balance, lifetime_earned, updated_at)\n54\t    VALUES (${userId}, ${wallet}, ${amount}, ${amount}, now())\n55\t    ON CONFLICT (user_id) DO UPDATE SET\n56\t      balance         = player_points.balance + ${amount},\n57\t      lifetime_earned = player_points.lifetime_earned + ${amount},\n58\t      updated_at      = now()\n59\t  `;\n60\t}\n61\t\n62\t/**\n63\t * Returns the multiplier for the currently active Dogpile event, or 1 if\n64\t * none is active.\n65\t */\n66\texport async function getActiveDogpileMultiplier(\n67\t  db: Db,\n68\t  timestamp: Date,\n69\t): Promise<number> {\n70\t  const rows = await db.rawSql<{ multiplier: string }[]>`\n71\t    SELECT multiplier FROM dogpile_events\n72\t    WHERE status = 'active'\n73\t      AND ${timestamp} BETWEEN starts_at AND ends_at\n74\t    LIMIT 1\n75\t  `;\n76\t  return rows.length > 0 ? parseFloat(rows[0]!.multiplier) : 1;\n77\t}\n78\t\n79\t// ---------------------------------------------------------------------------\n80\t// Handler factory\n81\t// ---------------------------------------------------------------------------\n82\t\n83\texport interface PointsGrantDeps {\n84\t  db: Db;\n85\t  /** Returns current SOL/USD price, or null if unavailable. */\n86\t  getSolPrice: () => Promise<number | null>;\n87\t}\n88\t\n89\texport function createPointsGrantHandler(deps: PointsGrantDeps) {\n90\t  const { db, getSolPrice } = deps;\n91\t\n92\t  return async (payload: Record<string, unknown>): Promise<void> => {\n93\t    const userId = payload.userId as string;\n94\t    const wallet = payload.wallet as string;\n95\t    const sourceType = payload.sourceType as string;\n96\t    const sourceId = payload.sourceId as string;\n97\t\n98\t    if (!userId || !wallet || !sourceType || !sourceId) {\n99\t      throw new Error(\n100\t        \"points.grant: malformed payload — missing userId, wallet, sourceType, or sourceId\",\n101\t      );\n102\t    }\n103\t\n104\t    let pointsAmount: bigint;\n105\t    const metadata: Record<string, unknown> = (payload.metadata as Record<string, unknown>) ?? {};\n106\t\n107\t    if (sourceType === \"wager\") {\n108\t      // Wager-based: calculate from lamports → USD → points\n109\t      const amountLamportsStr = payload.amountLamports as string;\n110\t      if (!amountLamportsStr) {\n111\t        throw new Error(\"points.grant: wager grant missing amountLamports\");\n112\t      }\n113\t\n114\t      const pointsPerDollarStr = await readRewardConfig(db, \"points_per_dollar\");\n115\t      if (!pointsPerDollarStr) {\n116\t        logger.warn(\"points.grant: points_per_dollar not configured, skipping\", { userId, sourceId });\n117\t        return;\n118\t      }\n119\t      const pointsPerDollar = parseFloat(pointsPerDollarStr);\n120\t\n121\t      const solPrice = await getSolPrice();\n122\t      if (solPrice === null || solPrice <= 0) {\n123\t        logger.warn(\"points.grant: SOL/USD price unavailable, skipping\", { userId, sourceId });\n124\t        return;\n125\t      }\n126\t\n127\t      const amountLamports = Number(amountLamportsStr);\n128\t      const wagerSol = amountLamports / 1e9;\n129\t      const wagerUsd = wagerSol * solPrice;\n130\t\n131\t      // Check for active Dogpile multiplier\n132\t      const settledAt = payload.settledAt\n133\t        ? new Date(payload.settledAt as string)\n134\t        : new Date();\n135\t      const multiplier = await getActiveDogpileMultiplier(db, settledAt);\n136\t\n137\t      pointsAmount = BigInt(Math.floor(wagerUsd * pointsPerDollar * multiplier));\n138\t\n139\t      metadata.solPrice = solPrice;\n140\t      metadata.wagerUsd = wagerUsd;\n141\t      metadata.pointsPerDollar = pointsPerDollar;\n142\t      metadata.multiplier = multiplier;\n143\t    } else {\n144\t      // Pre-calculated: crate_points, challenge_completed, bonus_completed\n145\t      const amount = payload.amount as string | number;\n146\t      if (amount === undefined || amount === null) {\n147\t        throw new Error(\"points.grant: non-wager grant missing amount\");\n148\t      }\n149\t      pointsAmount = BigInt(amount);\n150\t    }\n151\t\n152\t    if (pointsAmount <= 0n) {\n153\t      logger.debug(\"points.grant: calculated amount is zero, skipping\", { userId, sourceId, sourceType });\n154\t      return;\n155\t    }\n156\t\n157\t    // Run within a transaction for atomicity\n158\t    await db.withTransaction(async (txDb) => {\n159\t      // Insert ledger row (idempotency guard)\n160\t      const inserted = await insertPointGrant(\n161\t        txDb, userId, wallet, sourceType, sourceId, pointsAmount, metadata,\n162\t      );\n163\t      if (!inserted) {\n164\t        logger.info(\"points.grant: duplicate grant, skipping\", { userId, sourceType, sourceId });\n165\t        return;\n166\t      }\n167\t\n168\t      // Upsert player_points\n169\t      await upsertPlayerPoints(txDb, userId, wallet, pointsAmount);\n170\t\n171\t      logger.info(\"points.grant: points awarded\", {\n172\t        userId,\n173\t        sourceType,\n174\t        sourceId,\n175\t        amount: pointsAmount.toString(),\n176\t      });\n177\t    });\n178\t  };\n179\t}\n180\t"}]},"parent_tool_use_id":null,"session_id":"76dd357f-8d88-4f6f-a9bf-260ee83a7c97","uuid":"51dbf7c1-682f-4892-90f0-da3313ace567","timestamp":"2026-04-03T20:04:06.715Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/points-grant.ts","content":"/**\n * POINTS_GRANT handler — awards points to a player.\n *\n * For wager-based grants: converts lamports → USD → points using config rate\n * and applies any active Dogpile multiplier.\n * For pre-calculated grants (crate_points, challenge_completed, bonus_completed):\n * uses the `amount` field directly.\n *\n * Idempotent via UNIQUE(user_id, source_type, source_id) on point_grants.\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\nimport { readRewardConfig } from \"./reward-pool-fund.js\";\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/**\n * Insert a point grant ledger row. Returns false if a row for this\n * (user_id, source_type, source_id) already exists (idempotency guard).\n */\nexport async function insertPointGrant(\n  db: Db,\n  userId: string,\n  wallet: string,\n  sourceType: string,\n  sourceId: string,\n  amount: bigint,\n  metadata: Record<string, unknown>,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO point_grants (user_id, wallet, source_type, source_id, amount, metadata)\n    VALUES (${userId}, ${wallet}, ${sourceType}, ${sourceId}, ${amount}, ${JSON.stringify(metadata)})\n    ON CONFLICT (user_id, source_type, source_id) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n/**\n * Create or increment player_points. Uses upsert pattern so the first\n * grant for a user creates the row.\n */\nexport async function upsertPlayerPoints(\n  db: Db,\n  userId: string,\n  wallet: string,\n  amount: bigint,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO player_points (user_id, wallet, balance, lifetime_earned, updated_at)\n    VALUES (${userId}, ${wallet}, ${amount}, ${amount}, now())\n    ON CONFLICT (user_id) DO UPDATE SET\n      balance         = player_points.balance + ${amount},\n      lifetime_earned = player_points.lifetime_earned + ${amount},\n      updated_at      = now()\n  `;\n}\n\n/**\n * Returns the multiplier for the currently active Dogpile event, or 1 if\n * none is active.\n */\nexport async function getActiveDogpileMultiplier(\n  db: Db,\n  timestamp: Date,\n): Promise<number> {\n  const rows = await db.rawSql<{ multiplier: string }[]>`\n    SELECT multiplier FROM dogpile_events\n    WHERE status = 'active'\n      AND ${timestamp} BETWEEN starts_at AND ends_at\n    LIMIT 1\n  `;\n  return rows.length > 0 ? parseFloat(rows[0]!.multiplier) : 1;\n}\n\n// ---------------------------------------------------------------------------\n// Handler factory\n// ---------------------------------------------------------------------------\n\nexport interface PointsGrantDeps {\n  db: Db;\n  /** Returns current SOL/USD price, or null if unavailable. */\n  getSolPrice: () => Promise<number | null>;\n}\n\nexport function createPointsGrantHandler(deps: PointsGrantDeps) {\n  const { db, getSolPrice } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const userId = payload.userId as string;\n    const wallet = payload.wallet as string;\n    const sourceType = payload.sourceType as string;\n    const sourceId = payload.sourceId as string;\n\n    if (!userId || !wallet || !sourceType || !sourceId) {\n      throw new Error(\n        \"points.grant: malformed payload — missing userId, wallet, sourceType, or sourceId\",\n      );\n    }\n\n    let pointsAmount: bigint;\n    const metadata: Record<string, unknown> = (payload.metadata as Record<string, unknown>) ?? {};\n\n    if (sourceType === \"wager\") {\n      // Wager-based: calculate from lamports → USD → points\n      const amountLamportsStr = payload.amountLamports as string;\n      if (!amountLamportsStr) {\n        throw new Error(\"points.grant: wager grant missing amountLamports\");\n      }\n\n      const pointsPerDollarStr = await readRewardConfig(db, \"points_per_dollar\");\n      if (!pointsPerDollarStr) {\n        logger.warn(\"points.grant: points_per_dollar not configured, skipping\", { userId, sourceId });\n        return;\n      }\n      const pointsPerDollar = parseFloat(pointsPerDollarStr);\n\n      const solPrice = await getSolPrice();\n      if (solPrice === null || solPrice <= 0) {\n        logger.warn(\"points.grant: SOL/USD price unavailable, skipping\", { userId, sourceId });\n        return;\n      }\n\n      const amountLamports = Number(amountLamportsStr);\n      const wagerSol = amountLamports / 1e9;\n      const wagerUsd = wagerSol * solPrice;\n\n      // Check for active Dogpile multiplier\n      const settledAt = payload.settledAt\n        ? new Date(payload.settledAt as string)\n        : new Date();\n      const multiplier = await getActiveDogpileMultiplier(db, settledAt);\n\n      pointsAmount = BigInt(Math.floor(wagerUsd * pointsPerDollar * multiplier));\n\n      metadata.solPrice = solPrice;\n      metadata.wagerUsd = wagerUsd;\n      metadata.pointsPerDollar = pointsPerDollar;\n      metadata.multiplier = multiplier;\n    } else {\n      // Pre-calculated: crate_points, challenge_completed, bonus_completed\n      const amount = payload.amount as string | number;\n      if (amount === undefined || amount === null) {\n        throw new Error(\"points.grant: non-wager grant missing amount\");\n      }\n      pointsAmount = BigInt(amount);\n    }\n\n    if (pointsAmount <= 0n) {\n      logger.debug(\"points.grant: calculated amount is zero, skipping\", { userId, sourceId, sourceType });\n      return;\n    }\n\n    // Run within a transaction for atomicity\n    await db.withTransaction(async (txDb) => {\n      // Insert ledger row (idempotency guard)\n      const inserted = await insertPointGrant(\n        txDb, userId, wallet, sourceType, sourceId, pointsAmount, metadata,\n      );\n      if (!inserted) {\n        logger.info(\"points.grant: duplicate grant, skipping\", { userId, sourceType, sourceId });\n        return;\n      }\n\n      // Upsert player_points\n      await upsertPlayerPoints(txDb, userId, wallet, pointsAmount);\n\n      logger.info(\"points.grant: points awarded\", {\n        userId,\n        sourceType,\n        sourceId,\n        amount: pointsAmount.toString(),\n      });\n    });\n  };\n}\n","numLines":180,"startLine":1,"totalLines":180}}}
