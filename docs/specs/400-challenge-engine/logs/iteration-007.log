{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017yEEpVp1RFJxYKPdFU7S6d","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n31\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n32\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n33\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n34\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n35\timport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\n36\t\n37\t// ---------------------------------------------------------------------------\n38\t// Constants\n39\t// ---------------------------------------------------------------------------\n40\t\n41\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n42\t\n43\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n44\tfunction makeSql() {\n45\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n46\t  // Dev container: postgres listens on Unix socket only\n47\t  return postgres({\n48\t    host: \"/var/run/postgresql\",\n49\t    user: \"vscode\",\n50\t    database: \"rng_utopia_dev\",\n51\t  });\n52\t}\n53\t\n54\tconst AMOUNT_LAMPORTS = 5_000_000;\n55\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n56\tconst SIDE_HEADS = 0;\n57\tconst PHASE_LOCKED = 1;\n58\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n59\t\n60\t// ---------------------------------------------------------------------------\n61\t// JWT helper\n62\t// ---------------------------------------------------------------------------\n63\t\n64\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n65\t  const now = Math.floor(Date.now() / 1000);\n66\t  return new SignJWT({ wallet })\n67\t    .setProtectedHeader({ alg: \"HS256\" })\n68\t    .setSubject(userId)\n69\t    .setIssuedAt(now)\n70\t    .setExpirationTime(now + 3600)\n71\t    .sign(JWT_SECRET);\n72\t}\n73\t\n74\tfunction userIdFromWallet(wallet: string) {\n75\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n76\t}\n77\t\n78\t// ---------------------------------------------------------------------------\n79\t// Mock Connection\n80\t// ---------------------------------------------------------------------------\n81\t\n82\t/**\n83\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n84\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n85\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n86\t */\n87\tclass MockConnection {\n88\t  private _slot = 200;\n89\t  private _accounts = new Map<\n90\t    string,\n91\t    {\n92\t      data: Buffer;\n93\t      lamports: number;\n94\t      owner: PublicKey;\n95\t      executable: boolean;\n96\t    }\n97\t  >();\n98\t  lastRawTx: Buffer | null = null;\n99\t\n100\t  set slot(s: number) {\n101\t    this._slot = s;\n102\t  }\n103\t  get slot() {\n104\t    return this._slot;\n105\t  }\n106\t\n107\t  setAccount(\n108\t    pubkey: PublicKey,\n109\t    data: Buffer,\n110\t    opts?: { lamports?: number; owner?: PublicKey },\n111\t  ) {\n112\t    this._accounts.set(pubkey.toBase58(), {\n113\t      data,\n114\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n115\t      owner: opts?.owner ?? SystemProgram.programId,\n116\t      executable: false,\n117\t    });\n118\t  }\n119\t\n120\t  removeAccount(pubkey: PublicKey) {\n121\t    this._accounts.delete(pubkey.toBase58());\n122\t  }\n123\t\n124\t  async getLatestBlockhash() {\n125\t    return {\n126\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n127\t      lastValidBlockHeight: 999_999,\n128\t    };\n129\t  }\n130\t\n131\t  async getSlot() {\n132\t    return this._slot;\n133\t  }\n134\t\n135\t  async getAccountInfo(pubkey: PublicKey) {\n136\t    const acc = this._accounts.get(pubkey.toBase58());\n137\t    if (!acc) return null;\n138\t    return { ...acc, rentEpoch: 0 };\n139\t  }\n140\t\n141\t  async getProgramAccounts(\n142\t    programId: PublicKey,\n143\t    config?: {\n144\t      filters?: Array<\n145\t        | { dataSize: number }\n146\t        | { memcmp: { offset: number; bytes: string } }\n147\t      >;\n148\t    },\n149\t  ) {\n150\t    const results: Array<{"}]},"parent_tool_use_id":"toolu_01BwR7XYw5CndL7VcjkBTHPz","session_id":"76dd357f-8d88-4f6f-a9bf-260ee83a7c97","uuid":"cd3af745-422c-49c9-8295-822b494a3648","timestamp":"2026-04-03T20:01:54.944Z"}
