{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Erk8JC8Vac2DKKeqnKgxAY","type":"tool_result","content":"1\t-- 009_event_queue.sql — Postgres-backed async event queue.\n2\t--\n3\t-- Decouples settlement hot path from secondary side-effects (reward delivery,\n4\t-- notifications, analytics). Worker polls with SKIP LOCKED for safe concurrency.\n5\t\n6\tCREATE TABLE event_queue (\n7\t  id            BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n8\t  event_type    TEXT         NOT NULL,\n9\t  payload       JSONB        NOT NULL,\n10\t  status        TEXT         NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead')),\n11\t  attempts      INTEGER      NOT NULL DEFAULT 0,\n12\t  max_attempts  INTEGER      NOT NULL DEFAULT 3,\n13\t  scheduled_at  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n14\t  started_at    TIMESTAMPTZ,\n15\t  completed_at  TIMESTAMPTZ,\n16\t  error         TEXT,\n17\t  created_at    TIMESTAMPTZ  NOT NULL DEFAULT now()\n18\t);\n19\t\n20\tCREATE INDEX idx_event_queue_poll ON event_queue (scheduled_at) WHERE status = 'pending';\n21\tCREATE INDEX idx_event_queue_status ON event_queue (status, created_at);\n22\t"}]},"parent_tool_use_id":"toolu_01BwR7XYw5CndL7VcjkBTHPz","session_id":"76dd357f-8d88-4f6f-a9bf-260ee83a7c97","uuid":"24a7578f-d391-44d4-a8e4-db7f89ce02e9","timestamp":"2026-04-03T20:02:20.520Z"}
