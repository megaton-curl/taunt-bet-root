18\t    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n719\t  };\n720\t}\n721\t\n722\tfunction normalizePlayerProfile(row: PlayerProfile): PlayerProfile {\n723\t  return {\n724\t    ...row,\n725\t    id: Number(row.id),\n726\t    heat_multiplier: Number(row.heat_multiplier),\n727\t    points_balance: Number(row.points_balance),\n728\t  };\n729\t}\n730\t\n731\tfunction normalizeRound(row: Round): Round {\n732\t  return {\n733\t    ...row,\n734\t    amount_lamports: Number(row.amount_lamports),\n735\t    side: Number(row.side),\n736\t    settle_attempts: Number(row.settle_attempts),\n737\t    result_side: row.result_side === null ? null : Number(row.result_side),\n738\t    // Entries come from JOIN on game_entries, already parsed\n739\t    entries: Array.isArray(row.entries)\n740\t      ? row.entries.map((e) => ({\n741\t          player: e.player,\n742\t          amountLamports: Number(e.amountLamports),\n743\t        }))\n744\t      : null,\n745\t  };\n746\t}\n747\t\n748\tfunction normalizeGameEntry(row: Record<string, unknown>): GameEntry {\n749\t  return {\n750\t    id: Number(row.id),\n751\t    userId: row.user_id as string,\n752\t    wallet: row.wallet as string,\n753\t    game: row.game as string,\n754\t    roundPda: row.round_pda as string,\n755\t    matchId: row.match_id as string,\n756\t    amountLamports: Number(row.amount_lamports),\n757\t    side: (row.side as string) ?? null,\n758\t    isWinner: row.is_winner === null ? null : Boolean(row.is_winner),\n759\t    payoutLamports: Number(row.payout_lamports ?? 0),\n760\t    createdAt: row.created_at as Date,\n761\t    settledAt: (row.settled_at as Date) ?? null,\n762\t  };\n763\t}\n764\t\n765\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n766\texport function createDb(databaseUrl: string, _txSql?: any): Db {\n767\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n768\t  const sql: any = _txSql ?? postgres(databaseUrl);\n769\t  const _isOwner = !_txSql;\n770\t\n