{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q7qjMjSd79nDcwefMHu3Vb","type":"tool_result","content":"1\t/**\n2\t * Database client module — typed query functions for `rounds` and `operator_events`.\n3\t *\n4\t * Phase transitions are unidirectional: created → locked → settling → settled,\n5\t * or created → expired. The application layer rejects backward transitions.\n6\t */\n7\t\n8\timport postgres from \"postgres\";\n9\timport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n10\t\n11\t// ---------------------------------------------------------------------------\n12\t// Types\n13\t// ---------------------------------------------------------------------------\n14\t\n15\texport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n16\t\n17\texport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n18\texport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n19\t\n20\texport interface CloseCallRound {\n21\t  round_id: string;\n22\t  pda: string;\n23\t  server_key: string;\n24\t  phase: CloseCallPhase;\n25\t  open_price: number;\n26\t  open_price_expo: number;\n27\t  close_price: number | null;\n28\t  outcome: CloseCallOutcome;\n29\t  green_pool: number;\n30\t  red_pool: number;\n31\t  total_fee: number;\n32\t  green_entries: Array<{ player: string; amountLamports: number }>; // populated via JOIN on game_entries\n33\t  red_entries: Array<{ player: string; amountLamports: number }>;   // populated via JOIN on game_entries\n34\t  settle_tx: string | null;\n35\t  created_at: Date;\n36\t  settled_at: Date | null;\n37\t}\n38\t\n39\texport interface InsertCloseCallRoundParams {\n40\t  roundId: string;\n41\t  pda: string;\n42\t  serverKey: string;\n43\t  openPrice: number;\n44\t  openPriceExpo: number;\n45\t}\n46\t\n47\texport type OperatorEventType =\n48\t  | \"secret_generated\"\n49\t  | \"tx_built\"\n50\t  | \"match_detected\"\n51\t  | \"settle_submitted\"\n52\t  | \"settle_confirmed\"\n53\t  | \"settle_failed\"\n54\t  | \"settle_retried\"\n55\t  | \"timeout_detected\";\n56\t\n57\texport interface Round {\n58\t  pda: string;\n59\t  game: string;\n60\t  creator: string;\n61\t  server_key: string;\n62\t  secret: Buffer;\n63\t  commitment: Buffer;\n64\t  amount_lamports: number;\n65\t  side: number;\n66\t  match_id: string;\n67\t  phase: RoundPhase;\n68\t  target_slot: string | null;\n69\t  settle_tx: string | null;\n70\t  settle_attempts: number;\n71\t  result_hash: Buffer | null;\n72\t  result_side: number | null;\n73\t  winner: string | null;\n74\t  entries: Array<{ player: string; amountLamports: number }> | null; // populated via JOIN on game_entries\n75\t  created_at: Date;\n76\t  updated_at: Date;\n77\t  settled_at: Date | null;\n78\t}\n79\t\n80\texport interface InsertRoundParams {\n81\t  pda: string;\n82\t  game: string;\n83\t  creator: string;\n84\t  serverKey: string;\n85\t  secret: Buffer;\n86\t  commitment: Buffer;\n87\t  amountLamports: number;\n88\t  side: number;\n89\t  matchId: string;\n90\t  phase: RoundPhase;\n91\t}\n92\t\n93\texport interface OperatorEvent {\n94\t  id: string;\n95\t  pda: string | null;\n96\t  event_type: OperatorEventType;\n97\t  payload: unknown;\n98\t  created_at: Date;\n99\t}\n100\t\n101\t// ---------------------------------------------------------------------------\n102\t// Transaction types\n103\t// ---------------------------------------------------------------------------\n104\t\n105\texport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n106\t\n107\texport interface Transaction {\n108\t  id: string;\n109\t  wallet: string;\n110\t  game: string;\n111\t  match_id: string;\n112\t  tx_type: TransactionType;\n113\t  amount_lamports: number;\n114\t  tx_sig: string;\n115\t  created_at: Date;\n116\t}\n117\t\n118\texport interface InsertTransactionParams {\n119\t  userId?: string;\n120\t  wallet: string;\n121\t  game: string;\n122\t  matchId: string;\n123\t  txType: TransactionType;\n124\t  amountLamports: number;\n125\t  txSig: string;\n126\t}\n127\t\n128\t// ---------------------------------------------------------------------------\n129\t// Referral types\n130\t// ---------------------------------------------------------------------------\n131\t\n132\texport interface ReferralCode {\n133\t  id: number;\n134\t  user_id: string;\n135\t  wallet: string;\n136\t  code: string;\n137\t  created_at: Date;\n138\t  updated_at: Date;\n139\t}\n140\t\n141\texport interface ReferralLink {\n142\t  id: number;\n143\t  referrer_user_id: string;\n144\t  referee_user_id: string;\n145\t  referrer_wallet: string;\n146\t  referee_wallet: string;\n147\t  created_at: Date;\n148\t}\n149\t\n150\texport interface ReferralEarning {"}]},"parent_tool_use_id":"toolu_01BwR7XYw5CndL7VcjkBTHPz","session_id":"76dd357f-8d88-4f6f-a9bf-260ee83a7c97","uuid":"e0bcc4e9-e4ba-4fbb-976d-7ebdcf9f43b1","timestamp":"2026-04-03T20:01:54.552Z"}
