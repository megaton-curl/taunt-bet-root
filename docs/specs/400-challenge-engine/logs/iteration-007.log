{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T52rqFkxmVE68UiqBgbymQ","type":"tool_result","content":"1290\t    `;\n1291\t    expect(poolBefore.length).toBe(1);\n1292\t    expect(BigInt(poolBefore[0]!.balance_lamports)).toBe(0n);\n1293\t    expect(BigInt(poolBefore[0]!.lifetime_funded)).toBe(0n);\n1294\t\n1295\t    // Create handler and call it directly\n1296\t    const handler = createRewardPoolFundHandler({ db });\n1297\t\n1298\t    const feeLamports = \"500000\"; // 500_000 lamports fee\n1299\t    const roundId = \"test-round-pool-fund-001\";\n1300\t\n1301\t    await handler({\n1302\t      roundId,\n1303\t      feeLamports,\n1304\t    });\n1305\t\n1306\t    // Expected funded = floor(500_000 * 0.20) = 100_000\n1307\t    const expectedFunded = 100_000n;\n1308\t\n1309\t    // Verify reward_pool_fundings row\n1310\t    const fundings = await rawSql<{\n1311\t      round_id: string;\n1312\t      fee_lamports: string;\n1313\t      funded_lamports: string;\n1314\t    }[]>`\n1315\t      SELECT round_id, fee_lamports, funded_lamports FROM reward_pool_fundings WHERE round_id = ${roundId}\n1316\t    `;\n1317\t    expect(fundings.length).toBe(1);\n1318\t    expect(fundings[0]!.round_id).toBe(roundId);\n1319\t    expect(BigInt(fundings[0]!.fee_lamports)).toBe(500_000n);\n1320\t    expect(BigInt(fundings[0]!.funded_lamports)).toBe(expectedFunded);\n1321\t\n1322\t    // Verify pool balance incremented\n1323\t    const poolAfter = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1324\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1325\t    `;\n1326\t    expect(BigInt(poolAfter[0]!.balance_lamports)).toBe(expectedFunded);\n1327\t    expect(BigInt(poolAfter[0]!.lifetime_funded)).toBe(expectedFunded);\n1328\t\n1329\t    // --- Idempotency: re-emit same round_id ---\n1330\t    await handler({\n1331\t      roundId,\n1332\t      feeLamports,\n1333\t    });\n1334\t\n1335\t    // Verify no duplicate fund