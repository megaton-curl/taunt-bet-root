{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N3duJGjbGvaCtzYoRmXEpe","type":"tool_result","content":"150\t    const results: Array<{\n151\t      pubkey: PublicKey;\n152\t      account: {\n153\t        data: Buffer;\n154\t        lamports: number;\n155\t        owner: PublicKey;\n156\t        executable: boolean;\n157\t        rentEpoch: number;\n158\t      };\n159\t    }> = [];\n160\t\n161\t    for (const [key, acc] of this._accounts) {\n162\t      if (!acc.owner.equals(programId)) continue;\n163\t\n164\t      let matches = true;\n165\t      if (config?.filters) {\n166\t        for (const filter of config.filters) {\n167\t          if (\"dataSize\" in filter) {\n168\t            if (acc.data.length !== filter.dataSize) {\n169\t              matches = false;\n170\t              break;\n171\t            }\n172\t          }\n173\t          if (\"memcmp\" in filter) {\n174\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n175\t            const actual = acc.data.subarray(\n176\t              filter.memcmp.offset,\n177\t              filter.memcmp.offset + expected.length,\n178\t            );\n179\t            if (Buffer.compare(actual, expected) !== 0) {\n180\t              matches = false;\n181\t              break;\n182\t            }\n183\t          }\n184\t        }\n185\t      }\n186\t\n187\t      if (matches) {\n188\t        results.push({\n189\t          pubkey: new PublicKey(key),\n190\t          account: { ...acc, rentEpoch: 0 },\n191\t        });\n192\t      }\n193\t    }\n194\t    return results;\n195\t  }\n196\t\n197\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n198\t    this.lastRawTx = Buffer.from(rawTx);\n199\t    // Return a deterministic fake signature\n200\t    return bs58.encode(Buffer.alloc(64, 0x01));\n201\t  }\n202\t\n203\t  async confirmTransaction() {\n204\t    return { value: { err: null }, context: { slot: this._slot } };\n205\t  }\n206\t\n207\t  async getBlockTime(_slot: number) {\n208\t    return Math.floor(Date.now() / 1000);\n209\t  }\n210\t\n211\t  async getBalance() {\n212\t    return 2 * LAMPORTS_PER_SOL;\n213\t  }\n214\t}\n215\t\n216\t// ---------------------------------------------------------------------------\n217\t// Account data builders\n218\t// ---------------------------------------------------------------------------\n219\t\n220\tasync function buildMatchAccountData(params: {\n221\t  creator: PublicKey;\n222\t  opponent: PublicKey;\n223\t  server: PublicKey;\n224\t  entryAmount: bigint;\n225\t  creatorSide: number;\n226\t  phase: number;\n227\t  commitment: Buffer;\n228\t  algorithmVer: number;\n229\t  targetSlot: bigint;\n230\t  resolveDeadline: bigint;\n231\t  matchId: Buffer;\n232\t}): Promise<Buffer> {\n233\t  return encodeCoinflipMatch({\n234\t    creator: params.creator,\n235\t    opponent: params.opponent,\n236\t    server: params.server,\n237\t    entryAmount: params.entryAmount,\n238\t    creatorSide: params.creatorSide,\n239\t    phase: params.phase,\n240\t    commitment: [...params.commitment],\n241\t    algorithmVer: params.algorithmVer,\n242\t    targetSlot: params.targetSlot,\n243\t    resolveDeadline: params.resolveDeadline,\n244\t    resultHash: new Array(32).fill(0),\n245\t    result: 0,\n246\t    winner: PublicKey.default,\n247\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n248\t    matchId: [...params.matchId],\n249\t    bump: 0,\n250\t  });\n251\t}\n252\t\n253\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n254\t  return encodeCoinflipConfig({\n255\t    authority: PublicKey.default,\n256\t    treasury,\n257\t    paused: false,\n258\t    bump: 0,\n259\t  });\n260\t}\n261\t\n262\t/**\n263\t * Build PlatformConfig account data matching the on-chain layout.\n264\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n265\t */\n266\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n267\t  const buf = Buffer.alloc(74);\n268\t  // discriminator (8 bytes) — zeroed is fine for mock\n269\t  // authority at offset 8 — use default\n270\t  PublicKey.default.toBuffer().copy(buf, 8);\n271\t  // treasury at offset 40\n272\t  treasury.toBuffer().copy(buf, 40);\n273\t  // fee_bps at offset 72\n274\t  buf.writeUInt16LE(feeBps, 72);\n275\t  return buf;\n276\t}\n277\t\n278\t// ---------------------------------------------------------------------------\n279\t// Test suite\n280\t// ---------------------------------------------------------------------------\n281\t\n282\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n283\t  let db: Db;\n284\t  let rawSql: ReturnType<typeof postgres>;\n285\t  let mockConn: MockConnection;\n286\t  let app: Hono;\n287\t\n288\t  const serverKeypair = Keypair.generate();\n289\t  const creatorKeypair = Keypair.generate();\n290\t  const opponentKeypair = Keypair.generate();\n291\t  const treasuryKeypair = Keypair.generate();\n292\t  const entropyKeypair = Keypair.generate();\n293\t  const entropyAccount = entropyKeypair.publicKey;\n294\t\n295\t  const entropyData = Buffer.alloc(32);\n296\t  entropyData[0] = 0xab;\n297\t  entropyData[1] = 0xcd;\n298\t  entropyData[15] = 0x42;\n299\t\n300\t  beforeAll(async () => {\n301\t    rawSql = makeSql();\n302\t    await rawSql`\n303\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n304\t    `;\n305\t    await rawSql`\n306\t      CREATE TABLE referral_codes (\n307\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n308\t        user_id TEXT NOT NULL UNIQUE,\n309\t        wallet TEXT NOT NULL UNIQUE,\n310\t        code TEXT NOT NULL UNIQUE,\n311\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n312\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n313\t      )\n314\t    `;\n315\t    await rawSql`\n316\t      CREATE TABLE referral_links (\n317\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n318\t        referrer_user_id TEXT NOT NULL,\n319\t        referee_user_id TEXT NOT NULL UNIQUE,\n320\t        referrer_wallet TEXT NOT NULL,\n321\t        referee_wallet TEXT NOT NULL,\n322\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n323\t      )\n324\t    `;\n325\t    await rawSql`\n326\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n327\t    `;\n328\t    await rawSql`\n329\t      CREATE TABLE referral_earnings (\n330\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n331\t        referrer_user_id TEXT NOT NULL,\n332\t        referee_user_id TEXT NOT NULL,\n333\t        referrer_wallet TEXT NOT NULL,\n334\t        referee_wallet TEXT NOT NULL,\n335\t        round_id TEXT NOT NULL,\n336\t        game_type TEXT NOT NULL,\n337\t        wager_lamports BIGINT NOT NULL,\n338\t        fee_lamports BIGINT NOT NULL,\n339\t        referrer_earned_lamports BIGINT NOT NULL,\n340\t        referrer_rate_bps INTEGER NOT NULL,\n341\t        referee_rebate_lamports BIGINT NOT NULL,\n342\t        referee_rebate_rate_bps INTEGER NOT NULL,\n343\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n344\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n345\t      )\n346\t    `;\n347\t    await rawSql`\n348\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n349\t    `;"}]},"parent_tool_use_id":"toolu_01BwR7XYw5CndL7VcjkBTHPz","session_id":"76dd357f-8d88-4f6f-a9bf-260ee83a7c97","uuid":"a50e4d91-52ed-4bf9-ae42-3c73396f2c8b","timestamp":"2026-04-03T20:01:58.192Z"}
