{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S8SMMtkwXnj6BXbdSLVcGH","type":"tool_result","content":"1300\t    const roundId = \"test-round-pool-fund-001\";\n1301\t\n1302\t    await handler({\n1303\t      roundId,\n1304\t      feeLamports,\n1305\t    });\n1306\t\n1307\t    // Expected funded = floor(500_000 * 0.20) = 100_000\n1308\t    const expectedFunded = 100_000n;\n1309\t\n1310\t    // Verify reward_pool_fundings row\n1311\t    const fundings = await rawSql<{\n1312\t      round_id: string;\n1313\t      fee_lamports: string;\n1314\t      funded_lamports: string;\n1315\t    }[]>`\n1316\t      SELECT round_id, fee_lamports, funded_lamports FROM reward_pool_fundings WHERE round_id = ${roundId}\n1317\t    `;\n1318\t    expect(fundings.length).toBe(1);\n1319\t    expect(fundings[0]!.round_id).toBe(roundId);\n1320\t    expect(BigInt(fundings[0]!.fee_lamports)).toBe(500_000n);\n1321\t    expect(BigInt(fundings[0]!.funded_lamports)).toBe(expectedFunded);\n1322\t\n1323\t    // Verify pool balance incremented\n1324\t    const poolAfter = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1325\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1326\t    `;\n1327\t    expect(BigInt(poolAfter[0]!.balance_lamports)).toBe(expectedFunded);\n1328\t    expect(BigInt(poolAfter[0]!.lifetime_funded)).toBe(expectedFunded);\n1329\t\n1330\t    // --- Idempotency: re-emit same round_id ---\n1331\t    await handler({\n1332\t      roundId,\n1333\t      feeLamports,\n1334\t    });\n1335\t\n1336\t    // Verify no duplicate funding row\n1337\t    const fundingsAfterDupe = await rawSql<{ id: string }[]>`\n1338\t      SELECT id FROM reward_pool_fundings WHERE round_id = ${roundId}\n1339\t    `;\n1340\t    expect(fundingsAfterDupe.length).toBe(1);\n1341\t\n1342\t    // Verify pool balance unchanged\n1343\t    const poolAfterDupe = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1344\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1345\t    `;\n1346\t    expect(BigInt(poolAfterDupe[0]!.balance_lamports)).toBe(expectedFunded);\n1347\t    expect(BigInt(poolAfterDupe[0]!.lifetime_funded)).toBe(expectedFunded);\n1348\t  });\n1349\t\n1350\t  // ---------------------------------------------------------------------------\n1351\t  // POINTS_GRANT handler\n1352\t  // ---------------------------------------------------------------------------\n1353\t\n1354\t  it(\"points.grant handler: awards wager-based points and dedupes\", async () => {\n1355\t    // Ensure reward_config has points_per_dollar\n1356\t    const configRows = await rawSql<{ value: string }[]>`\n1357\t      SELECT value FROM reward_config WHERE key = 'points_per_dollar'\n1358\t    `;\n1359\t    if (configRows.length === 0) {\n1360\t      await rawSql`INSERT INTO reward_config (key, value) VALUES ('points_per_dollar', '500')`;\n1361\t    }\n1362\t\n1363\t    // Mock SOL/USD price at $100\n1364\t    const mockSolPrice = 100;\n1365\t    const handler = createPointsGrantHandler({\n1366\t      db,\n1367\t      getSolPrice: async () => mockSolPrice,\n1368\t    });\n1369\t\n1370\t    const userId = \"usr_pointstest1\";\n1371\t    const wallet = \"PointsTestWallet1111111111111111111111111\";\n1372\t    const sourceId = \"test-round-points-001\";\n1373\t    const amountLamports = \"50000000\"; // 0.05 SOL\n1374\t\n1375\t    await handler({\n1376\t      userId,\n1377\t      wallet,\n1378\t      sourceType: \"wager\",\n1379\t      sourceId,\n1380\t      amountLamports,\n1381\t      settledAt: new Date().toISOString(),\n1382\t    });\n1383\t\n1384\t    // Expected: 0.05 SOL * $100 = $5.00 * 500 points/dollar = 2500 points\n1385\t    const expectedPoints = 2500n;\n1386\t\n1387\t    // Verify point_grants row\n1388\t    const grants = await rawSql<{\n1389\t      user_id: string;\n1390\t      wallet: string;\n1391\t      source_type: string;\n1392\t      source_id: string;\n1393\t      amount: string;\n1394\t      metadata: string;\n1395\t    }[]>`\n1396\t      SELECT user_id, wallet, source_type, source_id, amount, metadata\n1397\t      FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n1398\t    `;\n1399\t    expect(grants.length).toBe(1);\n1400\t    expect(grants[0]!.source_type).toBe(\"wager\");\n1401\t    expect(BigInt(grants[0]!.amount)).toBe(expectedPoints);\n1402\t    const meta = typeof grants[0]!.metadata === \"string\"\n1403\t      ? JSON.parse(grants[0]!.metadata) : grants[0]!.metadata;\n1404\t    expect(meta).toMatchObject({\n1405\t      solPrice: mockSolPrice,\n1406\t      pointsPerDollar: 500,\n1407\t      multiplier: 1,\n1408\t    });\n1409\t\n1410\t    // Verify player_points upserted\n1411\t    const pp = await rawSql<{ balance: string; lifetime_earned: string }[]>`\n1412\t      SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n1413\t    `;\n1414\t    expect(pp.length).toBe(1);\n1415\t    expect(BigInt(pp[0]!.balance)).toBe(expectedPoints);\n1416\t    expect(BigInt(pp[0]!.lifetime_earned)).toBe(expectedPoints);\n1417\t\n1418\t    // --- Idempotency: re-emit same grant ---\n1419\t    await handler({\n1420\t      userId,\n1421\t      wallet,\n1422\t      sourceType: \"wager\",\n1423\t      sourceId,\n1424\t      amountLamports,\n1425\t      settledAt: new Date().toISOString(),\n1426\t    });\n1427\t\n1428\t    // Verify no duplicate grant row\n1429\t    const grantsAfterDupe = await rawSql<{ id: string }[]>`\n1430\t      SELECT id FROM point_grants WHERE user_id = ${userId} AND source_type = 'wager' AND source_id = ${sourceId}\n1431\t    `;\n1432\t    expect(grantsAfterDupe.length).toBe(1);\n1433\t\n1434\t    // Verify balance unchanged\n1435\t    const ppAfterDupe = await rawSql<{ balance: string }[]>`\n1436\t      SELECT balance FROM player_points WHERE user_id = ${userId}\n1437\t    `;\n1438\t    expect(BigInt(ppAfterDupe[0]!.balance)).toBe(expectedPoints);\n1439\t  });\n1440\t\n1441\t  it(\"points.grant handler: applies Dogpile 2x multiplier when active\", async () => {\n1442\t    // Ensure points_per_dollar config\n1443\t    const configRows = await rawSql<{ value: string }[]>`\n1444\t      SELECT value FROM reward_config WHERE key = 'points_per_dollar'\n1445\t    `;\n1446\t    if (configRows.length === 0) {\n1447\t      await rawSql`INSERT INTO reward_config (key, value) VALUES ('points_per_dollar', '500')`;\n1448\t    }\n1449\t"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"503e0fd1-41f2-4d54-934b-f3f04a05fb73","timestamp":"2026-04-03T20:11:43.689Z"}
