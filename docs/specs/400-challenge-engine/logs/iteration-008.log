};\n746\t}\n747\t\n748\tfunction normalizeGameEntry(row: Record<string, unknown>): GameEntry {\n749\t  return {"}]},"parent_tool_use_id":"toolu_01BjFVkGqa3nnge3wfvNTvkn","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"b7218d79-d6bd-4ccf-bdfe-364b7a102cf0","timestamp":"2026-04-03T20:11:49.854Z"}
