{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JNmEGs76v64mgjhTx3QBqc","type":"tool_result","content":"100\t\n101\t  set slot(s: number) {\n102\t    this._slot = s;\n103\t  }\n104\t  get slot() {\n105\t    return this._slot;\n106\t  }\n107\t\n108\t  setAccount(\n109\t    pubkey: PublicKey,\n110\t    data: Buffer,\n111\t    opts?: { lamports?: number; owner?: PublicKey },\n112\t  ) {\n113\t    this._accounts.set(pubkey.toBase58(), {\n114\t      data,\n115\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n116\t      owner: opts?.owner ?? SystemProgram.programId,\n117\t      executable: false,\n118\t    });\n119\t  }\n120\t\n121\t  removeAccount(pubkey: PublicKey) {\n122\t    this._accounts.delete(pubkey.toBase58());\n123\t  }\n124\t\n125\t  async getLatestBlockhash() {\n126\t    return {\n127\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n128\t      lastValidBlockHeight: 999_999,\n129\t    };\n130\t  }\n131\t\n132\t  async getSlot() {\n133\t    return this._slot;\n134\t  }\n135\t\n136\t  async getAccountInfo(pubkey: PublicKey) {\n137\t    const acc = this._accounts.get(pubkey.toBase58());\n138\t    if (!acc) return null;\n139\t    return { ...acc, rentEpoch: 0 };\n140\t  }\n141\t\n142\t  async getProgramAccounts(\n143\t    programId: PublicKey,\n144\t    config?: {\n145\t      filters?: Array<\n146\t        | { dataSize: number }\n147\t        | { memcmp: { offset: number; bytes: string } }\n148\t      >;\n149\t    },\n150\t  ) {\n151\t    const results: Array<{\n152\t      pubkey: PublicKey;\n153\t      account: {\n154\t        data: Buffer;\n155\t        lamports: number;\n156\t        owner: PublicKey;\n157\t        executable: boolean;\n158\t        rentEpoch: number;\n159\t      };\n160\t    }> = [];\n161\t\n162\t    for (const [key, acc] of this._accounts) {\n163\t      if (!acc.owner.equals(programId)) continue;\n164\t\n165\t      let matches = true;\n166\t      if (config?.filters) {\n167\t        for (const filter of config.filters) {\n168\t          if (\"dataSize\" in filter) {\n169\t            if (acc.data.length !== filter.dataSize) {\n170\t              matches = false;\n171\t              break;\n172\t            }\n173\t          }\n174\t          if (\"memcmp\" in filter) {\n175\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n176\t            const actual = acc.data.subarray(\n177\t              filter.memcmp.offset,\n178\t              filter.memcmp.offset + expected.length,\n179\t            );\n180\t            if (Buffer.compare(actual, expected) !== 0) {\n181\t              matches = false;\n182\t              break;\n183\t            }\n184\t          }\n185\t        }\n186\t      }\n187\t\n188\t      if (matches) {\n189\t        results.push({\n190\t          pubkey: new PublicKey(key),\n191\t          account: { ...acc, rentEpoch: 0 },\n192\t        });\n193\t      }\n194\t    }\n195\t    return results;\n196\t  }\n197\t\n198\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n199\t    this.lastRawTx = Buffer.from(rawTx);\n200\t    // Return a deterministic fake signature\n201\t    return bs58.encode(Buffer.alloc(64, 0x01));\n202\t  }\n203\t\n204\t  async confirmTransaction() {\n205\t    return { value: { err: null }, context: { slot: this._slot } };\n206\t  }\n207\t\n208\t  async getBlockTime(_slot: number) {\n209\t    return Math.floor(Date.now() / 1000);\n210\t  }\n211\t\n212\t  async getBalance() {\n213\t    return 2 * LAMPORTS_PER_SOL;\n214\t  }\n215\t}\n216\t\n217\t// ---------------------------------------------------------------------------\n218\t// Account data builders\n219\t// ---------------------------------------------------------------------------\n220\t\n221\tasync function buildMatchAccountData(params: {\n222\t  creator: PublicKey;\n223\t  opponent: PublicKey;\n224\t  server: PublicKey;\n225\t  entryAmount: bigint;\n226\t  creatorSide: number;\n227\t  phase: number;\n228\t  commitment: Buffer;\n229\t  algorithmVer: number;\n230\t  targetSlot: bigint;\n231\t  resolveDeadline: bigint;\n232\t  matchId: Buffer;\n233\t}): Promise<Buffer> {\n234\t  return encodeCoinflipMatch({\n235\t    creator: params.creator,\n236\t    opponent: params.opponent,\n237\t    server: params.server,\n238\t    entryAmount: params.entryAmount,\n239\t    creatorSide: params.creatorSide,\n240\t    phase: params.phase,\n241\t    commitment: [...params.commitment],\n242\t    algorithmVer: params.algorithmVer,\n243\t    targetSlot: params.targetSlot,\n244\t    resolveDeadline: params.resolveDeadline,\n245\t    resultHash: new Array(32).fill(0),\n246\t    result: 0,\n247\t    winner: PublicKey.default,\n248\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n249\t    matchId: [...params.matchId],"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"c79833a9-0df9-4c3d-a3a8-510134c7a3b5","timestamp":"2026-04-03T20:11:37.432Z"}
