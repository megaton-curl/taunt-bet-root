{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KQ7V5cb7yjRwgcSSBdSRRm","type":"tool_result","content":"1650\t    const userId = \"usr_cratemiss1\";\n1651\t    const wallet = \"CrateMissWallet1111111111111111111111111\";\n1652\t    const triggerId = \"test-round-crate-miss-001\";\n1653\t\n1654\t    await handler({\n1655\t      userId,\n1656\t      wallet,\n1657\t      triggerType: \"game_settled\",\n1658\t      triggerId,\n1659\t    });\n1660\t\n1661\t    // Verify no crate_drops row\n1662\t    const crates = await rawSql<{ id: string }[]>`\n1663\t      SELECT id FROM crate_drops WHERE user_id = ${userId}\n1664\t    `;\n1665\t    expect(crates.length).toBe(0);\n1666\t\n1667\t    // Verify no events emitted\n1668\t    const events = await rawSql<{ id: string }[]>`\n1669\t      SELECT id FROM event_queue WHERE event_type IN ('crate.sol_payout', 'points.grant')\n1670\t    `;\n1671\t    expect(events.length).toBe(0);\n1672\t  });\n1673\t\n1674\t  it(\"crate.drop handler: SOL crate suppressed when pool below min_value\", async () => {\n1675\t    // Pool balance too low: 50_000_000 * 0.10 = 5_000_000 < 10_000_000 min\n1676\t    await rawSql`UPDATE reward_pool SET balance_lamports = 50000000, lifetime_funded = 50000000 WHERE id = 1`;\n1677\t\n1678\t    // Roll = 0.005 → would be SOL crate, but pool can't fund it\n1679\t    const handler = createCrateDropHandler({\n1680\t      db,\n1681\t      rollRng: () => 0.005,\n1682\t    });\n1683\t\n1684\t    const userId = \"usr_cratesuppress1\";\n1685\t    const wallet = \"CrateSuppressWallet11111111111111111111\";\n1686\t    const triggerId = \"test-round-crate-suppress-001\";\n1687\t\n1688\t    await handler({\n1689\t      userId,\n1690\t      wallet,\n1691\t      triggerType: \"game_settled\",\n1692\t      triggerId,\n1693\t    });\n1694\t\n1695\t    // Verify no crate_drops row (suppressed, not even recorded)\n1696\t    const crates = await rawSql<{ id: string }[]>`\n1697\t      SELECT id FROM crate_drops WHERE user_id = ${userId}\n1698\t    `;\n1699\t    expect(crates.length).toBe(0);\n1700\t\n1701\t    // Verify pool balance unchanged\n1702\t    const pool = await rawSql<{ balance_lamports: string }[]>`\n1703\t      SELECT balance_lamports FROM reward_pool WHERE id = 1\n1704\t    `;\n1705\t    expect(BigInt(pool[0]!.balance_lamports)).toBe(50_000_000n);\n1706\t  });\n1707\t\n1708\t  it(\"crate.drop handler: idempotent — duplicate trigger skips\", async () => {\n1709\t    // Fund pool for SOL crate\n1710\t    await rawSql`UPDATE reward_pool SET balance_lamports = 200000000, lifetime_funded = 200000000 WHERE id = 1`;\n1711\t\n1712\t    const handler = createCrateDropHandler({\n1713\t      db,\n1714\t      rollRng: () => 0.005, // SOL crate hit\n1715\t    });\n1716\t\n1717\t    const userId = \"usr_cratededup1\";\n1718\t    const wallet = \"CrateDedupWallet1111111111111111111111\";\n1719\t    const triggerId = \"test-round-crate-dedup-001\";\n1720\t\n1721\t    // First call\n1722\t    await handler({\n1723\t      userId,\n1724\t      wallet,\n1725\t      triggerType: \"game_settled\",\n1726\t      triggerId,\n1727\t    });\n1728\t\n1729\t    const poolAfterFirst = await rawSql<{ balance_lamports: string }[]>`\n1730\t      SELECT balance_lamports FROM reward_pool WHERE id = 1\n1731\t    `;\n1732\t    const balanceAfterFirst = BigInt(poolAfterFirst[0]!.balance_lamports);\n1733\t\n1734\t    // Second call with same trigger — should be idempotent\n1735\t    await handler({\n1736\t      userId,\n1737\t      wallet,\n1738\t      triggerType: \"game_settled\",\n1739\t      triggerId,\n1740\t    });\n1741\t\n1742\t    // Verify still only one crate row\n1743\t    const crates = await rawSql<{ id: string }[]>`\n1744\t      SELECT id FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1745\t    `;\n1746\t    expect(crates.length).toBe(1);\n1747\t\n1748\t    // Verify pool not decremented again\n1749\t    const poolAfterSecond = await rawSql<{ balance_lamports: string }[]>`\n1750\t      SELECT balance_lamports FROM reward_pool WHERE id = 1\n1751\t    `;\n1752\t    expect(BigInt(poolAfterSecond[0]!.balance_lamports)).toBe(balanceAfterFirst);\n1753\t  });\n1754\t});\n1755\t"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"6b497312-1e40-4152-acc2-b4a03ee7b3cb","timestamp":"2026-04-03T20:11:46.005Z"}
