{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Xe9D6iY8d7DnksSm9YyJx","type":"tool_result","content":"800\t    },\n801\t\n802\t    async updateRoundPhase(pda, newPhase, updates) {\n803\t      // Fetch current phase to validate transition\n804\t      const current = await sql<Pick<Round, \"phase\">[]>`\n805\t        SELECT phase FROM rounds WHERE pda = ${pda}\n806\t      `;\n807\t\n808\t      if (current.length === 0) {\n809\t        throw new Error(`Round not found: ${pda}`);\n810\t      }\n811\t\n812\t      const currentPhase = current[0]!.phase as RoundPhase;\n813\t      assertPhaseTransition(currentPhase, newPhase);\n814\t\n815\t      // Build the update — always set phase + updated_at, set settled_at on settlement\n816\t      const rows = await sql<Round[]>`\n817\t        UPDATE rounds SET\n818\t          phase = ${newPhase},\n819\t          updated_at = now(),\n820\t          settled_at = ${newPhase === \"settled\" ? sql`now()` : sql`settled_at`},\n821\t          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n822\t          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n823\t          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n824\t          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n825\t          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n826\t          winner = COALESCE(${updates?.winner ?? null}, winner)\n827\t        WHERE pda = ${pda}\n828\t        RETURNING *, NULL::jsonb AS entries\n829\t      `;\n830\t\n831\t      return normalizeRound(rows[0]!);\n832\t    },\n833\t\n834\t    async getRoundByPda(pda) {\n835\t      const rows = await sql<Round[]>`\n836\t        SELECT r.*,\n837\t          COALESCE(\n838\t            json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports))\n839\t            FILTER (WHERE ge.id IS NOT NULL), '[]'\n840\t          ) AS entries\n841\t        FROM rounds r\n842\t        LEFT JOIN game_entries ge ON ge.round_pda = r.pda\n843\t        WHERE r.pda = ${pda}\n844\t        GROUP BY r.pda\n845\t      `;\n846\t      return rows[0] ? normalizeRound(rows[0]) : undefined;\n847\t    },\n848\t\n849\t    async getRoundByMatchId(matchId) {\n850\t      const rows = await sql<Round[]>`\n851\t        SELECT r.*,\n852\t          COALESCE(\n853\t            json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports))\n854\t            FILTER (WHERE ge.id IS NOT NULL), '[]'\n855\t          ) AS entries\n856\t        FROM rounds r\n857\t        LEFT JOIN game_entries ge ON ge.round_pda = r.pda\n858\t        WHERE r.match_id = ${matchId}\n859\t        GROUP BY r.pda\n860\t      `;\n861\t      return rows[0] ? normalizeRound(rows[0]) : undefined;\n862\t    },\n863\t\n864\t    async getRoundsByPhase(phase) {\n865\t      const rows = await sql<Round[]>`\n866\t        SELECT *, NULL::jsonb AS entries FROM rounds WHERE phase = ${phase}\n867\t      `;\n868\t      return rows.map(normalizeRound);\n869\t    },\n870\t\n871\t    async insertOperatorEvent(pda, eventType, payload) {\n872\t      const rows = await sql<OperatorEvent[]>`\n873\t        INSERT INTO operator_events (pda, event_type, payload)\n874\t        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n875\t        RETURNING *\n876\t      `;\n877\t      return rows[0]!;\n878\t    },\n879\t\n880\t    async getLatestOperatorEvent(pda, eventType) {\n881\t      const rows = await sql<OperatorEvent[]>`\n882\t        SELECT * FROM operator_events\n883\t        WHERE pda = ${pda} AND event_type = ${eventType}\n884\t        ORDER BY id DESC\n885\t        LIMIT 1\n886\t      `;\n887\t      return rows[0];\n888\t    },\n889\t\n890\t    async getLatestOperatorEventsForPdas(pdas, eventType) {\n891\t      if (pdas.length === 0) return new Map();\n892\t      const rows = await sql<OperatorEvent[]>`\n893\t        SELECT DISTINCT ON (pda) *\n894\t        FROM operator_events\n895\t        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n896\t        ORDER BY pda, id DESC\n897\t      `;\n898\t      const map = new Map<string, OperatorEvent>();\n899\t      for (const row of rows) {\n900\t        if (row.pda) map.set(row.pda, row);\n901\t      }\n902\t      return map;\n903\t    },\n904\t\n905\t    async getRecentSettledRounds(game, limit) {\n906\t      const rows = await sql<Round[]>`\n907\t        SELECT r.*,\n908\t          COALESCE(\n909\t            json_agg(json_build_object('player', ge.wallet, 'amountLamports', ge.amount_lamports))\n910\t            FILTER (WHERE ge.id IS NOT NULL), '[]'\n911\t          ) AS entries\n912\t        FROM rounds r\n913\t        LEFT JOIN game_entries ge ON ge.round_pda = r.pda\n914\t        WHERE r.game = ${game} AND r.phase = 'settled'\n915\t        GROUP BY r.pda\n916\t        ORDER BY r.updated_at DESC\n917\t        LIMIT ${limit}\n918\t      `;\n919\t      return rows.map(normalizeRound);\n920\t    },\n921\t\n922\t    async getUnsettledStats() {\n923\t      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n924\t        SELECT\n925\t          COUNT(*)::text AS count,\n926\t          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n927\t        FROM rounds\n928\t        WHERE phase NOT IN ('settled', 'expired')\n929\t      `;\n930\t      const row = rows[0]!;\n931\t      return {\n932\t        count: parseInt(row.count, 10),\n933\t        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n934\t      };\n935\t    },\n936\t\n937\t    // -----------------------------------------------------------------------\n938\t    // Close Call rounds\n939\t    // -----------------------------------------------------------------------\n940\t\n941\t    async insertCloseCallRound(params) {\n942\t      const rows = await sql<CloseCallRound[]>`\n943\t        I