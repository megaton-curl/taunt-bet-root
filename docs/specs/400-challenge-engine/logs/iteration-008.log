{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011yvK11T38Kca6PTHpDo1Uj","type":"tool_result","content":"Todos have been modified successfully. Ensure that you continue to use the todo list to track your progress. Please proceed with the current tasks if applicable"}]},"parent_tool_use_id":null,"session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"b255e5bf-a680-4738-8675-5c90318d20c8","timestamp":"2026-04-03T20:13:40.067Z","tool_use_result":{"oldTodos":[],"newTodos":[{"content":"Implement GAME_SETTLED handler with DB helpers","status":"in_progress","activeForm":"Implementing GAME_SETTLED handler with DB helpers"},{"content":"Register handler in index.ts","status":"pending","activeForm":"Registering handler in index.ts"},{"content":"Write integration tests","status":"pending","activeForm":"Writing integration tests"},{"content":"Run lint + typecheck + test","status":"pending","activeForm":"Running lint + typecheck + test"},{"content":"Check off spec item if passing","status":"pending","activeForm":"Checking off spec item"}],"verificationNudgeNeeded":false}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01NrPLCruhowNNzh1H72pVzC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FoQqZAMYDJnux3oVk5Kf9Z","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/game-settled.ts","content":"/**\n * GAME_SETTLED handler — the orchestrator for the challenge engine.\n *\n * Processes each player in a settled game event:\n *   1. Quest eligibility check (skip refunded games)\n *   2. Challenge progress evaluation via adapters\n *   3. Reward intent emission on challenge completion\n *   4. Wager-based points grant\n *   5. Crate drop roll\n *\n * Once per round: reward pool funding.\n *\n * Per-player try/catch ensures one player's error doesn't block others.\n * Idempotent via UNIQUE constraints on progress_events, point_grants,\n * crate_drops, and reward_pool_fundings.\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\nimport { emitEvent } from \"../emit-event.js\";\nimport { EventTypes } from \"../event-types.js\";\nimport {\n  questEligible,\n  getAdapter,\n  type GameSettledPayload,\n  type GameSettledPlayer,\n  type ChallengeAssignment,\n} from \"./challenge-adapters.js\";\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Row shape from the active-assignments + challenges JOIN. */\ninterface AssignmentWithChallenge {\n  id: string;\n  challenge_id: string;\n  action: string;\n  scope: string;\n  condition: string;\n  target: number;\n  progress: number;\n  status: string;\n  period_key: string;\n  campaign_id: string;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\n/**\n * Load active challenge assignments for a user, joined with their challenge\n * definitions. Uses the partial index on (user_id, status) WHERE status='active'.\n */\nexport async function getActiveAssignmentsWithChallenge(\n  db: Db,\n  userId: string,\n): Promise<AssignmentWithChallenge[]> {\n  return db.rawSql<AssignmentWithChallenge[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      c.action,\n      c.scope,\n      c.condition,\n      ca.target,\n      ca.progress,\n      ca.status,\n      ca.period_key,\n      c.campaign_id,\n      c.reward_type,\n      c.reward_amount\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.status = 'active'\n  `;\n}\n\n/**\n * Insert a progress event. Returns false if a row for this\n * (assignment_id, round_id) already exists (idempotency guard).\n */\nexport async function insertProgressEvent(\n  db: Db,\n  assignmentId: string,\n  roundId: string,\n  userId: string,\n  delta: number,\n  metadata: Record<string, unknown>,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO progress_events (assignment_id, round_id, user_id, progress_delta, metadata)\n    VALUES (${assignmentId}, ${roundId}, ${userId}, ${delta}, ${JSON.stringify(metadata)})\n    ON CONFLICT (assignment_id, round_id) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n/**\n * Atomically increment an assignment's progress by delta.\n * Returns the new progress value.\n */\nexport async function incrementAssignmentProgress(\n  db: Db,\n  assignmentId: string,\n  delta: number,\n): Promise<number> {\n  const rows = await db.rawSql<{ progress: number }[]>`\n    UPDATE challenge_assignments\n    SET progress = progress + ${delta}\n    WHERE id = ${assignmentId}\n    RETURNING progress\n  `;\n  return rows[0]!.progress;\n}\n\n/**\n * Mark an assignment as completed with a timestamp.\n */\nexport async function markAssignmentCompleted(\n  db: Db,\n  assignmentId: string,\n): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'completed', completed_at = now()\n    WHERE id = ${assignmentId}\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Handler factory\n// ---------------------------------------------------------------------------\n\nexport interface GameSettledDeps {\n  db: Db;\n}\n\nexport function createGameSettledHandler(deps: GameSettledDeps) {\n  const { db } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    // Validate and cast payload\n    const roundId = payload.roundId as string;\n    const game = payload.game as string;\n    const players = payload.players as GameSettledPlayer[] | undefined;\n    const feeLamports = payload.feeLamports as string;\n    const settledAt = payload.settledAt as string;\n    const roundPda = payload.roundPda as string;\n\n    if (!roundId || !game || !players || !feeLamports || !settledAt) {\n      throw new Error(\n        \"game.settled: malformed payload — missing roundId, game, players, feeLamports, or settledAt\",\n      );\n    }\n\n    // --- Once per round: emit reward.pool_fund ---\n    await emitEvent(db.rawSql, EventTypes.REWARD_POOL_FUND, {\n      roundId,\n      roundPda,\n      feeLamports,\n    });\n\n    // --- Per-player processing ---\n    for (const player of players) {\n      try {\n        // Quest eligibility gate — skip refunded games\n        if (!questEligible(player)) {\n          logger.debug(\"game.settled: player ineligible (refund)\", {\n            userId: player.userId,\n            roundId,\n          });\n          continue;\n        }\n\n        // ---- Challenge progress evaluation ----\n        const assignments = await getActiveAssignmentsWithChallenge(\n          db,\n          player.userId,\n        );\n\n        for (const assignment of assignments) {\n          const adapter = getAdapter(assignment.action);\n          const challengeAssignment: ChallengeAssignment = {\n            id: Number(assignment.id),\n            challengeId: Number(assignment.challenge_id),\n            action: assignment.action,\n            scope: assignment.scope,\n            condition: assignment.condition,\n            target: assignment.target,\n            progress: assignment.progress,\n            status: assignment.status,\n          };\n\n          const result = adapter(\n            payload as unknown as GameSettledPayload,\n            player,\n            challengeAssignment,\n          );\n\n          if (!result.shouldProgress) continue;\n\n          // Atomic: insert progress event + increment progress\n          await db.withTransaction(async (txDb) => {\n            const inserted = await insertProgressEvent(\n              txDb,\n              assignment.id,\n              roundId,\n              player.userId,\n              result.progressDelta,\n              { game },\n            );\n            if (!inserted) {\n              // Duplicate round for this assignment — skip\n              return;\n            }\n\n            const newProgress = await incrementAssignmentProgress(\n              txDb,\n              assignment.id,\n              result.progressDelta,\n            );\n\n            // Check completion\n            if (newProgress >= assignment.target) {\n              await markAssignmentCompleted(txDb, assignment.id);\n\n              // Emit reward intent based on challenge's reward_type\n              if (assignment.reward_type === \"points\" && assignment.reward_amount) {\n                await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n                  userId: player.userId,\n                  wallet: player.wallet,\n                  sourceType: \"challenge_completed\",\n                  sourceId: `challenge-${assignment.id}`,\n                  amount: assignment.reward_amount.toString(),\n                });\n              } else if (assignment.reward_type === \"crate\") {\n                await emitEvent(txDb.rawSql, EventTypes.CRATE_DROP, {\n                  userId: player.userId,\n                  wallet: player.wallet,\n                  triggerType: \"challenge_completed\",\n                  triggerId: `challenge-${assignment.id}`,\n                });\n              }\n\n              logger.info(\"game.settled: challenge completed\", {\n                userId: player.userId,\n                assignmentId: assignment.id,\n                challengeId: assignment.challenge_id,\n                rewardType: assignment.reward_type,\n              });\n            }\n          });\n        }\n\n        // ---- Wager-based points grant ----\n        await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n          userId: player.userId,\n          wallet: player.wallet,\n          sourceType: \"wager\",\n          sourceId: roundId,\n          amountLamports: player.amountLamports,\n          settledAt,\n        });\n\n        // ---- Crate drop ----\n        await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n          userId: player.userId,\n          wallet: player.wallet,\n          triggerType: \"game_settled\",\n          triggerId: roundId,\n        });\n      } catch (err) {\n        // Per-player try/catch — don't let one player's error block others\n        logger.error(\"game.settled: error processing player\", {\n          userId: player.userId,\n          roundId,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n    }\n\n    logger.info(\"game.settled: processed\", {\n      roundId,\n      game,\n      playerCount: players.length,\n    });\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":530,"cache_read_input_tokens":74665,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":530},"output_tokens":58,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"1ed4924f-c490-47d7-8a62-1b1e82a231c8"}
