{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MZzigQjYBR9newPwvfjKKd","type":"tool_result","content":"250\t/** @deprecated Use GameEntryUpsert instead */\n251\texport type GameEntryInsert = GameEntryUpsert;\n252\t\n253\texport interface GameEntry {\n254\t  id: number;\n255\t  userId: string;\n256\t  wallet: string;\n257\t  game: string;\n258\t  roundPda: string;\n259\t  matchId: string;\n260\t  amountLamports: number;\n261\t  side: string | null;\n262\t  isWinner: boolean | null;\n263\t  payoutLamports: number;\n264\t  createdAt: Date;\n265\t  settledAt: Date | null;\n266\t}\n267\t\n268\texport interface CloseCallCandle {\n269\t  minuteTs: number;\n270\t  price: bigint;\n271\t  expo: number;\n272\t  priceHuman: number;\n273\t}\n274\t\n275\texport interface LeaderboardEntry {\n276\t  rank: number;\n277\t  userId: string;\n278\t  username: string;\n279\t  avatarUrl: string | null;\n280\t  totalWagered: bigint;\n281\t  gamesPlayed: number;\n282\t  totalWins: number;\n283\t  winRate: number;\n284\t  netPnl: bigint;\n285\t}\n286\t\n287\texport interface LeaderboardResult {\n288\t  entries: LeaderboardEntry[];\n289\t  weekStart: string; // ISO date string (Monday 00:00 UTC)\n290\t  weekEnd: string;   // ISO date string (next Monday 00:00 UTC)\n291\t}\n292\t\n293\t// ---------------------------------------------------------------------------\n294\t// Phase transition guard\n295\t// ---------------------------------------------------------------------------\n296\t\n297\t/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n298\tconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n299\t  created: [\"locked\", \"expired\"],\n300\t  locked: [\"settling\"],\n301\t  settling: [\"settled\"],\n302\t  settled: [],\n303\t  expired: [],\n304\t};\n305\t\n306\tfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n307\t  const allowed = VALID_TRANSITIONS[from];\n308\t  if (!allowed.includes(to)) {\n309\t    throw new Error(\n310\t      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n311\t    );\n312\t  }\n313\t}\n314\t\n315\t// ---------------------------------------------------------------------------\n316\t// DB client\n317\t// ---------------------------------------------------------------------------\n318\t\n319\texport interface Db {\n320\t  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n321\t  insertRound(params: InsertRoundParams): Promise<Round>;\n322\t\n323\t  /** Delete a round by PDA. Returns true if a row was removed. */\n324\t  deleteRoundByPda(pda: string): Promise<boolean>;\n325\t\n326\t  /** Transition a round's phase. Enforces unidirectional state machine.\n327\t   *  Optional `updates` can set additional columns alongside the phase change. */\n328\t  updateRoundPhase(\n329\t    pda: string,\n330\t    newPhase: RoundPhase,\n331\t    updates?: Partial<\n332\t      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n333\t    >,\n334\t  ): Promise<Round>;\n335\t\n336\t  /** Get a single round by its PDA. Returns `undefined` if not found. */\n337\t  getRoundByPda(pda: string): Promise<Round | undefined>;\n338\t\n339\t  /** Get all rounds matching a given phase. */\n340\t  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n341\t\n342\t  /** Append an operator event to the audit log. */\n343\t  insertOperatorEvent(\n344\t    pda: string | null,\n345\t    eventType: OperatorEventType,\n346\t    payload?: unknown,\n347\t  ): Promise<OperatorEvent>;\n348\t\n349\t  /** Get the latest operator event for a PDA + type. */\n350\t  getLatestOperatorEvent(\n351\t    pda: string,\n352\t    eventType: OperatorEventType,\n353\t  ): Promise<OperatorEvent | undefined>;\n354\t\n355\t  /** Get a single round by its match_id. Returns `undefined` if not found. */\n356\t  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n357\t\n358\t  /** Batch-fetch the latest operator event per PDA for a given event type. */\n359\t  getLatestOperatorEventsForPdas(\n360\t    pdas: string[],\n361\t    eventType: OperatorEventType,\n362\t  ): Promise<Map<string, OperatorEvent>>;\n363\t\n364\t  /** Get recently settled rounds for a game, ordered newest first. */\n365\t  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n366\t\n367\t  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n368\t  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n369\t\n370\t  // -------------------------------------------------------------------------\n371\t  // Close Call rounds\n372\t  // -------------------------------------------------------------------------\n373\t\n374\t  /** Insert a new Close Call round. */\n375\t  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n376\t\n377\t  /** Get a Close Call round by round_id (16-char hex). */\n378\t  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n379\t\n380\t  /** Get the current active (open) Close Call round. */\n381\t  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n382\t\n383\t  /** Get the most recent settled/refunded Close Call rounds. */\n384\t  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n385\t\n386\t  /** Update a Close Call round after settlement. */\n387\t  settleCloseCallRound(\n388\t    roundId: string,\n389\t    updates: {\n390\t      phase: CloseCallPhase;\n391\t      outcome: CloseCallOutcome;\n392\t      closePrice?: number;\n393\t      greenPool?: number;\n394\t      redPool?: number;\n395\t      totalFee?: number;\n396\t      settleTx?: string;\n397\t    },\n398\t  ): Promise<CloseCallRound>;\n399\t\n400\t  // -------------------------------------------------------------------------\n401\t  // Transactions\n402\t  // -------------------------------------------------------------------------\n403\t\n404\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n405\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n406\t\n407\t  /** Insert multiple transactions in a single batch. */\n408\t  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n409\t\n410\t  /** Get paginated transactions for a wallet, newest first. */\n411\t  getTransactions(\n412\t    wallet: string,\n413\t    cursor?: string,\n414\t    limit?: number,\n415\t    game?: string,\n416\t  ): Promise<Transaction[]>;\n417\t\n418\t  /** Get paginated transactions for an authenticated user_id, newest first. */\n419\t  getTransactionsByUserId(\n420\t    userId: string,\n421\t    cursor?: string,\n422\t    limit?: number,\n423\t    game?: string,\n424\t  ): Promise<Transaction[]>;\n425\t\n426\t  // -------------------------------------------------------------------------\n427\t  // Referral — codes\n428\t  // -------------------------------------------------------------------------\n429\t\n430\t  /** Insert a new referral code for a user. Throws on duplicate user, wallet, or code. */\n431\t  insertReferralCode(\n432\t    userId: string,\n433\t    wallet: string,\n434\t    code: string,\n435\t  ): Promise<ReferralCode>;\n436\t\n437\t  /** Get a user's referral code. Returns `undefined` if none set. */\n438\t  getReferralCodeByUserId(userId: string): Promise<ReferralCode | undefined>;\n439\t\n440\t  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n441\t  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n442\t\n443\t  // -------------------------------------------------------------------------\n444\t  // Referral — links\n445\t  // -------------------------------------------------------------------------\n446\t\n447\t  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n448\t  insertReferralLink(params: {\n449\t    referrerUserId: string;"}]},"parent_tool_use_id":"toolu_01BjFVkGqa3nnge3wfvNTvkn","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"784cbd2b-565a-4ad8-b564-48f725d1df50","timestamp":"2026-04-03T20:11:46.865Z"}
