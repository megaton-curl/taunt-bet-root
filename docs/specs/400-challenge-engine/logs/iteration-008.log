{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EHNwoKAbhyFe7EKnnqMn5f","type":"tool_result","content":"1800\t\n1801\t      const rows = await sql<\n1802\t        Array<{\n1803\t          user_id: string;\n1804\t          username: string;\n1805\t          avatar_url: string | null;\n1806\t          total_wagered: string;\n1807\t          games_played: string;\n1808\t          total_wins: string;\n1809\t          net_pnl: string;\n1810\t        }>\n1811\t      >`\n1812\t        SELECT\n1813\t          ge.user_id,\n1814\t          COALESCE(p.username, LEFT(ge.user_id, 8)) AS username,\n1815\t          p.avatar_url,\n1816\t          SUM(ge.amount_lamports)::text               AS total_wagered,\n1817\t          COUNT(*)::text                               AS games_played,\n1818\t          SUM(CASE WHEN ge.is_winner = true THEN 1 ELSE 0 END)::text AS total_wins,\n1819\t          SUM(ge.payout_lamports - ge.amount_lamports)::text   AS net_pnl\n1820\t        FROM game_entries ge\n1821\t        JOIN player_profiles p ON p.user_id = ge.user_id\n1822\t        WHERE ge.settled_at IS NOT NULL\n1823\t          AND ge.settled_at >= date_trunc('week', now())\n1824\t          ${gameFilter}\n1825\t        GROUP BY ge.user_id, p.username, p.avatar_url\n1826\t        ORDER BY SUM(ge.amount_lamports) DESC\n1827\t        LIMIT ${effectiveLimit}\n1828\t        OFFSET ${offset}\n1829\t      `;\n1830\t\n1831\t      const entries: LeaderboardEntry[] = rows.map((row: (typeof rows)[number], i: number) => {\n1832\t        const gamesPlayed = Number(row.games_played);\n1833\t        const totalWins = Number(row.total_wins);\n1834\t        return {\n1835\t          rank: offset + i + 1,\n1836\t          userId: row.user_id,\n1837\t          username: row.username,\n1838\t          avatarUrl: row.avatar_url,\n1839\t          totalWagered: BigInt(row.total_wagered),\n1840\t          gamesPlayed,\n1841\t          totalWins,\n1842\t          winRate: gamesPlayed > 0 ? totalWins / gamesPlayed : 0,\n1843\t          netPnl: BigInt(row.net_pnl),\n1844\t        };\n1845\t      });\n1846\t\n1847\t      // Week boundaries: ISO week (Monday start)\n1848\t      const now = new Date();\n1849\t      const day = now.getUTCDay();\n1850\t      const diff = day === 0 ? 6 : day - 1;\n1851\t      const ws = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - diff));\n1852\t      const we = new Date(ws.getTime() + 7 * 24 * 60 * 60 * 1000);\n1853\t\n1854\t      return {\n1855\t        entries,\n1856\t        weekStart: ws.toISOString(),\n1857\t        weekEnd: we.toISOString(),\n1858\t      };\n1859\t    },\n1860\t\n1861\t    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n1862\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1863\t      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n1864\t    },\n1865\t\n1866\t    async close() {\n1867\t      if (_isOwner) await sql.end();\n1868\t    },\n1869\t  };\n1870\t}\n1871\t"}]},"parent_tool_use_id":"toolu_01BjFVkGqa3nnge3wfvNTvkn","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"0b29c53f-e07c-4466-a167-f077fbc6c912","timestamp":"2026-04-03T20:11:57.469Z"}
