{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016k2sUv3WcrW2xaPdz59f8y","type":"tool_result","content":"1150\t    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n1151\t\n1152\t    // Insert player profiles\n1153\t    await rawSql`\n1154\t      INSERT INTO player_profiles (user_id, wallet, username)\n1155\t      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n1156\t      ON CONFLICT (user_id) DO NOTHING\n1157\t    `;\n1158\t    await rawSql`\n1159\t      INSERT INTO player_profiles (user_id, wallet, username)\n1160\t      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n1161\t      ON CONFLICT (user_id) DO NOTHING\n1162\t    `;\n1163\t\n1164\t    // Create a round with minuteTs = 2 minutes ago (candle is closed)\n1165\t    const nowSec = Math.floor(Date.now() / 1000);\n1166\t    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n1167\t    const greenAmount = 5_000_000n;\n1168\t    const redAmount = 5_000_000n;\n1169\t    const openPrice = 69500_00n; // $69500.00 with expo -2\n1170\t\n1171\t    // Derive round PDA (seeds: [\"round\", minute_ts as LE i64, server pubkey])\n1172\t    const minuteTsBuf = Buffer.alloc(8);\n1173\t    minuteTsBuf.writeBigInt64LE(minuteTs);\n1174\t    const [roundPda] = PublicKey.findProgramAddressSync(\n1175\t      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n1176\t      CLOSECALL_PROGRAM_ID,\n1177\t    );\n1178\t\n1179\t    // Build on-chain round account data (phase=Open, with entries)\n1180\t    const roundAccountData = await encodeCloseCallRound({\n1181\t      minuteTs,\n1182\t      server: serverKeypair.publicKey,\n1183\t      phase: 0, // Open\n1184\t      greenEntries: [{ player: greenPlayer.publicKey, amountLamports: greenAmount }],\n1185\t      redEntries: [{ player: redPlayer.publicKey, amountLamports: redAmount }],\n1186\t      greenPool: greenAmount,\n1187\t      redPool: redAmount,\n1188\t      openPrice,\n1189\t      openPriceExpo: -2,\n1190\t      closePrice: 0n,\n1191\t      createdAt: minuteTs,\n1192\t      bettingEndsAt: minuteTs + 45n,\n1193\t      resolveDeadline: minuteTs + 300n,\n1194\t      outcome: 0, // Pending\n1195\t      totalFee: 0n,\n1196\t      bump: 0,\n1197\t    });\n1198\t\n1199\t    mockConn.setAccount(roundPda, roundAccountData, {\n1200\t      owner: CLOSECALL_PROGRAM_ID,\n1201\t    });\n1202\t\n1203\t    // Mock Hermes: returns a price > openPrice so outcome = green\n1204\t    // publishTime must be >= current minute boundary so captureBoundaryPrice() succeeds immediately\n1205\t    const closePrice = 69600_00n; // $69600.00\n1206\t    const mockHermes: HermesFetcher = {\n1207\t      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n1208\t        price: closePrice,\n1209\t        expo: -2,\n1210\t        publishTime: Math.floor(Date.now() / 1000), // always \"current\"\n1211\t        priceHuman: 69600.0,\n1212\t        vaaBase64: null,\n1213\t      }),\n1214\t    };\n1215\t\n1216\t    // Create clock worker with mock deps\n1217\t    const clock = createCloseCallClockWorker({\n1218\t      connection: mockConn as unknown as Connection,\n1219\t      serverKeypair,\n1220\t      db,\n1221\t      hermesFetcher: mockHermes,\n1222\t    });\n1223\t\n1224\t    // Call tick() — discovers the open round, captures boundary price, settles\n1225\t    await clock.tick();\n1226\t\n1227\t    // Verify game.settled event was emitted in event_queue\n1228\t    const events = await rawSql`\n1229\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1230\t    `;\n1231\t    expect(events.length).toBe(1);\n1232\t\n1233\t    const evt = events[0]!;\n1234\t    expect(evt.status).toBe(\"pending\");\n1235\t\n1236\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1237\t    const payload = evt.payload as any;\n1238\t    expect(payload.roundId).toBe(String(Number(minuteTs)));\n1239\t    expect(payload.roundPda).toBe(roundPda.toBase58());\n1240\t    expect(payload.game).toBe(\"closecall\");\n1241\t    expect(payload.feeLamports).toBeDefined();\n1242\t    expect(payload.settledAt).toBeDefined();\n1243\t\n1244\t    // Players array — both players should be present\n1245\t    expect(payload.players).toHaveLength(2);\n1246\t    const greenP = payload.players.find(\n1247\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1248\t      (p: any) => p.wallet === greenPlayer.publicKey.toBase58(),\n1249\t    );\n1250\t    const redP = payload.players.find(\n1251\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1252\t      (p: any) => p.wallet === redPlayer.publicKey.toBase58(),\n1253\t    );\n1254\t    expect(greenP).toBeDefined();\n1255\t    expect(redP).toBeDefined();\n1256\t    expect(greenP.userId).toBe(greenUserId);\n1257\t    expect(redP.userId).toBe(redUserId);\n1258\t    // Amounts are string-encoded lamports\n1259\t    expect(greenP.amountLamports).toBe(String(greenAmount));\n1260\t    expect(redP.amountLamports).toBe(String(redAmount));\n1261\t    // Green wins (closePrice > openPrice)\n1262\t    expect(greenP.isWinner).toBe(true);\n1263\t    expect(redP.isWinner).toBe(false);\n1264\t    // Winner payout > 0, loser payout = \"0\"\n1265\t    expect(Number(greenP.payoutLamports)).toBeGreaterThan(0);\n1266\t    expect(redP.payoutLamports).toBe(\"0\");\n1267\t    // Fee = totalPool * 500 bps / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n1268\t    expect(payload.feeLamports).toBe(String(500_000));\n1269\t    // isCreator: first entry (green) is creator\n1270\t    expect(greenP.isCreator).toBe(true);\n1271\t    expect(redP.isCreator).toBe(false);\n1272\t  });\n1273\t\n1274\t  // ---------------------------------------------------------------------------\n1275\t  // REWARD_POOL_FUND handler\n1276\t  // ---------------------------------------------------------------------------\n1277\t\n1278\t  it(\"reward.pool_fund handler: funds pool from fee and dedupes on round_id\", async () => {\n1279\t    // Ensure reward_config has the fee share (seeded by migration, but verify)\n1280\t    const configRows = await rawSql<{ value: string }[]>`\n1281\t      SELECT value FROM reward_config WHERE key = 'reward_pool_fee_share'\n1282\t    `;\n1283\t    if (configRows.length === 0) {\n1284\t      // Re-seed if TRUNCATE removed it\n1285\t      await rawSql`INSERT INTO reward_config (key, value) VALUES ('reward_pool_fee_share', '0.20')`;\n1286\t    }\n1287\t\n1288\t    // Verify pool starts at zero\n1289\t    const poolBefore = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1290\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1291\t    `;\n1292\t    expect(poolBefore.length).toBe(1);\n1293\t    expect(BigInt(poolBefore[0]!.balance_lamports)).toBe(0n);\n1294\t    expect(BigInt(poolBefore[0]!.lifetime_funded)).toBe(0n);\n1295\t\n1296\t    // Create handler and call it directly\n1297\t    const handler = createRewardPoolFundHandler({ db });\n1298\t\n1299\t    const feeLamports = \"500000\"; // 500_000 lamports fee"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"f423f5e0-e1b1-4464-84c3-63d29674a2b3","timestamp":"2026-04-03T20:11:43.485Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KvwqM3JsrKCpC8Bqib94h6","type":"tool_result","content":"1\t/**\n2\t * Database client module — typed query functions for `rounds` and `operator_events`.\n3\t *\n4\t * Phase transitions are unidirectional: created → locked → settling → settled,\n5\t * or created → expired. The application layer rejects backward transitions.\n6\t */\n7\t\n8\timport postgres from \"postgres\";\n9\timport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n10\t\n11\t// ---------------------------------------------------------------------------\n12\t// Types\n13\t// ---------------------------------------------------------------------------\n14\t\n15\texport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n16\t\n17\texport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n18\texport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n19\t\n20\texport interface CloseCallRound {\n21\t  round_id: string;\n22\t  pda: string;\n23\t  server_key: string;\n24\t  phase: CloseCallPhase;\n25\t  open_price: number;\n26\t  open_price_expo: number;\n27\t  close_price: number | null;\n28\t  outcome: CloseCallOutcome;\n29\t  green_pool: number;\n30\t  red_pool: number;\n31\t  total_fee: number;\n32\t  green_entries: Array<{ player: string; amountLamports: number }>; // populated via JOIN on game_entries\n33\t  red_entries: Array<{ player: string; amountLamports: number }>;   // populated via JOIN on game_entries\n34\t  settle_tx: string | null;\n35\t  created_at: Date;\n36\t  settled_at: Date | null;\n37\t}\n38\t\n39\texport interface InsertCloseCallRoundParams {\n40\t  roundId: string;\n41\t  pda: string;\n42\t  serverKey: string;\n43\t  openPrice: number;\n44\t  openPriceExpo: number;\n45\t}\n46\t\n47\texport type OperatorEventType =\n48\t  | \"secret_generated\"\n49\t  | \"tx_built\"\n50\t  | \"match_detected\"\n51\t  | \"settle_submitted\"\n52\t  | \"settle_confirmed\"\n53\t  | \"settle_failed\"\n54\t  | \"settle_retried\"\n55\t  | \"timeout_detected\";\n56\t\n57\texport interface Round {\n58\t  pda: string;\n59\t  game: string;\n60\t  creator: string;\n61\t  server_key: string;\n62\t  secret: Buffer;\n63\t  commitment: Buffer;\n64\t  amount_lamports: number;\n65\t  side: number;\n66\t  match_id: string;\n67\t  phase: RoundPhase;\n68\t  target_slot: string | null;\n69\t  settle_tx: string | null;\n70\t  settle_attempts: number;\n71\t  result_hash: Buffer | null;\n72\t  result_side: number | null;\n73\t  winner: string | null;\n74\t  entries: Array<{ player: string; amountLamports: number }> | null; // populated via JOIN on game_entries\n75\t  created_at: Date;\n76\t  updated_at: Date;\n77\t  settled_at: Date | null;\n78\t}\n79\t\n80\texport interface InsertRoundParams {\n81\t  pda: string;\n82\t  game: string;\n83\t  creator: string;\n84\t  serverKey: string;\n85\t  secret: Buffer;\n86\t  commitment: Buffer;\n87\t  amountLamports: number;\n88\t  side: number;\n89\t  matchId: string;\n90\t  phase: RoundPhase;\n91\t}\n92\t\n93\texport interface OperatorEvent {\n94\t  id: string;\n95\t  pda: string | null;\n96\t  event_type: OperatorEventType;\n97\t  payload: unknown;\n98\t  created_at: Date;\n99\t}\n100\t"}]},"parent_tool_use_id":"toolu_01BjFVkGqa3nnge3wfvNTvkn","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"59d6d547-c86f-44b1-a63b-0bf70a89acb6","timestamp":"2026-04-03T20:11:43.645Z"}
