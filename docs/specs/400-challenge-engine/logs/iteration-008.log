yerProfile(rows[0]) : null;\n1491\t    },\n1492\t\n1493\t    async updateUsername(wallet, newUsername) {\n1494\t      // Fetch current profile to check cooldown\n1495\t      const current = await sql<PlayerProfile[]>`\n1496\t        SELECT * FROM player_profiles WHERE wallet = ${wallet}\n1497\t      `;\n1498\t      if (current.length === 0) {\n1499\t        throw new Error(\"Profile not found\");\n1500\t      }\n1501\t\n1502\t      const profile = current[0]!;\n1503\t      if (profile.username_updated_at) {\n1504\t        const cooldownMs = 30 * 24 * 60 * 60 * 1000; // 30 days\n1505\t        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n1506\t        if (elapsed < cooldownMs) {\n1507\t          const nextEditAt = new Date(\n1508\t            new Date(profile.username_updated_at).getTime() + cooldownMs,\n1509\t          );\n1510\t          const err = new Error(\"Username cooldown active\") as Error & {\n1511\t            cooldown: true;\n1512\t            nextEditAvailableAt: Date;\n1513\t          };\n1514\t          err.cooldown = true;\n1515\t          err.nextEditAvailableAt = nextEditAt;\n1516\t          throw err;\n1517\t        }\n1518\t      }\n1519\t\n1520\t      const rows = await sql<PlayerProfile[]>`\n1521\t        UPDATE player_profiles\n1522\t        SET username = ${newUsername}, username_updated_at = now()\n1523\t        WHERE wallet = ${wallet}\n1524\t        RETURNING *\n1525\t      `;\n1526\t      return normalizePlayerProfile(rows[0]!);\n1527\t    },\n1528\t\n1529\t    async updateUsernameByUserId(userId, newUsername) {\n1530\t      const current = await sql<PlayerProfile[]>`\n1531\t        SELECT * FROM player_profiles WHERE user_id = ${userId}\n1532\t      `;\n1533\t      if (current.length === 0) {\n1534\t        throw new Error(\"Profile not found\");\n1535\t      }\n1536\t\n1537\t      const profile = current[0]!;\n1538\t      if (profile.username_updated_at) {\n1539\t        const cooldownMs = 30 * 24 * 60 *