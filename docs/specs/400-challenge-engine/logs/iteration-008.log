{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WwGPvHZJZ4b2caV3KXnBDG","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createInternalRoutes } from \"./routes/internal.js\";\n21\timport { swaggerUI } from \"@hono/swagger-ui\";\n22\timport { spec } from \"./openapi.js\";\n23\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n24\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n25\timport { createSettlementWorker } from \"./worker/settlement.js\";\n26\timport { settleRound } from \"./worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"./worker/retry.js\";\n28\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n29\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n30\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n31\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n32\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n33\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n34\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n35\timport { fetchSolPrice } from \"./routes/price.js\";\n36\timport { logger } from \"./logger.js\";\n37\t\n38\tconst config = loadConfig();\n39\t\n40\t// Single postgres pool shared by game DB, auth DB, and all workers\n41\tconst sql = postgres(config.databaseUrl);\n42\tconst db = createDb(config.databaseUrl, sql);\n43\tconst authDb = createAuthDb(sql);\n44\t\n45\tconst connection = new Connection(config.rpcUrl, {\n46\t  commitment: \"confirmed\",\n47\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n48\t});\n49\t\n50\tconst app = new Hono();\n51\t\n52\tapp.use(\n53\t  \"*\",\n54\t  cors({\n55\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n56\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n57\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n58\t  }),\n59\t);\n60\t\n61\t// Request logging — correlate frontend fetch timing with server-side processing\n62\tapp.use(\"*\", async (c, next) => {\n63\t  const start = Date.now();\n64\t  await next();\n65\t  const ms = Date.now() - start;\n66\t  const method = c.req.method;\n67\t  const path = c.req.path;\n68\t  // Skip noisy health checks and OPTIONS preflight\n69\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n70\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n71\t});\n72\t\n73\t// API docs — Swagger UI + raw OpenAPI spec\n74\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n75\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n76\t\n77\t// Auth routes — no JWT middleware (these are the login endpoints)\n78\t// Lighter rate limiting by IP for auth endpoints\n79\tapp.use(\n80\t  \"/auth/*\",\n81\t  createRateLimitMiddleware({\n82\t    perWallet: 20,\n83\t    global: config.rateLimitGlobal,\n84\t    windowMs: 60_000,\n85\t  }),\n86\t);\n87\t\n88\tapp.route(\n89\t  \"/auth\",\n90\t  createAuthRoutes({\n91\t    authDb,\n92\t    db,\n93\t    jwtSecret: config.jwtSecret,\n94\t    cluster: config.cluster,\n95\t    challengeTtlSeconds: config.challengeTtlSeconds,\n96\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n97\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n98\t  }),\n99\t);\n100\t\n101\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n102\tapp.use(\n103\t  \"/profile/*\",\n104\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n105\t);\n106\tapp.route(\"/profile\", createProfileRoutes({ db }));\n107\t\n108\t// Public profile routes — no auth required\n109\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n110\t\n111\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n112\tapp.use(\n113\t  \"/referral/*\",\n114\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n115\t);\n116\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n117\t\n118\t// JWT auth middleware for game endpoints\n119\tapp.use(\n120\t  \"/coinflip/*\",\n121\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n122\t);\n123\tapp.use(\n124\t  \"/lord/*\",\n125\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n126\t);\n127\t\n128\t// Rate limiting — per-wallet and global limits on POST requests\n129\tapp.use(\n130\t  \"/coinflip/*\",\n131\t  createRateLimitMiddleware({\n132\t    perWallet: config.rateLimitPerWallet,\n133\t    global: config.rateLimitGlobal,\n134\t    windowMs: 60_000,\n135\t  }),\n136\t);\n137\tapp.use(\n138\t  \"/lord/*\",\n139\t  createRateLimitMiddleware({\n140\t    perWallet: config.rateLimitPerWallet,\n141\t    global: config.rateLimitGlobal,\n142\t    windowMs: 60_000,\n143\t  }),\n144\t);\n145\t\n146\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n147\tconst entropyAccount = new PublicKey(config.entropyAccount);\n148\tconst retrySettler = createRetrySettler({\n149\t  db,\n150\t  connection,\n151\t  settleRound: (pda) =>\n152\t    settleRound(\n153\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n154\t      pda,\n155\t    ),\n156\t});\n157\t\n158\t// PDA watcher — WebSocket-based instant join detection\n159\tconst pdaWatcher = createPdaWatcher({\n160\t  connection,\n161\t  serverKey: config.serverKeypair.publicKey,\n162\t  db,\n163\t  onJoinDetected: async (pda, targetSlot) => {\n164\t    // Update DB phase if still in 'created'\n165\t    const round = await db.getRoundByPda(pda);\n166\t    if (round && round.phase === \"created\") {\n167\t      await db.updateRoundPhase(pda, \"locked\", {\n168\t        target_slot: targetSlot.toString(),\n169\t      });\n170\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n171\t        targetSlot: targetSlot.toString(),\n172\t        source: \"pda-watcher\",\n173\t        game: round.game,\n174\t      });\n175\t    }\n176\t\n177\t    // Check if target slot already passed — settle immediately if so\n178\t    const currentSlot = await connection.getSlot();\n179\t    if (BigInt(currentSlot) >= targetSlot) {\n180\t      await retrySettler.attemptSettle(pda);\n181\t      pdaWatcher.unwatch(pda);\n182\t    }\n183\t    // If target slot not reached yet, poll worker will pick it up next cycle\n184\t  },\n185\t});\n186\t\n187\tconst worker = createSettlementWorker({\n188\t  db,\n189\t  connection,\n190\t  serverKey: config.serverKeypair.publicKey,\n191\t  pollIntervalMs: config.workerPollIntervalMs,\n192\t  onSettleReady: async (pda) => {\n193\t    await retrySettler.attemptSettle(pda);\n194\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n195\t  },\n196\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n197\t});\n198\tworker.start();\n199\t\n200\t// Close Call clock worker — fetches boundary prices + settles open rounds\n201\t// Rounds are created on-demand by players via /closecall/bet\n202\tconst closeCallClock = createCloseCallClockWorker({\n203\t  connection,\n204\t  serverKeypair: config.serverKeypair,\n205\t  db,\n206\t});\n207\tcloseCallClock.start();\n208\t\n209\t// Register event handlers before starting the worker\n210\tregisterHandler(\n211\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n212\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n213\t);\n214\tregisterHandler(\n215\t  EventTypes.REWARD_POOL_FUND,\n216\t  createRewardPoolFundHandler({ db }),\n217\t);\n218\tregisterHandler(\n219\t  EventTypes.POINTS_GRANT,\n220\t  createPointsGrantHandler({\n221\t    db,\n222\t    getSolPrice: async () => {\n223\t      const result = await fetchSolPrice();\n224\t      return result?.price ?? null;\n225\t    },\n226\t  }),\n227\t);\n228\tregisterHandler(\n229\t  EventTypes.CRATE_DROP,\n230\t  createCrateDropHandler({ db }),\n231\t);\n232\t\n233\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n234\tconst eventWorker = createEventWorker(sql, {\n235\t  pollIntervalMs: config.eventQueuePollMs,\n236\t});\n237\teventWorker.start();\n238\tlogger.info(\"Event queue worker started\", {\n239\t  pollIntervalMs: config.eventQueuePollMs,\n240\t});\n241\t\n242\t// Game-specific routes\n243\tapp.route(\n244\t  \"/coinflip\",\n245\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n246\t);\n247\tapp.route(\n248\t  \"/lord\",\n249\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n250\t);\n251\t\n252\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n253\tapp.use(\n254\t  \"/closecall/bet\",\n255\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n256\t);\n257\tapp.use(\n258\t  \"/closecall/bet\",\n259\t  createRateLimitMiddleware({\n260\t    perWallet: config.rateLimitPerWallet,\n261\t    global: config.rateLimitGlobal,\n262\t    windowMs: 60_000,\n263\t  }),\n264\t);\n265\t\n266\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n267\tapp.route(\"/closecall\", createCloseCallRoutes({\n268\t  db,\n269\t  connection,\n270\t  serverKeypair: config.serverKeypair,\n271\t  clockWorker: closeCallClock,\n272\t}));\n273\t\n274\t// Leaderboard routes — public, no auth\n275\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n276\t\n277\t// Price routes — public, no auth\n278\tapp.route(\"/price\", createPriceRoutes());\n279\t\n280\t// Round verification routes\n281\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n282\t\n283\t// Health endpoint — wired after worker exists so we can query its status\n284\tapp.route(\n285\t  \"/health\",\n286\t  createHealthRoutes({\n287\t    db,\n288\t    sql,\n289\t    isWorkerRunning: () => worker.isRunning,\n290\t  }),\n291\t);\n292\t\n293\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n294\tif (config.adminToken) {\n295\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n296\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n297\t}\n298\t\n299\tconst port = config.port;\n300\tlogger.info(\"fairness-backend started\", { port });\n301\t\n302\tserve({\n303\t  fetch: app.fetch,\n304\t  port,\n305\t  hostname: \"0.0.0.0\",\n306\t});\n307\t\n308\texport default {\n309\t  port,\n310\t  fetch: app.fetch,\n311\t};\n312\t"}]},"parent_tool_use_id":null,"session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"8bc0cc88-8d46-4074-8745-98a420a2abce","timestamp":"2026-04-03T20:12:54.378Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { cors } from \"hono/cors\";\nimport { serve } from \"@hono/node-server\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport postgres from \"postgres\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createAuthDb } from \"./auth-db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createLordRoutes } from \"./routes/lord-create.js\";\nimport { createRoundsRoutes } from \"./routes/rounds.js\";\nimport { createCloseCallRoutes } from \"./routes/closecall.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createProfileRoutes } from \"./routes/profile.js\";\nimport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\nimport { createPriceRoutes } from \"./routes/price.js\";\nimport { createAuthRoutes } from \"./routes/auth.js\";\nimport { createReferralRoutes } from \"./routes/referral.js\";\nimport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\nimport { createInternalRoutes } from \"./routes/internal.js\";\nimport { swaggerUI } from \"@hono/swagger-ui\";\nimport { spec } from \"./openapi.js\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\nimport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\nimport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\nimport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\nimport { fetchSolPrice } from \"./routes/price.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Single postgres pool shared by game DB, auth DB, and all workers\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl, sql);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new Hono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// API docs — Swagger UI + raw OpenAPI spec\napp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\napp.get(\"/openapi.json\", (c) => c.json(spec));\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    db,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// Profile routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/profile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/profile\", createProfileRoutes({ db }));\n\n// Public profile routes — no auth required\napp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n\n// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\napp.use(\n  \"/referral/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n\n// JWT auth middleware for game endpoints\napp.use(\n  \"/coinflip/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/lord/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/coinflip/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\napp.use(\n  \"/lord/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  db,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Close Call clock worker — fetches boundary prices + settles open rounds\n// Rounds are created on-demand by players via /closecall/bet\nconst closeCallClock = createCloseCallClockWorker({\n  connection,\n  serverKeypair: config.serverKeypair,\n  db,\n});\ncloseCallClock.start();\n\n// Register event handlers before starting the worker\nregisterHandler(\n  EventTypes.REFERRAL_CLAIM_REQUESTED,\n  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\nregisterHandler(\n  EventTypes.REWARD_POOL_FUND,\n  createRewardPoolFundHandler({ db }),\n);\nregisterHandler(\n  EventTypes.POINTS_GRANT,\n  createPointsGrantHandler({\n    db,\n    getSolPrice: async () => {\n      const result = await fetchSolPrice();\n      return result?.price ?? null;\n    },\n  }),\n);\nregisterHandler(\n  EventTypes.CRATE_DROP,\n  createCrateDropHandler({ db }),\n);\n\n// Event queue worker — processes async side-effects (rewards, notifications, etc.)\nconst eventWorker = createEventWorker(sql, {\n  pollIntervalMs: config.eventQueuePollMs,\n});\neventWorker.start();\nlogger.info(\"Event queue worker started\", {\n  pollIntervalMs: config.eventQueuePollMs,\n});\n\n// Game-specific routes\napp.route(\n  \"/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/lord\",\n  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\napp.use(\n  \"/closecall/bet\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/closecall/bet\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Close Call routes (read endpoints are public, /bet is auth'd above)\napp.route(\"/closecall\", createCloseCallRoutes({\n  db,\n  connection,\n  serverKeypair: config.serverKeypair,\n  clockWorker: closeCallClock,\n}));\n\n// Leaderboard routes — public, no auth\napp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n\n// Price routes — public, no auth\napp.route(\"/price\", createPriceRoutes());\n\n// Round verification routes\napp.route(\"/rounds\", createRoundsRoutes({ db }));\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    db,\n    sql,\n    isWorkerRunning: () => worker.isRunning,\n  }),\n);\n\n// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\nif (config.adminToken) {\n  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n}\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", { port });\n\nserve({\n  fetch: app.fetch,\n  port,\n  hostname: \"0.0.0.0\",\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":312,"startLine":1,"totalLines":312}}}
