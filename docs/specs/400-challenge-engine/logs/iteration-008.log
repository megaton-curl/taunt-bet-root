{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FA3Gk9mkkCxLDRx8Xyc6e9","type":"tool_result","content":"400\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops RESTART IDENTITY CASCADE`;\n401\t    // Reset reward_pool balance to zero (keep singleton row from migration seed)\n402\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n403\t\n404\t    // Reset PlatformConfig cache so each test reads from its own mock\n405\t    resetPlatformConfigCache();\n406\t\n407\t    // Fresh mock Connection\n408\t    mockConn = new MockConnection();\n409\t\n410\t    // Pre-populate mock with entropy and config accounts\n411\t    mockConn.setAccount(entropyAccount, entropyData);\n412\t\n413\t    const [configPda] = PublicKey.findProgramAddressSync(\n414\t      [Buffer.from(\"coinflip_config\")],\n415\t      COINFLIP_PROGRAM_ID,\n416\t    );\n417\t    mockConn.setAccount(\n418\t      configPda,\n419\t      await buildConfigAccountData(treasuryKeypair.publicKey),\n420\t      { owner: COINFLIP_PROGRAM_ID },\n421\t    );\n422\t\n423\t    // PlatformConfig account — settlement reads fee_bps from here\n424\t    const [platformConfigPda] = derivePlatformConfigPda();\n425\t    mockConn.setAccount(\n426\t      platformConfigPda,\n427\t      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n428\t      { owner: PLATFORM_PROGRAM_ID },\n429\t    );\n430\t\n431\t    // Build the Hono app (no rate limiting for tests)\n432\t    app = new Hono();\n433\t\n434\t    app.use(\n435\t      \"/coinflip/*\",\n436\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n437\t    );\n438\t\n439\t    app.route(\n440\t      \"/coinflip\",\n441\t      createCoinflipRoutes({\n442\t        db,\n443\t        connection: mockConn as unknown as Connection,\n444\t        serverKeypair,\n445\t      }),\n446\t    );\n447\t\n448\t    app.route(\"/rounds\", createRoundsRoutes({ db }));\n449\t  });\n450\t\n451\t  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n452\t    const wallet = creatorKeypair.publicKey.toBase58();\n453\t    const token = await makeJwt(wallet);\n454\t\n455\t    // ------------------------------------------------------------------\n456\t    // 1. POST /coinflip/create\n457\t    // ------------------------------------------------------------------\n458\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n459\t\n460\t    const createRes = await app.request(\"/coinflip/create\", {\n461\t      method: \"POST\",\n462\t      headers: {\n463\t        \"Content-Type\": \"application/json\",\n464\t        \"Authorization\": `Bearer ${token}`,\n465\t      },\n466\t      body: JSON.stringify(body),\n467\t    });\n468\t\n469\t    expect(createRes.status).toBe(200);\n470\t    const createJson = (await createRes.json()) as {\n471\t      transaction: string;\n472\t      matchPda: string;\n473\t      matchId: string;\n474\t      commitment: string;\n475\t      lastValidBlockHeight: number;\n476\t    };\n477\t    expect(createJson.transaction).toBeDefined();\n478\t    expect(createJson.matchPda).toBeDefined();\n479\t    expect(createJson.commitment).toBeDefined();\n480\t    expect(createJson.lastValidBlockHeight).toBeDefined();\n481\t\n482\t    const matchPda = createJson.matchPda;\n483\t    const commitmentHex = createJson.commitment;\n484\t    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n485\t\n486\t    // ------------------------------------------------------------------\n487\t    // 2. Verify DB state — round in \"created\" phase\n488\t    // ------------------------------------------------------------------\n489\t    const round = await db.getRoundByPda(matchPda);\n490\t    expect(round).toBeDefined();\n491\t    expect(round!.phase).toBe(\"created\");\n492\t    expect(round!.game).toBe(\"coinflip\");\n493\t    expect(round!.creator).toBe(wallet);\n494\t    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n495\t    expect(round!.side).toBe(SIDE_HEADS);\n496\t    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n497\t    expect(round!.secret).toBeDefined();\n498\t    expect(round!.secret.length).toBe(32);\n499\t\n500\t    // Verify operator event was logged\n501\t    const events =\n502\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n503\t    expect(events.length).toBe(1);\n504\t    expect(events[0]!.event_type).toBe(\"secret_generated\");\n505\t\n506\t    // ------------------------------------------------------------------\n507\t    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n508\t    // ------------------------------------------------------------------\n509\t    const matchPubkey = new PublicKey(matchPda);\n510\t    const targetSlot = 150n;\n511\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n512\t\n513\t    const matchAccountData = await buildMatchAccountData({\n514\t      creator: creatorKeypair.publicKey,\n515\t      opponent: opponentKeypair.publicKey,\n516\t      server: serverKeypair.publicKey,\n517\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n518\t      creatorSide: SIDE_HEADS,\n519\t      phase: PHASE_LOCKED,\n520\t      commitment: commitmentBuf,\n521\t      algorithmVer: 1,\n522\t      targetSlot,\n523\t      resolveDeadline,\n524\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n525\t    });\n526\t\n527\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n528\t      owner: COINFLIP_PROGRAM_ID,\n529\t    });\n530\t\n531\t    // Set current slot past target_slot so settlement triggers immediately\n532\t    mockConn.slot = 200;\n533\t\n534\t    // ------------------------------------------------------------------\n535\t    // 4. Create worker + retry settler, trigger poll\n536\t    // ------------------------------------------------------------------\n537\t    let settlePromise: Promise<void> | null = null;\n538\t\n539\t    const retrySettler = createRetrySettler({\n540\t      db,\n541\t      connection: mockConn as unknown as Connection,\n542\t      settleRound: (pda) =>\n543\t        settleMatch(\n544\t          {\n545\t            db,\n546\t            connection: mockConn as unknown as Connection,\n547\t            serverKeypair,\n548\t            entropyAccount,\n549\t            referralDefaultRateBps: 1000,"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"427c22e7-84b5-4c8f-a8f5-346970bfd475","timestamp":"2026-04-03T20:11:38.007Z"}
