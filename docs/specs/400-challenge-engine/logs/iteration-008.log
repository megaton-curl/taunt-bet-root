{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014SjX6FUeCMgfUmZVcSf7R6","type":"tool_result","content":"1\t/**\n2\t * CRATE_DROP handler — rolls for a loot crate drop after a settled game.\n3\t *\n4\t * Drop logic per player per settled game:\n5\t *   roll = random()\n6\t *   if roll < sol_crate_drop_rate AND pool can fund:  → SOL crate\n7\t *   elif roll < sol_crate_drop_rate + points_crate_drop_rate:  → Points crate\n8\t *   else: no drop\n9\t *\n10\t * SOL crate is checked first (higher value, lower probability). If pool can't\n11\t * fund it, the roll is wasted (no fallback to points crate).\n12\t *\n13\t * Idempotent via UNIQUE(user_id, trigger_type, trigger_id) on crate_drops.\n14\t */\n15\t\n16\timport type { Db } from \"../../db.js\";\n17\timport { logger } from \"../../logger.js\";\n18\timport { readRewardConfig } from \"./reward-pool-fund.js\";\n19\timport { emitEvent } from \"../emit-event.js\";\n20\timport { EventTypes } from \"../event-types.js\";\n21\t\n22\t// ---------------------------------------------------------------------------\n23\t// DB helpers\n24\t// ---------------------------------------------------------------------------\n25\t\n26\texport interface RewardPoolRow {\n27\t  balance_lamports: string;\n28\t  lifetime_paid: string;\n29\t}\n30\t\n31\t/**\n32\t * Lock the reward_pool singleton row for update and return its current state.\n33\t * Must be called within a transaction.\n34\t */\n35\texport async function lockAndReadRewardPool(\n36\t  db: Db,\n37\t): Promise<RewardPoolRow> {\n38\t  const rows = await db.rawSql<RewardPoolRow[]>`\n39\t    SELECT balance_lamports, lifetime_paid\n40\t    FROM reward_pool\n41\t    WHERE id = 1\n42\t    FOR UPDATE\n43\t  `;\n44\t  if (rows.length === 0) {\n45\t    throw new Error(\"crate.drop: reward_pool singleton row missing\");\n46\t  }\n47\t  return rows[0]!;\n48\t}\n49\t\n50\t/**\n51\t * Atomically decrement reward_pool.balance_lamports and increment lifetime_paid.\n52\t * Must be called within a transaction after locking the row.\n53\t */\n54\texport async function decrementRewardPool(\n55\t  db: Db,\n56\t  payoutLamports: bigint,\n57\t): Promise<void> {\n58\t  await db.rawSql`\n59\t    UPDATE reward_pool\n60\t    SET balance_lamports = balance_lamports - ${payoutLamports},\n61\t        lifetime_paid    = lifetime_paid + ${payoutLamports},\n62\t        updated_at       = now()\n63\t    WHERE id = 1\n64\t  `;\n65\t}\n66\t\n67\t/**\n68\t * Insert a crate drop record. Returns false if a row for this\n69\t * (user_id, trigger_type, trigger_id) already exists (idempotency guard).\n70\t */\n71\texport async function insertCrateDrop(\n72\t  db: Db,\n73\t  userId: string,\n74\t  triggerType: string,\n75\t  triggerId: string,\n76\t  crateType: string,\n77\t  contentsAmount: string,\n78\t): Promise<boolean> {\n79\t  const rows = await db.rawSql<{ id: string }[]>`\n80\t    INSERT INTO crate_drops (user_id, trigger_type, trigger_id, crate_type, contents_amount)\n81\t    VALUES (${userId}, ${triggerType}, ${triggerId}, ${crateType}, ${contentsAmount})\n82\t    ON CONFLICT (user_id, trigger_type, trigger_id) DO NOTHING\n83\t    RETURNING id\n84\t  `;\n85\t  return rows.length > 0;\n86\t}\n87\t\n88\t// ---------------------------------------------------------------------------\n89\t// Handler factory\n90\t// ---------------------------------------------------------------------------\n91\t\n92\texport interface CrateDropDeps {\n93\t  db: Db;\n94\t  /** Injectable RNG for deterministic testing. Returns a number in [0, 1). */\n95\t  rollRng?: () => number;\n96\t}\n97\t\n98\texport function createCrateDropHandler(deps: CrateDropDeps) {\n99\t  const { db, rollRng = Math.random } = deps;\n100\t\n101\t  return async (payload: Record<string, unknown>): Promise<void> => {\n102\t    const userId = payload.userId as string;\n103\t    const wallet = payload.wallet as string;\n104\t    const triggerType = payload.triggerType as string;\n105\t    const triggerId = payload.triggerId as string;\n106\t\n107\t    if (!userId || !wallet || !triggerType || !triggerId) {\n108\t      throw new Error(\n109\t        \"crate.drop: malformed payload — missing userId, wallet, triggerType, or triggerId\",\n110\t      );\n111\t    }\n112\t\n113\t    // Read all config values upfront (outside transaction to minimise lock time)\n114\t    const [\n115\t      solDropRateStr,\n116\t      pointsDropRateStr,\n117\t      solPoolPctStr,\n118\t      solMinValueStr,\n119\t      pointsCrateMinStr,\n120\t      pointsCrateMaxStr,\n121\t    ] = await Promise.all([\n122\t      readRewardConfig(db, \"sol_crate_drop_rate\"),\n123\t      readRewardConfig(db, \"points_crate_drop_rate\"),\n124\t      readRewardConfig(db, \"sol_crate_pool_pct\"),\n125\t      readRewardConfig(db, \"sol_crate_min_value\"),\n126\t      readRewardConfig(db, \"points_crate_min\"),\n127\t      readRewardConfig(db, \"points_crate_max\"),\n128\t    ]);\n129\t\n130\t    const solDropRate = parseFloat(solDropRateStr ?? \"0\");\n131\t    const pointsDropRate = parseFloat(pointsDropRateStr ?? \"0\");\n132\t    const solPoolPct = parseFloat(solPoolPctStr ?? \"0\");\n133\t    const solMinValue = BigInt(solMinValueStr ?? \"0\");\n134\t    const pointsCrateMin = parseInt(pointsCrateMinStr ?? \"0\", 10);\n135\t    const pointsCrateMax = parseInt(pointsCrateMaxStr ?? \"0\", 10);\n136\t\n137\t    // Roll RNG\n138\t    const roll = rollRng();\n139\t\n140\t    if (roll < solDropRate) {\n141\t      // --- SOL crate path ---\n142\t      await db.withTransaction(async (txDb) => {\n143\t        // Lock pool row\n144\t        const pool = await lockAndReadRewardPool(txDb);\n145\t        const poolBalance = BigInt(pool.balance_lamports);\n146\t\n147\t        // Calculate payout: floor(balance * sol_crate_pool_pct)\n148\t        const payoutLamports = BigInt(\n149\t          Math.floor(Number(poolBalance) * solPoolPct),\n150\t        );\n151\t\n152\t        // Suppress if payout < min_value\n153\t        if (payoutLamports < solMinValue) {\n154\t          logger.info(\"crate.drop: SOL crate suppressed — pool below min\", {\n155\t            userId,\n156\t            triggerId,\n157\t            poolBalance: poolBalance.toString(),\n158\t            payoutLamports: payoutLamports.toString(),\n159\t            solMinValue: solMinValue.toString(),\n160\t          });\n161\t          return;\n162\t        }\n163\t\n164\t        // Insert crate record (idempotency guard)\n165\t        const inserted = await insertCrateDrop(\n166\t          txDb,\n167\t          userId,\n168\t          triggerType,\n169\t          triggerId,\n170\t          \"sol\",\n171\t          payoutLamports.toString(),\n172\t        );\n173\t        if (!inserted) {\n174\t          logger.info(\"crate.drop: duplicate crate, skipping\", {\n175\t            userId,\n176\t            triggerType,\n177\t            triggerId,\n178\t          });\n179\t          return;\n180\t        }\n181\t\n182\t        // Decrement pool\n183\t        await decrementRewardPool(txDb, payoutLamports);\n184\t\n185\t        // Emit CRATE_SOL_PAYOUT for async SOL transfer\n186\t        await emitEvent(txDb.rawSql, EventTypes.CRATE_SOL_PAYOUT, {\n187\t          userId,\n188\t          wallet,\n189\t          payoutLamports: payoutLamports.toString(),\n190\t          triggerId,\n191\t        });\n192\t\n193\t        logger.info(\"crate.drop: SOL crate dropped\", {\n194\t          userId,\n195\t          triggerId,\n196\t          payoutLamports: payoutLamports.toString(),\n197\t        });\n198\t      });\n199\t    } else if (roll < solDropRate + pointsDropRate) {\n200\t      // --- Points crate path ---\n201\t      const range = pointsCrateMax - pointsCrateMin;\n202\t      const pointsAmount =\n203\t        range > 0\n204\t          ? pointsCrateMin + Math.floor(rollRng() * (range + 1))\n205\t          : pointsCrateMin;\n206\t\n207\t      await db.withTransaction(async (txDb) => {\n208\t        // Insert crate record (idempotency guard)\n209\t        const inserted = await insertCrateDrop(\n210\t          txDb,\n211\t          userId,\n212\t          triggerType,\n213\t          triggerId,\n214\t          \"points\",\n215\t          pointsAmount.toString(),\n216\t        );\n217\t        if (!inserted) {\n218\t          logger.info(\"crate.drop: duplicate crate, skipping\", {\n219\t            userId,\n220\t            triggerType,\n221\t            triggerId,\n222\t          });\n223\t          return;\n224\t        }\n225\t\n226\t        // Emit POINTS_GRANT with source_type='crate_points'\n227\t        await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n228\t          userId,\n229\t          wallet,\n230\t          sourceType: \"crate_points\",\n231\t          sourceId: `crate-${triggerId}`,\n232\t          amount: pointsAmount.toString(),\n233\t        });\n234\t\n235\t        logger.info(\"crate.drop: points crate dropped\", {\n236\t          userId,\n237\t          triggerId,\n238\t          pointsAmount,\n239\t        });\n240\t      });\n241\t    } else {\n242\t      // --- Miss: no drop ---\n243\t      logger.debug(\"crate.drop: no drop\", { userId, triggerId, roll });\n244\t    }\n245\t  };\n246\t}\n247\t"}]},"parent_tool_use_id":"toolu_01VJQ4sBf1vsrCZSieVM4qX6","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"e2a9e7b2-90bf-4a25-a6ea-66840bffa484","timestamp":"2026-04-03T20:11:41.284Z"}
