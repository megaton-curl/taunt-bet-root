{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CP92KC5QUSvYQnx5hsMCaM","type":"tool_result","content":"850\t    });\n851\t    await rawSql`INSERT INTO referral_kol_rates (user_id, wallet, rate_bps, set_by) VALUES (${referrerUserId}, ${referrerWallet}, 2000, 'admin')`;\n852\t\n853\t    // Create + settle a coinflip match\n854\t    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n855\t    const createRes = await app.request(\"/coinflip/create\", {\n856\t      method: \"POST\",\n857\t      headers: {\n858\t        \"Content-Type\": \"application/json\",\n859\t        \"Authorization\": `Bearer ${token}`,\n860\t      },\n861\t      body: JSON.stringify({\n862\t        wallet: creatorWallet,\n863\t        amountLamports: AMOUNT_LAMPORTS,\n864\t        side: SIDE_HEADS,\n865\t      }),\n866\t    });\n867\t    expect(createRes.status).toBe(200);\n868\t    const createJson = (await createRes.json()) as {\n869\t      matchPda: string;\n870\t      matchId: string;\n871\t      commitment: string;\n872\t    };\n873\t\n874\t    const matchPubkey = new PublicKey(createJson.matchPda);\n875\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n876\t\n877\t    const matchAccountData = await buildMatchAccountData({\n878\t      creator: creatorKeypair.publicKey,\n879\t      opponent: opponentKeypair.publicKey,\n880\t      server: serverKeypair.publicKey,\n881\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n882\t      creatorSide: SIDE_HEADS,\n883\t      phase: PHASE_LOCKED,\n884\t      commitment: commitmentBuf,\n885\t      algorithmVer: 1,\n886\t      targetSlot: 150n,\n887\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n888\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n889\t    });\n890\t\n891\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n892\t      owner: COINFLIP_PROGRAM_ID,\n893\t    });\n894\t    mockConn.slot = 200;\n895\t\n896\t    let settlePromise2: Promise<void> | null = null;\n897\t\n898\t    const retrySettler = createRetrySettler({\n899\t      db,\n900\t      connection: mockConn as unknown as Connection,\n901\t      settleRound: (pda) =>\n902\t        settleMatch(\n903\t          {\n904\t            db,\n905\t            connection: mockConn as unknown as Connection,\n906\t            serverKeypair,\n907\t            entropyAccount,\n908\t            referralDefaultRateBps: 1000,\n909\t          },\n910\t          pda,\n911\t        ),\n912\t    });\n913\t\n914\t    const worker = createSettlementWorker({\n915\t      db,\n916\t      connection: mockConn as unknown as Connection,\n917\t      serverKey: serverKeypair.publicKey,\n918\t      pollIntervalMs: 60_000,\n919\t      onSettleReady: (pda) => {\n920\t        settlePromise2 = retrySettler.attemptSettle(pda);\n921\t        return settlePromise2;\n922\t      },\n923\t    });\n924\t\n925\t    await worker.poll();\n926\t    if (settlePromise2) await settlePromise2;\n927\t\n928\t    // Verify settlement completed\n929\t    const settled = await db.getRoundByPda(createJson.matchPda);\n930\t    expect(settled!.phase).toBe(\"settled\");\n931\t\n932\t    // Verify KOL rate was used for referrer earning\n933\t    // fee = 5_000_000 * 500 / 10_000 = 250_000\n934\t    // referrer_earned = 250_000 * 2000 / 10_000 = 50_000 (KOL rate)\n935\t    // referee_rebate = 250_000 * 1000 / 10_000 = 25_000 (always fixed 10%)\n936\t    const earnings =\n937\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n938\t    expect(earnings.length).toBe(1);\n939\t\n940\t    const earning = earnings[0]!;\n941\t    expect(Number(earning.referrer_earned_lamports)).toBe(50_000); // KOL: 2000 bps\n942\t    expect(Number(earning.referrer_rate_bps)).toBe(2000);\n943\t    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // Fixed 10%\n944\t    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n945\t  });\n946\t\n947\t  it(\"settlement emits game.settled event with correct payload shape\", async () => {\n948\t    const wallet = creatorKeypair.publicKey.toBase58();\n949\t    const token = await makeJwt(wallet);\n950\t\n951\t    // Create profiles for both players so game entries + event payloads get user IDs\n952\t    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n953\t    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n954\t    await rawSql`\n955\t      INSERT INTO player_profiles (user_id, wallet, username)\n956\t      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n957\t      ON CONFLICT (user_id) DO NOTHING\n958\t    `;\n959\t    await rawSql`\n960\t      INSERT INTO player_profiles (user_id, wallet, username)\n961\t      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n962\t      ON CONFLICT (user_id) DO NOTHING\n963\t    `;\n964\t\n965\t    // Create round via API\n966\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n967\t    const createRes = await app.request(\"/coinflip/create\", {\n968\t      method: \"POST\",\n969\t      headers: {\n970\t        \"Content-Type\": \"application/json\",\n971\t        Authorization: `Bearer ${token}`,\n972\t      },\n973\t      body: JSON.stringify(body),\n974\t    });\n975\t    expect(createRes.status).toBe(200);\n976\t    const createJson = (await createRes.json()) as {\n977\t      matchPda: string;\n978\t      matchId: string;\n979\t      commitment: string;\n980\t    };\n981\t\n982\t    // Simulate on-chain join — LOCKED match in mock\n983\t    const matchPubkey = new PublicKey(createJson.matchPda);\n984\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n985\t    const matchAccountData = await buildMatchAccountData({\n986\t      creator: creatorKeypair.publicKey,\n987\t      opponent: opponentKeypair.publicKey,\n988\t      server: serverKeypair.publicKey,\n989\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n990\t      creatorSide: SIDE_HEADS,\n991\t      phase: PHASE_LOCKED,\n992\t      commitment: commitmentBuf,\n993\t      algorithmVer: 1,\n994\t      targetSlot: 150n,\n995\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n996\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n997\t    });\n998\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n999\t      owner: COINFLIP_PROGRAM_ID,"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"48c216ad-4f13-468d-8c3c-7b233e69a242","timestamp":"2026-04-03T20:11:40.759Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016tRqBL2oz2Fhw4t6TmfSgi","type":"tool_result","content":"1\t/**\n2\t * Challenge verification adapters and quest eligibility check.\n3\t *\n4\t * quest_eligible() gates whether a settled game counts toward challenges,\n5\t * points, and crate drops. Refunded games (isWinner === null) are excluded.\n6\t *\n7\t * Each adapter evaluates whether a game.settled event advances a player's\n8\t * challenge progress. Adapters are pure functions of (event, player, assignment)\n9\t * — no side effects beyond the returned result.\n10\t */\n11\t\n12\timport { logger } from \"../../logger.js\";\n13\t\n14\t// ---------------------------------------------------------------------------\n15\t// Types\n16\t// ---------------------------------------------------------------------------\n17\t\n18\t/** A single player entry from the game.settled event payload. */\n19\texport interface GameSettledPlayer {\n20\t  userId: string;\n21\t  wallet: string;\n22\t  amountLamports: string;\n23\t  isWinner: boolean | null; // null = refund\n24\t  payoutLamports: string;\n25\t  isCreator: boolean;\n26\t}\n27\t\n28\t/** The game.settled event payload shape. */\n29\texport interface GameSettledPayload {\n30\t  roundId: string;\n31\t  roundPda: string;\n32\t  game: \"coinflip\" | \"lord\" | \"closecall\";\n33\t  players: GameSettledPlayer[];\n34\t  feeLamports: string;\n35\t  settledAt: string;\n36\t}\n37\t\n38\t/** A challenge assignment with its challenge definition. */\n39\texport interface ChallengeAssignment {\n40\t  id: number;\n41\t  challengeId: number;\n42\t  action: string;\n43\t  scope: string; // 'any' | 'coinflip' | 'lord' | 'closecall'\n44\t  condition: string;\n45\t  target: number;\n46\t  progress: number;\n47\t  status: string;\n48\t}\n49\t\n50\t/** Result from a verification adapter. */\n51\texport interface AdapterResult {\n52\t  shouldProgress: boolean;\n53\t  progressDelta: number;\n54\t}\n55\t\n56\t/** Verification adapter function signature. */\n57\texport type VerificationAdapter = (\n58\t  event: GameSettledPayload,\n59\t  player: GameSettledPlayer,\n60\t  assignment: ChallengeAssignment,\n61\t) => AdapterResult;\n62\t\n63\t// ---------------------------------------------------------------------------\n64\t// Quest Eligibility\n65\t// ---------------------------------------------------------------------------\n66\t\n67\t/**\n68\t * Returns false when the game was refunded (isWinner === null), true otherwise.\n69\t * Games that fail this check are skipped for challenge progress, points, AND\n70\t * crate drops. The game still counts for normal gameplay.\n71\t */\n72\texport function questEligible(\n73\t  player: GameSettledPlayer,\n74\t): boolean {\n75\t  return player.isWinner !== null;\n76\t}\n77\t\n78\t// ---------------------------------------------------------------------------\n79\t// Adapters\n80\t// ---------------------------------------------------------------------------\n81\t\n82\tfunction matchesScope(game: string, scope: string): boolean {\n83\t  return scope === \"any\" || scope === game;\n84\t}\n85\t\n86\tconst NO_PROGRESS: AdapterResult = { shouldProgress: false, progressDelta: 0 };\n87\tconst ONE_PROGRESS: AdapterResult = { shouldProgress: true, progressDelta: 1 };\n88\t\n89\t/**\n90\t * game_completed: player participated in a settled game.\n91\t * Optionally filtered by scope (game type).\n92\t */\n93\tfunction gameCompletedAdapter(\n94\t  event: GameSettledPayload,\n95\t  _player: GameSettledPlayer,\n96\t  assignment: ChallengeAssignment,\n97\t): AdapterResult {\n98\t  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n99\t  return ONE_PROGRESS;\n100\t}\n101\t\n102\t/**\n103\t * game_won: player won a settled game.\n104\t * Requires isWinner === true and game matches scope.\n105\t */\n106\tfunction gameWonAdapter(\n107\t  event: GameSettledPayload,\n108\t  player: GameSettledPlayer,\n109\t  assignment: ChallengeAssignment,\n110\t): AdapterResult {\n111\t  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n112\t  if (player.isWinner !== true) return NO_PROGRESS;\n113\t  return ONE_PROGRESS;\n114\t}\n115\t\n116\t/**\n117\t * lobby_filled: player created a game that was filled and settled.\n118\t * Requires isCreator === true.\n119\t */\n120\tfunction lobbyFilledAdapter(\n121\t  event: GameSettledPayload,\n122\t  player: GameSettledPlayer,\n123\t  assignment: ChallengeAssignment,\n124\t): AdapterResult {\n125\t  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n126\t  if (!player.isCreator) return NO_PROGRESS;\n127\t  return ONE_PROGRESS;\n128\t}\n129\t\n130\t// ---------------------------------------------------------------------------\n131\t// Adapter Registry\n132\t// ---------------------------------------------------------------------------\n133\t\n134\tconst adapterRegistry = new Map<string, VerificationAdapter>([\n135\t  [\"game_completed\", gameCompletedAdapter],\n136\t  [\"game_won\", gameWonAdapter],\n137\t  [\"lobby_filled\", lobbyFilledAdapter],\n138\t]);\n139\t\n140\t/**\n141\t * Look up a verification adapter by action type.\n142\t * Unknown action types log a warning and return a no-op adapter.\n143\t */\n144\texport function getAdapter(action: string): VerificationAdapter {\n145\t  const adapter = adapterRegistry.get(action);\n146\t  if (!adapter) {\n147\t    logger.warn(\"Unknown challenge adapter action type\", { action });\n148\t    return () => NO_PROGRESS;\n149\t  }\n150\t  return adapter;\n151\t}\n152\t"}]},"parent_tool_use_id":"toolu_01VJQ4sBf1vsrCZSieVM4qX6","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"e58e67f4-3f71-42ec-bd04-22a965d25595","timestamp":"2026-04-03T20:11:40.594Z"}
