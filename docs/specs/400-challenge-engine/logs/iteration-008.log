{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cb1XXYAUNcgspqtrsGBrPw","type":"tool_result","content":"550\t          },\n551\t          pda,\n552\t        ),\n553\t    });\n554\t\n555\t    const worker = createSettlementWorker({\n556\t      db,\n557\t      connection: mockConn as unknown as Connection,\n558\t      serverKey: serverKeypair.publicKey,\n559\t      pollIntervalMs: 60_000, // won't auto-poll\n560\t      onSettleReady: (pda) => {\n561\t        settlePromise = retrySettler.attemptSettle(pda);\n562\t        return settlePromise;\n563\t      },\n564\t    });\n565\t\n566\t    // Single poll cycle — should discover locked match and settle it\n567\t    await worker.poll();\n568\t    if (settlePromise) await settlePromise;\n569\t\n570\t    // ------------------------------------------------------------------\n571\t    // 5. Verify DB updated to \"settled\" with result data\n572\t    // ------------------------------------------------------------------\n573\t    const settled = await db.getRoundByPda(matchPda);\n574\t    expect(settled).toBeDefined();\n575\t    expect(settled!.phase).toBe(\"settled\");\n576\t    expect(settled!.settle_tx).toBeDefined();\n577\t    expect(settled!.result_hash).toBeDefined();\n578\t    expect(settled!.result_hash!.length).toBe(32);\n579\t    expect(settled!.result_side).toBeDefined();\n580\t    expect([0, 1]).toContain(settled!.result_side);\n581\t    expect(settled!.winner).toBeDefined();\n582\t\n583\t    // Winner should be one of the two players\n584\t    expect([\n585\t      creatorKeypair.publicKey.toBase58(),\n586\t      opponentKeypair.publicKey.toBase58(),\n587\t    ]).toContain(settled!.winner);\n588\t\n589\t    // Verify operator events trail\n590\t    const allEvents =\n591\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n592\t    const eventTypes = allEvents.map(\n593\t      (e) => (e as Record<string, unknown>).event_type,\n594\t    );\n595\t    expect(eventTypes).toContain(\"secret_generated\");\n596\t    expect(eventTypes).toContain(\"match_detected\");\n597\t    expect(eventTypes).toContain(\"settle_submitted\");\n598\t    expect(eventTypes).toContain(\"settle_confirmed\");\n599\t\n600\t    // ------------------------------------------------------------------\n601\t    // 6. GET /rounds/:pda — verify response includes secret\n602\t    // ------------------------------------------------------------------\n603\t    const roundsRes = await app.request(`/rounds/${matchPda}`);\n604\t    expect(roundsRes.status).toBe(200);\n605\t\n606\t    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n607\t    expect(roundsJson.pda).toBe(matchPda);\n608\t    expect(roundsJson.phase).toBe(\"settled\");\n609\t    expect(roundsJson.game).toBe(\"coinflip\");\n610\t    expect(roundsJson.creator).toBe(wallet);\n611\t    expect(roundsJson.commitment).toBe(commitmentHex);\n612\t\n613\t    // Settled round should include secret + verification payload\n614\t    expect(roundsJson.secret).toBeDefined();\n615\t    expect(typeof roundsJson.secret).toBe(\"string\");\n616\t    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n617\t    expect(roundsJson.resultHash).toBeDefined();\n618\t    expect(roundsJson.resultSide).toBeDefined();\n619\t    expect(roundsJson.winner).toBeDefined();\n620\t    expect(roundsJson.settleTx).toBeDefined();\n621\t\n622\t    // Verification object\n623\t    const verification = roundsJson.verification as Record<string, string>;\n624\t    expect(verification).toBeDefined();\n625\t    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n626\t    expect(verification.resultFormula).toContain(\"sha256(secret\");\n627\t    expect(verification.entropySource).toContain(\"SlotHashes\");\n628\t  });\n629\t\n630\t  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n631\t    const unknownPda = Keypair.generate().publicKey.toBase58();\n632\t    const res = await app.request(`/rounds/${unknownPda}`);\n633\t    expect(res.status).toBe(404);\n634\t  });\n635\t\n636\t  it(\"unsettled round does not expose secret\", async () => {\n637\t    const wallet = creatorKeypair.publicKey.toBase58();\n638\t    const token = await makeJwt(wallet);\n639\t\n640\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n641\t\n642\t    const res = await app.request(\"/coinflip/create\", {\n643\t      method: \"POST\",\n644\t      headers: {\n645\t        \"Content-Type\": \"application/json\",\n646\t        \"Authorization\": `Bearer ${token}`,\n647\t      },\n648\t      body: JSON.stringify(body),\n649\t    });\n650\t    expect(res.status).toBe(200);\n651\t    const json = (await res.json()) as { matchPda: string };\n652\t\n653\t    // GET the unsettled round\n654\t    const roundRes = await app.request(`/rounds/${json.matchPda}`);\n655\t    expect(roundRes.status).toBe(200);\n656\t    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n657\t    expect(roundJson.phase).toBe(\"created\");\n658\t    expect(roundJson.secret).toBeUndefined();\n659\t    expect(roundJson.resultHash).toBeUndefined();\n660\t    expect(roundJson.verification).toBeUndefined();\n661\t  });\n662\t\n663\t  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n664\t    const wallet = creatorKeypair.publicKey.toBase58();\n665\t    const token = await makeJwt(wallet);\n666\t\n667\t    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n668\t    const res1 = await app.request(\"/coinflip/create\", {\n669\t      method: \"POST\",\n670\t      headers: {\n671\t        \"Content-Type\": \"application/json\",\n672\t        \"Authorization\": `Bearer ${token}`,\n673\t      },\n674\t      body: JSON.stringify(body1),\n675\t    });\n676\t    expect(res1.status).toBe(200);\n677\t\n678\t    // Second request — different random matchId generated server-side\n679\t    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n680\t    const res2 = await app.request(\"/coinflip/create\", {\n681\t      method: \"POST\",\n682\t      headers: {\n683\t        \"Content-Type\": \"application/json\",\n684\t        \"Authorization\": `Bearer ${token}`,\n685\t      },\n686\t      body: JSON.stringify(body2),\n687\t    });\n688\t    expect(res2.status).toBe(200);\n689\t\n690\t    // Both should have different matchIds and PDAs\n691\t    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n692\t    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n693\t    expect(json1.matchPda).not.toBe(json2.matchPda);\n694\t    expect(json1.matchId).not.toBe(json2.matchId);\n695\t  });\n696\t\n697\t  it(\"settlement records referral earnings for referred player\", async () => {\n698\t    // Referrer is a third party; opponent is the referred player\n699\t    const referrerKeypair = Keypair.generate();"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"bbb997f5-607a-43a6-9bf9-f1e3b17429d5","timestamp":"2026-04-03T20:11:40.292Z"}
