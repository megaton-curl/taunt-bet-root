{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VJSEgyBL7pNS3XsQ4ssurH","type":"tool_result","content":"1450\t    // Insert an active Dogpile event covering now\n1451\t    const now = new Date();\n1452\t    const startsAt = new Date(now.getTime() - 60_000); // started 1 min ago\n1453\t    const endsAt = new Date(now.getTime() + 60_000);   // ends in 1 min\n1454\t    await rawSql`\n1455\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n1456\t      VALUES (${startsAt}, ${endsAt}, 2.0, 'active')\n1457\t    `;\n1458\t\n1459\t    const handler = createPointsGrantHandler({\n1460\t      db,\n1461\t      getSolPrice: async () => 100,\n1462\t    });\n1463\t\n1464\t    const userId = \"usr_dogpiletest1\";\n1465\t    const wallet = \"DogpileTestWallet111111111111111111111111\";\n1466\t    const sourceId = \"test-round-dogpile-001\";\n1467\t\n1468\t    await handler({\n1469\t      userId,\n1470\t      wallet,\n1471\t      sourceType: \"wager\",\n1472\t      sourceId,\n1473\t      amountLamports: \"50000000\", // 0.05 SOL\n1474\t      settledAt: now.toISOString(),\n1475\t    });\n1476\t\n1477\t    // Expected: 0.05 SOL * $100 = $5.00 * 500 * 2.0 dogpile = 5000 points\n1478\t    const expectedPoints = 5000n;\n1479\t\n1480\t    const grants = await rawSql<{ amount: string; metadata: string }[]>`\n1481\t      SELECT amount, metadata FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n1482\t    `;\n1483\t    expect(grants.length).toBe(1);\n1484\t    expect(BigInt(grants[0]!.amount)).toBe(expectedPoints);\n1485\t    const dogpileMeta = typeof grants[0]!.metadata === \"string\"\n1486\t      ? JSON.parse(grants[0]!.metadata) : grants[0]!.metadata;\n1487\t    expect(dogpileMeta).toMatchObject({ multiplier: 2 });\n1488\t\n1489\t    const pp = await rawSql<{ balance: string }[]>`\n1490\t      SELECT balance FROM player_points WHERE user_id = ${userId}\n1491\t    `;\n1492\t    expect(BigInt(pp[0]!.balance)).toBe(expectedPoints);\n1493\t  });\n1494\t\n1495\t  it(\"points.grant handler: handles pre-calculated crate_points grant\", async () => {\n1496\t    const handler = createPointsGrantHandler({\n1497\t      db,\n1498\t      getSolPrice: async () => 100,\n1499\t    });\n1500\t\n1501\t    const userId = \"usr_cratepoints1\";\n1502\t    const wallet = \"CratePointsWallet11111111111111111111111\";\n1503\t    const sourceId = \"crate-drop-001\";\n1504\t\n1505\t    await handler({\n1506\t      userId,\n1507\t      wallet,\n1508\t      sourceType: \"crate_points\",\n1509\t      sourceId,\n1510\t      amount: \"3000\",\n1511\t    });\n1512\t\n1513\t    const grants = await rawSql<{ amount: string; source_type: string }[]>`\n1514\t      SELECT amount, source_type FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n1515\t    `;\n1516\t    expect(grants.length).toBe(1);\n1517\t    expect(grants[0]!.source_type).toBe(\"crate_points\");\n1518\t    expect(BigInt(grants[0]!.amount)).toBe(3000n);\n1519\t\n1520\t    const pp = await rawSql<{ balance: string; lifetime_earned: string }[]>`\n1521\t      SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n1522\t    `;\n1523\t    expect(pp.length).toBe(1);\n1524\t    expect(BigInt(pp[0]!.balance)).toBe(3000n);\n1525\t    expect(BigInt(pp[0]!.lifetime_earned)).toBe(3000n);\n1526\t  });\n1527\t\n1528\t  // -----------------------------------------------------------------------\n1529\t  // CRATE_DROP handler tests\n1530\t  // -----------------------------------------------------------------------\n1531\t\n1532\t  it(\"crate.drop handler: SOL crate hit — decrements pool, creates crate row, emits sol_payout\", async () => {\n1533\t    // Fund the reward pool so a SOL crate can be funded\n1534\t    // sol_crate_min_value is 10_000_000 (10M lamports = 0.01 SOL)\n1535\t    // sol_crate_pool_pct is 0.10 → need pool >= 100_000_000 to get payout >= 10M\n1536\t    await rawSql`UPDATE reward_pool SET balance_lamports = 200000000, lifetime_funded = 200000000 WHERE id = 1`;\n1537\t\n1538\t    // Roll = 0.005, which is < sol_crate_drop_rate (0.01) → SOL crate hit\n1539\t    const handler = createCrateDropHandler({\n1540\t      db,\n1541\t      rollRng: () => 0.005,\n1542\t    });\n1543\t\n1544\t    const userId = \"usr_cratesol1\";\n1545\t    const wallet = \"CrateSolWallet1111111111111111111111111\";\n1546\t    const triggerId = \"test-round-crate-sol-001\";\n1547\t\n1548\t    await handler({\n1549\t      userId,\n1550\t      wallet,\n1551\t      triggerType: \"game_settled\",\n1552\t      triggerId,\n1553\t    });\n1554\t\n1555\t    // Expected payout: floor(200_000_000 * 0.10) = 20_000_000\n1556\t    const expectedPayout = 20_000_000n;\n1557\t\n1558\t    // Verify crate_drops row\n1559\t    const crates = await rawSql<{\n1560\t      user_id: string;\n1561\t      trigger_type: string;\n1562\t      trigger_id: string;\n1563\t      crate_type: string;\n1564\t      contents_amount: string;\n1565\t      status: string;\n1566\t    }[]>`\n1567\t      SELECT user_id, trigger_type, trigger_id, crate_type, contents_amount, status\n1568\t      FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1569\t    `;\n1570\t    expect(crates.length).toBe(1);\n1571\t    expect(crates[0]!.crate_type).toBe(\"sol\");\n1572\t    expect(BigInt(crates[0]!.contents_amount)).toBe(expectedPayout);\n1573\t    expect(crates[0]!.status).toBe(\"pending\");\n1574\t\n1575\t    // Verify pool decremented\n1576\t    const pool = await rawSql<{ balance_lamports: string; lifetime_paid: string }[]>`\n1577\t      SELECT balance_lamports, lifetime_paid FROM reward_pool WHERE id = 1\n1578\t    `;\n1579\t    expect(BigInt(pool[0]!.balance_lamports)).toBe(200_000_000n - expectedPayout);\n1580\t    expect(BigInt(pool[0]!.lifetime_paid)).toBe(expectedPayout);\n1581\t\n1582\t    // Verify CRATE_SOL_PAYOUT event emitted\n1583\t    const events = await rawSql<{ event_type: string; payload: string }[]>`\n1584\t      SELECT event_type, payload FROM event_queue WHERE event_type = 'crate.sol_payout'\n1585\t    `;\n1586\t    expect(events.length).toBe(1);\n1587\t    const eventPayload = typeof events[0]!.payload === \"string\"\n1588\t      ? JSON.parse(events[0]!.payload) : events[0]!.payload;\n1589\t    expect(eventPayload.userId).toBe(userId);\n1590\t    expect(eventPayload.wallet).toBe(wallet);\n1591\t    expect(eventPayload.payoutLamports).toBe(expectedPayout.toString());\n1592\t  });\n1593\t\n1594\t  it(\"crate.drop handler: points crate hit — creates crate row, emits points.grant\", async () => {\n1595\t    // Roll = 0.02, which is >= sol_crate_drop_rate (0.01) but < 0.01 + 0.05 = 0.06 → points crate\n1596\t    // Second roll for points amount: 0.5 → min + floor(0.5 * (max - min + 1)) = 500 + floor(0.5 * 4501) = 500 + 2250 = 2750\n1597\t    const rolls = [0.02, 0.5];\n1598\t    let rollIdx = 0;\n1599\t    const handler = createCrateDropHandler({\n1600\t      db,\n1601\t      rollRng: () => rolls[rollIdx++]!,\n1602\t    });\n1603\t\n1604\t    const userId = \"usr_cratepoints2\";\n1605\t    const wallet = \"CratePointsWallet2111111111111111111111\";\n1606\t    const triggerId = \"test-round-crate-pts-001\";\n1607\t\n1608\t    await handler({\n1609\t      userId,\n1610\t      wallet,\n1611\t      triggerType: \"game_settled\",\n1612\t      triggerId,\n1613\t    });\n1614\t\n1615\t    // Expected points: 500 + floor(0.5 * (5000 - 500 + 1)) = 500 + 2250 = 2750\n1616\t    const expectedPoints = 2750;\n1617\t\n1618\t    // Verify crate_drops row\n1619\t    const crates = await rawSql<{\n1620\t      crate_type: string;\n1621\t      contents_amount: string;\n1622\t    }[]>`\n1623\t      SELECT crate_type, contents_amount\n1624\t      FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1625\t    `;\n1626\t    expect(crates.length).toBe(1);\n1627\t    expect(crates[0]!.crate_type).toBe(\"points\");\n1628\t    expect(parseInt(crates[0]!.contents_amount, 10)).toBe(expectedPoints);\n1629\t\n1630\t    // Verify POINTS_GRANT event emitted\n1631\t    const events = await rawSql<{ event_type: string; payload: string }[]>`\n1632\t      SELECT event_type, payload FROM event_queue WHERE event_type = 'points.grant'\n1633\t    `;\n1634\t    expect(events.length).toBe(1);\n1635\t    const eventPayload = typeof events[0]!.payload === \"string\"\n1636\t      ? JSON.parse(events[0]!.payload) : events[0]!.payload;\n1637\t    expect(eventPayload.userId).toBe(userId);\n1638\t    expect(eventPayload.sourceType).toBe(\"crate_points\");\n1639\t    expect(eventPayload.sourceId).toBe(`crate-${triggerId}`);\n1640\t    expect(eventPayload.amount).toBe(expectedPoints.toString());\n1641\t  });\n1642\t\n1643\t  it(\"crate.drop handler: miss — no crate row created\", async () => {\n1644\t    // Roll = 0.50, which is >= sol_crate_drop_rate + points_crate_drop_rate (0.06) → miss\n1645\t    const handler = createCrateDropHandler({\n1646\t      db,\n1647\t      rollRng: () => 0.50,\n1648\t    });\n1649\t"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"725adc05-eaed-43ba-a171-e39705addb38","timestamp":"2026-04-03T20:11:45.837Z"}
