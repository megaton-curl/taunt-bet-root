{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018g5iz7rg98puDsnYS3wyEM","type":"tool_result","content":"380\t    await rawSql`\n381\t      CREATE TABLE referral_kol_rates (\n382\t        user_id TEXT PRIMARY KEY,\n383\t        wallet TEXT NOT NULL UNIQUE,\n384\t        rate_bps INTEGER NOT NULL,\n385\t        set_by TEXT NOT NULL,\n386\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n387\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n388\t      )\n389\t    `;\n390\t    db = createDb(DATABASE_URL, rawSql);\n391\t  });\n392\t\n393\t  afterAll(async () => {\n394\t    await db.close();\n395\t    await rawSql.end();\n396\t  });\n397\t\n398\t  beforeEach(async () => {\n399\t    // Clean tables for isolation\n400\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops RESTART IDENTITY CASCADE`;\n401\t    // Reset reward_pool balance to zero (keep singleton row from migration seed)\n402\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n403\t\n404\t    // Reset PlatformConfig cache so each test reads from its own mock\n405\t    resetPlatformConfigCache();\n406\t\n407\t    // Fresh mock Connection\n408\t    mockConn = new MockConnection();\n409\t\n410\t    // Pre-populate mock with entropy and config accounts\n411\t    mockConn.setAccount(entropyAccount, entropyData);\n412\t\n413\t    const [configPda] = PublicKey.findProgramAddressSync(\n414\t      [Buffer.from(\"coinflip_config\")],\n415\t      COINFLIP_PROGRAM_ID,\n416\t    );\n417\t    mockConn.setAccount(\n418\t      configPda,\n419\t      await buildConfigAccountData(treasuryKeypair.publicKey),\n420\t      { owner: COINFLIP_PROGRAM_ID },\n421\t    );\n422\t\n423\t    // PlatformConfig account — settlement reads fee_bps from here\n424\t    const [platformConfigPda] = derivePlatformConfigPda();\n425\t    mockConn.setAccount(\n426\t      platformConfigPda,\n427\t      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n428\t      { owner: PLATFORM_PROGRAM_ID },\n429\t    );\n430\t\n431\t    // Build the Hono app (no rate limiting for tests)\n432\t    app = new Hono();\n433\t\n434\t    app.use(\n435\t      \"/coinflip/*\",\n436\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n437\t    );\n438\t\n439\t    app.route(\n440\t      \"/coinflip\",\n441\t      createCoinflipRoutes({\n442\t        db,\n443\t        connection: mockConn as unknown as Connection,\n444\t        serverKeypair,\n445\t      }),\n446\t    );\n447\t\n448\t    app.route(\"/rounds\", createRoundsRoutes({ db }));\n449\t  });\n450\t\n451\t  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n452\t    const wallet = creatorKeypair.publicKey.toBase58();\n453\t    const token = await makeJwt(wallet);\n454\t\n455\t    // ------------------------------------------------------------------\n456\t    // 1. POST /coinflip/create\n457\t    // ------------------------------------------------------------------\n458\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n459\t"}]},"parent_tool_use_id":null,"session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"50abb8f5-e52a-4e0b-b703-1fa583f924e2","timestamp":"2026-04-03T20:13:03.243Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"    await rawSql`\n      CREATE TABLE referral_kol_rates (\n        user_id TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL UNIQUE,\n        rate_bps INTEGER NOT NULL,\n        set_by TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean tables for isolation\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops RESTART IDENTITY CASCADE`;\n    // Reset reward_pool balance to zero (keep singleton row from migration seed)\n    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n\n    // Reset PlatformConfig cache so each test reads from its own mock\n    resetPlatformConfigCache();\n\n    // Fresh mock Connection\n    mockConn = new MockConnection();\n\n    // Pre-populate mock with entropy and config accounts\n    mockConn.setAccount(entropyAccount, entropyData);\n\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"coinflip_config\")],\n      COINFLIP_PROGRAM_ID,\n    );\n    mockConn.setAccount(\n      configPda,\n      await buildConfigAccountData(treasuryKeypair.publicKey),\n      { owner: COINFLIP_PROGRAM_ID },\n    );\n\n    // PlatformConfig account — settlement reads fee_bps from here\n    const [platformConfigPda] = derivePlatformConfigPda();\n    mockConn.setAccount(\n      platformConfigPda,\n      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n      { owner: PLATFORM_PROGRAM_ID },\n    );\n\n    // Build the Hono app (no rate limiting for tests)\n    app = new Hono();\n\n    app.use(\n      \"/coinflip/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n\n    app.route(\n      \"/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/rounds\", createRoundsRoutes({ db }));\n  });\n\n  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    // ------------------------------------------------------------------\n    // 1. POST /coinflip/create\n    // ------------------------------------------------------------------\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n","numLines":80,"startLine":380,"totalLines":1755}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NpVHLwAFLNedNpzpYCqb29","type":"tool_result","content":"0\t/**\n1\t * Integration test: full create → join → settle lifecycle.\n2\t *\n3\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n4\t * the real HTTP endpoints, database, settlement worker, and retry logic\n5\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n6\t */\n7\t\n8\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n9\timport { Hono } from \"hono\";\n10\timport {\n11\t  Keypair,\n12\t  PublicKey,\n13\t  SystemProgram,\n14\t  LAMPORTS_PER_SOL,\n15\t} from \"@solana/web3.js\";\n16\timport type { Connection } from \"@solana/web3.js\";\n17\timport bs58 from \"bs58\";\n18\timport { SignJWT } from \"jose\";\n19\timport postgres from \"postgres\";\n20\timport { createDb, type Db } from \"../db.js\";\n21\timport { createCoinflipRoutes } from \"../routes/create.js\";\n22\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n23\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n24\timport { createSettlementWorker } from \"../worker/settlement.js\";\n25\timport { settleMatch } from \"../worker/settle-tx.js\";\n26\timport { createRetrySettler } from \"../worker/retry.js\";\n27\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n28\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n29\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n30\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n31\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n32\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n33\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n34\timport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\n35\timport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\n36\t\n37\t// ---------------------------------------------------------------------------\n38\t// Constants\n39\t// ---------------------------------------------------------------------------\n40\t\n41\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n42\t\n43\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n44\tfunction makeSql() {\n45\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n46\t  // Dev container: postgres listens on Unix socket only\n47\t  return postgres({\n48\t    host: \"/var/run/postgresql\",\n49\t    user: \"vscode\",\n50\t    database: \"rng_utopia_dev\",\n51\t  });\n52\t}\n53\t\n54\tconst AMOUNT_LAMPORTS = 5_000_000;\n55\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n56\tconst SIDE_HEADS = 0;\n57\tconst PHASE_LOCKED = 1;\n58\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n59\t"}]},"parent_tool_use_id":null,"session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"a7f177d0-8363-4477-9505-d34d67f4a9cd","timestamp":"2026-04-03T20:13:03.247Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"/**\n * Integration test: full create → join → settle lifecycle.\n *\n * Uses a mock Solana Connection to simulate on-chain state while exercising\n * the real HTTP endpoints, database, settlement worker, and retry logic\n * end-to-end. Auth uses JWT Bearer tokens (HS256).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\nimport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"rng_utopia_dev\",\n  });\n}\n\nconst AMOUNT_LAMPORTS = 5_000_000;\nconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\nconst SIDE_HEADS = 0;\nconst PHASE_LOCKED = 1;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n","numLines":60,"startLine":0,"totalLines":1755}}}
