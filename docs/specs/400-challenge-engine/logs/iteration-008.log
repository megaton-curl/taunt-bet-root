{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0138crortEMu8cXadnm19Ccc","type":"tool_result","content":"250\t    bump: 0,\n251\t  });\n252\t}\n253\t\n254\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n255\t  return encodeCoinflipConfig({\n256\t    authority: PublicKey.default,\n257\t    treasury,\n258\t    paused: false,\n259\t    bump: 0,\n260\t  });\n261\t}\n262\t\n263\t/**\n264\t * Build PlatformConfig account data matching the on-chain layout.\n265\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n266\t */\n267\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n268\t  const buf = Buffer.alloc(74);\n269\t  // discriminator (8 bytes) — zeroed is fine for mock\n270\t  // authority at offset 8 — use default\n271\t  PublicKey.default.toBuffer().copy(buf, 8);\n272\t  // treasury at offset 40\n273\t  treasury.toBuffer().copy(buf, 40);\n274\t  // fee_bps at offset 72\n275\t  buf.writeUInt16LE(feeBps, 72);\n276\t  return buf;\n277\t}\n278\t\n279\t// ---------------------------------------------------------------------------\n280\t// Test suite\n281\t// ---------------------------------------------------------------------------\n282\t\n283\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n284\t  let db: Db;\n285\t  let rawSql: ReturnType<typeof postgres>;\n286\t  let mockConn: MockConnection;\n287\t  let app: Hono;\n288\t\n289\t  const serverKeypair = Keypair.generate();\n290\t  const creatorKeypair = Keypair.generate();\n291\t  const opponentKeypair = Keypair.generate();\n292\t  const treasuryKeypair = Keypair.generate();\n293\t  const entropyKeypair = Keypair.generate();\n294\t  const entropyAccount = entropyKeypair.publicKey;\n295\t\n296\t  const entropyData = Buffer.alloc(32);\n297\t  entropyData[0] = 0xab;\n298\t  entropyData[1] = 0xcd;\n299\t  entropyData[15] = 0x42;\n300\t\n301\t  beforeAll(async () => {\n302\t    rawSql = makeSql();\n303\t    await rawSql`\n304\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n305\t    `;\n306\t    await rawSql`\n307\t      CREATE TABLE referral_codes (\n308\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n309\t        user_id TEXT NOT NULL UNIQUE,\n310\t        wallet TEXT NOT NULL UNIQUE,\n311\t        code TEXT NOT NULL UNIQUE,\n312\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n313\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n314\t      )\n315\t    `;\n316\t    await rawSql`\n317\t      CREATE TABLE referral_links (\n318\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n319\t        referrer_user_id TEXT NOT NULL,\n320\t        referee_user_id TEXT NOT NULL UNIQUE,\n321\t        referrer_wallet TEXT NOT NULL,\n322\t        referee_wallet TEXT NOT NULL,\n323\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n324\t      )\n325\t    `;\n326\t    await rawSql`\n327\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n328\t    `;\n329\t    await rawSql`\n330\t      CREATE TABLE referral_earnings (\n331\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n332\t        referrer_user_id TEXT NOT NULL,\n333\t        referee_user_id TEXT NOT NULL,\n334\t        referrer_wallet TEXT NOT NULL,\n335\t        referee_wallet TEXT NOT NULL,\n336\t        round_id TEXT NOT NULL,\n337\t        game_type TEXT NOT NULL,\n338\t        wager_lamports BIGINT NOT NULL,\n339\t        fee_lamports BIGINT NOT NULL,\n340\t        referrer_earned_lamports BIGINT NOT NULL,\n341\t        referrer_rate_bps INTEGER NOT NULL,\n342\t        referee_rebate_lamports BIGINT NOT NULL,\n343\t        referee_rebate_rate_bps INTEGER NOT NULL,\n344\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n345\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n346\t      )\n347\t    `;\n348\t    await rawSql`\n349\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n350\t    `;\n351\t    await rawSql`\n352\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n353\t    `;\n354\t    await rawSql`\n355\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n356\t    `;\n357\t    await rawSql`\n358\t      CREATE TABLE referral_claims (\n359\t        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n360\t        user_id TEXT NOT NULL,\n361\t        wallet TEXT NOT NULL,\n362\t        amount_lamports BIGINT NOT NULL,\n363\t        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n364\t        retry_count INTEGER NOT NULL DEFAULT 0,\n365\t        tx_signature TEXT,\n366\t        error TEXT,\n367\t        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n368\t        processed_at TIMESTAMPTZ\n369\t      )\n370\t    `;\n371\t    await rawSql`\n372\t      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n373\t    `;\n374\t    await rawSql`\n375\t      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n376\t    `;\n377\t    await rawSql`\n378\t      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n379\t    `;\n380\t    await rawSql`\n381\t      CREATE TABLE referral_kol_rates (\n382\t        user_id TEXT PRIMARY KEY,\n383\t        wallet TEXT NOT NULL UNIQUE,\n384\t        rate_bps INTEGER NOT NULL,\n385\t        set_by TEXT NOT NULL,\n386\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n387\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n388\t      )\n389\t    `;\n390\t    db = createDb(DATABASE_URL, rawSql);\n391\t  });\n392\t\n393\t  afterAll(async () => {\n394\t    await db.close();\n395\t    await rawSql.end();\n396\t  });\n397\t\n398\t  beforeEach(async () => {\n399\t    // Clean tables for isolation"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"7a827ee7-bdb5-4d57-9ee0-fc2b5e015cd8","timestamp":"2026-04-03T20:11:37.873Z"}
