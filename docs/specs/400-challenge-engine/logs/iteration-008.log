{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XATvvHhfLw18odmogi6E9k","type":"tool_result","content":"700\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n701\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n702\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n703\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n704\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n705\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n706\t    const referrerUserId = referrerProfile.user_id;\n707\t    const opponentUserId = opponentProfile.user_id;\n708\t    const creatorUserId = creatorProfile.user_id;\n709\t\n710\t    // Set up referral link: referrer → opponent (opponent is the referee)\n711\t    await db.insertReferralCode(referrerUserId, referrerWallet, \"test-ref\");\n712\t    await db.insertReferralLink({\n713\t      referrerUserId,\n714\t      refereeUserId: opponentUserId,\n715\t      referrerWallet,\n716\t      refereeWallet: opponentWallet,\n717\t    });\n718\t\n719\t    // 1. Create a coinflip match\n720\t    const token = await makeJwt(creatorWallet, creatorUserId);\n721\t    const createRes = await app.request(\"/coinflip/create\", {\n722\t      method: \"POST\",\n723\t      headers: {\n724\t        \"Content-Type\": \"application/json\",\n725\t        \"Authorization\": `Bearer ${token}`,\n726\t      },\n727\t      body: JSON.stringify({\n728\t        wallet: creatorWallet,\n729\t        amountLamports: AMOUNT_LAMPORTS,\n730\t        side: SIDE_HEADS,\n731\t      }),\n732\t    });\n733\t    expect(createRes.status).toBe(200);\n734\t    const createJson = (await createRes.json()) as {\n735\t      matchPda: string;\n736\t      matchId: string;\n737\t      commitment: string;\n738\t    };\n739\t\n740\t    // 2. Simulate on-chain join (opponent joins the match)\n741\t    const matchPubkey = new PublicKey(createJson.matchPda);\n742\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n743\t    const targetSlot = 150n;\n744\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n745\t\n746\t    const matchAccountData = await buildMatchAccountData({\n747\t      creator: creatorKeypair.publicKey,\n748\t      opponent: opponentKeypair.publicKey,\n749\t      server: serverKeypair.publicKey,\n750\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n751\t      creatorSide: SIDE_HEADS,\n752\t      phase: PHASE_LOCKED,\n753\t      commitment: commitmentBuf,\n754\t      algorithmVer: 1,\n755\t      targetSlot,\n756\t      resolveDeadline,\n757\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n758\t    });\n759\t\n760\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n761\t      owner: COINFLIP_PROGRAM_ID,\n762\t    });\n763\t    mockConn.slot = 200;\n764\t\n765\t    // 3. Settle the match\n766\t    let settlePromise: Promise<void> | null = null;\n767\t\n768\t    const retrySettler = createRetrySettler({\n769\t      db,\n770\t      connection: mockConn as unknown as Connection,\n771\t      settleRound: (pda) =>\n772\t        settleMatch(\n773\t          {\n774\t            db,\n775\t            connection: mockConn as unknown as Connection,\n776\t            serverKeypair,\n777\t            entropyAccount,\n778\t            referralDefaultRateBps: 1000,\n779\t          },\n780\t          pda,\n781\t        ),\n782\t    });\n783\t\n784\t    const worker = createSettlementWorker({\n785\t      db,\n786\t      connection: mockConn as unknown as Connection,\n787\t      serverKey: serverKeypair.publicKey,\n788\t      pollIntervalMs: 60_000,\n789\t      onSettleReady: (pda) => {\n790\t        settlePromise = retrySettler.attemptSettle(pda);\n791\t        return settlePromise;\n792\t      },\n793\t    });\n794\t\n795\t    await worker.poll();\n796\t    if (settlePromise) await settlePromise;\n797\t\n798\t    // 4. Verify match settled\n799\t    const settled = await db.getRoundByPda(createJson.matchPda);\n800\t    expect(settled).toBeDefined();\n801\t    expect(settled!.phase).toBe(\"settled\");\n802\t\n803\t    // 5. Verify referral earnings recorded for the opponent (the referee)\n804\t    // Expected: wager=5_000_000, fee=5_000_000*500/10_000=250_000\n805\t    //           referrer_earned=250_000*1000/10_000=25_000\n806\t    //           referee_rebate=250_000*1000/10_000=25_000\n807\t    const earnings =\n808\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n809\t    expect(earnings.length).toBe(1);\n810\t\n811\t    const earning = earnings[0]!;\n812\t    expect(earning.referrer_user_id).toBe(referrerUserId);\n813\t    expect(earning.referee_user_id).toBe(opponentUserId);\n814\t    expect(earning.referrer_wallet).toBe(referrerWallet);\n815\t    expect(earning.referee_wallet).toBe(opponentWallet);\n816\t    expect(earning.round_id).toBe(createJson.matchId);\n817\t    expect(earning.game_type).toBe(\"coinflip\");\n818\t    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS); // 5_000_000\n819\t    expect(Number(earning.fee_lamports)).toBe(250_000); // 5_000_000 * 500 / 10_000\n820\t    expect(Number(earning.referrer_earned_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n821\t    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n822\t    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n823\t    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n824\t\n825\t    // Creator is NOT referred, so no earnings for creator\n826\t    const creatorEarnings =\n827\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${creatorUserId}`;\n828\t    expect(creatorEarnings.length).toBe(0);\n829\t  });\n830\t\n831\t  it(\"settlement uses KOL custom rate for referrer earnings\", async () => {\n832\t    // Referrer has a KOL rate of 2000 bps (20% of fee)\n833\t    const referrerKeypair = Keypair.generate();\n834\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n835\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n836\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n837\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n838\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n839\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n840\t    const referrerUserId = referrerProfile.user_id;\n841\t    const opponentUserId = opponentProfile.user_id;\n842\t\n843\t    // Set up referral link + KOL rate override\n844\t    await db.insertReferralCode(referrerUserId, referrerWallet, \"kol-code\");\n845\t    await db.insertReferralLink({\n846\t      referrerUserId,\n847\t      refereeUserId: opponentUserId,\n848\t      referrerWallet,\n849\t      refereeWallet: opponentWallet,"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"e247c47f-c417-4186-94e5-c81227bebaa6","timestamp":"2026-04-03T20:11:40.485Z"}
