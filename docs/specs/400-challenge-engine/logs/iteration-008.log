{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V7xVGKGSVNkKg2NsN4v4pw","type":"tool_result","content":"1000\t    });\n1001\t\n1002\t    // Transition DB round to \"locked\" (normally the settlement worker does this on join detection)\n1003\t    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n1004\t\n1005\t    // Settle directly\n1006\t    await settleMatch(\n1007\t      {\n1008\t        db,\n1009\t        connection: mockConn as unknown as Connection,\n1010\t        serverKeypair,\n1011\t        entropyAccount,\n1012\t        referralDefaultRateBps: 1000,\n1013\t      },\n1014\t      createJson.matchPda,\n1015\t    );\n1016\t\n1017\t    // Verify game.settled event was emitted in event_queue\n1018\t    const events = await rawSql`\n1019\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1020\t    `;\n1021\t    expect(events.length).toBe(1);\n1022\t\n1023\t    const evt = events[0]!;\n1024\t    expect(evt.status).toBe(\"pending\");\n1025\t\n1026\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1027\t    const payload = evt.payload as any;\n1028\t    expect(payload.roundId).toBe(createJson.matchId);\n1029\t    expect(payload.roundPda).toBe(createJson.matchPda);\n1030\t    expect(payload.game).toBe(\"coinflip\");\n1031\t    expect(payload.feeLamports).toBeDefined();\n1032\t    expect(payload.settledAt).toBeDefined();\n1033\t\n1034\t    // Players array\n1035\t    expect(payload.players).toHaveLength(2);\n1036\t    const creator = payload.players.find(\n1037\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1038\t      (p: any) => p.wallet === creatorKeypair.publicKey.toBase58(),\n1039\t    );\n1040\t    const opponent = payload.players.find(\n1041\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1042\t      (p: any) => p.wallet === opponentKeypair.publicKey.toBase58(),\n1043\t    );\n1044\t    expect(creator).toBeDefined();\n1045\t    expect(opponent).toBeDefined();\n1046\t    expect(creator.isCreator).toBe(true);\n1047\t    expect(opponent.isCreator).toBe(false);\n1048\t    expect(creator.userId).toBe(creatorUserId);\n1049\t    expect(opponent.userId).toBe(opponentUserId);\n1050\t    // Amounts are string-encoded lamports\n1051\t    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n1052\t    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n1053\t    // Exactly one winner\n1054\t    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n1055\t    // Winner has payoutLamports > 0, loser has \"0\"\n1056\t    const winnerPlayer = creator.isWinner ? creator : opponent;\n1057\t    const loserPlayer = creator.isWinner ? opponent : creator;\n1058\t    expect(Number(winnerPlayer.payoutLamports)).toBeGreaterThan(0);\n1059\t    expect(loserPlayer.payoutLamports).toBe(\"0\");\n1060\t    // Fee = pool * 500 / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n1061\t    expect(payload.feeLamports).toBe(String(500_000));\n1062\t  });\n1063\t\n1064\t  it(\"duplicate settlement retry produces duplicate game.settled event rows safely\", async () => {\n1065\t    const wallet = creatorKeypair.publicKey.toBase58();\n1066\t    const token = await makeJwt(wallet);\n1067\t\n1068\t    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n1069\t    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n1070\t    await rawSql`\n1071\t      INSERT INTO player_profiles (user_id, wallet, username)\n1072\t      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n1073\t      ON CONFLICT (user_id) DO NOTHING\n1074\t    `;\n1075\t    await rawSql`\n1076\t      INSERT INTO player_profiles (user_id, wallet, username)\n1077\t      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n1078\t      ON CONFLICT (user_id) DO NOTHING\n1079\t    `;\n1080\t\n1081\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n1082\t    const createRes = await app.request(\"/coinflip/create\", {\n1083\t      method: \"POST\",\n1084\t      headers: {\n1085\t        \"Content-Type\": \"application/json\",\n1086\t        Authorization: `Bearer ${token}`,\n1087\t      },\n1088\t      body: JSON.stringify(body),\n1089\t    });\n1090\t    expect(createRes.status).toBe(200);\n1091\t    const createJson = (await createRes.json()) as {\n1092\t      matchPda: string;\n1093\t      matchId: string;\n1094\t      commitment: string;\n1095\t    };\n1096\t\n1097\t    const matchPubkey = new PublicKey(createJson.matchPda);\n1098\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n1099\t    const matchAccountData = await buildMatchAccountData({\n1100\t      creator: creatorKeypair.publicKey,\n1101\t      opponent: opponentKeypair.publicKey,\n1102\t      server: serverKeypair.publicKey,\n1103\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n1104\t      creatorSide: SIDE_HEADS,\n1105\t      phase: PHASE_LOCKED,\n1106\t      commitment: commitmentBuf,\n1107\t      algorithmVer: 1,\n1108\t      targetSlot: 150n,\n1109\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n1110\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n1111\t    });\n1112\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n1113\t      owner: COINFLIP_PROGRAM_ID,\n1114\t    });\n1115\t\n1116\t    // Transition DB round to \"locked\"\n1117\t    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n1118\t\n1119\t    // First settle\n1120\t    await settleMatch(\n1121\t      {\n1122\t        db,\n1123\t        connection: mockConn as unknown as Connection,\n1124\t        serverKeypair,\n1125\t        entropyAccount,\n1126\t        referralDefaultRateBps: 1000,\n1127\t      },\n1128\t      createJson.matchPda,\n1129\t    );\n1130\t\n1131\t    // Second settle attempt — should fail on phase check (already settled),\n1132\t    // but the first call already produced the event. Verify 1 event row exists.\n1133\t    const events = await rawSql`\n1134\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1135\t    `;\n1136\t    expect(events.length).toBe(1);\n1137\t\n1138\t    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n1139\t    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n1140\t    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n1141\t    // The first settle succeeded; a retry would be rejected by phase check before reaching\n1142\t    // the DB transaction. This test confirms the first call produces exactly 1 event.\n1143\t  });\n1144\t\n1145\t  it(\"closecall settlement emits game.settled event with correct payload shape\", async () => {\n1146\t    // Two players: one green, one red\n1147\t    const greenPlayer = Keypair.generate();\n1148\t    const redPlayer = Keypair.generate();\n1149\t    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());"}]},"parent_tool_use_id":"toolu_01SFNPztg4qXhAcgYUzx2och","session_id":"a0816eb3-ec81-48b4-9f7e-e95cff86009e","uuid":"dca54f36-ad2e-4a8f-af6a-8d84ab2be2c3","timestamp":"2026-04-03T20:11:43.030Z"}
