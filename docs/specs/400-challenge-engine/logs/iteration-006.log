{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DuWoADjkyH4YsRiaa24S4p","type":"tool_result","content":"200\t  connection,\n201\t  serverKeypair: config.serverKeypair,\n202\t  db,\n203\t});\n204\tcloseCallClock.start();\n205\t\n206\t// Register event handlers before starting the worker\n207\tregisterHandler(\n208\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n209\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n210\t);\n211\tregisterHandler(\n212\t  EventTypes.REWARD_POOL_FUND,\n213\t  createRewardPoolFundHandler({ db }),\n214\t);\n215\t\n216\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n217\tconst eventWorker = createEventWorker(sql, {\n218\t  pollIntervalMs: config.eventQueuePollMs,\n219\t});\n220\teventWorker.start();\n221\tlogger.info(\"Event queue worker started\", {\n222\t  pollIntervalMs: config.eventQueuePollMs,\n223\t});\n224\t\n225\t// Game-specific routes\n226\tapp.route(\n227\t  \"/coinflip\",\n228\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n229\t);\n230\tapp.route(\n231\t  \"/lord\",\n232\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n233\t);\n234\t\n235\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n236\tapp.use(\n237\t  \"/closecall/bet\",\n238\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n239\t);\n240\tapp.use(\n241\t  \"/closecall/bet\",\n242\t  createRateLimitMiddleware({\n243\t    perWallet: config.rateLimitPerWallet,\n244\t    global: config.rateLimitGlobal,\n245\t    windowMs: 60_000,\n246\t  }),\n247\t);\n248\t\n249\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n250\tapp.route(\"/closecall\", createCloseCallRoutes({\n251\t  db,\n252\t  connection,\n253\t  serverKeypair: config.serverKeypair,\n254\t  clockWorker: closeCallClock,\n255\t}));\n256\t\n257\t// Leaderboard routes — public, no auth\n258\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n259\t\n260\t// Price routes — public, no auth\n261\tapp.route(\"/price\", createPriceRoutes());\n262\t\n263\t// Round verification routes\n264\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n265\t\n266\t// Health endpoint — wired after worker exists so we can query its status\n267\tapp.route(\n268\t  \"/health\",\n269\t  createHealthRoutes({\n270\t    db,\n271\t    sql,\n272\t    isWorkerRunning: () => worker.isRunning,\n273\t  }),\n274\t);\n275\t\n276\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n277\tif (config.adminToken) {\n278\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n279\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n280\t}\n281\t\n282\tconst port = config.port;\n283\tlogger.info(\"fairness-backend started\", { port });\n284\t\n285\tserve({\n286\t  fetch: app.fetch,\n287\t  port,\n288\t  hostname: \"0.0.0.0\",\n289\t});\n290\t\n291\texport default {\n292\t  port,\n293\t  fetch: app.fetch,\n294\t};\n295\t"}]},"parent_tool_use_id":"toolu_01MTNmYokGVAnK87A22XpGfC","session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"7f26d13f-fa91-44ae-b9b4-4b226a82799f","timestamp":"2026-04-03T19:50:39.830Z"}
