{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015VWP3qv3U5StFbh9pGgqZk","type":"tool_result","content":"1\t/**\n2\t * Handler registry — maps event type strings to handler functions.\n3\t *\n4\t * One handler per event type (no pub/sub fan-out for v1).\n5\t * Handlers must be idempotent — re-processing is a safe no-op.\n6\t */\n7\t\n8\timport type { EventType } from \"./event-types.js\";\n9\t\n10\texport type EventHandler = (\n11\t  payload: Record<string, unknown>,\n12\t) => Promise<void>;\n13\t\n14\tconst handlers = new Map<string, EventHandler>();\n15\t\n16\texport function registerHandler(\n17\t  eventType: EventType,\n18\t  handler: EventHandler,\n19\t): void {\n20\t  handlers.set(eventType, handler);\n21\t}\n22\t\n23\texport function getHandler(eventType: string): EventHandler | undefined {\n24\t  return handlers.get(eventType);\n25\t}\n26\t\n27\t/** Remove all registered handlers. Used by tests for isolation. */\n28\texport function clearHandlers(): void {\n29\t  handlers.clear();\n30\t}\n31\t"}]},"parent_tool_use_id":"toolu_015ndMQo7XQGuB35MMd52m7h","session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"f5099bc8-c07e-48ec-81b1-156e04012a11","timestamp":"2026-04-03T19:50:04.254Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JvyNrKgUB969mawrpVqN1M","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n31\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n32\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n33\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n34\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n35\t\n36\t// ---------------------------------------------------------------------------\n37\t// Constants\n38\t// ---------------------------------------------------------------------------\n39\t\n40\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n41\t\n42\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n43\tfunction makeSql() {\n44\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n45\t  // Dev container: postgres listens on Unix socket only\n46\t  return postgres({\n47\t    host: \"/var/run/postgresql\",\n48\t    user: \"vscode\",\n49\t    database: \"rng_utopia_dev\",\n50\t  });\n51\t}\n52\t\n53\tconst AMOUNT_LAMPORTS = 5_000_000;\n54\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n55\tconst SIDE_HEADS = 0;\n56\tconst PHASE_LOCKED = 1;\n57\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n58\t\n59\t// ---------------------------------------------------------------------------\n60\t// JWT helper\n61\t// ---------------------------------------------------------------------------\n62\t\n63\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n64\t  const now = Math.floor(Date.now() / 1000);\n65\t  return new SignJWT({ wallet })\n66\t    .setProtectedHeader({ alg: \"HS256\" })\n67\t    .setSubject(userId)\n68\t    .setIssuedAt(now)\n69\t    .setExpirationTime(now + 3600)\n70\t    .sign(JWT_SECRET);\n71\t}\n72\t\n73\tfunction userIdFromWallet(wallet: string) {\n74\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n75\t}\n76\t\n77\t// ---------------------------------------------------------------------------\n78\t// Mock Connection\n79\t// ---------------------------------------------------------------------------\n80\t\n81\t/**\n82\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n83\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n84\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n85\t */\n86\tclass MockConnection {\n87\t  private _slot = 200;\n88\t  private _accounts = new Map<\n89\t    string,\n90\t    {\n91\t      data: Buffer;\n92\t      lamports: number;\n93\t      owner: PublicKey;\n94\t      executable: boolean;\n95\t    }\n96\t  >();\n97\t  lastRawTx: Buffer | null = null;\n98\t\n99\t  set slot(s: number) {\n100\t    this._slot = s;\n101\t  }\n102\t  get slot() {\n103\t    return this._slot;\n104\t  }\n105\t\n106\t  setAccount(\n107\t    pubkey: PublicKey,\n108\t    data: Buffer,\n109\t    opts?: { lamports?: number; owner?: PublicKey },\n110\t  ) {\n111\t    this._accounts.set(pubkey.toBase58(), {\n112\t      data,\n113\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n114\t      owner: opts?.owner ?? SystemProgram.programId,\n115\t      executable: false,\n116\t    });\n117\t  }\n118\t\n119\t  removeAccount(pubkey: PublicKey) {\n120\t    this._accounts.delete(pubkey.toBase58());\n121\t  }\n122\t\n123\t  async getLatestBlockhash() {\n124\t    return {\n125\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n126\t      lastValidBlockHeight: 999_999,\n127\t    };\n128\t  }\n129\t\n130\t  async getSlot() {\n131\t    return this._slot;\n132\t  }\n133\t\n134\t  async getAccountInfo(pubkey: PublicKey) {\n135\t    const acc = this._accounts.get(pubkey.toBase58());\n136\t    if (!acc) return null;\n137\t    return { ...acc, rentEpoch: 0 };\n138\t  }\n139\t\n140\t  async getProgramAccounts(\n141\t    programId: PublicKey,\n142\t    config?: {\n143\t      filters?: Array<\n144\t        | { dataSize: number }\n145\t        | { memcmp: { offset: number; bytes: string } }\n146\t      >;\n147\t    },\n148\t  ) {\n149\t    const results: Array<{\n150\t      pubkey: PublicKey;\n151\t      account: {\n152\t        data: Buffer;\n153\t        lamports: number;\n154\t        owner: PublicKey;\n155\t        executable: boolean;\n156\t        rentEpoch: number;\n157\t      };\n158\t    }> = [];\n159\t\n160\t    for (const [key, acc] of this._accounts) {\n161\t      if (!acc.owner.equals(programId)) continue;\n162\t\n163\t      let matches = true;\n164\t      if (config?.filters) {\n165\t        for (const filter of config.filters) {\n166\t          if (\"dataSize\" in filter) {\n167\t            if (acc.data.length !== filter.dataSize) {\n168\t              matches = false;\n169\t              break;\n170\t            }\n171\t          }\n172\t          if (\"memcmp\" in filter) {\n173\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n174\t            const actual = acc.data.subarray(\n175\t              filter.memcmp.offset,\n176\t              filter.memcmp.offset + expected.length,\n177\t            );\n178\t            if (Buffer.compare(actual, expected) !== 0) {\n179\t              matches = false;\n180\t              break;\n181\t            }\n182\t          }\n183\t        }\n184\t      }\n185\t\n186\t      if (matches) {\n187\t        results.push({\n188\t          pubkey: new PublicKey(key),\n189\t          account: { ...acc, rentEpoch: 0 },\n190\t        });\n191\t      }\n192\t    }\n193\t    return results;\n194\t  }\n195\t\n196\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n197\t    this.lastRawTx = Buffer.from(rawTx);\n198\t    // Return a deterministic fake signature\n199\t    return bs58.encode(Buffer.alloc(64, 0x01));\n200\t  }"}]},"parent_tool_use_id":"toolu_01MTNmYokGVAnK87A22XpGfC","session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"4e7ac1c0-b249-4b76-8519-4337052c995c","timestamp":"2026-04-03T19:50:04.085Z"}
