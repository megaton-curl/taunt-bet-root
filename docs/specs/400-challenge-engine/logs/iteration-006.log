{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AXnDfLPd1SadxptUnjKivt","type":"tool_result","content":"150\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n151\t      pda,\n152\t    ),\n153\t});\n154\t\n155\t// PDA watcher — WebSocket-based instant join detection\n156\tconst pdaWatcher = createPdaWatcher({\n157\t  connection,\n158\t  serverKey: config.serverKeypair.publicKey,\n159\t  db,\n160\t  onJoinDetected: async (pda, targetSlot) => {\n161\t    // Update DB phase if still in 'created'\n162\t    const round = await db.getRoundByPda(pda);\n163\t    if (round && round.phase === \"created\") {\n164\t      await db.updateRoundPhase(pda, \"locked\", {\n165\t        target_slot: targetSlot.toString(),\n166\t      });\n167\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n168\t        targetSlot: targetSlot.toString(),\n169\t        source: \"pda-watcher\",\n170\t        game: round.game,\n171\t      });\n172\t    }\n173\t\n174\t    // Check if target slot already passed — settle immediately if so\n175\t    const currentSlot = await connection.getSlot();\n176\t    if (BigInt(currentSlot) >= targetSlot) {\n177\t      await retrySettler.attemptSettle(pda);\n178\t      pdaWatcher.unwatch(pda);\n179\t    }\n180\t    // If target slot not reached yet, poll worker will pick it up next cycle\n181\t  },\n182\t});\n183\t\n184\tconst worker = createSettlementWorker({\n185\t  db,\n186\t  connection,\n187\t  serverKey: config.serverKeypair.publicKey,\n188\t  pollIntervalMs: config.workerPollIntervalMs,\n189\t  onSettleReady: async (pda) => {\n190\t    await retrySettler.attemptSettle(pda);\n191\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n192\t  },\n193\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n194\t});\n195\tworker.start();\n196\t\n197\t// Close Call clock worker — fetches boundary prices + settles open rounds\n198\t// Rounds are created on-demand by players via /closecall/bet\n199\tconst closeCallClock = createCloseCallClockWorker({\n200\t  connection,\n201\t  serverKeypair: config.serverKeypair,\n202\t  db,\n203\t});\n204\tcloseCallClock.start();\n205\t\n206\t// Register event handlers before starting the worker\n207\tregisterHandler(\n208\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n209\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n210\t);\n211\tregisterHandler(\n212\t  EventTypes.REWARD_POOL_FUND,\n213\t  createRewardPoolFundHandler({ db }),\n214\t);\n215\t\n216\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n217\tconst eventWorker = createEventWorker(sql, {\n218\t  pollIntervalMs: config.eventQueuePollMs,\n219\t});\n220\teventWorker.start();\n221\tlogger.info(\"Event queue worker started\", {\n222\t  pollIntervalMs: config.eventQueuePollMs,\n223\t});\n224\t\n225\t// Game-specific routes\n226\tapp.route(\n227\t  \"/coinflip\",\n228\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n229\t);\n230\tapp.route(\n231\t  \"/lord\",\n232\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n233\t);\n234\t\n235\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n236\tapp.use(\n237\t  \"/closecall/bet\",\n238\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n239\t);\n240\tapp.use(\n241\t  \"/closecall/bet\",\n242\t  createRateLimitMiddleware({\n243\t    perWallet: config.rateLimitPerWallet,\n244\t    global: config.rateLimitGlobal,\n245\t    windowMs: 60_000,\n246\t  }),\n247\t);\n248\t\n249\t// Close Call routes (read endpoints are public, /bet is auth'd above)"}]},"parent_tool_use_id":"toolu_015ndMQo7XQGuB35MMd52m7h","session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"b45d95f4-e2a1-423c-b89e-33f658f8e9e0","timestamp":"2026-04-03T19:50:15.591Z"}
