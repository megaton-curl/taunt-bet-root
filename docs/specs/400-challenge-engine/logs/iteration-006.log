{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XupWfXGvecBQkvK6qPZsGg","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createInternalRoutes } from \"./routes/internal.js\";\n21\timport { swaggerUI } from \"@hono/swagger-ui\";\n22\timport { spec } from \"./openapi.js\";\n23\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n24\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n25\timport { createSettlementWorker } from \"./worker/settlement.js\";\n26\timport { settleRound } from \"./worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"./worker/retry.js\";\n28\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n29\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n30\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n31\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n32\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n33\timport { logger } from \"./logger.js\";\n34\t\n35\tconst config = loadConfig();\n36\t\n37\t// Single postgres pool shared by game DB, auth DB, and all workers\n38\tconst sql = postgres(config.databaseUrl);\n39\tconst db = createDb(config.databaseUrl, sql);\n40\tconst authDb = createAuthDb(sql);\n41\t\n42\tconst connection = new Connection(config.rpcUrl, {\n43\t  commitment: \"confirmed\",\n44\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n45\t});\n46\t\n47\tconst app = new Hono();\n48\t\n49\tapp.use(\n50\t  \"*\",\n51\t  cors({\n52\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n53\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n54\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n55\t  }),\n56\t);\n57\t\n58\t// Request logging — correlate frontend fetch timing with server-side processing\n59\tapp.use(\"*\", async (c, next) => {\n60\t  const start = Date.now();\n61\t  await next();\n62\t  const ms = Date.now() - start;\n63\t  const method = c.req.method;\n64\t  const path = c.req.path;\n65\t  // Skip noisy health checks and OPTIONS preflight\n66\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n67\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n68\t});\n69\t\n70\t// API docs — Swagger UI + raw OpenAPI spec\n71\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n72\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n73\t\n74\t// Auth routes — no JWT middleware (these are the login endpoints)\n75\t// Lighter rate limiting by IP for auth endpoints\n76\tapp.use(\n77\t  \"/auth/*\",\n78\t  createRateLimitMiddleware({\n79\t    perWallet: 20,\n80\t    global: config.rateLimitGlobal,\n81\t    windowMs: 60_000,\n82\t  }),\n83\t);\n84\t\n85\tapp.route(\n86\t  \"/auth\",\n87\t  createAuthRoutes({\n88\t    authDb,\n89\t    db,\n90\t    jwtSecret: config.jwtSecret,\n91\t    cluster: config.cluster,\n92\t    challengeTtlSeconds: config.challengeTtlSeconds,\n93\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n94\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n95\t  }),\n96\t);\n97\t\n98\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n99\tapp.use(\n100\t  \"/profile/*\",\n101\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n102\t);\n103\tapp.route(\"/profile\", createProfileRoutes({ db }));\n104\t\n105\t// Public profile routes — no auth required\n106\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n107\t\n108\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n109\tapp.use(\n110\t  \"/referral/*\",\n111\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n112\t);\n113\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n114\t\n115\t// JWT auth middleware for game endpoints\n116\tapp.use(\n117\t  \"/coinflip/*\",\n118\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n119\t);\n120\tapp.use(\n121\t  \"/lord/*\",\n122\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n123\t);\n124\t\n125\t// Rate limiting — per-wallet and global limits on POST requests\n126\tapp.use(\n127\t  \"/coinflip/*\",\n128\t  createRateLimitMiddleware({\n129\t    perWallet: config.rateLimitPerWallet,\n130\t    global: config.rateLimitGlobal,\n131\t    windowMs: 60_000,\n132\t  }),\n133\t);\n134\tapp.use(\n135\t  \"/lord/*\",\n136\t  createRateLimitMiddleware({\n137\t    perWallet: config.rateLimitPerWallet,\n138\t    global: config.rateLimitGlobal,\n139\t    windowMs: 60_000,\n140\t  }),\n141\t);\n142\t\n143\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n144\tconst entropyAccount = new PublicKey(config.entropyAccount);\n145\tconst retrySettler = createRetrySettler({\n146\t  db,\n147\t  connection,\n148\t  settleRound: (pda) =>\n149\t    settleRound(\n150\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n151\t      pda,\n152\t    ),\n153\t});\n154\t\n155\t// PDA watcher — WebSocket-based instant join detection\n156\tconst pdaWatcher = createPdaWatcher({\n157\t  connection,\n158\t  serverKey: config.serverKeypair.publicKey,\n159\t  db,\n160\t  onJoinDetected: async (pda, targetSlot) => {\n161\t    // Update DB phase if still in 'created'\n162\t    const round = await db.getRoundByPda(pda);\n163\t    if (round && round.phase === \"created\") {\n164\t      await db.updateRoundPhase(pda, \"locked\", {\n165\t        target_slot: targetSlot.toString(),\n166\t      });\n167\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n168\t        targetSlot: targetSlot.toString(),\n169\t        source: \"pda-watcher\",\n170\t        game: round.game,\n171\t      });\n172\t    }\n173\t\n174\t    // Check if target slot already passed — settle immediately if so\n175\t    const currentSlot = await connection.getSlot();\n176\t    if (BigInt(currentSlot) >= targetSlot) {\n177\t      await retrySettler.attemptSettle(pda);\n178\t      pdaWatcher.unwatch(pda);\n179\t    }\n180\t    // If target slot not reached yet, poll worker will pick it up next cycle\n181\t  },\n182\t});\n183\t\n184\tconst worker = createSettlementWorker({\n185\t  db,\n186\t  connection,\n187\t  serverKey: config.serverKeypair.publicKey,\n188\t  pollIntervalMs: config.workerPollIntervalMs,\n189\t  onSettleReady: async (pda) => {\n190\t    await retrySettler.attemptSettle(pda);\n191\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n192\t  },\n193\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n194\t});\n195\tworker.start();\n196\t\n197\t// Close Call clock worker — fetches boundary prices + settles open rounds\n198\t// Rounds are created on-demand by players via /closecall/bet\n199\tconst closeCallClock = createCloseCallClockWorker({\n200\t  connection,"}]},"parent_tool_use_id":"toolu_01MTNmYokGVAnK87A22XpGfC","session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"0d8d0960-0cf2-4cac-9dea-b869e796c0d2","timestamp":"2026-04-03T19:50:38.346Z"}
