     funded_lamports: string;\n1313\t    }[]>`\n1314\t      SELECT round_id, fee_lamports, funded_lamports FROM reward_pool_fundings WHERE round_id = ${roundId}\n1315\t    `;\n1316\t    expect(fundings.length).toBe(1);\n1317\t    expect(fundings[0]!.round_id).toBe(roundId);\n1318\t    expect(BigInt(fundings[0]!.fee_lamports)).toBe(500_000n);\n1319\t    expect(BigInt(fundings[0]!.funded_lamports)).toBe(expectedFunded);\n1320\t\n1321\t    // Verify pool balance incremented\n1322\t    const poolAfter = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1323\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1324\t    `;\n1325\t    expect(BigInt(poolAfter[0]!.balance_lamports)).toBe(expectedFunded);\n1326\t    expect(BigInt(poolAfter[0]!.lifetime_funded)).toBe(expectedFunded);\n1327\t\n1328\t    // --- Idempotency: re-emit same round_id ---\n1329\t    await handler({\n1330\t      roundId,\n1331\t      feeLamports,\n1332\t    });\n1333\t\n1334\t    // Verify no duplicate funding row\n1335\t    const fundingsAfterDupe = await rawSql<{ id: string }[]>`\n1336\t      SELECT id FROM reward_pool_fundings WHERE round_id = ${roundId}\n1337\t    `;\n1338\t    expect(fundingsAfterDupe.length).toBe(1);\n1339\t\n1340\t    // Verify pool balance unchanged\n1341\t    const poolAfterDupe = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1342\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1343\t    `;\n1344\t    expect(BigInt(poolAfterDupe[0]!.balance_lamports)).toBe(expectedFunded);\n1345\t    expect(BigInt(poolAfterDupe[0]!.lifetime_funded)).toBe(expectedFunded);\n1346\t  });\n1347\t});\n1348\t"}]},"parent_tool_use_id":"toolu_01MTNmYokGVAnK87A22XpGfC","session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"6b8c3b56-a4d5-4c89-a581-dc9acaafb6b7","timestamp":"2026-04-03T19:50:10.077Z"}
