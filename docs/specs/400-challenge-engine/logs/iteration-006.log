{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012DgVCcHiZ42oDp8DELDVY9","type":"tool_result","content":"1\t/**\n2\t * Price routes — cached SOL/USD price from Pyth Hermes.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport { HermesClient } from \"@pythnetwork/hermes-client\";\n7\timport { logger } from \"../logger.js\";\n8\t\n9\t// SOL/USD Pyth feed ID (same on mainnet + devnet)\n10\tconst SOL_USD_FEED_ID =\n11\t  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n12\t\n13\tconst CACHE_TTL_MS = 60_000; // 60 seconds\n14\t\n15\tinterface CachedPrice {\n16\t  price: number;\n17\t  updatedAt: string;\n18\t  fetchedAt: number; // Date.now() for TTL check\n19\t}\n20\t\n21\tlet cached: CachedPrice | null = null;\n22\t\n23\tconst client = new HermesClient(\"https://hermes.pyth.network\", {});\n24\t\n25\tasync function fetchSolPrice(): Promise<CachedPrice | null> {\n26\t  // Return cached if still fresh\n27\t  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n28\t    return cached;\n29\t  }\n30\t\n31\t  try {\n32\t    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n33\t      encoding: \"base64\",\n34\t      parsed: true,\n35\t    });\n36\t    const feed = updates.parsed?.[0];\n37\t    if (!feed?.price) return cached; // stale cache better than nothing\n38\t\n39\t    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n40\t    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n41\t\n42\t    cached = { price, updatedAt, fetchedAt: Date.now() };\n43\t    return cached;\n44\t  } catch (err) {\n45\t    logger.warn(\"hermes: SOL/USD fetch failed\", {\n46\t      error: err instanceof Error ? err.message : String(err),\n47\t    });\n48\t    return cached; // return stale cache on error\n49\t  }\n50\t}\n51\t\n52\texport function createPriceRoutes() {\n53\t  const app = new Hono();\n54\t\n55\t  app.get(\"/sol-usd\", async (c) => {\n56\t    const result = await fetchSolPrice();\n57\t    if (!result) {\n58\t      return c.json({ error: \"Price unavailable\" }, 503);\n59\t    }\n60\t    return c.json({\n61\t      price: result.price,\n62\t      updatedAt: result.updatedAt,\n63\t    });\n64\t  });\n65\t\n66\t  return app;\n67\t}\n68\t"}]},"parent_tool_use_id":"toolu_01MTNmYokGVAnK87A22XpGfC","session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"ecbd4087-cbaa-4ed9-b04a-006064ffd17f","timestamp":"2026-04-03T19:50:04.283Z"}
