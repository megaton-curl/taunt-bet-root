\n}\n\n/**\n * Create or increment player_points. Uses upsert pattern so the first\n * grant for a user creates the row.\n */\nexport async function upsertPlayerPoints(\n  db: Db,\n  userId: string,\n  wallet: string,\n  amount: bigint,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO player_points (user_id, wallet, balance, lifetime_earned, updated_at)\n    VALUES (${userId}, ${wallet}, ${amount}, ${amount}, now())\n    ON CONFLICT (user_id) DO UPDATE SET\n      balance         = player_points.balance + ${amount},\n      lifetime_earned = player_points.lifetime_earned + ${amount},\n      updated_at      = now()\n  `;\n}\n\n/**\n * Returns the multiplier for the currently active Dogpile event, or 1 if\n * none is active.\n */\nexport async function getActiveDogpileMultiplier(\n  db: Db,\n  timestamp: Date,\n): Promise<number> {\n  const rows = await db.rawSql<{ multiplier: string }[]>`\n    SELECT multiplier FROM dogpile_events\n    WHERE status = 'active'\n      AND ${timestamp} BETWEEN starts_at AND ends_at\n    LIMIT 1\n  `;\n  return rows.length > 0 ? parseFloat(rows[0]!.multiplier) : 1;\n}\n\n// ---------------------------------------------------------------------------\n// Handler factory\n// ---------------------------------------------------------------------------\n\nexport interface PointsGrantDeps {\n  db: Db;\n  /** Returns current SOL/USD price, or null if unavailable. */\n  getSolPrice: () => Promise<number | null>;\n}\n\nexport function createPointsGrantHandler(deps: PointsGrantDeps) {\n  const { db, getSolPrice } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const userId = payload.userId as string;\n    const wallet = payload.wallet as string;\n    const sourceType = payload.sourceType as string;\n    const sourceId = payload.sourceId as string;\n\n    if (!userId || !wallet || !sourceType || !sourceId) {\n      throw new Error(\n        \"points.grant: malformed payload — missing userId, wallet, sourceType, or sourceId\",\n      );\n    }\n\n    let pointsAmount: bigint;\n    const metadata: Record<string, unknown> = (payload.metadata as Record<string, unknown>) ?? {};\n\n    if (sourceType === \"wager\") {\n      // Wager-based: calculate from lamports → USD → points\n      const amountLamportsStr = payload.amountLamports as string;\n      if (!amountLamportsStr) {\n        throw new Error(\"points.grant: wager grant missing amountLamports\");\n      }\n\n      const pointsPerDollarStr = await readRewardConfig(db, \"points_per_dollar\");\n      if (!pointsPerDollarStr) {\n        logger.warn(\"points.grant: points_per_dollar not configured, skipping\", { userId, sourceId });\n        return;\n      }\n      const pointsPerDollar = parseFloat(pointsPerDollarStr);\n\n      const solPrice = await getSolPrice();\n      if (solPrice === null || solPrice <= 0) {\n        logger.warn(\"points.grant: SOL/USD price unavailable, skipping\", { userId, sourceId });\n        return;\n      }\n\n      const amountLamports = Number(amountLamportsStr);\n      const wagerSol = amountLamports / 1e9;\n      const wagerUsd = wagerSol * solPrice;\n\n      // Check for active Dogpile multiplier\n      const settledAt = payload.settledAt\n        ? new Date(payload.settledAt as string)\n        : new Date();\n      const multiplier = await getActiveDogpileMultiplier(db, settledAt);\n\n      pointsAmount = BigInt(Math.floor(wagerUsd * pointsPerDollar * multiplier));\n\n      metadata.solPrice = solPrice;\n      metadata.wagerUsd = wagerUsd;\n      metadata.pointsPerDollar = pointsPerDollar;\n      metadata.multiplier = multiplier;\n    } else {\n      // Pre-calculated: crate_points, challenge_completed, bonus_completed\n      const amount = payload.amount as string | number;\n      if (amount === undefined || amount === null) {\n        throw new Error(\"points.grant: non-wager grant missing amount\");\n      }\n      pointsAmount = BigInt(amount);\n    }\n\n    if (pointsAmount <= 0n) {\n      logger.debug(\"points.grant: calculated amount is zero, skipping\", { userId, sourceId, sourceType });\n      return;\n    }\n\n    // Run within a transaction for atomicity\n    await db.withTransaction(async (txDb) => {\n      // Insert ledger row (idempotency guard)\n      const inserted = await insertPointGrant(\n        txDb, userId, wallet, sourceType, sourceId, pointsAmount, metadata,\n      );\n      if (!inserted) {\n        logger.info(\"points.grant: duplicate grant, skipping\", { userId, sourceType, sourceId });\n        return;\n      }\n\n      // Upsert player_points\n      await upsertPlayerPoints(txDb, userId, wallet, pointsAmount);\n\n      logger.info(\"points.grant: points awarded\", {\n        userId,\n        sourceType,\n        sourceId,\n        amount: pointsAmount.toString(),\n      });\n    });\n  };\n}\n","structuredPatch":[],"originalFile":null}}
