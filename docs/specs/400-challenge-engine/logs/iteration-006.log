{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Wfa2cvcnsG2kXR8Q8qyKX","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/routes/price.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"f004405f-9a6b-4998-9553-abea1f482ac6","timestamp":"2026-04-03T19:52:04.505Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/routes/price.ts","oldString":"async function fetchSolPrice(): Promise<CachedPrice | null> {","newString":"export async function fetchSolPrice(): Promise<CachedPrice | null> {","originalFile":"/**\n * Price routes — cached SOL/USD price from Pyth Hermes.\n */\n\nimport { Hono } from \"hono\";\nimport { HermesClient } from \"@pythnetwork/hermes-client\";\nimport { logger } from \"../logger.js\";\n\n// SOL/USD Pyth feed ID (same on mainnet + devnet)\nconst SOL_USD_FEED_ID =\n  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n\nconst CACHE_TTL_MS = 60_000; // 60 seconds\n\ninterface CachedPrice {\n  price: number;\n  updatedAt: string;\n  fetchedAt: number; // Date.now() for TTL check\n}\n\nlet cached: CachedPrice | null = null;\n\nconst client = new HermesClient(\"https://hermes.pyth.network\", {});\n\nasync function fetchSolPrice(): Promise<CachedPrice | null> {\n  // Return cached if still fresh\n  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n    return cached;\n  }\n\n  try {\n    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n      encoding: \"base64\",\n      parsed: true,\n    });\n    const feed = updates.parsed?.[0];\n    if (!feed?.price) return cached; // stale cache better than nothing\n\n    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n\n    cached = { price, updatedAt, fetchedAt: Date.now() };\n    return cached;\n  } catch (err) {\n    logger.warn(\"hermes: SOL/USD fetch failed\", {\n      error: err instanceof Error ? err.message : String(err),\n    });\n    return cached; // return stale cache on error\n  }\n}\n\nexport function createPriceRoutes() {\n  const app = new Hono();\n\n  app.get(\"/sol-usd\", async (c) => {\n    const result = await fetchSolPrice();\n    if (!result) {\n      return c.json({ error: \"Price unavailable\" }, 503);\n    }\n    return c.json({\n      price: result.price,\n      updatedAt: result.updatedAt,\n    });\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":22,"oldLines":7,"newStart":22,"newLines":7,"lines":[" "," const client = new HermesClient(\"https://hermes.pyth.network\", {});"," ","-async function fetchSolPrice(): Promise<CachedPrice | null> {","+export async function fetchSolPrice(): Promise<CachedPrice | null> {","   // Return cached if still fresh","   if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {","     return cached;"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018nHBiKZTv3N8diJWdVVK7T","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the `POINTS_GRANT` handler."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":254,"cache_read_input_tokens":58028,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":254},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"b6d21141-7d29-49f9-b0a7-1420fc421428"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018nHBiKZTv3N8diJWdVVK7T","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VvLeeAhXVXadAngkMuRpQn","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/points-grant.ts","content":"/**\n * POINTS_GRANT handler — awards points to a player.\n *\n * For wager-based grants: converts lamports → USD → points using config rate\n * and applies any active Dogpile multiplier.\n * For pre-calculated grants (crate_points, challenge_completed, bonus_completed):\n * uses the `amount` field directly.\n *\n * Idempotent via UNIQUE(user_id, source_type, source_id) on point_grants.\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\nimport { readRewardConfig } from \"./reward-pool-fund.js\";\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/**\n * Insert a point grant ledger row. Returns false if a row for this\n * (user_id, source_type, source_id) already exists (idempotency guard).\n */\nexport async function insertPointGrant(\n  db: Db,\n  userId: string,\n  wallet: string,\n  sourceType: string,\n  sourceId: string,\n  amount: bigint,\n  metadata: Record<string, unknown>,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO point_grants (user_id, wallet, source_type, source_id, amount, metadata)\n    VALUES (${userId}, ${wallet}, ${sourceType}, ${sourceId}, ${amount}, ${JSON.stringify(metadata)})\n    ON CONFLICT (user_id, source_type, source_id) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n/**\n * Create or increment player_points. Uses upsert pattern so the first\n * grant for a user creates the row.\n */\nexport async function upsertPlayerPoints(\n  db: Db,\n  userId: string,\n  wallet: string,\n  amount: bigint,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO player_points (user_id, wallet, balance, lifetime_earned, updated_at)\n    VALUES (${userId}, ${wallet}, ${amount}, ${amount}, now())\n    ON CONFLICT (user_id) DO UPDATE SET\n      balance         = player_points.balance + ${amount},\n      lifetime_earned = player_points.lifetime_earned + ${amount},\n      updated_at      = now()\n  `;\n}\n\n/**\n * Returns the multiplier for the currently active Dogpile event, or 1 if\n * none is active.\n */\nexport async function getActiveDogpileMultiplier(\n  db: Db,\n  timestamp: Date,\n): Promise<number> {\n  const rows = await db.rawSql<{ multiplier: string }[]>`\n    SELECT multiplier FROM dogpile_events\n    WHERE status = 'active'\n      AND ${timestamp} BETWEEN starts_at AND ends_at\n    LIMIT 1\n  `;\n  return rows.length > 0 ? parseFloat(rows[0]!.multiplier) : 1;\n}\n\n// ---------------------------------------------------------------------------\n// Handler factory\n// ---------------------------------------------------------------------------\n\nexport interface PointsGrantDeps {\n  db: Db;\n  /** Returns current SOL/USD price, or null if unavailable. */\n  getSolPrice: () => Promise<number | null>;\n}\n\nexport function createPointsGrantHandler(deps: PointsGrantDeps) {\n  const { db, getSolPrice } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const userId = payload.userId as string;\n    const wallet = payload.wallet as string;\n    const sourceType = payload.sourceType as string;\n    const sourceId = payload.sourceId as string;\n\n    if (!userId || !wallet || !sourceType || !sourceId) {\n      throw new Error(\n        \"points.grant: malformed payload — missing userId, wallet, sourceType, or sourceId\",\n      );\n    }\n\n    let pointsAmount: bigint;\n    const metadata: Record<string, unknown> = (payload.metadata as Record<string, unknown>) ?? {};\n\n    if (sourceType === \"wager\") {\n      // Wager-based: calculate from lamports → USD → points\n      const amountLamportsStr = payload.amountLamports as string;\n      if (!amountLamportsStr) {\n        throw new Error(\"points.grant: wager grant missing amountLamports\");\n      }\n\n      const pointsPerDollarStr = await readRewardConfig(db, \"points_per_dollar\");\n      if (!pointsPerDollarStr) {\n        logger.warn(\"points.grant: points_per_dollar not configured, skipping\", { userId, sourceId });\n        return;\n      }\n      const pointsPerDollar = parseFloat(pointsPerDollarStr);\n\n      const solPrice = await getSolPrice();\n      if (solPrice === null || solPrice <= 0) {\n        logger.warn(\"points.grant: SOL/USD price unavailable, skipping\", { userId, sourceId });\n        return;\n      }\n\n      const amountLamports = Number(amountLamportsStr);\n      const wagerSol = amountLamports / 1e9;\n      const wagerUsd = wagerSol * solPrice;\n\n      // Check for active Dogpile multiplier\n      const settledAt = payload.settledAt\n        ? new Date(payload.settledAt as string)\n        : new Date();\n      const multiplier = await getActiveDogpileMultiplier(db, settledAt);\n\n      pointsAmount = BigInt(Math.floor(wagerUsd * pointsPerDollar * multiplier));\n\n      metadata.solPrice = solPrice;\n      metadata.wagerUsd = wagerUsd;\n      metadata.pointsPerDollar = pointsPerDollar;\n      metadata.multiplier = multiplier;\n    } else {\n      // Pre-calculated: crate_points, challenge_completed, bonus_completed\n      const amount = payload.amount as string | number;\n      if (amount === undefined || amount === null) {\n        throw new Error(\"points.grant: non-wager grant missing amount\");\n      }\n      pointsAmount = BigInt(amount);\n    }\n\n    if (pointsAmount <= 0n) {\n      logger.debug(\"points.grant: calculated amount is zero, skipping\", { userId, sourceId, sourceType });\n      return;\n    }\n\n    // Run within a transaction for atomicity\n    await db.withTransaction(async (txDb) => {\n      // Insert ledger row (idempotency guard)\n      const inserted = await insertPointGrant(\n        txDb, userId, wallet, sourceType, sourceId, pointsAmount, metadata,\n      );\n      if (!inserted) {\n        logger.info(\"points.grant: duplicate grant, skipping\", { userId, sourceType, sourceId });\n        return;\n      }\n\n      // Upsert player_points\n      await upsertPlayerPoints(txDb, userId, wallet, pointsAmount);\n\n      logger.info(\"points.grant: points awarded\", {\n        userId,\n        sourceType,\n        sourceId,\n        amount: pointsAmount.toString(),\n      });\n    });\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":254,"cache_read_input_tokens":58028,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":254},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"879f40b8-780d-40e9-a32a-54f2e220afdd","uuid":"0b1beba4-2ab8-4576-a8f7-37586cd43686"}
