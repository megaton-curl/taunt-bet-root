{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01HKJbZkbxKk5BCJP1cU3kNG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016RbUVhq4VfGKKXBzSjiDTG","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","old_string":"  it(\"GET /dogpile/schedule returns empty array when no upcoming events\", async () => {\n    const res = await dogpileApp.request(\"/dogpile/schedule\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n  });\n});","new_string":"  it(\"GET /dogpile/schedule returns empty array when no upcoming events\", async () => {\n    const res = await dogpileApp.request(\"/dogpile/schedule\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Admin API Tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"Admin API: reward-config + reward-pool\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let adminApp: Hono;\n\n  const ADMIN_KEY = \"test-admin-key-secret\";\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n    // Reset reward_config to defaults\n    await rawSql`UPDATE reward_config SET value = '500' WHERE key = 'points_per_dollar'`;\n\n    adminApp = new Hono();\n    adminApp.route(\"/admin\", createAdminRoutes({ db, adminApiKey: ADMIN_KEY }));\n  });\n\n  it(\"request without X-Admin-Key returns 401\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config\", { method: \"GET\" });\n    expect(res.status).toBe(401);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"UNAUTHORIZED\");\n  });\n\n  it(\"request with wrong X-Admin-Key returns 401\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config\", {\n      method: \"GET\",\n      headers: { \"X-Admin-Key\": \"wrong-key\" },\n    });\n    expect(res.status).toBe(401);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"UNAUTHORIZED\");\n  });\n\n  it(\"GET /admin/reward-config returns all seeded defaults\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config\", {\n      method: \"GET\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n\n    // Verify all 11 seeded keys present\n    expect(Object.keys(body)).toHaveLength(11);\n    expect(body.points_per_dollar.value).toBe(\"500\");\n    expect(body.reward_pool_fee_share.value).toBe(\"0.20\");\n    expect(body.sol_crate_drop_rate.value).toBe(\"0.01\");\n    expect(body.daily_challenge_count.value).toBe(\"3\");\n    // Each entry has updatedAt\n    expect(body.points_per_dollar).toHaveProperty(\"updatedAt\");\n  });\n\n  it(\"PUT /admin/reward-config/:key updates value\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config/points_per_dollar\", {\n      method: \"PUT\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ value: \"1000\" }),\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.key).toBe(\"points_per_dollar\");\n    expect(body.value).toBe(\"1000\");\n\n    // Verify persisted\n    const verify = await adminApp.request(\"/admin/reward-config\", {\n      method: \"GET\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY },\n    });\n    const verifyBody = (await verify.json()) as Record<string, any>;\n    expect(verifyBody.points_per_dollar.value).toBe(\"1000\");\n  });\n\n  it(\"PUT /admin/reward-config/:key rejects unknown key with 400\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config/nonexistent_key\", {\n      method: \"PUT\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ value: \"123\" }),\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"INVALID_KEY\");\n  });\n\n  it(\"GET /admin/reward-pool returns pool balance\", async () => {\n    // Fund the pool first\n    await rawSql`UPDATE reward_pool SET balance_lamports = 5000000, lifetime_funded = 10000000, lifetime_paid = 5000000, updated_at = now() WHERE id = 1`;\n\n    const res = await adminApp.request(\"/admin/reward-pool\", {\n      method: \"GET\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.balanceLamports).toBe(\"5000000\");\n    expect(body.lifetimeFunded).toBe(\"10000000\");\n    expect(body.lifetimePaid).toBe(\"5000000\");\n    expect(body).toHaveProperty(\"updatedAt\");\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":362,"cache_read_input_tokens":66881,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":362},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"0d42be1a-ecbc-4165-85cc-a6ac47d0d246"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016RbUVhq4VfGKKXBzSjiDTG","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"b1e7822c-1ba7-4089-a0a6-73d0c27a6adb","timestamp":"2026-04-03T21:17:57.855Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","oldString":"  it(\"GET /dogpile/schedule returns empty array when no upcoming events\", async () => {\n    const res = await dogpileApp.request(\"/dogpile/schedule\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n  });\n});","newString":"  it(\"GET /dogpile/schedule returns empty array when no upcoming events\", async () => {\n    const res = await dogpileApp.request(\"/dogpile/schedule\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Admin API Tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"Admin API: reward-config + reward-pool\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let adminApp: Hono;\n\n  const ADMIN_KEY = \"test-admin-key-secret\";\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n    // Reset reward_config to defaults\n    await rawSql`UPDATE reward_config SET value = '500' WHERE key = 'points_per_dollar'`;\n\n    adminApp = new Hono();\n    adminApp.route(\"/admin\", createAdminRoutes({ db, adminApiKey: ADMIN_KEY }));\n  });\n\n  it(\"request without X-Admin-Key returns 401\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config\", { method: \"GET\" });\n    expect(res.status).toBe(401);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"UNAUTHORIZED\");\n  });\n\n  it(\"request with wrong X-Admin-Key returns 401\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config\", {\n      method: \"GET\",\n      headers: { \"X-Admin-Key\": \"wrong-key\" },\n    });\n    expect(res.status).toBe(401);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"UNAUTHORIZED\");\n  });\n\n  it(\"GET /admin/reward-config returns all seeded defaults\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config\", {\n      method: \"GET\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n\n    // Verify all 11 seeded keys present\n    expect(Object.keys(body)).toHaveLength(11);\n    expect(body.points_per_dollar.value).toBe(\"500\");\n    expect(body.reward_pool_fee_share.value).toBe(\"0.20\");\n    expect(body.sol_crate_drop_rate.value).toBe(\"0.01\");\n    expect(body.daily_challenge_count.value).toBe(\"3\");\n    // Each entry has updatedAt\n    expect(body.points_per_dollar).toHaveProperty(\"updatedAt\");\n  });\n\n  it(\"PUT /admin/reward-config/:key updates value\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config/points_per_dollar\", {\n      method: \"PUT\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ value: \"1000\" }),\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.key).toBe(\"points_per_dollar\");\n    expect(body.value).toBe(\"1000\");\n\n    // Verify persisted\n    const verify = await adminApp.request(\"/admin/reward-config\", {\n      method: \"GET\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY },\n    });\n    const verifyBody = (await verify.json()) as Record<string, any>;\n    expect(verifyBody.points_per_dollar.value).toBe(\"1000\");\n  });\n\n  it(\"PUT /admin/reward-config/:key rejects unknown key with 400\", async () => {\n    const res = await adminApp.request(\"/admin/reward-config/nonexistent_key\", {\n      method: \"PUT\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ value: \"123\" }),\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"INVALID_KEY\");\n  });\n\n  it(\"GET /admin/reward-pool returns pool balance\", async () => {\n    // Fund the pool first\n    await rawSql`UPDATE reward_pool SET balance_lamports = 5000000, lifetime_funded = 10000000, lifetime_paid = 5000000, updated_at = now() WHERE id = 1`;\n\n    const res = await adminApp.request(\"/admin/reward-pool\", {\n      method: \"GET\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.balanceLamports).toBe(\"5000000\");\n    expect(body.lifetimeFunded).toBe(\"10000000\");\n    expect(body.lifetimePaid).toBe(\"5000000\");\n    expect(body).toHaveProperty(\"updatedAt\");\n  });\n});","originalFile":"/**\n * Integration test: full create → join → settle lifecycle.\n *\n * Uses a mock Solana Connection to simulate on-chain state while exercising\n * the real HTTP endpoints, database, settlement worker, and retry logic\n * end-to-end. Auth uses JWT Bearer tokens (HS256).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\nimport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\nimport { createGameSettledHandler } from \"../queue/handlers/game-settled.js\";\nimport { createChallengeRoutes, dailyPeriodKey, weeklyPeriodKey } from \"../routes/challenges.js\";\nimport { createPointsRoutes, createCrateRoutes } from \"../routes/points.js\";\nimport { createDogpileRoutes } from \"../routes/dogpile.js\";\nimport { createAdminRoutes } from \"../routes/admin.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"rng_utopia_dev\",\n  });\n}\n\nconst AMOUNT_LAMPORTS = 5_000_000;\nconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\nconst SIDE_HEADS = 0;\nconst PHASE_LOCKED = 1;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n\n// ---------------------------------------------------------------------------\n// JWT helper\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n// ---------------------------------------------------------------------------\n// Mock Connection\n// ---------------------------------------------------------------------------\n\n/**\n * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n */\nclass MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getSlot() {\n    return this._slot;\n  }\n\n  async getAccountInfo(pubkey: PublicKey) {\n    const acc = this._accounts.get(pubkey.toBase58());\n    if (!acc) return null;\n    return { ...acc, rentEpoch: 0 };\n  }\n\n  async getProgramAccounts(\n    programId: PublicKey,\n    config?: {\n      filters?: Array<\n        | { dataSize: number }\n        | { memcmp: { offset: number; bytes: string } }\n      >;\n    },\n  ) {\n    const results: Array<{\n      pubkey: PublicKey;\n      account: {\n        data: Buffer;\n        lamports: number;\n        owner: PublicKey;\n        executable: boolean;\n        rentEpoch: number;\n      };\n    }> = [];\n\n    for (const [key, acc] of this._accounts) {\n      if (!acc.owner.equals(programId)) continue;\n\n      let matches = true;\n      if (config?.filters) {\n        for (const filter of config.filters) {\n          if (\"dataSize\" in filter) {\n            if (acc.data.length !== filter.dataSize) {\n              matches = false;\n              break;\n            }\n          }\n          if (\"memcmp\" in filter) {\n            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n            const actual = acc.data.subarray(\n              filter.memcmp.offset,\n              filter.memcmp.offset + expected.length,\n            );\n            if (Buffer.compare(actual, expected) !== 0) {\n              matches = false;\n              break;\n            }\n          }\n        }\n      }\n\n      if (matches) {\n        results.push({\n          pubkey: new PublicKey(key),\n          account: { ...acc, rentEpoch: 0 },\n        });\n      }\n    }\n    return results;\n  }\n\n  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n    this.lastRawTx = Buffer.from(rawTx);\n    // Return a deterministic fake signature\n    return bs58.encode(Buffer.alloc(64, 0x01));\n  }\n\n  async confirmTransaction() {\n    return { value: { err: null }, context: { slot: this._slot } };\n  }\n\n  async getBlockTime(_slot: number) {\n    return Math.floor(Date.now() / 1000);\n  }\n\n  async getBalance() {\n    return 2 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Account data builders\n// ---------------------------------------------------------------------------\n\nasync function buildMatchAccountData(params: {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: Buffer;\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  matchId: Buffer;\n}): Promise<Buffer> {\n  return encodeCoinflipMatch({\n    creator: params.creator,\n    opponent: params.opponent,\n    server: params.server,\n    entryAmount: params.entryAmount,\n    creatorSide: params.creatorSide,\n    phase: params.phase,\n    commitment: [...params.commitment],\n    algorithmVer: params.algorithmVer,\n    targetSlot: params.targetSlot,\n    resolveDeadline: params.resolveDeadline,\n    resultHash: new Array(32).fill(0),\n    result: 0,\n    winner: PublicKey.default,\n    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n    matchId: [...params.matchId],\n    bump: 0,\n  });\n}\n\nasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n  return encodeCoinflipConfig({\n    authority: PublicKey.default,\n    treasury,\n    paused: false,\n    bump: 0,\n  });\n}\n\n/**\n * Build PlatformConfig account data matching the on-chain layout.\n * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n */\nfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n  const buf = Buffer.alloc(74);\n  // discriminator (8 bytes) — zeroed is fine for mock\n  // authority at offset 8 — use default\n  PublicKey.default.toBuffer().copy(buf, 8);\n  // treasury at offset 40\n  treasury.toBuffer().copy(buf, 40);\n  // fee_bps at offset 72\n  buf.writeUInt16LE(feeBps, 72);\n  return buf;\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Integration: create → join → settle lifecycle\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    await rawSql`\n      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n    `;\n    await rawSql`\n      CREATE TABLE referral_codes (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id TEXT NOT NULL UNIQUE,\n        wallet TEXT NOT NULL UNIQUE,\n        code TEXT NOT NULL UNIQUE,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE referral_links (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL UNIQUE,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_earnings (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        round_id TEXT NOT NULL,\n        game_type TEXT NOT NULL,\n        wager_lamports BIGINT NOT NULL,\n        fee_lamports BIGINT NOT NULL,\n        referrer_earned_lamports BIGINT NOT NULL,\n        referrer_rate_bps INTEGER NOT NULL,\n        referee_rebate_lamports BIGINT NOT NULL,\n        referee_rebate_rate_bps INTEGER NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_claims (\n        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        amount_lamports BIGINT NOT NULL,\n        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n        retry_count INTEGER NOT NULL DEFAULT 0,\n        tx_signature TEXT,\n        error TEXT,\n        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        processed_at TIMESTAMPTZ\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n    `;\n    await rawSql`\n      CREATE TABLE referral_kol_rates (\n        user_id TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL UNIQUE,\n        rate_bps INTEGER NOT NULL,\n        set_by TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean tables for isolation\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n    // Reset reward_pool balance to zero (keep singleton row from migration seed)\n    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n\n    // Reset PlatformConfig cache so each test reads from its own mock\n    resetPlatformConfigCache();\n\n    // Fresh mock Connection\n    mockConn = new MockConnection();\n\n    // Pre-populate mock with entropy and config accounts\n    mockConn.setAccount(entropyAccount, entropyData);\n\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"coinflip_config\")],\n      COINFLIP_PROGRAM_ID,\n    );\n    mockConn.setAccount(\n      configPda,\n      await buildConfigAccountData(treasuryKeypair.publicKey),\n      { owner: COINFLIP_PROGRAM_ID },\n    );\n\n    // PlatformConfig account — settlement reads fee_bps from here\n    const [platformConfigPda] = derivePlatformConfigPda();\n    mockConn.setAccount(\n      platformConfigPda,\n      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n      { owner: PLATFORM_PROGRAM_ID },\n    );\n\n    // Build the Hono app (no rate limiting for tests)\n    app = new Hono();\n\n    app.use(\n      \"/coinflip/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n\n    app.route(\n      \"/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/rounds\", createRoundsRoutes({ db }));\n  });\n\n  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    // ------------------------------------------------------------------\n    // 1. POST /coinflip/create\n    // ------------------------------------------------------------------\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      transaction: string;\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n      lastValidBlockHeight: number;\n    };\n    expect(createJson.transaction).toBeDefined();\n    expect(createJson.matchPda).toBeDefined();\n    expect(createJson.commitment).toBeDefined();\n    expect(createJson.lastValidBlockHeight).toBeDefined();\n\n    const matchPda = createJson.matchPda;\n    const commitmentHex = createJson.commitment;\n    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n\n    // ------------------------------------------------------------------\n    // 2. Verify DB state — round in \"created\" phase\n    // ------------------------------------------------------------------\n    const round = await db.getRoundByPda(matchPda);\n    expect(round).toBeDefined();\n    expect(round!.phase).toBe(\"created\");\n    expect(round!.game).toBe(\"coinflip\");\n    expect(round!.creator).toBe(wallet);\n    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n    expect(round!.side).toBe(SIDE_HEADS);\n    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n    expect(round!.secret).toBeDefined();\n    expect(round!.secret.length).toBe(32);\n\n    // Verify operator event was logged\n    const events =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n    expect(events.length).toBe(1);\n    expect(events[0]!.event_type).toBe(\"secret_generated\");\n\n    // ------------------------------------------------------------------\n    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n    // ------------------------------------------------------------------\n    const matchPubkey = new PublicKey(matchPda);\n    const targetSlot = 150n;\n    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot,\n      resolveDeadline,\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n\n    // Set current slot past target_slot so settlement triggers immediately\n    mockConn.slot = 200;\n\n    // ------------------------------------------------------------------\n    // 4. Create worker + retry settler, trigger poll\n    // ------------------------------------------------------------------\n    let settlePromise: Promise<void> | null = null;\n\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000, // won't auto-poll\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    // Single poll cycle — should discover locked match and settle it\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    // ------------------------------------------------------------------\n    // 5. Verify DB updated to \"settled\" with result data\n    // ------------------------------------------------------------------\n    const settled = await db.getRoundByPda(matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n    expect(settled!.settle_tx).toBeDefined();\n    expect(settled!.result_hash).toBeDefined();\n    expect(settled!.result_hash!.length).toBe(32);\n    expect(settled!.result_side).toBeDefined();\n    expect([0, 1]).toContain(settled!.result_side);\n    expect(settled!.winner).toBeDefined();\n\n    // Winner should be one of the two players\n    expect([\n      creatorKeypair.publicKey.toBase58(),\n      opponentKeypair.publicKey.toBase58(),\n    ]).toContain(settled!.winner);\n\n    // Verify operator events trail\n    const allEvents =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n    const eventTypes = allEvents.map(\n      (e) => (e as Record<string, unknown>).event_type,\n    );\n    expect(eventTypes).toContain(\"secret_generated\");\n    expect(eventTypes).toContain(\"match_detected\");\n    expect(eventTypes).toContain(\"settle_submitted\");\n    expect(eventTypes).toContain(\"settle_confirmed\");\n\n    // ------------------------------------------------------------------\n    // 6. GET /rounds/:pda — verify response includes secret\n    // ------------------------------------------------------------------\n    const roundsRes = await app.request(`/rounds/${matchPda}`);\n    expect(roundsRes.status).toBe(200);\n\n    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n    expect(roundsJson.pda).toBe(matchPda);\n    expect(roundsJson.phase).toBe(\"settled\");\n    expect(roundsJson.game).toBe(\"coinflip\");\n    expect(roundsJson.creator).toBe(wallet);\n    expect(roundsJson.commitment).toBe(commitmentHex);\n\n    // Settled round should include secret + verification payload\n    expect(roundsJson.secret).toBeDefined();\n    expect(typeof roundsJson.secret).toBe(\"string\");\n    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n    expect(roundsJson.resultHash).toBeDefined();\n    expect(roundsJson.resultSide).toBeDefined();\n    expect(roundsJson.winner).toBeDefined();\n    expect(roundsJson.settleTx).toBeDefined();\n\n    // Verification object\n    const verification = roundsJson.verification as Record<string, string>;\n    expect(verification).toBeDefined();\n    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n    expect(verification.resultFormula).toContain(\"sha256(secret\");\n    expect(verification.entropySource).toContain(\"SlotHashes\");\n  });\n\n  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n    const unknownPda = Keypair.generate().publicKey.toBase58();\n    const res = await app.request(`/rounds/${unknownPda}`);\n    expect(res.status).toBe(404);\n  });\n\n  it(\"unsettled round does not expose secret\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n\n    const res = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { matchPda: string };\n\n    // GET the unsettled round\n    const roundRes = await app.request(`/rounds/${json.matchPda}`);\n    expect(roundRes.status).toBe(200);\n    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n    expect(roundJson.phase).toBe(\"created\");\n    expect(roundJson.secret).toBeUndefined();\n    expect(roundJson.resultHash).toBeUndefined();\n    expect(roundJson.verification).toBeUndefined();\n  });\n\n  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const res1 = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body1),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second request — different random matchId generated server-side\n    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const res2 = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body2),\n    });\n    expect(res2.status).toBe(200);\n\n    // Both should have different matchIds and PDAs\n    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n    expect(json1.matchPda).not.toBe(json2.matchPda);\n    expect(json1.matchId).not.toBe(json2.matchId);\n  });\n\n  it(\"settlement records referral earnings for referred player\", async () => {\n    // Referrer is a third party; opponent is the referred player\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n    const referrerUserId = referrerProfile.user_id;\n    const opponentUserId = opponentProfile.user_id;\n    const creatorUserId = creatorProfile.user_id;\n\n    // Set up referral link: referrer → opponent (opponent is the referee)\n    await db.insertReferralCode(referrerUserId, referrerWallet, \"test-ref\");\n    await db.insertReferralLink({\n      referrerUserId,\n      refereeUserId: opponentUserId,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n\n    // 1. Create a coinflip match\n    const token = await makeJwt(creatorWallet, creatorUserId);\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    // 2. Simulate on-chain join (opponent joins the match)\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n    const targetSlot = 150n;\n    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot,\n      resolveDeadline,\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    // 3. Settle the match\n    let settlePromise: Promise<void> | null = null;\n\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    // 4. Verify match settled\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n\n    // 5. Verify referral earnings recorded for the opponent (the referee)\n    // Expected: wager=5_000_000, fee=5_000_000*500/10_000=250_000\n    //           referrer_earned=250_000*1000/10_000=25_000\n    //           referee_rebate=250_000*1000/10_000=25_000\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n    expect(earnings.length).toBe(1);\n\n    const earning = earnings[0]!;\n    expect(earning.referrer_user_id).toBe(referrerUserId);\n    expect(earning.referee_user_id).toBe(opponentUserId);\n    expect(earning.referrer_wallet).toBe(referrerWallet);\n    expect(earning.referee_wallet).toBe(opponentWallet);\n    expect(earning.round_id).toBe(createJson.matchId);\n    expect(earning.game_type).toBe(\"coinflip\");\n    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS); // 5_000_000\n    expect(Number(earning.fee_lamports)).toBe(250_000); // 5_000_000 * 500 / 10_000\n    expect(Number(earning.referrer_earned_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n\n    // Creator is NOT referred, so no earnings for creator\n    const creatorEarnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${creatorUserId}`;\n    expect(creatorEarnings.length).toBe(0);\n  });\n\n  it(\"settlement uses KOL custom rate for referrer earnings\", async () => {\n    // Referrer has a KOL rate of 2000 bps (20% of fee)\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n    const referrerUserId = referrerProfile.user_id;\n    const opponentUserId = opponentProfile.user_id;\n\n    // Set up referral link + KOL rate override\n    await db.insertReferralCode(referrerUserId, referrerWallet, \"kol-code\");\n    await db.insertReferralLink({\n      referrerUserId,\n      refereeUserId: opponentUserId,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n    await rawSql`INSERT INTO referral_kol_rates (user_id, wallet, rate_bps, set_by) VALUES (${referrerUserId}, ${referrerWallet}, 2000, 'admin')`;\n\n    // Create + settle a coinflip match\n    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise2: Promise<void> | null = null;\n\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise2 = retrySettler.attemptSettle(pda);\n        return settlePromise2;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise2) await settlePromise2;\n\n    // Verify settlement completed\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled!.phase).toBe(\"settled\");\n\n    // Verify KOL rate was used for referrer earning\n    // fee = 5_000_000 * 500 / 10_000 = 250_000\n    // referrer_earned = 250_000 * 2000 / 10_000 = 50_000 (KOL rate)\n    // referee_rebate = 250_000 * 1000 / 10_000 = 25_000 (always fixed 10%)\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n    expect(earnings.length).toBe(1);\n\n    const earning = earnings[0]!;\n    expect(Number(earning.referrer_earned_lamports)).toBe(50_000); // KOL: 2000 bps\n    expect(Number(earning.referrer_rate_bps)).toBe(2000);\n    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // Fixed 10%\n    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n  });\n\n  it(\"settlement emits game.settled event with correct payload shape\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    // Create profiles for both players so game entries + event payloads get user IDs\n    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    // Create round via API\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    // Simulate on-chain join — LOCKED match in mock\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n\n    // Transition DB round to \"locked\" (normally the settlement worker does this on join detection)\n    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n\n    // Settle directly\n    await settleMatch(\n      {\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n        entropyAccount,\n        referralDefaultRateBps: 1000,\n      },\n      createJson.matchPda,\n    );\n\n    // Verify game.settled event was emitted in event_queue\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n\n    const evt = events[0]!;\n    expect(evt.status).toBe(\"pending\");\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const payload = evt.payload as any;\n    expect(payload.roundId).toBe(createJson.matchId);\n    expect(payload.roundPda).toBe(createJson.matchPda);\n    expect(payload.game).toBe(\"coinflip\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n\n    // Players array\n    expect(payload.players).toHaveLength(2);\n    const creator = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === creatorKeypair.publicKey.toBase58(),\n    );\n    const opponent = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === opponentKeypair.publicKey.toBase58(),\n    );\n    expect(creator).toBeDefined();\n    expect(opponent).toBeDefined();\n    expect(creator.isCreator).toBe(true);\n    expect(opponent.isCreator).toBe(false);\n    expect(creator.userId).toBe(creatorUserId);\n    expect(opponent.userId).toBe(opponentUserId);\n    // Amounts are string-encoded lamports\n    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n    // Exactly one winner\n    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n    // Winner has payoutLamports > 0, loser has \"0\"\n    const winnerPlayer = creator.isWinner ? creator : opponent;\n    const loserPlayer = creator.isWinner ? opponent : creator;\n    expect(Number(winnerPlayer.payoutLamports)).toBeGreaterThan(0);\n    expect(loserPlayer.payoutLamports).toBe(\"0\");\n    // Fee = pool * 500 / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n    expect(payload.feeLamports).toBe(String(500_000));\n  });\n\n  it(\"duplicate settlement retry produces duplicate game.settled event rows safely\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n\n    // Transition DB round to \"locked\"\n    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n\n    // First settle\n    await settleMatch(\n      {\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n        entropyAccount,\n        referralDefaultRateBps: 1000,\n      },\n      createJson.matchPda,\n    );\n\n    // Second settle attempt — should fail on phase check (already settled),\n    // but the first call already produced the event. Verify 1 event row exists.\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n\n    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n    // The first settle succeeded; a retry would be rejected by phase check before reaching\n    // the DB transaction. This test confirms the first call produces exactly 1 event.\n  });\n\n  it(\"closecall settlement emits game.settled event with correct payload shape\", async () => {\n    // Two players: one green, one red\n    const greenPlayer = Keypair.generate();\n    const redPlayer = Keypair.generate();\n    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());\n    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n\n    // Insert player profiles\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    // Create a round with minuteTs = 2 minutes ago (candle is closed)\n    const nowSec = Math.floor(Date.now() / 1000);\n    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n    const greenAmount = 5_000_000n;\n    const redAmount = 5_000_000n;\n    const openPrice = 69500_00n; // $69500.00 with expo -2\n\n    // Derive round PDA (seeds: [\"round\", minute_ts as LE i64, server pubkey])\n    const minuteTsBuf = Buffer.alloc(8);\n    minuteTsBuf.writeBigInt64LE(minuteTs);\n    const [roundPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n      CLOSECALL_PROGRAM_ID,\n    );\n\n    // Build on-chain round account data (phase=Open, with entries)\n    const roundAccountData = await encodeCloseCallRound({\n      minuteTs,\n      server: serverKeypair.publicKey,\n      phase: 0, // Open\n      greenEntries: [{ player: greenPlayer.publicKey, amountLamports: greenAmount }],\n      redEntries: [{ player: redPlayer.publicKey, amountLamports: redAmount }],\n      greenPool: greenAmount,\n      redPool: redAmount,\n      openPrice,\n      openPriceExpo: -2,\n      closePrice: 0n,\n      createdAt: minuteTs,\n      bettingEndsAt: minuteTs + 45n,\n      resolveDeadline: minuteTs + 300n,\n      outcome: 0, // Pending\n      totalFee: 0n,\n      bump: 0,\n    });\n\n    mockConn.setAccount(roundPda, roundAccountData, {\n      owner: CLOSECALL_PROGRAM_ID,\n    });\n\n    // Mock Hermes: returns a price > openPrice so outcome = green\n    // publishTime must be >= current minute boundary so captureBoundaryPrice() succeeds immediately\n    const closePrice = 69600_00n; // $69600.00\n    const mockHermes: HermesFetcher = {\n      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n        price: closePrice,\n        expo: -2,\n        publishTime: Math.floor(Date.now() / 1000), // always \"current\"\n        priceHuman: 69600.0,\n        vaaBase64: null,\n      }),\n    };\n\n    // Create clock worker with mock deps\n    const clock = createCloseCallClockWorker({\n      connection: mockConn as unknown as Connection,\n      serverKeypair,\n      db,\n      hermesFetcher: mockHermes,\n    });\n\n    // Call tick() — discovers the open round, captures boundary price, settles\n    await clock.tick();\n\n    // Verify game.settled event was emitted in event_queue\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n\n    const evt = events[0]!;\n    expect(evt.status).toBe(\"pending\");\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const payload = evt.payload as any;\n    expect(payload.roundId).toBe(String(Number(minuteTs)));\n    expect(payload.roundPda).toBe(roundPda.toBase58());\n    expect(payload.game).toBe(\"closecall\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n\n    // Players array — both players should be present\n    expect(payload.players).toHaveLength(2);\n    const greenP = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === greenPlayer.publicKey.toBase58(),\n    );\n    const redP = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === redPlayer.publicKey.toBase58(),\n    );\n    expect(greenP).toBeDefined();\n    expect(redP).toBeDefined();\n    expect(greenP.userId).toBe(greenUserId);\n    expect(redP.userId).toBe(redUserId);\n    // Amounts are string-encoded lamports\n    expect(greenP.amountLamports).toBe(String(greenAmount));\n    expect(redP.amountLamports).toBe(String(redAmount));\n    // Green wins (closePrice > openPrice)\n    expect(greenP.isWinner).toBe(true);\n    expect(redP.isWinner).toBe(false);\n    // Winner payout > 0, loser payout = \"0\"\n    expect(Number(greenP.payoutLamports)).toBeGreaterThan(0);\n    expect(redP.payoutLamports).toBe(\"0\");\n    // Fee = totalPool * 500 bps / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n    expect(payload.feeLamports).toBe(String(500_000));\n    // isCreator: first entry (green) is creator\n    expect(greenP.isCreator).toBe(true);\n    expect(redP.isCreator).toBe(false);\n  });\n\n  // ---------------------------------------------------------------------------\n  // REWARD_POOL_FUND handler\n  // ---------------------------------------------------------------------------\n\n  it(\"reward.pool_fund handler: funds pool from fee and dedupes on round_id\", async () => {\n    // Ensure reward_config has the fee share (seeded by migration, but verify)\n    const configRows = await rawSql<{ value: string }[]>`\n      SELECT value FROM reward_config WHERE key = 'reward_pool_fee_share'\n    `;\n    if (configRows.length === 0) {\n      // Re-seed if TRUNCATE removed it\n      await rawSql`INSERT INTO reward_config (key, value) VALUES ('reward_pool_fee_share', '0.20')`;\n    }\n\n    // Verify pool starts at zero\n    const poolBefore = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n    `;\n    expect(poolBefore.length).toBe(1);\n    expect(BigInt(poolBefore[0]!.balance_lamports)).toBe(0n);\n    expect(BigInt(poolBefore[0]!.lifetime_funded)).toBe(0n);\n\n    // Create handler and call it directly\n    const handler = createRewardPoolFundHandler({ db });\n\n    const feeLamports = \"500000\"; // 500_000 lamports fee\n    const roundId = \"test-round-pool-fund-001\";\n\n    await handler({\n      roundId,\n      feeLamports,\n    });\n\n    // Expected funded = floor(500_000 * 0.20) = 100_000\n    const expectedFunded = 100_000n;\n\n    // Verify reward_pool_fundings row\n    const fundings = await rawSql<{\n      round_id: string;\n      fee_lamports: string;\n      funded_lamports: string;\n    }[]>`\n      SELECT round_id, fee_lamports, funded_lamports FROM reward_pool_fundings WHERE round_id = ${roundId}\n    `;\n    expect(fundings.length).toBe(1);\n    expect(fundings[0]!.round_id).toBe(roundId);\n    expect(BigInt(fundings[0]!.fee_lamports)).toBe(500_000n);\n    expect(BigInt(fundings[0]!.funded_lamports)).toBe(expectedFunded);\n\n    // Verify pool balance incremented\n    const poolAfter = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n    `;\n    expect(BigInt(poolAfter[0]!.balance_lamports)).toBe(expectedFunded);\n    expect(BigInt(poolAfter[0]!.lifetime_funded)).toBe(expectedFunded);\n\n    // --- Idempotency: re-emit same round_id ---\n    await handler({\n      roundId,\n      feeLamports,\n    });\n\n    // Verify no duplicate funding row\n    const fundingsAfterDupe = await rawSql<{ id: string }[]>`\n      SELECT id FROM reward_pool_fundings WHERE round_id = ${roundId}\n    `;\n    expect(fundingsAfterDupe.length).toBe(1);\n\n    // Verify pool balance unchanged\n    const poolAfterDupe = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n    `;\n    expect(BigInt(poolAfterDupe[0]!.balance_lamports)).toBe(expectedFunded);\n    expect(BigInt(poolAfterDupe[0]!.lifetime_funded)).toBe(expectedFunded);\n  });\n\n  // ---------------------------------------------------------------------------\n  // POINTS_GRANT handler\n  // ---------------------------------------------------------------------------\n\n  it(\"points.grant handler: awards wager-based points and dedupes\", async () => {\n    // Ensure reward_config has points_per_dollar\n    const configRows = await rawSql<{ value: string }[]>`\n      SELECT value FROM reward_config WHERE key = 'points_per_dollar'\n    `;\n    if (configRows.length === 0) {\n      await rawSql`INSERT INTO reward_config (key, value) VALUES ('points_per_dollar', '500')`;\n    }\n\n    // Mock SOL/USD price at $100\n    const mockSolPrice = 100;\n    const handler = createPointsGrantHandler({\n      db,\n      getSolPrice: async () => mockSolPrice,\n    });\n\n    const userId = \"usr_pointstest1\";\n    const wallet = \"PointsTestWallet1111111111111111111111111\";\n    const sourceId = \"test-round-points-001\";\n    const amountLamports = \"50000000\"; // 0.05 SOL\n\n    await handler({\n      userId,\n      wallet,\n      sourceType: \"wager\",\n      sourceId,\n      amountLamports,\n      settledAt: new Date().toISOString(),\n    });\n\n    // Expected: 0.05 SOL * $100 = $5.00 * 500 points/dollar = 2500 points\n    const expectedPoints = 2500n;\n\n    // Verify point_grants row\n    const grants = await rawSql<{\n      user_id: string;\n      wallet: string;\n      source_type: string;\n      source_id: string;\n      amount: string;\n      metadata: string;\n    }[]>`\n      SELECT user_id, wallet, source_type, source_id, amount, metadata\n      FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n    `;\n    expect(grants.length).toBe(1);\n    expect(grants[0]!.source_type).toBe(\"wager\");\n    expect(BigInt(grants[0]!.amount)).toBe(expectedPoints);\n    const meta = typeof grants[0]!.metadata === \"string\"\n      ? JSON.parse(grants[0]!.metadata) : grants[0]!.metadata;\n    expect(meta).toMatchObject({\n      solPrice: mockSolPrice,\n      pointsPerDollar: 500,\n      multiplier: 1,\n    });\n\n    // Verify player_points upserted\n    const pp = await rawSql<{ balance: string; lifetime_earned: string }[]>`\n      SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n    `;\n    expect(pp.length).toBe(1);\n    expect(BigInt(pp[0]!.balance)).toBe(expectedPoints);\n    expect(BigInt(pp[0]!.lifetime_earned)).toBe(expectedPoints);\n\n    // --- Idempotency: re-emit same grant ---\n    await handler({\n      userId,\n      wallet,\n      sourceType: \"wager\",\n      sourceId,\n      amountLamports,\n      settledAt: new Date().toISOString(),\n    });\n\n    // Verify no duplicate grant row\n    const grantsAfterDupe = await rawSql<{ id: string }[]>`\n      SELECT id FROM point_grants WHERE user_id = ${userId} AND source_type = 'wager' AND source_id = ${sourceId}\n    `;\n    expect(grantsAfterDupe.length).toBe(1);\n\n    // Verify balance unchanged\n    const ppAfterDupe = await rawSql<{ balance: string }[]>`\n      SELECT balance FROM player_points WHERE user_id = ${userId}\n    `;\n    expect(BigInt(ppAfterDupe[0]!.balance)).toBe(expectedPoints);\n  });\n\n  it(\"points.grant handler: applies Dogpile 2x multiplier when active\", async () => {\n    // Ensure points_per_dollar config\n    const configRows = await rawSql<{ value: string }[]>`\n      SELECT value FROM reward_config WHERE key = 'points_per_dollar'\n    `;\n    if (configRows.length === 0) {\n      await rawSql`INSERT INTO reward_config (key, value) VALUES ('points_per_dollar', '500')`;\n    }\n\n    // Insert an active Dogpile event covering now\n    const now = new Date();\n    const startsAt = new Date(now.getTime() - 60_000); // started 1 min ago\n    const endsAt = new Date(now.getTime() + 60_000);   // ends in 1 min\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (${startsAt}, ${endsAt}, 2.0, 'active')\n    `;\n\n    const handler = createPointsGrantHandler({\n      db,\n      getSolPrice: async () => 100,\n    });\n\n    const userId = \"usr_dogpiletest1\";\n    const wallet = \"DogpileTestWallet111111111111111111111111\";\n    const sourceId = \"test-round-dogpile-001\";\n\n    await handler({\n      userId,\n      wallet,\n      sourceType: \"wager\",\n      sourceId,\n      amountLamports: \"50000000\", // 0.05 SOL\n      settledAt: now.toISOString(),\n    });\n\n    // Expected: 0.05 SOL * $100 = $5.00 * 500 * 2.0 dogpile = 5000 points\n    const expectedPoints = 5000n;\n\n    const grants = await rawSql<{ amount: string; metadata: string }[]>`\n      SELECT amount, metadata FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n    `;\n    expect(grants.length).toBe(1);\n    expect(BigInt(grants[0]!.amount)).toBe(expectedPoints);\n    const dogpileMeta = typeof grants[0]!.metadata === \"string\"\n      ? JSON.parse(grants[0]!.metadata) : grants[0]!.metadata;\n    expect(dogpileMeta).toMatchObject({ multiplier: 2 });\n\n    const pp = await rawSql<{ balance: string }[]>`\n      SELECT balance FROM player_points WHERE user_id = ${userId}\n    `;\n    expect(BigInt(pp[0]!.balance)).toBe(expectedPoints);\n  });\n\n  it(\"points.grant handler: handles pre-calculated crate_points grant\", async () => {\n    const handler = createPointsGrantHandler({\n      db,\n      getSolPrice: async () => 100,\n    });\n\n    const userId = \"usr_cratepoints1\";\n    const wallet = \"CratePointsWallet11111111111111111111111\";\n    const sourceId = \"crate-drop-001\";\n\n    await handler({\n      userId,\n      wallet,\n      sourceType: \"crate_points\",\n      sourceId,\n      amount: \"3000\",\n    });\n\n    const grants = await rawSql<{ amount: string; source_type: string }[]>`\n      SELECT amount, source_type FROM point_grants WHERE user_id = ${userId} AND source_id = ${sourceId}\n    `;\n    expect(grants.length).toBe(1);\n    expect(grants[0]!.source_type).toBe(\"crate_points\");\n    expect(BigInt(grants[0]!.amount)).toBe(3000n);\n\n    const pp = await rawSql<{ balance: string; lifetime_earned: string }[]>`\n      SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n    `;\n    expect(pp.length).toBe(1);\n    expect(BigInt(pp[0]!.balance)).toBe(3000n);\n    expect(BigInt(pp[0]!.lifetime_earned)).toBe(3000n);\n  });\n\n  // -----------------------------------------------------------------------\n  // CRATE_DROP handler tests\n  // -----------------------------------------------------------------------\n\n  it(\"crate.drop handler: SOL crate hit — decrements pool, creates crate row, emits sol_payout\", async () => {\n    // Fund the reward pool so a SOL crate can be funded\n    // sol_crate_min_value is 10_000_000 (10M lamports = 0.01 SOL)\n    // sol_crate_pool_pct is 0.10 → need pool >= 100_000_000 to get payout >= 10M\n    await rawSql`UPDATE reward_pool SET balance_lamports = 200000000, lifetime_funded = 200000000 WHERE id = 1`;\n\n    // Roll = 0.005, which is < sol_crate_drop_rate (0.01) → SOL crate hit\n    const handler = createCrateDropHandler({\n      db,\n      rollRng: () => 0.005,\n    });\n\n    const userId = \"usr_cratesol1\";\n    const wallet = \"CrateSolWallet1111111111111111111111111\";\n    const triggerId = \"test-round-crate-sol-001\";\n\n    await handler({\n      userId,\n      wallet,\n      triggerType: \"game_settled\",\n      triggerId,\n    });\n\n    // Expected payout: floor(200_000_000 * 0.10) = 20_000_000\n    const expectedPayout = 20_000_000n;\n\n    // Verify crate_drops row\n    const crates = await rawSql<{\n      user_id: string;\n      trigger_type: string;\n      trigger_id: string;\n      crate_type: string;\n      contents_amount: string;\n      status: string;\n    }[]>`\n      SELECT user_id, trigger_type, trigger_id, crate_type, contents_amount, status\n      FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n    `;\n    expect(crates.length).toBe(1);\n    expect(crates[0]!.crate_type).toBe(\"sol\");\n    expect(BigInt(crates[0]!.contents_amount)).toBe(expectedPayout);\n    expect(crates[0]!.status).toBe(\"pending\");\n\n    // Verify pool decremented\n    const pool = await rawSql<{ balance_lamports: string; lifetime_paid: string }[]>`\n      SELECT balance_lamports, lifetime_paid FROM reward_pool WHERE id = 1\n    `;\n    expect(BigInt(pool[0]!.balance_lamports)).toBe(200_000_000n - expectedPayout);\n    expect(BigInt(pool[0]!.lifetime_paid)).toBe(expectedPayout);\n\n    // Verify CRATE_SOL_PAYOUT event emitted\n    const events = await rawSql<{ event_type: string; payload: string }[]>`\n      SELECT event_type, payload FROM event_queue WHERE event_type = 'crate.sol_payout'\n    `;\n    expect(events.length).toBe(1);\n    const eventPayload = typeof events[0]!.payload === \"string\"\n      ? JSON.parse(events[0]!.payload) : events[0]!.payload;\n    expect(eventPayload.userId).toBe(userId);\n    expect(eventPayload.wallet).toBe(wallet);\n    expect(eventPayload.payoutLamports).toBe(expectedPayout.toString());\n  });\n\n  it(\"crate.drop handler: points crate hit — creates crate row, emits points.grant\", async () => {\n    // Roll = 0.02, which is >= sol_crate_drop_rate (0.01) but < 0.01 + 0.05 = 0.06 → points crate\n    // Second roll for points amount: 0.5 → min + floor(0.5 * (max - min + 1)) = 500 + floor(0.5 * 4501) = 500 + 2250 = 2750\n    const rolls = [0.02, 0.5];\n    let rollIdx = 0;\n    const handler = createCrateDropHandler({\n      db,\n      rollRng: () => rolls[rollIdx++]!,\n    });\n\n    const userId = \"usr_cratepoints2\";\n    const wallet = \"CratePointsWallet2111111111111111111111\";\n    const triggerId = \"test-round-crate-pts-001\";\n\n    await handler({\n      userId,\n      wallet,\n      triggerType: \"game_settled\",\n      triggerId,\n    });\n\n    // Expected points: 500 + floor(0.5 * (5000 - 500 + 1)) = 500 + 2250 = 2750\n    const expectedPoints = 2750;\n\n    // Verify crate_drops row\n    const crates = await rawSql<{\n      crate_type: string;\n      contents_amount: string;\n    }[]>`\n      SELECT crate_type, contents_amount\n      FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n    `;\n    expect(crates.length).toBe(1);\n    expect(crates[0]!.crate_type).toBe(\"points\");\n    expect(parseInt(crates[0]!.contents_amount, 10)).toBe(expectedPoints);\n\n    // Verify POINTS_GRANT event emitted\n    const events = await rawSql<{ event_type: string; payload: string }[]>`\n      SELECT event_type, payload FROM event_queue WHERE event_type = 'points.grant'\n    `;\n    expect(events.length).toBe(1);\n    const eventPayload = typeof events[0]!.payload === \"string\"\n      ? JSON.parse(events[0]!.payload) : events[0]!.payload;\n    expect(eventPayload.userId).toBe(userId);\n    expect(eventPayload.sourceType).toBe(\"crate_points\");\n    expect(eventPayload.sourceId).toBe(`crate-${triggerId}`);\n    expect(eventPayload.amount).toBe(expectedPoints.toString());\n  });\n\n  it(\"crate.drop handler: miss — no crate row created\", async () => {\n    // Roll = 0.50, which is >= sol_crate_drop_rate + points_crate_drop_rate (0.06) → miss\n    const handler = createCrateDropHandler({\n      db,\n      rollRng: () => 0.50,\n    });\n\n    const userId = \"usr_cratemiss1\";\n    const wallet = \"CrateMissWallet1111111111111111111111111\";\n    const triggerId = \"test-round-crate-miss-001\";\n\n    await handler({\n      userId,\n      wallet,\n      triggerType: \"game_settled\",\n      triggerId,\n    });\n\n    // Verify no crate_drops row\n    const crates = await rawSql<{ id: string }[]>`\n      SELECT id FROM crate_drops WHERE user_id = ${userId}\n    `;\n    expect(crates.length).toBe(0);\n\n    // Verify no events emitted\n    const events = await rawSql<{ id: string }[]>`\n      SELECT id FROM event_queue WHERE event_type IN ('crate.sol_payout', 'points.grant')\n    `;\n    expect(events.length).toBe(0);\n  });\n\n  it(\"crate.drop handler: SOL crate suppressed when pool below min_value\", async () => {\n    // Pool balance too low: 50_000_000 * 0.10 = 5_000_000 < 10_000_000 min\n    await rawSql`UPDATE reward_pool SET balance_lamports = 50000000, lifetime_funded = 50000000 WHERE id = 1`;\n\n    // Roll = 0.005 → would be SOL crate, but pool can't fund it\n    const handler = createCrateDropHandler({\n      db,\n      rollRng: () => 0.005,\n    });\n\n    const userId = \"usr_cratesuppress1\";\n    const wallet = \"CrateSuppressWallet11111111111111111111\";\n    const triggerId = \"test-round-crate-suppress-001\";\n\n    await handler({\n      userId,\n      wallet,\n      triggerType: \"game_settled\",\n      triggerId,\n    });\n\n    // Verify no crate_drops row (suppressed, not even recorded)\n    const crates = await rawSql<{ id: string }[]>`\n      SELECT id FROM crate_drops WHERE user_id = ${userId}\n    `;\n    expect(crates.length).toBe(0);\n\n    // Verify pool balance unchanged\n    const pool = await rawSql<{ balance_lamports: string }[]>`\n      SELECT balance_lamports FROM reward_pool WHERE id = 1\n    `;\n    expect(BigInt(pool[0]!.balance_lamports)).toBe(50_000_000n);\n  });\n\n  it(\"crate.drop handler: idempotent — duplicate trigger skips\", async () => {\n    // Fund pool for SOL crate\n    await rawSql`UPDATE reward_pool SET balance_lamports = 200000000, lifetime_funded = 200000000 WHERE id = 1`;\n\n    const handler = createCrateDropHandler({\n      db,\n      rollRng: () => 0.005, // SOL crate hit\n    });\n\n    const userId = \"usr_cratededup1\";\n    const wallet = \"CrateDedupWallet1111111111111111111111\";\n    const triggerId = \"test-round-crate-dedup-001\";\n\n    // First call\n    await handler({\n      userId,\n      wallet,\n      triggerType: \"game_settled\",\n      triggerId,\n    });\n\n    const poolAfterFirst = await rawSql<{ balance_lamports: string }[]>`\n      SELECT balance_lamports FROM reward_pool WHERE id = 1\n    `;\n    const balanceAfterFirst = BigInt(poolAfterFirst[0]!.balance_lamports);\n\n    // Second call with same trigger — should be idempotent\n    await handler({\n      userId,\n      wallet,\n      triggerType: \"game_settled\",\n      triggerId,\n    });\n\n    // Verify still only one crate row\n    const crates = await rawSql<{ id: string }[]>`\n      SELECT id FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n    `;\n    expect(crates.length).toBe(1);\n\n    // Verify pool not decremented again\n    const poolAfterSecond = await rawSql<{ balance_lamports: string }[]>`\n      SELECT balance_lamports FROM reward_pool WHERE id = 1\n    `;\n    expect(BigInt(poolAfterSecond[0]!.balance_lamports)).toBe(balanceAfterFirst);\n  });\n\n  // =====================================================================\n  // GAME_SETTLED handler (orchestrator)\n  // =====================================================================\n\n  it(\"game.settled handler: processes challenge progress + emits reward events\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_gs_progress1\";\n    const wallet = \"GsProgressWallet1111111111111111111111\";\n\n    // Look up the 'Play 3 Games' daily challenge (game_completed, scope=any, threshold=3)\n    const challenges = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenges WHERE title = 'Play 3 Games' LIMIT 1\n    `;\n    expect(challenges.length).toBe(1);\n    const challengeId = challenges[0]!.id;\n\n    // Create an active assignment for this user\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n      VALUES (${userId}, ${challengeId}, 'daily:2026-04-03', 3)\n    `;\n\n    // Emit a game.settled event\n    await handler({\n      roundId: \"test-gs-round-001\",\n      roundPda: \"GsRoundPda111111111111111111111111111\",\n      game: \"coinflip\",\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner: true,\n          payoutLamports: \"9500000\",\n          isCreator: true,\n        },\n      ],\n      feeLamports: \"500000\",\n      settledAt: new Date().toISOString(),\n    });\n\n    // Verify progress incremented to 1\n    const assignments = await rawSql<{ progress: number; status: string }[]>`\n      SELECT progress, status FROM challenge_assignments WHERE user_id = ${userId}\n    `;\n    expect(assignments[0]!.progress).toBe(1);\n    expect(assignments[0]!.status).toBe(\"active\");\n\n    // Verify progress_events row\n    const progressEvents = await rawSql<{ round_id: string; progress_delta: number }[]>`\n      SELECT round_id, progress_delta FROM progress_events WHERE user_id = ${userId}\n    `;\n    expect(progressEvents.length).toBe(1);\n    expect(progressEvents[0]!.round_id).toBe(\"test-gs-round-001\");\n    expect(progressEvents[0]!.progress_delta).toBe(1);\n\n    // Verify reward events emitted: reward.pool_fund, points.grant (wager), crate.drop\n    const events = await rawSql<{ event_type: string }[]>`\n      SELECT event_type FROM event_queue ORDER BY id\n    `;\n    const types = events.map((e) => e.event_type);\n    expect(types).toContain(\"reward.pool_fund\");\n    expect(types).toContain(\"points.grant\");\n    expect(types).toContain(\"crate.drop\");\n  });\n\n  it(\"game.settled handler: completes challenge + emits reward intent when target reached\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_gs_complete1\";\n    const wallet = \"GsCompleteWallet11111111111111111111\";\n\n    // Look up 'Win a Coinflip' daily challenge (game_won, scope=coinflip, threshold=1, reward=150 points)\n    const challenges = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenges WHERE title = 'Win a Coinflip' LIMIT 1\n    `;\n    const challengeId = challenges[0]!.id;\n\n    // Create assignment at 0 progress, target 1\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n      VALUES (${userId}, ${challengeId}, 'daily:2026-04-03', 1)\n    `;\n\n    // Win a coinflip — should complete the challenge\n    await handler({\n      roundId: \"test-gs-complete-001\",\n      roundPda: \"GsCompletePda1111111111111111111111111\",\n      game: \"coinflip\",\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner: true,\n          payoutLamports: \"9500000\",\n          isCreator: false,\n        },\n      ],\n      feeLamports: \"500000\",\n      settledAt: new Date().toISOString(),\n    });\n\n    // Verify assignment completed\n    const assignments = await rawSql<{ progress: number; status: string; completed_at: string | null }[]>`\n      SELECT progress, status, completed_at FROM challenge_assignments WHERE user_id = ${userId}\n    `;\n    expect(assignments[0]!.progress).toBe(1);\n    expect(assignments[0]!.status).toBe(\"completed\");\n    expect(assignments[0]!.completed_at).not.toBeNull();\n\n    // Verify challenge completion reward intent emitted (points.grant with source_type=challenge_completed)\n    const events = await rawSql<{ event_type: string; payload: Record<string, unknown> }[]>`\n      SELECT event_type, payload FROM event_queue ORDER BY id\n    `;\n    const challengeRewards = events.filter(\n      (e) =>\n        e.event_type === \"points.grant\" &&\n        (e.payload as Record<string, unknown>).sourceType === \"challenge_completed\",\n    );\n    expect(challengeRewards.length).toBe(1);\n    const rewardPayload = challengeRewards[0]!.payload as Record<string, unknown>;\n    expect(rewardPayload.userId).toBe(userId);\n    expect(rewardPayload.amount).toBe(\"150\");\n  });\n\n  it(\"game.settled handler: skips refunded game (isWinner === null)\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_gs_refund1\";\n    const wallet = \"GsRefundWallet111111111111111111111111\";\n\n    // Create assignment\n    const challenges = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenges WHERE title = 'Play 3 Games' LIMIT 1\n    `;\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n      VALUES (${userId}, ${challenges[0]!.id}, 'daily:2026-04-03', 3)\n    `;\n\n    // Emit refunded game (isWinner = null)\n    await handler({\n      roundId: \"test-gs-refund-001\",\n      roundPda: \"GsRefundPda11111111111111111111111111111\",\n      game: \"coinflip\",\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner: null,\n          payoutLamports: \"5000000\",\n          isCreator: true,\n        },\n      ],\n      feeLamports: \"0\",\n      settledAt: new Date().toISOString(),\n    });\n\n    // Verify NO progress\n    const assignments = await rawSql<{ progress: number }[]>`\n      SELECT progress FROM challenge_assignments WHERE user_id = ${userId}\n    `;\n    expect(assignments[0]!.progress).toBe(0);\n\n    // Verify NO points.grant or crate.drop events for this player\n    // (reward.pool_fund is per-round, not per-player, so it still emits)\n    const events = await rawSql<{ event_type: string; payload: Record<string, unknown> }[]>`\n      SELECT event_type, payload FROM event_queue ORDER BY id\n    `;\n    const playerRewards = events.filter(\n      (e) =>\n        (e.event_type === \"points.grant\" || e.event_type === \"crate.drop\") &&\n        (e.payload as Record<string, unknown>).userId === userId,\n    );\n    expect(playerRewards.length).toBe(0);\n\n    // But reward.pool_fund still emitted (once per round)\n    const poolFunds = events.filter((e) => e.event_type === \"reward.pool_fund\");\n    expect(poolFunds.length).toBe(1);\n  });\n\n  it(\"game.settled handler: idempotent — same event twice produces no double progress\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_gs_idemp1\";\n    const wallet = \"GsIdempWallet111111111111111111111111\";\n\n    const challenges = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenges WHERE title = 'Play 3 Games' LIMIT 1\n    `;\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n      VALUES (${userId}, ${challenges[0]!.id}, 'daily:2026-04-03', 3)\n    `;\n\n    const payload = {\n      roundId: \"test-gs-idemp-001\",\n      roundPda: \"GsIdempPda111111111111111111111111111111\",\n      game: \"coinflip\" as const,\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner: true,\n          payoutLamports: \"9500000\",\n          isCreator: false,\n        },\n      ],\n      feeLamports: \"500000\",\n      settledAt: new Date().toISOString(),\n    };\n\n    // Process twice\n    await handler(payload);\n    await handler(payload);\n\n    // Verify progress is still 1, not 2\n    const assignments = await rawSql<{ progress: number }[]>`\n      SELECT progress FROM challenge_assignments WHERE user_id = ${userId}\n    `;\n    expect(assignments[0]!.progress).toBe(1);\n\n    // Verify only one progress_events row\n    const progressEvents = await rawSql<{ id: string }[]>`\n      SELECT id FROM progress_events WHERE user_id = ${userId}\n    `;\n    expect(progressEvents.length).toBe(1);\n  });\n\n  it(\"game.settled handler: completion bonus awarded when all daily challenges completed\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_gs_bonus1\";\n    const wallet = \"GsBonusWallet11111111111111111111111111\";\n    const periodKey = \"daily:2026-04-03\";\n\n    // Look up the daily campaign and its completion bonus\n    const campaigns = await rawSql<{ id: string }[]>`\n      SELECT id FROM campaigns WHERE name = 'Daily Challenges' LIMIT 1\n    `;\n    const campaignId = campaigns[0]!.id;\n\n    // Get 3 daily challenges (the bonus requires 3 completed)\n    const dailyChallenges = await rawSql<{ id: string; action: string; scope: string }[]>`\n      SELECT id, action, scope FROM challenges\n      WHERE campaign_id = ${campaignId} AND is_active = true\n      ORDER BY sort_order ASC\n      LIMIT 3\n    `;\n    expect(dailyChallenges.length).toBe(3);\n\n    // Create 3 assignments — first two already completed, third active with target=1\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, progress, status, completed_at)\n      VALUES\n        (${userId}, ${dailyChallenges[0]!.id}, ${periodKey}, 1, 1, 'completed', now()),\n        (${userId}, ${dailyChallenges[1]!.id}, ${periodKey}, 1, 1, 'completed', now()),\n        (${userId}, ${dailyChallenges[2]!.id}, ${periodKey}, 1, 0, 'active', NULL)\n    `;\n\n    // Determine what game event will complete the 3rd challenge\n    const thirdChallenge = dailyChallenges[2]!;\n    const isWinner = thirdChallenge.action === \"game_won\" ? true : true;\n    const game = thirdChallenge.scope === \"any\" ? \"coinflip\" : thirdChallenge.scope;\n\n    // Settle a game that completes the 3rd daily challenge\n    await handler({\n      roundId: \"test-gs-bonus-001\",\n      roundPda: \"GsBonusPda1111111111111111111111111111111\",\n      game,\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner,\n          payoutLamports: \"9500000\",\n          isCreator: true,\n        },\n      ],\n      feeLamports: \"500000\",\n      settledAt: new Date().toISOString(),\n    });\n\n    // Verify 3rd assignment is now completed\n    const assignments = await rawSql<{ status: string; challenge_id: string }[]>`\n      SELECT status, challenge_id FROM challenge_assignments\n      WHERE user_id = ${userId} AND period_key = ${periodKey}\n      ORDER BY id\n    `;\n    expect(assignments[2]!.status).toBe(\"completed\");\n\n    // Verify bonus_completions row created\n    const bonuses = await rawSql<{ user_id: string; bonus_id: string; period_key: string }[]>`\n      SELECT user_id, bonus_id, period_key FROM bonus_completions\n      WHERE user_id = ${userId}\n    `;\n    expect(bonuses.length).toBe(1);\n    expect(bonuses[0]!.period_key).toBe(periodKey);\n\n    // Verify bonus reward event emitted (crate.drop with trigger_type='bonus_completed')\n    const events = await rawSql<{ event_type: string; payload: Record<string, unknown> }[]>`\n      SELECT event_type, payload FROM event_queue ORDER BY id\n    `;\n    const bonusRewards = events.filter(\n      (e) =>\n        e.event_type === \"crate.drop\" &&\n        (e.payload as Record<string, unknown>).triggerType === \"bonus_completed\",\n    );\n    expect(bonusRewards.length).toBe(1);\n    expect((bonusRewards[0]!.payload as Record<string, unknown>).userId).toBe(userId);\n  });\n\n  it(\"game.settled handler: completion bonus is idempotent — no duplicate on re-trigger\", async () => {\n    const userId = \"usr_gs_bonus_dup\";\n    const wallet = \"GsBonusDupWallet1111111111111111111111\";\n    const periodKey = \"daily:2026-04-03\";\n\n    const campaigns = await rawSql<{ id: string }[]>`\n      SELECT id FROM campaigns WHERE name = 'Daily Challenges' LIMIT 1\n    `;\n    const campaignId = campaigns[0]!.id;\n\n    const dailyChallenges = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenges\n      WHERE campaign_id = ${campaignId} AND is_active = true\n      ORDER BY sort_order ASC\n      LIMIT 3\n    `;\n\n    // All 3 assignments already completed\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, progress, status, completed_at)\n      VALUES\n        (${userId}, ${dailyChallenges[0]!.id}, ${periodKey}, 1, 1, 'completed', now()),\n        (${userId}, ${dailyChallenges[1]!.id}, ${periodKey}, 1, 1, 'completed', now()),\n        (${userId}, ${dailyChallenges[2]!.id}, ${periodKey}, 1, 1, 'completed', now())\n    `;\n\n    // Bonus already awarded\n    const bonusRows = await rawSql<{ id: string }[]>`\n      SELECT id FROM completion_bonuses WHERE campaign_id = ${campaignId} LIMIT 1\n    `;\n    await rawSql`\n      INSERT INTO bonus_completions (user_id, bonus_id, period_key)\n      VALUES (${userId}, ${bonusRows[0]!.id}, ${periodKey})\n    `;\n\n    // Settle a new game — the handler won't find active assignments (all completed),\n    // so the bonus check won't re-trigger. But let's also directly test the bonus\n    // check doesn't duplicate if somehow called again.\n    const { checkCompletionBonus } = await import(\"../queue/handlers/completion-bonus.js\");\n    await checkCompletionBonus(db, userId, wallet, periodKey, campaignId);\n\n    // Verify still only 1 bonus_completions row\n    const bonuses = await rawSql<{ id: string }[]>`\n      SELECT id FROM bonus_completions WHERE user_id = ${userId}\n    `;\n    expect(bonuses.length).toBe(1);\n\n    // Verify no bonus reward events emitted (queue should be empty)\n    const events = await rawSql<{ event_type: string; payload: Record<string, unknown> }[]>`\n      SELECT event_type, payload FROM event_queue\n      WHERE event_type IN ('crate.drop', 'points.grant')\n    `;\n    const bonusEvents = events.filter(\n      (e) => {\n        const p = e.payload as Record<string, unknown>;\n        return p.triggerType === \"bonus_completed\" || p.sourceType === \"bonus_completed\";\n      },\n    );\n    expect(bonusEvents.length).toBe(0);\n  });\n\n  it(\"game.settled handler: no bonus when only 2 of 3 daily challenges completed\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_gs_bonus_partial\";\n    const wallet = \"GsBonusPartialWallet111111111111111111\";\n    const periodKey = \"daily:2026-04-03\";\n\n    const campaigns = await rawSql<{ id: string }[]>`\n      SELECT id FROM campaigns WHERE name = 'Daily Challenges' LIMIT 1\n    `;\n    const campaignId = campaigns[0]!.id;\n\n    const dailyChallenges = await rawSql<{ id: string; action: string; scope: string }[]>`\n      SELECT id, action, scope FROM challenges\n      WHERE campaign_id = ${campaignId} AND is_active = true\n      ORDER BY sort_order ASC\n      LIMIT 3\n    `;\n\n    // 1 completed, 1 about to complete, 1 still active with more progress needed\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, progress, status, completed_at)\n      VALUES\n        (${userId}, ${dailyChallenges[0]!.id}, ${periodKey}, 1, 1, 'completed', now()),\n        (${userId}, ${dailyChallenges[1]!.id}, ${periodKey}, 1, 0, 'active', NULL),\n        (${userId}, ${dailyChallenges[2]!.id}, ${periodKey}, 3, 0, 'active', NULL)\n    `;\n\n    // Settle a game that completes the 2nd challenge\n    const secondChallenge = dailyChallenges[1]!;\n    const game = secondChallenge.scope === \"any\" ? \"coinflip\" : secondChallenge.scope;\n\n    await handler({\n      roundId: \"test-gs-bonus-partial-001\",\n      roundPda: \"GsBonusPartialPda111111111111111111111\",\n      game,\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner: true,\n          payoutLamports: \"9500000\",\n          isCreator: true,\n        },\n      ],\n      feeLamports: \"500000\",\n      settledAt: new Date().toISOString(),\n    });\n\n    // Verify 2nd assignment completed but 3rd still active\n    const assignments = await rawSql<{ status: string }[]>`\n      SELECT status FROM challenge_assignments\n      WHERE user_id = ${userId} AND period_key = ${periodKey}\n      ORDER BY id\n    `;\n    expect(assignments[1]!.status).toBe(\"completed\");\n    expect(assignments[2]!.status).toBe(\"active\");\n\n    // Verify NO bonus_completions row (only 2 of 3 completed)\n    const bonuses = await rawSql<{ id: string }[]>`\n      SELECT id FROM bonus_completions WHERE user_id = ${userId}\n    `;\n    expect(bonuses.length).toBe(0);\n\n    // Verify no bonus reward events\n    const events = await rawSql<{ event_type: string; payload: Record<string, unknown> }[]>`\n      SELECT event_type, payload FROM event_queue ORDER BY id\n    `;\n    const bonusEvents = events.filter(\n      (e) => {\n        const p = e.payload as Record<string, unknown>;\n        return p.triggerType === \"bonus_completed\" || p.sourceType === \"bonus_completed\";\n      },\n    );\n    expect(bonusEvents.length).toBe(0);\n  });\n\n  // ---------------------------------------------------------------------------\n  // Onboarding chain progression\n  // ---------------------------------------------------------------------------\n\n  it(\"game.settled handler: completing onboarding step 1 auto-assigns step 2\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_onboard_chain1\";\n    const wallet = \"OnboardChainWallet1111111111111111111\";\n\n    // Look up the 3 onboarding challenges (ordered by sort_order)\n    const onboardingChallenges = await rawSql<{ id: string; title: string; threshold: number; prerequisite_id: string | null }[]>`\n      SELECT c.id, c.title, c.threshold, c.prerequisite_id\n      FROM challenges c\n      JOIN campaigns camp ON camp.id = c.campaign_id\n      WHERE camp.campaign_type = 'onboarding'\n      ORDER BY c.sort_order ASC\n    `;\n    expect(onboardingChallenges.length).toBe(3);\n    const step1 = onboardingChallenges[0]!;\n    const step2 = onboardingChallenges[1]!;\n\n    // Step 2 should have step 1 as prerequisite\n    expect(step2.prerequisite_id).toBe(step1.id);\n\n    // Assign step 1 to the user (target = 1, game_completed any)\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n      VALUES (${userId}, ${step1.id}, 'onboarding', ${step1.threshold})\n    `;\n\n    // Settle a game — should complete step 1 and auto-assign step 2\n    await handler({\n      roundId: \"test-onboard-round-001\",\n      roundPda: \"OnboardRoundPda111111111111111111111\",\n      game: \"coinflip\",\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner: true,\n          payoutLamports: \"9500000\",\n          isCreator: true,\n        },\n      ],\n      feeLamports: \"500000\",\n      settledAt: new Date().toISOString(),\n    });\n\n    // Verify step 1 completed\n    const step1Assignment = await rawSql<{ status: string; progress: number }[]>`\n      SELECT status, progress FROM challenge_assignments\n      WHERE user_id = ${userId} AND challenge_id = ${step1.id}\n    `;\n    expect(step1Assignment[0]!.status).toBe(\"completed\");\n    expect(step1Assignment[0]!.progress).toBe(1);\n\n    // Verify step 2 auto-assigned\n    const step2Assignment = await rawSql<{ status: string; progress: number; period_key: string; target: number; expires_at: string | null }[]>`\n      SELECT status, progress, period_key, target, expires_at FROM challenge_assignments\n      WHERE user_id = ${userId} AND challenge_id = ${step2.id}\n    `;\n    expect(step2Assignment.length).toBe(1);\n    expect(step2Assignment[0]!.status).toBe(\"active\");\n    expect(step2Assignment[0]!.progress).toBe(0);\n    expect(step2Assignment[0]!.period_key).toBe(\"onboarding\");\n    expect(step2Assignment[0]!.target).toBe(step2.threshold);\n    expect(step2Assignment[0]!.expires_at).toBeNull();\n  });\n\n  it(\"game.settled handler: completing all 3 onboarding steps creates no further assignment\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_onboard_chain2\";\n    const wallet = \"OnboardChainWallet2222222222222222222\";\n\n    // Look up onboarding challenges\n    const onboardingChallenges = await rawSql<{ id: string; threshold: number }[]>`\n      SELECT c.id, c.threshold\n      FROM challenges c\n      JOIN campaigns camp ON camp.id = c.campaign_id\n      WHERE camp.campaign_type = 'onboarding'\n      ORDER BY c.sort_order ASC\n    `;\n    expect(onboardingChallenges.length).toBe(3);\n    const step3 = onboardingChallenges[2]!;\n\n    // Pre-complete steps 1 and 2, assign step 3 as active\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, progress, status, completed_at)\n      VALUES\n        (${userId}, ${onboardingChallenges[0]!.id}, 'onboarding', ${onboardingChallenges[0]!.threshold}, ${onboardingChallenges[0]!.threshold}, 'completed', now()),\n        (${userId}, ${onboardingChallenges[1]!.id}, 'onboarding', ${onboardingChallenges[1]!.threshold}, ${onboardingChallenges[1]!.threshold}, 'completed', now())\n    `;\n\n    // Step 3 is 'game_completed' with scope='any' and threshold depends on seed (3 for unique_game_types)\n    // But the adapter is 'game_completed' which just checks scope match. We need to settle enough\n    // games to reach the threshold. For simplicity, set target=1 for our test assignment.\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n      VALUES (${userId}, ${step3.id}, 'onboarding', 1)\n    `;\n\n    // Settle a game — should complete step 3\n    await handler({\n      roundId: \"test-onboard-round-003\",\n      roundPda: \"OnboardRoundPda333333333333333333333\",\n      game: \"coinflip\",\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner: true,\n          payoutLamports: \"9500000\",\n          isCreator: true,\n        },\n      ],\n      feeLamports: \"500000\",\n      settledAt: new Date().toISOString(),\n    });\n\n    // Verify step 3 completed\n    const step3Assignment = await rawSql<{ status: string }[]>`\n      SELECT status FROM challenge_assignments\n      WHERE user_id = ${userId} AND challenge_id = ${step3.id}\n    `;\n    expect(step3Assignment[0]!.status).toBe(\"completed\");\n\n    // Verify NO further assignment created (no step 4 exists)\n    const allAssignments = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenge_assignments\n      WHERE user_id = ${userId} AND period_key = 'onboarding'\n    `;\n    expect(allAssignments.length).toBe(3); // step 1, 2, 3 — no step 4\n  });\n\n  it(\"game.settled handler: onboarding chain progression is idempotent per assignment\", async () => {\n    const handler = createGameSettledHandler({ db });\n    const userId = \"usr_onboard_chain3\";\n    const wallet = \"OnboardChainWallet3333333333333333333\";\n\n    // Look up onboarding challenges\n    const onboardingChallenges = await rawSql<{ id: string; threshold: number }[]>`\n      SELECT c.id, c.threshold\n      FROM challenges c\n      JOIN campaigns camp ON camp.id = c.campaign_id\n      WHERE camp.campaign_type = 'onboarding'\n      ORDER BY c.sort_order ASC\n    `;\n    const step1 = onboardingChallenges[0]!;\n    const step2 = onboardingChallenges[1]!;\n\n    // Assign step 1\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n      VALUES (${userId}, ${step1.id}, 'onboarding', ${step1.threshold})\n    `;\n\n    const settledPayload = {\n      roundId: \"test-onboard-round-idempotent\",\n      roundPda: \"OnboardIdempotentPda1111111111111111\",\n      game: \"coinflip\" as const,\n      players: [\n        {\n          userId,\n          wallet,\n          amountLamports: \"5000000\",\n          isWinner: true,\n          payoutLamports: \"9500000\",\n          isCreator: true,\n        },\n      ],\n      feeLamports: \"500000\",\n      settledAt: new Date().toISOString(),\n    };\n\n    // First call — completes step 1, assigns step 2\n    await handler(settledPayload);\n\n    // Verify step 1 progress is exactly 1 (not double-counted)\n    const step1After = await rawSql<{ progress: number; status: string }[]>`\n      SELECT progress, status FROM challenge_assignments\n      WHERE user_id = ${userId} AND challenge_id = ${step1.id}\n    `;\n    expect(step1After[0]!.progress).toBe(1);\n    expect(step1After[0]!.status).toBe(\"completed\");\n\n    // Step 2 should be assigned exactly once (UNIQUE constraint)\n    const step2Assignments = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenge_assignments\n      WHERE user_id = ${userId} AND challenge_id = ${step2.id} AND period_key = 'onboarding'\n    `;\n    expect(step2Assignments.length).toBe(1);\n\n    // Re-process the same event — step 1 progress_event UNIQUE prevents double progress\n    await handler(settledPayload);\n\n    // Step 1 progress should still be 1 (idempotent via progress_events UNIQUE on assignment_id + round_id)\n    const step1AfterRetry = await rawSql<{ progress: number }[]>`\n      SELECT progress FROM challenge_assignments\n      WHERE user_id = ${userId} AND challenge_id = ${step1.id}\n    `;\n    expect(step1AfterRetry[0]!.progress).toBe(1);\n\n    // Step 2 still assigned exactly once (createAssignment's ON CONFLICT DO NOTHING)\n    const step2AfterRetry = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenge_assignments\n      WHERE user_id = ${userId} AND challenge_id = ${step2.id} AND period_key = 'onboarding'\n    `;\n    expect(step2AfterRetry.length).toBe(1);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// GET /challenges/mine — lazy assignment + response shape\n// ---------------------------------------------------------------------------\n\ndescribe(\"GET /challenges/mine\", () => {\n  let rawSql: ReturnType<typeof makeSql>;\n  let db: Db;\n  let challengeApp: InstanceType<typeof Hono>;\n\n  const testWallet = Keypair.generate().publicKey.toBase58();\n  const testUserId = userIdFromWallet(testWallet);\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n\n    challengeApp = new Hono();\n    challengeApp.use(\n      \"/challenges/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    challengeApp.route(\"/challenges\", createChallengeRoutes({ db }));\n  });\n\n  it(\"first call creates 3 daily + 2 weekly + 1 onboarding assignment, returns correct shape\", async () => {\n    const token = await makeJwt(testWallet, testUserId);\n\n    const res = await challengeApp.request(\"/challenges/mine\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n\n    // Daily section\n    expect(body.daily).toBeDefined();\n    expect(body.daily.challenges).toHaveLength(3);\n    expect(body.daily.resetsAt).toBeDefined();\n    for (const ch of body.daily.challenges) {\n      expect(ch).toHaveProperty(\"id\");\n      expect(ch).toHaveProperty(\"title\");\n      expect(ch).toHaveProperty(\"description\");\n      expect(ch).toHaveProperty(\"progress\");\n      expect(ch).toHaveProperty(\"target\");\n      expect(ch).toHaveProperty(\"status\");\n      expect(ch).toHaveProperty(\"reward\");\n      expect(ch.reward).toHaveProperty(\"type\");\n      expect(ch).toHaveProperty(\"completedAt\");\n      expect(ch.status).toBe(\"active\");\n      expect(ch.progress).toBe(0);\n    }\n\n    // Daily bonus\n    expect(body.daily.bonus).toBeDefined();\n    expect(body.daily.bonus.required).toBe(3);\n    expect(body.daily.bonus.completed).toBe(0);\n    expect(body.daily.bonus.status).toBe(\"active\");\n    expect(body.daily.bonus.reward).toHaveProperty(\"type\");\n\n    // Weekly section\n    expect(body.weekly).toBeDefined();\n    expect(body.weekly.challenges).toHaveLength(2);\n    expect(body.weekly.resetsAt).toBeDefined();\n    for (const ch of body.weekly.challenges) {\n      expect(ch.status).toBe(\"active\");\n      expect(ch.progress).toBe(0);\n    }\n\n    // Onboarding section\n    expect(body.onboarding).toBeDefined();\n    expect(body.onboarding).not.toBeNull();\n    expect(body.onboarding.completed).toBe(false);\n    expect(body.onboarding.steps).toBeDefined();\n    expect(body.onboarding.steps.length).toBeGreaterThanOrEqual(1);\n\n    // First step should be unlocked, rest locked\n    const steps = body.onboarding.steps;\n    expect(steps[0].locked).toBe(false);\n    if (steps.length > 1) {\n      expect(steps[1].locked).toBe(true);\n    }\n\n    // Verify DB: 3 daily + 2 weekly + 1 onboarding = 6 total assignments\n    const assignments = await rawSql<{ period_key: string }[]>`\n      SELECT period_key FROM challenge_assignments WHERE user_id = ${testUserId}\n    `;\n    const dailyKey = dailyPeriodKey();\n    const weeklyKey = weeklyPeriodKey();\n    const dailyCount = assignments.filter((a) => a.period_key === dailyKey).length;\n    const weeklyCount = assignments.filter((a) => a.period_key === weeklyKey).length;\n    const onboardingCount = assignments.filter((a) => a.period_key === \"onboarding\").length;\n    expect(dailyCount).toBe(3);\n    expect(weeklyCount).toBe(2);\n    expect(onboardingCount).toBe(1);\n  });\n\n  it(\"second call returns same assignments (no duplicates)\", async () => {\n    const token = await makeJwt(testWallet, testUserId);\n\n    // First call — creates assignments\n    await challengeApp.request(\"/challenges/mine\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n\n    // Second call — should return same data\n    const res = await challengeApp.request(\"/challenges/mine\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.daily.challenges).toHaveLength(3);\n    expect(body.weekly.challenges).toHaveLength(2);\n\n    // Total assignments unchanged\n    const assignments = await rawSql<{ id: string }[]>`\n      SELECT id FROM challenge_assignments WHERE user_id = ${testUserId}\n    `;\n    expect(assignments.length).toBe(6); // 3 daily + 2 weekly + 1 onboarding\n  });\n\n  it(\"expired assignments are marked expired\", async () => {\n    const token = await makeJwt(testWallet, testUserId);\n\n    // Insert an assignment that's already expired\n    const dailyCampaign = await rawSql<{ id: string }[]>`\n      SELECT id FROM campaigns WHERE campaign_type = 'daily' LIMIT 1\n    `;\n    const challenges = await rawSql<{ id: string; threshold: number }[]>`\n      SELECT id, threshold FROM challenges WHERE campaign_id = ${dailyCampaign[0]!.id} AND is_active = true ORDER BY sort_order ASC LIMIT 1\n    `;\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n      VALUES (${testUserId}, ${challenges[0]!.id}, 'daily:2020-01-01', ${challenges[0]!.threshold}, '2020-01-02T00:00:00Z')\n    `;\n\n    // Verify it's active\n    const before = await rawSql<{ status: string }[]>`\n      SELECT status FROM challenge_assignments WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n    `;\n    expect(before[0]!.status).toBe(\"active\");\n\n    // Call /mine — should expire the stale assignment\n    await challengeApp.request(\"/challenges/mine\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n\n    // Verify it's now expired\n    const after = await rawSql<{ status: string }[]>`\n      SELECT status FROM challenge_assignments WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n    `;\n    expect(after[0]!.status).toBe(\"expired\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// GET /points/mine, GET /points/mine/history, GET /crates/mine\n// ---------------------------------------------------------------------------\n\ndescribe(\"GET /points/mine + /points/mine/history + /crates/mine\", () => {\n  let rawSql: ReturnType<typeof makeSql>;\n  let db: Db;\n  let pointsApp: InstanceType<typeof Hono>;\n  let cratesApp: InstanceType<typeof Hono>;\n\n  const testWallet = Keypair.generate().publicKey.toBase58();\n  const testUserId = userIdFromWallet(testWallet);\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n\n    pointsApp = new Hono();\n    pointsApp.use(\n      \"/points/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    pointsApp.route(\"/points\", createPointsRoutes({ db }));\n\n    cratesApp = new Hono();\n    cratesApp.use(\n      \"/crates/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    cratesApp.route(\"/crates\", createCrateRoutes({ db }));\n  });\n\n  it(\"GET /points/mine returns zeros when no player_points row exists\", async () => {\n    const token = await makeJwt(testWallet, testUserId);\n    const res = await pointsApp.request(\"/points/mine\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.balance).toBe(0);\n    expect(body.lifetimeEarned).toBe(0);\n  });\n\n  it(\"GET /points/mine returns balance and lifetimeEarned from player_points\", async () => {\n    // Seed player_points\n    await rawSql`\n      INSERT INTO player_points (user_id, wallet, balance, lifetime_earned)\n      VALUES (${testUserId}, ${testWallet}, 5000, 12000)\n    `;\n\n    const token = await makeJwt(testWallet, testUserId);\n    const res = await pointsApp.request(\"/points/mine\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.balance).toBe(5000);\n    expect(body.lifetimeEarned).toBe(12000);\n  });\n\n  it(\"GET /points/mine/history returns paginated point_grants with cursor\", async () => {\n    // Seed 3 point_grants\n    for (let i = 1; i <= 3; i++) {\n      await rawSql`\n        INSERT INTO point_grants (user_id, wallet, source_type, source_id, amount, metadata)\n        VALUES (${testUserId}, ${testWallet}, 'wager', ${\"round_\" + i}, ${1000 * i}, ${JSON.stringify({ solPrice: 100 })})\n      `;\n    }\n\n    const token = await makeJwt(testWallet, testUserId);\n\n    // Fetch first page with limit=2\n    const res1 = await pointsApp.request(\"/points/mine/history?limit=2\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res1.status).toBe(200);\n    const body1 = (await res1.json()) as Record<string, any>;\n    expect(body1.items).toHaveLength(2);\n    // DESC order: id=3 first, id=2 second\n    expect(body1.items[0].sourceType).toBe(\"wager\");\n    expect(body1.items[0].amount).toBe(3000);\n    expect(body1.items[1].amount).toBe(2000);\n    expect(body1.nextCursor).not.toBeNull();\n    // Verify shape\n    expect(body1.items[0]).toHaveProperty(\"id\");\n    expect(body1.items[0]).toHaveProperty(\"sourceId\");\n    expect(body1.items[0]).toHaveProperty(\"metadata\");\n    expect(body1.items[0]).toHaveProperty(\"createdAt\");\n\n    // Fetch second page using cursor\n    const res2 = await pointsApp.request(`/points/mine/history?limit=2&cursor=${body1.nextCursor}`, {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res2.status).toBe(200);\n    const body2 = (await res2.json()) as Record<string, any>;\n    expect(body2.items).toHaveLength(1);\n    expect(body2.items[0].amount).toBe(1000);\n    expect(body2.nextCursor).toBeNull(); // No more pages\n  });\n\n  it(\"GET /points/mine/history returns empty array when no grants\", async () => {\n    const token = await makeJwt(testWallet, testUserId);\n    const res = await pointsApp.request(\"/points/mine/history\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n    expect(body.nextCursor).toBeNull();\n  });\n\n  it(\"GET /crates/mine returns paginated crate_drops with cursor\", async () => {\n    // Seed 3 crate_drops\n    await rawSql`\n      INSERT INTO crate_drops (user_id, trigger_type, trigger_id, crate_type, contents_amount, status)\n      VALUES (${testUserId}, 'game_settled', 'round_1', 'points', '2500', 'granted')\n    `;\n    await rawSql`\n      INSERT INTO crate_drops (user_id, trigger_type, trigger_id, crate_type, contents_amount, status, granted_at)\n      VALUES (${testUserId}, 'game_settled', 'round_2', 'sol', '10000000', 'granted', now())\n    `;\n    await rawSql`\n      INSERT INTO crate_drops (user_id, trigger_type, trigger_id, crate_type, contents_amount, status)\n      VALUES (${testUserId}, 'game_settled', 'round_3', 'points', '500', 'pending')\n    `;\n\n    const token = await makeJwt(testWallet, testUserId);\n\n    // Fetch first page with limit=2\n    const res1 = await cratesApp.request(\"/crates/mine?limit=2\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res1.status).toBe(200);\n    const body1 = (await res1.json()) as Record<string, any>;\n    expect(body1.items).toHaveLength(2);\n    // DESC order: id=3 first (pending points), id=2 second (granted sol)\n    expect(body1.items[0].crateType).toBe(\"points\");\n    expect(body1.items[0].status).toBe(\"pending\");\n    expect(body1.items[0].contentsAmount).toBe(\"500\");\n    expect(body1.items[0].grantedAt).toBeNull();\n    expect(body1.items[1].crateType).toBe(\"sol\");\n    expect(body1.items[1].status).toBe(\"granted\");\n    expect(body1.items[1].grantedAt).not.toBeNull();\n    expect(body1.nextCursor).not.toBeNull();\n    // Verify shape\n    expect(body1.items[0]).toHaveProperty(\"id\");\n    expect(body1.items[0]).toHaveProperty(\"createdAt\");\n\n    // Fetch second page using cursor\n    const res2 = await cratesApp.request(`/crates/mine?limit=2&cursor=${body1.nextCursor}`, {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res2.status).toBe(200);\n    const body2 = (await res2.json()) as Record<string, any>;\n    expect(body2.items).toHaveLength(1);\n    expect(body2.items[0].crateType).toBe(\"points\");\n    expect(body2.items[0].contentsAmount).toBe(\"2500\");\n    expect(body2.nextCursor).toBeNull();\n  });\n\n  it(\"GET /crates/mine returns empty array when no crate drops\", async () => {\n    const token = await makeJwt(testWallet, testUserId);\n    const res = await cratesApp.request(\"/crates/mine\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n    expect(body.nextCursor).toBeNull();\n  });\n});\n\n// ---------------------------------------------------------------------------\n// GET /challenges/mine/history, GET /dogpile/current, GET /dogpile/schedule\n// ---------------------------------------------------------------------------\n\ndescribe(\"GET /challenges/mine/history + /dogpile/current + /dogpile/schedule\", () => {\n  let rawSql: ReturnType<typeof makeSql>;\n  let db: Db;\n  let challengeApp: InstanceType<typeof Hono>;\n  let dogpileApp: InstanceType<typeof Hono>;\n\n  const testWallet = Keypair.generate().publicKey.toBase58();\n  const testUserId = userIdFromWallet(testWallet);\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n\n    challengeApp = new Hono();\n    challengeApp.use(\n      \"/challenges/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    challengeApp.route(\"/challenges\", createChallengeRoutes({ db }));\n\n    dogpileApp = new Hono();\n    dogpileApp.route(\"/dogpile\", createDogpileRoutes({ db }));\n  });\n\n  // -- /challenges/mine/history tests --\n\n  it(\"GET /challenges/mine/history returns paginated completed assignments\", async () => {\n    // Seed 3 completed challenge assignments\n    const challenges = await rawSql<{ id: string; threshold: number; }[]>`\n      SELECT id, threshold FROM challenges WHERE is_active = true ORDER BY sort_order ASC LIMIT 3\n    `;\n\n    for (let i = 0; i < 3; i++) {\n      await rawSql`\n        INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, status, progress, completed_at)\n        VALUES (${testUserId}, ${challenges[i]!.id}, ${\"daily:2026-01-0\" + (i + 1)}, ${challenges[i]!.threshold}, 'completed', ${challenges[i]!.threshold}, ${new Date(Date.UTC(2026, 0, i + 1)).toISOString()})\n      `;\n    }\n\n    const token = await makeJwt(testWallet, testUserId);\n\n    // Fetch first page with limit=2\n    const res1 = await challengeApp.request(\"/challenges/mine/history?limit=2\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res1.status).toBe(200);\n    const body1 = (await res1.json()) as Record<string, any>;\n    expect(body1.items).toHaveLength(2);\n    // DESC order by id: most recently inserted first\n    expect(body1.items[0]).toHaveProperty(\"id\");\n    expect(body1.items[0]).toHaveProperty(\"title\");\n    expect(body1.items[0]).toHaveProperty(\"description\");\n    expect(body1.items[0]).toHaveProperty(\"completedAt\");\n    expect(body1.items[0]).toHaveProperty(\"reward\");\n    expect(body1.items[0].reward).toHaveProperty(\"type\");\n    expect(body1.nextCursor).not.toBeNull();\n\n    // Fetch second page\n    const res2 = await challengeApp.request(`/challenges/mine/history?limit=2&cursor=${body1.nextCursor}`, {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res2.status).toBe(200);\n    const body2 = (await res2.json()) as Record<string, any>;\n    expect(body2.items).toHaveLength(1);\n    expect(body2.nextCursor).toBeNull();\n  });\n\n  it(\"GET /challenges/mine/history returns empty when no completed assignments\", async () => {\n    // Insert active (not completed) assignment\n    const challenges = await rawSql<{ id: string; threshold: number }[]>`\n      SELECT id, threshold FROM challenges WHERE is_active = true ORDER BY sort_order ASC LIMIT 1\n    `;\n    await rawSql`\n      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, status)\n      VALUES (${testUserId}, ${challenges[0]!.id}, 'daily:2026-01-01', ${challenges[0]!.threshold}, 'active')\n    `;\n\n    const token = await makeJwt(testWallet, testUserId);\n    const res = await challengeApp.request(\"/challenges/mine/history\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n    expect(body.nextCursor).toBeNull();\n  });\n\n  // -- /dogpile/current tests --\n\n  it(\"GET /dogpile/current returns active event over scheduled\", async () => {\n    // Insert active event\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() - interval '1 hour', now() + interval '1 hour', 2.5, 'active')\n    `;\n    // Insert scheduled event\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() + interval '2 hours', now() + interval '3 hours', 3.0, 'scheduled')\n    `;\n\n    const res = await dogpileApp.request(\"/dogpile/current\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body).not.toBeNull();\n    expect(body.status).toBe(\"active\");\n    expect(body.multiplier).toBe(2.5);\n    expect(body).toHaveProperty(\"id\");\n    expect(body).toHaveProperty(\"startsAt\");\n    expect(body).toHaveProperty(\"endsAt\");\n    expect(body).toHaveProperty(\"endsIn\");\n    expect(body.endsIn).toBeGreaterThan(0);\n  });\n\n  it(\"GET /dogpile/current returns next scheduled when no active event\", async () => {\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() + interval '2 hours', now() + interval '3 hours', 3.0, 'scheduled')\n    `;\n\n    const res = await dogpileApp.request(\"/dogpile/current\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body).not.toBeNull();\n    expect(body.status).toBe(\"scheduled\");\n    expect(body.multiplier).toBe(3.0);\n    expect(body).toHaveProperty(\"startsIn\");\n    expect(body.startsIn).toBeGreaterThan(0);\n  });\n\n  it(\"GET /dogpile/current returns null when no events\", async () => {\n    const res = await dogpileApp.request(\"/dogpile/current\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(body).toBeNull();\n  });\n\n  // -- /dogpile/schedule tests --\n\n  it(\"GET /dogpile/schedule returns upcoming events ordered by starts_at\", async () => {\n    // Insert events in reverse order to verify ORDER BY\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() + interval '5 hours', now() + interval '6 hours', 2.0, 'scheduled')\n    `;\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() - interval '1 hour', now() + interval '1 hour', 3.0, 'active')\n    `;\n    // Ended event — should NOT appear\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() - interval '5 hours', now() - interval '4 hours', 1.5, 'ended')\n    `;\n\n    const res = await dogpileApp.request(\"/dogpile/schedule\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(2); // active + scheduled, not ended\n    // Ordered by starts_at ASC: active (earlier) first, then scheduled\n    expect(body.items[0].status).toBe(\"active\");\n    expect(body.items[0].multiplier).toBe(3.0);\n    expect(body.items[1].status).toBe(\"scheduled\");\n    expect(body.items[1].multiplier).toBe(2.0);\n    // Verify shape\n    expect(body.items[0]).toHaveProperty(\"id\");\n    expect(body.items[0]).toHaveProperty(\"startsAt\");\n    expect(body.items[0]).toHaveProperty(\"endsAt\");\n  });\n\n  it(\"GET /dogpile/schedule returns empty array when no upcoming events\", async () => {\n    const res = await dogpileApp.request(\"/dogpile/schedule\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n  });\n});\n","structuredPatch":[{"oldStart":2973,"oldLines":3,"newStart":2973,"newLines":123,"lines":["     expect(body.items).toHaveLength(0);","   });"," });","+","+// ---------------------------------------------------------------------------","+// Admin API Tests","+// ---------------------------------------------------------------------------","+","+describe(\"Admin API: reward-config + reward-pool\", () => {","+  let db: Db;","+  let rawSql: ReturnType<typeof postgres>;","+  let adminApp: Hono;","+","+  const ADMIN_KEY = \"test-admin-key-secret\";","+","+  beforeAll(async () => {","+    rawSql = makeSql();","+    db = createDb(DATABASE_URL, rawSql);","+  });","+","+  afterAll(async () => {","+    await db.close();","+    await rawSql.end();","+  });","+","+  beforeEach(async () => {","+    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;","+    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;","+    // Reset reward_config to defaults","+    await rawSql`UPDATE reward_config SET value = '500' WHERE key = 'points_per_dollar'`;","+","+    adminApp = new Hono();","+    adminApp.route(\"/admin\", createAdminRoutes({ db, adminApiKey: ADMIN_KEY }));","+  });","+","+  it(\"request without X-Admin-Key returns 401\", async () => {","+    const res = await adminApp.request(\"/admin/reward-config\", { method: \"GET\" });","+    expect(res.status).toBe(401);","+    const body = (await res.json()) as Record<string, any>;","+    expect(body.error).toBe(\"UNAUTHORIZED\");","+  });","+","+  it(\"request with wrong X-Admin-Key returns 401\", async () => {","+    const res = await adminApp.request(\"/admin/reward-config\", {","+      method: \"GET\",","+      headers: { \"X-Admin-Key\": \"wrong-key\" },","+    });","+    expect(res.status).toBe(401);","+    const body = (await res.json()) as Record<string, any>;","+    expect(body.error).toBe(\"UNAUTHORIZED\");","+  });","+","+  it(\"GET /admin/reward-config returns all seeded defaults\", async () => {","+    const res = await adminApp.request(\"/admin/reward-config\", {","+      method: \"GET\",","+      headers: { \"X-Admin-Key\": ADMIN_KEY },","+    });","+    expect(res.status).toBe(200);","+    const body = (await res.json()) as Record<string, any>;","+","+    // Verify all 11 seeded keys present","+    expect(Object.keys(body)).toHaveLength(11);","+    expect(body.points_per_dollar.value).toBe(\"500\");","+    expect(body.reward_pool_fee_share.value).toBe(\"0.20\");","+    expect(body.sol_crate_drop_rate.value).toBe(\"0.01\");","+    expect(body.daily_challenge_count.value).toBe(\"3\");","+    // Each entry has updatedAt","+    expect(body.points_per_dollar).toHaveProperty(\"updatedAt\");","+  });","+","+  it(\"PUT /admin/reward-config/:key updates value\", async () => {","+    const res = await adminApp.request(\"/admin/reward-config/points_per_dollar\", {","+      method: \"PUT\",","+      headers: {","+        \"X-Admin-Key\": ADMIN_KEY,","+        \"Content-Type\": \"application/json\",","+      },","+      body: JSON.stringify({ value: \"1000\" }),","+    });","+    expect(res.status).toBe(200);","+    const body = (await res.json()) as Record<string, any>;","+    expect(body.key).toBe(\"points_per_dollar\");","+    expect(body.value).toBe(\"1000\");","+","+    // Verify persisted","+    const verify = await adminApp.request(\"/admin/reward-config\", {","+      method: \"GET\",","+      headers: { \"X-Admin-Key\": ADMIN_KEY },","+    });","+    const verifyBody = (await verify.json()) as Record<string, any>;","+    expect(verifyBody.points_per_dollar.value).toBe(\"1000\");","+  });","+","+  it(\"PUT /admin/reward-config/:key rejects unknown key with 400\", async () => {","+    const res = await adminApp.request(\"/admin/reward-config/nonexistent_key\", {","+      method: \"PUT\",","+      headers: {","+        \"X-Admin-Key\": ADMIN_KEY,","+        \"Content-Type\": \"application/json\",","+      },","+      body: JSON.stringify({ value: \"123\" }),","+    });","+    expect(res.status).toBe(400);","+    const body = (await res.json()) as Record<string, any>;","+    expect(body.error).toBe(\"INVALID_KEY\");","+  });","+","+  it(\"GET /admin/reward-pool returns pool balance\", async () => {","+    // Fund the pool first","+    await rawSql`UPDATE reward_pool SET balance_lamports = 5000000, lifetime_funded = 10000000, lifetime_paid = 5000000, updated_at = now() WHERE id = 1`;","+","+    const res = await adminApp.request(\"/admin/reward-pool\", {","+      method: \"GET\",","+      headers: { \"X-Admin-Key\": ADMIN_KEY },","+    });","+    expect(res.status).toBe(200);","+    const body = (await res.json()) as Record<string, any>;","+    expect(body.balanceLamports).toBe(\"5000000\");","+    expect(body.lifetimeFunded).toBe(\"10000000\");","+    expect(body.lifetimePaid).toBe(\"5000000\");","+    expect(body).toHaveProperty(\"updatedAt\");","+  });","+});"]}],"userModified":false,"replaceAll":false}}
