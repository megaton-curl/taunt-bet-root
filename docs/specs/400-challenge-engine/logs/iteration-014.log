{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012N2X6brvDFTvdwXS18nggJ","type":"tool_result","content":"2426\tdescribe(\"GET /challenges/mine\", () => {\n2427\t  let rawSql: ReturnType<typeof makeSql>;\n2428\t  let db: Db;\n2429\t  let challengeApp: InstanceType<typeof Hono>;\n2430\t\n2431\t  const testWallet = Keypair.generate().publicKey.toBase58();\n2432\t  const testUserId = userIdFromWallet(testWallet);\n2433\t\n2434\t  beforeAll(async () => {\n2435\t    rawSql = makeSql();\n2436\t    db = createDb(DATABASE_URL, rawSql);\n2437\t  });\n2438\t\n2439\t  afterAll(async () => {\n2440\t    await db.close();\n2441\t    await rawSql.end();\n2442\t  });\n2443\t\n2444\t  beforeEach(async () => {\n2445\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n2446\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n2447\t\n2448\t    challengeApp = new Hono();\n2449\t    challengeApp.use(\n2450\t      \"/challenges/*\",\n2451\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n2452\t    );\n2453\t    challengeApp.route(\"/challenges\", createChallengeRoutes({ db }));\n2454\t  });\n2455\t\n2456\t  it(\"first call creates 3 daily + 2 weekly + 1 onboarding assignment, returns correct shape\", async () => {\n2457\t    const token = await makeJwt(testWallet, testUserId);\n2458\t\n2459\t    const res = await challengeApp.request(\"/challenges/mine\", {\n2460\t      method: \"GET\",\n2461\t      headers: { Authorization: `Bearer ${token}` },\n2462\t    });\n2463\t\n2464\t    expect(res.status).toBe(200);\n2465\t    const body = (await res.json()) as Record<string, any>;\n2466\t\n2467\t    // Daily section\n2468\t    expect(body.daily).toBeDefined();\n2469\t    expect(body.daily.challenges).toHaveLength(3);\n2470\t    expect(body.daily.resetsAt).toBeDefined();\n2471\t    for (const ch of body.daily.challenges) {\n2472\t      expect(ch).toHaveProperty(\"id\");\n2473\t      expect(ch).toHaveProperty(\"title\");\n2474\t      expect(ch).toHaveProperty(\"description\");\n2475\t      expect(ch).toHaveProperty(\"progress\");"}]},"parent_tool_use_id":"toolu_01Gj5iM3voZR8DZFb6zcBaEh","session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"489b01b6-e73c-4539-8432-840c60db2959","timestamp":"2026-04-03T21:15:41.887Z"}
