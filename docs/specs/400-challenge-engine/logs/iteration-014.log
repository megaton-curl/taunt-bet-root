{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fm646tdte4EdYb3JyMfLu5","type":"tool_result","content":"1\t/**\n2\t * REWARD_POOL_FUND handler — allocates a share of game fees to the reward pool.\n3\t *\n4\t * Emitted once per settled round. Calculates `floor(feeLamports * reward_pool_fee_share)`\n5\t * and credits the reward pool accounting ledger. Idempotent via UNIQUE(round_id)\n6\t * on reward_pool_fundings.\n7\t */\n8\t\n9\timport type { Db } from \"../../db.js\";\n10\timport { logger } from \"../../logger.js\";\n11\t\n12\t// ---------------------------------------------------------------------------\n13\t// DB helpers\n14\t// ---------------------------------------------------------------------------\n15\t\n16\t/** Read a single reward_config value by key. */\n17\texport async function readRewardConfig(\n18\t  db: Db,\n19\t  key: string,\n20\t): Promise<string | null> {\n21\t  const rows = await db.rawSql<{ value: string }[]>`\n22\t    SELECT value FROM reward_config WHERE key = ${key}\n23\t  `;\n24\t  return rows.length > 0 ? rows[0]!.value : null;\n25\t}\n26\t\n27\t/**\n28\t * Insert a pool funding record. Returns false if a row for this round_id\n29\t * already exists (idempotency guard).\n30\t */\n31\texport async function insertPoolFunding(\n32\t  db: Db,\n33\t  roundId: string,\n34\t  feeLamports: bigint,\n35\t  fundedLamports: bigint,\n36\t): Promise<boolean> {\n37\t  const rows = await db.rawSql<{ id: string }[]>`\n38\t    INSERT INTO reward_pool_fundings (round_id, fee_lamports, funded_lamports)\n39\t    VALUES (${roundId}, ${feeLamports}, ${fundedLamports})\n40\t    ON CONFLICT (round_id) DO NOTHING\n41\t    RETURNING id\n42\t  `;\n43\t  return rows.length > 0;\n44\t}\n45\t\n46\t/**\n47\t * Atomically increment reward_pool.balance_lamports and lifetime_funded.\n48\t */\n49\texport async function incrementRewardPool(\n50\t  db: Db,\n51\t  deltaLamports: bigint,\n52\t): Promise<void> {\n53\t  await db.rawSql`\n54\t    UPDATE reward_pool\n55\t    SET balance_lamports = balance_lamports + ${deltaLamports},\n56\t        lifetime_funded  = lifetime_funded + ${deltaLamports},\n57\t        updated_at       = now()\n58\t    WHERE id = 1\n59\t  `;\n60\t}\n61\t\n62\t// ---------------------------------------------------------------------------\n63\t// Handler factory\n64\t// ---------------------------------------------------------------------------\n65\t\n66\texport interface RewardPoolFundDeps {\n67\t  db: Db;\n68\t}\n69\t\n70\texport function createRewardPoolFundHandler(deps: RewardPoolFundDeps) {\n71\t  const { db } = deps;\n72\t\n73\t  return async (payload: Record<string, unknown>): Promise<void> => {\n74\t    const roundId = payload.roundId as string;\n75\t    const feeLamportsStr = payload.feeLamports as string;\n76\t\n77\t    if (!roundId || !feeLamportsStr) {\n78\t      throw new Error(\n79\t        \"reward.pool_fund: malformed payload — missing roundId or feeLamports\",\n80\t      );\n81\t    }\n82\t\n83\t    const feeLamports = BigInt(feeLamportsStr);\n84\t\n85\t    // Read fee share from config\n86\t    const shareStr = await readRewardConfig(db, \"reward_pool_fee_share\");\n87\t    if (!shareStr) {\n88\t      logger.warn(\"reward.pool_fund: reward_pool_fee_share not configured, skipping\", { roundId });\n89\t      return;\n90\t    }\n91\t    const share = parseFloat(shareStr);\n92\t    if (Number.isNaN(share) || share <= 0) {\n93\t      logger.warn(\"reward.pool_fund: invalid reward_pool_fee_share\", { roundId, shareStr });\n94\t      return;\n95\t    }\n96\t\n97\t    // Calculate funded amount: floor(feeLamports * share)\n98\t    // Use Number for the multiplication since share is a float, then BigInt the floor\n99\t    const fundedLamports = BigInt(Math.floor(Number(feeLamports) * share));\n100\t\n101\t    if (fundedLamports <= 0n) {\n102\t      logger.debug(\"reward.pool_fund: funded amount is zero, skipping\", { roundId, feeLamports: feeLamportsStr });\n103\t      return;\n104\t    }\n105\t\n106\t    // Run within a transaction for atomicity\n107\t    await db.withTransaction(async (txDb) => {\n108\t      // Insert funding record (idempotency guard)\n109\t      const inserted = await insertPoolFunding(txDb, roundId, feeLamports, fundedLamports);\n110\t      if (!inserted) {\n111\t        logger.info(\"reward.pool_fund: duplicate round_id, skipping\", { roundId });\n112\t        return;\n113\t      }\n114\t\n115\t      // Increment pool balance\n116\t      await incrementRewardPool(txDb, fundedLamports);\n117\t\n118\t      logger.info(\"reward.pool_fund: pool funded\", {\n119\t        roundId,\n120\t        feeLamports: feeLamportsStr,\n121\t        fundedLamports: fundedLamports.toString(),\n122\t        share,\n123\t      });\n124\t    });\n125\t  };\n126\t}\n127\t"}]},"parent_tool_use_id":null,"session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"b226dee6-743b-4dac-885d-69f7abd93aab","timestamp":"2026-04-03T21:16:25.997Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/reward-pool-fund.ts","content":"/**\n * REWARD_POOL_FUND handler — allocates a share of game fees to the reward pool.\n *\n * Emitted once per settled round. Calculates `floor(feeLamports * reward_pool_fee_share)`\n * and credits the reward pool accounting ledger. Idempotent via UNIQUE(round_id)\n * on reward_pool_fundings.\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Read a single reward_config value by key. */\nexport async function readRewardConfig(\n  db: Db,\n  key: string,\n): Promise<string | null> {\n  const rows = await db.rawSql<{ value: string }[]>`\n    SELECT value FROM reward_config WHERE key = ${key}\n  `;\n  return rows.length > 0 ? rows[0]!.value : null;\n}\n\n/**\n * Insert a pool funding record. Returns false if a row for this round_id\n * already exists (idempotency guard).\n */\nexport async function insertPoolFunding(\n  db: Db,\n  roundId: string,\n  feeLamports: bigint,\n  fundedLamports: bigint,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO reward_pool_fundings (round_id, fee_lamports, funded_lamports)\n    VALUES (${roundId}, ${feeLamports}, ${fundedLamports})\n    ON CONFLICT (round_id) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n/**\n * Atomically increment reward_pool.balance_lamports and lifetime_funded.\n */\nexport async function incrementRewardPool(\n  db: Db,\n  deltaLamports: bigint,\n): Promise<void> {\n  await db.rawSql`\n    UPDATE reward_pool\n    SET balance_lamports = balance_lamports + ${deltaLamports},\n        lifetime_funded  = lifetime_funded + ${deltaLamports},\n        updated_at       = now()\n    WHERE id = 1\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Handler factory\n// ---------------------------------------------------------------------------\n\nexport interface RewardPoolFundDeps {\n  db: Db;\n}\n\nexport function createRewardPoolFundHandler(deps: RewardPoolFundDeps) {\n  const { db } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const roundId = payload.roundId as string;\n    const feeLamportsStr = payload.feeLamports as string;\n\n    if (!roundId || !feeLamportsStr) {\n      throw new Error(\n        \"reward.pool_fund: malformed payload — missing roundId or feeLamports\",\n      );\n    }\n\n    const feeLamports = BigInt(feeLamportsStr);\n\n    // Read fee share from config\n    const shareStr = await readRewardConfig(db, \"reward_pool_fee_share\");\n    if (!shareStr) {\n      logger.warn(\"reward.pool_fund: reward_pool_fee_share not configured, skipping\", { roundId });\n      return;\n    }\n    const share = parseFloat(shareStr);\n    if (Number.isNaN(share) || share <= 0) {\n      logger.warn(\"reward.pool_fund: invalid reward_pool_fee_share\", { roundId, shareStr });\n      return;\n    }\n\n    // Calculate funded amount: floor(feeLamports * share)\n    // Use Number for the multiplication since share is a float, then BigInt the floor\n    const fundedLamports = BigInt(Math.floor(Number(feeLamports) * share));\n\n    if (fundedLamports <= 0n) {\n      logger.debug(\"reward.pool_fund: funded amount is zero, skipping\", { roundId, feeLamports: feeLamportsStr });\n      return;\n    }\n\n    // Run within a transaction for atomicity\n    await db.withTransaction(async (txDb) => {\n      // Insert funding record (idempotency guard)\n      const inserted = await insertPoolFunding(txDb, roundId, feeLamports, fundedLamports);\n      if (!inserted) {\n        logger.info(\"reward.pool_fund: duplicate round_id, skipping\", { roundId });\n        return;\n      }\n\n      // Increment pool balance\n      await incrementRewardPool(txDb, fundedLamports);\n\n      logger.info(\"reward.pool_fund: pool funded\", {\n        roundId,\n        feeLamports: feeLamportsStr,\n        fundedLamports: fundedLamports.toString(),\n        share,\n      });\n    });\n  };\n}\n","numLines":127,"startLine":1,"totalLines":127}}}
