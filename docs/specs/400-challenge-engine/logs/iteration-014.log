{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0123rPb4oVvcwJpK12uBCS82","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n31\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n32\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n33\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n34\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n35\timport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\n36\timport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\n37\timport { createGameSettledHandler } from \"../queue/handlers/game-settled.js\";\n38\timport { createChallengeRoutes, dailyPeriodKey, weeklyPeriodKey } from \"../routes/challenges.js\";\n39\timport { createPointsRoutes, createCrateRoutes } from \"../routes/points.js\";\n40\timport { createDogpileRoutes } from \"../routes/dogpile.js\";\n41\t\n42\t// ---------------------------------------------------------------------------\n43\t// Constants\n44\t// ---------------------------------------------------------------------------\n45\t\n46\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n47\t\n48\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n49\tfunction makeSql() {\n50\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n51\t  // Dev container: postgres listens on Unix socket only\n52\t  return postgres({\n53\t    host: \"/var/run/postgresql\",\n54\t    user: \"vscode\",\n55\t    database: \"rng_utopia_dev\",\n56\t  });\n57\t}\n58\t\n59\tconst AMOUNT_LAMPORTS = 5_000_000;\n60\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n61\tconst SIDE_HEADS = 0;\n62\tconst PHASE_LOCKED = 1;\n63\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n64\t\n65\t// ---------------------------------------------------------------------------\n66\t// JWT helper\n67\t// ---------------------------------------------------------------------------\n68\t\n69\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n70\t  const now = Math.floor(Date.now() / 1000);\n71\t  return new SignJWT({ wallet })\n72\t    .setProtectedHeader({ alg: \"HS256\" })\n73\t    .setSubject(userId)\n74\t    .setIssuedAt(now)\n75\t    .setExpirationTime(now + 3600)\n76\t    .sign(JWT_SECRET);\n77\t}\n78\t\n79\tfunction userIdFromWallet(wallet: string) {\n80\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n81\t}\n82\t\n83\t// ---------------------------------------------------------------------------\n84\t// Mock Connection\n85\t// ---------------------------------------------------------------------------\n86\t\n87\t/**\n88\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n89\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n90\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n91\t */\n92\tclass MockConnection {\n93\t  private _slot = 200;\n94\t  private _accounts = new Map<\n95\t    string,\n96\t    {\n97\t      data: Buffer;\n98\t      lamports: number;\n99\t      owner: PublicKey;\n100\t      executable: boolean;"}]},"parent_tool_use_id":"toolu_01Gj5iM3voZR8DZFb6zcBaEh","session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"2e3fa3b5-c383-495f-ace4-da264959b866","timestamp":"2026-04-03T21:15:23.924Z"}
