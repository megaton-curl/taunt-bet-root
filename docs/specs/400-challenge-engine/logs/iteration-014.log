{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015ZwuEtq3tFMxbW1CfnS2N2","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createChallengeRoutes } from \"./routes/challenges.js\";\n21\timport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\n22\timport { createDogpileRoutes } from \"./routes/dogpile.js\";\n23\timport { createInternalRoutes } from \"./routes/internal.js\";\n24\timport { swaggerUI } from \"@hono/swagger-ui\";\n25\timport { spec } from \"./openapi.js\";\n26\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n27\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n28\timport { createSettlementWorker } from \"./worker/settlement.js\";\n29\timport { settleRound } from \"./worker/settle-tx.js\";\n30\timport { createRetrySettler } from \"./worker/retry.js\";\n31\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n32\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n33\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n34\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n35\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n36\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n37\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n38\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n39\timport { fetchSolPrice } from \"./routes/price.js\";\n40\timport { logger } from \"./logger.js\";\n41\t\n42\tconst config = loadConfig();\n43\t\n44\t// Single postgres pool shared by game DB, auth DB, and all workers\n45\tconst sql = postgres(config.databaseUrl);\n46\tconst db = createDb(config.databaseUrl, sql);\n47\tconst authDb = createAuthDb(sql);\n48\t\n49\tconst connection = new Connection(config.rpcUrl, {\n50\t  commitment: \"confirmed\",\n51\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n52\t});\n53\t\n54\tconst app = new Hono();\n55\t\n56\tapp.use(\n57\t  \"*\",\n58\t  cors({\n59\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n60\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n61\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n62\t  }),\n63\t);\n64\t\n65\t// Request logging — correlate frontend fetch timing with server-side processing\n66\tapp.use(\"*\", async (c, next) => {\n67\t  const start = Date.now();\n68\t  await next();\n69\t  const ms = Date.now() - start;\n70\t  const method = c.req.method;\n71\t  const path = c.req.path;\n72\t  // Skip noisy health checks and OPTIONS preflight\n73\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n74\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n75\t});\n76\t\n77\t// API docs — Swagger UI + raw OpenAPI spec\n78\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n79\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n80\t\n81\t// Auth routes — no JWT middleware (these are the login endpoints)\n82\t// Lighter rate limiting by IP for auth endpoints\n83\tapp.use(\n84\t  \"/auth/*\",\n85\t  createRateLimitMiddleware({\n86\t    perWallet: 20,\n87\t    global: config.rateLimitGlobal,\n88\t    windowMs: 60_000,\n89\t  }),\n90\t);\n91\t\n92\tapp.route(\n93\t  \"/auth\",\n94\t  createAuthRoutes({\n95\t    authDb,\n96\t    db,\n97\t    jwtSecret: config.jwtSecret,\n98\t    cluster: config.cluster,\n99\t    challengeTtlSeconds: config.challengeTtlSeconds,\n100\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n101\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n102\t  }),\n103\t);\n104\t\n105\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n106\tapp.use(\n107\t  \"/profile/*\",\n108\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n109\t);\n110\tapp.route(\"/profile\", createProfileRoutes({ db }));\n111\t\n112\t// Public profile routes — no auth required\n113\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n114\t\n115\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n116\tapp.use(\n117\t  \"/referral/*\",\n118\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n119\t);\n120\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n121\t\n122\t// JWT auth middleware for game endpoints\n123\tapp.use(\n124\t  \"/coinflip/*\",\n125\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n126\t);\n127\tapp.use(\n128\t  \"/lord/*\",\n129\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n130\t);\n131\t\n132\t// Rate limiting — per-wallet and global limits on POST requests\n133\tapp.use(\n134\t  \"/coinflip/*\",\n135\t  createRateLimitMiddleware({\n136\t    perWallet: config.rateLimitPerWallet,\n137\t    global: config.rateLimitGlobal,\n138\t    windowMs: 60_000,\n139\t  }),\n140\t);\n141\tapp.use(\n142\t  \"/lord/*\",\n143\t  createRateLimitMiddleware({\n144\t    perWallet: config.rateLimitPerWallet,\n145\t    global: config.rateLimitGlobal,\n146\t    windowMs: 60_000,\n147\t  }),\n148\t);\n149\t\n150\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n151\tconst entropyAccount = new PublicKey(config.entropyAccount);\n152\tconst retrySettler = createRetrySettler({\n153\t  db,\n154\t  connection,\n155\t  settleRound: (pda) =>\n156\t    settleRound(\n157\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n158\t      pda,\n159\t    ),\n160\t});\n161\t\n162\t// PDA watcher — WebSocket-based instant join detection\n163\tconst pdaWatcher = createPdaWatcher({\n164\t  connection,\n165\t  serverKey: config.serverKeypair.publicKey,\n166\t  db,\n167\t  onJoinDetected: async (pda, targetSlot) => {\n168\t    // Update DB phase if still in 'created'\n169\t    const round = await db.getRoundByPda(pda);\n170\t    if (round && round.phase === \"created\") {\n171\t      await db.updateRoundPhase(pda, \"locked\", {\n172\t        target_slot: targetSlot.toString(),\n173\t      });\n174\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n175\t        targetSlot: targetSlot.toString(),\n176\t        source: \"pda-watcher\",\n177\t        game: round.game,\n178\t      });\n179\t    }\n180\t\n181\t    // Check if target slot already passed — settle immediately if so\n182\t    const currentSlot = await connection.getSlot();\n183\t    if (BigInt(currentSlot) >= targetSlot) {\n184\t      await retrySettler.attemptSettle(pda);\n185\t      pdaWatcher.unwatch(pda);\n186\t    }\n187\t    // If target slot not reached yet, poll worker will pick it up next cycle\n188\t  },\n189\t});\n190\t\n191\tconst worker = createSettlementWorker({\n192\t  db,\n193\t  connection,\n194\t  serverKey: config.serverKeypair.publicKey,\n195\t  pollIntervalMs: config.workerPollIntervalMs,\n196\t  onSettleReady: async (pda) => {\n197\t    await retrySettler.attemptSettle(pda);\n198\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n199\t  },\n200\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n201\t});\n202\tworker.start();\n203\t\n204\t// Close Call clock worker — fetches boundary prices + settles open rounds\n205\t// Rounds are created on-demand by players via /closecall/bet\n206\tconst closeCallClock = createCloseCallClockWorker({\n207\t  connection,\n208\t  serverKeypair: config.serverKeypair,\n209\t  db,\n210\t});\n211\tcloseCallClock.start();\n212\t\n213\t// Register event handlers before starting the worker\n214\tregisterHandler(\n215\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n216\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n217\t);\n218\tregisterHandler(\n219\t  EventTypes.GAME_SETTLED,\n220\t  createGameSettledHandler({ db }),\n221\t);\n222\tregisterHandler(\n223\t  EventTypes.REWARD_POOL_FUND,\n224\t  createRewardPoolFundHandler({ db }),\n225\t);\n226\tregisterHandler(\n227\t  EventTypes.POINTS_GRANT,\n228\t  createPointsGrantHandler({\n229\t    db,\n230\t    getSolPrice: async () => {\n231\t      const result = await fetchSolPrice();\n232\t      return result?.price ?? null;\n233\t    },\n234\t  }),\n235\t);\n236\tregisterHandler(\n237\t  EventTypes.CRATE_DROP,\n238\t  createCrateDropHandler({ db }),\n239\t);\n240\t\n241\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n242\tconst eventWorker = createEventWorker(sql, {\n243\t  pollIntervalMs: config.eventQueuePollMs,\n244\t});\n245\teventWorker.start();\n246\tlogger.info(\"Event queue worker started\", {\n247\t  pollIntervalMs: config.eventQueuePollMs,\n248\t});\n249\t\n250\t// Game-specific routes\n251\tapp.route(\n252\t  \"/coinflip\",\n253\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n254\t);\n255\tapp.route(\n256\t  \"/lord\",\n257\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n258\t);\n259\t\n260\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n261\tapp.use(\n262\t  \"/closecall/bet\",\n263\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n264\t);\n265\tapp.use(\n266\t  \"/closecall/bet\",\n267\t  createRateLimitMiddleware({\n268\t    perWallet: config.rateLimitPerWallet,\n269\t    global: config.rateLimitGlobal,\n270\t    windowMs: 60_000,\n271\t  }),\n272\t);\n273\t\n274\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n275\tapp.route(\"/closecall\", createCloseCallRoutes({\n276\t  db,\n277\t  connection,\n278\t  serverKeypair: config.serverKeypair,\n279\t  clockWorker: closeCallClock,\n280\t}));\n281\t\n282\t// Challenge routes — authenticated GET endpoints (require JWT on all methods)\n283\tapp.use(\n284\t  \"/challenges/*\",\n285\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n286\t);\n287\tapp.route(\"/challenges\", createChallengeRoutes({ db }));\n288\t\n289\t// Points routes — authenticated GET endpoints (require JWT on all methods)\n290\tapp.use(\n291\t  \"/points/*\",\n292\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n293\t);\n294\tapp.route(\"/points\", createPointsRoutes({ db }));\n295\t\n296\t// Crate routes — authenticated GET endpoints (require JWT on all methods)\n297\tapp.use(\n298\t  \"/crates/*\",\n299\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n300\t);\n301\tapp.route(\"/crates\", createCrateRoutes({ db }));\n302\t\n303\t// Dogpile routes — public, no auth\n304\tapp.route(\"/dogpile\", createDogpileRoutes({ db }));\n305\t\n306\t// Leaderboard routes — public, no auth\n307\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n308\t\n309\t// Price routes — public, no auth\n310\tapp.route(\"/price\", createPriceRoutes());\n311\t\n312\t// Round verification routes\n313\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n314\t\n315\t// Health endpoint — wired after worker exists so we can query its status\n316\tapp.route(\n317\t  \"/health\",\n318\t  createHealthRoutes({\n319\t    db,\n320\t    sql,\n321\t    isWorkerRunning: () => worker.isRunning,\n322\t  }),\n323\t);\n324\t\n325\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n326\tif (config.adminToken) {\n327\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n328\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n329\t}\n330\t\n331\tconst port = config.port;\n332\tlogger.info(\"fairness-backend started\", { port });\n333\t\n334\tserve({\n335\t  fetch: app.fetch,\n336\t  port,\n337\t  hostname: \"0.0.0.0\",\n338\t});\n339\t\n340\texport default {\n341\t  port,\n342\t  fetch: app.fetch,\n343\t};\n344\t"}]},"parent_tool_use_id":"toolu_01BQjHTvaud19GtiJZqBMpnc","session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"a348d8eb-e43f-4bf2-9ec0-101c4516eb9a","timestamp":"2026-04-03T21:15:14.212Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011XpZZUSWnqzXN9ADqdujEf","type":"tool_result","content":"1\t/**\n2\t * Challenge routes — player-facing challenge/quest endpoints.\n3\t *\n4\t * GET /mine           — returns active daily, weekly, and onboarding challenges\n5\t *                       with lazy assignment on first call per period.\n6\t * GET /mine/history   — paginated completed challenge assignments.\n7\t */\n8\t\n9\timport { Hono } from \"hono\";\n10\timport type { AppEnv } from \"../hono-env.js\";\n11\timport type { Db } from \"../db.js\";\n12\timport { logger } from \"../logger.js\";\n13\timport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n14\t\n15\t// ---------------------------------------------------------------------------\n16\t// Types\n17\t// ---------------------------------------------------------------------------\n18\t\n19\texport interface ChallengeRoutesDeps {\n20\t  db: Db;\n21\t}\n22\t\n23\tinterface ChallengeRow {\n24\t  id: string;\n25\t  campaign_id: string;\n26\t  title: string;\n27\t  description: string;\n28\t  action: string;\n29\t  scope: string;\n30\t  condition: string;\n31\t  threshold: number;\n32\t  reward_type: string;\n33\t  reward_amount: number | null;\n34\t  sort_order: number;\n35\t  prerequisite_id: string | null;\n36\t}\n37\t\n38\tinterface AssignmentRow {\n39\t  id: string;\n40\t  challenge_id: string;\n41\t  period_key: string;\n42\t  status: string;\n43\t  progress: number;\n44\t  target: number;\n45\t  expires_at: string | null;\n46\t  completed_at: string | null;\n47\t  title: string;\n48\t  description: string;\n49\t  reward_type: string;\n50\t  reward_amount: number | null;"}]},"parent_tool_use_id":"toolu_01BQjHTvaud19GtiJZqBMpnc","session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"833a7707-ffb9-4ef6-a8ab-c4a9861232f0","timestamp":"2026-04-03T21:15:14.182Z"}
