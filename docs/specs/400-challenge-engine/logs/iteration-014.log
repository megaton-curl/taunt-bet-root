{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01NvVJYqCtfpnj7ReytCF9Fx","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01DuatBGZhKHxJ57Vqqiv7XF","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/routes/admin.ts","content":"/**\n * Admin API routes — reward config, reward pool, and admin-level management.\n *\n * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n */\n\nimport { Hono } from \"hono\";\nimport type { Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Known config keys — reject unknown keys with 400\n// ---------------------------------------------------------------------------\n\nconst VALID_CONFIG_KEYS = new Set([\n  \"points_per_dollar\",\n  \"dogpile_default_multiplier\",\n  \"reward_pool_fee_share\",\n  \"points_crate_drop_rate\",\n  \"sol_crate_drop_rate\",\n  \"sol_crate_pool_pct\",\n  \"sol_crate_min_value\",\n  \"points_crate_min\",\n  \"points_crate_max\",\n  \"daily_challenge_count\",\n  \"weekly_challenge_count\",\n]);\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport interface AdminRoutesDeps {\n  db: Db;\n  adminApiKey: string;\n}\n\nexport function createAdminRoutes(deps: AdminRoutesDeps) {\n  const { db, adminApiKey } = deps;\n  const app = new Hono();\n\n  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n  app.use(\"*\", async (c, next) => {\n    const key = c.req.header(\"X-Admin-Key\");\n    if (!key || key !== adminApiKey) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    await next();\n  });\n\n  // GET /reward-config — all config key-value pairs\n  app.get(\"/reward-config\", async (c) => {\n    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n    `;\n    const config: Record<string, { value: string; updatedAt: string }> = {};\n    for (const row of rows) {\n      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n    }\n    return c.json(config);\n  });\n\n  // PUT /reward-config/:key — update a single config value\n  app.put(\"/reward-config/:key\", async (c) => {\n    const key = c.req.param(\"key\");\n\n    if (!VALID_CONFIG_KEYS.has(key)) {\n      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n    }\n\n    const body = await c.req.json<{ value?: string }>();\n    if (body.value === undefined || body.value === null) {\n      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n    }\n\n    await db.rawSql`\n      UPDATE reward_config\n      SET value = ${String(body.value)}, updated_at = now()\n      WHERE key = ${key}\n    `;\n\n    return c.json({ key, value: String(body.value) });\n  });\n\n  // GET /reward-pool — current pool state\n  app.get(\"/reward-pool\", async (c) => {\n    const rows = await db.rawSql<{\n      balance_lamports: string;\n      lifetime_funded: string;\n      lifetime_paid: string;\n      updated_at: string;\n    }[]>`\n      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n      FROM reward_pool WHERE id = 1\n    `;\n    if (rows.length === 0) {\n      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n    }\n    const pool = rows[0]!;\n    return c.json({\n      balanceLamports: pool.balance_lamports,\n      lifetimeFunded: pool.lifetime_funded,\n      lifetimePaid: pool.lifetime_paid,\n      updatedAt: pool.updated_at,\n    });\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":158,"cache_read_input_tokens":59371,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":158},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"7370bff7-ff5b-47cd-919a-96211b9b6044"}
