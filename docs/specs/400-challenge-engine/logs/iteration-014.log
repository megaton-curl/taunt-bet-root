{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JZt6sqC8sFM9WTrz5A6e4w","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createChallengeRoutes } from \"./routes/challenges.js\";\n21\timport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\n22\timport { createDogpileRoutes } from \"./routes/dogpile.js\";\n23\timport { createInternalRoutes } from \"./routes/internal.js\";\n24\timport { swaggerUI } from \"@hono/swagger-ui\";\n25\timport { spec } from \"./openapi.js\";\n26\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n27\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n28\timport { createSettlementWorker } from \"./worker/settlement.js\";\n29\timport { settleRound } from \"./worker/settle-tx.js\";\n30\timport { createRetrySettler } from \"./worker/retry.js\";\n31\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n32\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n33\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n34\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n35\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n36\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n37\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n38\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n39\timport { fetchSolPrice } from \"./routes/price.js\";\n40\timport { logger } from \"./logger.js\";\n41\t\n42\tconst config = loadConfig();\n43\t\n44\t// Single postgres pool shared by game DB, auth DB, and all workers\n45\tconst sql = postgres(config.databaseUrl);\n46\tconst db = createDb(config.databaseUrl, sql);\n47\tconst authDb = createAuthDb(sql);\n48\t\n49\tconst connection = new Connection(config.rpcUrl, {\n50\t  commitment: \"confirmed\",\n51\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n52\t});\n53\t\n54\tconst app = new Hono();\n55\t\n56\tapp.use(\n57\t  \"*\",\n58\t  cors({\n59\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n60\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n61\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n62\t  }),\n63\t);\n64\t\n65\t// Request logging — correlate frontend fetch timing with server-side processing\n66\tapp.use(\"*\", async (c, next) => {\n67\t  const start = Date.now();\n68\t  await next();\n69\t  const ms = Date.now() - start;\n70\t  const method = c.req.method;\n71\t  const path = c.req.path;\n72\t  // Skip noisy health checks and OPTIONS preflight\n73\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n74\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n75\t});\n76\t\n77\t// API docs — Swagger UI + raw OpenAPI spec\n78\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n79\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n80\t\n81\t// Auth routes — no JWT middleware (these are the login endpoints)\n82\t// Lighter rate limiting by IP for auth endpoints\n83\tapp.use(\n84\t  \"/auth/*\",\n85\t  createRateLimitMiddleware({\n86\t    perWallet: 20,\n87\t    global: config.rateLimitGlobal,\n88\t    windowMs: 60_000,\n89\t  }),\n90\t);\n91\t\n92\tapp.route(\n93\t  \"/auth\",\n94\t  createAuthRoutes({\n95\t    authDb,\n96\t    db,\n97\t    jwtSecret: config.jwtSecret,\n98\t    cluster: config.cluster,\n99\t    challengeTtlSeconds: config.challengeTtlSeconds,\n100\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n101\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n102\t  }),\n103\t);\n104\t\n105\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n106\tapp.use(\n107\t  \"/profile/*\",\n108\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n109\t);\n110\tapp.route(\"/profile\", createProfileRoutes({ db }));\n111\t\n112\t// Public profile routes — no auth required\n113\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n114\t\n115\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n116\tapp.use(\n117\t  \"/referral/*\",\n118\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n119\t);\n120\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n121\t\n122\t// JWT auth middleware for game endpoints\n123\tapp.use(\n124\t  \"/coinflip/*\",\n125\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n126\t);\n127\tapp.use(\n128\t  \"/lord/*\",\n129\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n130\t);\n131\t\n132\t// Rate limiting — per-wallet and global limits on POST requests\n133\tapp.use(\n134\t  \"/coinflip/*\",\n135\t  createRateLimitMiddleware({\n136\t    perWallet: config.rateLimitPerWallet,\n137\t    global: config.rateLimitGlobal,\n138\t    windowMs: 60_000,\n139\t  }),\n140\t);\n141\tapp.use(\n142\t  \"/lord/*\",\n143\t  createRateLimitMiddleware({\n144\t    perWallet: config.rateLimitPerWallet,\n145\t    global: config.rateLimitGlobal,\n146\t    windowMs: 60_000,\n147\t  }),\n148\t);\n149\t\n150\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n151\tconst entropyAccount = new PublicKey(config.entropyAccount);\n152\tconst retrySettler = createRetrySettler({\n153\t  db,\n154\t  connection,\n155\t  settleRound: (pda) =>\n156\t    settleRound(\n157\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n158\t      pda,\n159\t    ),\n160\t});\n161\t\n162\t// PDA watcher — WebSocket-based instant join detection\n163\tconst pdaWatcher = createPdaWatcher({\n164\t  connection,\n165\t  serverKey: config.serverKeypair.publicKey,\n166\t  db,\n167\t  onJoinDetected: async (pda, targetSlot) => {\n168\t    // Update DB phase if still in 'created'\n169\t    const round = await db.getRoundByPda(pda);\n170\t    if (round && round.phase === \"created\") {\n171\t      await db.updateRoundPhase(pda, \"locked\", {\n172\t        target_slot: targetSlot.toString(),\n173\t      });\n174\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n175\t        targetSlot: targetSlot.toString(),\n176\t        source: \"pda-watcher\",\n177\t        game: round.game,\n178\t      });\n179\t    }\n180\t\n181\t    // Check if target slot already passed — settle immediately if so\n182\t    const currentSlot = await connection.getSlot();\n183\t    if (BigInt(currentSlot) >= targetSlot) {\n184\t      await retrySettler.attemptSettle(pda);\n185\t      pdaWatcher.unwatch(pda);\n186\t    }\n187\t    // If target slot not reached yet, poll worker will pick it up next cycle\n188\t  },\n189\t});\n190\t\n191\tconst worker = createSettlementWorker({\n192\t  db,\n193\t  connection,\n194\t  serverKey: config.serverKeypair.publicKey,\n195\t  pollIntervalMs: config.workerPollIntervalMs,\n196\t  onSettleReady: async (pda) => {\n197\t    await retrySettler.attemptSettle(pda);\n198\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n199\t  },\n200\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n201\t});\n202\tworker.start();\n203\t\n204\t// Close Call clock worker — fetches boundary prices + settles open rounds\n205\t// Rounds are created on-demand by players via /closecall/bet\n206\tconst closeCallClock = createCloseCallClockWorker({\n207\t  connection,\n208\t  serverKeypair: config.serverKeypair,\n209\t  db,\n210\t});\n211\tcloseCallClock.start();\n212\t\n213\t// Register event handlers before starting the worker\n214\tregisterHandler(\n215\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n216\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n217\t);\n218\tregisterHandler(\n219\t  EventTypes.GAME_SETTLED,\n220\t  createGameSettledHandler({ db }),\n221\t);\n222\tregisterHandler(\n223\t  EventTypes.REWARD_POOL_FUND,\n224\t  createRewardPoolFundHandler({ db }),\n225\t);\n226\tregisterHandler(\n227\t  EventTypes.POINTS_GRANT,\n228\t  createPointsGrantHandler({\n229\t    db,\n230\t    getSolPrice: async () => {\n231\t      const result = await fetchSolPrice();\n232\t      return result?.price ?? null;\n233\t    },\n234\t  }),\n235\t);\n236\tregisterHandler(\n237\t  EventTypes.CRATE_DROP,\n238\t  createCrateDropHandler({ db }),\n239\t);\n240\t\n241\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n242\tconst eventWorker = createEventWorker(sql, {\n243\t  pollIntervalMs: config.eventQueuePollMs,\n244\t});\n245\teventWorker.start();\n246\tlogger.info(\"Event queue worker started\", {\n247\t  pollIntervalMs: config.eventQueuePollMs,\n248\t});\n249\t\n250\t// Game-specific routes\n251\tapp.route(\n252\t  \"/coinflip\",\n253\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n254\t);\n255\tapp.route(\n256\t  \"/lord\",\n257\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n258\t);\n259\t\n260\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n261\tapp.use(\n262\t  \"/closecall/bet\",\n263\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n264\t);\n265\tapp.use(\n266\t  \"/closecall/bet\",\n267\t  createRateLimitMiddleware({\n268\t    perWallet: config.rateLimitPerWallet,\n269\t    global: config.rateLimitGlobal,\n270\t    windowMs: 60_000,\n271\t  }),\n272\t);\n273\t\n274\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n275\tapp.route(\"/closecall\", createCloseCallRoutes({\n276\t  db,\n277\t  connection,\n278\t  serverKeypair: config.serverKeypair,\n279\t  clockWorker: closeCallClock,\n280\t}));\n281\t\n282\t// Challenge routes — authenticated GET endpoints (require JWT on all methods)\n283\tapp.use(\n284\t  \"/challenges/*\",\n285\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n286\t);\n287\tapp.route(\"/challenges\", createChallengeRoutes({ db }));\n288\t\n289\t// Points routes — authenticated GET endpoints (require JWT on all methods)\n290\tapp.use(\n291\t  \"/points/*\",\n292\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n293\t);\n294\tapp.route(\"/points\", createPointsRoutes({ db }));\n295\t\n296\t// Crate routes — authenticated GET endpoints (require JWT on all methods)\n297\tapp.use(\n298\t  \"/crates/*\",\n299\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n300\t);\n301\tapp.route(\"/crates\", createCrateRoutes({ db }));\n302\t\n303\t// Dogpile routes — public, no auth\n304\tapp.route(\"/dogpile\", createDogpileRoutes({ db }));\n305\t\n306\t// Leaderboard routes — public, no auth\n307\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n308\t\n309\t// Price routes — public, no auth\n310\tapp.route(\"/price\", createPriceRoutes());\n311\t\n312\t// Round verification routes\n313\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n314\t\n315\t// Health endpoint — wired after worker exists so we can query its status\n316\tapp.route(\n317\t  \"/health\",\n318\t  createHealthRoutes({\n319\t    db,\n320\t    sql,\n321\t    isWorkerRunning: () => worker.isRunning,\n322\t  }),\n323\t);\n324\t\n325\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n326\tif (config.adminToken) {\n327\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n328\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n329\t}\n330\t\n331\tconst port = config.port;\n332\tlogger.info(\"fairness-backend started\", { port });\n333\t\n334\tserve({\n335\t  fetch: app.fetch,\n336\t  port,\n337\t  hostname: \"0.0.0.0\",\n338\t});\n339\t\n340\texport default {\n341\t  port,\n342\t  fetch: app.fetch,\n343\t};\n344\t"}]},"parent_tool_use_id":null,"session_id":"854178fe-49ab-42ba-ac58-41bc6d7d756e","uuid":"4f3eb9c3-6b4b-4c3a-8be7-19abd7de39bb","timestamp":"2026-04-03T21:16:08.266Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { cors } from \"hono/cors\";\nimport { serve } from \"@hono/node-server\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport postgres from \"postgres\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createAuthDb } from \"./auth-db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createLordRoutes } from \"./routes/lord-create.js\";\nimport { createRoundsRoutes } from \"./routes/rounds.js\";\nimport { createCloseCallRoutes } from \"./routes/closecall.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createProfileRoutes } from \"./routes/profile.js\";\nimport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\nimport { createPriceRoutes } from \"./routes/price.js\";\nimport { createAuthRoutes } from \"./routes/auth.js\";\nimport { createReferralRoutes } from \"./routes/referral.js\";\nimport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\nimport { createChallengeRoutes } from \"./routes/challenges.js\";\nimport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\nimport { createDogpileRoutes } from \"./routes/dogpile.js\";\nimport { createInternalRoutes } from \"./routes/internal.js\";\nimport { swaggerUI } from \"@hono/swagger-ui\";\nimport { spec } from \"./openapi.js\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\nimport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\nimport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\nimport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\nimport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\nimport { fetchSolPrice } from \"./routes/price.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Single postgres pool shared by game DB, auth DB, and all workers\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl, sql);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new Hono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// API docs — Swagger UI + raw OpenAPI spec\napp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\napp.get(\"/openapi.json\", (c) => c.json(spec));\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    db,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// Profile routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/profile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/profile\", createProfileRoutes({ db }));\n\n// Public profile routes — no auth required\napp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n\n// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\napp.use(\n  \"/referral/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n\n// JWT auth middleware for game endpoints\napp.use(\n  \"/coinflip/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/lord/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/coinflip/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\napp.use(\n  \"/lord/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  db,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Close Call clock worker — fetches boundary prices + settles open rounds\n// Rounds are created on-demand by players via /closecall/bet\nconst closeCallClock = createCloseCallClockWorker({\n  connection,\n  serverKeypair: config.serverKeypair,\n  db,\n});\ncloseCallClock.start();\n\n// Register event handlers before starting the worker\nregisterHandler(\n  EventTypes.REFERRAL_CLAIM_REQUESTED,\n  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\nregisterHandler(\n  EventTypes.GAME_SETTLED,\n  createGameSettledHandler({ db }),\n);\nregisterHandler(\n  EventTypes.REWARD_POOL_FUND,\n  createRewardPoolFundHandler({ db }),\n);\nregisterHandler(\n  EventTypes.POINTS_GRANT,\n  createPointsGrantHandler({\n    db,\n    getSolPrice: async () => {\n      const result = await fetchSolPrice();\n      return result?.price ?? null;\n    },\n  }),\n);\nregisterHandler(\n  EventTypes.CRATE_DROP,\n  createCrateDropHandler({ db }),\n);\n\n// Event queue worker — processes async side-effects (rewards, notifications, etc.)\nconst eventWorker = createEventWorker(sql, {\n  pollIntervalMs: config.eventQueuePollMs,\n});\neventWorker.start();\nlogger.info(\"Event queue worker started\", {\n  pollIntervalMs: config.eventQueuePollMs,\n});\n\n// Game-specific routes\napp.route(\n  \"/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/lord\",\n  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\napp.use(\n  \"/closecall/bet\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/closecall/bet\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Close Call routes (read endpoints are public, /bet is auth'd above)\napp.route(\"/closecall\", createCloseCallRoutes({\n  db,\n  connection,\n  serverKeypair: config.serverKeypair,\n  clockWorker: closeCallClock,\n}));\n\n// Challenge routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/challenges/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/challenges\", createChallengeRoutes({ db }));\n\n// Points routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/points/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/points\", createPointsRoutes({ db }));\n\n// Crate routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/crates/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/crates\", createCrateRoutes({ db }));\n\n// Dogpile routes — public, no auth\napp.route(\"/dogpile\", createDogpileRoutes({ db }));\n\n// Leaderboard routes — public, no auth\napp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n\n// Price routes — public, no auth\napp.route(\"/price\", createPriceRoutes());\n\n// Round verification routes\napp.route(\"/rounds\", createRoundsRoutes({ db }));\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    db,\n    sql,\n    isWorkerRunning: () => worker.isRunning,\n  }),\n);\n\n// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\nif (config.adminToken) {\n  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n}\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", { port });\n\nserve({\n  fetch: app.fetch,\n  port,\n  hostname: \"0.0.0.0\",\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":344,"startLine":1,"totalLines":344}}}
