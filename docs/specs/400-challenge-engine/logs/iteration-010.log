{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011AZjFWzadweCmv9PMUGJ3d","type":"tool_result","content":"1\t/**\n2\t * GAME_SETTLED handler — the orchestrator for the challenge engine.\n3\t *\n4\t * Processes each player in a settled game event:\n5\t *   1. Quest eligibility check (skip refunded games)\n6\t *   2. Challenge progress evaluation via adapters\n7\t *   3. Reward intent emission on challenge completion\n8\t *   4. Wager-based points grant\n9\t *   5. Crate drop roll\n10\t *\n11\t * Once per round: reward pool funding.\n12\t *\n13\t * Per-player try/catch ensures one player's error doesn't block others.\n14\t * Idempotent via UNIQUE constraints on progress_events, point_grants,\n15\t * crate_drops, and reward_pool_fundings.\n16\t */\n17\t\n18\timport type { Db } from \"../../db.js\";\n19\timport { logger } from \"../../logger.js\";\n20\timport { emitEvent } from \"../emit-event.js\";\n21\timport { EventTypes } from \"../event-types.js\";\n22\timport {\n23\t  questEligible,\n24\t  getAdapter,\n25\t  type GameSettledPayload,\n26\t  type GameSettledPlayer,\n27\t  type ChallengeAssignment,\n28\t} from \"./challenge-adapters.js\";\n29\timport { checkCompletionBonus } from \"./completion-bonus.js\";\n30\t\n31\t// ---------------------------------------------------------------------------\n32\t// DB helpers\n33\t// ---------------------------------------------------------------------------\n34\t\n35\t/** Row shape from the active-assignments + challenges JOIN. */\n36\tinterface AssignmentWithChallenge {\n37\t  id: string;\n38\t  challenge_id: string;\n39\t  action: string;\n40\t  scope: string;\n41\t  condition: string;\n42\t  target: number;\n43\t  progress: number;\n44\t  status: string;\n45\t  period_key: string;\n46\t  campaign_id: string;\n47\t  reward_type: string;\n48\t  reward_amount: number | null;\n49\t}\n50\t\n51\t/**\n52\t * Load active challenge assignments for a user, joined with their challenge\n53\t * definitions. Uses the partial index on (user_id, status) WHERE status='active'.\n54\t */\n55\texport async function getActiveAssignmentsWithChallenge(\n56\t  db: Db,\n57\t  userId: string,\n58\t): Promise<AssignmentWithChallenge[]> {\n59\t  return db.rawSql<AssignmentWithChallenge[]>`\n60\t    SELECT\n61\t      ca.id,\n62\t      ca.challenge_id,\n63\t      c.action,\n64\t      c.scope,\n65\t      c.condition,\n66\t      ca.target,\n67\t      ca.progress,\n68\t      ca.status,\n69\t      ca.period_key,\n70\t      c.campaign_id,\n71\t      c.reward_type,\n72\t      c.reward_amount\n73\t    FROM challenge_assignments ca\n74\t    JOIN challenges c ON c.id = ca.challenge_id\n75\t    WHERE ca.user_id = ${userId}\n76\t      AND ca.status = 'active'\n77\t  `;\n78\t}\n79\t\n80\t/**\n81\t * Insert a progress event. Returns false if a row for this\n82\t * (assignment_id, round_id) already exists (idempotency guard).\n83\t */\n84\texport async function insertProgressEvent(\n85\t  db: Db,\n86\t  assignmentId: string,\n87\t  roundId: string,\n88\t  userId: string,\n89\t  delta: number,\n90\t  metadata: Record<string, unknown>,\n91\t): Promise<boolean> {\n92\t  const rows = await db.rawSql<{ id: string }[]>`\n93\t    INSERT INTO progress_events (assignment_id, round_id, user_id, progress_delta, metadata)\n94\t    VALUES (${assignmentId}, ${roundId}, ${userId}, ${delta}, ${JSON.stringify(metadata)})\n95\t    ON CONFLICT (assignment_id, round_id) DO NOTHING\n96\t    RETURNING id\n97\t  `;\n98\t  return rows.length > 0;\n99\t}\n100\t\n101\t/**\n102\t * Atomically increment an assignment's progress by delta.\n103\t * Returns the new progress value.\n104\t */\n105\texport async function incrementAssignmentProgress(\n106\t  db: Db,\n107\t  assignmentId: string,\n108\t  delta: number,\n109\t): Promise<number> {\n110\t  const rows = await db.rawSql<{ progress: number }[]>`\n111\t    UPDATE challenge_assignments\n112\t    SET progress = progress + ${delta}\n113\t    WHERE id = ${assignmentId}\n114\t    RETURNING progress\n115\t  `;\n116\t  return rows[0]!.progress;\n117\t}\n118\t\n119\t/**\n120\t * Mark an assignment as completed with a timestamp.\n121\t */\n122\texport async function markAssignmentCompleted(\n123\t  db: Db,\n124\t  assignmentId: string,\n125\t): Promise<void> {\n126\t  await db.rawSql`\n127\t    UPDATE challenge_assignments\n128\t    SET status = 'completed', completed_at = now()\n129\t    WHERE id = ${assignmentId}\n130\t  `;\n131\t}\n132\t\n133\t// ---------------------------------------------------------------------------\n134\t// Handler factory\n135\t// ---------------------------------------------------------------------------\n136\t\n137\texport interface GameSettledDeps {\n138\t  db: Db;\n139\t}\n140\t\n141\texport function createGameSettledHandler(deps: GameSettledDeps) {\n142\t  const { db } = deps;\n143\t\n144\t  return async (payload: Record<string, unknown>): Promise<void> => {\n145\t    // Validate and cast payload\n146\t    const roundId = payload.roundId as string;\n147\t    const game = payload.game as string;\n148\t    const players = payload.players as GameSettledPlayer[] | undefined;\n149\t    const feeLamports = payload.feeLamports as string;\n150\t    const settledAt = payload.settledAt as string;\n151\t    const roundPda = payload.roundPda as string;\n152\t\n153\t    if (!roundId || !game || !players || !feeLamports || !settledAt) {\n154\t      throw new Error(\n155\t        \"game.settled: malformed payload — missing roundId, game, players, feeLamports, or settledAt\",\n156\t      );\n157\t    }\n158\t\n159\t    // --- Once per round: emit reward.pool_fund ---\n160\t    await emitEvent(db.rawSql, EventTypes.REWARD_POOL_FUND, {\n161\t      roundId,\n162\t      roundPda,\n163\t      feeLamports,\n164\t    });\n165\t\n166\t    // --- Per-player processing ---\n167\t    for (const player of players) {\n168\t      try {\n169\t        // Quest eligibility gate — skip refunded games\n170\t        if (!questEligible(player)) {\n171\t          logger.debug(\"game.settled: player ineligible (refund)\", {\n172\t            userId: player.userId,\n173\t            roundId,\n174\t          });\n175\t          continue;\n176\t        }\n177\t\n178\t        // ---- Challenge progress evaluation ----\n179\t        const assignments = await getActiveAssignmentsWithChallenge(\n180\t          db,\n181\t          player.userId,\n182\t        );\n183\t\n184\t        for (const assignment of assignments) {\n185\t          const adapter = getAdapter(assignment.action);\n186\t          const challengeAssignment: ChallengeAssignment = {\n187\t            id: Number(assignment.id),\n188\t            challengeId: Number(assignment.challenge_id),\n189\t            action: assignment.action,\n190\t            scope: assignment.scope,\n191\t            condition: assignment.condition,\n192\t            target: assignment.target,\n193\t            progress: assignment.progress,\n194\t            status: assignment.status,\n195\t          };\n196\t\n197\t          const result = adapter(\n198\t            payload as unknown as GameSettledPayload,\n199\t            player,\n200\t            challengeAssignment,\n201\t          );\n202\t\n203\t          if (!result.shouldProgress) continue;\n204\t\n205\t          // Atomic: insert progress event + increment progress\n206\t          await db.withTransaction(async (txDb) => {\n207\t            const inserted = await insertProgressEvent(\n208\t              txDb,\n209\t              assignment.id,\n210\t              roundId,\n211\t              player.userId,\n212\t              result.progressDelta,\n213\t              { game },\n214\t            );\n215\t            if (!inserted) {\n216\t              // Duplicate round for this assignment — skip\n217\t              return;\n218\t            }\n219\t\n220\t            const newProgress = await incrementAssignmentProgress(\n221\t              txDb,\n222\t              assignment.id,\n223\t              result.progressDelta,\n224\t            );\n225\t\n226\t            // Check completion\n227\t            if (newProgress >= assignment.target) {\n228\t              await markAssignmentCompleted(txDb, assignment.id);\n229\t\n230\t              // Emit reward intent based on challenge's reward_type\n231\t              if (assignment.reward_type === \"points\" && assignment.reward_amount) {\n232\t                await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n233\t                  userId: player.userId,\n234\t                  wallet: player.wallet,\n235\t                  sourceType: \"challenge_completed\",\n236\t                  sourceId: `challenge-${assignment.id}`,\n237\t                  amount: assignment.reward_amount.toString(),\n238\t                });\n239\t              } else if (assignment.reward_type === \"crate\") {\n240\t                await emitEvent(txDb.rawSql, EventTypes.CRATE_DROP, {\n241\t                  userId: player.userId,\n242\t                  wallet: player.wallet,\n243\t                  triggerType: \"challenge_completed\",\n244\t                  triggerId: `challenge-${assignment.id}`,\n245\t                });\n246\t              }\n247\t\n248\t              logger.info(\"game.settled: challenge completed\", {\n249\t                userId: player.userId,\n250\t                assignmentId: assignment.id,\n251\t                challengeId: assignment.challenge_id,\n252\t                rewardType: assignment.reward_type,\n253\t              });\n254\t\n255\t              // Check completion bonus (e.g., all daily challenges done → bonus crate)\n256\t              await checkCompletionBonus(\n257\t                txDb,\n258\t                player.userId,\n259\t                player.wallet,\n260\t                assignment.period_key,\n261\t                assignment.campaign_id,\n262\t              );\n263\t            }\n264\t          });\n265\t        }\n266\t\n267\t        // ---- Wager-based points grant ----\n268\t        await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n269\t          userId: player.userId,\n270\t          wallet: player.wallet,\n271\t          sourceType: \"wager\",\n272\t          sourceId: roundId,\n273\t          amountLamports: player.amountLamports,\n274\t          settledAt,\n275\t        });\n276\t\n277\t        // ---- Crate drop ----\n278\t        await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n279\t          userId: player.userId,\n280\t          wallet: player.wallet,\n281\t          triggerType: \"game_settled\",\n282\t          triggerId: roundId,\n283\t        });\n284\t      } catch (err) {\n285\t        // Per-player try/catch — don't let one player's error block others\n286\t        logger.error(\"game.settled: error processing player\", {\n287\t          userId: player.userId,\n288\t          roundId,\n289\t          error: err instanceof Error ? err.message : String(err),\n290\t        });\n291\t      }\n292\t    }\n293\t\n294\t    logger.info(\"game.settled: processed\", {\n295\t      roundId,\n296\t      game,\n297\t      playerCount: players.length,\n298\t    });\n299\t  };\n300\t}\n301\t"}]},"parent_tool_use_id":null,"session_id":"a8262916-ffcb-4b28-90e1-2b18f6c84ba5","uuid":"46f57afe-acd4-4293-bd8f-49c1c86f7e75","timestamp":"2026-04-03T20:34:28.677Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/game-settled.ts","content":"/**\n * GAME_SETTLED handler — the orchestrator for the challenge engine.\n *\n * Processes each player in a settled game event:\n *   1. Quest eligibility check (skip refunded games)\n *   2. Challenge progress evaluation via adapters\n *   3. Reward intent emission on challenge completion\n *   4. Wager-based points grant\n *   5. Crate drop roll\n *\n * Once per round: reward pool funding.\n *\n * Per-player try/catch ensures one player's error doesn't block others.\n * Idempotent via UNIQUE constraints on progress_events, point_grants,\n * crate_drops, and reward_pool_fundings.\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\nimport { emitEvent } from \"../emit-event.js\";\nimport { EventTypes } from \"../event-types.js\";\nimport {\n  questEligible,\n  getAdapter,\n  type GameSettledPayload,\n  type GameSettledPlayer,\n  type ChallengeAssignment,\n} from \"./challenge-adapters.js\";\nimport { checkCompletionBonus } from \"./completion-bonus.js\";\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Row shape from the active-assignments + challenges JOIN. */\ninterface AssignmentWithChallenge {\n  id: string;\n  challenge_id: string;\n  action: string;\n  scope: string;\n  condition: string;\n  target: number;\n  progress: number;\n  status: string;\n  period_key: string;\n  campaign_id: string;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\n/**\n * Load active challenge assignments for a user, joined with their challenge\n * definitions. Uses the partial index on (user_id, status) WHERE status='active'.\n */\nexport async function getActiveAssignmentsWithChallenge(\n  db: Db,\n  userId: string,\n): Promise<AssignmentWithChallenge[]> {\n  return db.rawSql<AssignmentWithChallenge[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      c.action,\n      c.scope,\n      c.condition,\n      ca.target,\n      ca.progress,\n      ca.status,\n      ca.period_key,\n      c.campaign_id,\n      c.reward_type,\n      c.reward_amount\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.status = 'active'\n  `;\n}\n\n/**\n * Insert a progress event. Returns false if a row for this\n * (assignment_id, round_id) already exists (idempotency guard).\n */\nexport async function insertProgressEvent(\n  db: Db,\n  assignmentId: string,\n  roundId: string,\n  userId: string,\n  delta: number,\n  metadata: Record<string, unknown>,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO progress_events (assignment_id, round_id, user_id, progress_delta, metadata)\n    VALUES (${assignmentId}, ${roundId}, ${userId}, ${delta}, ${JSON.stringify(metadata)})\n    ON CONFLICT (assignment_id, round_id) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n/**\n * Atomically increment an assignment's progress by delta.\n * Returns the new progress value.\n */\nexport async function incrementAssignmentProgress(\n  db: Db,\n  assignmentId: string,\n  delta: number,\n): Promise<number> {\n  const rows = await db.rawSql<{ progress: number }[]>`\n    UPDATE challenge_assignments\n    SET progress = progress + ${delta}\n    WHERE id = ${assignmentId}\n    RETURNING progress\n  `;\n  return rows[0]!.progress;\n}\n\n/**\n * Mark an assignment as completed with a timestamp.\n */\nexport async function markAssignmentCompleted(\n  db: Db,\n  assignmentId: string,\n): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'completed', completed_at = now()\n    WHERE id = ${assignmentId}\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Handler factory\n// ---------------------------------------------------------------------------\n\nexport interface GameSettledDeps {\n  db: Db;\n}\n\nexport function createGameSettledHandler(deps: GameSettledDeps) {\n  const { db } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    // Validate and cast payload\n    const roundId = payload.roundId as string;\n    const game = payload.game as string;\n    const players = payload.players as GameSettledPlayer[] | undefined;\n    const feeLamports = payload.feeLamports as string;\n    const settledAt = payload.settledAt as string;\n    const roundPda = payload.roundPda as string;\n\n    if (!roundId || !game || !players || !feeLamports || !settledAt) {\n      throw new Error(\n        \"game.settled: malformed payload — missing roundId, game, players, feeLamports, or settledAt\",\n      );\n    }\n\n    // --- Once per round: emit reward.pool_fund ---\n    await emitEvent(db.rawSql, EventTypes.REWARD_POOL_FUND, {\n      roundId,\n      roundPda,\n      feeLamports,\n    });\n\n    // --- Per-player processing ---\n    for (const player of players) {\n      try {\n        // Quest eligibility gate — skip refunded games\n        if (!questEligible(player)) {\n          logger.debug(\"game.settled: player ineligible (refund)\", {\n            userId: player.userId,\n            roundId,\n          });\n          continue;\n        }\n\n        // ---- Challenge progress evaluation ----\n        const assignments = await getActiveAssignmentsWithChallenge(\n          db,\n          player.userId,\n        );\n\n        for (const assignment of assignments) {\n          const adapter = getAdapter(assignment.action);\n          const challengeAssignment: ChallengeAssignment = {\n            id: Number(assignment.id),\n            challengeId: Number(assignment.challenge_id),\n            action: assignment.action,\n            scope: assignment.scope,\n            condition: assignment.condition,\n            target: assignment.target,\n            progress: assignment.progress,\n            status: assignment.status,\n          };\n\n          const result = adapter(\n            payload as unknown as GameSettledPayload,\n            player,\n            challengeAssignment,\n          );\n\n          if (!result.shouldProgress) continue;\n\n          // Atomic: insert progress event + increment progress\n          await db.withTransaction(async (txDb) => {\n            const inserted = await insertProgressEvent(\n              txDb,\n              assignment.id,\n              roundId,\n              player.userId,\n              result.progressDelta,\n              { game },\n            );\n            if (!inserted) {\n              // Duplicate round for this assignment — skip\n              return;\n            }\n\n            const newProgress = await incrementAssignmentProgress(\n              txDb,\n              assignment.id,\n              result.progressDelta,\n            );\n\n            // Check completion\n            if (newProgress >= assignment.target) {\n              await markAssignmentCompleted(txDb, assignment.id);\n\n              // Emit reward intent based on challenge's reward_type\n              if (assignment.reward_type === \"points\" && assignment.reward_amount) {\n                await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n                  userId: player.userId,\n                  wallet: player.wallet,\n                  sourceType: \"challenge_completed\",\n                  sourceId: `challenge-${assignment.id}`,\n                  amount: assignment.reward_amount.toString(),\n                });\n              } else if (assignment.reward_type === \"crate\") {\n                await emitEvent(txDb.rawSql, EventTypes.CRATE_DROP, {\n                  userId: player.userId,\n                  wallet: player.wallet,\n                  triggerType: \"challenge_completed\",\n                  triggerId: `challenge-${assignment.id}`,\n                });\n              }\n\n              logger.info(\"game.settled: challenge completed\", {\n                userId: player.userId,\n                assignmentId: assignment.id,\n                challengeId: assignment.challenge_id,\n                rewardType: assignment.reward_type,\n              });\n\n              // Check completion bonus (e.g., all daily challenges done → bonus crate)\n              await checkCompletionBonus(\n                txDb,\n                player.userId,\n                player.wallet,\n                assignment.period_key,\n                assignment.campaign_id,\n              );\n            }\n          });\n        }\n\n        // ---- Wager-based points grant ----\n        await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n          userId: player.userId,\n          wallet: player.wallet,\n          sourceType: \"wager\",\n          sourceId: roundId,\n          amountLamports: player.amountLamports,\n          settledAt,\n        });\n\n        // ---- Crate drop ----\n        await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n          userId: player.userId,\n          wallet: player.wallet,\n          triggerType: \"game_settled\",\n          triggerId: roundId,\n        });\n      } catch (err) {\n        // Per-player try/catch — don't let one player's error block others\n        logger.error(\"game.settled: error processing player\", {\n          userId: player.userId,\n          roundId,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n    }\n\n    logger.info(\"game.settled: processed\", {\n      roundId,\n      game,\n      playerCount: players.length,\n    });\n  };\n}\n","numLines":301,"startLine":1,"totalLines":301}}}
