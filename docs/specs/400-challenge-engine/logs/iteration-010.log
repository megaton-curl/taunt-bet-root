{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01UwtMwSo5XdR192heTmssxF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019MHUp661Hd7ruvJJWNgnQ9","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/onboarding-chain.ts","content":"/**\n * Onboarding chain progression — auto-assigns the next onboarding step\n * when a player completes an onboarding challenge.\n *\n * Onboarding challenges are linked via `prerequisite_id`. Completing step N\n * triggers assignment of step N+1 (if it exists and hasn't been assigned yet).\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\ninterface NextStep {\n  id: string;\n  threshold: number;\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/**\n * Find the next onboarding challenge whose `prerequisite_id` matches\n * the just-completed challenge.\n */\nexport async function getNextOnboardingStep(\n  db: Db,\n  completedChallengeId: string,\n): Promise<NextStep | null> {\n  const rows = await db.rawSql<NextStep[]>`\n    SELECT id, threshold\n    FROM challenges\n    WHERE prerequisite_id = ${completedChallengeId}\n      AND is_active = true\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/**\n * Create a challenge assignment. Returns false if a row for this\n * (user_id, challenge_id, period_key) already exists (idempotency via UNIQUE).\n */\nexport async function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n// ---------------------------------------------------------------------------\n// Main\n// ---------------------------------------------------------------------------\n\n/**\n * After an onboarding assignment is completed, check if there's a next step\n * in the chain and auto-assign it.\n *\n * Called from game-settled handler within the completion transaction.\n */\nexport async function advanceOnboardingChain(\n  db: Db,\n  userId: string,\n  completedChallengeId: string,\n  periodKey: string,\n): Promise<void> {\n  // Only process onboarding assignments\n  if (periodKey !== \"onboarding\") return;\n\n  const nextStep = await getNextOnboardingStep(db, completedChallengeId);\n  if (!nextStep) {\n    logger.debug(\"onboarding: no next step (chain complete)\", {\n      userId,\n      completedChallengeId,\n    });\n    return;\n  }\n\n  const created = await createAssignment(\n    db,\n    userId,\n    nextStep.id,\n    \"onboarding\",\n    nextStep.threshold,\n    null,\n  );\n\n  if (created) {\n    logger.info(\"onboarding: next step assigned\", {\n      userId,\n      completedChallengeId,\n      nextChallengeId: nextStep.id,\n    });\n  } else {\n    logger.debug(\"onboarding: next step already assigned (idempotent)\", {\n      userId,\n      nextChallengeId: nextStep.id,\n    });\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4418,"cache_read_input_tokens":48586,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4418},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a8262916-ffcb-4b28-90e1-2b18f6c84ba5","uuid":"b9922e9b-e47c-4f35-ab2b-16c7164de20a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019MHUp661Hd7ruvJJWNgnQ9","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/backend/services/backend/src/queue/handlers/onboarding-chain.ts"}]},"parent_tool_use_id":null,"session_id":"a8262916-ffcb-4b28-90e1-2b18f6c84ba5","uuid":"132ddf66-5ba9-4b99-96e0-17547bcb4016","timestamp":"2026-04-03T20:34:43.145Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/onboarding-chain.ts","content":"/**\n * Onboarding chain progression — auto-assigns the next onboarding step\n * when a player completes an onboarding challenge.\n *\n * Onboarding challenges are linked via `prerequisite_id`. Completing step N\n * triggers assignment of step N+1 (if it exists and hasn't been assigned yet).\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\ninterface NextStep {\n  id: string;\n  threshold: number;\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/**\n * Find the next onboarding challenge whose `prerequisite_id` matches\n * the just-completed challenge.\n */\nexport async function getNextOnboardingStep(\n  db: Db,\n  completedChallengeId: string,\n): Promise<NextStep | null> {\n  const rows = await db.rawSql<NextStep[]>`\n    SELECT id, threshold\n    FROM challenges\n    WHERE prerequisite_id = ${completedChallengeId}\n      AND is_active = true\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/**\n * Create a challenge assignment. Returns false if a row for this\n * (user_id, challenge_id, period_key) already exists (idempotency via UNIQUE).\n */\nexport async function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n// ---------------------------------------------------------------------------\n// Main\n// ---------------------------------------------------------------------------\n\n/**\n * After an onboarding assignment is completed, check if there's a next step\n * in the chain and auto-assign it.\n *\n * Called from game-settled handler within the completion transaction.\n */\nexport async function advanceOnboardingChain(\n  db: Db,\n  userId: string,\n  completedChallengeId: string,\n  periodKey: string,\n): Promise<void> {\n  // Only process onboarding assignments\n  if (periodKey !== \"onboarding\") return;\n\n  const nextStep = await getNextOnboardingStep(db, completedChallengeId);\n  if (!nextStep) {\n    logger.debug(\"onboarding: no next step (chain complete)\", {\n      userId,\n      completedChallengeId,\n    });\n    return;\n  }\n\n  const created = await createAssignment(\n    db,\n    userId,\n    nextStep.id,\n    \"onboarding\",\n    nextStep.threshold,\n    null,\n  );\n\n  if (created) {\n    logger.info(\"onboarding: next step assigned\", {\n      userId,\n      completedChallengeId,\n      nextChallengeId: nextStep.id,\n    });\n  } else {\n    logger.debug(\"onboarding: next step already assigned (idempotent)\", {\n      userId,\n      nextChallengeId: nextStep.id,\n    });\n  }\n}\n","structuredPatch":[],"originalFile":null}}
