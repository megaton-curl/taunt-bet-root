{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015KgoY9xZSrbDBannrCSjg6","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n31\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n32\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n33\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n34\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n35\timport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\n36\timport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\n37\timport { createGameSettledHandler } from \"../queue/handlers/game-settled.js\";\n38\t\n39\t// ---------------------------------------------------------------------------\n40\t// Constants\n41\t// ---------------------------------------------------------------------------\n42\t\n43\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n44\t\n45\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n46\tfunction makeSql() {\n47\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n48\t  // Dev container: postgres listens on Unix socket only\n49\t  return postgres({\n50\t    host: \"/var/run/postgresql\",\n51\t    user: \"vscode\",\n52\t    database: \"rng_utopia_dev\",\n53\t  });\n54\t}\n55\t\n56\tconst AMOUNT_LAMPORTS = 5_000_000;\n57\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n58\tconst SIDE_HEADS = 0;\n59\tconst PHASE_LOCKED = 1;\n60\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n61\t\n62\t// ---------------------------------------------------------------------------\n63\t// JWT helper\n64\t// ---------------------------------------------------------------------------\n65\t\n66\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n67\t  const now = Math.floor(Date.now() / 1000);\n68\t  return new SignJWT({ wallet })\n69\t    .setProtectedHeader({ alg: \"HS256\" })\n70\t    .setSubject(userId)\n71\t    .setIssuedAt(now)\n72\t    .setExpirationTime(now + 3600)\n73\t    .sign(JWT_SECRET);\n74\t}\n75\t\n76\tfunction userIdFromWallet(wallet: string) {\n77\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n78\t}\n79\t\n80\t// ---------------------------------------------------------------------------"}]},"parent_tool_use_id":"toolu_011TgKHX9MnRxSyLdxvnPaLH","session_id":"a8262916-ffcb-4b28-90e1-2b18f6c84ba5","uuid":"16fb5edc-c721-4423-b6ed-08930bcd6060","timestamp":"2026-04-03T20:34:04.209Z"}
