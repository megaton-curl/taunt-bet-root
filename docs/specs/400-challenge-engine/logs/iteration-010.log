{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XuF1GF9PwpDXdseXe88tXT","type":"tool_result","content":"1\t/**\n2\t * Completion bonus check — runs after a challenge assignment is marked completed.\n3\t *\n4\t * When a player completes enough challenges in a period (e.g., 3 daily challenges),\n5\t * they earn a bonus reward (e.g., a crate drop). Idempotent via UNIQUE(user_id, bonus_id, period_key).\n6\t */\n7\t\n8\timport type { Db } from \"../../db.js\";\n9\timport { logger } from \"../../logger.js\";\n10\timport { emitEvent } from \"../emit-event.js\";\n11\timport { EventTypes } from \"../event-types.js\";\n12\t\n13\t// ---------------------------------------------------------------------------\n14\t// DB helpers\n15\t// ---------------------------------------------------------------------------\n16\t\n17\tinterface CompletionBonus {\n18\t  id: string;\n19\t  campaign_id: string;\n20\t  required_count: number;\n21\t  reward_type: string;\n22\t  reward_amount: number | null;\n23\t}\n24\t\n25\t/**\n26\t * Get active completion bonuses for a campaign.\n27\t */\n28\texport async function getCompletionBonuses(\n29\t  db: Db,\n30\t  campaignId: string,\n31\t): Promise<CompletionBonus[]> {\n32\t  return db.rawSql<CompletionBonus[]>`\n33\t    SELECT id, campaign_id, required_count, reward_type, reward_amount\n34\t    FROM completion_bonuses\n35\t    WHERE campaign_id = ${campaignId}\n36\t      AND is_active = true\n37\t  `;\n38\t}\n39\t\n40\t/**\n41\t * Count completed assignments for a user in a given period and campaign.\n42\t */\n43\texport async function countCompletedAssignments(\n44\t  db: Db,\n45\t  userId: string,\n46\t  periodKey: string,\n47\t  campaignId: string,\n48\t): Promise<number> {\n49\t  const rows = await db.rawSql<{ count: string }[]>`\n50\t    SELECT COUNT(*)::TEXT AS count\n51\t    FROM challenge_assignments\n52\t    WHERE user_id = ${userId}\n53\t      AND period_key = ${periodKey}\n54\t      AND status = 'completed'\n55\t      AND challenge_id IN (SELECT id FROM challenges WHERE campaign_id = ${campaignId})\n56\t  `;\n57\t  return Number(rows[0]!.count);\n58\t}\n59\t\n60\t/**\n61\t * Insert a bonus completion row. Returns false if a row for this\n62\t * (user_id, bonus_id, period_key) already exists (idempotency guard).\n63\t */\n64\texport async function insertBonusCompletion(\n65\t  db: Db,\n66\t  userId: string,\n67\t  bonusId: string,\n68\t  periodKey: string,\n69\t): Promise<boolean> {\n70\t  const rows = await db.rawSql<{ id: string }[]>`\n71\t    INSERT INTO bonus_completions (user_id, bonus_id, period_key)\n72\t    VALUES (${userId}, ${bonusId}, ${periodKey})\n73\t    ON CONFLICT (user_id, bonus_id, period_key) DO NOTHING\n74\t    RETURNING id\n75\t  `;\n76\t  return rows.length > 0;\n77\t}\n78\t\n79\t// ---------------------------------------------------------------------------\n80\t// Main check\n81\t// ---------------------------------------------------------------------------\n82\t\n83\t/**\n84\t * Check and award completion bonuses after an assignment is completed.\n85\t *\n86\t * Called from the game.settled handler within the completion transaction.\n87\t * For each active bonus in the campaign: count completed assignments,\n88\t * if count >= required_count and no existing bonus_completion, insert row\n89\t * and emit reward intent.\n90\t */\n91\texport async function checkCompletionBonus(\n92\t  db: Db,\n93\t  userId: string,\n94\t  wallet: string,\n95\t  periodKey: string,\n96\t  campaignId: string,\n97\t): Promise<void> {\n98\t  const bonuses = await getCompletionBonuses(db, campaignId);\n99\t\n100\t  for (const bonus of bonuses) {\n101\t    const completedCount = await countCompletedAssignments(\n102\t      db,\n103\t      userId,\n104\t      periodKey,\n105\t      campaignId,\n106\t    );\n107\t\n108\t    if (completedCount < bonus.required_count) continue;\n109\t\n110\t    const inserted = await insertBonusCompletion(\n111\t      db,\n112\t      userId,\n113\t      bonus.id,\n114\t      periodKey,\n115\t    );\n116\t    if (!inserted) {\n117\t      // Already awarded — idempotency guard\n118\t      continue;\n119\t    }\n120\t\n121\t    // Emit reward intent based on bonus reward_type\n122\t    if (bonus.reward_type === \"points\" && bonus.reward_amount) {\n123\t      await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n124\t        userId,\n125\t        wallet,\n126\t        sourceType: \"bonus_completed\",\n127\t        sourceId: `bonus-${bonus.id}-${periodKey}`,\n128\t        amount: bonus.reward_amount.toString(),\n129\t      });\n130\t    } else if (bonus.reward_type === \"crate\") {\n131\t      await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n132\t        userId,\n133\t        wallet,\n134\t        triggerType: \"bonus_completed\",\n135\t        triggerId: `bonus-${bonus.id}-${periodKey}`,\n136\t      });\n137\t    }\n138\t\n139\t    logger.info(\"completion-bonus: bonus awarded\", {\n140\t      userId,\n141\t      bonusId: bonus.id,\n142\t      periodKey,\n143\t      campaignId,\n144\t      rewardType: bonus.reward_type,\n145\t    });\n146\t  }\n147\t}\n148\t"}]},"parent_tool_use_id":"toolu_012t83rEKUYNg6927DoaKqhs","session_id":"a8262916-ffcb-4b28-90e1-2b18f6c84ba5","uuid":"0bc4723c-b67c-4aae-a122-3316e629b4ab","timestamp":"2026-04-03T20:33:57.216Z"}
