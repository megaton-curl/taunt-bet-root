{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018LcUaRQZ8Wq3uSqbD6WsnR","type":"tool_result","content":"1985\t  it(\"game.settled handler: completion bonus awarded when all daily challenges completed\", async () => {\n1986\t    const handler = createGameSettledHandler({ db });\n1987\t    const userId = \"usr_gs_bonus1\";\n1988\t    const wallet = \"GsBonusWallet11111111111111111111111111\";\n1989\t    const periodKey = \"daily:2026-04-03\";\n1990\t\n1991\t    // Look up the daily campaign and its completion bonus\n1992\t    const campaigns = await rawSql<{ id: string }[]>`\n1993\t      SELECT id FROM campaigns WHERE name = 'Daily Challenges' LIMIT 1\n1994\t    `;\n1995\t    const campaignId = campaigns[0]!.id;\n1996\t\n1997\t    // Get 3 daily challenges (the bonus requires 3 completed)\n1998\t    const dailyChallenges = await rawSql<{ id: string; action: string; scope: string }[]>`\n1999\t      SELECT id, action, scope FROM challenges\n2000\t      WHERE campaign_id = ${campaignId} AND is_active = true\n2001\t      ORDER BY sort_order ASC\n2002\t      LIMIT 3\n2003\t    `;\n2004\t    expect(dailyChallenges.length).toBe(3);\n2005\t\n2006\t    // Create 3 assignments — first two already completed, third active with target=1\n2007\t    await rawSql`\n2008\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, progress, status, completed_at)\n2009\t      VALUES\n2010\t        (${userId}, ${dailyChallenges[0]!.id}, ${periodKey}, 1, 1, 'completed', now()),\n2011\t        (${userId}, ${dailyChallenges[1]!.id}, ${periodKey}, 1, 1, 'completed', now()),\n2012\t        (${userId}, ${dailyChallenges[2]!.id}, ${periodKey}, 1, 0, 'active', NULL)\n2013\t    `;\n2014\t\n2015\t    // Determine what game event will complete the 3rd challenge\n2016\t    const thirdChallenge = dailyChallenges[2]!;\n2017\t    const isWinner = thirdChallenge.action === \"game_won\" ? true : true;\n2018\t    const game = thirdChallenge.scope === \"any\" ? \"coinflip\" : thirdChallenge.scope;\n2019\t\n2020\t    // Settle a game that completes the 3rd daily challenge\n2021\t    await handler({\n2022\t      roundId: \"test-gs-bonus-001\",\n2023\t      roundPda: \"GsBonusPda1111111111111111111111111111111\",\n2024\t      game,\n2025\t      players: [\n2026\t        {\n2027\t          userId,\n2028\t          wallet,\n2029\t          amountLamports: \"5000000\",\n2030\t          isWinner,\n2031\t          payoutLamports: \"9500000\",\n2032\t          isCreator: true,\n2033\t        },\n2034\t      ],\n2035\t      feeLamports: \"500000\",\n2036\t      settledAt: new Date().toISOString(),\n2037\t    });\n2038\t\n2039\t    // Verify 3rd assignment is now completed\n2040\t    const assignments = await rawSql<{ status: string; challenge_id: string }[]>`\n2041\t      SELECT status, challenge_id FROM challenge_assignments\n2042\t      WHERE user_id = ${userId} AND period_key = ${periodKey}\n2043\t      ORDER BY id\n2044\t    `;\n2045\t    expect(assignments[2]!.status).toBe(\"completed\");\n2046\t\n2047\t    // Verify bonus_completions row created\n2048\t    const bonuses = await rawSql<{ user_id: string; bonus_id: string; period_key: string }[]>`\n2049\t      SELECT user_id, bonus_id, period_key FROM bonus_completions\n2050\t      WHERE user_id = ${userId}\n2051\t    `;\n2052\t    expect(bonuses.length).toBe(1);\n2053\t    expect(bonuses[0]!.period_key).toBe(periodKey);\n2054\t\n2055\t    // Verify bonus reward event emitted (crate.drop with trigger_type='bonus_completed')\n2056\t    const events = await rawSql<{ event_type: string; payload: Record<string, unknown> }[]>`\n2057\t      SELECT event_type, payload FROM event_queue ORDER BY id\n2058\t    `;\n2059\t    const bonusRewards = events.filter(\n2060\t      (e) =>\n2061\t        e.event_type === \"crate.drop\" &&\n2062\t        (e.payload as Record<string, unknown>).triggerType === \"bonus_completed\",\n2063\t    );\n2064\t    expect(bonusRewards.length).toBe(1);\n2065\t    expect((bonusRewards[0]!.payload as Record<string, unknown>).userId).toBe(userId);\n2066\t  });\n2067\t\n2068\t  it(\"game.settled handler: completion bonus is idempotent — no duplicate on re-trigger\", async () => {\n2069\t    const userId = \"usr_gs_bonus_dup\";\n2070\t    const wallet = \"GsBonusDupWallet1111111111111111111111\";\n2071\t    const periodKey = \"daily:2026-04-03\";\n2072\t\n2073\t    const campaigns = await rawSql<{ id: string }[]>`\n2074\t      SELECT id FROM campaigns WHERE name = 'Daily Challenges' LIMIT 1"}]},"parent_tool_use_id":"toolu_011TgKHX9MnRxSyLdxvnPaLH","session_id":"a8262916-ffcb-4b28-90e1-2b18f6c84ba5","uuid":"a738949e-91d9-4130-b171-02db1ceb64e2","timestamp":"2026-04-03T20:34:09.611Z"}
