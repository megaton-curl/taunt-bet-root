{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T5vaBdzE1t6XxUymAJGpki","type":"tool_result","content":"160\t      };\n161\t    }> = [];\n162\t\n163\t    for (const [key, acc] of this._accounts) {\n164\t      if (!acc.owner.equals(programId)) continue;\n165\t\n166\t      let matches = true;\n167\t      if (config?.filters) {\n168\t        for (const filter of config.filters) {\n169\t          if (\"dataSize\" in filter) {\n170\t            if (acc.data.length !== filter.dataSize) {\n171\t              matches = false;\n172\t              break;\n173\t            }\n174\t          }\n175\t          if (\"memcmp\" in filter) {\n176\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n177\t            const actual = acc.data.subarray(\n178\t              filter.memcmp.offset,\n179\t              filter.memcmp.offset + expected.length,\n180\t            );\n181\t            if (Buffer.compare(actual, expected) !== 0) {\n182\t              matches = false;\n183\t              break;\n184\t            }\n185\t          }\n186\t        }\n187\t      }\n188\t\n189\t      if (matches) {\n190\t        results.push({\n191\t          pubkey: new PublicKey(key),\n192\t          account: { ...acc, rentEpoch: 0 },\n193\t        });\n194\t      }\n195\t    }\n196\t    return results;\n197\t  }\n198\t\n199\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n200\t    this.lastRawTx = Buffer.from(rawTx);\n201\t    // Return a deterministic fake signature\n202\t    return bs58.encode(Buffer.alloc(64, 0x01));\n203\t  }\n204\t\n205\t  async confirmTransaction() {\n206\t    return { value: { err: null }, context: { slot: this._slot } };\n207\t  }\n208\t\n209\t  async getBlockTime(_slot: number) {\n210\t    return Math.floor(Date.now() / 1000);\n211\t  }\n212\t\n213\t  async getBalance() {\n214\t    return 2 * LAMPORTS_PER_SOL;\n215\t  }\n216\t}\n217\t\n218\t// ---------------------------------------------------------------------------\n219\t// Account data builders\n220\t// ---------------------------------------------------------------------------\n221\t\n222\tasync function buildMatchAccountData(params: {\n223\t  creator: PublicKey;\n224\t  opponent: PublicKey;\n225\t  server: PublicKey;\n226\t  entryAmount: bigint;\n227\t  creatorSide: number;\n228\t  phase: number;\n229\t  commitment: Buffer;\n230\t  algorithmVer: number;\n231\t  targetSlot: bigint;\n232\t  resolveDeadline: bigint;\n233\t  matchId: Buffer;\n234\t}): Promise<Buffer> {\n235\t  return encodeCoinflipMatch({\n236\t    creator: params.creator,\n237\t    opponent: params.opponent,\n238\t    server: params.server,\n239\t    entryAmount: params.entryAmount,\n240\t    creatorSide: params.creatorSide,\n241\t    phase: params.phase,\n242\t    commitment: [...params.commitment],\n243\t    algorithmVer: params.algorithmVer,\n244\t    targetSlot: params.targetSlot,\n245\t    resolveDeadline: params.resolveDeadline,\n246\t    resultHash: new Array(32).fill(0),\n247\t    result: 0,\n248\t    winner: PublicKey.default,\n249\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n250\t    matchId: [...params.matchId],\n251\t    bump: 0,\n252\t  });\n253\t}\n254\t\n255\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n256\t  return encodeCoinflipConfig({\n257\t    authority: PublicKey.default,\n258\t    treasury,\n259\t    paused: false,\n260\t    bump: 0,\n261\t  });\n262\t}\n263\t\n264\t/**\n265\t * Build PlatformConfig account data matching the on-chain layout.\n266\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n267\t */\n268\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n269\t  const buf = Buffer.alloc(74);\n270\t  // discriminator (8 bytes) — zeroed is fine for mock\n271\t  // authority at offset 8 — use default\n272\t  PublicKey.default.toBuffer().copy(buf, 8);\n273\t  // treasury at offset 40\n274\t  treasury.toBuffer().copy(buf, 40);\n275\t  // fee_bps at offset 72\n276\t  buf.writeUInt16LE(feeBps, 72);\n277\t  return buf;\n278\t}\n279\t\n280\t// ---------------------------------------------------------------------------\n281\t// Test suite\n282\t// ---------------------------------------------------------------------------\n283\t\n284\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n285\t  let db: Db;\n286\t  let rawSql: ReturnType<typeof postgres>;\n287\t  let mockConn: MockConnection;\n288\t  let app: Hono;\n289\t\n290\t  const serverKeypair = Keypair.generate();\n291\t  const creatorKeypair = Keypair.generate();\n292\t  const opponentKeypair = Keypair.generate();\n293\t  const treasuryKeypair = Keypair.generate();\n294\t  const entropyKeypair = Keypair.generate();\n295\t  const entropyAccount = entropyKeypair.publicKey;\n296\t\n297\t  const entropyData = Buffer.alloc(32);\n298\t  entropyData[0] = 0xab;\n299\t  entropyData[1] = 0xcd;\n300\t  entropyData[15] = 0x42;\n301\t\n302\t  beforeAll(async () => {\n303\t    rawSql = makeSql();\n304\t    await rawSql`\n305\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n306\t    `;\n307\t    await rawSql`\n308\t      CREATE TABLE referral_codes (\n309\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n310\t        user_id TEXT NOT NULL UNIQUE,\n311\t        wallet TEXT NOT NULL UNIQUE,\n312\t        code TEXT NOT NULL UNIQUE,\n313\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n314\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n315\t      )\n316\t    `;\n317\t    await rawSql`\n318\t      CREATE TABLE referral_links (\n319\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n320\t        referrer_user_id TEXT NOT NULL,\n321\t        referee_user_id TEXT NOT NULL UNIQUE,\n322\t        referrer_wallet TEXT NOT NULL,\n323\t        referee_wallet TEXT NOT NULL,\n324\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n325\t      )\n326\t    `;\n327\t    await rawSql`\n328\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n329\t    `;\n330\t    await rawSql`\n331\t      CREATE TABLE referral_earnings (\n332\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n333\t        referrer_user_id TEXT NOT NULL,\n334\t        referee_user_id TEXT NOT NULL,\n335\t        referrer_wallet TEXT NOT NULL,\n336\t        referee_wallet TEXT NOT NULL,\n337\t        round_id TEXT NOT NULL,\n338\t        game_type TEXT NOT NULL,\n339\t        wager_lamports BIGINT NOT NULL,\n340\t        fee_lamports BIGINT NOT NULL,\n341\t        referrer_earned_lamports BIGINT NOT NULL,\n342\t        referrer_rate_bps INTEGER NOT NULL,\n343\t        referee_rebate_lamports BIGINT NOT NULL,\n344\t        referee_rebate_rate_bps INTEGER NOT NULL,\n345\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n346\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n347\t      )\n348\t    `;\n349\t    await rawSql`\n350\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n351\t    `;\n352\t    await rawSql`\n353\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n354\t    `;\n355\t    await rawSql`\n356\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n357\t    `;\n358\t    await rawSql`\n359\t      CREATE TABLE referral_claims ("}]},"parent_tool_use_id":"toolu_011TgKHX9MnRxSyLdxvnPaLH","session_id":"a8262916-ffcb-4b28-90e1-2b18f6c84ba5","uuid":"ea77c8bf-f1f0-41c8-8694-d9a9da94447d","timestamp":"2026-04-03T20:34:05.918Z"}
