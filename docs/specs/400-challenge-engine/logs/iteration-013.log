{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FYfSBzCxCA8rT3GDfX7iFC","type":"tool_result","content":"1\t/**\n2\t * Points & Crate routes — player-facing endpoints for points balance,\n3\t * points history, and crate drop history.\n4\t *\n5\t * GET /mine           — current point balance + lifetime earned\n6\t * GET /mine/history   — paginated point_grants ledger\n7\t * GET /crates/mine    — paginated crate_drops history\n8\t */\n9\t\n10\timport { Hono } from \"hono\";\n11\timport type { AppEnv } from \"../hono-env.js\";\n12\timport type { Db } from \"../db.js\";\n13\timport { logger } from \"../logger.js\";\n14\t\n15\t// ---------------------------------------------------------------------------\n16\t// Types\n17\t// ---------------------------------------------------------------------------\n18\t\n19\texport interface PointsRoutesDeps {\n20\t  db: Db;\n21\t}\n22\t\n23\t// ---------------------------------------------------------------------------\n24\t// Helpers\n25\t// ---------------------------------------------------------------------------\n26\t\n27\t/** Parse and clamp a numeric query param. Returns `defaultVal` if missing/invalid. */\n28\tfunction parseIntParam(raw: string | undefined, defaultVal: number, max: number): number {\n29\t  if (!raw) return defaultVal;\n30\t  const parsed = parseInt(raw, 10);\n31\t  if (isNaN(parsed) || parsed < 1) return defaultVal;\n32\t  return Math.min(parsed, max);\n33\t}\n34\t\n35\t// ---------------------------------------------------------------------------\n36\t// Route factory\n37\t// ---------------------------------------------------------------------------\n38\t\n39\texport function createPointsRoutes(deps: PointsRoutesDeps) {\n40\t  const { db } = deps;\n41\t  const app = new Hono<AppEnv>();\n42\t\n43\t  // GET /mine — point balance\n44\t  app.get(\"/mine\", async (c) => {\n45\t    const userId = c.get(\"userId\");\n46\t    if (!userId) {\n47\t      return c.json({ error: \"Authentication required\" }, 401);\n48\t    }\n49\t\n50\t    try {\n51\t      const rows = await db.rawSql<{ balance: string; lifetime_earned: string }[]>`\n52\t        SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n53\t      `;\n54\t      if (rows.length === 0) {\n55\t        return c.json({ balance: 0, lifetimeEarned: 0 });\n56\t      }\n57\t      return c.json({\n58\t        balance: Number(rows[0]!.balance),\n59\t        lifetimeEarned: Number(rows[0]!.lifetime_earned),\n60\t      });\n61\t    } catch (err) {\n62\t      logger.error(\"GET /points/mine failed\", {\n63\t        userId,\n64\t        error: err instanceof Error ? err.message : \"Unknown error\",\n65\t      });\n66\t      return c.json({ error: \"Failed to fetch points\" }, 500);\n67\t    }\n68\t  });\n69\t\n70\t  // GET /mine/history — paginated point_grants\n71\t  app.get(\"/mine/history\", async (c) => {\n72\t    const userId = c.get(\"userId\");\n73\t    if (!userId) {\n74\t      return c.json({ error: \"Authentication required\" }, 401);\n75\t    }\n76\t\n77\t    const cursor = c.req.query(\"cursor\") || undefined;\n78\t    const limit = parseIntParam(c.req.query(\"limit\"), 20, 50);\n79\t\n80\t    try {\n81\t      const cursorFilter = cursor\n82\t        ? db.rawSql`AND id < ${cursor}`\n83\t        : db.rawSql``;\n84\t\n85\t      const rows = await db.rawSql<\n86\t        {\n87\t          id: string;\n88\t          source_type: string;\n89\t          source_id: string;\n90\t          amount: string;\n91\t          metadata: Record<string, unknown>;\n92\t          created_at: Date;\n93\t        }[]\n94\t      >`\n95\t        SELECT id, source_type, source_id, amount, metadata, created_at\n96\t        FROM point_grants\n97\t        WHERE user_id = ${userId} ${cursorFilter}\n98\t        ORDER BY id DESC\n99\t        LIMIT ${limit}\n100\t      `;\n101\t\n102\t      const items = rows.map((r: { id: string; source_type: string; source_id: string; amount: string; metadata: Record<string, unknown>; created_at: Date }) => ({\n103\t        id: Number(r.id),\n104\t        sourceType: r.source_type,\n105\t        sourceId: r.source_id,\n106\t        amount: Number(r.amount),\n107\t        metadata: r.metadata,\n108\t        createdAt: r.created_at.toISOString(),\n109\t      }));\n110\t\n111\t      const nextCursor =\n112\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n113\t\n114\t      return c.json({ items, nextCursor });\n115\t    } catch (err) {\n116\t      logger.error(\"GET /points/mine/history failed\", {\n117\t        userId,\n118\t        error: err instanceof Error ? err.message : \"Unknown error\",\n119\t      });\n120\t      return c.json({ error: \"Failed to fetch points history\" }, 500);\n121\t    }\n122\t  });\n123\t\n124\t  return app;\n125\t}\n126\t\n127\t// ---------------------------------------------------------------------------\n128\t// Crate routes factory\n129\t// ---------------------------------------------------------------------------\n130\t\n131\texport function createCrateRoutes(deps: PointsRoutesDeps) {\n132\t  const { db } = deps;\n133\t  const app = new Hono<AppEnv>();\n134\t\n135\t  // GET /mine — paginated crate_drops\n136\t  app.get(\"/mine\", async (c) => {\n137\t    const userId = c.get(\"userId\");\n138\t    if (!userId) {\n139\t      return c.json({ error: \"Authentication required\" }, 401);\n140\t    }\n141\t\n142\t    const cursor = c.req.query(\"cursor\") || undefined;\n143\t    const limit = parseIntParam(c.req.query(\"limit\"), 20, 50);\n144\t\n145\t    try {\n146\t      const cursorFilter = cursor\n147\t        ? db.rawSql`AND id < ${cursor}`\n148\t        : db.rawSql``;\n149\t\n150\t      const rows = await db.rawSql<\n151\t        {\n152\t          id: string;\n153\t          crate_type: string;\n154\t          contents_amount: string;\n155\t          status: string;\n156\t          created_at: Date;\n157\t          granted_at: Date | null;\n158\t        }[]\n159\t      >`\n160\t        SELECT id, crate_type, contents_amount, status, created_at, granted_at\n161\t        FROM crate_drops\n162\t        WHERE user_id = ${userId} ${cursorFilter}\n163\t        ORDER BY id DESC\n164\t        LIMIT ${limit}\n165\t      `;\n166\t\n167\t      const items = rows.map((r: { id: string; crate_type: string; contents_amount: string; status: string; created_at: Date; granted_at: Date | null }) => ({\n168\t        id: Number(r.id),\n169\t        crateType: r.crate_type,\n170\t        contentsAmount: r.contents_amount,\n171\t        status: r.status,\n172\t        createdAt: r.created_at.toISOString(),\n173\t        grantedAt: r.granted_at ? r.granted_at.toISOString() : null,\n174\t      }));\n175\t\n176\t      const nextCursor =\n177\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n178\t\n179\t      return c.json({ items, nextCursor });\n180\t    } catch (err) {\n181\t      logger.error(\"GET /crates/mine failed\", {\n182\t        userId,\n183\t        error: err instanceof Error ? err.message : \"Unknown error\",\n184\t      });\n185\t      return c.json({ error: \"Failed to fetch crate history\" }, 500);\n186\t    }\n187\t  });\n188\t\n189\t  return app;\n190\t}\n191\t"}]},"parent_tool_use_id":null,"session_id":"8b2f7dd7-97bd-434b-b775-f78d70040f2b","uuid":"7bfdc8dd-22f9-41d5-8810-2ba69d28aa66","timestamp":"2026-04-03T21:04:35.367Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/routes/points.ts","content":"/**\n * Points & Crate routes — player-facing endpoints for points balance,\n * points history, and crate drop history.\n *\n * GET /mine           — current point balance + lifetime earned\n * GET /mine/history   — paginated point_grants ledger\n * GET /crates/mine    — paginated crate_drops history\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface PointsRoutesDeps {\n  db: Db;\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\n/** Parse and clamp a numeric query param. Returns `defaultVal` if missing/invalid. */\nfunction parseIntParam(raw: string | undefined, defaultVal: number, max: number): number {\n  if (!raw) return defaultVal;\n  const parsed = parseInt(raw, 10);\n  if (isNaN(parsed) || parsed < 1) return defaultVal;\n  return Math.min(parsed, max);\n}\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createPointsRoutes(deps: PointsRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  // GET /mine — point balance\n  app.get(\"/mine\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const rows = await db.rawSql<{ balance: string; lifetime_earned: string }[]>`\n        SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n      `;\n      if (rows.length === 0) {\n        return c.json({ balance: 0, lifetimeEarned: 0 });\n      }\n      return c.json({\n        balance: Number(rows[0]!.balance),\n        lifetimeEarned: Number(rows[0]!.lifetime_earned),\n      });\n    } catch (err) {\n      logger.error(\"GET /points/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch points\" }, 500);\n    }\n  });\n\n  // GET /mine/history — paginated point_grants\n  app.get(\"/mine/history\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limit = parseIntParam(c.req.query(\"limit\"), 20, 50);\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          source_type: string;\n          source_id: string;\n          amount: string;\n          metadata: Record<string, unknown>;\n          created_at: Date;\n        }[]\n      >`\n        SELECT id, source_type, source_id, amount, metadata, created_at\n        FROM point_grants\n        WHERE user_id = ${userId} ${cursorFilter}\n        ORDER BY id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; source_type: string; source_id: string; amount: string; metadata: Record<string, unknown>; created_at: Date }) => ({\n        id: Number(r.id),\n        sourceType: r.source_type,\n        sourceId: r.source_id,\n        amount: Number(r.amount),\n        metadata: r.metadata,\n        createdAt: r.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return c.json({ items, nextCursor });\n    } catch (err) {\n      logger.error(\"GET /points/mine/history failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch points history\" }, 500);\n    }\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// Crate routes factory\n// ---------------------------------------------------------------------------\n\nexport function createCrateRoutes(deps: PointsRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  // GET /mine — paginated crate_drops\n  app.get(\"/mine\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const cursor = c.req.query(\"cursor\") || undefined;\n    const limit = parseIntParam(c.req.query(\"limit\"), 20, 50);\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          crate_type: string;\n          contents_amount: string;\n          status: string;\n          created_at: Date;\n          granted_at: Date | null;\n        }[]\n      >`\n        SELECT id, crate_type, contents_amount, status, created_at, granted_at\n        FROM crate_drops\n        WHERE user_id = ${userId} ${cursorFilter}\n        ORDER BY id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; crate_type: string; contents_amount: string; status: string; created_at: Date; granted_at: Date | null }) => ({\n        id: Number(r.id),\n        crateType: r.crate_type,\n        contentsAmount: r.contents_amount,\n        status: r.status,\n        createdAt: r.created_at.toISOString(),\n        grantedAt: r.granted_at ? r.granted_at.toISOString() : null,\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return c.json({ items, nextCursor });\n    } catch (err) {\n      logger.error(\"GET /crates/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch crate history\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":191,"startLine":1,"totalLines":191}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018jjvPiGBLmQBtE9q6S7BoL","type":"tool_result","content":"1\t/**\n2\t * Challenge routes — player-facing challenge/quest endpoints.\n3\t *\n4\t * GET /mine — returns active daily, weekly, and onboarding challenges\n5\t * with lazy assignment on first call per period.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { AppEnv } from \"../hono-env.js\";\n10\timport type { Db } from \"../db.js\";\n11\timport { logger } from \"../logger.js\";\n12\timport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n13\t\n14\t// ---------------------------------------------------------------------------\n15\t// Types\n16\t// ---------------------------------------------------------------------------\n17\t\n18\texport interface ChallengeRoutesDeps {\n19\t  db: Db;\n20\t}\n21\t\n22\tinterface ChallengeRow {\n23\t  id: string;\n24\t  campaign_id: string;\n25\t  title: string;\n26\t  description: string;\n27\t  action: string;\n28\t  scope: string;\n29\t  condition: string;\n30\t  threshold: number;\n31\t  reward_type: string;\n32\t  reward_amount: number | null;\n33\t  sort_order: number;\n34\t  prerequisite_id: string | null;\n35\t}\n36\t\n37\tinterface AssignmentRow {\n38\t  id: string;\n39\t  challenge_id: string;\n40\t  period_key: string;\n41\t  status: string;\n42\t  progress: number;\n43\t  target: number;\n44\t  expires_at: string | null;\n45\t  completed_at: string | null;\n46\t  title: string;\n47\t  description: string;\n48\t  reward_type: string;\n49\t  reward_amount: number | null;\n50\t  campaign_type: string;\n51\t}\n52\t\n53\tinterface CompletionBonusRow {\n54\t  id: string;\n55\t  title: string;\n56\t  required_count: number;\n57\t  reward_type: string;\n58\t  reward_amount: number | null;\n59\t}\n60\t\n61\tinterface BonusCompletionRow {\n62\t  id: string;\n63\t}\n64\t\n65\t// ---------------------------------------------------------------------------\n66\t// Period key helpers\n67\t// ---------------------------------------------------------------------------\n68\t\n69\t/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\n70\texport function dailyPeriodKey(now?: Date): string {\n71\t  const d = now ?? new Date();\n72\t  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n73\t}\n74\t\n75\t/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\n76\texport function weeklyPeriodKey(now?: Date): string {\n77\t  const d = now ?? new Date();\n78\t  // ISO week calculation\n79\t  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n80\t  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n81\t  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n82\t  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n83\t  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n84\t}\n85\t\n86\t/** Returns midnight UTC of the next day (daily reset). */\n87\texport function dailyResetsAt(now?: Date): string {\n88\t  const d = now ?? new Date();\n89\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n90\t  return next.toISOString();\n91\t}\n92\t\n93\t/** Returns midnight UTC of next Monday (weekly reset). */\n94\texport function weeklyResetsAt(now?: Date): string {\n95\t  const d = now ?? new Date();\n96\t  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n97\t  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n98\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n99\t  return next.toISOString();\n100\t}\n101\t\n102\t// ---------------------------------------------------------------------------\n103\t// DB helpers\n104\t// ---------------------------------------------------------------------------\n105\t\n106\t/** Expire stale assignments (expires_at < now AND status='active'). */\n107\tasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n108\t  await db.rawSql`\n109\t    UPDATE challenge_assignments\n110\t    SET status = 'expired'\n111\t    WHERE user_id = ${userId}\n112\t      AND status = 'active'\n113\t      AND expires_at IS NOT NULL\n114\t      AND expires_at < now()\n115\t  `;\n116\t}\n117\t\n118\t/** Get assignments for a user in a given period, joined with challenge metadata. */\n119\tasync function getAssignmentsForPeriod(\n120\t  db: Db,\n121\t  userId: string,\n122\t  periodKey: string,\n123\t): Promise<AssignmentRow[]> {\n124\t  return db.rawSql<AssignmentRow[]>`\n125\t    SELECT\n126\t      ca.id,\n127\t      ca.challenge_id,\n128\t      ca.period_key,\n129\t      ca.status,\n130\t      ca.progress,\n131\t      ca.target,\n132\t      ca.expires_at,\n133\t      ca.completed_at,\n134\t      c.title,\n135\t      c.description,\n136\t      c.reward_type,\n137\t      c.reward_amount,\n138\t      camp.campaign_type\n139\t    FROM challenge_assignments ca\n140\t    JOIN challenges c ON c.id = ca.challenge_id\n141\t    JOIN campaigns camp ON camp.id = c.campaign_id\n142\t    WHERE ca.user_id = ${userId}\n143\t      AND ca.period_key = ${periodKey}\n144\t    ORDER BY c.sort_order ASC\n145\t  `;\n146\t}\n147\t\n148\t/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\n149\tasync function getActiveChallengesBySort(\n150\t  db: Db,\n151\t  campaignId: string,\n152\t  limit: number,\n153\t): Promise<ChallengeRow[]> {\n154\t  return db.rawSql<ChallengeRow[]>`\n155\t    SELECT id, campaign_id, title, description, action, scope, condition,\n156\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n157\t    FROM challenges\n158\t    WHERE campaign_id = ${campaignId}\n159\t      AND is_active = true\n160\t    ORDER BY sort_order ASC\n161\t    LIMIT ${limit}\n162\t  `;\n163\t}\n164\t\n165\t/** Get the campaign ID for a given campaign type. */\n166\tasync function getCampaignByType(\n167\t  db: Db,\n168\t  campaignType: string,\n169\t): Promise<{ id: string } | null> {\n170\t  const rows = await db.rawSql<{ id: string }[]>`\n171\t    SELECT id FROM campaigns\n172\t    WHERE campaign_type = ${campaignType}\n173\t      AND is_active = true\n174\t    LIMIT 1\n175\t  `;\n176\t  return rows[0] ?? null;\n177\t}\n178\t\n179\t/** Get all onboarding assignments for a user (any status). */\n180\tasync function getOnboardingAssignments(\n181\t  db: Db,\n182\t  userId: string,\n183\t): Promise<AssignmentRow[]> {\n184\t  return db.rawSql<AssignmentRow[]>`\n185\t    SELECT\n186\t      ca.id,\n187\t      ca.challenge_id,\n188\t      ca.period_key,\n189\t      ca.status,\n190\t      ca.progress,\n191\t      ca.target,\n192\t      ca.expires_at,\n193\t      ca.completed_at,\n194\t      c.title,\n195\t      c.description,\n196\t      c.reward_type,\n197\t      c.reward_amount,\n198\t      camp.campaign_type\n199\t    FROM challenge_assignments ca\n200\t    JOIN challenges c ON c.id = ca.challenge_id\n201\t    JOIN campaigns camp ON camp.id = c.campaign_id\n202\t    WHERE ca.user_id = ${userId}\n203\t      AND ca.period_key = 'onboarding'\n204\t    ORDER BY c.sort_order ASC\n205\t  `;\n206\t}\n207\t\n208\t/** Get all onboarding challenge templates (ordered by chain). */\n209\tasync function getOnboardingChallenges(\n210\t  db: Db,\n211\t  campaignId: string,\n212\t): Promise<ChallengeRow[]> {\n213\t  return db.rawSql<ChallengeRow[]>`\n214\t    SELECT id, campaign_id, title, description, action, scope, condition,\n215\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n216\t    FROM challenges\n217\t    WHERE campaign_id = ${campaignId}\n218\t      AND is_active = true\n219\t    ORDER BY sort_order ASC\n220\t  `;\n221\t}\n222\t\n223\t/** Get completion bonuses for a campaign. */\n224\tasync function getCompletionBonusesForCampaign(\n225\t  db: Db,\n226\t  campaignId: string,\n227\t): Promise<CompletionBonusRow[]> {\n228\t  return db.rawSql<CompletionBonusRow[]>`\n229\t    SELECT id, title, required_count, reward_type, reward_amount\n230\t    FROM completion_bonuses\n231\t    WHERE campaign_id = ${campaignId}\n232\t      AND is_active = true\n233\t  `;\n234\t}\n235\t\n236\t/** Check if a bonus was completed for a user in a given period. */\n237\tasync function getBonusCompletion(\n238\t  db: Db,\n239\t  userId: string,\n240\t  bonusId: string,\n241\t  periodKey: string,\n242\t): Promise<BonusCompletionRow | null> {\n243\t  const rows = await db.rawSql<BonusCompletionRow[]>`\n244\t    SELECT id FROM bonus_completions\n245\t    WHERE user_id = ${userId}\n246\t      AND bonus_id = ${bonusId}\n247\t      AND period_key = ${periodKey}\n248\t    LIMIT 1\n249\t  `;\n250\t  return rows[0] ?? null;\n251\t}\n252\t\n253\t/** Count completed assignments for a user in a period+campaign. */\n254\tasync function countCompleted(\n255\t  db: Db,\n256\t  userId: string,\n257\t  periodKey: string,\n258\t  campaignId: string,\n259\t): Promise<number> {\n260\t  const rows = await db.rawSql<{ count: string }[]>`\n261\t    SELECT COUNT(*)::TEXT AS count\n262\t    FROM challenge_assignments ca\n263\t    JOIN challenges c ON c.id = ca.challenge_id\n264\t    WHERE ca.user_id = ${userId}\n265\t      AND ca.period_key = ${periodKey}\n266\t      AND ca.status = 'completed'\n267\t      AND c.campaign_id = ${campaignId}\n268\t  `;\n269\t  return Number(rows[0]!.count);\n270\t}\n271\t\n272\t/** Create an assignment (idempotent via UNIQUE). */\n273\tasync function createAssignment(\n274\t  db: Db,\n275\t  userId: string,\n276\t  challengeId: string,\n277\t  periodKey: string,\n278\t  target: number,\n279\t  expiresAt: string | null,\n280\t): Promise<void> {\n281\t  await db.rawSql`\n282\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n283\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n284\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n285\t  `;\n286\t}\n287\t\n288\t// ---------------------------------------------------------------------------\n289\t// Route factory\n290\t// ---------------------------------------------------------------------------\n291\t\n292\texport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n293\t  const { db } = deps;\n294\t  const app = new Hono<AppEnv>();\n295\t\n296\t  app.get(\"/mine\", async (c) => {\n297\t    const userId = c.get(\"userId\");\n298\t    if (!userId) {\n299\t      return c.json({ error: \"Authentication required\" }, 401);\n300\t    }\n301\t\n302\t    try {\n303\t      const now = new Date();\n304\t\n305\t      // 1. Expire stale assignments\n306\t      await expireStaleAssignments(db, userId);\n307\t\n308\t      // 2. Compute current period keys\n309\t      const dailyKey = dailyPeriodKey(now);\n310\t      const weeklyKey = weeklyPeriodKey(now);\n311\t\n312\t      // 3. Read config for challenge counts\n313\t      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n314\t      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n315\t      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n316\t      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n317\t\n318\t      // 4. Look up campaign IDs\n319\t      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n320\t        getCampaignByType(db, \"daily\"),\n321\t        getCampaignByType(db, \"weekly\"),\n322\t        getCampaignByType(db, \"onboarding\"),\n323\t      ]);\n324\t\n325\t      // 5. Lazy assignment — daily\n326\t      let dailyAssignments = dailyCampaign\n327\t        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n328\t        : [];\n329\t\n330\t      if (dailyAssignments.length === 0 && dailyCampaign) {\n331\t        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n332\t        const dailyExpires = dailyResetsAt(now);\n333\t        for (const t of templates) {\n334\t          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n335\t        }\n336\t        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n337\t      }\n338\t\n339\t      // 6. Lazy assignment — weekly\n340\t      let weeklyAssignments = weeklyCampaign\n341\t        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n342\t        : [];\n343\t\n344\t      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n345\t        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n346\t        const weeklyExpires = weeklyResetsAt(now);\n347\t        for (const t of templates) {\n348\t          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n349\t        }\n350\t        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n351\t      }\n352\t\n353\t      // 7. Lazy assignment — onboarding\n354\t      let onboardingAssignments = onboardingCampaign\n355\t        ? await getOnboardingAssignments(db, userId)\n356\t        : [];\n357\t\n358\t      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n359\t        // Assign first step (prerequisite_id IS NULL)\n360\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n361\t        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n362\t        if (firstStep) {\n363\t          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n364\t          onboardingAssignments = await getOnboardingAssignments(db, userId);\n365\t        }\n366\t      }\n367\t\n368\t      // 8. Build bonus status for daily\n369\t      let dailyBonus: object | null = null;\n370\t      if (dailyCampaign) {\n371\t        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n372\t        if (bonuses.length > 0) {\n373\t          const bonus = bonuses[0]!;\n374\t          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n375\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n376\t          dailyBonus = {\n377\t            title: bonus.title,\n378\t            required: bonus.required_count,\n379\t            completed: completedCount,\n380\t            status: bonusCompletion ? \"completed\" : \"active\",\n381\t            reward: {\n382\t              type: bonus.reward_type,\n383\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n384\t            },\n385\t          };\n386\t        }\n387\t      }\n388\t\n389\t      // 9. Build bonus status for weekly\n390\t      let weeklyBonus: object | null = null;\n391\t      if (weeklyCampaign) {\n392\t        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n393\t        if (bonuses.length > 0) {\n394\t          const bonus = bonuses[0]!;\n395\t          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n396\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n397\t          weeklyBonus = {\n398\t            title: bonus.title,\n399\t            required: bonus.required_count,\n400\t            completed: completedCount,\n401\t            status: bonusCompletion ? \"completed\" : \"active\",\n402\t            reward: {\n403\t              type: bonus.reward_type,\n404\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n405\t            },\n406\t          };\n407\t        }\n408\t      }\n409\t\n410\t      // 10. Build onboarding section\n411\t      let onboarding: object | null = null;\n412\t      if (onboardingCampaign) {\n413\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n414\t        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n415\t        const completedIds = new Set(\n416\t          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n417\t        );\n418\t        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n419\t\n420\t        if (allCompleted) {\n421\t          onboarding = null;\n422\t        } else {\n423\t          const steps = allSteps.map((step) => {\n424\t            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n425\t            const isAssigned = assignedIds.has(step.id);\n426\t            const locked = !isAssigned;\n427\t            return {\n428\t              id: Number(step.id),\n429\t              title: step.title,\n430\t              description: step.description,\n431\t              progress: assignment ? assignment.progress : 0,\n432\t              target: step.threshold,\n433\t              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n434\t              reward: {\n435\t                type: step.reward_type,\n436\t                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n437\t              },\n438\t              completedAt: assignment?.completed_at ?? null,\n439\t              locked,\n440\t            };\n441\t          });\n442\t          onboarding = { steps, completed: false };\n443\t        }\n444\t      }\n445\t\n446\t      // 11. Format response\n447\t      const formatChallenge = (a: AssignmentRow) => ({\n448\t        id: Number(a.id),\n449\t        title: a.title,\n450\t        description: a.description,\n451\t        progress: a.progress,\n452\t        target: a.target,\n453\t        status: a.status as \"active\" | \"completed\" | \"expired\",\n454\t        reward: {\n455\t          type: a.reward_type,\n456\t          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n457\t        },\n458\t        completedAt: a.completed_at ?? null,\n459\t      });\n460\t\n461\t      return c.json({\n462\t        daily: {\n463\t          challenges: dailyAssignments.map(formatChallenge),\n464\t          bonus: dailyBonus,\n465\t          resetsAt: dailyResetsAt(now),\n466\t        },\n467\t        weekly: {\n468\t          challenges: weeklyAssignments.map(formatChallenge),\n469\t          bonus: weeklyBonus,\n470\t          resetsAt: weeklyResetsAt(now),\n471\t        },\n472\t        onboarding,\n473\t      });\n474\t    } catch (err) {\n475\t      logger.error(\"challenges/mine failed\", {\n476\t        userId,\n477\t        error: err instanceof Error ? err.message : String(err),\n478\t      });\n479\t      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n480\t    }\n481\t  });\n482\t\n483\t  return app;\n484\t}\n485\t"}]},"parent_tool_use_id":null,"session_id":"8b2f7dd7-97bd-434b-b775-f78d70040f2b","uuid":"be5b1c35-6727-4f5d-aa7b-d5ad5bafab3d","timestamp":"2026-04-03T21:04:35.760Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/routes/challenges.ts","content":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine — returns active daily, weekly, and onboarding challenges\n * with lazy assignment on first call per period.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface ChallengeRoutesDeps {\n  db: Db;\n}\n\ninterface ChallengeRow {\n  id: string;\n  campaign_id: string;\n  title: string;\n  description: string;\n  action: string;\n  scope: string;\n  condition: string;\n  threshold: number;\n  reward_type: string;\n  reward_amount: number | null;\n  sort_order: number;\n  prerequisite_id: string | null;\n}\n\ninterface AssignmentRow {\n  id: string;\n  challenge_id: string;\n  period_key: string;\n  status: string;\n  progress: number;\n  target: number;\n  expires_at: string | null;\n  completed_at: string | null;\n  title: string;\n  description: string;\n  reward_type: string;\n  reward_amount: number | null;\n  campaign_type: string;\n}\n\ninterface CompletionBonusRow {\n  id: string;\n  title: string;\n  required_count: number;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\ninterface BonusCompletionRow {\n  id: string;\n}\n\n// ---------------------------------------------------------------------------\n// Period key helpers\n// ---------------------------------------------------------------------------\n\n/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\nexport function dailyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n}\n\n/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\nexport function weeklyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  // ISO week calculation\n  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n}\n\n/** Returns midnight UTC of the next day (daily reset). */\nexport function dailyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n  return next.toISOString();\n}\n\n/** Returns midnight UTC of next Monday (weekly reset). */\nexport function weeklyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n  return next.toISOString();\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Expire stale assignments (expires_at < now AND status='active'). */\nasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'expired'\n    WHERE user_id = ${userId}\n      AND status = 'active'\n      AND expires_at IS NOT NULL\n      AND expires_at < now()\n  `;\n}\n\n/** Get assignments for a user in a given period, joined with challenge metadata. */\nasync function getAssignmentsForPeriod(\n  db: Db,\n  userId: string,\n  periodKey: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\nasync function getActiveChallengesBySort(\n  db: Db,\n  campaignId: string,\n  limit: number,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n    LIMIT ${limit}\n  `;\n}\n\n/** Get the campaign ID for a given campaign type. */\nasync function getCampaignByType(\n  db: Db,\n  campaignType: string,\n): Promise<{ id: string } | null> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    SELECT id FROM campaigns\n    WHERE campaign_type = ${campaignType}\n      AND is_active = true\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Get all onboarding assignments for a user (any status). */\nasync function getOnboardingAssignments(\n  db: Db,\n  userId: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = 'onboarding'\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get all onboarding challenge templates (ordered by chain). */\nasync function getOnboardingChallenges(\n  db: Db,\n  campaignId: string,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n  `;\n}\n\n/** Get completion bonuses for a campaign. */\nasync function getCompletionBonusesForCampaign(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonusRow[]> {\n  return db.rawSql<CompletionBonusRow[]>`\n    SELECT id, title, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/** Check if a bonus was completed for a user in a given period. */\nasync function getBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<BonusCompletionRow | null> {\n  const rows = await db.rawSql<BonusCompletionRow[]>`\n    SELECT id FROM bonus_completions\n    WHERE user_id = ${userId}\n      AND bonus_id = ${bonusId}\n      AND period_key = ${periodKey}\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Count completed assignments for a user in a period+campaign. */\nasync function countCompleted(\n  db: Db,\n  userId: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<number> {\n  const rows = await db.rawSql<{ count: string }[]>`\n    SELECT COUNT(*)::TEXT AS count\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n      AND ca.status = 'completed'\n      AND c.campaign_id = ${campaignId}\n  `;\n  return Number(rows[0]!.count);\n}\n\n/** Create an assignment (idempotent via UNIQUE). */\nasync function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  app.get(\"/mine\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const now = new Date();\n\n      // 1. Expire stale assignments\n      await expireStaleAssignments(db, userId);\n\n      // 2. Compute current period keys\n      const dailyKey = dailyPeriodKey(now);\n      const weeklyKey = weeklyPeriodKey(now);\n\n      // 3. Read config for challenge counts\n      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n\n      // 4. Look up campaign IDs\n      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n        getCampaignByType(db, \"daily\"),\n        getCampaignByType(db, \"weekly\"),\n        getCampaignByType(db, \"onboarding\"),\n      ]);\n\n      // 5. Lazy assignment — daily\n      let dailyAssignments = dailyCampaign\n        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n        : [];\n\n      if (dailyAssignments.length === 0 && dailyCampaign) {\n        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n        const dailyExpires = dailyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n        }\n        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n      }\n\n      // 6. Lazy assignment — weekly\n      let weeklyAssignments = weeklyCampaign\n        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n        : [];\n\n      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n        const weeklyExpires = weeklyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n        }\n        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n      }\n\n      // 7. Lazy assignment — onboarding\n      let onboardingAssignments = onboardingCampaign\n        ? await getOnboardingAssignments(db, userId)\n        : [];\n\n      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n        // Assign first step (prerequisite_id IS NULL)\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n        if (firstStep) {\n          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n          onboardingAssignments = await getOnboardingAssignments(db, userId);\n        }\n      }\n\n      // 8. Build bonus status for daily\n      let dailyBonus: object | null = null;\n      if (dailyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n          dailyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" : \"active\",\n            reward: {\n              type: bonus.reward_type,\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 9. Build bonus status for weekly\n      let weeklyBonus: object | null = null;\n      if (weeklyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n          weeklyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" : \"active\",\n            reward: {\n              type: bonus.reward_type,\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 10. Build onboarding section\n      let onboarding: object | null = null;\n      if (onboardingCampaign) {\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n        const completedIds = new Set(\n          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n        );\n        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n\n        if (allCompleted) {\n          onboarding = null;\n        } else {\n          const steps = allSteps.map((step) => {\n            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n            const isAssigned = assignedIds.has(step.id);\n            const locked = !isAssigned;\n            return {\n              id: Number(step.id),\n              title: step.title,\n              description: step.description,\n              progress: assignment ? assignment.progress : 0,\n              target: step.threshold,\n              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n              reward: {\n                type: step.reward_type,\n                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n              },\n              completedAt: assignment?.completed_at ?? null,\n              locked,\n            };\n          });\n          onboarding = { steps, completed: false };\n        }\n      }\n\n      // 11. Format response\n      const formatChallenge = (a: AssignmentRow) => ({\n        id: Number(a.id),\n        title: a.title,\n        description: a.description,\n        progress: a.progress,\n        target: a.target,\n        status: a.status as \"active\" | \"completed\" | \"expired\",\n        reward: {\n          type: a.reward_type,\n          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n        },\n        completedAt: a.completed_at ?? null,\n      });\n\n      return c.json({\n        daily: {\n          challenges: dailyAssignments.map(formatChallenge),\n          bonus: dailyBonus,\n          resetsAt: dailyResetsAt(now),\n        },\n        weekly: {\n          challenges: weeklyAssignments.map(formatChallenge),\n          bonus: weeklyBonus,\n          resetsAt: weeklyResetsAt(now),\n        },\n        onboarding,\n      });\n    } catch (err) {\n      logger.error(\"challenges/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":485,"startLine":1,"totalLines":485}}}
