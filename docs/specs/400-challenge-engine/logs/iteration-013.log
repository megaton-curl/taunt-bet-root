e routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/challenges/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/challenges\", createChallengeRoutes({ db }));\n\n// Points routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/points/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/points\", createPointsRoutes({ db }));\n\n// Crate routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/crates/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/crates\", createCrateRoutes({ db }));\n\n// Leaderboard routes — public, no auth\napp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n\n// Price routes — public, no auth\napp.route(\"/price\", createPriceRoutes());\n\n// Round verification routes\napp.route(\"/rounds\", createRoundsRoutes({ db }));\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({","numLines":40,"startLine":275,"totalLines":340}}}
