bc38-5a3711be3335","timestamp":"2026-04-03T21:04:47.948Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"  const testWallet = Keypair.generate().publicKey.toBase58();\n  const testUserId = userIdFromWallet(testWallet);\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n\n    challengeApp = new Hono();\n    challengeApp.use(\n      \"/challenges/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    challengeApp.route(\"/challenges\", createChallengeRoutes({ db }));\n  });\n\n  it(\"first call creates 3 daily + 2 weekly + 1 onboarding assignment, returns correct shape\", async () => {\n    const token = await makeJwt(testWallet, testUserId);\n\n    const res = await challengeApp.request(\"/challenges/mine\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${token}` },\n    });\n\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n\n    // Daily section\n    expect(body.daily).toBeDefined();\n    expect(body.daily.challenges).toHaveLength(3);\n    expect(body.daily.resetsAt).toBeDefined();\n    for (const ch of body.daily.challenges) {\n      expect(ch).toHaveProperty(\"id\");\n      expect(ch).toHaveProperty(\"title\");\n      expect(ch).toHaveProperty(\"description\");\n      expect(ch).toHaveProperty(\"progress\");\n      expect(ch).toHaveProperty(\"target\");\n      expect(ch).toHaveProperty(\"status\");\n      expect(ch).toHaveProperty(\"reward\");\n      expect(ch.reward).toHaveProperty(\"type\");\n      expect(ch).toHaveProperty(\"completedAt\");\n      expect(ch.status).toBe(\"active\");\n      expect(ch.progress).toBe(0);\n    }\n\n    // Daily bonus\n    expect(body.daily.bonus).toBeDefined();\n    expect(body.daily.bonus.required).toBe(3);\n    expect(body.daily.bonus.completed).toBe(0);\n    expect(body.daily.bonus.status).toBe(\"active\");\n    expect(body.daily.bonus.reward).toHaveProperty(\"type\");\n\n    // Weekly section\n    expect(body.weekly).toBeDefined();\n    expect(body.weekly.challenges).toHaveLength(2);\n    expect(body.weekly.resetsAt).toBeDefined();\n    for (const ch of body.weekly.challenges) {\n      expect(ch.status).toBe(\"active\");\n      expect(ch.progress).toBe(0);\n    }\n\n    // Onboarding section\n    expect(body.onboarding).toBeDefined();\n    expect(body.onboarding).not.toBeNull();\n    expect(body.onboarding.completed).toBe(false);\n    expect(body.onboarding.steps).toBeDefined();\n    expect(body.onboarding.steps.length).toBeGreaterThanOrEqual(1);\n\n    // First step should be unlocked, rest locked\n    const steps = body.onboarding.steps;\n    expect(steps[0].locked).toBe(false);","numLines":80,"startLine":2430,"totalLines":2779}}}
