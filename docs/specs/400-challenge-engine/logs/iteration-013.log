{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011KkkDdAENbk2Mipicbh8nm","type":"tool_result","content":"2478\t      expect(ch.reward).toHaveProperty(\"type\");\n2479\t      expect(ch).toHaveProperty(\"completedAt\");\n2480\t      expect(ch.status).toBe(\"active\");\n2481\t      expect(ch.progress).toBe(0);\n2482\t    }\n2483\t\n2484\t    // Daily bonus\n2485\t    expect(body.daily.bonus).toBeDefined();\n2486\t    expect(body.daily.bonus.required).toBe(3);\n2487\t    expect(body.daily.bonus.completed).toBe(0);\n2488\t    expect(body.daily.bonus.status).toBe(\"active\");\n2489\t    expect(body.daily.bonus.reward).toHaveProperty(\"type\");\n2490\t\n2491\t    // Weekly section\n2492\t    expect(body.weekly).toBeDefined();\n2493\t    expect(body.weekly.challenges).toHaveLength(2);\n2494\t    expect(body.weekly.resetsAt).toBeDefined();\n2495\t    for (const ch of body.weekly.challenges) {\n2496\t      expect(ch.status).toBe(\"active\");\n2497\t      expect(ch.progress).toBe(0);\n2498\t    }\n2499\t\n2500\t    // Onboarding section\n2501\t    expect(body.onboarding).toBeDefined();\n2502\t    expect(body.onboarding).not.toBeNull();\n2503\t    expect(body.onboarding.completed).toBe(false);\n2504\t    expect(body.onboarding.steps).toBeDefined();\n2505\t    expect(body.onboarding.steps.length).toBeGreaterThanOrEqual(1);\n2506\t\n2507\t    // First step should be unlocked, rest locked\n2508\t    const steps = body.onboarding.steps;\n2509\t    expect(steps[0].locked).toBe(false);\n2510\t    if (steps.length > 1) {\n2511\t      expect(steps[1].locked).toBe(true);\n2512\t    }\n2513\t\n2514\t    // Verify DB: 3 daily + 2 weekly + 1 onboarding = 6 total assignments\n2515\t    const assignments = await rawSql<{ period_key: string }[]>`\n2516\t      SELECT period_key FROM challenge_assignments WHERE user_id = ${testUserId}\n2517\t    `;\n2518\t    const dailyKey = dailyPeriodKey();\n2519\t    const weeklyKey = weeklyPeriodKey();\n2520\t    const dailyCount = assignments.filter((a) => a.period_key === dailyKey).length;\n2521\t    const weeklyCount = assignments.filter((a) => a.period_key === weeklyKey).length;\n2522\t    const onboardingCount = assignments.filter((a) => a.period_key === \"onboarding\").length;\n2523\t    expect(dailyCount).toBe(3);\n2524\t    expect(weeklyCount).toBe(2);\n2525\t    expect(onboardingCount).toBe(1);\n2526\t  });\n2527\t\n2528\t  it(\"second call returns same assignments (no duplicates)\", async () => {\n2529\t    const token = await makeJwt(testWallet, testUserId);\n2530\t\n2531\t    // First call — creates assignments\n2532\t    await challengeApp.request(\"/challenges/mine\", {\n2533\t      method: \"GET\",\n2534\t      headers: { Authorization: `Bearer ${token}` },\n2535\t    });\n2536\t\n2537\t    // Second call — should return same data\n2538\t    const res = await challengeApp.request(\"/challenges/mine\", {\n2539\t      method: \"GET\",\n2540\t      headers: { Authorization: `Bearer ${token}` },\n2541\t    });\n2542\t\n2543\t    expect(res.status).toBe(200);\n2544\t    const body = (await res.json()) as Record<string, any>;\n2545\t    expect(body.daily.challenges).toHaveLength(3);\n2546\t    expect(body.weekly.challenges).toHaveLength(2);\n2547\t\n2548\t    // Total assignments unchanged\n2549\t    const assignments = await rawSql<{ id: string }[]>`\n2550\t      SELECT id FROM challenge_assignments WHERE user_id = ${testUserId}\n2551\t    `;\n2552\t    expect(assignments.length).toBe(6); // 3 daily + 2 weekly + 1 onboarding\n2553\t  });\n2554\t\n2555\t  it(\"expired assignments are marked expired\", async () => {\n2556\t    const token = await makeJwt(testWallet, testUserId);\n2557\t\n2558\t    // Insert an assignment that's already expired\n2559\t    const dailyCampaign = await rawSql<{ id: string }[]>`\n2560\t      SELECT id FROM campaigns WHERE campaign_type = 'daily' LIMIT 1\n2561\t    `;\n2562\t    const challenges = await rawSql<{ id: string; threshold: number }[]>`\n2563\t      SELECT id, threshold FROM challenges WHERE campaign_id = ${dailyCampaign[0]!.id} AND is_active = true ORDER BY sort_order ASC LIMIT 1\n2564\t    `;\n2565\t    await rawSql`\n2566\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n2567\t      VALUES (${testUserId}, ${challenges[0]!.id}, 'daily:2020-01-01', ${challenges[0]!.threshold}, '2020-01-02T00:00:00Z')\n2568\t    `;\n2569\t\n2570\t    // Verify it's active\n2571\t    const before = await rawSql<{ status: string }[]>`\n2572\t      SELECT status FROM challenge_assignments WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n2573\t    `;\n2574\t    expect(before[0]!.status).toBe(\"active\");\n2575\t\n2576\t    // Call /mine — should expire the stale assignment\n2577\t    await challengeApp.request(\"/challenges/mine\", {\n2578\t      method: \"GET\",\n2579\t      headers: { Authorization: `Bearer ${token}` },\n2580\t    });\n2581\t\n2582\t    // Verify it's now expired\n2583\t    const after = await rawSql<{ status: string }[]>`\n2584\t      SELECT status FROM challenge_assignments WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n2585\t    `;\n2586\t    expect(after[0]!.status).toBe(\"expired\");\n2587\t  });\n2588\t});\n2589\t\n2590\t// ---------------------------------------------------------------------------\n2591\t// GET /points/mine, GET /points/mine/history, GET /crates/mine\n2592\t// ---------------------------------------------------------------------------\n2593\t\n2594\tdescribe(\"GET /points/mine + /points/mine/history + /crates/mine\", () => {\n2595\t  let rawSql: ReturnType<typeof makeSql>;\n2596\t  let db: Db;\n2597\t  let pointsApp: InstanceType<typeof Hono>;\n2598\t  let cratesApp: InstanceType<typeof Hono>;\n2599\t\n2600\t  const testWallet = Keypair.generate().publicKey.toBase58();\n2601\t  const testUserId = userIdFromWallet(testWallet);\n2602\t\n2603\t  beforeAll(async () => {\n2604\t    rawSql = makeSql();\n2605\t    db = createDb(DATABASE_URL, rawSql);\n2606\t  });\n2607\t\n2608\t  afterAll(async () => {\n2609\t    await db.close();\n2610\t    await rawSql.end();\n2611\t  });\n2612\t\n2613\t  beforeEach(async () => {\n2614\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n2615\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n2616\t\n2617\t    pointsApp = new Hono();\n2618\t    pointsApp.use(\n2619\t      \"/points/*\",\n2620\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n2621\t    );\n2622\t    pointsApp.route(\"/points\", createPointsRoutes({ db }));\n2623\t\n2624\t    cratesApp = new Hono();\n2625\t    cratesApp.use(\n2626\t      \"/crates/*\",\n2627\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n2628\t    );\n2629\t    cratesApp.route(\"/crates\", createCrateRoutes({ db }));\n2630\t  });\n2631\t\n2632\t  it(\"GET /points/mine returns zeros when no player_points row exists\", async () => {\n2633\t    const token = await makeJwt(testWallet, testUserId);\n2634\t    const res = await pointsApp.request(\"/points/mine\", {\n2635\t      method: \"GET\",\n2636\t      headers: { Authorization: `Bearer ${token}` },\n2637\t    });\n2638\t    expect(res.status).toBe(200);\n2639\t    const body = (await res.json()) as Record<string, any>;\n2640\t    expect(body.balance).toBe(0);\n2641\t    expect(body.lifetimeEarned).toBe(0);\n2642\t  });\n2643\t\n2644\t  it(\"GET /points/mine returns balance and lifetimeEarned from player_points\", async () => {\n2645\t    // Seed player_points\n2646\t    await rawSql`\n2647\t      INSERT INTO player_points (user_id, wallet, balance, lifetime_earned)\n2648\t      VALUES (${testUserId}, ${testWallet}, 5000, 12000)\n2649\t    `;\n2650\t\n2651\t    const token = await makeJwt(testWallet, testUserId);\n2652\t    const res = await pointsApp.request(\"/points/mine\", {\n2653\t      method: \"GET\",\n2654\t      headers: { Authorization: `Bearer ${token}` },\n2655\t    });\n2656\t    expect(res.status).toBe(200);\n2657\t    const body = (await res.json()) as Record<string, any>;\n2658\t    expect(body.balance).toBe(5000);\n2659\t    expect(body.lifetimeEarned).toBe(12000);\n2660\t  });\n2661\t\n2662\t  it(\"GET /points/mine/history returns paginated point_grants with cursor\", async () => {\n2663\t    // Seed 3 point_grants\n2664\t    for (let i = 1; i <= 3; i++) {\n2665\t      await rawSql`\n2666\t        INSERT INTO point_grants (user_id, wallet, source_type, source_id, amount, metadata)\n2667\t        VALUES (${testUserId}, ${testWallet}, 'wager', ${\"round_\" + i}, ${1000 * i}, ${JSON.stringify({ solPrice: 100 })})\n2668\t      `;\n2669\t    }\n2670\t\n2671\t    const token = await makeJwt(testWallet, testUserId);\n2672\t\n2673\t    // Fetch first page with limit=2\n2674\t    const res1 = await pointsApp.request(\"/points/mine/history?limit=2\", {\n2675\t      method: \"GET\",\n2676\t      headers: { Authorization: `Bearer ${token}` },\n2677\t    });\n2678\t    expect(res1.status).toBe(200);\n2679\t    const body1 = (await res1.json()) as Record<string, any>;\n2680\t    expect(body1.items).toHaveLength(2);\n2681\t    // DESC order: id=3 first, id=2 second\n2682\t    expect(body1.items[0].sourceType).toBe(\"wager\");\n2683\t    expect(body1.items[0].amount).toBe(3000);\n2684\t    expect(body1.items[1].amount).toBe(2000);\n2685\t    expect(body1.nextCursor).not.toBeNull();\n2686\t    // Verify shape\n2687\t    expect(body1.items[0]).toHaveProperty(\"id\");\n2688\t    expect(body1.items[0]).toHaveProperty(\"sourceId\");\n2689\t    expect(body1.items[0]).toHaveProperty(\"metadata\");\n2690\t    expect(body1.items[0]).toHaveProperty(\"createdAt\");\n2691\t\n2692\t    // Fetch second page using cursor\n2693\t    const res2 = await pointsApp.request(`/points/mine/history?limit=2&cursor=${body1.nextCursor}`, {\n2694\t      method: \"GET\",\n2695\t      headers: { Authorization: `Bearer ${token}` },\n2696\t    });\n2697\t    expect(res2.status).toBe(200);\n2698\t    const body2 = (await res2.json()) as Record<string, any>;\n2699\t    expect(body2.items).toHaveLength(1);\n2700\t    expect(body2.items[0].amount).toBe(1000);\n2701\t    expect(body2.nextCursor).toBeNull(); // No more pages\n2702\t  });\n2703\t\n2704\t  it(\"GET /points/mine/history returns empty array when no grants\", async () => {\n2705\t    const token = await makeJwt(testWallet, testUserId);\n2706\t    const res = await pointsApp.request(\"/points/mine/history\", {\n2707\t      method: \"GET\",\n2708\t      headers: { Authorization: `Bearer ${token}` },\n2709\t    });\n2710\t    expect(res.status).toBe(200);\n2711\t    const body = (await res.json()) as Record<string, any>;\n2712\t    expect(body.items).toHaveLength(0);\n2713\t    expect(body.nextCursor).toBeNull();\n2714\t  });\n2715\t\n2716\t  it(\"GET /crates/mine returns paginated crate_drops with cursor\", async () => {\n2717\t    // Seed 3 crate_drops\n2718\t    await rawSql`\n2719\t      INSERT INTO crate_drops (user_id, trigger_type, trigger_id, crate_type, contents_amount, status)\n2720\t      VALUES (${testUserId}, 'game_settled', 'round_1', 'points', '2500', 'granted')\n2721\t    `;\n2722\t    await rawSql`\n2723\t      INSERT INTO crate_drops (user_id, trigger_type, trigger_id, crate_type, contents_amount, status, granted_at)\n2724\t      VALUES (${testUserId}, 'game_settled', 'round_2', 'sol', '10000000', 'granted', now())\n2725\t    `;\n2726\t    await rawSql`\n2727\t      INSERT INTO crate_drops (user_id, trigger_type, trigger_id, crate_type, contents_amount, status)\n2728\t      VALUES (${testUserId}, 'game_settled', 'round_3', 'points', '500', 'pending')\n2729\t    `;\n2730\t\n2731\t    const token = await makeJwt(testWallet, testUserId);\n2732\t\n2733\t    // Fetch first page with limit=2\n2734\t    const res1 = await cratesApp.request(\"/crates/mine?limit=2\", {\n2735\t      method: \"GET\",\n2736\t      headers: { Authorization: `Bearer ${token}` },\n2737\t    });\n2738\t    expect(res1.status).toBe(200);\n2739\t    const body1 = (await res1.json()) as Record<string, any>;\n2740\t    expect(body1.items).toHaveLength(2);\n2741\t    // DESC order: id=3 first (pending points), id=2 second (granted sol)\n2742\t    expect(body1.items[0].crateType).toBe(\"points\");\n2743\t    expect(body1.items[0].status).toBe(\"pending\");\n2744\t    expect(body1.items[0].contentsAmount).toBe(\"500\");\n2745\t    expect(body1.items[0].grantedAt).toBeNull();\n2746\t    expect(body1.items[1].crateType).toBe(\"sol\");\n2747\t    expect(body1.items[1].status).toBe(\"granted\");\n2748\t    expect(body1.items[1].grantedAt).not.toBeNull();\n2749\t    expect(body1.nextCursor).not.toBeNull();\n2750\t    // Verify shape\n2751\t    expect(body1.items[0]).toHaveProperty(\"id\");\n2752\t    expect(body1.items[0]).toHaveProperty(\"createdAt\");\n2753\t\n2754\t    // Fetch second page using cursor\n2755\t    const res2 = await cratesApp.request(`/crates/mine?limit=2&cursor=${body1.nextCursor}`, {\n2756\t      method: \"GET\",\n2757\t      headers: { Authorization: `Bearer ${token}` },\n2758\t    });\n2759\t    expect(res2.status).toBe(200);\n2760\t    const body2 = (await res2.json()) as Record<string, any>;\n2761\t    expect(body2.items).toHaveLength(1);\n2762\t    expect(body2.items[0].crateType).toBe(\"points\");\n2763\t    expect(body2.items[0].contentsAmount).toBe(\"2500\");\n2764\t    expect(body2.nextCursor).toBeNull();\n2765\t  });\n2766\t\n2767\t  it(\"GET /crates/mine returns empty array when no crate drops\", async () => {\n2768\t    const token = await makeJwt(testWallet, testUserId);\n2769\t    const res = await cratesApp.request(\"/crates/mine\", {\n2770\t      method: \"GET\",\n2771\t      headers: { Authorization: `Bearer ${token}` },\n2772\t    });\n2773\t    expect(res.status).toBe(200);\n2774\t    const body = (await res.json()) as Record<string, any>;\n2775\t    expect(body.items).toHaveLength(0);\n2776\t    expect(body.nextCursor).toBeNull();\n2777\t  });\n2778\t});\n2779\t"}]},"parent_tool_use_id":"toolu_01QpcN3UH9p1wNALSuksnNE1","session_id":"8b2f7dd7-97bd-434b-b775-f78d70040f2b","uuid":"f9663433-c71a-432f-bf8b-a3ae28b60190","timestamp":"2026-04-03T21:03:59.661Z"}
