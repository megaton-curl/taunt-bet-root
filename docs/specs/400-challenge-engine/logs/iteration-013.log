{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ANgAJ84hWRguqd2TbMzz6H","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/routes/challenges.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"8b2f7dd7-97bd-434b-b775-f78d70040f2b","uuid":"43a4b567-2133-4d49-99b4-dd24ca459581","timestamp":"2026-04-03T21:04:59.357Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/routes/challenges.ts","oldString":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine — returns active daily, weekly, and onboarding challenges\n * with lazy assignment on first call per period.\n */","newString":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine           — returns active daily, weekly, and onboarding challenges\n *                       with lazy assignment on first call per period.\n * GET /mine/history   — paginated completed challenge assignments.\n */","originalFile":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine — returns active daily, weekly, and onboarding challenges\n * with lazy assignment on first call per period.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface ChallengeRoutesDeps {\n  db: Db;\n}\n\ninterface ChallengeRow {\n  id: string;\n  campaign_id: string;\n  title: string;\n  description: string;\n  action: string;\n  scope: string;\n  condition: string;\n  threshold: number;\n  reward_type: string;\n  reward_amount: number | null;\n  sort_order: number;\n  prerequisite_id: string | null;\n}\n\ninterface AssignmentRow {\n  id: string;\n  challenge_id: string;\n  period_key: string;\n  status: string;\n  progress: number;\n  target: number;\n  expires_at: string | null;\n  completed_at: string | null;\n  title: string;\n  description: string;\n  reward_type: string;\n  reward_amount: number | null;\n  campaign_type: string;\n}\n\ninterface CompletionBonusRow {\n  id: string;\n  title: string;\n  required_count: number;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\ninterface BonusCompletionRow {\n  id: string;\n}\n\n// ---------------------------------------------------------------------------\n// Period key helpers\n// ---------------------------------------------------------------------------\n\n/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\nexport function dailyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n}\n\n/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\nexport function weeklyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  // ISO week calculation\n  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n}\n\n/** Returns midnight UTC of the next day (daily reset). */\nexport function dailyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n  return next.toISOString();\n}\n\n/** Returns midnight UTC of next Monday (weekly reset). */\nexport function weeklyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n  return next.toISOString();\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Expire stale assignments (expires_at < now AND status='active'). */\nasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'expired'\n    WHERE user_id = ${userId}\n      AND status = 'active'\n      AND expires_at IS NOT NULL\n      AND expires_at < now()\n  `;\n}\n\n/** Get assignments for a user in a given period, joined with challenge metadata. */\nasync function getAssignmentsForPeriod(\n  db: Db,\n  userId: string,\n  periodKey: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\nasync function getActiveChallengesBySort(\n  db: Db,\n  campaignId: string,\n  limit: number,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n    LIMIT ${limit}\n  `;\n}\n\n/** Get the campaign ID for a given campaign type. */\nasync function getCampaignByType(\n  db: Db,\n  campaignType: string,\n): Promise<{ id: string } | null> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    SELECT id FROM campaigns\n    WHERE campaign_type = ${campaignType}\n      AND is_active = true\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Get all onboarding assignments for a user (any status). */\nasync function getOnboardingAssignments(\n  db: Db,\n  userId: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = 'onboarding'\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get all onboarding challenge templates (ordered by chain). */\nasync function getOnboardingChallenges(\n  db: Db,\n  campaignId: string,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n  `;\n}\n\n/** Get completion bonuses for a campaign. */\nasync function getCompletionBonusesForCampaign(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonusRow[]> {\n  return db.rawSql<CompletionBonusRow[]>`\n    SELECT id, title, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/** Check if a bonus was completed for a user in a given period. */\nasync function getBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<BonusCompletionRow | null> {\n  const rows = await db.rawSql<BonusCompletionRow[]>`\n    SELECT id FROM bonus_completions\n    WHERE user_id = ${userId}\n      AND bonus_id = ${bonusId}\n      AND period_key = ${periodKey}\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Count completed assignments for a user in a period+campaign. */\nasync function countCompleted(\n  db: Db,\n  userId: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<number> {\n  const rows = await db.rawSql<{ count: string }[]>`\n    SELECT COUNT(*)::TEXT AS count\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n      AND ca.status = 'completed'\n      AND c.campaign_id = ${campaignId}\n  `;\n  return Number(rows[0]!.count);\n}\n\n/** Create an assignment (idempotent via UNIQUE). */\nasync function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  app.get(\"/mine\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const now = new Date();\n\n      // 1. Expire stale assignments\n      await expireStaleAssignments(db, userId);\n\n      // 2. Compute current period keys\n      const dailyKey = dailyPeriodKey(now);\n      const weeklyKey = weeklyPeriodKey(now);\n\n      // 3. Read config for challenge counts\n      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n\n      // 4. Look up campaign IDs\n      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n        getCampaignByType(db, \"daily\"),\n        getCampaignByType(db, \"weekly\"),\n        getCampaignByType(db, \"onboarding\"),\n      ]);\n\n      // 5. Lazy assignment — daily\n      let dailyAssignments = dailyCampaign\n        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n        : [];\n\n      if (dailyAssignments.length === 0 && dailyCampaign) {\n        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n        const dailyExpires = dailyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n        }\n        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n      }\n\n      // 6. Lazy assignment — weekly\n      let weeklyAssignments = weeklyCampaign\n        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n        : [];\n\n      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n        const weeklyExpires = weeklyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n        }\n        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n      }\n\n      // 7. Lazy assignment — onboarding\n      let onboardingAssignments = onboardingCampaign\n        ? await getOnboardingAssignments(db, userId)\n        : [];\n\n      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n        // Assign first step (prerequisite_id IS NULL)\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n        if (firstStep) {\n          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n          onboardingAssignments = await getOnboardingAssignments(db, userId);\n        }\n      }\n\n      // 8. Build bonus status for daily\n      let dailyBonus: object | null = null;\n      if (dailyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n          dailyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" : \"active\",\n            reward: {\n              type: bonus.reward_type,\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 9. Build bonus status for weekly\n      let weeklyBonus: object | null = null;\n      if (weeklyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n          weeklyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" : \"active\",\n            reward: {\n              type: bonus.reward_type,\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 10. Build onboarding section\n      let onboarding: object | null = null;\n      if (onboardingCampaign) {\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n        const completedIds = new Set(\n          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n        );\n        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n\n        if (allCompleted) {\n          onboarding = null;\n        } else {\n          const steps = allSteps.map((step) => {\n            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n            const isAssigned = assignedIds.has(step.id);\n            const locked = !isAssigned;\n            return {\n              id: Number(step.id),\n              title: step.title,\n              description: step.description,\n              progress: assignment ? assignment.progress : 0,\n              target: step.threshold,\n              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n              reward: {\n                type: step.reward_type,\n                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n              },\n              completedAt: assignment?.completed_at ?? null,\n              locked,\n            };\n          });\n          onboarding = { steps, completed: false };\n        }\n      }\n\n      // 11. Format response\n      const formatChallenge = (a: AssignmentRow) => ({\n        id: Number(a.id),\n        title: a.title,\n        description: a.description,\n        progress: a.progress,\n        target: a.target,\n        status: a.status as \"active\" | \"completed\" | \"expired\",\n        reward: {\n          type: a.reward_type,\n          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n        },\n        completedAt: a.completed_at ?? null,\n      });\n\n      return c.json({\n        daily: {\n          challenges: dailyAssignments.map(formatChallenge),\n          bonus: dailyBonus,\n          resetsAt: dailyResetsAt(now),\n        },\n        weekly: {\n          challenges: weeklyAssignments.map(formatChallenge),\n          bonus: weeklyBonus,\n          resetsAt: weeklyResetsAt(now),\n        },\n        onboarding,\n      });\n    } catch (err) {\n      logger.error(\"challenges/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":1,"oldLines":8,"newStart":1,"newLines":9,"lines":[" /**","  * Challenge routes — player-facing challenge/quest endpoints.","  *","- * GET /mine — returns active daily, weekly, and onboarding challenges","- * with lazy assignment on first call per period.","+ * GET /mine           — returns active daily, weekly, and onboarding challenges","+ *                       with lazy assignment on first call per period.","+ * GET /mine/history   — paginated completed challenge assignments.","  */"," "," import { Hono } from \"hono\";"]}],"userModified":false,"replaceAll":false}}
