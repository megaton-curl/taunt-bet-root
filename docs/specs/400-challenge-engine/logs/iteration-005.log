{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qxy7MvuVc4AVTAPpus9k4d","type":"tool_result","content":"800\t    //           referrer_earned=250_000*1000/10_000=25_000\n801\t    //           referee_rebate=250_000*1000/10_000=25_000\n802\t    const earnings =\n803\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n804\t    expect(earnings.length).toBe(1);\n805\t\n806\t    const earning = earnings[0]!;\n807\t    expect(earning.referrer_user_id).toBe(referrerUserId);\n808\t    expect(earning.referee_user_id).toBe(opponentUserId);\n809\t    expect(earning.referrer_wallet).toBe(referrerWallet);\n810\t    expect(earning.referee_wallet).toBe(opponentWallet);\n811\t    expect(earning.round_id).toBe(createJson.matchId);\n812\t    expect(earning.game_type).toBe(\"coinflip\");\n813\t    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS); // 5_000_000\n814\t    expect(Number(earning.fee_lamports)).toBe(250_000); // 5_000_000 * 500 / 10_000\n815\t    expect(Number(earning.referrer_earned_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n816\t    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n817\t    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n818\t    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n819\t\n820\t    // Creator is NOT referred, so no earnings for creator\n821\t    const creatorEarnings =\n822\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${creatorUserId}`;\n823\t    expect(creatorEarnings.length).toBe(0);\n824\t  });\n825\t\n826\t  it(\"settlement uses KOL custom rate for referrer earnings\", async () => {\n827\t    // Referrer has a KOL rate of 2000 bps (20% of fee)\n828\t    const referrerKeypair = Keypair.generate();\n829\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n830\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n831\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n832\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n833\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n834\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n835\t    const referrerUserId = referrerProfile.user_id;\n836\t    const opponentUserId = opponentProfile.user_id;\n837\t\n838\t    // Set up referral link + KOL rate override\n839\t    await db.insertReferralCode(referrerUserId, referrerWallet, \"kol-code\");\n840\t    await db.insertReferralLink({\n841\t      referrerUserId,\n842\t      refereeUserId: opponentUserId,\n843\t      referrerWallet,\n844\t      refereeWallet: opponentWallet,\n845\t    });\n846\t    await rawSql`INSERT INTO referral_kol_rates (user_id, wallet, rate_bps, set_by) VALUES (${referrerUserId}, ${referrerWallet}, 2000, 'admin')`;\n847\t\n848\t    // Create + settle a coinflip match\n849\t    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n850\t    const createRes = await app.request(\"/coinflip/create\", {\n851\t      method: \"POST\",\n852\t      headers: {\n853\t        \"Content-Type\": \"application/json\",\n854\t        \"Authorization\": `Bearer ${token}`,\n855\t      },\n856\t      body: JSON.stringify({\n857\t        wallet: creatorWallet,\n858\t        amountLamports: AMOUNT_LAMPORTS,\n859\t        side: SIDE_HEADS,\n860\t      }),\n861\t    });\n862\t    expect(createRes.status).toBe(200);\n863\t    const createJson = (await createRes.json()) as {\n864\t      matchPda: string;\n865\t      matchId: string;\n866\t      commitment: string;\n867\t    };\n868\t\n869\t    const matchPubkey = new PublicKey(createJson.matchPda);\n870\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n871\t\n872\t    const matchAccountData = await buildMatchAccountData({\n873\t      creator: creatorKeypair.publicKey,\n874\t      opponent: opponentKeypair.publicKey,\n875\t      server: serverKeypair.publicKey,\n876\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n877\t      creatorSide: SIDE_HEADS,\n878\t      phase: PHASE_LOCKED,\n879\t      commitment: commitmentBuf,\n880\t      algorithmVer: 1,\n881\t      targetSlot: 150n,\n882\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n883\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n884\t    });\n885\t\n886\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n887\t      owner: COINFLIP_PROGRAM_ID,\n888\t    });\n889\t    mockConn.slot = 200;\n890\t\n891\t    let settlePromise2: Promise<void> | null = null;\n892\t\n893\t    const retrySettler = createRetrySettler({\n894\t      db,\n895\t      connection: mockConn as unknown as Connection,\n896\t      settleRound: (pda) =>\n897\t        settleMatch(\n898\t          {\n899\t            db,\n900\t            connection: mockConn as unknown as Connection,\n901\t            serverKeypair,\n902\t            entropyAccount,\n903\t            referralDefaultRateBps: 1000,\n904\t          },\n905\t          pda,\n906\t        ),\n907\t    });\n908\t\n909\t    const worker = createSettlementWorker({\n910\t      db,\n911\t      connection: mockConn as unknown as Connection,\n912\t      serverKey: serverKeypair.publicKey,\n913\t      pollIntervalMs: 60_000,\n914\t      onSettleReady: (pda) => {\n915\t        settlePromise2 = retrySettler.attemptSettle(pda);\n916\t        return settlePromise2;\n917\t      },\n918\t    });\n919\t\n920\t    await worker.poll();\n921\t    if (settlePromise2) await settlePromise2;\n922\t\n923\t    // Verify settlement completed\n924\t    const settled = await db.getRoundByPda(createJson.matchPda);\n925\t    expect(settled!.phase).toBe(\"settled\");\n926\t\n927\t    // Verify KOL rate was used for referrer earning\n928\t    // fee = 5_000_000 * 500 / 10_000 = 250_000\n929\t    // referrer_earned = 250_000 * 2000 / 10_000 = 50_000 (KOL rate)\n930\t    // referee_rebate = 250_000 * 1000 / 10_000 = 25_000 (always fixed 10%)\n931\t    const earnings =\n932\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n933\t    expect(earnings.length).toBe(1);\n934\t\n935\t    const earning = earnings[0]!;\n936\t    expect(Number(earning.referrer_earned_lamports)).toBe(50_000); // KOL: 2000 bps\n937\t    expect(Number(earning.referrer_rate_bps)).toBe(2000);\n938\t    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // Fixed 10%\n939\t    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n940\t  });\n941\t\n942\t  it(\"settlement emits game.settled event with correct payload shape\", async () => {\n943\t    const wallet = creatorKeypair.publicKey.toBase58();\n944\t    const token = await makeJwt(wallet);\n945\t\n946\t    // Create profiles for both players so game entries + event payloads get user IDs\n947\t    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n948\t    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n949\t    await rawSql`\n950\t      INSERT INTO player_profiles (user_id, wallet, username)\n951\t      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n952\t      ON CONFLICT (user_id) DO NOTHING\n953\t    `;\n954\t    await rawSql`\n955\t      INSERT INTO player_profiles (user_id, wallet, username)\n956\t      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n957\t      ON CONFLICT (user_id) DO NOTHING\n958\t    `;\n959\t\n960\t    // Create round via API\n961\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n962\t    const createRes = await app.request(\"/coinflip/create\", {\n963\t      method: \"POST\",\n964\t      headers: {\n965\t        \"Content-Type\": \"application/json\",\n966\t        Authorization: `Bearer ${token}`,\n967\t      },\n968\t      body: JSON.stringify(body),\n969\t    });\n970\t    expect(createRes.status).toBe(200);\n971\t    const createJson = (await createRes.json()) as {\n972\t      matchPda: string;\n973\t      matchId: string;\n974\t      commitment: string;\n975\t    };\n976\t\n977\t    // Simulate on-chain join — LOCKED match in mock\n978\t    const matchPubkey = new PublicKey(createJson.matchPda);\n979\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n980\t    const matchAccountData = await buildMatchAccountData({\n981\t      creator: creatorKeypair.publicKey,\n982\t      opponent: opponentKeypair.publicKey,\n983\t      server: serverKeypair.publicKey,\n984\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n985\t      creatorSide: SIDE_HEADS,\n986\t      phase: PHASE_LOCKED,\n987\t      commitment: commitmentBuf,\n988\t      algorithmVer: 1,\n989\t      targetSlot: 150n,\n990\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n991\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n992\t    });\n993\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n994\t      owner: COINFLIP_PROGRAM_ID,\n995\t    });\n996\t\n997\t    // Transition DB round to \"locked\" (normally the settlement worker does this on join detection)\n998\t    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n999\t"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"596bc63d-2729-45ee-862b-44bbad55ed05","timestamp":"2026-04-03T19:38:16.807Z"}
