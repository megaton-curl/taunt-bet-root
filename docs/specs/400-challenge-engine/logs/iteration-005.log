{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017CFB529qLHYNYJYxB1E1E6","type":"tool_result","content":"710\t      feeBps,\n711\t      referralDefaultRateBps: deps.referralDefaultRateBps,\n712\t      players: serializedEntries.map((e) => ({\n713\t        wallet: e.player,\n714\t        wagerLamports: e.amountLamports,\n715\t      })),\n716\t    });\n717\t\n718\t    // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n719\t    const settledAt = new Date().toISOString();\n720\t    // Aggregate per-player totals for lord (a player may have multiple entries)\n721\t    const playerAgg = new Map<string, { total: bigint; isWinner: boolean }>();\n722\t    for (const e of serializedEntries) {\n723\t      const existing = playerAgg.get(e.player);\n724\t      playerAgg.set(e.player, {\n725\t        total: (existing?.total ?? 0n) + BigInt(e.amountLamports),\n726\t        isWinner: existing?.isWinner || e.player === winnerKey,\n727\t      });\n728\t    }\n729\t    await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n730\t      roundId: round.match_id,\n731\t      roundPda: pda,\n732\t      game: \"lord\",\n733\t      players: [...playerAgg.entries()].map(([wallet, agg]) => ({\n734\t        userId: profileMap.get(wallet)?.user_id ?? wallet,\n735\t        wallet,\n736\t        amountLamports: String(agg.total),\n737\t        isWinner: agg.isWinner,\n738\t        payoutLamports: agg.isWinner ? String(payoutAmount) : \"0\",\n739\t        isCreator: serializedEntries[0]?.player === wallet, // first entry is creator\n740\t      })),\n741\t      feeLamports: String(feeAmount),\n742\t      settledAt,\n743\t    });\n744\t  });\n745\t\n746\t  const tDone = performance.now();\n747\t  logger.info(\"lord settlement transaction confirmed\", {\n748\t    pda,\n749\t    txSignature,\n750\t    winner: winner.toBase58(),\n751\t    winningEntryIndex: winnerEntryIndex,\n752\t    timing: {\n753\t      dbMs: Math.round(tDb - t0),\n754\t      fetchMs: Math.round(tFetch - tDb),\n755\t      buildMs: Math.round(tBuild - tFetch),\n756\t      sendMs: Math.round(tSend - tBuild),\n757\t      confirmMs: Math.round(tConfirm - tSend),\n758\t      dbWriteMs: Math.round(tDone - tConfirm),\n759\t      totalMs: Math.round(tDone - t0),\n760\t    },\n761\t  });\n762\t\n763\t  return {\n764\t    txSignature,\n765\t    resultHash,\n766\t    winningEntryIndex: winnerEntryIndex,\n767\t    winner: winner.toBase58(),\n768\t  };\n769\t}\n770\t\n771\texport async function settleRound(\n772\t  deps: SettleTxDeps,\n773\t  pda: string,\n774\t): Promise<SettleResult> {\n775\t  const round = await deps.db.getRoundByPda(pda);\n776\t  if (!round) {\n777\t    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n778\t  }\n779\t\n780\t  if (round.game === \"lord\") {\n781\t    return settleLordRound(deps, pda);\n782\t  }\n783\t\n784\t  return settleMatch(deps, pda);\n785\t}\n786\t\n787\t// ---------------------------------------------------------------------------\n788\t// Close Call — transaction builders\n789\t// ---------------------------------------------------------------------------\n790\t\n791\tfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n792\t  return PublicKey.findProgramAddressSync(\n793\t    [Buffer.from(\"closecall_config\")],\n794\t    CLOSECALL_PROGRAM_ID,\n795\t  );\n796\t}\n797\t\n798\t\n799\tfunction minuteTsToBuffer(ts: bigint): Buffer {\n800\t  const buf = Buffer.alloc(8);\n801\t  buf.writeBigInt64LE(ts);\n802\t  return buf;\n803\t}\n804\t\n805\tfunction deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n806\t  return PublicKey.findProgramAddressSync(\n807\t    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n808\t    CLOSECALL_PROGRAM_ID,\n809\t  );"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"786039fb-0931-48e8-ba5f-bde50c76e403","timestamp":"2026-04-03T19:38:42.179Z"}
