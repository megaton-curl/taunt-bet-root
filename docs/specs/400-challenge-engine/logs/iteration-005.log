{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G5jZwidt2iVvdRMTD4bVwT","type":"tool_result","content":"0\t/**\n1\t * Integration test: full create → join → settle lifecycle.\n2\t *\n3\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n4\t * the real HTTP endpoints, database, settlement worker, and retry logic\n5\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n6\t */\n7\t\n8\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n9\timport { Hono } from \"hono\";\n10\timport {\n11\t  Keypair,\n12\t  PublicKey,\n13\t  SystemProgram,\n14\t  LAMPORTS_PER_SOL,\n15\t} from \"@solana/web3.js\";\n16\timport type { Connection } from \"@solana/web3.js\";\n17\timport bs58 from \"bs58\";\n18\timport { SignJWT } from \"jose\";\n19\timport postgres from \"postgres\";\n20\timport { createDb, type Db } from \"../db.js\";\n21\timport { createCoinflipRoutes } from \"../routes/create.js\";\n22\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n23\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n24\timport { createSettlementWorker } from \"../worker/settlement.js\";\n25\timport { settleMatch } from \"../worker/settle-tx.js\";\n26\timport { createRetrySettler } from \"../worker/retry.js\";\n27\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n28\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n29\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n30\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n31\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n32\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n33\t\n34\t// ---------------------------------------------------------------------------\n35\t// Constants\n36\t// ---------------------------------------------------------------------------\n37\t\n38\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n39\t\n40\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n41\tfunction makeSql() {\n42\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n43\t  // Dev container: postgres listens on Unix socket only\n44\t  return postgres({\n45\t    host: \"/var/run/postgresql\",\n46\t    user: \"vscode\",\n47\t    database: \"rng_utopia_dev\",\n48\t  });\n49\t}\n50\t\n51\tconst AMOUNT_LAMPORTS = 5_000_000;\n52\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n53\tconst SIDE_HEADS = 0;\n54\tconst PHASE_LOCKED = 1;\n55\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n56\t\n57\t// ---------------------------------------------------------------------------\n58\t// JWT helper\n59\t// ---------------------------------------------------------------------------\n60\t\n61\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n62\t  const now = Math.floor(Date.now() / 1000);\n63\t  return new SignJWT({ wallet })\n64\t    .setProtectedHeader({ alg: \"HS256\" })\n65\t    .setSubject(userId)\n66\t    .setIssuedAt(now)\n67\t    .setExpirationTime(now + 3600)\n68\t    .sign(JWT_SECRET);\n69\t}\n70\t\n71\tfunction userIdFromWallet(wallet: string) {\n72\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n73\t}\n74\t\n75\t// ---------------------------------------------------------------------------\n76\t// Mock Connection\n77\t// ---------------------------------------------------------------------------\n78\t\n79\t/**\n80\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n81\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n82\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n83\t */\n84\tclass MockConnection {\n85\t  private _slot = 200;\n86\t  private _accounts = new Map<\n87\t    string,\n88\t    {\n89\t      data: Buffer;\n90\t      lamports: number;\n91\t      owner: PublicKey;\n92\t      executable: boolean;\n93\t    }\n94\t  >();\n95\t  lastRawTx: Buffer | null = null;\n96\t\n97\t  set slot(s: number) {\n98\t    this._slot = s;\n99\t  }\n100\t  get slot() {\n101\t    return this._slot;\n102\t  }\n103\t\n104\t  setAccount(\n105\t    pubkey: PublicKey,\n106\t    data: Buffer,\n107\t    opts?: { lamports?: number; owner?: PublicKey },\n108\t  ) {\n109\t    this._accounts.set(pubkey.toBase58(), {\n110\t      data,\n111\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n112\t      owner: opts?.owner ?? SystemProgram.programId,\n113\t      executable: false,\n114\t    });\n115\t  }\n116\t\n117\t  removeAccount(pubkey: PublicKey) {\n118\t    this._accounts.delete(pubkey.toBase58());\n119\t  }\n120\t\n121\t  async getLatestBlockhash() {\n122\t    return {\n123\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n124\t      lastValidBlockHeight: 999_999,\n125\t    };\n126\t  }\n127\t\n128\t  async getSlot() {\n129\t    return this._slot;\n130\t  }\n131\t\n132\t  async getAccountInfo(pubkey: PublicKey) {\n133\t    const acc = this._accounts.get(pubkey.toBase58());\n134\t    if (!acc) return null;\n135\t    return { ...acc, rentEpoch: 0 };\n136\t  }\n137\t\n138\t  async getProgramAccounts(\n139\t    programId: PublicKey,\n140\t    config?: {\n141\t      filters?: Array<\n142\t        | { dataSize: number }\n143\t        | { memcmp: { offset: number; bytes: string } }\n144\t      >;\n145\t    },\n146\t  ) {\n147\t    const results: Array<{\n148\t      pubkey: PublicKey;\n149\t      account: {\n150\t        data: Buffer;\n151\t        lamports: number;\n152\t        owner: PublicKey;\n153\t        executable: boolean;\n154\t        rentEpoch: number;\n155\t      };\n156\t    }> = [];\n157\t\n158\t    for (const [key, acc] of this._accounts) {\n159\t      if (!acc.owner.equals(programId)) continue;\n160\t\n161\t      let matches = true;\n162\t      if (config?.filters) {\n163\t        for (const filter of config.filters) {\n164\t          if (\"dataSize\" in filter) {\n165\t            if (acc.data.length !== filter.dataSize) {\n166\t              matches = false;\n167\t              break;\n168\t            }\n169\t          }\n170\t          if (\"memcmp\" in filter) {\n171\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n172\t            const actual = acc.data.subarray(\n173\t              filter.memcmp.offset,\n174\t              filter.memcmp.offset + expected.length,\n175\t            );\n176\t            if (Buffer.compare(actual, expected) !== 0) {\n177\t              matches = false;\n178\t              break;\n179\t            }\n180\t          }\n181\t        }\n182\t      }\n183\t\n184\t      if (matches) {\n185\t        results.push({\n186\t          pubkey: new PublicKey(key),\n187\t          account: { ...acc, rentEpoch: 0 },\n188\t        });\n189\t      }\n190\t    }\n191\t    return results;\n192\t  }\n193\t\n194\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n195\t    this.lastRawTx = Buffer.from(rawTx);\n196\t    // Return a deterministic fake signature\n197\t    return bs58.encode(Buffer.alloc(64, 0x01));\n198\t  }\n199\t"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"12dc72a9-1a6d-4b22-ac68-6531d459346d","timestamp":"2026-04-03T19:38:06.997Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018esjLw9Czf6ERPh7eLr2yb","type":"tool_result","content":"1\t/**\n2\t * Handler registry — maps event type strings to handler functions.\n3\t *\n4\t * One handler per event type (no pub/sub fan-out for v1).\n5\t * Handlers must be idempotent — re-processing is a safe no-op.\n6\t */\n7\t\n8\timport type { EventType } from \"./event-types.js\";\n9\t\n10\texport type EventHandler = (\n11\t  payload: Record<string, unknown>,\n12\t) => Promise<void>;\n13\t\n14\tconst handlers = new Map<string, EventHandler>();\n15\t\n16\texport function registerHandler(\n17\t  eventType: EventType,\n18\t  handler: EventHandler,\n19\t): void {\n20\t  handlers.set(eventType, handler);\n21\t}\n22\t\n23\texport function getHandler(eventType: string): EventHandler | undefined {\n24\t  return handlers.get(eventType);\n25\t}\n26\t\n27\t/** Remove all registered handlers. Used by tests for isolation. */\n28\texport function clearHandlers(): void {\n29\t  handlers.clear();\n30\t}\n31\t"}]},"parent_tool_use_id":"toolu_018VhPYzbAyLvaxkyKr8pAVh","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"2cb71878-e881-4f54-8674-90a8973611bf","timestamp":"2026-04-03T19:38:06.851Z"}
