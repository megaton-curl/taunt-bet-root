{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012vgJpJ47WYyhfRXbqhrpp2","type":"tool_result","content":"1\t/**\n2\t * Event producer — inserts an event into the queue within an existing\n3\t * database transaction so the event is committed atomically with the\n4\t * triggering operation.\n5\t */\n6\t\n7\timport type postgres from \"postgres\";\n8\timport type { EventType } from \"./event-types.js\";\n9\t\n10\t/** The transaction/sql handle accepted by emitEvent — works with both sql and tx from sql.begin(). */\n11\texport type SqlOrTransaction = postgres.Sql;\n12\t\n13\texport interface EmitEventOptions {\n14\t  maxAttempts?: number; // default: 3\n15\t  scheduledAt?: Date; // default: now\n16\t}\n17\t\n18\texport async function emitEvent(\n19\t  tx: SqlOrTransaction,\n20\t  eventType: EventType,\n21\t  payload: Record<string, unknown>,\n22\t  options?: EmitEventOptions,\n23\t): Promise<{ eventId: bigint }> {\n24\t  const maxAttempts = options?.maxAttempts ?? 3;\n25\t  const scheduledAt = options?.scheduledAt ?? new Date();\n26\t\n27\t  const rows = await tx<{ id: string }[]>`\n28\t    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n29\t    VALUES (${eventType}, ${tx.json(payload as postgres.JSONValue)}, ${maxAttempts}, ${scheduledAt})\n30\t    RETURNING id\n31\t  `;\n32\t\n33\t  return { eventId: BigInt(rows[0]!.id) };\n34\t}\n35\t"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"029058fd-b9c9-40e0-8a53-6617148bd9ed","timestamp":"2026-04-03T19:38:47.456Z"}
