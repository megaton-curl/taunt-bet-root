{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QtZzLD3DpaCNiTQ3QAqMQm","type":"tool_result","content":"400\t    resetPlatformConfigCache();\n401\t\n402\t    // Fresh mock Connection\n403\t    mockConn = new MockConnection();\n404\t\n405\t    // Pre-populate mock with entropy and config accounts\n406\t    mockConn.setAccount(entropyAccount, entropyData);\n407\t\n408\t    const [configPda] = PublicKey.findProgramAddressSync(\n409\t      [Buffer.from(\"coinflip_config\")],\n410\t      COINFLIP_PROGRAM_ID,\n411\t    );\n412\t    mockConn.setAccount(\n413\t      configPda,\n414\t      await buildConfigAccountData(treasuryKeypair.publicKey),\n415\t      { owner: COINFLIP_PROGRAM_ID },\n416\t    );\n417\t\n418\t    // PlatformConfig account — settlement reads fee_bps from here\n419\t    const [platformConfigPda] = derivePlatformConfigPda();\n420\t    mockConn.setAccount(\n421\t      platformConfigPda,\n422\t      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n423\t      { owner: PLATFORM_PROGRAM_ID },\n424\t    );\n425\t\n426\t    // Build the Hono app (no rate limiting for tests)\n427\t    app = new Hono();\n428\t\n429\t    app.use(\n430\t      \"/coinflip/*\",\n431\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n432\t    );\n433\t\n434\t    app.route(\n435\t      \"/coinflip\",\n436\t      createCoinflipRoutes({\n437\t        db,\n438\t        connection: mockConn as unknown as Connection,\n439\t        serverKeypair,\n440\t      }),\n441\t    );\n442\t\n443\t    app.route(\"/rounds\", createRoundsRoutes({ db }));\n444\t  });\n445\t\n446\t  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n447\t    const wallet = creatorKeypair.publicKey.toBase58();\n448\t    const token = await makeJwt(wallet);\n449\t\n450\t    // ------------------------------------------------------------------\n451\t    // 1. POST /coinflip/create\n452\t    // ------------------------------------------------------------------\n453\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n454\t\n455\t    const createRes = await app.request(\"/coinflip/create\", {\n456\t      method: \"POST\",\n457\t      headers: {\n458\t        \"Content-Type\": \"application/json\",\n459\t        \"Authorization\": `Bearer ${token}`,\n460\t      },\n461\t      body: JSON.stringify(body),\n462\t    });\n463\t\n464\t    expect(createRes.status).toBe(200);\n465\t    const createJson = (await createRes.json()) as {\n466\t      transaction: string;\n467\t      matchPda: string;\n468\t      matchId: string;\n469\t      commitment: string;\n470\t      lastValidBlockHeight: number;\n471\t    };\n472\t    expect(createJson.transaction).toBeDefined();\n473\t    expect(createJson.matchPda).toBeDefined();\n474\t    expect(createJson.commitment).toBeDefined();\n475\t    expect(createJson.lastValidBlockHeight).toBeDefined();\n476\t\n477\t    const matchPda = createJson.matchPda;\n478\t    const commitmentHex = createJson.commitment;\n479\t    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n480\t\n481\t    // ------------------------------------------------------------------\n482\t    // 2. Verify DB state — round in \"created\" phase\n483\t    // ------------------------------------------------------------------\n484\t    const round = await db.getRoundByPda(matchPda);\n485\t    expect(round).toBeDefined();\n486\t    expect(round!.phase).toBe(\"created\");\n487\t    expect(round!.game).toBe(\"coinflip\");\n488\t    expect(round!.creator).toBe(wallet);\n489\t    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n490\t    expect(round!.side).toBe(SIDE_HEADS);\n491\t    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n492\t    expect(round!.secret).toBeDefined();\n493\t    expect(round!.secret.length).toBe(32);\n494\t\n495\t    // Verify operator event was logged\n496\t    const events =\n497\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n498\t    expect(events.length).toBe(1);\n499\t    expect(events[0]!.event_type).toBe(\"secret_generated\");\n500\t\n501\t    // ------------------------------------------------------------------\n502\t    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n503\t    // ------------------------------------------------------------------\n504\t    const matchPubkey = new PublicKey(matchPda);\n505\t    const targetSlot = 150n;\n506\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n507\t\n508\t    const matchAccountData = await buildMatchAccountData({\n509\t      creator: creatorKeypair.publicKey,\n510\t      opponent: opponentKeypair.publicKey,\n511\t      server: serverKeypair.publicKey,\n512\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n513\t      creatorSide: SIDE_HEADS,\n514\t      phase: PHASE_LOCKED,\n515\t      commitment: commitmentBuf,\n516\t      algorithmVer: 1,\n517\t      targetSlot,\n518\t      resolveDeadline,\n519\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n520\t    });\n521\t\n522\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n523\t      owner: COINFLIP_PROGRAM_ID,\n524\t    });\n525\t\n526\t    // Set current slot past target_slot so settlement triggers immediately\n527\t    mockConn.slot = 200;\n528\t\n529\t    // ------------------------------------------------------------------\n530\t    // 4. Create worker + retry settler, trigger poll\n531\t    // ------------------------------------------------------------------\n532\t    let settlePromise: Promise<void> | null = null;\n533\t\n534\t    const retrySettler = createRetrySettler({\n535\t      db,\n536\t      connection: mockConn as unknown as Connection,\n537\t      settleRound: (pda) =>\n538\t        settleMatch(\n539\t          {\n540\t            db,\n541\t            connection: mockConn as unknown as Connection,\n542\t            serverKeypair,\n543\t            entropyAccount,\n544\t            referralDefaultRateBps: 1000,\n545\t          },\n546\t          pda,\n547\t        ),\n548\t    });\n549\t\n550\t    const worker = createSettlementWorker({\n551\t      db,\n552\t      connection: mockConn as unknown as Connection,\n553\t      serverKey: serverKeypair.publicKey,\n554\t      pollIntervalMs: 60_000, // won't auto-poll\n555\t      onSettleReady: (pda) => {\n556\t        settlePromise = retrySettler.attemptSettle(pda);\n557\t        return settlePromise;\n558\t      },\n559\t    });\n560\t\n561\t    // Single poll cycle — should discover locked match and settle it\n562\t    await worker.poll();\n563\t    if (settlePromise) await settlePromise;\n564\t\n565\t    // ------------------------------------------------------------------\n566\t    // 5. Verify DB updated to \"settled\" with result data\n567\t    // ------------------------------------------------------------------\n568\t    const settled = await db.getRoundByPda(matchPda);\n569\t    expect(settled).toBeDefined();\n570\t    expect(settled!.phase).toBe(\"settled\");\n571\t    expect(settled!.settle_tx).toBeDefined();\n572\t    expect(settled!.result_hash).toBeDefined();\n573\t    expect(settled!.result_hash!.length).toBe(32);\n574\t    expect(settled!.result_side).toBeDefined();\n575\t    expect([0, 1]).toContain(settled!.result_side);\n576\t    expect(settled!.winner).toBeDefined();\n577\t\n578\t    // Winner should be one of the two players\n579\t    expect([\n580\t      creatorKeypair.publicKey.toBase58(),\n581\t      opponentKeypair.publicKey.toBase58(),\n582\t    ]).toContain(settled!.winner);\n583\t\n584\t    // Verify operator events trail\n585\t    const allEvents =\n586\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n587\t    const eventTypes = allEvents.map(\n588\t      (e) => (e as Record<string, unknown>).event_type,\n589\t    );\n590\t    expect(eventTypes).toContain(\"secret_generated\");\n591\t    expect(eventTypes).toContain(\"match_detected\");\n592\t    expect(eventTypes).toContain(\"settle_submitted\");\n593\t    expect(eventTypes).toContain(\"settle_confirmed\");\n594\t\n595\t    // ------------------------------------------------------------------\n596\t    // 6. GET /rounds/:pda — verify response includes secret\n597\t    // ------------------------------------------------------------------\n598\t    const roundsRes = await app.request(`/rounds/${matchPda}`);\n599\t    expect(roundsRes.status).toBe(200);"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"e48874ce-1513-47a9-ab94-ab8ef7c87580","timestamp":"2026-04-03T19:38:14.219Z"}
