ner: winner.toBase58(),\n475\t    timing: {\n476\t      dbMs: Math.round(tDb - t0),\n477\t      fetchMs: Math.round(tFetch - tDb),\n478\t      buildMs: Math.round(tBuild - tFetch),\n479\t      sendMs: Math.round(tSend - tBuild),\n480\t      confirmMs: Math.round(tConfirm - tSend),\n481\t      dbWriteMs: Math.round(tDone - tConfirm),\n482\t      totalMs: Math.round(tDone - t0),\n483\t    },\n484\t  });\n485\t\n486\t  return {\n487\t    txSignature,\n488\t    resultHash,\n489\t    resultSide,\n490\t    winner: winner.toBase58(),\n491\t  };\n492\t}\n493\t\n494\texport async function settleLordRound(\n495\t  deps: SettleTxDeps,\n496\t  pda: string,\n497\t): Promise<SettleResult> {\n498\t  const t0 = performance.now();\n499\t  const { db, connection, serverKeypair, entropyAccount } = deps;\n500\t  const roundPubkey = new PublicKey(pda);\n501\t\n502\t  const round = await db.getRoundByPda(pda);\n503\t  const tDb = performance.now();\n504\t  if (!round) {\n505\t    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n506\t  }\n507\t  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n508\t    throw new PermanentSettleError(\n509\t      `Round ${pda} in unexpected phase: ${round.phase}`,\n510\t    );\n511\t  }\n512\t\n513\t  const secret = Buffer.from(round.secret);\n514\t\n515\t  if (round.phase === \"locked\") {\n516\t    await db.updateRoundPhase(pda, \"settling\");\n517\t  }\n518\t\n519\t  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n520\t    attempt: round.settle_attempts + 1,\n521\t    game: \"lord\",\n522\t  });\n523\t\n524\t  const [platformConfigPda] = derivePlatformConfigPda();\n525\t  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n526\t    await Promise.all([\n527\t      connection.getAccountInfo(roundPubkey),\n528\t      getPlatformConfig(connection),\n529\t      connection.getAccountInfo(entropyAccount),"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-411