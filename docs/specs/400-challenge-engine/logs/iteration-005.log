{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RE1ZW72VhhWz2CEYnxfzyd","type":"tool_result","content":"150\texport interface ReferralEarning {\n151\t  id: number;\n152\t  referrer_user_id: string;\n153\t  referee_user_id: string;\n154\t  referrer_wallet: string;\n155\t  referee_wallet: string;\n156\t  round_id: string;\n157\t  game_type: string;\n158\t  wager_lamports: number;\n159\t  fee_lamports: number;\n160\t  referrer_earned_lamports: number;\n161\t  referrer_rate_bps: number;\n162\t  referee_rebate_lamports: number;\n163\t  referee_rebate_rate_bps: number;\n164\t  created_at: Date;\n165\t}\n166\t\n167\texport interface ReferralStats {\n168\t  referred_count: number;\n169\t  active_count: number;\n170\t  total_volume_lamports: string;\n171\t  total_earned_lamports: string;\n172\t  total_rebate_lamports: string;\n173\t  pending_lamports: string;\n174\t}\n175\t\n176\texport interface ReferralClaim {\n177\t  id: string;\n178\t  user_id: string;\n179\t  wallet: string;\n180\t  amount_lamports: string;\n181\t  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n182\t  retry_count: number;\n183\t  tx_signature: string | null;\n184\t  error: string | null;\n185\t  requested_at: Date;\n186\t  processed_at: Date | null;\n187\t}\n188\t\n189\t// ---------------------------------------------------------------------------\n190\t// Player profile types\n191\t// ---------------------------------------------------------------------------\n192\t\n193\texport interface PlayerProfile {\n194\t  id: number;\n195\t  user_id: string;\n196\t  wallet: string;\n197\t  username: string;\n198\t  username_updated_at: Date | null;\n199\t  avatar_url: string | null;\n200\t  heat_multiplier: number;\n201\t  points_balance: number;\n202\t  created_at: Date;\n203\t}\n204\t\n205\texport interface PlayerStats {\n206\t  gamesPlayed: number;\n207\t  totalWagered: bigint;\n208\t  totalWins: number;\n209\t  winRate: number;\n210\t  netPnl: bigint;\n211\t}\n212\t\n213\texport interface PublicPlayerStats {\n214\t  gamesPlayed: number;\n215\t  totalWins: number;\n216\t  winRate: number;\n217\t}\n218\t\n219\texport interface WinStreaks {\n220\t  current: number;\n221\t  best: number;\n222\t}\n223\t\n224\texport interface GameBreakdownStats {\n225\t  gamesPlayed: number;\n226\t  totalWagered: bigint;\n227\t  totalWins: number;\n228\t  winRate: number;\n229\t  netPnl: bigint;\n230\t}\n231\t\n232\t// ---------------------------------------------------------------------------\n233\t// Game entries — single source of truth for participation + stats + leaderboard\n234\t// Written at participation time (create/bet), updated at settlement via UPSERT.\n235\t// ---------------------------------------------------------------------------\n236\t\n237\texport interface GameEntryUpsert {\n238\t  userId: string;\n239\t  wallet: string;\n240\t  game: string;\n241\t  roundPda: string;\n242\t  matchId: string;\n243\t  amountLamports: number;\n244\t  side?: string;\n245\t  isWinner?: boolean;       // null at participation time, null for refunds\n246\t  payoutLamports?: number;\n247\t  settledAt?: Date;\n248\t}\n249\t\n250\t/** @deprecated Use GameEntryUpsert instead */\n251\texport type GameEntryInsert = GameEntryUpsert;\n252\t\n253\texport interface GameEntry {\n254\t  id: number;\n255\t  userId: string;\n256\t  wallet: string;\n257\t  game: string;\n258\t  roundPda: string;\n259\t  matchId: string;\n260\t  amountLamports: number;\n261\t  side: string | null;\n262\t  isWinner: boolean | null;\n263\t  payoutLamports: number;\n264\t  createdAt: Date;\n265\t  settledAt: Date | null;\n266\t}\n267\t\n268\texport interface CloseCallCandle {\n269\t  minuteTs: number;\n270\t  price: bigint;\n271\t  expo: number;\n272\t  priceHuman: number;\n273\t}\n274\t\n275\texport interface LeaderboardEntry {\n276\t  rank: number;\n277\t  userId: string;\n278\t  username: string;\n279\t  avatarUrl: string | null;\n280\t  totalWagered: bigint;\n281\t  gamesPlayed: number;\n282\t  totalWins: number;\n283\t  winRate: number;\n284\t  netPnl: bigint;\n285\t}\n286\t\n287\texport interface LeaderboardResult {\n288\t  entries: LeaderboardEntry[];\n289\t  weekStart: string; // ISO date string (Monday 00:00 UTC)\n290\t  weekEnd: string;   // ISO date string (next Monday 00:00 UTC)\n291\t}\n292\t\n293\t// ---------------------------------------------------------------------------\n294\t// Phase transition guard\n295\t// ---------------------------------------------------------------------------\n296\t\n297\t/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n298\tconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n299\t  created: [\"locked\", \"expired\"],\n300\t  locked: [\"settling\"],\n301\t  settling: [\"settled\"],\n302\t  settled: [],\n303\t  expired: [],\n304\t};\n305\t\n306\tfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n307\t  const allowed = VALID_TRANSITIONS[from];\n308\t  if (!allowed.includes(to)) {\n309\t    throw new Error(\n310\t      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n311\t    );\n312\t  }\n313\t}\n314\t\n315\t// ---------------------------------------------------------------------------\n316\t// DB client\n317\t// ---------------------------------------------------------------------------\n318\t\n319\texport interface Db {\n320\t  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n321\t  insertRound(params: InsertRoundParams): Promise<Round>;\n322\t\n323\t  /** Delete a round by PDA. Returns true if a row was removed. */\n324\t  deleteRoundByPda(pda: string): Promise<boolean>;\n325\t\n326\t  /** Transition a round's phase. Enforces unidirectional state machine.\n327\t   *  Optional `updates` can set additional columns alongside the phase change. */\n328\t  updateRoundPhase(\n329\t    pda: string,\n330\t    newPhase: RoundPhase,\n331\t    updates?: Partial<\n332\t      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n333\t    >,\n334\t  ): Promise<Round>;\n335\t\n336\t  /** Get a single round by its PDA. Returns `undefined` if not found. */\n337\t  getRoundByPda(pda: string): Promise<Round | undefined>;\n338\t\n339\t  /** Get all rounds matching a given phase. */\n340\t  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n341\t\n342\t  /** Append an operator event to the audit log. */\n343\t  insertOperatorEvent(\n344\t    pda: string | null,\n345\t    eventType: OperatorEventType,\n346\t    payload?: unknown,\n347\t  ): Promise<OperatorEvent>;\n348\t\n349\t  /** Get the latest operator event for a PDA + type. */"}]},"parent_tool_use_id":"toolu_018VhPYzbAyLvaxkyKr8pAVh","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"c4341b58-e24e-4368-b61e-855464c11b9c","timestamp":"2026-04-03T19:38:13.013Z"}
