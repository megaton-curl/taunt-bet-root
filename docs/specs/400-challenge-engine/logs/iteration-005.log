{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HppLTfRZiWsTcEcwXiNQTm","type":"tool_result","content":"0\t/**\n1\t * Database client module — typed query functions for `rounds` and `operator_events`.\n2\t *\n3\t * Phase transitions are unidirectional: created → locked → settling → settled,\n4\t * or created → expired. The application layer rejects backward transitions.\n5\t */\n6\t\n7\timport postgres from \"postgres\";\n8\timport { generateUserId, generateUsername } from \"./utils/username-gen.js\";\n9\t\n10\t// ---------------------------------------------------------------------------\n11\t// Types\n12\t// ---------------------------------------------------------------------------\n13\t\n14\texport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n15\t\n16\texport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n17\texport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n18\t\n19\texport interface CloseCallRound {\n20\t  round_id: string;\n21\t  pda: string;\n22\t  server_key: string;\n23\t  phase: CloseCallPhase;\n24\t  open_price: number;\n25\t  open_price_expo: number;\n26\t  close_price: number | null;\n27\t  outcome: CloseCallOutcome;\n28\t  green_pool: number;\n29\t  red_pool: number;\n30\t  total_fee: number;\n31\t  green_entries: Array<{ player: string; amountLamports: number }>; // populated via JOIN on game_entries\n32\t  red_entries: Array<{ player: string; amountLamports: number }>;   // populated via JOIN on game_entries\n33\t  settle_tx: string | null;\n34\t  created_at: Date;\n35\t  settled_at: Date | null;\n36\t}\n37\t\n38\texport interface InsertCloseCallRoundParams {\n39\t  roundId: string;\n40\t  pda: string;\n41\t  serverKey: string;\n42\t  openPrice: number;\n43\t  openPriceExpo: number;\n44\t}\n45\t\n46\texport type OperatorEventType =\n47\t  | \"secret_generated\"\n48\t  | \"tx_built\"\n49\t  | \"match_detected\"\n50\t  | \"settle_submitted\"\n51\t  | \"settle_confirmed\"\n52\t  | \"settle_failed\"\n53\t  | \"settle_retried\"\n54\t  | \"timeout_detected\";\n55\t\n56\texport interface Round {\n57\t  pda: string;\n58\t  game: string;\n59\t  creator: string;\n60\t  server_key: string;\n61\t  secret: Buffer;\n62\t  commitment: Buffer;\n63\t  amount_lamports: number;\n64\t  side: number;\n65\t  match_id: string;\n66\t  phase: RoundPhase;\n67\t  target_slot: string | null;\n68\t  settle_tx: string | null;\n69\t  settle_attempts: number;\n70\t  result_hash: Buffer | null;\n71\t  result_side: number | null;\n72\t  winner: string | null;\n73\t  entries: Array<{ player: string; amountLamports: number }> | null; // populated via JOIN on game_entries\n74\t  created_at: Date;\n75\t  updated_at: Date;\n76\t  settled_at: Date | null;\n77\t}\n78\t\n79\texport interface InsertRoundParams {\n80\t  pda: string;\n81\t  game: string;\n82\t  creator: string;\n83\t  serverKey: string;\n84\t  secret: Buffer;\n85\t  commitment: Buffer;\n86\t  amountLamports: number;\n87\t  side: number;\n88\t  matchId: string;\n89\t  phase: RoundPhase;\n90\t}\n91\t\n92\texport interface OperatorEvent {\n93\t  id: string;\n94\t  pda: string | null;\n95\t  event_type: OperatorEventType;\n96\t  payload: unknown;\n97\t  created_at: Date;\n98\t}\n99\t\n100\t// ---------------------------------------------------------------------------\n101\t// Transaction types\n102\t// ---------------------------------------------------------------------------\n103\t\n104\texport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n105\t\n106\texport interface Transaction {\n107\t  id: string;\n108\t  wallet: string;\n109\t  game: string;\n110\t  match_id: string;\n111\t  tx_type: TransactionType;\n112\t  amount_lamports: number;\n113\t  tx_sig: string;\n114\t  created_at: Date;\n115\t}\n116\t\n117\texport interface InsertTransactionParams {\n118\t  userId?: string;\n119\t  wallet: string;\n120\t  game: string;\n121\t  matchId: string;\n122\t  txType: TransactionType;\n123\t  amountLamports: number;\n124\t  txSig: string;\n125\t}\n126\t\n127\t// ---------------------------------------------------------------------------\n128\t// Referral types\n129\t// ---------------------------------------------------------------------------\n130\t\n131\texport interface ReferralCode {\n132\t  id: number;\n133\t  user_id: string;\n134\t  wallet: string;\n135\t  code: string;\n136\t  created_at: Date;\n137\t  updated_at: Date;\n138\t}\n139\t\n140\texport interface ReferralLink {\n141\t  id: number;\n142\t  referrer_user_id: string;\n143\t  referee_user_id: string;\n144\t  referrer_wallet: string;\n145\t  referee_wallet: string;\n146\t  created_at: Date;\n147\t}\n148\t\n149\texport interface ReferralEarning {"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"155c5951-48c8-4065-97a5-b48238a97f6b","timestamp":"2026-04-03T19:38:22.169Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PKwrRJ6q6UEnJkQKDLD46e","type":"tool_result","content":"import { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\nimport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Single postgres pool shared by game DB, auth DB, and all workers\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl, sql);\nconst authDb = createAuthDb(sql);\n\n--\nregisterHandler(\n  EventTypes.REFERRAL_CLAIM_REQUESTED,\n  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\n\n// Event queue worker — processes async side-effects (rewards, notifications, etc.)\nconst eventWorker = createEventWorker(sql, {\n  pollIntervalMs: config.eventQueuePollMs,\n});\neventWorker.start();\nlogger.info(\"Event queue worker started\", {","is_error":false}]},"parent_tool_use_id":"toolu_018VhPYzbAyLvaxkyKr8pAVh","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"f0e72df8-6792-4411-9c49-481c99a8b240","timestamp":"2026-04-03T19:38:22.201Z"}
