{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015nmhiQrmCbD4iiGSUAPVAU","type":"tool_result","content":"1\t/**\n2\t * Known event type constants for the async event queue.\n3\t *\n4\t * Using a const object + derived union makes typos a compile error\n5\t * instead of a dead event at runtime.\n6\t */\n7\t\n8\texport const EventTypes = {\n9\t  REFERRAL_CODE_APPLIED: \"referral.code_applied\",\n10\t  REFERRAL_GAME_SETTLED: \"referral.game_settled\",\n11\t  REFERRAL_CLAIM_REQUESTED: \"referral.claim_requested\",\n12\t  GAME_SETTLED: \"game.settled\",\n13\t  REWARD_POOL_FUND: \"reward.pool_fund\",\n14\t  POINTS_GRANT: \"points.grant\",\n15\t  CRATE_DROP: \"crate.drop\",\n16\t  CRATE_SOL_PAYOUT: \"crate.sol_payout\",\n17\t} as const;\n18\t\n19\texport type EventType = (typeof EventTypes)[keyof typeof EventTypes];\n20\t"}]},"parent_tool_use_id":"toolu_018VhPYzbAyLvaxkyKr8pAVh","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"91686740-75cd-48fe-bcc8-407a1a704741","timestamp":"2026-04-03T19:38:07.250Z"}
