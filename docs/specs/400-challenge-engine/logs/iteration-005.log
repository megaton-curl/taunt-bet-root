{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01AN5BmzNRP1jUvbBtPCJxdx","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Mc14d5quheUqR82QBqzwQY","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","limit":200,"offset":600},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":5167,"cache_read_input_tokens":34516,"cache_creation":{"ephemeral_5m_input_tokens":5167,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"ce9dcbb9-7096-4d06-a454-7f47a6830612"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mc14d5quheUqR82QBqzwQY","type":"tool_result","content":"600\t\n601\t    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n602\t    expect(roundsJson.pda).toBe(matchPda);\n603\t    expect(roundsJson.phase).toBe(\"settled\");\n604\t    expect(roundsJson.game).toBe(\"coinflip\");\n605\t    expect(roundsJson.creator).toBe(wallet);\n606\t    expect(roundsJson.commitment).toBe(commitmentHex);\n607\t\n608\t    // Settled round should include secret + verification payload\n609\t    expect(roundsJson.secret).toBeDefined();\n610\t    expect(typeof roundsJson.secret).toBe(\"string\");\n611\t    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n612\t    expect(roundsJson.resultHash).toBeDefined();\n613\t    expect(roundsJson.resultSide).toBeDefined();\n614\t    expect(roundsJson.winner).toBeDefined();\n615\t    expect(roundsJson.settleTx).toBeDefined();\n616\t\n617\t    // Verification object\n618\t    const verification = roundsJson.verification as Record<string, string>;\n619\t    expect(verification).toBeDefined();\n620\t    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n621\t    expect(verification.resultFormula).toContain(\"sha256(secret\");\n622\t    expect(verification.entropySource).toContain(\"SlotHashes\");\n623\t  });\n624\t\n625\t  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n626\t    const unknownPda = Keypair.generate().publicKey.toBase58();\n627\t    const res = await app.request(`/rounds/${unknownPda}`);\n628\t    expect(res.status).toBe(404);\n629\t  });\n630\t\n631\t  it(\"unsettled round does not expose secret\", async () => {\n632\t    const wallet = creatorKeypair.publicKey.toBase58();\n633\t    const token = await makeJwt(wallet);\n634\t\n635\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n636\t\n637\t    const res = await app.request(\"/coinflip/create\", {\n638\t      method: \"POST\",\n639\t      headers: {\n640\t        \"Content-Type\": \"application/json\",\n641\t        \"Authorization\": `Bearer ${token}`,\n642\t      },\n643\t      body: JSON.stringify(body),\n644\t    });\n645\t    expect(res.status).toBe(200);\n646\t    const json = (await res.json()) as { matchPda: string };\n647\t\n648\t    // GET the unsettled round\n649\t    const roundRes = await app.request(`/rounds/${json.matchPda}`);\n650\t    expect(roundRes.status).toBe(200);\n651\t    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n652\t    expect(roundJson.phase).toBe(\"created\");\n653\t    expect(roundJson.secret).toBeUndefined();\n654\t    expect(roundJson.resultHash).toBeUndefined();\n655\t    expect(roundJson.verification).toBeUndefined();\n656\t  });\n657\t\n658\t  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n659\t    const wallet = creatorKeypair.publicKey.toBase58();\n660\t    const token = await makeJwt(wallet);\n661\t\n662\t    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n663\t    const res1 = await app.request(\"/coinflip/create\", {\n664\t      method: \"POST\",\n665\t      headers: {\n666\t        \"Content-Type\": \"application/json\",\n667\t        \"Authorization\": `Bearer ${token}`,\n668\t      },\n669\t      body: JSON.stringify(body1),\n670\t    });\n671\t    expect(res1.status).toBe(200);\n672\t\n673\t    // Second request — different random matchId generated server-side\n674\t    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n675\t    const res2 = await app.request(\"/coinflip/create\", {\n676\t      method: \"POST\",\n677\t      headers: {\n678\t        \"Content-Type\": \"application/json\",\n679\t        \"Authorization\": `Bearer ${token}`,\n680\t      },\n681\t      body: JSON.stringify(body2),\n682\t    });\n683\t    expect(res2.status).toBe(200);\n684\t\n685\t    // Both should have different matchIds and PDAs\n686\t    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n687\t    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n688\t    expect(json1.matchPda).not.toBe(json2.matchPda);\n689\t    expect(json1.matchId).not.toBe(json2.matchId);\n690\t  });\n691\t\n692\t  it(\"settlement records referral earnings for referred player\", async () => {\n693\t    // Referrer is a third party; opponent is the referred player\n694\t    const referrerKeypair = Keypair.generate();\n695\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n696\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n697\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n698\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n699\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n700\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n701\t    const referrerUserId = referrerProfile.user_id;\n702\t    const opponentUserId = opponentProfile.user_id;\n703\t    const creatorUserId = creatorProfile.user_id;\n704\t\n705\t    // Set up referral link: referrer → opponent (opponent is the referee)\n706\t    await db.insertReferralCode(referrerUserId, referrerWallet, \"test-ref\");\n707\t    await db.insertReferralLink({\n708\t      referrerUserId,\n709\t      refereeUserId: opponentUserId,\n710\t      referrerWallet,\n711\t      refereeWallet: opponentWallet,\n712\t    });\n713\t\n714\t    // 1. Create a coinflip match\n715\t    const token = await makeJwt(creatorWallet, creatorUserId);\n716\t    const createRes = await app.request(\"/coinflip/create\", {\n717\t      method: \"POST\",\n718\t      headers: {\n719\t        \"Content-Type\": \"application/json\",\n720\t        \"Authorization\": `Bearer ${token}`,\n721\t      },\n722\t      body: JSON.stringify({\n723\t        wallet: creatorWallet,\n724\t        amountLamports: AMOUNT_LAMPORTS,\n725\t        side: SIDE_HEADS,\n726\t      }),\n727\t    });\n728\t    expect(createRes.status).toBe(200);\n729\t    const createJson = (await createRes.json()) as {\n730\t      matchPda: string;\n731\t      matchId: string;\n732\t      commitment: string;\n733\t    };\n734\t\n735\t    // 2. Simulate on-chain join (opponent joins the match)\n736\t    const matchPubkey = new PublicKey(createJson.matchPda);\n737\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n738\t    const targetSlot = 150n;\n739\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n740\t\n741\t    const matchAccountData = await buildMatchAccountData({\n742\t      creator: creatorKeypair.publicKey,\n743\t      opponent: opponentKeypair.publicKey,\n744\t      server: serverKeypair.publicKey,\n745\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n746\t      creatorSide: SIDE_HEADS,\n747\t      phase: PHASE_LOCKED,\n748\t      commitment: commitmentBuf,\n749\t      algorithmVer: 1,\n750\t      targetSlot,\n751\t      resolveDeadline,\n752\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n753\t    });\n754\t\n755\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n756\t      owner: COINFLIP_PROGRAM_ID,\n757\t    });\n758\t    mockConn.slot = 200;\n759\t\n760\t    // 3. Settle the match\n761\t    let settlePromise: Promise<void> | null = null;\n762\t\n763\t    const retrySettler = createRetrySettler({\n764\t      db,\n765\t      connection: mockConn as unknown as Connection,\n766\t      settleRound: (pda) =>\n767\t        settleMatch(\n768\t          {\n769\t            db,\n770\t            connection: mockConn as unknown as Connection,\n771\t            serverKeypair,\n772\t            entropyAccount,\n773\t            referralDefaultRateBps: 1000,\n774\t          },\n775\t          pda,\n776\t        ),\n777\t    });\n778\t\n779\t    const worker = createSettlementWorker({\n780\t      db,\n781\t      connection: mockConn as unknown as Connection,\n782\t      serverKey: serverKeypair.publicKey,\n783\t      pollIntervalMs: 60_000,\n784\t      onSettleReady: (pda) => {\n785\t        settlePromise = retrySettler.attemptSettle(pda);\n786\t        return settlePromise;\n787\t      },\n788\t    });\n789\t\n790\t    await worker.poll();\n791\t    if (settlePromise) await settlePromise;\n792\t\n793\t    // 4. Verify match settled\n794\t    const settled = await db.getRoundByPda(createJson.matchPda);\n795\t    expect(settled).toBeDefined();\n796\t    expect(settled!.phase).toBe(\"settled\");\n797\t\n798\t    // 5. Verify referral earnings recorded for the opponent (the referee)\n799\t    // Expected: wager=5_000_000, fee=5_000_000*500/10_000=250_000"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"47d70bbd-55e2-4624-9444-b3cb2267595b","timestamp":"2026-04-03T19:38:16.668Z"}
