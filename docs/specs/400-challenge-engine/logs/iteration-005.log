{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017ArzqthCSqDeg4uZQPa8Vu","type":"tool_result","content":"1000\t    // Settle directly\n1001\t    await settleMatch(\n1002\t      {\n1003\t        db,\n1004\t        connection: mockConn as unknown as Connection,\n1005\t        serverKeypair,\n1006\t        entropyAccount,\n1007\t        referralDefaultRateBps: 1000,\n1008\t      },\n1009\t      createJson.matchPda,\n1010\t    );\n1011\t\n1012\t    // Verify game.settled event was emitted in event_queue\n1013\t    const events = await rawSql`\n1014\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1015\t    `;\n1016\t    expect(events.length).toBe(1);\n1017\t\n1018\t    const evt = events[0]!;\n1019\t    expect(evt.status).toBe(\"pending\");\n1020\t\n1021\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1022\t    const payload = evt.payload as any;\n1023\t    expect(payload.roundId).toBe(createJson.matchId);\n1024\t    expect(payload.roundPda).toBe(createJson.matchPda);\n1025\t    expect(payload.game).toBe(\"coinflip\");\n1026\t    expect(payload.feeLamports).toBeDefined();\n1027\t    expect(payload.settledAt).toBeDefined();\n1028\t\n1029\t    // Players array\n1030\t    expect(payload.players).toHaveLength(2);\n1031\t    const creator = payload.players.find(\n1032\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1033\t      (p: any) => p.wallet === creatorKeypair.publicKey.toBase58(),\n1034\t    );\n1035\t    const opponent = payload.players.find(\n1036\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1037\t      (p: any) => p.wallet === opponentKeypair.publicKey.toBase58(),\n1038\t    );\n1039\t    expect(creator).toBeDefined();\n1040\t    expect(opponent).toBeDefined();\n1041\t    expect(creator.isCreator).toBe(true);\n1042\t    expect(opponent.isCreator).toBe(false);\n1043\t    expect(creator.userId).toBe(creatorUserId);\n1044\t    expect(opponent.userId).toBe(opponentUserId);\n1045\t    // Amounts are string-encoded lamports\n1046\t    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n1047\t    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n1048\t    // Exactly one winner\n1049\t    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n1050\t    // Winner has payoutLamports > 0, loser has \"0\"\n1051\t    const winnerPlayer = creator.isWinner ? creator : opponent;\n1052\t    const loserPlayer = creator.isWinner ? opponent : creator;\n1053\t    expect(Number(winnerPlayer.payoutLamports)).toBeGreaterThan(0);\n1054\t    expect(loserPlayer.payoutLamports).toBe(\"0\");\n1055\t    // Fee = pool * 500 / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n1056\t    expect(payload.feeLamports).toBe(String(500_000));\n1057\t  });\n1058\t\n1059\t  it(\"duplicate settlement retry produces duplicate game.settled event rows safely\", async () => {\n1060\t    const wallet = creatorKeypair.publicKey.toBase58();\n1061\t    const token = await makeJwt(wallet);\n1062\t\n1063\t    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n1064\t    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n1065\t    await rawSql`\n1066\t      INSERT INTO player_profiles (user_id, wallet, username)\n1067\t      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n1068\t      ON CONFLICT (user_id) DO NOTHING\n1069\t    `;\n1070\t    await rawSql`\n1071\t      INSERT INTO player_profiles (user_id, wallet, username)\n1072\t      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n1073\t      ON CONFLICT (user_id) DO NOTHING\n1074\t    `;\n1075\t\n1076\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n1077\t    const createRes = await app.request(\"/coinflip/create\", {\n1078\t      method: \"POST\",\n1079\t      headers: {\n1080\t        \"Content-Type\": \"application/json\",\n1081\t        Authorization: `Bearer ${token}`,\n1082\t      },\n1083\t      body: JSON.stringify(body),\n1084\t    });\n1085\t    expect(createRes.status).toBe(200);\n1086\t    const createJson = (await createRes.json()) as {\n1087\t      matchPda: string;\n1088\t      matchId: string;\n1089\t      commitment: string;\n1090\t    };\n1091\t\n1092\t    const matchPubkey = new PublicKey(createJson.matchPda);\n1093\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n1094\t    const matchAccountData = await buildMatchAccountData({\n1095\t      creator: creatorKeypair.publicKey,\n1096\t      opponent: opponentKeypair.publicKey,\n1097\t      server: serverKeypair.publicKey,\n1098\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n1099\t      creatorSide: SIDE_HEADS,\n1100\t      phase: PHASE_LOCKED,\n1101\t      commitment: commitmentBuf,\n1102\t      algorithmVer: 1,\n1103\t      targetSlot: 150n,\n1104\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n1105\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n1106\t    });\n1107\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n1108\t      owner: COINFLIP_PROGRAM_ID,\n1109\t    });\n1110\t\n1111\t    // Transition DB round to \"locked\"\n1112\t    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n1113\t\n1114\t    // First settle\n1115\t    await settleMatch(\n1116\t      {\n1117\t        db,\n1118\t        connection: mockConn as unknown as Connection,\n1119\t        serverKeypair,\n1120\t        entropyAccount,\n1121\t        referralDefaultRateBps: 1000,\n1122\t      },\n1123\t      createJson.matchPda,\n1124\t    );\n1125\t\n1126\t    // Second settle attempt — should fail on phase check (already settled),\n1127\t    // but the first call already produced the event. Verify 1 event row exists.\n1128\t    const events = await rawSql`\n1129\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1130\t    `;\n1131\t    expect(events.length).toBe(1);\n1132\t\n1133\t    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n1134\t    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n1135\t    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n1136\t    // The first settle succeeded; a retry would be rejected by phase check before reaching\n1137\t    // the DB transaction. This test confirms the first call produces exactly 1 event.\n1138\t  });\n1139\t\n1140\t  it(\"closecall settlement emits game.settled event with correct payload shape\", async () => {\n1141\t    // Two players: one green, one red\n1142\t    const greenPlayer = Keypair.generate();\n1143\t    const redPlayer = Keypair.generate();\n1144\t    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());\n1145\t    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n1146\t\n1147\t    // Insert player profiles\n1148\t    await rawSql`\n1149\t      INSERT INTO player_profiles (user_id, wallet, username)\n1150\t      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n1151\t      ON CONFLICT (user_id) DO NOTHING\n1152\t    `;\n1153\t    await rawSql`\n1154\t      INSERT INTO player_profiles (user_id, wallet, username)\n1155\t      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n1156\t      ON CONFLICT (user_id) DO NOTHING\n1157\t    `;\n1158\t\n1159\t    // Create a round with minuteTs = 2 minutes ago (candle is closed)\n1160\t    const nowSec = Math.floor(Date.now() / 1000);\n1161\t    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n1162\t    const greenAmount = 5_000_000n;\n1163\t    const redAmount = 5_000_000n;\n1164\t    const openPrice = 69500_00n; // $69500.00 with expo -2\n1165\t\n1166\t    // Derive round PDA (seeds: [\"round\", minute_ts as LE i64, server pubkey])\n1167\t    const minuteTsBuf = Buffer.alloc(8);\n1168\t    minuteTsBuf.writeBigInt64LE(minuteTs);\n1169\t    const [roundPda] = PublicKey.findProgramAddressSync(\n1170\t      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n1171\t      CLOSECALL_PROGRAM_ID,\n1172\t    );\n1173\t\n1174\t    // Build on-chain round account data (phase=Open, with entries)\n1175\t    const roundAccountData = await encodeCloseCallRound({\n1176\t      minuteTs,\n1177\t      server: serverKeypair.publicKey,\n1178\t      phase: 0, // Open\n1179\t      greenEntries: [{ player: greenPlayer.publicKey, amountLamports: greenAmount }],\n1180\t      redEntries: [{ player: redPlayer.publicKey, amountLamports: redAmount }],\n1181\t      greenPool: greenAmount,\n1182\t      redPool: redAmount,\n1183\t      openPrice,\n1184\t      openPriceExpo: -2,\n1185\t      closePrice: 0n,\n1186\t      createdAt: minuteTs,\n1187\t      bettingEndsAt: minuteTs + 45n,\n1188\t      resolveDeadline: minuteTs + 300n,\n1189\t      outcome: 0, // Pending\n1190\t      totalFee: 0n,\n1191\t      bump: 0,\n1192\t    });\n1193\t\n1194\t    mockConn.setAccount(roundPda, roundAccountData, {\n1195\t      owner: CLOSECALL_PROGRAM_ID,\n1196\t    });\n1197\t\n1198\t    // Mock Hermes: returns a price > openPrice so outcome = green\n1199\t    // publishTime must be >= current minute boundary so captureBoundaryPrice() succeeds immediately"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"b437dab9-d17c-4c33-affa-2a208a3c31b1","timestamp":"2026-04-03T19:38:19.198Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01McaXNR7sBqrcxRPaDUb3Ca","type":"tool_result","content":"1200\t    const closePrice = 69600_00n; // $69600.00\n1201\t    const mockHermes: HermesFetcher = {\n1202\t      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n1203\t        price: closePrice,\n1204\t        expo: -2,\n1205\t        publishTime: Math.floor(Date.now() / 1000), // always \"current\"\n1206\t        priceHuman: 69600.0,\n1207\t        vaaBase64: null,\n1208\t      }),\n1209\t    };\n1210\t\n1211\t    // Create clock worker with mock deps\n1212\t    const clock = createCloseCallClockWorker({\n1213\t      connection: mockConn as unknown as Connection,\n1214\t      serverKeypair,\n1215\t      db,\n1216\t      hermesFetcher: mockHermes,\n1217\t    });\n1218\t\n1219\t    // Call tick() — discovers the open round, captures boundary price, settles\n1220\t    await clock.tick();\n1221\t\n1222\t    // Verify game.settled event was emitted in event_queue\n1223\t    const events = await rawSql`\n1224\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1225\t    `;\n1226\t    expect(events.length).toBe(1);\n1227\t\n1228\t    const evt = events[0]!;\n1229\t    expect(evt.status).toBe(\"pending\");\n1230\t\n1231\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1232\t    const payload = evt.payload as any;\n1233\t    expect(payload.roundId).toBe(String(Number(minuteTs)));\n1234\t    expect(payload.roundPda).toBe(roundPda.toBase58());\n1235\t    expect(payload.game).toBe(\"closecall\");\n1236\t    expect(payload.feeLamports).toBeDefined();\n1237\t    expect(payload.settledAt).toBeDefined();\n1238\t\n1239\t    // Players array — both players should be present\n1240\t    expect(payload.players).toHaveLength(2);\n1241\t    const greenP = payload.players.find(\n1242\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1243\t      (p: any) => p.wallet === greenPlayer.publicKey.toBase58(),\n1244\t    );\n1245\t    const redP = payload.players.find(\n1246\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1247\t      (p: any) => p.wallet === redPlayer.publicKey.toBase58(),\n1248\t    );\n1249\t    expect(greenP).toBeDefined();\n1250\t    expect(redP).toBeDefined();\n1251\t    expect(greenP.userId).toBe(greenUserId);\n1252\t    expect(redP.userId).toBe(redUserId);\n1253\t    // Amounts are string-encoded lamports\n1254\t    expect(greenP.amountLamports).toBe(String(greenAmount));\n1255\t    expect(redP.amountLamports).toBe(String(redAmount));\n1256\t    // Green wins (closePrice > openPrice)\n1257\t    expect(greenP.isWinner).toBe(true);\n1258\t    expect(redP.isWinner).toBe(false);\n1259\t    // Winner payout > 0, loser payout = \"0\"\n1260\t    expect(Number(greenP.payoutLamports)).toBeGreaterThan(0);\n1261\t    expect(redP.payoutLamports).toBe(\"0\");\n1262\t    // Fee = totalPool * 500 bps / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n1263\t    expect(payload.feeLamports).toBe(String(500_000));\n1264\t    // isCreator: first entry (green) is creator\n1265\t    expect(greenP.isCreator).toBe(true);\n1266\t    expect(redP.isCreator).toBe(false);\n1267\t  });\n1268\t});\n1269\t"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"60347347-afd7-4d2e-950a-b98af9f5b599","timestamp":"2026-04-03T19:38:19.267Z"}
