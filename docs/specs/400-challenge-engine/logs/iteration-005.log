{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012CGWY7Gz8pRyGusgQ7Xdw8","type":"tool_result","content":"315\t// ---------------------------------------------------------------------------\n316\t// DB client\n317\t// ---------------------------------------------------------------------------\n318\t\n319\texport interface Db {\n320\t  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n321\t  insertRound(params: InsertRoundParams): Promise<Round>;\n322\t\n323\t  /** Delete a round by PDA. Returns true if a row was removed. */\n324\t  deleteRoundByPda(pda: string): Promise<boolean>;\n325\t\n326\t  /** Transition a round's phase. Enforces unidirectional state machine.\n327\t   *  Optional `updates` can set additional columns alongside the phase change. */\n328\t  updateRoundPhase(\n329\t    pda: string,\n330\t    newPhase: RoundPhase,\n331\t    updates?: Partial<\n332\t      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n333\t    >,\n334\t  ): Promise<Round>;\n335\t\n336\t  /** Get a single round by its PDA. Returns `undefined` if not found. */\n337\t  getRoundByPda(pda: string): Promise<Round | undefined>;\n338\t\n339\t  /** Get all rounds matching a given phase. */\n340\t  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n341\t\n342\t  /** Append an operator event to the audit log. */\n343\t  insertOperatorEvent(\n344\t    pda: string | null,\n345\t    eventType: OperatorEventType,\n346\t    payload?: unknown,\n347\t  ): Promise<OperatorEvent>;\n348\t\n349\t  /** Get the latest operator event for a PDA + type. */\n350\t  getLatestOperatorEvent(\n351\t    pda: string,\n352\t    eventType: OperatorEventType,\n353\t  ): Promise<OperatorEvent | undefined>;\n354\t\n355\t  /** Get a single round by its match_id. Returns `undefined` if not found. */\n356\t  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n357\t\n358\t  /** Batch-fetch the latest operator event per PDA for a given event type. */\n359\t  getLatestOperatorEventsForPdas(\n360\t    pdas: string[],\n361\t    eventType: OperatorEventType,\n362\t  ): Promise<Map<string, OperatorEvent>>;\n363\t\n364\t  /** Get recently settled rounds for a game, ordered newest first. */\n365\t  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n366\t\n367\t  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n368\t  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n369\t\n370\t  // -------------------------------------------------------------------------\n371\t  // Close Call rounds\n372\t  // -------------------------------------------------------------------------\n373\t\n374\t  /** Insert a new Close Call round. */\n375\t  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n376\t\n377\t  /** Get a Close Call round by round_id (16-char hex). */\n378\t  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n379\t\n380\t  /** Get the current active (open) Close Call round. */\n381\t  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n382\t\n383\t  /** Get the most recent settled/refunded Close Call rounds. */\n384\t  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n385\t\n386\t  /** Update a Close Call round after settlement. */\n387\t  settleCloseCallRound(\n388\t    roundId: string,\n389\t    updates: {\n390\t      phase: CloseCallPhase;\n391\t      outcome: CloseCallOutcome;\n392\t      closePrice?: number;\n393\t      greenPool?: number;\n394\t      redPool?: number;\n395\t      totalFee?: number;\n396\t      settleTx?: string;\n397\t    },\n398\t  ): Promise<CloseCallRound>;\n399\t\n400\t  // -------------------------------------------------------------------------\n401\t  // Transactions\n402\t  // -------------------------------------------------------------------------\n403\t\n404\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n405\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n406\t\n407\t  /** Insert multiple transactions in a single batch. */\n408\t  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n409\t\n410\t  /** Get paginated transactions for a wallet, newest first. */\n411\t  getTransactions(\n412\t    wallet: string,\n413\t    cursor?: string,\n414\t    limit?: number,\n415\t    game?: string,\n416\t  ): Promise<Transaction[]>;\n417\t\n418\t  /** Get paginated transactions for an authenticated user_id, newest first. */\n419\t  getTransactionsByUserId(\n420\t    userId: string,\n421\t    cursor?: string,\n422\t    limit?: number,\n423\t    game?: string,\n424\t  ): Promise<Transaction[]>;\n425\t\n426\t  // -------------------------------------------------------------------------\n427\t  // Referral — codes\n428\t  // -------------------------------------------------------------------------\n429\t\n430\t  /** Insert a new referral code for a user. Throws on duplicate user, wallet, or code. */\n431\t  insertReferralCode(\n432\t    userId: string,\n433\t    wallet: string,\n434\t    code: string,\n435\t  ): Promise<ReferralCode>;\n436\t\n437\t  /** Get a user's referral code. Returns `undefined` if none set. */\n438\t  getReferralCodeByUserId(userId: string): Promise<ReferralCode | undefined>;\n439\t\n440\t  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n441\t  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n442\t\n443\t  // -------------------------------------------------------------------------\n444\t  // Referral — links\n445\t  // -------------------------------------------------------------------------\n446\t\n447\t  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n448\t  insertReferralLink(params: {\n449\t    referrerUserId: string;\n450\t    refereeUserId: string;\n451\t    referrerWallet: string;\n452\t    refereeWallet: string;\n453\t  }): Promise<ReferralLink>;\n454\t\n455\t  /** Get the referral link for a referee user. Returns `undefined` if not referred. */\n456\t  getReferralLinkByRefereeUserId(\n457\t    refereeUserId: string,\n458\t  ): Promise<ReferralLink | undefined>;\n459\t\n460\t  /** Get all referral links where the given user is the referrer. */\n461\t  getReferralLinksByReferrerUserId(referrerUserId: string): Promise<ReferralLink[]>;\n462\t\n463\t  // -------------------------------------------------------------------------\n464\t  // Referral — earnings & stats\n465\t  // -------------------------------------------------------------------------\n466\t\n467\t  /** Insert a referral earning row. Throws on duplicate (referee_user_id, round_id). */\n468\t  insertReferralEarning(params: {\n469\t    referrerUserId: string;\n470\t    refereeUserId: string;\n471\t    referrerWallet: string;\n472\t    refereeWallet: string;\n473\t    roundId: string;\n474\t    gameType: string;\n475\t    wagerLamports: number;\n476\t    feeLamports: number;\n477\t    referrerEarnedLamports: number;\n478\t    referrerRateBps: number;\n479\t    refereeRebateLamports: number;\n480\t    refereeRebateRateBps: number;\n481\t  }): Promise<ReferralEarning>;\n482\t\n483\t  /**\n484\t   * Get the pending (unclaimed) balance for a user.\n485\t   * Sum of referrer_earned where user_id=referrer + sum of referee_rebate where\n486\t   * user_id=referee, minus sum of claims for that user.\n487\t   * Returns a lamport string.\n488\t   */\n489\t  getPendingBalanceByUserId(userId: string): Promise<string>;\n490\t\n491\t  /** Get paginated per-game earnings for a user (as referrer). Newest first. */\n492\t  getReferralEarningsByUserId(\n493\t    userId: string,\n494\t    page: number,\n495\t    limit: number,\n496\t  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n497\t\n498\t  /** Get referral summary stats for a user. */\n499\t  getReferralStatsByUserId(userId: string): Promise<ReferralStats>;\n500\t\n501\t  // -------------------------------------------------------------------------\n502\t  // Referral — claims & rates\n503\t  // -------------------------------------------------------------------------\n504\t\n505\t  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n506\t  insertReferralClaim(\n507\t    userId: string,\n508\t    wallet: string,\n509\t    amountLamports: string,\n510\t  ): Promise<ReferralClaim>;\n511\t\n512\t  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n513\t  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n514\t\n515\t  /**\n516\t   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n517\t   * Returns the updated claim.\n518\t   */\n519\t  updateClaimStatus(\n520\t    claimId: string,\n521\t    status: ReferralClaim[\"status\"],\n522\t    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n523\t  ): Promise<ReferralClaim>;\n524\t\n525\t  /**\n526\t   * Get the effective referrer rate for a user in bps.\n527\t   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n528\t   */\n529\t  getReferrerRate(\n530\t    userId: string,\n531\t    defaultRateBps: number,\n532\t  ): Promise<number>;\n533\t\n534\t  // -------------------------------------------------------------------------\n535\t  // Player profiles\n536\t  // -------------------------------------------------------------------------\n537\t\n538\t  /**\n539\t   * Create a new player profile with auto-generated user_id and username.\n540\t   * Retries up to 5 times on username collision, then falls back to `user-{random8}`.\n541\t   */\n542\t  createPlayerProfile(wallet: string): Promise<PlayerProfile>;\n543\t\n544\t  /** Get a player profile by wallet address. Returns `null` if not found. */\n545\t  getProfileByWallet(wallet: string): Promise<PlayerProfile | null>;\n546\t\n547\t  /** Get a player profile by user_id. Returns `null` if not found. */\n548\t  getProfileByUserId(userId: string): Promise<PlayerProfile | null>;\n549\t\n550\t  /**\n551\t   * Get a player profile by public identifier.\n552\t   * If identifier starts with `usr_`, looks up by `user_id`.\n553\t   * Otherwise looks up by username (case-insensitive).\n554\t   */\n555\t  getProfileByIdentifier(identifier: string): Promise<PlayerProfile | null>;\n556\t\n557\t  /**\n558\t   * Update a player's username. Validates 30-day cooldown (first edit is free).\n559\t   * Throws on cooldown violation or UNIQUE conflict.\n560\t   */\n561\t  updateUsername(wallet: string, newUsername: string): Promise<PlayerProfile>;\n562\t\n563\t  /** Update a player's username by canonical user_id. */\n564\t  updateUsernameByUserId(userId: string, newUsername: string): Promise<PlayerProfile>;\n565\t\n566\t  /**\n567\t   * Compute aggregate stats from the transactions table for a wallet.\n568\t   * Returns gamesPlayed, totalWagered, totalWins, winRate, netPnl.\n569\t   */\n570\t  getPlayerStats(wallet: string): Promise<PlayerStats>;\n571\t\n572\t  /** Compute aggregate stats from game_entries for a canonical user_id. */\n573\t  getPlayerStatsByUserId(userId: string): Promise<PlayerStats>;\n574\t\n575\t  /**\n576\t   * Get public-safe subset of player stats (no wagered, no PnL).\n577\t   */\n578\t  getPublicPlayerStats(wallet: string): Promise<PublicPlayerStats>;\n579\t\n580\t  /** Get public-safe subset of player stats by canonical user_id. */\n581\t  getPublicPlayerStatsByUserId(userId: string): Promise<PublicPlayerStats>;\n582\t\n583\t  /**\n584\t   * Compute per-game aggregate stats from the transactions table.\n585\t   * Returns a record keyed by frontend game name (coinflip, lord-of-rngs, close-call).\n586\t   * Games with zero activity are omitted.\n587\t   */\n588\t  getGameBreakdown(wallet: string): Promise<Record<string, GameBreakdownStats>>;\n589\t\n590\t  /** Compute per-game aggregate stats for a canonical user_id. */\n591\t  getGameBreakdownByUserId(userId: string): Promise<Record<string, GameBreakdownStats>>;\n592\t\n593\t  /**\n594\t   * Compute win streaks from the transactions table.\n595\t   * Returns current (consecutive wins from most recent) and best (longest ever).\n596\t   * Refund-only matches are excluded from streak calculation.\n597\t   */\n598\t  getWinStreaks(wallet: string): Promise<WinStreaks>;\n599\t\n600\t  /** Compute win streaks for a canonical user_id. */\n601\t  getWinStreaksByUserId(userId: string): Promise<WinStreaks>;\n602\t\n603\t  // -------------------------------------------------------------------------\n604\t  // Game entries\n605\t  // -------------------------------------------------------------------------\n606\t\n607\t  /**\n608\t   * Upsert a single game entry. Inserts at participation time; updates at settlement.\n609\t   * ON CONFLICT (wallet, round_pda) DO UPDATE for settlement UPSERT pattern.\n610\t   */\n611\t  upsertGameEntry(entry: GameEntryUpsert): Promise<void>;\n612\t\n613\t  /**\n614\t   * Batch-upsert game entries. Used at settlement to update existing entries\n615\t   * and insert new ones (joiners) in one pass.\n616\t   */\n617\t  upsertGameEntries(entries: GameEntryUpsert[]): Promise<void>;\n618\t\n619\t  /**\n620\t   * Get all game entries for a round. Used by settlement to read participant list.\n621\t   */\n622\t  getEntriesByRound(roundPda: string): Promise<GameEntry[]>;\n623\t\n624\t  /**\n625\t   * @deprecated Use upsertGameEntries instead.\n626\t   */\n627\t  insertGameEntries(entries: GameEntryInsert[]): Promise<void>;\n628\t\n629\t  // -------------------------------------------------------------------------\n630\t  // Close Call candles\n631\t  // -------------------------------------------------------------------------\n632\t\n633\t  /** Insert a Close Call candle price. ON CONFLICT DO NOTHING. */\n634\t  insertCloseCallCandle(\n635\t    minuteTs: number,\n636\t    price: bigint,\n637\t    expo: number,\n638\t    priceHuman: number,\n639\t    hermesVaa: string | null,\n640\t  ): Promise<void>;\n641\t\n642\t  /** Get the most recent Close Call candle. */\n643\t  getLatestCloseCallCandle(): Promise<CloseCallCandle | null>;\n644\t\n645\t  /** Get recent Close Call candles, ordered by minute_ts DESC. */\n646\t  getCloseCallCandles(limit: number): Promise<CloseCallCandle[]>;\n647\t\n648\t  // -------------------------------------------------------------------------\n649\t  // Profile helpers\n650\t  // -------------------------------------------------------------------------\n651\t\n652\t  /**\n653\t   * Get or create a player profile for a wallet.\n654\t   * INSERT ON CONFLICT DO NOTHING + SELECT. Used at settlement for joiners.\n655\t   */\n656\t  getOrCreateProfile(wallet: string): Promise<PlayerProfile>;\n657\t\n658\t  /**\n659\t   * Get the weekly leaderboard ranked by total wagered volume.\n660\t   * Week boundary: Monday 00:00 UTC to next Monday 00:00 UTC.\n661\t   * Optional game filter (db name: \"coinflip\", \"lord\", \"closecall\").\n662\t   */\n663\t  getWeeklyLeaderboard(\n664\t    game?: string,\n665\t    limit?: number,\n666\t    offset?: number,\n667\t  ): Promise<LeaderboardResult>;\n668\t\n669\t  /**\n670\t   * Execute a function within a database transaction.\n671\t   * All db methods called on the transactional Db share the same transaction.\n672\t   * Rolls back on error, commits on success.\n673\t   */\n674\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n675\t\n676\t  /** Expose the underlying SQL/transaction handle for use with emitEvent(). */\n677\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n678\t  readonly rawSql: any;\n679\t\n680\t  /** Gracefully close the connection pool. */\n681\t  close(): Promise<void>;\n682\t}\n683\t\n684\tfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n685\t  return {\n686\t    ...row,\n687\t    open_price: Number(row.open_price),\n688\t    open_price_expo: Number(row.open_price_expo),\n689\t    close_price: row.close_price === null ? null : Number(row.close_price),\n690\t    green_pool: Number(row.green_pool),\n691\t    red_pool: Number(row.red_pool),\n692\t    total_fee: Number(row.total_fee),\n693\t    // Entries come from JOIN on game_entries, already parsed\n694\t    green_entries: Array.isArray(row.green_entries)\n695\t      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n696\t      : [],\n697\t    red_entries: Array.isArray(row.red_entries)\n698\t      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n699\t      : [],\n700\t  };\n701\t}\n702\t\n703\tfunction normalizeTransaction(row: Transaction): Transaction {\n704\t  return {\n705\t    ...row,\n706\t    amount_lamports: Number(row.amount_lamports),\n707\t  };\n708\t}\n709\t\n710\tfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n711\t  return {\n712\t    ...row,\n713\t    wager_lamports: Number(row.wager_lamports),\n714\t    fee_lamports: Number(row.fee_lamports),"}]},"parent_tool_use_id":"toolu_018VhPYzbAyLvaxkyKr8pAVh","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"ef14d22b-d2fd-41b8-8572-7236d7578aa2","timestamp":"2026-04-03T19:38:24.113Z"}
