{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Trf2MWJAawMTr8xo3kycBD","type":"tool_result","content":"200\t\n201\t  async confirmTransaction() {\n202\t    return { value: { err: null }, context: { slot: this._slot } };\n203\t  }\n204\t\n205\t  async getBlockTime(_slot: number) {\n206\t    return Math.floor(Date.now() / 1000);\n207\t  }\n208\t\n209\t  async getBalance() {\n210\t    return 2 * LAMPORTS_PER_SOL;\n211\t  }\n212\t}\n213\t\n214\t// ---------------------------------------------------------------------------\n215\t// Account data builders\n216\t// ---------------------------------------------------------------------------\n217\t\n218\tasync function buildMatchAccountData(params: {\n219\t  creator: PublicKey;\n220\t  opponent: PublicKey;\n221\t  server: PublicKey;\n222\t  entryAmount: bigint;\n223\t  creatorSide: number;\n224\t  phase: number;\n225\t  commitment: Buffer;\n226\t  algorithmVer: number;\n227\t  targetSlot: bigint;\n228\t  resolveDeadline: bigint;\n229\t  matchId: Buffer;\n230\t}): Promise<Buffer> {\n231\t  return encodeCoinflipMatch({\n232\t    creator: params.creator,\n233\t    opponent: params.opponent,\n234\t    server: params.server,\n235\t    entryAmount: params.entryAmount,\n236\t    creatorSide: params.creatorSide,\n237\t    phase: params.phase,\n238\t    commitment: [...params.commitment],\n239\t    algorithmVer: params.algorithmVer,\n240\t    targetSlot: params.targetSlot,\n241\t    resolveDeadline: params.resolveDeadline,\n242\t    resultHash: new Array(32).fill(0),\n243\t    result: 0,\n244\t    winner: PublicKey.default,\n245\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n246\t    matchId: [...params.matchId],\n247\t    bump: 0,\n248\t  });\n249\t}\n250\t\n251\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n252\t  return encodeCoinflipConfig({\n253\t    authority: PublicKey.default,\n254\t    treasury,\n255\t    paused: false,\n256\t    bump: 0,\n257\t  });\n258\t}\n259\t\n260\t/**\n261\t * Build PlatformConfig account data matching the on-chain layout.\n262\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n263\t */\n264\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n265\t  const buf = Buffer.alloc(74);\n266\t  // discriminator (8 bytes) — zeroed is fine for mock\n267\t  // authority at offset 8 — use default\n268\t  PublicKey.default.toBuffer().copy(buf, 8);\n269\t  // treasury at offset 40\n270\t  treasury.toBuffer().copy(buf, 40);\n271\t  // fee_bps at offset 72\n272\t  buf.writeUInt16LE(feeBps, 72);\n273\t  return buf;\n274\t}\n275\t\n276\t// ---------------------------------------------------------------------------\n277\t// Test suite\n278\t// ---------------------------------------------------------------------------\n279\t\n280\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n281\t  let db: Db;\n282\t  let rawSql: ReturnType<typeof postgres>;\n283\t  let mockConn: MockConnection;\n284\t  let app: Hono;\n285\t\n286\t  const serverKeypair = Keypair.generate();\n287\t  const creatorKeypair = Keypair.generate();\n288\t  const opponentKeypair = Keypair.generate();\n289\t  const treasuryKeypair = Keypair.generate();\n290\t  const entropyKeypair = Keypair.generate();\n291\t  const entropyAccount = entropyKeypair.publicKey;\n292\t\n293\t  const entropyData = Buffer.alloc(32);\n294\t  entropyData[0] = 0xab;\n295\t  entropyData[1] = 0xcd;\n296\t  entropyData[15] = 0x42;\n297\t\n298\t  beforeAll(async () => {\n299\t    rawSql = makeSql();\n300\t    await rawSql`\n301\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n302\t    `;\n303\t    await rawSql`\n304\t      CREATE TABLE referral_codes (\n305\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n306\t        user_id TEXT NOT NULL UNIQUE,\n307\t        wallet TEXT NOT NULL UNIQUE,\n308\t        code TEXT NOT NULL UNIQUE,\n309\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n310\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n311\t      )\n312\t    `;\n313\t    await rawSql`\n314\t      CREATE TABLE referral_links (\n315\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n316\t        referrer_user_id TEXT NOT NULL,\n317\t        referee_user_id TEXT NOT NULL UNIQUE,\n318\t        referrer_wallet TEXT NOT NULL,\n319\t        referee_wallet TEXT NOT NULL,\n320\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n321\t      )\n322\t    `;\n323\t    await rawSql`\n324\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n325\t    `;\n326\t    await rawSql`\n327\t      CREATE TABLE referral_earnings (\n328\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n329\t        referrer_user_id TEXT NOT NULL,\n330\t        referee_user_id TEXT NOT NULL,\n331\t        referrer_wallet TEXT NOT NULL,\n332\t        referee_wallet TEXT NOT NULL,\n333\t        round_id TEXT NOT NULL,\n334\t        game_type TEXT NOT NULL,\n335\t        wager_lamports BIGINT NOT NULL,\n336\t        fee_lamports BIGINT NOT NULL,\n337\t        referrer_earned_lamports BIGINT NOT NULL,\n338\t        referrer_rate_bps INTEGER NOT NULL,\n339\t        referee_rebate_lamports BIGINT NOT NULL,\n340\t        referee_rebate_rate_bps INTEGER NOT NULL,\n341\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n342\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n343\t      )\n344\t    `;\n345\t    await rawSql`\n346\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n347\t    `;\n348\t    await rawSql`\n349\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n350\t    `;\n351\t    await rawSql`\n352\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n353\t    `;\n354\t    await rawSql`\n355\t      CREATE TABLE referral_claims (\n356\t        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n357\t        user_id TEXT NOT NULL,\n358\t        wallet TEXT NOT NULL,\n359\t        amount_lamports BIGINT NOT NULL,\n360\t        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n361\t        retry_count INTEGER NOT NULL DEFAULT 0,\n362\t        tx_signature TEXT,\n363\t        error TEXT,\n364\t        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n365\t        processed_at TIMESTAMPTZ\n366\t      )\n367\t    `;\n368\t    await rawSql`\n369\t      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n370\t    `;\n371\t    await rawSql`\n372\t      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n373\t    `;\n374\t    await rawSql`\n375\t      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n376\t    `;\n377\t    await rawSql`\n378\t      CREATE TABLE referral_kol_rates (\n379\t        user_id TEXT PRIMARY KEY,\n380\t        wallet TEXT NOT NULL UNIQUE,\n381\t        rate_bps INTEGER NOT NULL,\n382\t        set_by TEXT NOT NULL,\n383\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n384\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n385\t      )\n386\t    `;\n387\t    db = createDb(DATABASE_URL, rawSql);\n388\t  });\n389\t\n390\t  afterAll(async () => {\n391\t    await db.close();\n392\t    await rawSql.end();\n393\t  });\n394\t\n395\t  beforeEach(async () => {\n396\t    // Clean tables for isolation\n397\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates RESTART IDENTITY CASCADE`;\n398\t\n399\t    // Reset PlatformConfig cache so each test reads from its own mock"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"700e6846-036d-4dda-a3d9-49d230e3e497","timestamp":"2026-04-03T19:38:13.977Z"}
