{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QBMQxgdu9k5tJdp1Zpq8UK","type":"tool_result","content":"1\t/**\n2\t * Challenge verification adapters and quest eligibility check.\n3\t *\n4\t * quest_eligible() gates whether a settled game counts toward challenges,\n5\t * points, and crate drops. Refunded games (isWinner === null) are excluded.\n6\t *\n7\t * Each adapter evaluates whether a game.settled event advances a player's\n8\t * challenge progress. Adapters are pure functions of (event, player, assignment)\n9\t * — no side effects beyond the returned result.\n10\t */\n11\t\n12\timport { logger } from \"../../logger.js\";\n13\t\n14\t// ---------------------------------------------------------------------------\n15\t// Types\n16\t// ---------------------------------------------------------------------------\n17\t\n18\t/** A single player entry from the game.settled event payload. */\n19\texport interface GameSettledPlayer {\n20\t  userId: string;\n21\t  wallet: string;\n22\t  amountLamports: string;\n23\t  isWinner: boolean | null; // null = refund\n24\t  payoutLamports: string;\n25\t  isCreator: boolean;\n26\t}\n27\t\n28\t/** The game.settled event payload shape. */\n29\texport interface GameSettledPayload {\n30\t  roundId: string;\n31\t  roundPda: string;\n32\t  game: \"coinflip\" | \"lord\" | \"closecall\";\n33\t  players: GameSettledPlayer[];\n34\t  feeLamports: string;\n35\t  settledAt: string;\n36\t}\n37\t\n38\t/** A challenge assignment with its challenge definition. */\n39\texport interface ChallengeAssignment {\n40\t  id: number;\n41\t  challengeId: number;\n42\t  action: string;\n43\t  scope: string; // 'any' | 'coinflip' | 'lord' | 'closecall'\n44\t  condition: string;\n45\t  target: number;\n46\t  progress: number;\n47\t  status: string;\n48\t}\n49\t\n50\t/** Result from a verification adapter. */\n51\texport interface AdapterResult {\n52\t  shouldProgress: boolean;\n53\t  progressDelta: number;\n54\t}\n55\t\n56\t/** Verification adapter function signature. */\n57\texport type VerificationAdapter = (\n58\t  event: GameSettledPayload,\n59\t  player: GameSettledPlayer,\n60\t  assignment: ChallengeAssignment,\n61\t) => AdapterResult;\n62\t\n63\t// ---------------------------------------------------------------------------\n64\t// Quest Eligibility\n65\t// ---------------------------------------------------------------------------\n66\t\n67\t/**\n68\t * Returns false when the game was refunded (isWinner === null), true otherwise.\n69\t * Games that fail this check are skipped for challenge progress, points, AND\n70\t * crate drops. The game still counts for normal gameplay.\n71\t */\n72\texport function questEligible(\n73\t  player: GameSettledPlayer,\n74\t): boolean {\n75\t  return player.isWinner !== null;\n76\t}\n77\t\n78\t// ---------------------------------------------------------------------------\n79\t// Adapters\n80\t// ---------------------------------------------------------------------------\n81\t\n82\tfunction matchesScope(game: string, scope: string): boolean {\n83\t  return scope === \"any\" || scope === game;\n84\t}\n85\t\n86\tconst NO_PROGRESS: AdapterResult = { shouldProgress: false, progressDelta: 0 };\n87\tconst ONE_PROGRESS: AdapterResult = { shouldProgress: true, progressDelta: 1 };\n88\t\n89\t/**\n90\t * game_completed: player participated in a settled game.\n91\t * Optionally filtered by scope (game type).\n92\t */\n93\tfunction gameCompletedAdapter(\n94\t  event: GameSettledPayload,\n95\t  _player: GameSettledPlayer,\n96\t  assignment: ChallengeAssignment,\n97\t): AdapterResult {\n98\t  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n99\t  return ONE_PROGRESS;\n100\t}\n101\t\n102\t/**\n103\t * game_won: player won a settled game.\n104\t * Requires isWinner === true and game matches scope.\n105\t */\n106\tfunction gameWonAdapter(\n107\t  event: GameSettledPayload,\n108\t  player: GameSettledPlayer,\n109\t  assignment: ChallengeAssignment,\n110\t): AdapterResult {\n111\t  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n112\t  if (player.isWinner !== true) return NO_PROGRESS;\n113\t  return ONE_PROGRESS;\n114\t}\n115\t\n116\t/**\n117\t * lobby_filled: player created a game that was filled and settled.\n118\t * Requires isCreator === true.\n119\t */\n120\tfunction lobbyFilledAdapter(\n121\t  event: GameSettledPayload,\n122\t  player: GameSettledPlayer,\n123\t  assignment: ChallengeAssignment,\n124\t): AdapterResult {\n125\t  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n126\t  if (!player.isCreator) return NO_PROGRESS;\n127\t  return ONE_PROGRESS;\n128\t}\n129\t\n130\t// ---------------------------------------------------------------------------\n131\t// Adapter Registry\n132\t// ---------------------------------------------------------------------------\n133\t\n134\tconst adapterRegistry = new Map<string, VerificationAdapter>([\n135\t  [\"game_completed\", gameCompletedAdapter],\n136\t  [\"game_won\", gameWonAdapter],\n137\t  [\"lobby_filled\", lobbyFilledAdapter],\n138\t]);\n139\t\n140\t/**\n141\t * Look up a verification adapter by action type.\n142\t * Unknown action types log a warning and return a no-op adapter.\n143\t */\n144\texport function getAdapter(action: string): VerificationAdapter {\n145\t  const adapter = adapterRegistry.get(action);\n146\t  if (!adapter) {\n147\t    logger.warn(\"Unknown challenge adapter action type\", { action });\n148\t    return () => NO_PROGRESS;\n149\t  }\n150\t  return adapter;\n151\t}\n152\t"}]},"parent_tool_use_id":null,"session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"bb4d0094-d229-44f5-85aa-5c6201cfa9a9","timestamp":"2026-04-03T19:39:51.229Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/challenge-adapters.ts","content":"/**\n * Challenge verification adapters and quest eligibility check.\n *\n * quest_eligible() gates whether a settled game counts toward challenges,\n * points, and crate drops. Refunded games (isWinner === null) are excluded.\n *\n * Each adapter evaluates whether a game.settled event advances a player's\n * challenge progress. Adapters are pure functions of (event, player, assignment)\n * — no side effects beyond the returned result.\n */\n\nimport { logger } from \"../../logger.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\n/** A single player entry from the game.settled event payload. */\nexport interface GameSettledPlayer {\n  userId: string;\n  wallet: string;\n  amountLamports: string;\n  isWinner: boolean | null; // null = refund\n  payoutLamports: string;\n  isCreator: boolean;\n}\n\n/** The game.settled event payload shape. */\nexport interface GameSettledPayload {\n  roundId: string;\n  roundPda: string;\n  game: \"coinflip\" | \"lord\" | \"closecall\";\n  players: GameSettledPlayer[];\n  feeLamports: string;\n  settledAt: string;\n}\n\n/** A challenge assignment with its challenge definition. */\nexport interface ChallengeAssignment {\n  id: number;\n  challengeId: number;\n  action: string;\n  scope: string; // 'any' | 'coinflip' | 'lord' | 'closecall'\n  condition: string;\n  target: number;\n  progress: number;\n  status: string;\n}\n\n/** Result from a verification adapter. */\nexport interface AdapterResult {\n  shouldProgress: boolean;\n  progressDelta: number;\n}\n\n/** Verification adapter function signature. */\nexport type VerificationAdapter = (\n  event: GameSettledPayload,\n  player: GameSettledPlayer,\n  assignment: ChallengeAssignment,\n) => AdapterResult;\n\n// ---------------------------------------------------------------------------\n// Quest Eligibility\n// ---------------------------------------------------------------------------\n\n/**\n * Returns false when the game was refunded (isWinner === null), true otherwise.\n * Games that fail this check are skipped for challenge progress, points, AND\n * crate drops. The game still counts for normal gameplay.\n */\nexport function questEligible(\n  player: GameSettledPlayer,\n): boolean {\n  return player.isWinner !== null;\n}\n\n// ---------------------------------------------------------------------------\n// Adapters\n// ---------------------------------------------------------------------------\n\nfunction matchesScope(game: string, scope: string): boolean {\n  return scope === \"any\" || scope === game;\n}\n\nconst NO_PROGRESS: AdapterResult = { shouldProgress: false, progressDelta: 0 };\nconst ONE_PROGRESS: AdapterResult = { shouldProgress: true, progressDelta: 1 };\n\n/**\n * game_completed: player participated in a settled game.\n * Optionally filtered by scope (game type).\n */\nfunction gameCompletedAdapter(\n  event: GameSettledPayload,\n  _player: GameSettledPlayer,\n  assignment: ChallengeAssignment,\n): AdapterResult {\n  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n  return ONE_PROGRESS;\n}\n\n/**\n * game_won: player won a settled game.\n * Requires isWinner === true and game matches scope.\n */\nfunction gameWonAdapter(\n  event: GameSettledPayload,\n  player: GameSettledPlayer,\n  assignment: ChallengeAssignment,\n): AdapterResult {\n  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n  if (player.isWinner !== true) return NO_PROGRESS;\n  return ONE_PROGRESS;\n}\n\n/**\n * lobby_filled: player created a game that was filled and settled.\n * Requires isCreator === true.\n */\nfunction lobbyFilledAdapter(\n  event: GameSettledPayload,\n  player: GameSettledPlayer,\n  assignment: ChallengeAssignment,\n): AdapterResult {\n  if (!matchesScope(event.game, assignment.scope)) return NO_PROGRESS;\n  if (!player.isCreator) return NO_PROGRESS;\n  return ONE_PROGRESS;\n}\n\n// ---------------------------------------------------------------------------\n// Adapter Registry\n// ---------------------------------------------------------------------------\n\nconst adapterRegistry = new Map<string, VerificationAdapter>([\n  [\"game_completed\", gameCompletedAdapter],\n  [\"game_won\", gameWonAdapter],\n  [\"lobby_filled\", lobbyFilledAdapter],\n]);\n\n/**\n * Look up a verification adapter by action type.\n * Unknown action types log a warning and return a no-op adapter.\n */\nexport function getAdapter(action: string): VerificationAdapter {\n  const adapter = adapterRegistry.get(action);\n  if (!adapter) {\n    logger.warn(\"Unknown challenge adapter action type\", { action });\n    return () => NO_PROGRESS;\n  }\n  return adapter;\n}\n","numLines":152,"startLine":1,"totalLines":152}}}
