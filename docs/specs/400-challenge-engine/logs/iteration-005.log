{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EtSveYJrMsXHhvdqo8RLua","type":"tool_result","content":"0\t/**\n1\t * Unit tests for the async event queue module.\n2\t *\n3\t * Covers:\n4\t * 1. emitEvent — inserts with correct fields, returns eventId\n5\t * 2. emitEvent — rolled-back transaction does NOT persist\n6\t * 3. Handler registry — register/get, unknown returns undefined\n7\t * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n8\t *\n9\t * Requires a running Postgres database (same as backend).\n10\t */\n11\t\n12\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n13\timport postgres from \"postgres\";\n14\timport { emitEvent } from \"../emit-event.js\";\n15\timport { registerHandler, getHandler } from \"../handler-registry.js\";\n16\timport { EventTypes } from \"../event-types.js\";\n17\timport { getBackoffSeconds } from \"../worker.js\";\n18\t\n19\tdescribe(\"event queue unit tests\", () => {\n20\t  let sql: ReturnType<typeof postgres>;\n21\t\n22\t  beforeAll(async () => {\n23\t    sql = process.env.DATABASE_URL\n24\t      ? postgres(process.env.DATABASE_URL)\n25\t      : postgres({\n26\t          host: \"/var/run/postgresql\",\n27\t          database: \"rng_utopia_dev\",\n28\t          username: \"vscode\",\n29\t        });\n30\t  });\n31\t\n32\t  afterAll(async () => {\n33\t    await sql.end();\n34\t  });\n35\t\n36\t  beforeEach(async () => {\n37\t    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n38\t  });\n39\t\n40\t  // -------------------------------------------------------------------------\n41\t  // emitEvent\n42\t  // -------------------------------------------------------------------------\n43\t\n44\t  describe(\"emitEvent\", () => {\n45\t    it(\"inserts a row with correct fields and returns eventId\", async () => {\n46\t      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n47\t\n48\t      const result = await sql.begin(async (tx) => {\n49\t        return emitEvent(\n50\t          tx as unknown as postgres.Sql,\n51\t          EventTypes.REFERRAL_GAME_SETTLED,\n52\t          payload,\n53\t        );\n54\t      });\n55\t\n56\t      expect(result.eventId).toBeTypeOf(\"bigint\");\n57\t      expect(result.eventId).toBeGreaterThan(0n);\n58\t\n59\t      // Verify the persisted row\n60\t      const rows = await sql`\n61\t        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n62\t      `;\n63\t      expect(rows).toHaveLength(1);\n64\t\n65\t      const row = rows[0]!;\n66\t      expect(row.event_type).toBe(\"referral.game_settled\");\n67\t      expect(row.payload).toEqual(payload);\n68\t      expect(row.status).toBe(\"pending\");\n69\t      expect(row.attempts).toBe(0);\n70\t      expect(row.max_attempts).toBe(3);\n71\t      expect(row.scheduled_at).toBeInstanceOf(Date);\n72\t      expect(row.created_at).toBeInstanceOf(Date);\n73\t    });\n74\t\n75\t    it(\"does NOT persist when transaction is rolled back\", async () => {\n76\t      let capturedId: bigint | undefined;\n77\t\n78\t      try {\n79\t        await sql.begin(async (tx) => {\n80\t          const result = await emitEvent(\n81\t            tx as unknown as postgres.Sql,\n82\t            EventTypes.REFERRAL_CODE_APPLIED,\n83\t            { test: true },\n84\t          );\n85\t          capturedId = result.eventId;\n86\t          throw new Error(\"intentional rollback\");\n87\t        });\n88\t      } catch {\n89\t        // Expected — begin() re-throws after rollback\n90\t      }\n91\t\n92\t      expect(capturedId).toBeDefined();\n93\t      const rows = await sql`\n94\t        SELECT * FROM event_queue WHERE id = ${capturedId!.toString()}\n95\t      `;\n96\t      expect(rows).toHaveLength(0);\n97\t    });\n98\t\n99\t    it(\"respects custom maxAttempts and scheduledAt\", async () => {\n100\t      const future = new Date(Date.now() + 60_000);\n101\t\n102\t      const result = await sql.begin(async (tx) => {\n103\t        return emitEvent(\n104\t          tx as unknown as postgres.Sql,\n105\t          EventTypes.REFERRAL_CLAIM_REQUESTED,\n106\t          { foo: \"bar\" },\n107\t          { maxAttempts: 5, scheduledAt: future },\n108\t        );\n109\t      });\n110\t\n111\t      const rows = await sql`\n112\t        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n113\t      `;\n114\t      expect(rows[0]!.max_attempts).toBe(5);\n115\t      // scheduled_at should be close to the future date (within 1s tolerance)\n116\t      const diff = Math.abs(rows[0]!.scheduled_at.getTime() - future.getTime());\n117\t      expect(diff).toBeLessThan(1000);\n118\t    });\n119\t  });\n120\t\n121\t  // -------------------------------------------------------------------------\n122\t  // Handler registry\n123\t  // -------------------------------------------------------------------------\n124\t\n125\t  describe(\"handler registry\", () => {\n126\t    it(\"register → get returns the handler\", () => {\n127\t      const handler = async () => {};\n128\t      registerHandler(EventTypes.REFERRAL_GAME_SETTLED, handler);\n129\t      expect(getHandler(\"referral.game_settled\")).toBe(handler);\n130\t    });\n131\t\n132\t    it(\"get for unknown type returns undefined\", () => {\n133\t      expect(getHandler(\"unknown.event.type\")).toBeUndefined();\n134\t    });\n135\t  });\n136\t\n137\t  // -------------------------------------------------------------------------\n138\t  // Backoff calculation\n139\t  // -------------------------------------------------------------------------\n140\t\n141\t  describe(\"getBackoffSeconds\", () => {\n142\t    it(\"attempt 1 → 5 seconds\", () => {\n143\t      expect(getBackoffSeconds(1)).toBe(5);\n144\t    });\n145\t\n146\t    it(\"attempt 2 → 30 seconds\", () => {\n147\t      expect(getBackoffSeconds(2)).toBe(30);\n148\t    });\n149\t"}]},"parent_tool_use_id":"toolu_01CVmZqtC5WVWyyBbUAzj1uy","session_id":"704bd991-5045-4113-8fa3-9bd3dc1e7fdb","uuid":"23b630d7-3067-4bf9-a809-82e4c807ee44","timestamp":"2026-04-03T19:38:51.327Z"}
