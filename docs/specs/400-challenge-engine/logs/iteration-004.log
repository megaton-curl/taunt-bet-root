{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B7HwCS4iKcwCJNpvrv7UAx","type":"tool_result","content":"664\t    game?: string,\n665\t    limit?: number,\n666\t    offset?: number,\n667\t  ): Promise<LeaderboardResult>;\n668\t\n669\t  /**\n670\t   * Execute a function within a database transaction.\n671\t   * All db methods called on the transactional Db share the same transaction.\n672\t   * Rolls back on error, commits on success.\n673\t   */\n674\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n675\t\n676\t  /** Expose the underlying SQL/transaction handle for use with emitEvent(). */\n677\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n678\t  readonly rawSql: any;\n679\t\n680\t  /** Gracefully close the connection pool. */\n681\t  close(): Promise<void>;\n682\t}\n683\t\n684\tfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n685\t  return {\n686\t    ...row,\n687\t    open_price: Number(row.open_price),\n688\t    open_price_expo: Number(row.open_price_expo),\n689\t    close_price: row.close_price === null ? null : Number(row.close_price),\n690\t    green_pool: Number(row.green_pool),\n691\t    red_pool: Number(row.red_pool),\n692\t    total_fee: Number(row.total_fee),\n693\t    // Entries come from JOIN on game_entries, already parsed\n694\t    green_entries: Array.isArray(row.green_entries)\n695\t      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n696\t      : [],\n697\t    red_entries: Array.isArray(row.red_entries)\n698\t      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n699\t      : [],\n700\t  };\n701\t}\n702\t\n703\tfunction normalizeTransaction(row: Transaction): Transaction {\n704\t  return {\n705\t    ...row,\n706\t    amount_lamports: Number(row.amount_lamports),\n707\t  };\n708\t}\n709\t\n710\tfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n711\t  return {\n712\t    ...row,\n713\t    wager_lamports: Number(row.wager_lamports),\n714\t    fee_lamports: Number(row.fee_lamports),\n715\t    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n716\t    referrer_rate_bps: Number(row.referrer_rate_bps),\n717\t    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n718\t    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n719\t  };\n720\t}\n721\t\n722\tfunction normalizePlayerProfile(row: PlayerProfile): PlayerProfile {\n723\t  return {\n724\t    ...row,\n725\t    id: Number(row.id),\n726\t    heat_multiplier: Number(row.heat_multiplier),\n727\t    points_balance: Number(row.points_balance),\n728\t  };\n729\t}\n730\t\n731\tfunction normalizeRound(row: Round): Round {\n732\t  return {\n733\t    ...row,\n734\t    amount_lamports: Number(row.amount_lamports),\n735\t    side: Number(row.side),\n736\t    settle_attempts: Number(row.settle_attempts),\n737\t    result_side: row.result_side === null ? null : Number(row.result_side),\n738\t    // Entries come from JOIN on game_entries, already parsed\n739\t    entries: Array.isArray(row.entries)\n740\t      ? row.entries.map((e) => ({\n741\t          player: e.player,\n742\t          amountLamports: Number(e.amountLamports),\n743\t        }))\n744\t      : null,\n745\t  };\n746\t}\n747\t\n748\tfunction normalizeGameEntry(row: Record<string, unknown>): GameEntry {\n749\t  return {\n750\t    id: Number(row.id),\n751\t    userId: row.user_id as string,\n752\t    wallet: row.wallet as string,\n753\t    game: row.game as string,\n754\t    roundPda: row.round_pda as string,\n755\t    matchId: row.match_id as string,\n756\t    amountLamports: Number(row.amount_lamports),\n757\t    side: (row.side as string) ?? null,\n758\t    isWinner: row.is_winner === null ? null : Boolean(row.is_winner),\n759\t    payoutLamports: Number(row.payout_lamports ?? 0),\n760\t    createdAt: row.created_at as Date,\n761\t    settledAt: (row.settled_at as Date) ?? null,\n762\t  };\n763\t}\n764\t\n765\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n766\texport function createDb(databaseUrl: string, _txSql?: any): Db {\n767\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n768\t  const sql: any = _txSql ?? postgres(databaseUrl);\n769\t  const _isOwner = !_txSql;\n770\t\n771\t  return {\n772\t    rawSql: sql,\n773\t\n774\t    async insertRound(params) {\n775\t      const rows = await sql<Round[]>`\n776\t        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)\n777\t        VALUES (\n778\t          ${params.pda},\n779\t          ${params.game},\n780\t          ${params.creator},\n781\t          ${params.serverKey},\n782\t          ${params.secret},\n783\t          ${params.commitment},"}]},"parent_tool_use_id":"toolu_012uVnuaN6MtseZ8yLSM3NZr","session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"f0dd9111-99ce-4856-8478-3bb2bc79fef1","timestamp":"2026-04-03T19:29:23.616Z"}
