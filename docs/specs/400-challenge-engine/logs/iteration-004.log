{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RgyZXs6Neb9BhCeKmkt9NH","type":"message","role":"assistant","content":[{"type":"text","text":"Now write the unit tests. These are pure functions so no DB needed."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":248,"cache_read_input_tokens":64157,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":248},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"b9bff24e-7feb-4711-80de-5b8a80329266"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RgyZXs6Neb9BhCeKmkt9NH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MrrY9trx6DBKofLTRhcLak","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/__tests__/challenge-adapters.test.ts","content":"/**\n * Unit tests for challenge verification adapters and quest eligibility.\n *\n * Covers:\n * 1. questEligible — excludes refunded games (isWinner === null)\n * 2. game_completed adapter — scope filtering\n * 3. game_won adapter — scope + isWinner check\n * 4. lobby_filled adapter — scope + isCreator check\n * 5. Unknown adapter type — logs warning, returns shouldProgress: false\n */\n\nimport { describe, it, expect } from \"vitest\";\nimport {\n  questEligible,\n  getAdapter,\n  type GameSettledPayload,\n  type GameSettledPlayer,\n  type ChallengeAssignment,\n} from \"../handlers/challenge-adapters.js\";\n\n// ---------------------------------------------------------------------------\n// Test helpers\n// ---------------------------------------------------------------------------\n\nfunction makePlayer(overrides: Partial<GameSettledPlayer> = {}): GameSettledPlayer {\n  return {\n    userId: \"user-1\",\n    wallet: \"WaLLet111111111111111111111111111111111111111\",\n    amountLamports: \"1000000000\",\n    isWinner: true,\n    payoutLamports: \"1900000000\",\n    isCreator: false,\n    ...overrides,\n  };\n}\n\nfunction makeEvent(overrides: Partial<GameSettledPayload> = {}): GameSettledPayload {\n  return {\n    roundId: \"abc123\",\n    roundPda: \"PDA111111111111111111111111111111111111111111\",\n    game: \"coinflip\",\n    players: [makePlayer()],\n    feeLamports: \"100000000\",\n    settledAt: new Date().toISOString(),\n    ...overrides,\n  };\n}\n\nfunction makeAssignment(overrides: Partial<ChallengeAssignment> = {}): ChallengeAssignment {\n  return {\n    id: 1,\n    challengeId: 10,\n    action: \"game_completed\",\n    scope: \"any\",\n    condition: \"count\",\n    target: 5,\n    progress: 0,\n    status: \"active\",\n    ...overrides,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// questEligible\n// ---------------------------------------------------------------------------\n\ndescribe(\"questEligible\", () => {\n  it(\"returns true for a winning player\", () => {\n    expect(questEligible(makePlayer({ isWinner: true }))).toBe(true);\n  });\n\n  it(\"returns true for a losing player\", () => {\n    expect(questEligible(makePlayer({ isWinner: false }))).toBe(true);\n  });\n\n  it(\"returns false for a refunded player (isWinner === null)\", () => {\n    expect(questEligible(makePlayer({ isWinner: null }))).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// game_completed adapter\n// ---------------------------------------------------------------------------\n\ndescribe(\"game_completed adapter\", () => {\n  const adapter = getAdapter(\"game_completed\");\n\n  it(\"returns shouldProgress: true when scope is 'any'\", () => {\n    const result = adapter(makeEvent(), makePlayer(), makeAssignment({ scope: \"any\" }));\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"returns shouldProgress: true when scope matches game\", () => {\n    const result = adapter(\n      makeEvent({ game: \"coinflip\" }),\n      makePlayer(),\n      makeAssignment({ scope: \"coinflip\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"returns shouldProgress: false when scope does not match game\", () => {\n    const result = adapter(\n      makeEvent({ game: \"coinflip\" }),\n      makePlayer(),\n      makeAssignment({ scope: \"lord\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"works for closecall scope\", () => {\n    const result = adapter(\n      makeEvent({ game: \"closecall\" }),\n      makePlayer(),\n      makeAssignment({ scope: \"closecall\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"does not check isWinner (losers count too)\", () => {\n    const result = adapter(\n      makeEvent(),\n      makePlayer({ isWinner: false }),\n      makeAssignment({ scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n});\n\n// ---------------------------------------------------------------------------\n// game_won adapter\n// ---------------------------------------------------------------------------\n\ndescribe(\"game_won adapter\", () => {\n  const adapter = getAdapter(\"game_won\");\n\n  it(\"returns shouldProgress: true when player won and scope matches\", () => {\n    const result = adapter(\n      makeEvent({ game: \"coinflip\" }),\n      makePlayer({ isWinner: true }),\n      makeAssignment({ action: \"game_won\", scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"returns shouldProgress: false when player lost\", () => {\n    const result = adapter(\n      makeEvent(),\n      makePlayer({ isWinner: false }),\n      makeAssignment({ action: \"game_won\", scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns shouldProgress: false when scope does not match\", () => {\n    const result = adapter(\n      makeEvent({ game: \"lord\" }),\n      makePlayer({ isWinner: true }),\n      makeAssignment({ action: \"game_won\", scope: \"coinflip\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns shouldProgress: true for scope-specific win\", () => {\n    const result = adapter(\n      makeEvent({ game: \"lord\" }),\n      makePlayer({ isWinner: true }),\n      makeAssignment({ action: \"game_won\", scope: \"lord\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n});\n\n// ---------------------------------------------------------------------------\n// lobby_filled adapter\n// ---------------------------------------------------------------------------\n\ndescribe(\"lobby_filled adapter\", () => {\n  const adapter = getAdapter(\"lobby_filled\");\n\n  it(\"returns shouldProgress: true when player is creator and scope matches\", () => {\n    const result = adapter(\n      makeEvent({ game: \"coinflip\" }),\n      makePlayer({ isCreator: true }),\n      makeAssignment({ action: \"lobby_filled\", scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"returns shouldProgress: false when player is not creator\", () => {\n    const result = adapter(\n      makeEvent(),\n      makePlayer({ isCreator: false }),\n      makeAssignment({ action: \"lobby_filled\", scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns shouldProgress: false when scope does not match\", () => {\n    const result = adapter(\n      makeEvent({ game: \"closecall\" }),\n      makePlayer({ isCreator: true }),\n      makeAssignment({ action: \"lobby_filled\", scope: \"coinflip\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns shouldProgress: true for scope-specific lobby fill\", () => {\n    const result = adapter(\n      makeEvent({ game: \"closecall\" }),\n      makePlayer({ isCreator: true }),\n      makeAssignment({ action: \"lobby_filled\", scope: \"closecall\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Unknown adapter type\n// ---------------------------------------------------------------------------\n\ndescribe(\"unknown adapter type\", () => {\n  it(\"returns shouldProgress: false for unknown action\", () => {\n    const adapter = getAdapter(\"nonexistent_action\");\n    const result = adapter(makeEvent(), makePlayer(), makeAssignment({ action: \"nonexistent_action\" }));\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns a function (not undefined)\", () => {\n    const adapter = getAdapter(\"totally_made_up\");\n    expect(typeof adapter).toBe(\"function\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":248,"cache_read_input_tokens":64157,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":248},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"28ef500c-0633-4bbb-823d-2e1267ced5c0"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MrrY9trx6DBKofLTRhcLak","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/backend/services/backend/src/queue/__tests__/challenge-adapters.test.ts"}]},"parent_tool_use_id":null,"session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"5f8b9e21-feb3-4ef8-ad71-1c53616066b1","timestamp":"2026-04-03T19:31:24.501Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/__tests__/challenge-adapters.test.ts","content":"/**\n * Unit tests for challenge verification adapters and quest eligibility.\n *\n * Covers:\n * 1. questEligible — excludes refunded games (isWinner === null)\n * 2. game_completed adapter — scope filtering\n * 3. game_won adapter — scope + isWinner check\n * 4. lobby_filled adapter — scope + isCreator check\n * 5. Unknown adapter type — logs warning, returns shouldProgress: false\n */\n\nimport { describe, it, expect } from \"vitest\";\nimport {\n  questEligible,\n  getAdapter,\n  type GameSettledPayload,\n  type GameSettledPlayer,\n  type ChallengeAssignment,\n} from \"../handlers/challenge-adapters.js\";\n\n// ---------------------------------------------------------------------------\n// Test helpers\n// ---------------------------------------------------------------------------\n\nfunction makePlayer(overrides: Partial<GameSettledPlayer> = {}): GameSettledPlayer {\n  return {\n    userId: \"user-1\",\n    wallet: \"WaLLet111111111111111111111111111111111111111\",\n    amountLamports: \"1000000000\",\n    isWinner: true,\n    payoutLamports: \"1900000000\",\n    isCreator: false,\n    ...overrides,\n  };\n}\n\nfunction makeEvent(overrides: Partial<GameSettledPayload> = {}): GameSettledPayload {\n  return {\n    roundId: \"abc123\",\n    roundPda: \"PDA111111111111111111111111111111111111111111\",\n    game: \"coinflip\",\n    players: [makePlayer()],\n    feeLamports: \"100000000\",\n    settledAt: new Date().toISOString(),\n    ...overrides,\n  };\n}\n\nfunction makeAssignment(overrides: Partial<ChallengeAssignment> = {}): ChallengeAssignment {\n  return {\n    id: 1,\n    challengeId: 10,\n    action: \"game_completed\",\n    scope: \"any\",\n    condition: \"count\",\n    target: 5,\n    progress: 0,\n    status: \"active\",\n    ...overrides,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// questEligible\n// ---------------------------------------------------------------------------\n\ndescribe(\"questEligible\", () => {\n  it(\"returns true for a winning player\", () => {\n    expect(questEligible(makePlayer({ isWinner: true }))).toBe(true);\n  });\n\n  it(\"returns true for a losing player\", () => {\n    expect(questEligible(makePlayer({ isWinner: false }))).toBe(true);\n  });\n\n  it(\"returns false for a refunded player (isWinner === null)\", () => {\n    expect(questEligible(makePlayer({ isWinner: null }))).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// game_completed adapter\n// ---------------------------------------------------------------------------\n\ndescribe(\"game_completed adapter\", () => {\n  const adapter = getAdapter(\"game_completed\");\n\n  it(\"returns shouldProgress: true when scope is 'any'\", () => {\n    const result = adapter(makeEvent(), makePlayer(), makeAssignment({ scope: \"any\" }));\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"returns shouldProgress: true when scope matches game\", () => {\n    const result = adapter(\n      makeEvent({ game: \"coinflip\" }),\n      makePlayer(),\n      makeAssignment({ scope: \"coinflip\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"returns shouldProgress: false when scope does not match game\", () => {\n    const result = adapter(\n      makeEvent({ game: \"coinflip\" }),\n      makePlayer(),\n      makeAssignment({ scope: \"lord\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"works for closecall scope\", () => {\n    const result = adapter(\n      makeEvent({ game: \"closecall\" }),\n      makePlayer(),\n      makeAssignment({ scope: \"closecall\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"does not check isWinner (losers count too)\", () => {\n    const result = adapter(\n      makeEvent(),\n      makePlayer({ isWinner: false }),\n      makeAssignment({ scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n});\n\n// ---------------------------------------------------------------------------\n// game_won adapter\n// ---------------------------------------------------------------------------\n\ndescribe(\"game_won adapter\", () => {\n  const adapter = getAdapter(\"game_won\");\n\n  it(\"returns shouldProgress: true when player won and scope matches\", () => {\n    const result = adapter(\n      makeEvent({ game: \"coinflip\" }),\n      makePlayer({ isWinner: true }),\n      makeAssignment({ action: \"game_won\", scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"returns shouldProgress: false when player lost\", () => {\n    const result = adapter(\n      makeEvent(),\n      makePlayer({ isWinner: false }),\n      makeAssignment({ action: \"game_won\", scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns shouldProgress: false when scope does not match\", () => {\n    const result = adapter(\n      makeEvent({ game: \"lord\" }),\n      makePlayer({ isWinner: true }),\n      makeAssignment({ action: \"game_won\", scope: \"coinflip\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns shouldProgress: true for scope-specific win\", () => {\n    const result = adapter(\n      makeEvent({ game: \"lord\" }),\n      makePlayer({ isWinner: true }),\n      makeAssignment({ action: \"game_won\", scope: \"lord\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n});\n\n// ---------------------------------------------------------------------------\n// lobby_filled adapter\n// ---------------------------------------------------------------------------\n\ndescribe(\"lobby_filled adapter\", () => {\n  const adapter = getAdapter(\"lobby_filled\");\n\n  it(\"returns shouldProgress: true when player is creator and scope matches\", () => {\n    const result = adapter(\n      makeEvent({ game: \"coinflip\" }),\n      makePlayer({ isCreator: true }),\n      makeAssignment({ action: \"lobby_filled\", scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n\n  it(\"returns shouldProgress: false when player is not creator\", () => {\n    const result = adapter(\n      makeEvent(),\n      makePlayer({ isCreator: false }),\n      makeAssignment({ action: \"lobby_filled\", scope: \"any\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns shouldProgress: false when scope does not match\", () => {\n    const result = adapter(\n      makeEvent({ game: \"closecall\" }),\n      makePlayer({ isCreator: true }),\n      makeAssignment({ action: \"lobby_filled\", scope: \"coinflip\" }),\n    );\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns shouldProgress: true for scope-specific lobby fill\", () => {\n    const result = adapter(\n      makeEvent({ game: \"closecall\" }),\n      makePlayer({ isCreator: true }),\n      makeAssignment({ action: \"lobby_filled\", scope: \"closecall\" }),\n    );\n    expect(result).toEqual({ shouldProgress: true, progressDelta: 1 });\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Unknown adapter type\n// ---------------------------------------------------------------------------\n\ndescribe(\"unknown adapter type\", () => {\n  it(\"returns shouldProgress: false for unknown action\", () => {\n    const adapter = getAdapter(\"nonexistent_action\");\n    const result = adapter(makeEvent(), makePlayer(), makeAssignment({ action: \"nonexistent_action\" }));\n    expect(result).toEqual({ shouldProgress: false, progressDelta: 0 });\n  });\n\n  it(\"returns a function (not undefined)\", () => {\n    const adapter = getAdapter(\"totally_made_up\");\n    expect(typeof adapter).toBe(\"function\");\n  });\n});\n","structuredPatch":[],"originalFile":null}}
