{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BqGiqJSgy68p1MrCMs1LNL","type":"tool_result","content":"1\t/**\n2\t * Handler registry — maps event type strings to handler functions.\n3\t *\n4\t * One handler per event type (no pub/sub fan-out for v1).\n5\t * Handlers must be idempotent — re-processing is a safe no-op.\n6\t */\n7\t\n8\timport type { EventType } from \"./event-types.js\";\n9\t\n10\texport type EventHandler = (\n11\t  payload: Record<string, unknown>,\n12\t) => Promise<void>;\n13\t\n14\tconst handlers = new Map<string, EventHandler>();\n15\t\n16\texport function registerHandler(\n17\t  eventType: EventType,\n18\t  handler: EventHandler,\n19\t): void {\n20\t  handlers.set(eventType, handler);\n21\t}\n22\t\n23\texport function getHandler(eventType: string): EventHandler | undefined {\n24\t  return handlers.get(eventType);\n25\t}\n26\t\n27\t/** Remove all registered handlers. Used by tests for isolation. */\n28\texport function clearHandlers(): void {\n29\t  handlers.clear();\n30\t}\n31\t"}]},"parent_tool_use_id":"toolu_01NexKQGxRmVdUbtyxqrufdk","session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"69323c36-0fd0-4bee-b88e-8ef8739c5baa","timestamp":"2026-04-03T19:28:35.753Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018BaYd5DdUYKeUvRo7ek4f4","type":"tool_result","content":"1\t/**\n2\t * Known event type constants for the async event queue.\n3\t *\n4\t * Using a const object + derived union makes typos a compile error\n5\t * instead of a dead event at runtime.\n6\t */\n7\t\n8\texport const EventTypes = {\n9\t  REFERRAL_CODE_APPLIED: \"referral.code_applied\",\n10\t  REFERRAL_GAME_SETTLED: \"referral.game_settled\",\n11\t  REFERRAL_CLAIM_REQUESTED: \"referral.claim_requested\",\n12\t  GAME_SETTLED: \"game.settled\",\n13\t  REWARD_POOL_FUND: \"reward.pool_fund\",\n14\t  POINTS_GRANT: \"points.grant\",\n15\t  CRATE_DROP: \"crate.drop\",\n16\t  CRATE_SOL_PAYOUT: \"crate.sol_payout\",\n17\t} as const;\n18\t\n19\texport type EventType = (typeof EventTypes)[keyof typeof EventTypes];\n20\t"}]},"parent_tool_use_id":"toolu_01NexKQGxRmVdUbtyxqrufdk","session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"afdf7844-69c1-416b-924c-69fec5f41deb","timestamp":"2026-04-03T19:28:35.768Z"}
