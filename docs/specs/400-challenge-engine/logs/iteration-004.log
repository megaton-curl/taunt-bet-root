{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RnvXL8pL6Zm1eCuox4CFmY","type":"tool_result","content":"1\t/**\n2\t * Integration tests for the event queue worker.\n3\t *\n4\t * Tests the full lifecycle: emit → worker poll → handler dispatch → status transitions.\n5\t * Requires a running Postgres database (same as backend).\n6\t *\n7\t * Covers:\n8\t * 1. Happy path — handler called, event status = completed\n9\t * 2. Failure → retry → dead — attempts increment, backoff applied, final status = dead\n10\t * 3. Concurrent safety — two workers, SKIP LOCKED, each event processed exactly once\n11\t */\n12\t\n13\timport {\n14\t  describe,\n15\t  it,\n16\t  beforeAll,\n17\t  afterAll,\n18\t  beforeEach,\n19\t  expect,\n20\t} from \"vitest\";\n21\timport postgres from \"postgres\";\n22\timport { emitEvent } from \"../emit-event.js\";\n23\timport {\n24\t  registerHandler,\n25\t  clearHandlers,\n26\t} from \"../handler-registry.js\";\n27\timport { EventTypes } from \"../event-types.js\";\n28\timport { createEventWorker } from \"../worker.js\";\n29\t\n30\t/** Poll until condition is true or timeout. */\n31\tasync function waitFor(\n32\t  condition: () => boolean,\n33\t  timeoutMs: number,\n34\t): Promise<void> {\n35\t  const start = Date.now();\n36\t  while (!condition()) {\n37\t    if (Date.now() - start > timeoutMs) {\n38\t      throw new Error(`waitFor timed out after ${timeoutMs}ms`);\n39\t    }\n40\t    await new Promise((r) => setTimeout(r, 50));\n41\t  }\n42\t}\n43\t\n44\tdescribe(\"event queue integration tests\", () => {\n45\t  let sql: ReturnType<typeof postgres>;\n46\t\n47\t  beforeAll(async () => {\n48\t    sql = process.env.DATABASE_URL\n49\t      ? postgres(process.env.DATABASE_URL)\n50\t      : postgres({\n51\t          host: \"/var/run/postgresql\",\n52\t          database: \"rng_utopia_dev\",\n53\t          username: \"vscode\",\n54\t        });\n55\t  });\n56\t\n57\t  afterAll(async () => {\n58\t    await sql.end();\n59\t  });\n60\t\n61\t  beforeEach(async () => {\n62\t    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n63\t    clearHandlers();\n64\t  });\n65\t\n66\t  // -------------------------------------------------------------------------\n67\t  // 1. Happy path\n68\t  // -------------------------------------------------------------------------\n69\t\n70\t  it(\"happy path: handler called and event status = completed\", async () => {\n71\t    let handlerCalled = false;\n72\t    let capturedPayload: Record<string, unknown> | null = null;\n73\t\n74\t    registerHandler(EventTypes.REFERRAL_GAME_SETTLED, async (payload) => {\n75\t      handlerCalled = true;\n76\t      capturedPayload = payload;\n77\t    });\n78\t\n79\t    const payload = { referrerWallet: \"abc\", roundId: \"test-round\" };\n80\t    await sql.begin(async (tx) => {\n81\t      await emitEvent(\n82\t        tx as unknown as postgres.Sql,\n83\t        EventTypes.REFERRAL_GAME_SETTLED,\n84\t        payload,\n85\t      );\n86\t    });\n87\t\n88\t    const worker = createEventWorker(sql, { pollIntervalMs: 100 });\n89\t    worker.start();\n90\t\n91\t    // Wait for handler to be called (up to 3s)\n92\t    await waitFor(() => handlerCalled, 3000);\n93\t    worker.stop();\n94\t\n95\t    expect(handlerCalled).toBe(true);\n96\t    expect(capturedPayload).toEqual(payload);\n97\t\n98\t    // Verify DB status\n99\t    const rows = await sql`SELECT * FROM event_queue WHERE status = 'completed'`;\n100\t    expect(rows).toHaveLength(1);"}]},"parent_tool_use_id":"toolu_01NexKQGxRmVdUbtyxqrufdk","session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"4080d947-6601-48af-b5f4-eda4766927e1","timestamp":"2026-04-03T19:29:07.628Z"}
