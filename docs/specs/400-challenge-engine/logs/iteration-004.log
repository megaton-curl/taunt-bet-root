{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HxFRt9gQgDs7ZqnArXYvHH","type":"tool_result","content":"1\t/**\n2\t * Unit tests for the async event queue module.\n3\t *\n4\t * Covers:\n5\t * 1. emitEvent — inserts with correct fields, returns eventId\n6\t * 2. emitEvent — rolled-back transaction does NOT persist\n7\t * 3. Handler registry — register/get, unknown returns undefined\n8\t * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n9\t *\n10\t * Requires a running Postgres database (same as backend).\n11\t */\n12\t\n13\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n14\timport postgres from \"postgres\";\n15\timport { emitEvent } from \"../emit-event.js\";\n16\timport { registerHandler, getHandler } from \"../handler-registry.js\";\n17\timport { EventTypes } from \"../event-types.js\";\n18\timport { getBackoffSeconds } from \"../worker.js\";\n19\t\n20\tdescribe(\"event queue unit tests\", () => {\n21\t  let sql: ReturnType<typeof postgres>;\n22\t\n23\t  beforeAll(async () => {\n24\t    sql = process.env.DATABASE_URL\n25\t      ? postgres(process.env.DATABASE_URL)\n26\t      : postgres({\n27\t          host: \"/var/run/postgresql\",\n28\t          database: \"rng_utopia_dev\",\n29\t          username: \"vscode\",\n30\t        });"}]},"parent_tool_use_id":null,"session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"9737bed9-672c-4bfd-927e-b215f633416f","timestamp":"2026-04-03T19:30:55.075Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/__tests__/queue.test.ts","content":"/**\n * Unit tests for the async event queue module.\n *\n * Covers:\n * 1. emitEvent — inserts with correct fields, returns eventId\n * 2. emitEvent — rolled-back transaction does NOT persist\n * 3. Handler registry — register/get, unknown returns undefined\n * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n *\n * Requires a running Postgres database (same as backend).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport postgres from \"postgres\";\nimport { emitEvent } from \"../emit-event.js\";\nimport { registerHandler, getHandler } from \"../handler-registry.js\";\nimport { EventTypes } from \"../event-types.js\";\nimport { getBackoffSeconds } from \"../worker.js\";\n\ndescribe(\"event queue unit tests\", () => {\n  let sql: ReturnType<typeof postgres>;\n\n  beforeAll(async () => {\n    sql = process.env.DATABASE_URL\n      ? postgres(process.env.DATABASE_URL)\n      : postgres({\n          host: \"/var/run/postgresql\",\n          database: \"rng_utopia_dev\",\n          username: \"vscode\",\n        });","numLines":30,"startLine":1,"totalLines":157}}}
