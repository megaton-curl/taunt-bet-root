, agg]) => ({\n        userId: profileMap.get(wallet)?.user_id ?? wallet,\n        wallet,\n        amountLamports: String(agg.total),\n        isWinner: agg.isWinner,\n        payoutLamports: agg.isWinner ? String(payoutAmount) : \"0\",\n        isCreator: serializedEntries[0]?.player === wallet, // first entry is creator","is_error":false}]},"parent_tool_use_id":"toolu_012uVnuaN6MtseZ8yLSM3NZr","session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"1f52a06c-f6e3-43b4-b4b2-a3c6d07fe54a","timestamp":"2026-04-03T19:29:17.551Z"}
