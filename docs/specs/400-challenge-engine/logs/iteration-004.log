{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BgXvDar8YXVrTCaZU5F1Rj","type":"tool_result","content":"1\t/**\n2\t * Queue health — provides event counts by status for observability.\n3\t */\n4\t\n5\timport type postgres from \"postgres\";\n6\t\n7\texport interface QueueDepth {\n8\t  pending: number;\n9\t  processing: number;\n10\t  dead: number;\n11\t  completed: number;\n12\t}\n13\t\n14\texport async function getQueueDepth(sql: postgres.Sql): Promise<QueueDepth> {\n15\t  const rows = await sql<{ status: string; count: string }[]>`\n16\t    SELECT status, count(*)::text AS count\n17\t    FROM event_queue\n18\t    WHERE status IN ('pending', 'processing', 'dead', 'completed')\n19\t    GROUP BY status\n20\t  `;\n21\t\n22\t  const counts: QueueDepth = { pending: 0, processing: 0, dead: 0, completed: 0 };\n23\t  for (const row of rows) {\n24\t    if (row.status in counts) {\n25\t      counts[row.status as keyof QueueDepth] = parseInt(row.count, 10);\n26\t    }\n27\t  }\n28\t  return counts;\n29\t}\n30\t"}]},"parent_tool_use_id":"toolu_012uVnuaN6MtseZ8yLSM3NZr","session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"67476e00-f556-4f7e-8d6d-1bd4360c9fa1","timestamp":"2026-04-03T19:28:56.594Z"}
