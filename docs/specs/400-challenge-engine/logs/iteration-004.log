{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SHD77Bxx49RZEHkPoeAqry","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createInternalRoutes } from \"./routes/internal.js\";\n21\timport { swaggerUI } from \"@hono/swagger-ui\";\n22\timport { spec } from \"./openapi.js\";\n23\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n24\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n25\timport { createSettlementWorker } from \"./worker/settlement.js\";\n26\timport { settleRound } from \"./worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"./worker/retry.js\";\n28\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n29\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n30\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n31\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n32\timport { logger } from \"./logger.js\";\n33\t\n34\tconst config = loadConfig();\n35\t\n36\t// Single postgres pool shared by game DB, auth DB, and all workers\n37\tconst sql = postgres(config.databaseUrl);\n38\tconst db = createDb(config.databaseUrl, sql);\n39\tconst authDb = createAuthDb(sql);\n40\t\n41\tconst connection = new Connection(config.rpcUrl, {\n42\t  commitment: \"confirmed\",\n43\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n44\t});\n45\t\n46\tconst app = new Hono();\n47\t\n48\tapp.use(\n49\t  \"*\",\n50\t  cors({\n51\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n52\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n53\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n54\t  }),\n55\t);\n56\t\n57\t// Request logging — correlate frontend fetch timing with server-side processing\n58\tapp.use(\"*\", async (c, next) => {\n59\t  const start = Date.now();\n60\t  await next();\n61\t  const ms = Date.now() - start;\n62\t  const method = c.req.method;\n63\t  const path = c.req.path;\n64\t  // Skip noisy health checks and OPTIONS preflight\n65\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n66\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n67\t});\n68\t\n69\t// API docs — Swagger UI + raw OpenAPI spec\n70\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n71\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n72\t\n73\t// Auth routes — no JWT middleware (these are the login endpoints)\n74\t// Lighter rate limiting by IP for auth endpoints\n75\tapp.use(\n76\t  \"/auth/*\",\n77\t  createRateLimitMiddleware({\n78\t    perWallet: 20,\n79\t    global: config.rateLimitGlobal,\n80\t    windowMs: 60_000,\n81\t  }),\n82\t);\n83\t\n84\tapp.route(\n85\t  \"/auth\",\n86\t  createAuthRoutes({\n87\t    authDb,\n88\t    db,\n89\t    jwtSecret: config.jwtSecret,\n90\t    cluster: config.cluster,\n91\t    challengeTtlSeconds: config.challengeTtlSeconds,\n92\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n93\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n94\t  }),\n95\t);\n96\t\n97\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n98\tapp.use(\n99\t  \"/profile/*\",\n100\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n101\t);\n102\tapp.route(\"/profile\", createProfileRoutes({ db }));\n103\t\n104\t// Public profile routes — no auth required\n105\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n106\t\n107\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n108\tapp.use(\n109\t  \"/referral/*\",\n110\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n111\t);\n112\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n113\t\n114\t// JWT auth middleware for game endpoints\n115\tapp.use(\n116\t  \"/coinflip/*\",\n117\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n118\t);\n119\tapp.use(\n120\t  \"/lord/*\",\n121\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n122\t);\n123\t\n124\t// Rate limiting — per-wallet and global limits on POST requests\n125\tapp.use(\n126\t  \"/coinflip/*\",\n127\t  createRateLimitMiddleware({\n128\t    perWallet: config.rateLimitPerWallet,\n129\t    global: config.rateLimitGlobal,\n130\t    windowMs: 60_000,\n131\t  }),\n132\t);\n133\tapp.use(\n134\t  \"/lord/*\",\n135\t  createRateLimitMiddleware({\n136\t    perWallet: config.rateLimitPerWallet,\n137\t    global: config.rateLimitGlobal,\n138\t    windowMs: 60_000,\n139\t  }),\n140\t);\n141\t\n142\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n143\tconst entropyAccount = new PublicKey(config.entropyAccount);\n144\tconst retrySettler = createRetrySettler({\n145\t  db,\n146\t  connection,\n147\t  settleRound: (pda) =>\n148\t    settleRound(\n149\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n150\t      pda,\n151\t    ),\n152\t});\n153\t\n154\t// PDA watcher — WebSocket-based instant join detection\n155\tconst pdaWatcher = createPdaWatcher({\n156\t  connection,\n157\t  serverKey: config.serverKeypair.publicKey,\n158\t  db,\n159\t  onJoinDetected: async (pda, targetSlot) => {\n160\t    // Update DB phase if still in 'created'\n161\t    const round = await db.getRoundByPda(pda);\n162\t    if (round && round.phase === \"created\") {\n163\t      await db.updateRoundPhase(pda, \"locked\", {\n164\t        target_slot: targetSlot.toString(),\n165\t      });\n166\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n167\t        targetSlot: targetSlot.toString(),\n168\t        source: \"pda-watcher\",\n169\t        game: round.game,\n170\t      });\n171\t    }\n172\t\n173\t    // Check if target slot already passed — settle immediately if so\n174\t    const currentSlot = await connection.getSlot();\n175\t    if (BigInt(currentSlot) >= targetSlot) {\n176\t      await retrySettler.attemptSettle(pda);\n177\t      pdaWatcher.unwatch(pda);\n178\t    }\n179\t    // If target slot not reached yet, poll worker will pick it up next cycle\n180\t  },\n181\t});\n182\t\n183\tconst worker = createSettlementWorker({\n184\t  db,\n185\t  connection,\n186\t  serverKey: config.serverKeypair.publicKey,\n187\t  pollIntervalMs: config.workerPollIntervalMs,\n188\t  onSettleReady: async (pda) => {\n189\t    await retrySettler.attemptSettle(pda);\n190\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n191\t  },\n192\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n193\t});\n194\tworker.start();\n195\t\n196\t// Close Call clock worker — fetches boundary prices + settles open rounds\n197\t// Rounds are created on-demand by players via /closecall/bet\n198\tconst closeCallClock = createCloseCallClockWorker({\n199\t  connection,\n200\t  serverKeypair: config.serverKeypair,\n201\t  db,\n202\t});\n203\tcloseCallClock.start();\n204\t\n205\t// Register event handlers before starting the worker\n206\tregisterHandler(\n207\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n208\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n209\t);\n210\t\n211\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n212\tconst eventWorker = createEventWorker(sql, {\n213\t  pollIntervalMs: config.eventQueuePollMs,\n214\t});\n215\teventWorker.start();\n216\tlogger.info(\"Event queue worker started\", {\n217\t  pollIntervalMs: config.eventQueuePollMs,\n218\t});\n219\t\n220\t// Game-specific routes\n221\tapp.route(\n222\t  \"/coinflip\",\n223\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n224\t);\n225\tapp.route(\n226\t  \"/lord\",\n227\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n228\t);\n229\t\n230\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n231\tapp.use(\n232\t  \"/closecall/bet\",\n233\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n234\t);\n235\tapp.use(\n236\t  \"/closecall/bet\",\n237\t  createRateLimitMiddleware({\n238\t    perWallet: config.rateLimitPerWallet,\n239\t    global: config.rateLimitGlobal,\n240\t    windowMs: 60_000,\n241\t  }),\n242\t);\n243\t\n244\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n245\tapp.route(\"/closecall\", createCloseCallRoutes({\n246\t  db,\n247\t  connection,\n248\t  serverKeypair: config.serverKeypair,\n249\t  clockWorker: closeCallClock,\n250\t}));\n251\t\n252\t// Leaderboard routes — public, no auth\n253\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n254\t\n255\t// Price routes — public, no auth\n256\tapp.route(\"/price\", createPriceRoutes());\n257\t\n258\t// Round verification routes\n259\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n260\t\n261\t// Health endpoint — wired after worker exists so we can query its status\n262\tapp.route(\n263\t  \"/health\",\n264\t  createHealthRoutes({\n265\t    db,\n266\t    sql,\n267\t    isWorkerRunning: () => worker.isRunning,\n268\t  }),\n269\t);\n270\t\n271\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n272\tif (config.adminToken) {\n273\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n274\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n275\t}\n276\t\n277\tconst port = config.port;\n278\tlogger.info(\"fairness-backend started\", { port });\n279\t\n280\tserve({\n281\t  fetch: app.fetch,\n282\t  port,\n283\t  hostname: \"0.0.0.0\",\n284\t});\n285\t\n286\texport default {\n287\t  port,\n288\t  fetch: app.fetch,\n289\t};\n290\t"}]},"parent_tool_use_id":"toolu_012uVnuaN6MtseZ8yLSM3NZr","session_id":"f10eba72-1ffd-4ead-a08a-c9ca057b30d5","uuid":"2f9c57d4-3162-456b-a304-852d1be8d51f","timestamp":"2026-04-03T19:28:59.240Z"}
