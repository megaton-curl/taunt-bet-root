{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E4d4bLWU7UKTPQBGFFpi5w","type":"tool_result","content":"1\t/**\n2\t * GAME_SETTLED handler — the orchestrator for the challenge engine.\n3\t *\n4\t * Processes each player in a settled game event:\n5\t *   1. Quest eligibility check (skip refunded games)\n6\t *   2. Challenge progress evaluation via adapters\n7\t *   3. Reward intent emission on challenge completion\n8\t *   4. Wager-based points grant\n9\t *   5. Crate drop roll\n10\t *\n11\t * Once per round: reward pool funding.\n12\t *\n13\t * Per-player try/catch ensures one player's error doesn't block others.\n14\t * Idempotent via UNIQUE constraints on progress_events, point_grants,\n15\t * crate_drops, and reward_pool_fundings.\n16\t */\n17\t\n18\timport type { Db } from \"../../db.js\";\n19\timport { logger } from \"../../logger.js\";\n20\timport { emitEvent } from \"../emit-event.js\";\n21\timport { EventTypes } from \"../event-types.js\";\n22\timport {\n23\t  questEligible,\n24\t  getAdapter,\n25\t  type GameSettledPayload,\n26\t  type GameSettledPlayer,\n27\t  type ChallengeAssignment,\n28\t} from \"./challenge-adapters.js\";\n29\t\n30\t// ---------------------------------------------------------------------------\n31\t// DB helpers\n32\t// ---------------------------------------------------------------------------\n33\t\n34\t/** Row shape from the active-assignments + challenges JOIN. */\n35\tinterface AssignmentWithChallenge {\n36\t  id: string;\n37\t  challenge_id: string;\n38\t  action: string;\n39\t  scope: string;\n40\t  condition: string;\n41\t  target: number;\n42\t  progress: number;\n43\t  status: string;\n44\t  period_key: string;\n45\t  campaign_id: string;\n46\t  reward_type: string;\n47\t  reward_amount: number | null;\n48\t}\n49\t\n50\t/**\n51\t * Load active challenge assignments for a user, joined with their challenge\n52\t * definitions. Uses the partial index on (user_id, status) WHERE status='active'.\n53\t */\n54\texport async function getActiveAssignmentsWithChallenge(\n55\t  db: Db,\n56\t  userId: string,\n57\t): Promise<AssignmentWithChallenge[]> {\n58\t  return db.rawSql<AssignmentWithChallenge[]>`\n59\t    SELECT\n60\t      ca.id,\n61\t      ca.challenge_id,\n62\t      c.action,\n63\t      c.scope,\n64\t      c.condition,\n65\t      ca.target,\n66\t      ca.progress,\n67\t      ca.status,\n68\t      ca.period_key,\n69\t      c.campaign_id,\n70\t      c.reward_type,\n71\t      c.reward_amount\n72\t    FROM challenge_assignments ca\n73\t    JOIN challenges c ON c.id = ca.challenge_id\n74\t    WHERE ca.user_id = ${userId}\n75\t      AND ca.status = 'active'\n76\t  `;\n77\t}\n78\t\n79\t/**\n80\t * Insert a progress event. Returns false if a row for this\n81\t * (assignment_id, round_id) already exists (idempotency guard).\n82\t */\n83\texport async function insertProgressEvent(\n84\t  db: Db,\n85\t  assignmentId: string,\n86\t  roundId: string,\n87\t  userId: string,\n88\t  delta: number,\n89\t  metadata: Record<string, unknown>,\n90\t): Promise<boolean> {\n91\t  const rows = await db.rawSql<{ id: string }[]>`\n92\t    INSERT INTO progress_events (assignment_id, round_id, user_id, progress_delta, metadata)\n93\t    VALUES (${assignmentId}, ${roundId}, ${userId}, ${delta}, ${JSON.stringify(metadata)})\n94\t    ON CONFLICT (assignment_id, round_id) DO NOTHING\n95\t    RETURNING id\n96\t  `;\n97\t  return rows.length > 0;\n98\t}\n99\t\n100\t/**\n101\t * Atomically increment an assignment's progress by delta.\n102\t * Returns the new progress value.\n103\t */\n104\texport async function incrementAssignmentProgress(\n105\t  db: Db,\n106\t  assignmentId: string,\n107\t  delta: number,\n108\t): Promise<number> {\n109\t  const rows = await db.rawSql<{ progress: number }[]>`\n110\t    UPDATE challenge_assignments\n111\t    SET progress = progress + ${delta}\n112\t    WHERE id = ${assignmentId}\n113\t    RETURNING progress\n114\t  `;\n115\t  return rows[0]!.progress;\n116\t}\n117\t\n118\t/**\n119\t * Mark an assignment as completed with a timestamp.\n120\t */\n121\texport async function markAssignmentCompleted(\n122\t  db: Db,\n123\t  assignmentId: string,\n124\t): Promise<void> {\n125\t  await db.rawSql`\n126\t    UPDATE challenge_assignments\n127\t    SET status = 'completed', completed_at = now()\n128\t    WHERE id = ${assignmentId}\n129\t  `;\n130\t}\n131\t\n132\t// ---------------------------------------------------------------------------\n133\t// Handler factory\n134\t// ---------------------------------------------------------------------------\n135\t\n136\texport interface GameSettledDeps {\n137\t  db: Db;\n138\t}\n139\t\n140\texport function createGameSettledHandler(deps: GameSettledDeps) {\n141\t  const { db } = deps;\n142\t\n143\t  return async (payload: Record<string, unknown>): Promise<void> => {\n144\t    // Validate and cast payload\n145\t    const roundId = payload.roundId as string;\n146\t    const game = payload.game as string;\n147\t    const players = payload.players as GameSettledPlayer[] | undefined;\n148\t    const feeLamports = payload.feeLamports as string;\n149\t    const settledAt = payload.settledAt as string;\n150\t    const roundPda = payload.roundPda as string;\n151\t\n152\t    if (!roundId || !game || !players || !feeLamports || !settledAt) {\n153\t      throw new Error(\n154\t        \"game.settled: malformed payload — missing roundId, game, players, feeLamports, or settledAt\",\n155\t      );\n156\t    }\n157\t\n158\t    // --- Once per round: emit reward.pool_fund ---\n159\t    await emitEvent(db.rawSql, EventTypes.REWARD_POOL_FUND, {\n160\t      roundId,\n161\t      roundPda,\n162\t      feeLamports,\n163\t    });\n164\t\n165\t    // --- Per-player processing ---\n166\t    for (const player of players) {\n167\t      try {\n168\t        // Quest eligibility gate — skip refunded games\n169\t        if (!questEligible(player)) {\n170\t          logger.debug(\"game.settled: player ineligible (refund)\", {\n171\t            userId: player.userId,\n172\t            roundId,\n173\t          });\n174\t          continue;\n175\t        }\n176\t\n177\t        // ---- Challenge progress evaluation ----\n178\t        const assignments = await getActiveAssignmentsWithChallenge(\n179\t          db,\n180\t          player.userId,\n181\t        );\n182\t\n183\t        for (const assignment of assignments) {\n184\t          const adapter = getAdapter(assignment.action);\n185\t          const challengeAssignment: ChallengeAssignment = {\n186\t            id: Number(assignment.id),\n187\t            challengeId: Number(assignment.challenge_id),\n188\t            action: assignment.action,\n189\t            scope: assignment.scope,\n190\t            condition: assignment.condition,\n191\t            target: assignment.target,\n192\t            progress: assignment.progress,\n193\t            status: assignment.status,\n194\t          };\n195\t\n196\t          const result = adapter(\n197\t            payload as unknown as GameSettledPayload,\n198\t            player,\n199\t            challengeAssignment,\n200\t          );\n201\t\n202\t          if (!result.shouldProgress) continue;\n203\t\n204\t          // Atomic: insert progress event + increment progress\n205\t          await db.withTransaction(async (txDb) => {\n206\t            const inserted = await insertProgressEvent(\n207\t              txDb,\n208\t              assignment.id,\n209\t              roundId,\n210\t              player.userId,\n211\t              result.progressDelta,\n212\t              { game },\n213\t            );\n214\t            if (!inserted) {\n215\t              // Duplicate round for this assignment — skip\n216\t              return;\n217\t            }\n218\t\n219\t            const newProgress = await incrementAssignmentProgress(\n220\t              txDb,\n221\t              assignment.id,\n222\t              result.progressDelta,\n223\t            );\n224\t\n225\t            // Check completion\n226\t            if (newProgress >= assignment.target) {\n227\t              await markAssignmentCompleted(txDb, assignment.id);\n228\t\n229\t              // Emit reward intent based on challenge's reward_type\n230\t              if (assignment.reward_type === \"points\" && assignment.reward_amount) {\n231\t                await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n232\t                  userId: player.userId,\n233\t                  wallet: player.wallet,\n234\t                  sourceType: \"challenge_completed\",\n235\t                  sourceId: `challenge-${assignment.id}`,\n236\t                  amount: assignment.reward_amount.toString(),\n237\t                });\n238\t              } else if (assignment.reward_type === \"crate\") {\n239\t                await emitEvent(txDb.rawSql, EventTypes.CRATE_DROP, {\n240\t                  userId: player.userId,\n241\t                  wallet: player.wallet,\n242\t                  triggerType: \"challenge_completed\",\n243\t                  triggerId: `challenge-${assignment.id}`,\n244\t                });\n245\t              }\n246\t\n247\t              logger.info(\"game.settled: challenge completed\", {\n248\t                userId: player.userId,\n249\t                assignmentId: assignment.id,\n250\t                challengeId: assignment.challenge_id,\n251\t                rewardType: assignment.reward_type,\n252\t              });\n253\t            }\n254\t          });\n255\t        }\n256\t\n257\t        // ---- Wager-based points grant ----\n258\t        await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n259\t          userId: player.userId,\n260\t          wallet: player.wallet,\n261\t          sourceType: \"wager\",\n262\t          sourceId: roundId,\n263\t          amountLamports: player.amountLamports,\n264\t          settledAt,\n265\t        });\n266\t\n267\t        // ---- Crate drop ----\n268\t        await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n269\t          userId: player.userId,\n270\t          wallet: player.wallet,\n271\t          triggerType: \"game_settled\",\n272\t          triggerId: roundId,\n273\t        });\n274\t      } catch (err) {\n275\t        // Per-player try/catch — don't let one player's error block others\n276\t        logger.error(\"game.settled: error processing player\", {\n277\t          userId: player.userId,\n278\t          roundId,\n279\t          error: err instanceof Error ? err.message : String(err),\n280\t        });\n281\t      }\n282\t    }\n283\t\n284\t    logger.info(\"game.settled: processed\", {\n285\t      roundId,\n286\t      game,\n287\t      playerCount: players.length,\n288\t    });\n289\t  };\n290\t}\n291\t"}]},"parent_tool_use_id":null,"session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"2821fb4e-76df-4505-b8df-f05050bfa01d","timestamp":"2026-04-03T20:20:54.013Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/game-settled.ts","content":"/**\n * GAME_SETTLED handler — the orchestrator for the challenge engine.\n *\n * Processes each player in a settled game event:\n *   1. Quest eligibility check (skip refunded games)\n *   2. Challenge progress evaluation via adapters\n *   3. Reward intent emission on challenge completion\n *   4. Wager-based points grant\n *   5. Crate drop roll\n *\n * Once per round: reward pool funding.\n *\n * Per-player try/catch ensures one player's error doesn't block others.\n * Idempotent via UNIQUE constraints on progress_events, point_grants,\n * crate_drops, and reward_pool_fundings.\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\nimport { emitEvent } from \"../emit-event.js\";\nimport { EventTypes } from \"../event-types.js\";\nimport {\n  questEligible,\n  getAdapter,\n  type GameSettledPayload,\n  type GameSettledPlayer,\n  type ChallengeAssignment,\n} from \"./challenge-adapters.js\";\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Row shape from the active-assignments + challenges JOIN. */\ninterface AssignmentWithChallenge {\n  id: string;\n  challenge_id: string;\n  action: string;\n  scope: string;\n  condition: string;\n  target: number;\n  progress: number;\n  status: string;\n  period_key: string;\n  campaign_id: string;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\n/**\n * Load active challenge assignments for a user, joined with their challenge\n * definitions. Uses the partial index on (user_id, status) WHERE status='active'.\n */\nexport async function getActiveAssignmentsWithChallenge(\n  db: Db,\n  userId: string,\n): Promise<AssignmentWithChallenge[]> {\n  return db.rawSql<AssignmentWithChallenge[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      c.action,\n      c.scope,\n      c.condition,\n      ca.target,\n      ca.progress,\n      ca.status,\n      ca.period_key,\n      c.campaign_id,\n      c.reward_type,\n      c.reward_amount\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.status = 'active'\n  `;\n}\n\n/**\n * Insert a progress event. Returns false if a row for this\n * (assignment_id, round_id) already exists (idempotency guard).\n */\nexport async function insertProgressEvent(\n  db: Db,\n  assignmentId: string,\n  roundId: string,\n  userId: string,\n  delta: number,\n  metadata: Record<string, unknown>,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO progress_events (assignment_id, round_id, user_id, progress_delta, metadata)\n    VALUES (${assignmentId}, ${roundId}, ${userId}, ${delta}, ${JSON.stringify(metadata)})\n    ON CONFLICT (assignment_id, round_id) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n/**\n * Atomically increment an assignment's progress by delta.\n * Returns the new progress value.\n */\nexport async function incrementAssignmentProgress(\n  db: Db,\n  assignmentId: string,\n  delta: number,\n): Promise<number> {\n  const rows = await db.rawSql<{ progress: number }[]>`\n    UPDATE challenge_assignments\n    SET progress = progress + ${delta}\n    WHERE id = ${assignmentId}\n    RETURNING progress\n  `;\n  return rows[0]!.progress;\n}\n\n/**\n * Mark an assignment as completed with a timestamp.\n */\nexport async function markAssignmentCompleted(\n  db: Db,\n  assignmentId: string,\n): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'completed', completed_at = now()\n    WHERE id = ${assignmentId}\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Handler factory\n// ---------------------------------------------------------------------------\n\nexport interface GameSettledDeps {\n  db: Db;\n}\n\nexport function createGameSettledHandler(deps: GameSettledDeps) {\n  const { db } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    // Validate and cast payload\n    const roundId = payload.roundId as string;\n    const game = payload.game as string;\n    const players = payload.players as GameSettledPlayer[] | undefined;\n    const feeLamports = payload.feeLamports as string;\n    const settledAt = payload.settledAt as string;\n    const roundPda = payload.roundPda as string;\n\n    if (!roundId || !game || !players || !feeLamports || !settledAt) {\n      throw new Error(\n        \"game.settled: malformed payload — missing roundId, game, players, feeLamports, or settledAt\",\n      );\n    }\n\n    // --- Once per round: emit reward.pool_fund ---\n    await emitEvent(db.rawSql, EventTypes.REWARD_POOL_FUND, {\n      roundId,\n      roundPda,\n      feeLamports,\n    });\n\n    // --- Per-player processing ---\n    for (const player of players) {\n      try {\n        // Quest eligibility gate — skip refunded games\n        if (!questEligible(player)) {\n          logger.debug(\"game.settled: player ineligible (refund)\", {\n            userId: player.userId,\n            roundId,\n          });\n          continue;\n        }\n\n        // ---- Challenge progress evaluation ----\n        const assignments = await getActiveAssignmentsWithChallenge(\n          db,\n          player.userId,\n        );\n\n        for (const assignment of assignments) {\n          const adapter = getAdapter(assignment.action);\n          const challengeAssignment: ChallengeAssignment = {\n            id: Number(assignment.id),\n            challengeId: Number(assignment.challenge_id),\n            action: assignment.action,\n            scope: assignment.scope,\n            condition: assignment.condition,\n            target: assignment.target,\n            progress: assignment.progress,\n            status: assignment.status,\n          };\n\n          const result = adapter(\n            payload as unknown as GameSettledPayload,\n            player,\n            challengeAssignment,\n          );\n\n          if (!result.shouldProgress) continue;\n\n          // Atomic: insert progress event + increment progress\n          await db.withTransaction(async (txDb) => {\n            const inserted = await insertProgressEvent(\n              txDb,\n              assignment.id,\n              roundId,\n              player.userId,\n              result.progressDelta,\n              { game },\n            );\n            if (!inserted) {\n              // Duplicate round for this assignment — skip\n              return;\n            }\n\n            const newProgress = await incrementAssignmentProgress(\n              txDb,\n              assignment.id,\n              result.progressDelta,\n            );\n\n            // Check completion\n            if (newProgress >= assignment.target) {\n              await markAssignmentCompleted(txDb, assignment.id);\n\n              // Emit reward intent based on challenge's reward_type\n              if (assignment.reward_type === \"points\" && assignment.reward_amount) {\n                await emitEvent(txDb.rawSql, EventTypes.POINTS_GRANT, {\n                  userId: player.userId,\n                  wallet: player.wallet,\n                  sourceType: \"challenge_completed\",\n                  sourceId: `challenge-${assignment.id}`,\n                  amount: assignment.reward_amount.toString(),\n                });\n              } else if (assignment.reward_type === \"crate\") {\n                await emitEvent(txDb.rawSql, EventTypes.CRATE_DROP, {\n                  userId: player.userId,\n                  wallet: player.wallet,\n                  triggerType: \"challenge_completed\",\n                  triggerId: `challenge-${assignment.id}`,\n                });\n              }\n\n              logger.info(\"game.settled: challenge completed\", {\n                userId: player.userId,\n                assignmentId: assignment.id,\n                challengeId: assignment.challenge_id,\n                rewardType: assignment.reward_type,\n              });\n            }\n          });\n        }\n\n        // ---- Wager-based points grant ----\n        await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n          userId: player.userId,\n          wallet: player.wallet,\n          sourceType: \"wager\",\n          sourceId: roundId,\n          amountLamports: player.amountLamports,\n          settledAt,\n        });\n\n        // ---- Crate drop ----\n        await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n          userId: player.userId,\n          wallet: player.wallet,\n          triggerType: \"game_settled\",\n          triggerId: roundId,\n        });\n      } catch (err) {\n        // Per-player try/catch — don't let one player's error block others\n        logger.error(\"game.settled: error processing player\", {\n          userId: player.userId,\n          roundId,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n    }\n\n    logger.info(\"game.settled: processed\", {\n      roundId,\n      game,\n      playerCount: players.length,\n    });\n  };\n}\n","numLines":291,"startLine":1,"totalLines":291}}}
