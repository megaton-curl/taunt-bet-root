{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LB9NXDaM9Fse2BDw3CGioz","type":"tool_result","content":"1\t/**\n2\t * Event producer — inserts an event into the queue within an existing\n3\t * database transaction so the event is committed atomically with the\n4\t * triggering operation.\n5\t */\n6\t\n7\timport type postgres from \"postgres\";\n8\timport type { EventType } from \"./event-types.js\";\n9\t\n10\t/** The transaction/sql handle accepted by emitEvent — works with both sql and tx from sql.begin(). */\n11\texport type SqlOrTransaction = postgres.Sql;\n12\t\n13\texport interface EmitEventOptions {\n14\t  maxAttempts?: number; // default: 3\n15\t  scheduledAt?: Date; // default: now\n16\t}\n17\t\n18\texport async function emitEvent(\n19\t  tx: SqlOrTransaction,\n20\t  eventType: EventType,\n21\t  payload: Record<string, unknown>,\n22\t  options?: EmitEventOptions,\n23\t): Promise<{ eventId: bigint }> {\n24\t  const maxAttempts = options?.maxAttempts ?? 3;\n25\t  const scheduledAt = options?.scheduledAt ?? new Date();\n26\t\n27\t  const rows = await tx<{ id: string }[]>`\n28\t    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n29\t    VALUES (${eventType}, ${tx.json(payload as postgres.JSONValue)}, ${maxAttempts}, ${scheduledAt})\n30\t    RETURNING id\n31\t  `;\n32\t\n33\t  return { eventId: BigInt(rows[0]!.id) };\n34\t}\n35\t"}]},"parent_tool_use_id":null,"session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"a042d22c-62c5-4e22-9fa7-5bc17a79eb80","timestamp":"2026-04-03T20:21:12.474Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/queue/emit-event.ts","content":"/**\n * Event producer — inserts an event into the queue within an existing\n * database transaction so the event is committed atomically with the\n * triggering operation.\n */\n\nimport type postgres from \"postgres\";\nimport type { EventType } from \"./event-types.js\";\n\n/** The transaction/sql handle accepted by emitEvent — works with both sql and tx from sql.begin(). */\nexport type SqlOrTransaction = postgres.Sql;\n\nexport interface EmitEventOptions {\n  maxAttempts?: number; // default: 3\n  scheduledAt?: Date; // default: now\n}\n\nexport async function emitEvent(\n  tx: SqlOrTransaction,\n  eventType: EventType,\n  payload: Record<string, unknown>,\n  options?: EmitEventOptions,\n): Promise<{ eventId: bigint }> {\n  const maxAttempts = options?.maxAttempts ?? 3;\n  const scheduledAt = options?.scheduledAt ?? new Date();\n\n  const rows = await tx<{ id: string }[]>`\n    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n    VALUES (${eventType}, ${tx.json(payload as postgres.JSONValue)}, ${maxAttempts}, ${scheduledAt})\n    RETURNING id\n  `;\n\n  return { eventId: BigInt(rows[0]!.id) };\n}\n","numLines":35,"startLine":1,"totalLines":35}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LNpipkQa6kcSFatPP2jB3Z","type":"message","role":"assistant","content":[{"type":"text","text":"Now I have a complete picture. Let me implement the completion bonus check.\n\n**Plan:**\n1. Create `completion-bonus.ts` with DB helpers and `checkCompletionBonus()` function\n2. Hook it into `game-settled.ts` after `markAssignmentCompleted()`\n3. Add integration tests"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1574,"cache_read_input_tokens":59212,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1574},"output_tokens":7,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"ee10ae00-c15c-45a4-9ff5-8dec312ecb46"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LNpipkQa6kcSFatPP2jB3Z","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0177Q4xek9NyK5uyMo4oFkWC","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/queue/handlers/completion-bonus.ts","content":"/**\n * Completion bonus check — runs after a challenge assignment is marked completed.\n *\n * When a player completes enough challenges in a period (e.g., 3 daily challenges),\n * they earn a bonus reward (e.g., a crate drop). Idempotent via UNIQUE(user_id, bonus_id, period_key).\n */\n\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\nimport { emitEvent } from \"../emit-event.js\";\nimport { EventTypes } from \"../event-types.js\";\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\ninterface CompletionBonus {\n  id: string;\n  campaign_id: string;\n  required_count: number;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\n/**\n * Get active completion bonuses for a campaign.\n */\nexport async function getCompletionBonuses(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonus[]> {\n  return db.rawSql<CompletionBonus[]>`\n    SELECT id, campaign_id, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/**\n * Count completed assignments for a user in a given period and campaign.\n */\nexport async function countCompletedAssignments(\n  db: Db,\n  userId: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<number> {\n  const rows = await db.rawSql<{ count: string }[]>`\n    SELECT COUNT(*)::TEXT AS count\n    FROM challenge_assignments\n    WHERE user_id = ${userId}\n      AND period_key = ${periodKey}\n      AND status = 'completed'\n      AND challenge_id IN (SELECT id FROM challenges WHERE campaign_id = ${campaignId})\n  `;\n  return Number(rows[0]!.count);\n}\n\n/**\n * Insert a bonus completion row. Returns false if a row for this\n * (user_id, bonus_id, period_key) already exists (idempotency guard).\n */\nexport async function insertBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<boolean> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    INSERT INTO bonus_completions (user_id, bonus_id, period_key)\n    VALUES (${userId}, ${bonusId}, ${periodKey})\n    ON CONFLICT (user_id, bonus_id, period_key) DO NOTHING\n    RETURNING id\n  `;\n  return rows.length > 0;\n}\n\n// ---------------------------------------------------------------------------\n// Main check\n// ---------------------------------------------------------------------------\n\n/**\n * Check and award completion bonuses after an assignment is completed.\n *\n * Called from the game.settled handler within the completion transaction.\n * For each active bonus in the campaign: count completed assignments,\n * if count >= required_count and no existing bonus_completion, insert row\n * and emit reward intent.\n */\nexport async function checkCompletionBonus(\n  db: Db,\n  userId: string,\n  wallet: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<void> {\n  const bonuses = await getCompletionBonuses(db, campaignId);\n\n  for (const bonus of bonuses) {\n    const completedCount = await countCompletedAssignments(\n      db,\n      userId,\n      periodKey,\n      campaignId,\n    );\n\n    if (completedCount < bonus.required_count) continue;\n\n    const inserted = await insertBonusCompletion(\n      db,\n      userId,\n      bonus.id,\n      periodKey,\n    );\n    if (!inserted) {\n      // Already awarded — idempotency guard\n      continue;\n    }\n\n    // Emit reward intent based on bonus reward_type\n    if (bonus.reward_type === \"points\" && bonus.reward_amount) {\n      await emitEvent(db.rawSql, EventTypes.POINTS_GRANT, {\n        userId,\n        wallet,\n        sourceType: \"bonus_completed\",\n        sourceId: `bonus-${bonus.id}-${periodKey}`,\n        amount: bonus.reward_amount.toString(),\n      });\n    } else if (bonus.reward_type === \"crate\") {\n      await emitEvent(db.rawSql, EventTypes.CRATE_DROP, {\n        userId,\n        wallet,\n        triggerType: \"bonus_completed\",\n        triggerId: `bonus-${bonus.id}-${periodKey}`,\n      });\n    }\n\n    logger.info(\"completion-bonus: bonus awarded\", {\n      userId,\n      bonusId: bonus.id,\n      periodKey,\n      campaignId,\n      rewardType: bonus.reward_type,\n    });\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1574,"cache_read_input_tokens":59212,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1574},"output_tokens":7,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"66cdbee4-b494-4584-97ac-4af421856520"}
