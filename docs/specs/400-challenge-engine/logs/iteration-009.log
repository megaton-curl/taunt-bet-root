onfig?.filters) {\n168\t        for (const filter of config.filters) {\n169\t          if (\"dataSize\" in filter) {\n170\t            if (acc.data.length !== filter.dataSize) {\n171\t              matches = false;\n172\t              break;\n173\t            }\n174\t          }\n175\t          if (\"memcmp\" in filter) {\n176\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n177\t            const actual = acc.data.subarray(\n178\t              filter.memcmp.offset,\n179\t              filter.memcmp.offset + expected.length,\n180\t            );\n181\t            if (Buffer.compare(actual, expected) !== 0) {\n182\t              matches = false;\n183\t              break;\n184\t            }\n185\t          }\n186\t        }\n187\t      }\n188\t\n189\t      if (matches) {\n190\t        results.push({\n191\t          pubkey: new PublicKey(key),\n192\t          account: { ...acc, rentEpoch: 0 },\n193\t        });\n194\t      }\n195\t    }\n196\t    return results;\n197\t  }\n198\t\n199\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"5be2124d-7e3e-47e4-80c4-afad63959afa","timestamp":"2026-04-03T20:20:02.100Z"}
