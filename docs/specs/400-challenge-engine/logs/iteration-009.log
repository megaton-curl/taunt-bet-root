{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LF9tAFn2eodUcQ6ghsduc4","type":"tool_result","content":"800\t    const settled = await db.getRoundByPda(createJson.matchPda);\n801\t    expect(settled).toBeDefined();\n802\t    expect(settled!.phase).toBe(\"settled\");\n803\t\n804\t    // 5. Verify referral earnings recorded for the opponent (the referee)\n805\t    // Expected: wager=5_000_000, fee=5_000_000*500/10_000=250_000\n806\t    //           referrer_earned=250_000*1000/10_000=25_000\n807\t    //           referee_rebate=250_000*1000/10_000=25_000\n808\t    const earnings =\n809\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n810\t    expect(earnings.length).toBe(1);\n811\t\n812\t    const earning = earnings[0]!;\n813\t    expect(earning.referrer_user_id).toBe(referrerUserId);\n814\t    expect(earning.referee_user_id).toBe(opponentUserId);\n815\t    expect(earning.referrer_wallet).toBe(referrerWallet);\n816\t    expect(earning.referee_wallet).toBe(opponentWallet);\n817\t    expect(earning.round_id).toBe(createJson.matchId);\n818\t    expect(earning.game_type).toBe(\"coinflip\");\n819\t    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS); // 5_000_000\n820\t    expect(Number(earning.fee_lamports)).toBe(250_000); // 5_000_000 * 500 / 10_000\n821\t    expect(Number(earning.referrer_earned_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n822\t    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n823\t    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n824\t    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n825\t\n826\t    // Creator is NOT referred, so no earnings for creator\n827\t    const creatorEarnings =\n828\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${creatorUserId}`;\n829\t    expect(creatorEarnings.length).toBe(0);\n830\t  });\n831\t\n832\t  it(\"settlement uses KOL custom rate for referrer earnings\", async () => {\n833\t    // Referrer has a KOL rate of 2000 bps (20% of fee)\n834\t    const referrerKeypair = Keypair.generate();\n835\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n836\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n837\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n838\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n839\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n840\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n841\t    const referrerUserId = referrerProfile.user_id;\n842\t    const opponentUserId = opponentProfile.user_id;\n843\t\n844\t    // Set up referral link + KOL rate override\n845\t    await db.insertReferralCode(referrerUserId, referrerWallet, \"kol-code\");\n846\t    await db.insertReferralLink({\n847\t      referrerUserId,\n848\t      refereeUserId: opponentUserId,\n849\t      referrerWallet,\n850\t      refereeWallet: opponentWallet,\n851\t    });\n852\t    await rawSql`INSERT INTO referral_kol_rates (user_id, wallet, rate_bps, set_by) VALUES (${referrerUserId}, ${referrerWallet}, 2000, 'admin')`;\n853\t\n854\t    // Create + settle a coinflip match\n855\t    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n856\t    const createRes = await app.request(\"/coinflip/create\", {\n857\t      method: \"POST\",\n858\t      headers: {\n859\t        \"Content-Type\": \"application/json\",\n860\t        \"Authorization\": `Bearer ${token}`,\n861\t      },\n862\t      body: JSON.stringify({\n863\t        wallet: creatorWallet,\n864\t        amountLamports: AMOUNT_LAMPORTS,\n865\t        side: SIDE_HEADS,\n866\t      }),\n867\t    });\n868\t    expect(createRes.status).toBe(200);\n869\t    const createJson = (await createRes.json()) as {\n870\t      matchPda: string;\n871\t      matchId: string;\n872\t      commitment: string;\n873\t    };\n874\t\n875\t    const matchPubkey = new PublicKey(createJson.matchPda);\n876\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n877\t\n878\t    const matchAccountData = await buildMatchAccountData({\n879\t      creator: creatorKeypair.publicKey,\n880\t      opponent: opponentKeypair.publicKey,\n881\t      server: serverKeypair.publicKey,\n882\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n883\t      creatorSide: SIDE_HEADS,\n884\t      phase: PHASE_LOCKED,\n885\t      commitment: commitmentBuf,\n886\t      algorithmVer: 1,\n887\t      targetSlot: 150n,\n888\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n889\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n890\t    });\n891\t\n892\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n893\t      owner: COINFLIP_PROGRAM_ID,\n894\t    });\n895\t    mockConn.slot = 200;\n896\t\n897\t    let settlePromise2: Promise<void> | null = null;\n898\t\n899\t    const retrySettler = createRetrySettler({"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"181c8107-4de1-4ff7-84c1-d116c00e10b4","timestamp":"2026-04-03T20:20:09.498Z"}
