{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014xUAxcgGFuyyNrVQ52UYXH","type":"tool_result","content":"900\t      db,\n901\t      connection: mockConn as unknown as Connection,\n902\t      settleRound: (pda) =>\n903\t        settleMatch(\n904\t          {\n905\t            db,\n906\t            connection: mockConn as unknown as Connection,\n907\t            serverKeypair,\n908\t            entropyAccount,\n909\t            referralDefaultRateBps: 1000,\n910\t          },\n911\t          pda,\n912\t        ),\n913\t    });\n914\t\n915\t    const worker = createSettlementWorker({\n916\t      db,\n917\t      connection: mockConn as unknown as Connection,\n918\t      serverKey: serverKeypair.publicKey,\n919\t      pollIntervalMs: 60_000,\n920\t      onSettleReady: (pda) => {\n921\t        settlePromise2 = retrySettler.attemptSettle(pda);\n922\t        return settlePromise2;\n923\t      },\n924\t    });\n925\t\n926\t    await worker.poll();\n927\t    if (settlePromise2) await settlePromise2;\n928\t\n929\t    // Verify settlement completed\n930\t    const settled = await db.getRoundByPda(createJson.matchPda);\n931\t    expect(settled!.phase).toBe(\"settled\");\n932\t\n933\t    // Verify KOL rate was used for referrer earning\n934\t    // fee = 5_000_000 * 500 / 10_000 = 250_000\n935\t    // referrer_earned = 250_000 * 2000 / 10_000 = 50_000 (KOL rate)\n936\t    // referee_rebate = 250_000 * 1000 / 10_000 = 25_000 (always fixed 10%)\n937\t    const earnings =\n938\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n939\t    expect(earnings.length).toBe(1);\n940\t\n941\t    const earning = earnings[0]!;\n942\t    expect(Number(earning.referrer_earned_lamports)).toBe(50_000); // KOL: 2000 bps\n943\t    expect(Number(earning.referrer_rate_bps)).toBe(2000);\n944\t    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // Fixed 10%\n945\t    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n946\t  });\n947\t\n948\t  it(\"settlement emits game.settled event with correct payload shape\", async () => {\n949\t    const wallet = creatorKeypair.publicKey.toBase58();\n950\t    const token = await makeJwt(wallet);\n951\t\n952\t    // Create profiles for both players so game entries + event payloads get user IDs\n953\t    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n954\t    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n955\t    await rawSql`\n956\t      INSERT INTO player_profiles (user_id, wallet, username)\n957\t      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n958\t      ON CONFLICT (user_id) DO NOTHING\n959\t    `;\n960\t    await rawSql`\n961\t      INSERT INTO player_profiles (user_id, wallet, username)\n962\t      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n963\t      ON CONFLICT (user_id) DO NOTHING\n964\t    `;\n965\t\n966\t    // Create round via API\n967\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n968\t    const createRes = await app.request(\"/coinflip/create\", {\n969\t      method: \"POST\",\n970\t      headers: {\n971\t        \"Content-Type\": \"application/json\",\n972\t        Authorization: `Bearer ${token}`,\n973\t      },\n974\t      body: JSON.stringify(body),\n975\t    });\n976\t    expect(createRes.status).toBe(200);\n977\t    const createJson = (await createRes.json()) as {\n978\t      matchPda: string;\n979\t      matchId: string;\n980\t      commitment: string;\n981\t    };\n982\t\n983\t    // Simulate on-chain join — LOCKED match in mock\n984\t    const matchPubkey = new PublicKey(createJson.matchPda);\n985\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n986\t    const matchAccountData = await buildMatchAccountData({\n987\t      creator: creatorKeypair.publicKey,\n988\t      opponent: opponentKeypair.publicKey,\n989\t      server: serverKeypair.publicKey,\n990\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n991\t      creatorSide: SIDE_HEADS,\n992\t      phase: PHASE_LOCKED,\n993\t      commitment: commitmentBuf,\n994\t      algorithmVer: 1,\n995\t      targetSlot: 150n,\n996\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n997\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n998\t    });\n999\t    mockConn.setAccount(matchPubkey, matchAccountData, {"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"14cb1d23-b482-4f25-b040-ca2e8f034c70","timestamp":"2026-04-03T20:20:09.719Z"}
