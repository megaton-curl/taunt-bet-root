te_drop_rate (0.01) → SOL crate hit\n1540\t    const handler = createCrateDropHandler({\n1541\t      db,\n1542\t      rollRng: () => 0.005,\n1543\t    });\n1544\t\n1545\t    const userId = \"usr_cratesol1\";\n1546\t    const wallet = \"CrateSolWallet1111111111111111111111111\";\n1547\t    const triggerId = \"test-round-crate-sol-001\";\n1548\t\n1549\t    await handler({\n1550\t      userId,\n1551\t      wallet,\n1552\t      triggerType: \"game_settled\",\n1553\t      triggerId,\n1554\t    });\n1555\t\n1556\t    // Expected payout: floor(200_000_000 * 0.10) = 20_000_000\n1557\t    const expectedPayout = 20_000_000n;\n1558\t\n1559\t    // Verify crate_drops row\n1560\t    const crates = await rawSql<{\n1561\t      user_id: string;\n1562\t      trigger_type: string;\n1563\t      trigger_id: string;\n1564\t      crate_type: string;\n1565\t      contents_amount: string;\n1566\t      status: string;\n1567\t    }[]>`\n1568\t      SELECT user_id, trigger_type, trigger_id, crate_type, contents_amount, status\n1569\t      FROM crate_drops WHERE user_id = ${userId} AND trigger_id = ${triggerId}\n1570\t    `;\n1571\t    expect(crates.length).toBe(1);\n1572\t    expect(crates[0]!.crate_type).toBe(\"sol\");\n1573\t    expect(BigInt(crates[0]!.contents_amount)).toBe(expectedPayout);\n1574\t    expect(crates[0]!.status).toBe(\"pending\");\n1575\t\n1576\t    // Verify pool decremented\n1577\t    const pool = await rawSql<{ balance_lamports: string; lifetime_paid: string }[]>`\n1578\t      SELECT balance_lamports, lifetime_paid FROM reward_pool WHERE id = 1\n1579\t    `;\n1580\t    expect(BigInt(pool[0]!.balance_lamports)).toBe(200_000_000n - expectedPayout);\n1581\t    expect(BigInt(pool[0]!.lifetime_paid)).toBe(expectedPayout);\n1582\t\n1583\t    // Verify CRATE_SOL_PAYOUT event emitted\n1584\t    const events = await rawSql<{ event_type: string; payload: string }[]>`\n1585\t      SELECT event_type, payload FROM event_queue WHERE event_type = 'crate.sol_payout'\n1586\t    `;\n1587\