{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CvHLBNysLYXMt8ta52K2co","type":"tool_result","content":"600\t\n601\t    // ------------------------------------------------------------------\n602\t    // 6. GET /rounds/:pda — verify response includes secret\n603\t    // ------------------------------------------------------------------\n604\t    const roundsRes = await app.request(`/rounds/${matchPda}`);\n605\t    expect(roundsRes.status).toBe(200);\n606\t\n607\t    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n608\t    expect(roundsJson.pda).toBe(matchPda);\n609\t    expect(roundsJson.phase).toBe(\"settled\");\n610\t    expect(roundsJson.game).toBe(\"coinflip\");\n611\t    expect(roundsJson.creator).toBe(wallet);\n612\t    expect(roundsJson.commitment).toBe(commitmentHex);\n613\t\n614\t    // Settled round should include secret + verification payload\n615\t    expect(roundsJson.secret).toBeDefined();\n616\t    expect(typeof roundsJson.secret).toBe(\"string\");\n617\t    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n618\t    expect(roundsJson.resultHash).toBeDefined();\n619\t    expect(roundsJson.resultSide).toBeDefined();\n620\t    expect(roundsJson.winner).toBeDefined();\n621\t    expect(roundsJson.settleTx).toBeDefined();\n622\t\n623\t    // Verification object\n624\t    const verification = roundsJson.verification as Record<string, string>;\n625\t    expect(verification).toBeDefined();\n626\t    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n627\t    expect(verification.resultFormula).toContain(\"sha256(secret\");\n628\t    expect(verification.entropySource).toContain(\"SlotHashes\");\n629\t  });\n630\t\n631\t  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n632\t    const unknownPda = Keypair.generate().publicKey.toBase58();\n633\t    const res = await app.request(`/rounds/${unknownPda}`);\n634\t    expect(res.status).toBe(404);\n635\t  });\n636\t\n637\t  it(\"unsettled round does not expose secret\", async () => {\n638\t    const wallet = creatorKeypair.publicKey.toBase58();\n639\t    const token = await makeJwt(wallet);\n640\t\n641\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n642\t\n643\t    const res = await app.request(\"/coinflip/create\", {\n644\t      method: \"POST\",\n645\t      headers: {\n646\t        \"Content-Type\": \"application/json\",\n647\t        \"Authorization\": `Bearer ${token}`,\n648\t      },\n649\t      body: JSON.stringify(body),\n650\t    });\n651\t    expect(res.status).toBe(200);\n652\t    const json = (await res.json()) as { matchPda: string };\n653\t\n654\t    // GET the unsettled round\n655\t    const roundRes = await app.request(`/rounds/${json.matchPda}`);\n656\t    expect(roundRes.status).toBe(200);\n657\t    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n658\t    expect(roundJson.phase).toBe(\"created\");\n659\t    expect(roundJson.secret).toBeUndefined();\n660\t    expect(roundJson.resultHash).toBeUndefined();\n661\t    expect(roundJson.verification).toBeUndefined();\n662\t  });\n663\t\n664\t  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n665\t    const wallet = creatorKeypair.publicKey.toBase58();\n666\t    const token = await makeJwt(wallet);\n667\t\n668\t    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n669\t    const res1 = await app.request(\"/coinflip/create\", {\n670\t      method: \"POST\",\n671\t      headers: {\n672\t        \"Content-Type\": \"application/json\",\n673\t        \"Authorization\": `Bearer ${token}`,\n674\t      },\n675\t      body: JSON.stringify(body1),\n676\t    });\n677\t    expect(res1.status).toBe(200);\n678\t\n679\t    // Second request — different random matchId generated server-side\n680\t    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n681\t    const res2 = await app.request(\"/coinflip/create\", {\n682\t      method: \"POST\",\n683\t      headers: {\n684\t        \"Content-Type\": \"application/json\",\n685\t        \"Authorization\": `Bearer ${token}`,\n686\t      },\n687\t      body: JSON.stringify(body2),\n688\t    });\n689\t    expect(res2.status).toBe(200);\n690\t\n691\t    // Both should have different matchIds and PDAs\n692\t    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n693\t    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n694\t    expect(json1.matchPda).not.toBe(json2.matchPda);\n695\t    expect(json1.matchId).not.toBe(json2.matchId);\n696\t  });\n697\t\n698\t  it(\"settlement records referral earnings for referred player\", async () => {\n699\t    // Referrer is a third party; opponent is the referred player"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"d7be632a-0394-4740-a8d6-a9ba688ebc26","timestamp":"2026-04-03T20:20:07.191Z"}
