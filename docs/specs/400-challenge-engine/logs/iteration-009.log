{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VaYmUdQwhcirUmggrApXmG","type":"tool_result","content":"1760\t  it(\"game.settled handler: processes challenge progress + emits reward events\", async () => {\n1761\t    const handler = createGameSettledHandler({ db });\n1762\t    const userId = \"usr_gs_progress1\";\n1763\t    const wallet = \"GsProgressWallet1111111111111111111111\";\n1764\t\n1765\t    // Look up the 'Play 3 Games' daily challenge (game_completed, scope=any, threshold=3)\n1766\t    const challenges = await rawSql<{ id: string }[]>`\n1767\t      SELECT id FROM challenges WHERE title = 'Play 3 Games' LIMIT 1\n1768\t    `;\n1769\t    expect(challenges.length).toBe(1);\n1770\t    const challengeId = challenges[0]!.id;\n1771\t\n1772\t    // Create an active assignment for this user\n1773\t    await rawSql`\n1774\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n1775\t      VALUES (${userId}, ${challengeId}, 'daily:2026-04-03', 3)\n1776\t    `;\n1777\t\n1778\t    // Emit a game.settled event\n1779\t    await handler({\n1780\t      roundId: \"test-gs-round-001\",\n1781\t      roundPda: \"GsRoundPda111111111111111111111111111\",\n1782\t      game: \"coinflip\",\n1783\t      players: [\n1784\t        {\n1785\t          userId,\n1786\t          wallet,\n1787\t          amountLamports: \"5000000\",\n1788\t          isWinner: true,\n1789\t          payoutLamports: \"9500000\",\n1790\t          isCreator: true,\n1791\t        },\n1792\t      ],\n1793\t      feeLamports: \"500000\",\n1794\t      settledAt: new Date().toISOString(),\n1795\t    });\n1796\t\n1797\t    // Verify progress incremented to 1\n1798\t    const assignments = await rawSql<{ progress: number; status: string }[]>`\n1799\t      SELECT progress, status FROM challenge_assignments WHERE user_id = ${userId}\n1800\t    `;\n1801\t    expect(assignments[0]!.progress).toBe(1);\n1802\t    expect(assignments[0]!.status).toBe(\"active\");\n1803\t\n1804\t    // Verify progress_events row\n1805\t    const progressEvents = await rawSql<{ round_id: string; progress_delta: number }[]>`\n1806\t      SELECT round_id, progress_delta FROM progress_events WHERE user_id = ${userId}\n1807\t    `;\n1808\t    expect(progressEvents.length).toBe(1);\n1809\t    expect(progressEvents[0]!.round_id).toBe(\"test-gs-round-001\");\n1810\t    expect(progressEvents[0]!.progress_delta).toBe(1);\n1811\t\n1812\t    // Verify reward events emitted: reward.pool_fund, points.grant (wager), crate.drop\n1813\t    const events = await rawSql<{ event_type: string }[]>`\n1814\t      SELECT event_type FROM event_queue ORDER BY id\n1815\t    `;\n1816\t    const types = events.map((e) => e.event_type);\n1817\t    expect(types).toContain(\"reward.pool_fund\");\n1818\t    expect(types).toContain(\"points.grant\");\n1819\t    expect(types).toContain(\"crate.drop\");\n1820\t  });\n1821\t\n1822\t  it(\"game.settled handler: completes challenge + emits reward intent when target reached\", async () => {\n1823\t    const handler = createGameSettledHandler({ db });\n1824\t    const userId = \"usr_gs_complete1\";\n1825\t    const wallet = \"GsCompleteWallet11111111111111111111\";\n1826\t\n1827\t    // Look up 'Win a Coinflip' daily challenge (game_won, scope=coinflip, threshold=1, reward=150 points)\n1828\t    const challenges = await rawSql<{ id: string }[]>`\n1829\t      SELECT id FROM challenges WHERE title = 'Win a Coinflip' LIMIT 1\n1830\t    `;\n1831\t    const challengeId = challenges[0]!.id;\n1832\t\n1833\t    // Create assignment at 0 progress, target 1\n1834\t    await rawSql`\n1835\t      INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target)\n1836\t      VALUES (${userId}, ${challengeId}, 'daily:2026-04-03', 1)\n1837\t    `;\n1838\t\n1839\t    // Win a coinflip — should complete the challenge\n1840\t    await handler({\n1841\t      roundId: \"test-gs-complete-001\",\n1842\t      roundPda: \"GsCompletePda111111111111111