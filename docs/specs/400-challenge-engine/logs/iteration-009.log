{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TcQxiPY72F2JVjtfrwotNR","type":"tool_result","content":"500\t\n501\t    // Verify operator event was logged\n502\t    const events =\n503\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n504\t    expect(events.length).toBe(1);\n505\t    expect(events[0]!.event_type).toBe(\"secret_generated\");\n506\t\n507\t    // ------------------------------------------------------------------\n508\t    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n509\t    // ------------------------------------------------------------------\n510\t    const matchPubkey = new PublicKey(matchPda);\n511\t    const targetSlot = 150n;\n512\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n513\t\n514\t    const matchAccountData = await buildMatchAccountData({\n515\t      creator: creatorKeypair.publicKey,\n516\t      opponent: opponentKeypair.publicKey,\n517\t      server: serverKeypair.publicKey,\n518\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n519\t      creatorSide: SIDE_HEADS,\n520\t      phase: PHASE_LOCKED,\n521\t      commitment: commitmentBuf,\n522\t      algorithmVer: 1,\n523\t      targetSlot,\n524\t      resolveDeadline,\n525\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n526\t    });\n527\t\n528\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n529\t      owner: COINFLIP_PROGRAM_ID,\n530\t    });\n531\t\n532\t    // Set current slot past target_slot so settlement triggers immediately\n533\t    mockConn.slot = 200;\n534\t\n535\t    // ------------------------------------------------------------------\n536\t    // 4. Create worker + retry settler, trigger poll\n537\t    // ------------------------------------------------------------------\n538\t    let settlePromise: Promise<void> | null = null;\n539\t\n540\t    const retrySettler = createRetrySettler({\n541\t      db,\n542\t      connection: mockConn as unknown as Connection,\n543\t      settleRound: (pda) =>\n544\t        settleMatch(\n545\t          {\n546\t            db,\n547\t            connection: mockConn as unknown as Connection,\n548\t            serverKeypair,\n549\t            entropyAccount,\n550\t            referralDefaultRateBps: 1000,\n551\t          },\n552\t          pda,\n553\t        ),\n554\t    });\n555\t\n556\t    const worker = createSettlementWorker({\n557\t      db,\n558\t      connection: mockConn as unknown as Connection,\n559\t      serverKey: serverKeypair.publicKey,\n560\t      pollIntervalMs: 60_000, // won't auto-poll\n561\t      onSettleReady: (pda) => {\n562\t        settlePromise = retrySettler.attemptSettle(pda);\n563\t        return settlePromise;\n564\t      },\n565\t    });\n566\t\n567\t    // Single poll cycle — should discover locked match and settle it\n568\t    await worker.poll();\n569\t    if (settlePromise) await settlePromise;\n570\t\n571\t    // ------------------------------------------------------------------\n572\t    // 5. Verify DB updated to \"settled\" with result data\n573\t    // ------------------------------------------------------------------\n574\t    const settled = await db.getRoundByPda(matchPda);\n575\t    expect(settled).toBeDefined();\n576\t    expect(settled!.phase).toBe(\"settled\");\n577\t    expect(settled!.settle_tx).toBeDefined();\n578\t    expect(settled!.result_hash).toBeDefined();\n579\t    expect(settled!.result_hash!.length).toBe(32);\n580\t    expect(settled!.result_side).toBeDefined();\n581\t    expect([0, 1]).toContain(settled!.result_side);\n582\t    expect(settled!.winner).toBeDefined();\n583\t\n584\t    // Winner should be one of the two players\n585\t    expect([\n586\t      creatorKeypair.publicKey.toBase58(),\n587\t      opponentKeypair.publicKey.toBase58(),\n588\t    ]).toContain(settled!.winner);\n589\t\n590\t    // Verify operator events trail\n591\t    const allEvents =\n592\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n593\t    const eventTypes = allEvents.map(\n594\t      (e) => (e as Record<string, unknown>).event_type,\n595\t    );\n596\t    expect(eventTypes).toContain(\"secret_generated\");\n597\t    expect(eventTypes).toContain(\"match_detected\");\n598\t    expect(eventTypes).toContain(\"settle_submitted\");\n599\t    expect(eventTypes).toContain(\"settle_confirmed\");"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"b6cb5207-3347-4005-ba2c-cb6876eee025","timestamp":"2026-04-03T20:20:06.973Z"}
