{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q22hv83FdZmU9p5TBuvHmg","type":"tool_result","content":"0\t/**\n1\t * Integration test: full create → join → settle lifecycle.\n2\t *\n3\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n4\t * the real HTTP endpoints, database, settlement worker, and retry logic\n5\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n6\t */\n7\t\n8\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n9\timport { Hono } from \"hono\";\n10\timport {\n11\t  Keypair,\n12\t  PublicKey,\n13\t  SystemProgram,\n14\t  LAMPORTS_PER_SOL,\n15\t} from \"@solana/web3.js\";\n16\timport type { Connection } from \"@solana/web3.js\";\n17\timport bs58 from \"bs58\";\n18\timport { SignJWT } from \"jose\";\n19\timport postgres from \"postgres\";\n20\timport { createDb, type Db } from \"../db.js\";\n21\timport { createCoinflipRoutes } from \"../routes/create.js\";\n22\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n23\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n24\timport { createSettlementWorker } from \"../worker/settlement.js\";\n25\timport { settleMatch } from \"../worker/settle-tx.js\";\n26\timport { createRetrySettler } from \"../worker/retry.js\";\n27\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n28\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n29\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n30\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n31\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n32\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n33\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n34\timport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\n35\timport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\n36\timport { createGameSettledHandler } from \"../queue/handlers/game-settled.js\";\n37\t\n38\t// ---------------------------------------------------------------------------\n39\t// Constants\n40\t// ---------------------------------------------------------------------------\n41\t\n42\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n43\t\n44\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n45\tfunction makeSql() {\n46\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n47\t  // Dev container: postgres listens on Unix socket only\n48\t  return postgres({\n49\t    host: \"/var/run/postgresql\",\n50\t    user: \"vscode\",\n51\t    database: \"rng_utopia_dev\",\n52\t  });\n53\t}\n54\t\n55\tconst AMOUNT_LAMPORTS = 5_000_000;\n56\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n57\tconst SIDE_HEADS = 0;\n58\tconst PHASE_LOCKED = 1;\n59\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n60\t\n61\t// ---------------------------------------------------------------------------\n62\t// JWT helper\n63\t// ---------------------------------------------------------------------------\n64\t\n65\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n66\t  const now = Math.floor(Date.now() / 1000);\n67\t  return new SignJWT({ wallet })\n68\t    .setProtectedHeader({ alg: \"HS256\" })\n69\t    .setSubject(userId)\n70\t    .setIssuedAt(now)\n71\t    .setExpirationTime(now + 3600)\n72\t    .sign(JWT_SECRET);\n73\t}\n74\t\n75\tfunction userIdFromWallet(wallet: string) {\n76\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n77\t}\n78\t\n79\t// ---------------------------------------------------------------------------\n80\t// Mock Connection\n81\t// ---------------------------------------------------------------------------\n82\t\n83\t/**\n84\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n85\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n86\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n87\t */\n88\tclass MockConnection {\n89\t  private _slot = 200;\n90\t  private _accounts = new Map<\n91\t    string,\n92\t    {\n93\t      data: Buffer;\n94\t      lamports: number;\n95\t      owner: PublicKey;\n96\t      executable: boolean;\n97\t    }\n98\t  >();\n99\t  lastRawTx: Buffer | null = null;"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"e294e347-5139-440f-b081-8b67946ff789","timestamp":"2026-04-03T20:20:01.779Z"}
