{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KADYLxCBtovnoMxTruzp8k","type":"tool_result","content":"1100\t    const matchAccountData = await buildMatchAccountData({\n1101\t      creator: creatorKeypair.publicKey,\n1102\t      opponent: opponentKeypair.publicKey,\n1103\t      server: serverKeypair.publicKey,\n1104\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n1105\t      creatorSide: SIDE_HEADS,\n1106\t      phase: PHASE_LOCKED,\n1107\t      commitment: commitmentBuf,\n1108\t      algorithmVer: 1,\n1109\t      targetSlot: 150n,\n1110\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n1111\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n1112\t    });\n1113\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n1114\t      owner: COINFLIP_PROGRAM_ID,\n1115\t    });\n1116\t\n1117\t    // Transition DB round to \"locked\"\n1118\t    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n1119\t\n1120\t    // First settle\n1121\t    await settleMatch(\n1122\t      {\n1123\t        db,\n1124\t        connection: mockConn as unknown as Connection,\n1125\t        serverKeypair,\n1126\t        entropyAccount,\n1127\t        referralDefaultRateBps: 1000,\n1128\t      },\n1129\t      createJson.matchPda,\n1130\t    );\n1131\t\n1132\t    // Second settle attempt — should fail on phase check (already settled),\n1133\t    // but the first call already produced the event. Verify 1 event row exists.\n1134\t    const events = await rawSql`\n1135\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1136\t    `;\n1137\t    expect(events.length).toBe(1);\n1138\t\n1139\t    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n1140\t    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n1141\t    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n1142\t    // The first settle succeeded; a retry would be rejected by phase check before reaching\n1143\t    // the DB transaction. This test confirms the first call produces exactly 1 event.\n1144\t  });\n1145\t\n1146\t  it(\"closecall settlement emits game.settled event with correct payload shape\", async () => {\n1147\t    // Two players: one green, one red\n1148\t    const greenPlayer = Keypair.generate();\n1149\t    const redPlayer = Keypair.generate();\n1150\t    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());\n1151\t    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n1152\t\n1153\t    // Insert player profiles\n1154\t    await rawSql`\n1155\t      INSERT INTO player_profiles (user_id, wallet, username)\n1156\t      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n1157\t      ON CONFLICT (user_id) DO NOTHING\n1158\t    `;\n1159\t    await rawSql`\n1160\t      INSERT INTO player_profiles (user_id, wallet, username)\n1161\t      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n1162\t      ON CONFLICT (user_id) DO NOTHING\n1163\t    `;\n1164\t\n1165\t    // Create a round with minuteTs = 2 minutes ago (candle is closed)\n1166\t    const nowSec = Math.floor(Date.now() / 1000);\n1167\t    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n1168\t    const greenAmount = 5_000_000n;\n1169\t    const redAmount = 5_000_000n;\n1170\t    const openPrice = 69500_00n; // $69500.00 with expo -2\n1171\t\n1172\t    // Derive round PDA (seeds: [\"round\", minute_ts as LE i64, server pubkey])\n1173\t    const minuteTsBuf = Buffer.alloc(8);\n1174\t    minuteTsBuf.writeBigInt64LE(minuteTs);\n1175\t    const [roundPda] = PublicKey.findProgramAddressSync(\n1176\t      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n1177\t      CLOSECALL_PROGRAM_ID,\n1178\t    );\n1179\t\n1180\t    // Build on-chain round account data (phase=Open, with entries)\n1181\t    const roundAccountData = await encodeCloseCallRound({\n1182\t      minuteTs,\n1183\t      server: serverKeypair.publicKey,\n1184\t      phase: 0, // Open\n1185\t      greenEntries: [{ player: greenPlayer.publicKey, amountLamports: greenAmount }],\n1186\t      redEntries: [{ player: redPlayer.publicKey, amountLamports: redAmount }],\n1187\t      greenPool: greenAmount,\n1188\t      redPool: redAmount,\n1189\t      openPrice,\n1190\t      openPriceExpo: -2,\n1191\t      closePrice: 0n,\n1192\t      createdAt: minuteTs,\n1193\t      bettingEndsAt: minuteTs + 45n,\n1194\t      resolveDeadline: minuteTs + 300n,\n1195\t      outcome: 0, // Pending\n1196\t      totalFee: 0n,\n1197\t      bump: 0,\n1198\t    });\n1199\t"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"bc022e46-54d9-4a91-8041-b4a255df9e8a","timestamp":"2026-04-03T20:20:12.017Z"}
