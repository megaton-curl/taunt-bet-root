{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0191DbiJ96q4ZfUJ2AW9PNHU","type":"tool_result","content":"700\t    const referrerKeypair = Keypair.generate();\n701\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n702\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n703\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n704\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n705\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n706\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n707\t    const referrerUserId = referrerProfile.user_id;\n708\t    const opponentUserId = opponentProfile.user_id;\n709\t    const creatorUserId = creatorProfile.user_id;\n710\t\n711\t    // Set up referral link: referrer → opponent (opponent is the referee)\n712\t    await db.insertReferralCode(referrerUserId, referrerWallet, \"test-ref\");\n713\t    await db.insertReferralLink({\n714\t      referrerUserId,\n715\t      refereeUserId: opponentUserId,\n716\t      referrerWallet,\n717\t      refereeWallet: opponentWallet,\n718\t    });\n719\t\n720\t    // 1. Create a coinflip match\n721\t    const token = await makeJwt(creatorWallet, creatorUserId);\n722\t    const createRes = await app.request(\"/coinflip/create\", {\n723\t      method: \"POST\",\n724\t      headers: {\n725\t        \"Content-Type\": \"application/json\",\n726\t        \"Authorization\": `Bearer ${token}`,\n727\t      },\n728\t      body: JSON.stringify({\n729\t        wallet: creatorWallet,\n730\t        amountLamports: AMOUNT_LAMPORTS,\n731\t        side: SIDE_HEADS,\n732\t      }),\n733\t    });\n734\t    expect(createRes.status).toBe(200);\n735\t    const createJson = (await createRes.json()) as {\n736\t      matchPda: string;\n737\t      matchId: string;\n738\t      commitment: string;\n739\t    };\n740\t\n741\t    // 2. Simulate on-chain join (opponent joins the match)\n742\t    const matchPubkey = new PublicKey(createJson.matchPda);\n743\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n744\t    const targetSlot = 150n;\n745\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n746\t\n747\t    const matchAccountData = await buildMatchAccountData({\n748\t      creator: creatorKeypair.publicKey,\n749\t      opponent: opponentKeypair.publicKey,\n750\t      server: serverKeypair.publicKey,\n751\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n752\t      creatorSide: SIDE_HEADS,\n753\t      phase: PHASE_LOCKED,\n754\t      commitment: commitmentBuf,\n755\t      algorithmVer: 1,\n756\t      targetSlot,\n757\t      resolveDeadline,\n758\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n759\t    });\n760\t\n761\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n762\t      owner: COINFLIP_PROGRAM_ID,\n763\t    });\n764\t    mockConn.slot = 200;\n765\t\n766\t    // 3. Settle the match\n767\t    let settlePromise: Promise<void> | null = null;\n768\t\n769\t    const retrySettler = createRetrySettler({\n770\t      db,\n771\t      connection: mockConn as unknown as Connection,\n772\t      settleRound: (pda) =>\n773\t        settleMatch(\n774\t          {\n775\t            db,\n776\t            connection: mockConn as unknown as Connection,\n777\t            serverKeypair,\n778\t            entropyAccount,\n779\t            referralDefaultRateBps: 1000,\n780\t          },\n781\t          pda,\n782\t        ),\n783\t    });\n784\t\n785\t    const worker = createSettlementWorker({\n786\t      db,\n787\t      connection: mockConn as unknown as Connection,\n788\t      serverKey: serverKeypair.publicKey,\n789\t      pollIntervalMs: 60_000,\n790\t      onSettleReady: (pda) => {\n791\t        settlePromise = retrySettler.attemptSettle(pda);\n792\t        return settlePromise;\n793\t      },\n794\t    });\n795\t\n796\t    await worker.poll();\n797\t    if (settlePromise) await settlePromise;\n798\t\n799\t    // 4. Verify match settled"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"f896909e-6dd3-419b-bcd3-c948e738ce93","timestamp":"2026-04-03T20:20:07.507Z"}
