{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WEY8pCoHgdMRRKesrkWBZr","type":"tool_result","content":"1000\t      owner: COINFLIP_PROGRAM_ID,\n1001\t    });\n1002\t\n1003\t    // Transition DB round to \"locked\" (normally the settlement worker does this on join detection)\n1004\t    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n1005\t\n1006\t    // Settle directly\n1007\t    await settleMatch(\n1008\t      {\n1009\t        db,\n1010\t        connection: mockConn as unknown as Connection,\n1011\t        serverKeypair,\n1012\t        entropyAccount,\n1013\t        referralDefaultRateBps: 1000,\n1014\t      },\n1015\t      createJson.matchPda,\n1016\t    );\n1017\t\n1018\t    // Verify game.settled event was emitted in event_queue\n1019\t    const events = await rawSql`\n1020\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1021\t    `;\n1022\t    expect(events.length).toBe(1);\n1023\t\n1024\t    const evt = events[0]!;\n1025\t    expect(evt.status).toBe(\"pending\");\n1026\t\n1027\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1028\t    const payload = evt.payload as any;\n1029\t    expect(payload.roundId).toBe(createJson.matchId);\n1030\t    expect(payload.roundPda).toBe(createJson.matchPda);\n1031\t    expect(payload.game).toBe(\"coinflip\");\n1032\t    expect(payload.feeLamports).toBeDefined();\n1033\t    expect(payload.settledAt).toBeDefined();\n1034\t\n1035\t    // Players array\n1036\t    expect(payload.players).toHaveLength(2);\n1037\t    const creator = payload.players.find(\n1038\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1039\t      (p: any) => p.wallet === creatorKeypair.publicKey.toBase58(),\n1040\t    );\n1041\t    const opponent = payload.players.find(\n1042\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1043\t      (p: any) => p.wallet === opponentKeypair.publicKey.toBase58(),\n1044\t    );\n1045\t    expect(creator).toBeDefined();\n1046\t    expect(opponent).toBeDefined();\n1047\t    expect(creator.isCreator).toBe(true);\n1048\t    expect(opponent.isCreator).toBe(false);\n1049\t    expect(creator.userId).toBe(creatorUserId);\n1050\t    expect(opponent.userId).toBe(opponentUserId);\n1051\t    // Amounts are string-encoded lamports\n1052\t    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n1053\t    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n1054\t    // Exactly one winner\n1055\t    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n1056\t    // Winner has payoutLamports > 0, loser has \"0\"\n1057\t    const winnerPlayer = creator.isWinner ? creator : opponent;\n1058\t    const loserPlayer = creator.isWinner ? opponent : creator;\n1059\t    expect(Number(winnerPlayer.payoutLamports)).toBeGreaterThan(0);\n1060\t    expect(loserPlayer.payoutLamports).toBe(\"0\");\n1061\t    // Fee = pool * 500 / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n1062\t    expect(payload.feeLamports).toBe(String(500_000));\n1063\t  });\n1064\t\n1065\t  it(\"duplicate settlement retry produces duplicate game.settled event rows safely\", async () => {\n1066\t    const wallet = creatorKeypair.publicKey.toBase58();\n1067\t    const token = await makeJwt(wallet);\n1068\t\n1069\t    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n1070\t    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n1071\t    await rawSql`\n1072\t      INSERT INTO player_profiles (user_id, wallet, username)\n1073\t      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n1074\t      ON CONFLICT (user_id) DO NOTHING\n1075\t    `;\n1076\t    await rawSql`\n1077\t      INSERT INTO player_profiles (user_id, wallet, username)\n1078\t      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n1079\t      ON CONFLICT (user_id) DO NOTHING\n1080\t    `;\n1081\t\n1082\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n1083\t    const createRes = await app.request(\"/coinflip/create\", {\n1084\t      method: \"POST\",\n1085\t      headers: {\n1086\t        \"Content-Type\": \"application/json\",\n1087\t        Authorization: `Bearer ${token}`,\n1088\t      },\n1089\t      body: JSON.stringify(body),\n1090\t    });\n1091\t    expect(createRes.status).toBe(200);\n1092\t    const createJson = (await createRes.json()) as {\n1093\t      matchPda: string;\n1094\t      matchId: string;\n1095\t      commitment: string;\n1096\t    };\n1097\t\n1098\t    const matchPubkey = new PublicKey(createJson.matchPda);\n1099\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"facd2056-ca3e-43f3-8883-ef94ceab9bd0","timestamp":"2026-04-03T20:20:09.943Z"}
