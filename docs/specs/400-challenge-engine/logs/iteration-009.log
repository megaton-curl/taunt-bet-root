{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015GMC4jTNzMkyAP2HtqSzqZ","type":"tool_result","content":"1200\t    mockConn.setAccount(roundPda, roundAccountData, {\n1201\t      owner: CLOSECALL_PROGRAM_ID,\n1202\t    });\n1203\t\n1204\t    // Mock Hermes: returns a price > openPrice so outcome = green\n1205\t    // publishTime must be >= current minute boundary so captureBoundaryPrice() succeeds immediately\n1206\t    const closePrice = 69600_00n; // $69600.00\n1207\t    const mockHermes: HermesFetcher = {\n1208\t      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n1209\t        price: closePrice,\n1210\t        expo: -2,\n1211\t        publishTime: Math.floor(Date.now() / 1000), // always \"current\"\n1212\t        priceHuman: 69600.0,\n1213\t        vaaBase64: null,\n1214\t      }),\n1215\t    };\n1216\t\n1217\t    // Create clock worker with mock deps\n1218\t    const clock = createCloseCallClockWorker({\n1219\t      connection: mockConn as unknown as Connection,\n1220\t      serverKeypair,\n1221\t      db,\n1222\t      hermesFetcher: mockHermes,\n1223\t    });\n1224\t\n1225\t    // Call tick() — discovers the open round, captures boundary price, settles\n1226\t    await clock.tick();\n1227\t\n1228\t    // Verify game.settled event was emitted in event_queue\n1229\t    const events = await rawSql`\n1230\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1231\t    `;\n1232\t    expect(events.length).toBe(1);\n1233\t\n1234\t    const evt = events[0]!;\n1235\t    expect(evt.status).toBe(\"pending\");\n1236\t\n1237\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1238\t    const payload = evt.payload as any;\n1239\t    expect(payload.roundId).toBe(String(Number(minuteTs)));\n1240\t    expect(payload.roundPda).toBe(roundPda.toBase58());\n1241\t    expect(payload.game).toBe(\"closecall\");\n1242\t    expect(payload.feeLamports).toBeDefined();\n1243\t    expect(payload.settledAt).toBeDefined();\n1244\t\n1245\t    // Players array — both players should be present\n1246\t    expect(payload.players).toHaveLength(2);\n1247\t    const greenP = payload.players.find(\n1248\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1249\t      (p: any) => p.wallet === greenPlayer.publicKey.toBase58(),\n1250\t    );\n1251\t    const redP = payload.players.find(\n1252\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1253\t      (p: any) => p.wallet === redPlayer.publicKey.toBase58(),\n1254\t    );\n1255\t    expect(greenP).toBeDefined();\n1256\t    expect(redP).toBeDefined();\n1257\t    expect(greenP.userId).toBe(greenUserId);\n1258\t    expect(redP.userId).toBe(redUserId);\n1259\t    // Amounts are string-encoded lamports\n1260\t    expect(greenP.amountLamports).toBe(String(greenAmount));\n1261\t    expect(redP.amountLamports).toBe(String(redAmount));\n1262\t    // Green wins (closePrice > openPrice)\n1263\t    expect(greenP.isWinner).toBe(true);\n1264\t    expect(redP.isWinner).toBe(false);\n1265\t    // Winner payout > 0, loser payout = \"0\"\n1266\t    expect(Number(greenP.payoutLamports)).toBeGreaterThan(0);\n1267\t    expect(redP.payoutLamports).toBe(\"0\");\n1268\t    // Fee = totalPool * 500 bps / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n1269\t    expect(payload.feeLamports).toBe(String(500_000));\n1270\t    // isCreator: first entry (green) is creator\n1271\t    expect(greenP.isCreator).toBe(true);\n1272\t    expect(redP.isCreator).toBe(false);\n1273\t  });\n1274\t\n1275\t  // ---------------------------------------------------------------------------\n1276\t  // REWARD_POOL_FUND handler\n1277\t  // ---------------------------------------------------------------------------\n1278\t\n1279\t  it(\"reward.pool_fund handler: funds pool from fee and dedupes on round_id\", async () => {\n1280\t    // Ensure reward_config has the fee share (seeded by migration, but verify)\n1281\t    const configRows = await rawSql<{ value: string }[]>`\n1282\t      SELECT value FROM reward_config WHERE key = 'reward_pool_fee_share'\n1283\t    `;\n1284\t    if (configRows.length === 0) {\n1285\t      // Re-seed if TRUNCATE removed it\n1286\t      await rawSql`INSERT INTO reward_config (key, value) VALUES ('reward_pool_fee_share', '0.20')`;\n1287\t    }\n1288\t\n1289\t    // Verify pool starts at zero\n1290\t    const poolBefore = await rawSql<{ balance_lamports: string; lifetime_funded: string }[]>`\n1291\t      SELECT balance_lamports, lifetime_funded FROM reward_pool WHERE id = 1\n1292\t    `;\n1293\t    expect(poolBefore.length).toBe(1);\n1294\t    expect(BigInt(poolBefore[0]!.balance_lamports)).toBe(0n);\n1295\t    expect(BigInt(poolBefore[0]!.lifetime_funded)).toBe(0n);\n1296\t\n1297\t    // Create handler and call it directly\n1298\t    const handler = createRewardPoolFundHandler({ db });\n1299\t"}]},"parent_tool_use_id":"toolu_01K3HHnXZYzfSc9sUzLpNNpp","session_id":"6576ed6a-06e5-40ef-875a-a4c0ef7a496b","uuid":"7fb4f73c-4686-42db-a40d-fcf2acdeee75","timestamp":"2026-04-03T20:20:12.419Z"}
