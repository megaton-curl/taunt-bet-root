{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KfeapbNdhoou7VcTL9GLhC","type":"tool_result","content":"700\t    const referrerKeypair = Keypair.generate();\n701\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n702\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n703\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n704\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n705\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n706\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n707\t    const referrerUserId = referrerProfile.user_id;\n708\t    const opponentUserId = opponentProfile.user_id;\n709\t    const creatorUserId = creatorProfile.user_id;\n710\t\n711\t    // Set up referral link: referrer → opponent (opponent is the referee)\n712\t    await db.insertReferralCode(referrerUserId, referrerWallet, \"test-ref\");\n713\t    await db.insertReferralLink({\n714\t      referrerUserId,\n715\t      refereeUserId: opponentUserId,\n716\t      referrerWallet,\n717\t      refereeWallet: opponentWallet,\n718\t    });\n719\t\n720\t    // 1. Create a coinflip match\n721\t    const token = await makeJwt(creatorWallet, creatorUserId);\n722\t    const createRes = await app.request(\"/coinflip/create\", {\n723\t      method: \"POST\",\n724\t      headers: {\n725\t        \"Content-Type\": \"application/json\",\n726\t        \"Authorization\": `Bearer ${token}`,\n727\t      },\n728\t      body: JSON.stringify({\n729\t        wallet: creatorWallet,\n730\t        amountLamports: AMOUNT_LAMPORTS,\n731\t        side: SIDE_HEADS,\n732\t      }),\n733\t    });\n734\t    expect(createRes.status).toBe(200);\n735\t    const createJson = (await createRes.json()) as {\n736\t      matchPda: string;\n737\t      matchId: string;\n738\t      commitment: string;\n739\t    };\n740\t\n741\t    // 2. Simulate on-chain join (opponent joins the match)\n742\t