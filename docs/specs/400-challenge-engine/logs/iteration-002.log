{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011gGgoK49XMB68THcEYjHp3","type":"tool_result","content":"1\t/**\n2\t * Close Call clock worker — precise minute-boundary price capture + settlement.\n3\t *\n4\t * Scheduling:\n5\t *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n6\t *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n7\t *   - Caches the boundary price (both close of old candle, open of next)\n8\t *   - Settles any open rounds whose candle has closed\n9\t *   - Schedules next tick at (next minute + 1s)\n10\t *\n11\t * Rounds are created on-demand by the first bettor (via /closecall/bet).\n12\t * On start, loads the latest boundary price from DB to seed the cache.\n13\t */\n14\t\n15\timport { performance } from \"node:perf_hooks\";\n16\timport {\n17\t  Connection,\n18\t  Keypair,\n19\t  PublicKey,\n20\t  Transaction,\n21\t} from \"@solana/web3.js\";\n22\timport type { Db } from \"../db.js\";\n23\timport { logger } from \"../logger.js\";\n24\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n25\timport { getPlatformConfig } from \"../platform-config.js\";\n26\timport {\n27\t  buildCloseCallSettleRoundIx,\n28\t} from \"./settle-tx.js\";\n29\timport {\n30\t  closeCallRoundDiscriminatorFilter,\n31\t  decodeCloseCallRound,\n32\t} from \"./account-decoder.js\";\n33\timport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n34\t\n35\t/** Close Call on-chain phase values */\n36\tconst PHASE_OPEN = 0;\n37\t\n38\t/** How long to wait after minute boundary before first Hermes poll (ms). */\n39\tconst BOUNDARY_OFFSET_MS = 1_000;\n40\t\n41\t/** Poll Hermes every 1s when waiting for boundary price. */\n42\tconst HERMES_POLL_INTERVAL_MS = 1_000;\n43\t\n44\t/** Max attempts to fetch a fresh boundary price (10s total). */\n45\tconst HERMES_MAX_RETRIES = 10;\n46\t\n47\t/** Maximum retry attempts for a single tx submission. */\n48\tconst MAX_TX_RETRIES = 3;\n49\tconst TX_RETRY_DELAY_MS = 2_000;\n50\t\n51\t// ---------------------------------------------------------------------------\n52\t// Types\n53\t// ---------------------------------------------------------------------------\n54\t\n55\texport interface BoundaryPrice {\n56\t  price: bigint;\n57\t  expo: number;\n58\t  minuteTs: number;\n59\t  priceHuman: number;\n60\t}\n61\t\n62\texport interface CloseCallClockDeps {\n63\t  connection: Connection;\n64\t  serverKeypair: Keypair;\n65\t  /** Typed database client. */\n66\t  db: Db;\n67\t  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n68\t  hermesEndpoint?: string;\n69\t}\n70\t\n71\texport interface CloseCallClockWorker {\n72\t  start(): void;\n73\t  stop(): void;\n74\t  readonly isRunning: boolean;\n75\t  /** Run a single tick (exposed for testing). */\n76\t  tick(): Promise<void>;\n77\t  /** Get the most recent minute-boundary price (from cache). */\n78\t  getLatestBoundaryPrice(): BoundaryPrice | null;\n79\t}\n80\t\n81\t// ---------------------------------------------------------------------------\n82\t// Factory\n83\t// ---------------------------------------------------------------------------\n84\t\n85\texport function createCloseCallClockWorker(\n86\t  deps: CloseCallClockDeps,\n87\t): CloseCallClockWorker {\n88\t  const { connection, serverKeypair, hermesEndpoint, db } = deps;\n89\t\n90\t  const hermes: HermesFetcher = createHermesFetcher(hermesEndpoint);\n91\t\n92\t  let running = false;\n93\t  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n94\t\n95\t  /** Cached latest boundary price (in-memory). */\n96\t  let cachedBoundaryPrice: BoundaryPrice | null = null;\n97\t\n98\t  // -----------------------------------------------------------------------\n99\t  // Scheduling\n100\t  // -----------------------------------------------------------------------\n101\t\n102\t  /** Milliseconds until the next minute boundary + offset. */\n103\t  function msUntilNextBoundary(): number {\n104\t    const now = Date.now();\n105\t    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n106\t    return nextMinute - now + BOUNDARY_OFFSET_MS;\n107\t  }\n108\t\n109\t  // -----------------------------------------------------------------------\n110\t  // Helpers\n111\t  // -----------------------------------------------------------------------\n112\t\n113\t  /** Send a legacy Transaction with retry. Uses the tx's original blockhash for confirmation. */\n114\t  async function sendAndConfirm(\n115\t    tx: Transaction,\n116\t    label: string,\n117\t    txBlockhash: string,\n118\t    txLastValidBlockHeight: number,\n119\t  ): Promise<string> {\n120\t    let lastError: unknown;\n121\t\n122\t    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n123\t      try {\n124\t        const sig = await connection.sendRawTransaction(tx.serialize(), {\n125\t          skipPreflight: false,\n126\t        });\n127\t        const confirmation = await connection.confirmTransaction(\n128\t          { signature: sig, blockhash: txBlockhash, lastValidBlockHeight: txLastValidBlockHeight },\n129\t          \"confirmed\",\n130\t        );\n131\t        if (confirmation.value.err) {\n132\t          throw new Error(\n133\t            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n134\t          );\n135\t        }\n136\t        return sig;\n137\t      } catch (err) {\n138\t        lastError = err;\n139\t        if (attempt < MAX_TX_RETRIES - 1) {\n140\t          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n141\t            error: err instanceof Error ? err.message : String(err),\n142\t          });\n143\t          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n144\t        }\n145\t      }\n146\t    }\n147\t\n148\t    throw lastError;\n149\t  }\n150\t\n151\t  /** Read treasury and feeBps from the shared PlatformConfig account. */\n152\t  async function readPlatformConfig(): Promise<{ treasury: PublicKey; feeBps: number } | null> {\n153\t    try {\n154\t      return await getPlatformConfig(connection);\n155\t    } catch {\n156\t      return null;\n157\t    }\n158\t  }\n159\t\n160\t  // -----------------------------------------------------------------------\n161\t  // Candle DB operations\n162\t  // -----------------------------------------------------------------------\n163\t\n164\t  /** Save a boundary price to the closecall_candles table (upsert). */\n165\t  async function saveBoundaryPrice(\n166\t    minuteTs: number,\n167\t    price: bigint,\n168\t    expo: number,\n169\t    priceHuman: number,\n170\t    hermesVaa: string | null,\n171\t  ): Promise<void> {\n172\t    try {\n173\t      await db.insertCloseCallCandle(minuteTs, price, expo, priceHuman, hermesVaa);\n174\t    } catch (err) {\n175\t      logger.error(\"closecall clock: failed to save boundary price\", {\n176\t        minuteTs,\n177\t        error: err instanceof Error ? err.message : String(err),\n178\t      });\n179\t    }\n180\t  }\n181\t\n182\t  /** Load the latest boundary price from DB (for startup cache seeding). */\n183\t  async function loadLatestBoundaryFromDb(): Promise<void> {\n184\t    try {\n185\t      const candle = await db.getLatestCloseCallCandle();\n186\t      if (candle) {\n187\t        cachedBoundaryPrice = {\n188\t          price: candle.price,\n189\t          expo: candle.expo,\n190\t          minuteTs: candle.minuteTs,\n191\t          priceHuman: candle.priceHuman,\n192\t        };\n193\t        logger.info(\"closecall clock: loaded boundary price from DB\", {\n194\t          minuteTs: cachedBoundaryPrice.minuteTs,\n195\t          priceHuman: cachedBoundaryPrice.priceHuman,\n196\t        });\n197\t      }\n198\t    } catch (err) {\n199\t      logger.warn(\"closecall clock: failed to load boundary price from DB\", {\n200\t        error: err instanceof Error ? err.message : String(err),\n201\t      });\n202\t    }\n203\t  }\n204\t\n205\t  // -----------------------------------------------------------------------\n206\t  // Boundary price capture — poll Hermes until fresh price arrives\n207\t  // -----------------------------------------------------------------------\n208\t\n209\t  /**\n210\t   * Poll Hermes every 1s until we get a price with publishTime >= boundaryTs.\n211\t   * Returns the captured price or null if max retries exceeded.\n212\t   */\n213\t  async function captureBoundaryPrice(\n214\t    boundaryTs: number,\n215\t  ): Promise<BoundaryPrice | null> {\n216\t    for (let attempt = 0; attempt < HERMES_MAX_RETRIES; attempt++) {\n217\t      try {\n218\t        const result = await hermes.fetchLatestBtcPrice();\n219\t        if (result && result.publishTime >= boundaryTs) {\n220\t          const bp: BoundaryPrice = {\n221\t            price: result.price,\n222\t            expo: result.expo,\n223\t            minuteTs: boundaryTs,\n224\t            priceHuman: result.priceHuman,\n225\t          };\n226\t\n227\t          // Save to DB with VAA proof\n228\t          await saveBoundaryPrice(\n229\t            boundaryTs,\n230\t            result.price,\n231\t            result.expo,\n232\t            result.priceHuman,\n233\t            result.vaaBase64,\n234\t          );\n235\t\n236\t          cachedBoundaryPrice = bp;\n237\t\n238\t          logger.info(\"closecall clock: boundary price captured\", {\n239\t            minuteTs: boundaryTs,\n240\t            priceHuman: result.priceHuman,\n241\t            publishTime: result.publishTime,\n242\t            attempts: attempt + 1,\n243\t          });\n244\t\n245\t          return bp;\n246\t        }\n247\t\n248\t        if (result) {\n249\t          logger.debug(\"closecall clock: Hermes price not yet at boundary\", {\n250\t            publishTime: result.publishTime,\n251\t            boundaryTs,\n252\t            attempt: attempt + 1,\n253\t          });\n254\t        }\n255\t      } catch (err) {\n256\t        logger.warn(\"closecall clock: Hermes poll failed\", {\n257\t          attempt: attempt + 1,\n258\t          error: err instanceof Error ? err.message : String(err),\n259\t        });\n260\t      }\n261\t\n262\t      // Wait 1s before next attempt\n263\t      if (attempt < HERMES_MAX_RETRIES - 1) {\n264\t        await new Promise((r) => setTimeout(r, HERMES_POLL_INTERVAL_MS));\n265\t      }\n266\t    }\n267\t\n268\t    logger.warn(\"closecall clock: failed to capture boundary price after max retries\", {\n269\t      boundaryTs,\n270\t    });\n271\t    return null;\n272\t  }\n273\t\n274\t  // -----------------------------------------------------------------------\n275\t  // Round discovery\n276\t  // -----------------------------------------------------------------------\n277\t\n278\t  /**\n279\t   * Discover ALL existing open rounds owned by this server.\n280\t   */\n281\t  async function discoverOpenRounds(): Promise<\n282\t    Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }>\n283\t  > {\n284\t    const results: Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }> = [];\n285\t    try {\n286\t      const accounts = await connection.getProgramAccounts(\n287\t        CLOSECALL_PROGRAM_ID,\n288\t        { filters: [closeCallRoundDiscriminatorFilter()] },\n289\t      );\n290\t\n291\t      const now = Math.floor(Date.now() / 1000);\n292\t\n293\t      for (const { pubkey, account } of accounts) {\n294\t        try {\n295\t          const round = decodeCloseCallRound(Buffer.from(account.data));\n296\t\n297\t          // Skip rounds with garbage minuteTs (old format / random bytes)\n298\t          const ts = Number(round.minuteTs);\n299\t          if (ts < 1700000000 || ts > now + 120) continue;\n300\t\n301\t          if (\n302\t            round.phase === PHASE_OPEN &&\n303\t            round.server.equals(serverKeypair.publicKey)\n304\t          ) {\n305\t            results.push({ pda: pubkey, minuteTs: round.minuteTs, round });\n306\t          }\n307\t        } catch {\n308\t          // Skip undecodeable accounts\n309\t        }\n310\t      }\n311\t    } catch (err) {\n312\t      logger.warn(\"closecall clock: discovery scan failed\", {\n313\t        error: err instanceof Error ? err.message : String(err),\n314\t      });\n315\t    }\n316\t    return results;\n317\t  }\n318\t\n319\t  // -----------------------------------------------------------------------\n320\t  // Settlement\n321\t  // -----------------------------------------------------------------------\n322\t\n323\t  /**\n324\t   * Settle a single round. Returns true on success.\n325\t   */\n326\t  async function settleRound(\n327\t    roundPda: PublicKey,\n328\t    minuteTs: bigint,\n329\t    round: ReturnType<typeof decodeCloseCallRound>,\n330\t  ): Promise<boolean> {\n331\t    try {\n332\t      const nowSec = Math.floor(Date.now() / 1000);\n333\t      const candleCloseTime = Number(minuteTs) + 60;\n334\t\n335\t      if (nowSec < candleCloseTime) {\n336\t        logger.debug(\"closecall clock: candle not closed yet\", {\n337\t          pda: roundPda.toBase58(),\n338\t          secondsRemaining: candleCloseTime - nowSec,\n339\t        });\n340\t        return false;\n341\t      }\n342\t\n343\t      const greenCount = round.greenEntries.length;\n344\t      const redCount = round.redEntries.length;\n345\t      const totalCount = greenCount + redCount;\n346\t\n347\t      // Fetch platform config (treasury + feeBps) + close price\n348\t      const [platformConfig, hermesPrice] = await Promise.all([\n349\t        readPlatformConfig(),\n350\t        hermes.fetchLatestBtcPrice(),\n351\t      ]);\n352\t\n353\t      if (!platformConfig) {\n354\t        logger.error(\"closecall clock: cannot read platform config treasury\");\n355\t        return false;\n356\t      }\n357\t      const { treasury, feeBps } = platformConfig;\n358\t      if (!hermesPrice) {\n359\t        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n360\t        return false;\n361\t      }\n362\t\n363\t      if (totalCount === 0) {\n364\t        logger.info(\"closecall clock: settling empty round\", {\n365\t          pda: roundPda.toBase58(),\n366\t        });\n367\t      }\n368\t\n369\t      // Pre-determine outcome\n370\t      const hasBothSides = greenCount > 0 && redCount > 0;\n371\t      const isRefund =\n372\t        totalCount === 0 ||\n373\t        !hasBothSides ||\n374\t        totalCount === 1 ||\n375\t        hermesPrice.price === round.openPrice;\n376\t\n377\t      let remainingAccounts: PublicKey[];\n378\t      if (isRefund) {\n379\t        remainingAccounts = [\n380\t          ...round.greenEntries.map((e) => e.player),\n381\t          ...round.redEntries.map((e) => e.player),\n382\t        ];\n383\t      } else if (hermesPrice.price > round.openPrice) {\n384\t        remainingAccounts = round.greenEntries.map((e) => e.player);\n385\t      } else {\n386\t        remainingAccounts = round.redEntries.map((e) => e.player);\n387\t      }\n388\t\n389\t      const ix = buildCloseCallSettleRoundIx(\n390\t        serverKeypair.publicKey,\n391\t        minuteTs,\n392\t        hermesPrice.price,\n393\t        hermesPrice.expo,\n394\t        treasury,\n395\t        remainingAccounts,\n396\t      );\n397\t\n398\t      const { blockhash, lastValidBlockHeight } =\n399\t        await connection.getLatestBlockhash();\n400\t      const tx = new Transaction({\n401\t        feePayer: serverKeypair.publicKey,\n402\t        blockhash,\n403\t        lastValidBlockHeight,\n404\t      });\n405\t      tx.add(ix);\n406\t      tx.sign(serverKeypair);\n407\t\n408\t      const sig = await sendAndConfirm(tx, \"settle\", blockhash, lastValidBlockHeight);\n409\t\n410\t      const outcomeStr = isRefund\n411\t        ? \"refund\"\n412\t        : hermesPrice.price > round.openPrice\n413\t          ? \"green\"\n414\t          : \"red\";\n415\t\n416\t      logger.info(\"closecall clock: round settled\", {\n417\t        pda: roundPda.toBase58(),\n418\t        tx: sig,\n419\t        totalEntries: totalCount,\n420\t        outcome: outcomeStr,\n421\t      });\n422\t\n423\t      // Persist settlement to DB (atomic transaction)\n424\t      try {\n425\t        const greenEntries = round.greenEntries.map((e) => ({\n426\t          player: e.player.toBase58(),\n427\t          amountLamports: Number(e.amountLamports),\n428\t        }));\n429\t        const redEntries = round.redEntries.map((e) => ({\n430\t          player: e.player.toBase58(),\n431\t          amountLamports: Number(e.amountLamports),\n432\t        }));\n433\t\n434\t        const totalPool = Number(round.greenPool) + Number(round.redPool);\n435\t        const computedFee = isRefund ? 0 : Math.floor(totalPool * feeBps / 10_000);\n436\t        const netPool = totalPool - computedFee;\n437\t        const roundId = String(Number(minuteTs));\n438\t        const pdaStr = roundPda.toBase58();\n439\t\n440\t        await db.withTransaction(async (txDb) => {\n441\t          // Ensure round record exists\n442\t          await txDb.insertCloseCallRound({\n443\t            roundId,\n444\t            pda: pdaStr,\n445\t            serverKey: serverKeypair.publicKey.toBase58(),\n446\t            openPrice: Number(round.openPrice),\n447\t            openPriceExpo: round.openPriceExpo,\n448\t          });\n449\t\n450\t          // Settle round\n451\t          await txDb.settleCloseCallRound(roundId, {\n452\t            phase: isRefund ? \"refunded\" : \"settled\",\n453\t            outcome: outcomeStr as \"green\" | \"red\" | \"refund\",\n454\t            closePrice: Number(hermesPrice.price),\n455\t            greenPool: Number(round.greenPool),\n456\t            redPool: Number(round.redPool),\n457\t            totalFee: computedFee,\n458\t            settleTx: sig,\n459\t          });\n460\t\n461\t          // Resolve profiles for all participants (used by both tx inserts and game entries)\n462\t          const allEntries = [\n463\t            ...greenEntries.map((e) => ({ ...e, side: \"green\" as const })),\n464\t            ...redEntries.map((e) => ({ ...e, side: \"red\" as const })),\n465\t          ];\n466\t\n467\t          const profileResults = allEntries.length > 0\n468\t            ? await Promise.all(\n469\t                allEntries.map(async (e) => {\n470\t                  const profile = await txDb.getProfileByWallet(e.player);\n471\t                  return [e.player, profile] as const;\n472\t                }),\n473\t              )\n474\t            : [];\n475\t          const profileMap = new Map(\n476\t            profileResults.filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1]),\n477\t          );\n478\t\n479\t          // Transaction rows — real SOL movements\n480\t          const txParams: Array<{\n481\t            userId?: string;\n482\t            wallet: string;\n483\t            game: string;\n484\t            matchId: string;\n485\t            txType: \"deposit\" | \"payout\" | \"refund\";\n486\t            amountLamports: number;\n487\t            txSig: string;\n488\t          }> = [];\n489\t\n490\t          for (const entry of greenEntries) {\n491\t            const userId = profileMap.get(entry.player)?.user_id;\n492\t            if (isRefund) {\n493\t              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n494\t            } else if (outcomeStr === \"green\") {\n495\t              const greenPool = Number(round.greenPool);\n496\t              const payout = greenPool > 0 ? Math.floor((entry.amountLamports / greenPool) * netPool) : 0;\n497\t              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n498\t            }\n499\t          }\n500\t          for (const entry of redEntries) {\n501\t            const userId = profileMap.get(entry.player)?.user_id;\n502\t            if (isRefund) {\n503\t              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n504\t            } else if (outcomeStr === \"red\") {\n505\t              const redPool = Number(round.redPool);\n506\t              const payout = redPool > 0 ? Math.floor((entry.amountLamports / redPool) * netPool) : 0;\n507\t              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n508\t            }\n509\t          }\n510\t\n511\t          if (txParams.length > 0) {\n512\t            await txDb.insertTransactions(txParams);\n513\t          }\n514\t\n515\t          // Game entries — UPSERT with settlement result\n516\t          if (allEntries.length > 0) {\n517\t            const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);\n518\t            if (missingWallets.length > 0) {\n519\t              logger.warn(\"closecall settle: missing profiles for participants — skipping their game entries\", {\n520\t                pda: pdaStr,\n521\t                missingWallets,\n522\t              });\n523\t            }\n524\t            const profileMap = new Map(\n525\t              profileResults\n526\t                .filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1])\n527\t                .map(([w, p]) => [w, p.user_id]),\n528\t            );\n529\t\n530\t            const gameEntries = allEntries\n531\t              .filter((e) => profileMap.has(e.player))\n532\t              .map((e) => {\n533\t                let entryIsWinner: boolean | undefined;\n534\t                let entryPayout: number;\n535\t\n536\t                if (isRefund) {\n537\t                  entryIsWinner = undefined; // null = refund, no winner/loser\n538\t                  entryPayout = e.amountLamports;\n539\t                } else {\n540\t                  const isWinningSide = e.side === outcomeStr;\n541\t                  entryIsWinner = isWinningSide;\n542\t                  if (isWinningSide) {\n543\t                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n544\t                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n545\t                  } else {\n546\t                    entryPayout = 0;\n547\t                  }\n548\t                }\n549\t\n550\t                return {\n551\t                  userId: profileMap.get(e.player)!,\n552\t                  wallet: e.player,\n553\t                  game: \"closecall\",\n554\t                  roundPda: pdaStr,\n555\t                  matchId: roundId,\n556\t                  amountLamports: e.amountLamports,\n557\t                  side: e.side,\n558\t                  isWinner: entryIsWinner,\n559\t                  payoutLamports: entryPayout,\n560\t                  settledAt: new Date(),\n561\t                };\n562\t              });\n563\t\n564\t            if (gameEntries.length > 0) {\n565\t              await txDb.upsertGameEntries(gameEntries);\n566\t            }\n567\t          }\n568\t        });\n569\t      } catch (dbErr) {\n570\t        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n571\t          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n572\t        });\n573\t      }\n574\t\n575\t      return true;\n576\t    } catch (err) {\n577\t      logger.error(\"closecall clock: settlement failed\", {\n578\t        pda: roundPda.toBase58(),\n579\t        error: err instanceof Error ? err.message : String(err),\n580\t      });\n581\t      return false;\n582\t    }\n583\t  }\n584\t\n585\t  // -----------------------------------------------------------------------\n586\t  // Tick — fires at minute boundary + 1s\n587\t  // -----------------------------------------------------------------------\n588\t\n589\t  async function tick(): Promise<void> {\n590\t    const t0 = performance.now();\n591\t    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n592\t\n593\t    // Step 1: Capture boundary price (poll Hermes until fresh)\n594\t    await captureBoundaryPrice(boundaryTs);\n595\t\n596\t    // Step 2: Discover + settle all open rounds whose candle has closed\n597\t    const openRounds = await discoverOpenRounds();\n598\t\n599\t    for (const { pda, minuteTs, round } of openRounds) {\n600\t      await settleRound(pda, minuteTs, round);\n601\t    }\n602\t\n603\t    const elapsed = Math.round(performance.now() - t0);\n604\t    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n605\t  }\n606\t\n607\t  async function loop(): Promise<void> {\n608\t    if (!running) return;\n609\t    try {\n610\t      await tick();\n611\t    } catch (err) {\n612\t      logger.error(\"closecall clock loop error\", {\n613\t        error: err instanceof Error ? err.message : String(err),\n614\t      });\n615\t    }\n616\t    if (running) {\n617\t      const delay = msUntilNextBoundary();\n618\t      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n619\t      timeoutId = setTimeout(loop, delay);\n620\t    }\n621\t  }\n622\t\n623\t  // -----------------------------------------------------------------------\n624\t  // Public interface\n625\t  // -----------------------------------------------------------------------\n626\t\n627\t  return {\n628\t    start() {\n629\t      if (running) return;\n630\t      running = true;\n631\t\n632\t      logger.info(\"closecall clock started\", {\n633\t        serverKey: serverKeypair.publicKey.toBase58(),\n634\t        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n635\t      });\n636\t\n637\t      // Load latest boundary price from DB, then schedule first tick\n638\t      loadLatestBoundaryFromDb()\n639\t        .then(() => {\n640\t          if (!running) return;\n641\t          const delay = msUntilNextBoundary();\n642\t          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n643\t          timeoutId = setTimeout(loop, delay);\n644\t        })\n645\t        .catch((err) => {\n646\t          logger.error(\"closecall clock: startup init failed\", {\n647\t            error: err instanceof Error ? err.message : String(err),\n648\t          });\n649\t          if (running) {\n650\t            const delay = msUntilNextBoundary();\n651\t            timeoutId = setTimeout(loop, delay);\n652\t          }\n653\t        });\n654\t    },\n655\t\n656\t    stop() {\n657\t      running = false;\n658\t      if (timeoutId) {\n659\t        clearTimeout(timeoutId);\n660\t        timeoutId = null;\n661\t      }\n662\t      logger.info(\"closecall clock stopped\");\n663\t    },\n664\t\n665\t    get isRunning() {\n666\t      return running;\n667\t    },\n668\t\n669\t    tick,\n670\t\n671\t    getLatestBoundaryPrice(): BoundaryPrice | null {\n672\t      return cachedBoundaryPrice;\n673\t    },\n674\t  };\n675\t}\n676\t"}]},"parent_tool_use_id":"toolu_01ByQycRucFD9Hh6wuMLvTLQ","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"1a6afa4e-9195-47a7-a1a2-f1c617409a22","timestamp":"2026-04-03T19:01:28.598Z"}
