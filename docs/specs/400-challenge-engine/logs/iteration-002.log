\",\"message\":\"coinflip create prepared\",\"wallet\":\"DuXw1Sgn3SxATS1ekJSC5hiQFQq9kjoss6GCDCSzjUku\",\"matchPda\":\"CTogntWL7tBWXnTnT2FCrafuFK8gxQwodanfbwr1pCFJ\",\"matchId\":\"e0073a19ef871530\",\"amountLamports\":5000000,\"side\":0,\"lastValidBlockHeight\":999999}\n{\"timestamp\":\"2026-04-03T19:14:26.048Z\",\"level\":\"info\",\"message\":\"settlement transaction submitted\",\"pda\":\"CTogntWL7tBWXnTnT2FCrafuFK8gxQwodanfbwr1pCFJ\",\"txSignature\":\"2AXDGYSE4f2sz7tvMMzyHvUfcoJmxudvdhBcmiUSo6ijwfYmfZYsKRxboQMPh3R4kUhXRVdtSXFXMheka4Rc4P2\",\"attempt\":1,\"dbMs\":1,\"fetchMs\":4,\"buildMs\":21,\"sendMs\":1}\n{\"timestamp\":\"2026-04-03T19:14:26.065Z\",\"level\":\"info\",\"message\":\"settlement transaction confirmed\",\"pda\":\"CTogntWL7tBWXnTnT2FCrafuFK8gxQwodanfbwr1pCFJ\",\"txSignature\":\"2AXDGYSE4f2sz7tvMMzyHvUfcoJmxudvdhBcmiUSo6ijwfYmfZYsKRxboQMPh3R4kUhXRVdtSXFXMheka4Rc4P2\",\"resultSide\":0,\"winner\":\"DuXw1Sgn3SxATS1ekJSC5hiQFQq9kjoss6GCDCSzjUku\",\"timing\":{\"dbMs\":1,\"fetchMs\":4,\"buildMs\":21,\"sendMs\":1,\"confirmMs\":0,\"dbWriteMs\":17,\"totalMs\":43}}\n{\"timestamp\":\"2026-04-03T19:14:26.155Z\",\"level\":\"info\",\"message\":\"coinflip create requested\",\"wallet\":\"DuXw1Sgn3SxATS1ekJSC5hiQFQq9kjoss6GCDCSzjUku\",\"amountLamports\":5000000,\"side\":0}\n{\"timestamp\":\"2026-04-03T19:14:26.190Z\",\"level\":\"info\",\"message\":\"coinflip create prepared\",\"wallet\":\"DuXw1Sgn3SxATS1ekJSC5hiQFQq9kjoss6GCDCSzjUku\",\"matchPda\":\"DA3Zvh89Z3m8NQTkg3Je7Nxywu6XgThqzDRhVzk42PTY\",\"matchId\":\"99862fbdc53d4abc\",\"amountLamports\":5000000,\"side\":0,\"lastValidBlockHeight\":999999}\n{\"timestamp\":\"2026-04-03T19:14:26.216Z\",\"level\":\"info\",\"message\":\"settlement transaction submitted\",\"pda\":\"DA3Zvh89Z3m8NQTkg3Je7Nxywu6XgThqzDRhVzk42PTY\",\"txSignature\":\"2AXDGYSE4f2sz7tvMMzyHvUfcoJmxudvdhBcmiUSo6ijwfYmfZYsKRxboQMPh3R4kUhXRVdtSXFXMheka4Rc4P2\",\"attempt\":1,\"dbMs\":1,\"fetchMs\":5,\"buildMs\":14,\"sendMs\":0}\n{\"timestamp\":\"2026-04-03T19: