{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VSizwaUkfbPedAVeJPHY64","type":"tool_result","content":"1\t/**\n2\t * Integration test for profile lifecycle:\n3\t * auth → profile auto-created → GET /profile/me → PUT /profile/username →\n4\t * cooldown → taken username → GET /public-profile/:identifier → no wallet leaks\n5\t */\n6\t\n7\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n8\timport { Hono } from \"hono\";\n9\timport { Keypair } from \"@solana/web3.js\";\n10\timport nacl from \"tweetnacl\";\n11\timport bs58 from \"bs58\";\n12\timport postgres from \"postgres\";\n13\timport { createAuthDb, type AuthDb } from \"../auth-db.js\";\n14\timport { createAuthRoutes } from \"../routes/auth.js\";\n15\timport { createProfileRoutes } from \"../routes/profile.js\";\n16\timport { createPublicProfileRoutes } from \"../routes/public-profile.js\";\n17\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n18\timport { createDb, type Db } from \"../db.js\";\n19\t\n20\t// ---------------------------------------------------------------------------\n21\t// Constants\n22\t// ---------------------------------------------------------------------------\n23\t\n24\tconst DATABASE_URL =\n25\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n26\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-profile-tests\");\n27\t\n28\t// ---------------------------------------------------------------------------\n29\t// Helpers\n30\t// ---------------------------------------------------------------------------\n31\t\n32\t/** Perform challenge → sign → verify and return access token + wallet. */\n33\tasync function authenticateWallet(\n34\t  app: Hono,\n35\t  keypair: Keypair,\n36\t): Promise<{ accessToken: string; wallet: string }> {\n37\t  const wallet = keypair.publicKey.toBase58();\n38\t\n39\t  // 1. Challenge\n40\t  const challengeRes = await app.request(\"/auth/challenge\", {\n41\t    method: \"POST\",\n42\t    headers: { \"Content-Type\": \"application/json\" },\n43\t    body: JSON.stringify({ wallet }),\n44\t  });\n45\t  expect(challengeRes.status).toBe(200);\n46\t  const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n47\t\n48\t  // 2. Sign\n49\t  const messageBytes = new TextEncoder().encode(challenge.message);\n50\t  const signatureBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n51\t  const signature = bs58.encode(signatureBytes);\n52\t\n53\t  // 3. Verify\n54\t  const verifyRes = await app.request(\"/auth/verify\", {\n55\t    method: \"POST\",\n56\t    headers: { \"Content-Type\": \"application/json\" },\n57\t    body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n58\t  });\n59\t  expect(verifyRes.status).toBe(200);\n60\t  const tokens = (await verifyRes.json()) as { accessToken: string };\n61\t  return { accessToken: tokens.accessToken, wallet };\n62\t}\n63\t\n64\t// ---------------------------------------------------------------------------\n65\t// Suite\n66\t// ---------------------------------------------------------------------------\n67\t\n68\tdescribe(\"Profile lifecycle integration\", () => {\n69\t  let rawSql: ReturnType<typeof postgres>;\n70\t  let authDb: AuthDb;\n71\t  let db: Db;\n72\t  let app: Hono;\n73\t\n74\t  const keypairA = Keypair.generate();\n75\t  const keypairB = Keypair.generate();\n76\t\n77\t  beforeAll(async () => {\n78\t    rawSql = postgres(DATABASE_URL);\n79\t\n80\t    // Ensure required tables exist\n81\t    await rawSql`DROP TABLE IF EXISTS auth_challenges, refresh_tokens`;\n82\t    await rawSql`\n83\t      CREATE TABLE IF NOT EXISTS auth_challenges (\n84\t        nonce TEXT PRIMARY KEY,\n85\t        wallet TEXT NOT NULL,\n86\t        cluster TEXT NOT NULL DEFAULT 'devnet',\n87\t        message TEXT NOT NULL,\n88\t        expires_at TIMESTAMPTZ NOT NULL,\n89\t        used BOOLEAN DEFAULT FALSE,\n90\t        created_at TIMESTAMPTZ DEFAULT now()\n91\t      )\n92\t    `;\n93\t    await rawSql`\n94\t      CREATE TABLE IF NOT EXISTS refresh_tokens (\n95\t        id BIGSERIAL PRIMARY KEY,\n96\t        user_id TEXT NOT NULL,\n97\t        wallet TEXT NOT NULL,\n98\t        token_hash BYTEA NOT NULL UNIQUE,\n99\t        family_id TEXT NOT NULL,\n100\t        expires_at TIMESTAMPTZ NOT NULL,"}]},"parent_tool_use_id":"toolu_012jf9LmiuJjw8ajAdHxfbKe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"a9be46d1-d75f-48c1-8f31-2c431a96d0b7","timestamp":"2026-04-03T19:02:17.380Z"}
