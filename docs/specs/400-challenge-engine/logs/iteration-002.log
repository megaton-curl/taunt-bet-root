y(createJson.matchPda);\n976\t    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n977\t    const matchAccountData = await buildMatchAccountData({\n978\t      creator: creatorKeypair.publicKey,\n979\t      opponent: opponentKeypair.publicKey,\n980\t      server: serverKeypair.publicKey,\n981\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n982\t      creatorSide: SIDE_HEADS,\n983\t      phase: PHASE_LOCKED,\n984\t      commitment: commitmentBuf,\n985\t      algorithmVer: 1,\n986\t      targetSlot: 150n,\n987\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n988\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n989\t    });\n990\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n991\t      owner: COINFLIP_PROGRAM_ID,\n992\t    });\n993\t\n994\t    // Transition DB round to \"locked\" (normally the settlement worker does this on join detection)\n995\t    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n996\t\n997\t    // Settle directly\n998\t    await settleMatch(\n999\t      {\n1000\t        db,\n1001\t        connection: mockConn as unknown as Connection,\n1002\t        serverKeypair,\n1003\t        entropyAccount,\n1004\t        referralDefaultRateBps: 1000,\n1005\t      },\n1006\t      createJson.matchPda,\n1007\t    );\n1008\t\n1009\t    // Verify game.settled event was emitted in event_queue\n1010\t    const events = await rawSql`\n1011\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n1012\t    `;\n1013\t    expect(events.length).toBe(1);\n1014\t\n1015\t    const evt = events[0]!;\n1016\t    expect(evt.status).toBe(\"pending\");\n1017\t\n1018\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1019\t    const payload = evt.payload as any;\n1020\t    expect(payload.roundId).toBe(createJson.matchId);\n1021\t    expect(payload.roundPda).toBe(createJson.matchPda);\n1022\t    expect(payload.game).toBe(\"coinflip\");\n1023\t    expect(payload.feeLamports).toBeDefined();\n1024\t    expect(payload.settledAt).toBeDefined();\n1025\t\n1026\t    // Players array\n1027\t    expect(payload.players).toHaveLength(2);\n1028\t    const creator = payload.players.find(\n1029\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1030\t      (p: any) => p.wallet === creatorKeypair.publicKey.toBase58(),\n1031\t    );\n1032\t    const opponent = payload.players.find(\n1033\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1034\t      (p: any) => p.wallet === opponentKeypair.publicKey.toBase58(),\n1035\t    );\n1036\t    expect(creator).toBeDefined();\n1037\t    expect(opponent).toBeDefined();\n1038\t    expect(creator.isCreator).toBe(true);\n1039\t    expect(opponent.isCreator).toBe(false);\n1040\t    expect(creator.userId).toBe(creatorUserId);\n1041\t    expect(opponent.userId).toBe(opponentUserId);\n1042\t    // Amounts are string-encoded lamports\n1043\t    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n1044\t    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n1045\t    // Exactly one winner\n1046\t    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n1047\t    // Winner has payoutLamports > 0, loser has \"0\"\n1048\t    const winnerPlayer = creator.isWinner ? creator : opponent;\n1049\t    const loserPlayer = creator.isWinner ? opponent : creator;\n1050\t    expect(Number(winnerPlayer.payoutLamports)).toBeGreaterThan(0);\n1051\t    expect(loserPlayer.payoutLamports).toBe(\"0\");\n1052\t    // Fee = pool * 500 / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n1053\t    expect(payload.feeLamports).toBe(String(500_000));\n1054\t  });\n1055\t\n1056\t  it(\"duplicate settlement retry produces duplicate game.settled event rows safely\", async () => {\n1057\t    const wallet = creatorKeypair.publicKey.toBase58();\n1058\t    const token = await makeJwt(wallet);\n1059\t\n1060\t    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58())