{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YQnc1pTDuLzmvFzzVw43uM","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/worker/closecall-clock.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"2ca19c4a-9bdd-41aa-90d9-e617125ac8d0","timestamp":"2026-04-03T19:04:02.489Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/worker/closecall-clock.ts","oldString":"          // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n          if (allEntries.length > 0) {\n            const settledAt = new Date().toISOString();\n            // Build per-player entries; for closecall, no single \"creator\" — first entry is treated as creator\n            const firstPlayer = allEntries[0]?.player;\n\n            const players = allEntries\n              .filter((e) => profileMap.has(e.player))\n              .map((e) => {\n                const userId = profileMap.get(e.player)!;\n                let entryIsWinner: boolean | null;","newString":"          // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n          if (allEntries.length > 0) {\n            const settledAt = new Date().toISOString();\n            // Build per-player entries; for closecall, no single \"creator\" — first entry is treated as creator\n            const firstPlayer = allEntries[0]?.player;\n\n            const players = allEntries\n              .filter((e) => profileMap.has(e.player))\n              .map((e) => {\n                const userId = profileMap.get(e.player)!.user_id;\n                let entryIsWinner: boolean | null;","originalFile":"/**\n * Close Call clock worker — precise minute-boundary price capture + settlement.\n *\n * Scheduling:\n *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n *   - Caches the boundary price (both close of old candle, open of next)\n *   - Settles any open rounds whose candle has closed\n *   - Schedules next tick at (next minute + 1s)\n *\n * Rounds are created on-demand by the first bettor (via /closecall/bet).\n * On start, loads the latest boundary price from DB to seed the cache.\n */\n\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { getPlatformConfig } from \"../platform-config.js\";\nimport {\n  buildCloseCallSettleRoundIx,\n} from \"./settle-tx.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport {\n  closeCallRoundDiscriminatorFilter,\n  decodeCloseCallRound,\n} from \"./account-decoder.js\";\nimport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n\n/** Close Call on-chain phase values */\nconst PHASE_OPEN = 0;\n\n/** How long to wait after minute boundary before first Hermes poll (ms). */\nconst BOUNDARY_OFFSET_MS = 1_000;\n\n/** Poll Hermes every 1s when waiting for boundary price. */\nconst HERMES_POLL_INTERVAL_MS = 1_000;\n\n/** Max attempts to fetch a fresh boundary price (10s total). */\nconst HERMES_MAX_RETRIES = 10;\n\n/** Maximum retry attempts for a single tx submission. */\nconst MAX_TX_RETRIES = 3;\nconst TX_RETRY_DELAY_MS = 2_000;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface BoundaryPrice {\n  price: bigint;\n  expo: number;\n  minuteTs: number;\n  priceHuman: number;\n}\n\nexport interface CloseCallClockDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n  /** Typed database client. */\n  db: Db;\n  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n  hermesEndpoint?: string;\n}\n\nexport interface CloseCallClockWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single tick (exposed for testing). */\n  tick(): Promise<void>;\n  /** Get the most recent minute-boundary price (from cache). */\n  getLatestBoundaryPrice(): BoundaryPrice | null;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createCloseCallClockWorker(\n  deps: CloseCallClockDeps,\n): CloseCallClockWorker {\n  const { connection, serverKeypair, hermesEndpoint, db } = deps;\n\n  const hermes: HermesFetcher = createHermesFetcher(hermesEndpoint);\n\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  /** Cached latest boundary price (in-memory). */\n  let cachedBoundaryPrice: BoundaryPrice | null = null;\n\n  // -----------------------------------------------------------------------\n  // Scheduling\n  // -----------------------------------------------------------------------\n\n  /** Milliseconds until the next minute boundary + offset. */\n  function msUntilNextBoundary(): number {\n    const now = Date.now();\n    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    return nextMinute - now + BOUNDARY_OFFSET_MS;\n  }\n\n  // -----------------------------------------------------------------------\n  // Helpers\n  // -----------------------------------------------------------------------\n\n  /** Send a legacy Transaction with retry. Uses the tx's original blockhash for confirmation. */\n  async function sendAndConfirm(\n    tx: Transaction,\n    label: string,\n    txBlockhash: string,\n    txLastValidBlockHeight: number,\n  ): Promise<string> {\n    let lastError: unknown;\n\n    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n      try {\n        const sig = await connection.sendRawTransaction(tx.serialize(), {\n          skipPreflight: false,\n        });\n        const confirmation = await connection.confirmTransaction(\n          { signature: sig, blockhash: txBlockhash, lastValidBlockHeight: txLastValidBlockHeight },\n          \"confirmed\",\n        );\n        if (confirmation.value.err) {\n          throw new Error(\n            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n          );\n        }\n        return sig;\n      } catch (err) {\n        lastError = err;\n        if (attempt < MAX_TX_RETRIES - 1) {\n          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n        }\n      }\n    }\n\n    throw lastError;\n  }\n\n  /** Read treasury and feeBps from the shared PlatformConfig account. */\n  async function readPlatformConfig(): Promise<{ treasury: PublicKey; feeBps: number } | null> {\n    try {\n      return await getPlatformConfig(connection);\n    } catch {\n      return null;\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Candle DB operations\n  // -----------------------------------------------------------------------\n\n  /** Save a boundary price to the closecall_candles table (upsert). */\n  async function saveBoundaryPrice(\n    minuteTs: number,\n    price: bigint,\n    expo: number,\n    priceHuman: number,\n    hermesVaa: string | null,\n  ): Promise<void> {\n    try {\n      await db.insertCloseCallCandle(minuteTs, price, expo, priceHuman, hermesVaa);\n    } catch (err) {\n      logger.error(\"closecall clock: failed to save boundary price\", {\n        minuteTs,\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  /** Load the latest boundary price from DB (for startup cache seeding). */\n  async function loadLatestBoundaryFromDb(): Promise<void> {\n    try {\n      const candle = await db.getLatestCloseCallCandle();\n      if (candle) {\n        cachedBoundaryPrice = {\n          price: candle.price,\n          expo: candle.expo,\n          minuteTs: candle.minuteTs,\n          priceHuman: candle.priceHuman,\n        };\n        logger.info(\"closecall clock: loaded boundary price from DB\", {\n          minuteTs: cachedBoundaryPrice.minuteTs,\n          priceHuman: cachedBoundaryPrice.priceHuman,\n        });\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: failed to load boundary price from DB\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Boundary price capture — poll Hermes until fresh price arrives\n  // -----------------------------------------------------------------------\n\n  /**\n   * Poll Hermes every 1s until we get a price with publishTime >= boundaryTs.\n   * Returns the captured price or null if max retries exceeded.\n   */\n  async function captureBoundaryPrice(\n    boundaryTs: number,\n  ): Promise<BoundaryPrice | null> {\n    for (let attempt = 0; attempt < HERMES_MAX_RETRIES; attempt++) {\n      try {\n        const result = await hermes.fetchLatestBtcPrice();\n        if (result && result.publishTime >= boundaryTs) {\n          const bp: BoundaryPrice = {\n            price: result.price,\n            expo: result.expo,\n            minuteTs: boundaryTs,\n            priceHuman: result.priceHuman,\n          };\n\n          // Save to DB with VAA proof\n          await saveBoundaryPrice(\n            boundaryTs,\n            result.price,\n            result.expo,\n            result.priceHuman,\n            result.vaaBase64,\n          );\n\n          cachedBoundaryPrice = bp;\n\n          logger.info(\"closecall clock: boundary price captured\", {\n            minuteTs: boundaryTs,\n            priceHuman: result.priceHuman,\n            publishTime: result.publishTime,\n            attempts: attempt + 1,\n          });\n\n          return bp;\n        }\n\n        if (result) {\n          logger.debug(\"closecall clock: Hermes price not yet at boundary\", {\n            publishTime: result.publishTime,\n            boundaryTs,\n            attempt: attempt + 1,\n          });\n        }\n      } catch (err) {\n        logger.warn(\"closecall clock: Hermes poll failed\", {\n          attempt: attempt + 1,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n\n      // Wait 1s before next attempt\n      if (attempt < HERMES_MAX_RETRIES - 1) {\n        await new Promise((r) => setTimeout(r, HERMES_POLL_INTERVAL_MS));\n      }\n    }\n\n    logger.warn(\"closecall clock: failed to capture boundary price after max retries\", {\n      boundaryTs,\n    });\n    return null;\n  }\n\n  // -----------------------------------------------------------------------\n  // Round discovery\n  // -----------------------------------------------------------------------\n\n  /**\n   * Discover ALL existing open rounds owned by this server.\n   */\n  async function discoverOpenRounds(): Promise<\n    Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }>\n  > {\n    const results: Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }> = [];\n    try {\n      const accounts = await connection.getProgramAccounts(\n        CLOSECALL_PROGRAM_ID,\n        { filters: [closeCallRoundDiscriminatorFilter()] },\n      );\n\n      const now = Math.floor(Date.now() / 1000);\n\n      for (const { pubkey, account } of accounts) {\n        try {\n          const round = decodeCloseCallRound(Buffer.from(account.data));\n\n          // Skip rounds with garbage minuteTs (old format / random bytes)\n          const ts = Number(round.minuteTs);\n          if (ts < 1700000000 || ts > now + 120) continue;\n\n          if (\n            round.phase === PHASE_OPEN &&\n            round.server.equals(serverKeypair.publicKey)\n          ) {\n            results.push({ pda: pubkey, minuteTs: round.minuteTs, round });\n          }\n        } catch {\n          // Skip undecodeable accounts\n        }\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: discovery scan failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    return results;\n  }\n\n  // -----------------------------------------------------------------------\n  // Settlement\n  // -----------------------------------------------------------------------\n\n  /**\n   * Settle a single round. Returns true on success.\n   */\n  async function settleRound(\n    roundPda: PublicKey,\n    minuteTs: bigint,\n    round: ReturnType<typeof decodeCloseCallRound>,\n  ): Promise<boolean> {\n    try {\n      const nowSec = Math.floor(Date.now() / 1000);\n      const candleCloseTime = Number(minuteTs) + 60;\n\n      if (nowSec < candleCloseTime) {\n        logger.debug(\"closecall clock: candle not closed yet\", {\n          pda: roundPda.toBase58(),\n          secondsRemaining: candleCloseTime - nowSec,\n        });\n        return false;\n      }\n\n      const greenCount = round.greenEntries.length;\n      const redCount = round.redEntries.length;\n      const totalCount = greenCount + redCount;\n\n      // Fetch platform config (treasury + feeBps) + close price\n      const [platformConfig, hermesPrice] = await Promise.all([\n        readPlatformConfig(),\n        hermes.fetchLatestBtcPrice(),\n      ]);\n\n      if (!platformConfig) {\n        logger.error(\"closecall clock: cannot read platform config treasury\");\n        return false;\n      }\n      const { treasury, feeBps } = platformConfig;\n      if (!hermesPrice) {\n        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n        return false;\n      }\n\n      if (totalCount === 0) {\n        logger.info(\"closecall clock: settling empty round\", {\n          pda: roundPda.toBase58(),\n        });\n      }\n\n      // Pre-determine outcome\n      const hasBothSides = greenCount > 0 && redCount > 0;\n      const isRefund =\n        totalCount === 0 ||\n        !hasBothSides ||\n        totalCount === 1 ||\n        hermesPrice.price === round.openPrice;\n\n      let remainingAccounts: PublicKey[];\n      if (isRefund) {\n        remainingAccounts = [\n          ...round.greenEntries.map((e) => e.player),\n          ...round.redEntries.map((e) => e.player),\n        ];\n      } else if (hermesPrice.price > round.openPrice) {\n        remainingAccounts = round.greenEntries.map((e) => e.player);\n      } else {\n        remainingAccounts = round.redEntries.map((e) => e.player);\n      }\n\n      const ix = buildCloseCallSettleRoundIx(\n        serverKeypair.publicKey,\n        minuteTs,\n        hermesPrice.price,\n        hermesPrice.expo,\n        treasury,\n        remainingAccounts,\n      );\n\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      const tx = new Transaction({\n        feePayer: serverKeypair.publicKey,\n        blockhash,\n        lastValidBlockHeight,\n      });\n      tx.add(ix);\n      tx.sign(serverKeypair);\n\n      const sig = await sendAndConfirm(tx, \"settle\", blockhash, lastValidBlockHeight);\n\n      const outcomeStr = isRefund\n        ? \"refund\"\n        : hermesPrice.price > round.openPrice\n          ? \"green\"\n          : \"red\";\n\n      logger.info(\"closecall clock: round settled\", {\n        pda: roundPda.toBase58(),\n        tx: sig,\n        totalEntries: totalCount,\n        outcome: outcomeStr,\n      });\n\n      // Persist settlement to DB (atomic transaction)\n      try {\n        const greenEntries = round.greenEntries.map((e) => ({\n          player: e.player.toBase58(),\n          amountLamports: Number(e.amountLamports),\n        }));\n        const redEntries = round.redEntries.map((e) => ({\n          player: e.player.toBase58(),\n          amountLamports: Number(e.amountLamports),\n        }));\n\n        const totalPool = Number(round.greenPool) + Number(round.redPool);\n        const computedFee = isRefund ? 0 : Math.floor(totalPool * feeBps / 10_000);\n        const netPool = totalPool - computedFee;\n        const roundId = String(Number(minuteTs));\n        const pdaStr = roundPda.toBase58();\n\n        await db.withTransaction(async (txDb) => {\n          // Ensure round record exists\n          await txDb.insertCloseCallRound({\n            roundId,\n            pda: pdaStr,\n            serverKey: serverKeypair.publicKey.toBase58(),\n            openPrice: Number(round.openPrice),\n            openPriceExpo: round.openPriceExpo,\n          });\n\n          // Settle round\n          await txDb.settleCloseCallRound(roundId, {\n            phase: isRefund ? \"refunded\" : \"settled\",\n            outcome: outcomeStr as \"green\" | \"red\" | \"refund\",\n            closePrice: Number(hermesPrice.price),\n            greenPool: Number(round.greenPool),\n            redPool: Number(round.redPool),\n            totalFee: computedFee,\n            settleTx: sig,\n          });\n\n          // Resolve profiles for all participants (used by both tx inserts and game entries)\n          const allEntries = [\n            ...greenEntries.map((e) => ({ ...e, side: \"green\" as const })),\n            ...redEntries.map((e) => ({ ...e, side: \"red\" as const })),\n          ];\n\n          const profileResults = allEntries.length > 0\n            ? await Promise.all(\n                allEntries.map(async (e) => {\n                  const profile = await txDb.getProfileByWallet(e.player);\n                  return [e.player, profile] as const;\n                }),\n              )\n            : [];\n          const profileMap = new Map(\n            profileResults.filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1]),\n          );\n\n          // Transaction rows — real SOL movements\n          const txParams: Array<{\n            userId?: string;\n            wallet: string;\n            game: string;\n            matchId: string;\n            txType: \"deposit\" | \"payout\" | \"refund\";\n            amountLamports: number;\n            txSig: string;\n          }> = [];\n\n          for (const entry of greenEntries) {\n            const userId = profileMap.get(entry.player)?.user_id;\n            if (isRefund) {\n              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n            } else if (outcomeStr === \"green\") {\n              const greenPool = Number(round.greenPool);\n              const payout = greenPool > 0 ? Math.floor((entry.amountLamports / greenPool) * netPool) : 0;\n              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n            }\n          }\n          for (const entry of redEntries) {\n            const userId = profileMap.get(entry.player)?.user_id;\n            if (isRefund) {\n              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n            } else if (outcomeStr === \"red\") {\n              const redPool = Number(round.redPool);\n              const payout = redPool > 0 ? Math.floor((entry.amountLamports / redPool) * netPool) : 0;\n              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n            }\n          }\n\n          if (txParams.length > 0) {\n            await txDb.insertTransactions(txParams);\n          }\n\n          // Game entries — UPSERT with settlement result\n          if (allEntries.length > 0) {\n            const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);\n            if (missingWallets.length > 0) {\n              logger.warn(\"closecall settle: missing profiles for participants — skipping their game entries\", {\n                pda: pdaStr,\n                missingWallets,\n              });\n            }\n            const profileMap = new Map(\n              profileResults\n                .filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1])\n                .map(([w, p]) => [w, p.user_id]),\n            );\n\n            const gameEntries = allEntries\n              .filter((e) => profileMap.has(e.player))\n              .map((e) => {\n                let entryIsWinner: boolean | undefined;\n                let entryPayout: number;\n\n                if (isRefund) {\n                  entryIsWinner = undefined; // null = refund, no winner/loser\n                  entryPayout = e.amountLamports;\n                } else {\n                  const isWinningSide = e.side === outcomeStr;\n                  entryIsWinner = isWinningSide;\n                  if (isWinningSide) {\n                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n                  } else {\n                    entryPayout = 0;\n                  }\n                }\n\n                return {\n                  userId: profileMap.get(e.player)!,\n                  wallet: e.player,\n                  game: \"closecall\",\n                  roundPda: pdaStr,\n                  matchId: roundId,\n                  amountLamports: e.amountLamports,\n                  side: e.side,\n                  isWinner: entryIsWinner,\n                  payoutLamports: entryPayout,\n                  settledAt: new Date(),\n                };\n              });\n\n            if (gameEntries.length > 0) {\n              await txDb.upsertGameEntries(gameEntries);\n            }\n          }\n\n          // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n          if (allEntries.length > 0) {\n            const settledAt = new Date().toISOString();\n            // Build per-player entries; for closecall, no single \"creator\" — first entry is treated as creator\n            const firstPlayer = allEntries[0]?.player;\n\n            const players = allEntries\n              .filter((e) => profileMap.has(e.player))\n              .map((e) => {\n                const userId = profileMap.get(e.player)!;\n                let entryIsWinner: boolean | null;\n                let entryPayout: number;\n\n                if (isRefund) {\n                  entryIsWinner = null; // null = refund\n                  entryPayout = e.amountLamports;\n                } else {\n                  const isWinningSide = e.side === outcomeStr;\n                  entryIsWinner = isWinningSide;\n                  if (isWinningSide) {\n                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n                  } else {\n                    entryPayout = 0;\n                  }\n                }\n\n                return {\n                  userId,\n                  wallet: e.player,\n                  amountLamports: String(e.amountLamports),\n                  isWinner: entryIsWinner,\n                  payoutLamports: String(entryPayout),\n                  isCreator: e.player === firstPlayer,\n                };\n              });\n\n            if (players.length > 0) {\n              await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n                roundId,\n                roundPda: pdaStr,\n                game: \"closecall\",\n                players,\n                feeLamports: String(computedFee),\n                settledAt,\n              });\n            }\n          }\n        });\n      } catch (dbErr) {\n        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n        });\n      }\n\n      return true;\n    } catch (err) {\n      logger.error(\"closecall clock: settlement failed\", {\n        pda: roundPda.toBase58(),\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return false;\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Tick — fires at minute boundary + 1s\n  // -----------------------------------------------------------------------\n\n  async function tick(): Promise<void> {\n    const t0 = performance.now();\n    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n\n    // Step 1: Capture boundary price (poll Hermes until fresh)\n    await captureBoundaryPrice(boundaryTs);\n\n    // Step 2: Discover + settle all open rounds whose candle has closed\n    const openRounds = await discoverOpenRounds();\n\n    for (const { pda, minuteTs, round } of openRounds) {\n      await settleRound(pda, minuteTs, round);\n    }\n\n    const elapsed = Math.round(performance.now() - t0);\n    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await tick();\n    } catch (err) {\n      logger.error(\"closecall clock loop error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      const delay = msUntilNextBoundary();\n      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n      timeoutId = setTimeout(loop, delay);\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Public interface\n  // -----------------------------------------------------------------------\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n\n      logger.info(\"closecall clock started\", {\n        serverKey: serverKeypair.publicKey.toBase58(),\n        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n      });\n\n      // Load latest boundary price from DB, then schedule first tick\n      loadLatestBoundaryFromDb()\n        .then(() => {\n          if (!running) return;\n          const delay = msUntilNextBoundary();\n          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n          timeoutId = setTimeout(loop, delay);\n        })\n        .catch((err) => {\n          logger.error(\"closecall clock: startup init failed\", {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          if (running) {\n            const delay = msUntilNextBoundary();\n            timeoutId = setTimeout(loop, delay);\n          }\n        });\n    },\n\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"closecall clock stopped\");\n    },\n\n    get isRunning() {\n      return running;\n    },\n\n    tick,\n\n    getLatestBoundaryPrice(): BoundaryPrice | null {\n      return cachedBoundaryPrice;\n    },\n  };\n}\n","structuredPatch":[{"oldStart":577,"oldLines":7,"newStart":577,"newLines":7,"lines":["             const players = allEntries","               .filter((e) => profileMap.has(e.player))","               .map((e) => {","-                const userId = profileMap.get(e.player)!;","+                const userId = profileMap.get(e.player)!.user_id;","                 let entryIsWinner: boolean | null;","                 let entryPayout: number;"," "]}],"userModified":false,"replaceAll":false}}
