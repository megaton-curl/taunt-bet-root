{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0161WSaZLfFfGELcF8YmES2W","type":"tool_result","content":"1\t/**\n2\t * Settle transaction builder + submission.\n3\t *\n4\t * Retrieves the stored secret, reads on-chain match + config data to resolve\n5\t * all accounts, builds the `settle` instruction, submits it, and updates the\n6\t * DB on confirmation.\n7\t */\n8\t\n9\timport { createHash } from \"node:crypto\";\n10\timport { performance } from \"node:perf_hooks\";\n11\timport {\n12\t  Connection,\n13\t  Keypair,\n14\t  PublicKey,\n15\t  SystemProgram,\n16\t  Transaction,\n17\t  TransactionInstruction,\n18\t} from \"@solana/web3.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport { emitEvent } from \"../queue/emit-event.js\";\n22\timport { EventTypes } from \"../queue/event-types.js\";\n23\timport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n24\timport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n25\timport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@taunt-bet/anchor-client\";\n26\timport {\n27\t  decodeCoinflipMatch,\n28\t  decodeLordRound,\n29\t  type DecodedJackpotRound,\n30\t} from \"./account-decoder.js\";\n31\t\n32\t// ---------------------------------------------------------------------------\n33\t// Instruction discriminators (from IDL — no hardcoded byte arrays)\n34\t// ---------------------------------------------------------------------------\n35\t\n36\tfunction getInstructionDiscriminator(\n37\t  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n38\t  instructionName: string,\n39\t): Buffer {\n40\t  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n41\t  if (!instruction) {\n42\t    throw new Error(`Instruction ${instructionName} not found in IDL`);\n43\t  }\n44\t  return Buff