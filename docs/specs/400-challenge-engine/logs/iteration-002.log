{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018oBiFBBeZrhW25TiNjG4YL","type":"tool_result","content":"320\t  // Settlement\n321\t  // -----------------------------------------------------------------------\n322\t\n323\t  /**\n324\t   * Settle a single round. Returns true on success.\n325\t   */\n326\t  async function settleRound(\n327\t    roundPda: PublicKey,\n328\t    minuteTs: bigint,\n329\t    round: ReturnType<typeof decodeCloseCallRound>,\n330\t  ): Promise<boolean> {\n331\t    try {\n332\t      const nowSec = Math.floor(Date.now() / 1000);\n333\t      const candleCloseTime = Number(minuteTs) + 60;\n334\t\n335\t      if (nowSec < candleCloseTime) {\n336\t        logger.debug(\"closecall clock: candle not closed yet\", {\n337\t          pda: roundPda.toBase58(),\n338\t          secondsRemaining: candleCloseTime - nowSec,\n339\t        });\n340\t        return false;\n341\t      }\n342\t\n343\t      const greenCount = round.greenEntries.length;\n344\t      const redCount = round.redEntries.length;\n345\t      const totalCount = greenCount + redCount;\n346\t\n347\t      // Fetch platform config (treasury + feeBps) + close price\n348\t      const [platformConfig, hermesPrice] = await Promise.all([\n349\t        readPlatformConfig(),\n350\t        hermes.fetchLatestBtcPrice(),\n351\t      ]);\n352\t\n353\t      if (!platformConfig) {\n354\t        logger.error(\"closecall clock: cannot read platform config treasury\");\n355\t        return false;\n356\t      }\n357\t      const { treasury, feeBps } = platformConfig;\n358\t      if (!hermesPrice) {\n359\t        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n360\t        return false;\n361\t      }\n362\t\n363\t      if (totalCount === 0) {\n364\t        logger.info(\"closecall clock: settling empty round\", {\n365\t          pda: roundPda.toBase58(),\n366\t        });\n367\t      }\n368\t\n369\t      // Pre-determine outcome\n370\t      const hasBothSides = greenCount > 0 && redCount > 0;\n371\t      const isRefund =\n372\t        totalCount === 0 ||\n373\t        !hasBothSides ||\n374\t        totalCount === 1 ||\n375\t        hermesPrice.price === round.openPrice;\n376\t\n377\t      let remainingAccounts: PublicKey[];\n378\t      if (isRefund) {\n379\t        remainingAccounts = [\n380\t          ...round.greenEntries.map((e) => e.player),\n381\t          ...round.redEntries.map((e) => e.player),\n382\t        ];\n383\t      } else if (hermesPrice.price > round.openPrice) {\n384\t        remainingAccounts = round.greenEntries.map((e) => e.player);\n385\t      } else {\n386\t        remainingAccounts = round.redEntries.map((e) => e.player);\n387\t      }\n388\t\n389\t      const ix = buildCloseCallSettleRoundIx(\n390\t        serverKeypair.publicKey,\n391\t        minuteTs,\n392\t        hermesPrice.price,\n393\t        hermesPrice.expo,\n394\t        treasury,\n395\t        remainingAccounts,\n396\t      );\n397\t\n398\t      const { blockhash, lastValidBlockHeight } =\n399\t        await connection.getLatestBlockhash();\n400\t      const tx = new Transaction({\n401\t        feePayer: serverKeypair.publicKey,\n402\t        blockhash,\n403\t        lastValidBlockHeight,\n404\t      });\n405\t      tx.add(ix);\n406\t      tx.sign(serverKeypair);\n407\t\n408\t      const sig = await sendAndConfirm(tx, \"settle\", blockhash, lastValidBlockHeight);\n409\t\n410\t      const outcomeStr = isRefund\n411\t        ? \"refund\"\n412\t        : hermesPrice.price > round.openPrice\n413\t          ? \"green\"\n414\t          : \"red\";\n415\t\n416\t      logger.info(\"closecall clock: round settled\", {\n417\t        pda: roundPda.toBase58(),\n418\t        tx: sig,\n419\t        totalEntries: totalCount,\n420\t        outcome: outcomeStr,\n421\t      });\n422\t\n423\t      // Persist settlement to DB (atomic transaction)\n424\t      try {\n425\t        const greenEntries = round.greenEntries.map((e) => ({\n426\t          player: 