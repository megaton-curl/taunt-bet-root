{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G6PscJzHAnjTQkFQyYxxc4","type":"tool_result","content":"438\t    // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n439\t    const settledAt = new Date().toISOString();\n440\t    const creatorUserId = winner.equals(creator) ? winnerProfile?.user_id : loserProfile?.user_id;\n441\t    const opponentUserId = winner.equals(creator) ? loserProfile?.user_id : winnerProfile?.user_id;\n442\t    await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n443\t      roundId: round.match_id,\n444\t      roundPda: pda,\n445\t      game: \"coinflip\",\n446\t      players: [\n447\t        {\n448\t          userId: creatorUserId ?? creator.toBase58(),\n449\t          wallet: creator.toBase58(),\n450\t          amountLamports: String(entryAmount),\n451\t          isWinner: winner.equals(creator),\n452\t          payoutLamports: winner.equals(creator) ? String(payoutAmount) : \"0\",\n453\t          isCreator: true,\n454\t        },\n455\t        {\n456\t          userId: opponentUserId ?? opponent.toBase58(),\n457\t          wallet: opponent.toBase58(),\n458\t          amountLamports: String(entryAmount),\n459\t          isWinner: winner.equals(opponent),\n460\t          payoutLamports: winner.equals(opponent) ? String(payoutAmount) : \"0\",\n461\t          isCreator: false,\n462\t        },\n463\t      ],\n464\t      feeLamports: String(feeAmount),\n465\t      settledAt,\n466\t    });\n467\t  });\n468\t\n469\t  const tDone = performance.now();\n470\t  logger.info(\"settlement transaction confirmed\", {\n471\t    pda,\n472\t    txSignature,\n473\t    resultSide,\n474\t    winner: winner.toBase58(),\n475\t    timing: {\n476\t      dbMs: Math.round(tDb - t0),\n477\t      fetchMs: Math.round(tFetch - tDb),"}]},"parent_tool_use_id":"toolu_01DuKqK91GsF5p6uEGeMga7o","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"f21c900a-d432-4135-824a-34ff3c91ad42","timestamp":"2026-04-0