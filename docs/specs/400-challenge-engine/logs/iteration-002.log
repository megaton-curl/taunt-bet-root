{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TBeaTMP9LdeA7WJzo4ksrP","type":"tool_result","content":"1\t/**\n2\t * Integration test: full create → join → settle lifecycle.\n3\t *\n4\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n5\t * the real HTTP endpoints, database, settlement worker, and retry logic\n6\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport {\n12\t  Keypair,\n13\t  PublicKey,\n14\t  SystemProgram,\n15\t  LAMPORTS_PER_SOL,\n16\t} from \"@solana/web3.js\";\n17\timport type { Connection } from \"@solana/web3.js\";\n18\timport bs58 from \"bs58\";\n19\timport { SignJWT } from \"jose\";\n20\timport postgres from \"postgres\";\n21\timport { createDb, type Db } from \"../db.js\";\n22\timport { createCoinflipRoutes } from \"../routes/create.js\";\n23\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n24\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n25\timport { createSettlementWorker } from \"../worker/settlement.js\";\n26\timport { settleMatch } from \"../worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"../worker/retry.js\";\n28\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n29\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n30\timport { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n31\t\n32\t// ---------------------------------------------------------------------------\n33\t// Constants\n34\t// ---------------------------------------------------------------------------\n35\t\n36\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n37\t\n38\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n39\tfunction makeSql() {\n40\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n41\t  // Dev container: postgres listens on Unix socket only\n42\t  return postgres({\n43\t    host: \"/var/run/postgresql\",\n44\t    user: \"vscode\",\n45\t    database: \"rng_utopia_dev\",\n46\t  });\n47\t}\n48\t\n49\tconst AMOUNT_LAMPORTS = 5_000_000;\n50\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n51\tconst SIDE_HEADS = 0;\n52\tconst PHASE_LOCKED = 1;\n53\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n54\t\n55\t// ---------------------------------------------------------------------------\n56\t// JWT helper\n57\t// ---------------------------------------------------------------------------\n58\t\n59\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n60\t  const now = Math.floor(Date.now() / 1000);\n61\t  return new SignJWT({ wallet })\n62\t    .setProtectedHeader({ alg: \"HS256\" })\n63\t    .setSubject(userId)\n64\t    .setIssuedAt(now)\n65\t    .setExpirationTime(now + 3600)\n66\t    .sign(JWT_SECRET);\n67\t}\n68\t\n69\tfunction userIdFromWallet(wallet: string) {\n70\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n71\t}\n72\t\n73\t// ---------------------------------------------------------------------------\n74\t// Mock Connection\n75\t// ---------------------------------------------------------------------------\n76\t\n77\t/**\n78\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n79\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n80\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n81\t */\n82\tclass MockConnection {\n83\t  private _slot = 200;\n84\t  private _accounts = new Map<\n85\t    string,\n86\t    {\n87\t      data: Buffer;\n88\t      lamports: number;\n89\t      owner: PublicKey;\n90\t      executable: boolean;\n91\t    }\n92\t  >();\n93\t  lastRawTx: Buffer | null = null;\n94\t\n95\t  set slot(s: number) {\n96\t    this._slot = s;\n97\t  }\n98\t  get slot() {\n99\t    return this._slot;\n100\t  }\n101\t\n102\t  setAccount(\n103\t    pubkey: PublicKey,\n104\t    data: Buffer,\n105\t    opts?: { lamports?: number; owner?: PublicKey },\n106\t  ) {\n107\t    this._accounts.set(pubkey.toBase58(), {\n108\t      data,\n109\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n110\t      owner: opts?.owner ?? SystemProgram.programId,\n111\t      executable: false,\n112\t    });\n113\t  }\n114\t\n115\t  removeAccount(pubkey: PublicKey) {\n116\t    this._accounts.delete(pubkey.toBase58());\n117\t  }\n118\t\n119\t  async getLatestBlockhash() {\n120\t    return {\n121\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n122\t      lastValidBlockHeight: 999_999,\n123\t    };\n124\t  }\n125\t\n126\t  async getSlot() {\n127\t    return this._slot;\n128\t  }\n129\t\n130\t  async getAccountInfo(pubkey: PublicKey) {\n131\t    const acc = this._accounts.get(pubkey.toBase58());\n132\t    if (!acc) return null;\n133\t    return { ...acc, rentEpoch: 0 };\n134\t  }\n135\t\n136\t  async getProgramAccounts(\n137\t    programId: PublicKey,\n138\t    config?: {\n139\t      filters?: Array<\n140\t        | { dataSize: number }\n141\t        | { memcmp: { offset: number; bytes: string } }\n142\t      >;\n143\t    },\n144\t  ) {\n145\t    const results: Array<{\n146\t      pubkey: PublicKey;\n147\t      account: {\n148\t        data: Buffer;\n149\t        lamports: number;\n150\t        owner: PublicKey;\n151\t        executable: boolean;\n152\t        rentEpoch: number;\n153\t      };\n154\t    }> = [];\n155\t\n156\t    for (const [key, acc] of this._accounts) {\n157\t      if (!acc.owner.equals(programId)) continue;\n158\t\n159\t      let matches = true;\n160\t      if (config?.filters) {\n161\t        for (const filter of config.filters) {\n162\t          if (\"dataSize\" in filter) {\n163\t            if (acc.data.length !== filter.dataSize) {\n164\t              matches = false;\n165\t              break;\n166\t            }\n167\t          }\n168\t          if (\"memcmp\" in filter) {\n169\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n170\t            const actual = acc.data.subarray(\n171\t              filter.memcmp.offset,\n172\t              filter.memcmp.offset + expected.length,\n173\t            );\n174\t            if (Buffer.compare(actual, expected) !== 0) {\n175\t              matches = false;\n176\t              break;\n177\t            }\n178\t          }\n179\t        }\n180\t      }\n181\t\n182\t      if (matches) {\n183\t        results.push({\n184\t          pubkey: new PublicKey(key),\n185\t          account: { ...acc, rentEpoch: 0 },\n186\t        });\n187\t      }\n188\t    }\n189\t    return results;\n190\t  }\n191\t\n192\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n193\t    this.lastRawTx = Buffer.from(rawTx);\n194\t    // Return a deterministic fake signature\n195\t    return bs58.encode(Buffer.alloc(64, 0x01));\n196\t  }\n197\t\n198\t  async confirmTransaction() {\n199\t    return { value: { err: null }, context: { slot: this._slot } };\n200\t  }\n201\t\n202\t  async getBlockTime(_slot: number) {\n203\t    return Math.floor(Date.now() / 1000);\n204\t  }\n205\t\n206\t  async getBalance() {\n207\t    return 2 * LAMPORTS_PER_SOL;\n208\t  }\n209\t}\n210\t\n211\t// ---------------------------------------------------------------------------\n212\t// Account data builders\n213\t// ---------------------------------------------------------------------------\n214\t\n215\tasync function buildMatchAccountData(params: {\n216\t  creator: PublicKey;\n217\t  opponent: PublicKey;\n218\t  server: PublicKey;\n219\t  entryAmount: bigint;\n220\t  creatorSide: number;\n221\t  phase: number;\n222\t  commitment: Buffer;\n223\t  algorithmVer: number;\n224\t  targetSlot: bigint;\n225\t  resolveDeadline: bigint;\n226\t  matchId: Buffer;\n227\t}): Promise<Buffer> {\n228\t  return encodeCoinflipMatch({\n229\t    creator: params.creator,\n230\t    opponent: params.opponent,\n231\t    server: params.server,\n232\t    entryAmount: params.entryAmount,\n233\t    creatorSide: params.creatorSide,\n234\t    phase: params.phase,\n235\t    commitment: [...params.commitment],\n236\t    algorithmVer: params.algorithmVer,\n237\t    targetSlot: params.targetSlot,\n238\t    resolveDeadline: params.resolveDeadline,\n239\t    resultHash: new Array(32).fill(0),\n240\t    result: 0,\n241\t    winner: PublicKey.default,\n242\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n243\t    matchId: [...params.matchId],\n244\t    bump: 0,\n245\t  });\n246\t}\n247\t\n248\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n249\t  return encodeCoinflipConfig({\n250\t    authority: PublicKey.default,\n251\t    treasury,\n252\t    paused: false,\n253\t    bump: 0,\n254\t  });\n255\t}\n256\t\n257\t/**\n258\t * Build PlatformConfig account data matching the on-chain layout.\n259\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n260\t */\n261\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n262\t  const buf = Buffer.alloc(74);\n263\t  // discriminator (8 bytes) — zeroed is fine for mock\n264\t  // authority at offset 8 — use default\n265\t  PublicKey.default.toBuffer().copy(buf, 8);\n266\t  // treasury at offset 40\n267\t  treasury.toBuffer().copy(buf, 40);\n268\t  // fee_bps at offset 72\n269\t  buf.writeUInt16LE(feeBps, 72);\n270\t  return buf;\n271\t}\n272\t\n273\t// ---------------------------------------------------------------------------\n274\t// Test suite\n275\t// ---------------------------------------------------------------------------\n276\t\n277\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n278\t  let db: Db;\n279\t  let rawSql: ReturnType<typeof postgres>;\n280\t  let mockConn: MockConnection;\n281\t  let app: Hono;\n282\t\n283\t  const serverKeypair = Keypair.generate();\n284\t  const creatorKeypair = Keypair.generate();\n285\t  const opponentKeypair = Keypair.generate();\n286\t  const treasuryKeypair = Keypair.generate();\n287\t  const entropyKeypair = Keypair.generate();\n288\t  const entropyAccount = entropyKeypair.publicKey;\n289\t\n290\t  const entropyData = Buffer.alloc(32);\n291\t  entropyData[0] = 0xab;\n292\t  entropyData[1] = 0xcd;\n293\t  entropyData[15] = 0x42;\n294\t\n295\t  beforeAll(async () => {\n296\t    rawSql = makeSql();\n297\t    await rawSql`\n298\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n299\t    `;\n300\t    await rawSql`"}]},"parent_tool_use_id":"toolu_017sWZHEt75rtcKF3tGqjVJe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"fb7cd125-3704-4fa5-b277-7e4897f04b10","timestamp":"2026-04-03T19:06:06.454Z"}
