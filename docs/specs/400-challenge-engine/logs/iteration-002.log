{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GUkVHDVpokSPPLVLyf2vCk","type":"tool_result","content":"0\t/**\n1\t * IDL-driven account decoder — single source of truth for all Solana account\n2\t * data access in the backend.\n3\t *\n4\t * Uses Anchor's BorshAccountsCoder to decode/encode accounts directly from\n5\t * the generated IDL JSON files, eliminating all hardcoded byte offsets.\n6\t */\n7\t\n8\timport anchor, { type Idl } from \"@coral-xyz/anchor\";\n9\t\n10\tconst { BorshAccountsCoder, BN } = anchor;\n11\timport { PublicKey } from \"@solana/web3.js\";\n12\timport {\n13\t  CoinflipIDL as coinflipIdl,\n14\t  ClosecallIDL as closecallIdl,\n15\t  LordofrngsIDL as lordIdl,\n16\t} from \"@taunt-bet/anchor-client\";\n17\t\n18\t// ---------------------------------------------------------------------------\n19\t// Coders (instantiated once at module load)\n20\t// ---------------------------------------------------------------------------\n21\t\n22\tconst coinflipCoder = new BorshAccountsCoder(coinflipIdl as Idl);\n23\tconst closecallCoder = new BorshAccountsCoder(closecallIdl as Idl);\n24\tconst lordCoder = new BorshAccountsCoder(lordIdl as Idl);\n25\t\n26\t// ---------------------------------------------------------------------------\n27\t// Type helpers\n28\t// ---------------------------------------------------------------------------\n29\t"}]},"parent_tool_use_id":null,"session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"3728f7a6-a8b6-4a8e-8410-358cc479bb53","timestamp":"2026-04-03T19:10:07.776Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/worker/account-decoder.ts","content":"/**\n * IDL-driven account decoder — single source of truth for all Solana account\n * data access in the backend.\n *\n * Uses Anchor's BorshAccountsCoder to decode/encode accounts directly from\n * the generated IDL JSON files, eliminating all hardcoded byte offsets.\n */\n\nimport anchor, { type Idl } from \"@coral-xyz/anchor\";\n\nconst { BorshAccountsCoder, BN } = anchor;\nimport { PublicKey } from \"@solana/web3.js\";\nimport {\n  CoinflipIDL as coinflipIdl,\n  ClosecallIDL as closecallIdl,\n  LordofrngsIDL as lordIdl,\n} from \"@taunt-bet/anchor-client\";\n\n// ---------------------------------------------------------------------------\n// Coders (instantiated once at module load)\n// ---------------------------------------------------------------------------\n\nconst coinflipCoder = new BorshAccountsCoder(coinflipIdl as Idl);\nconst closecallCoder = new BorshAccountsCoder(closecallIdl as Idl);\nconst lordCoder = new BorshAccountsCoder(lordIdl as Idl);\n\n// ---------------------------------------------------------------------------\n// Type helpers\n// ---------------------------------------------------------------------------\n","numLines":30,"startLine":0,"totalLines":336}}}
