rice from DB, then schedule first tick\n689\t      loadLatestBoundaryFromDb()\n690\t        .then(() => {\n691\t          if (!running) return;\n692\t          const delay = msUntilNextBoundary();\n693\t          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n694\t          timeoutId = setTimeout(loop, delay);\n695\t        })\n696\t        .catch((err) => {\n697\t          logger.error(\"closecall clock: startup init failed\", {\n698\t            error: err instanceof Error ? err.message : String(err),\n699\t          });\n700\t          if (running) {\n701\t            const delay = msUntilNextBoundary();\n702\t            timeoutId = setTimeout(loop, delay);\n703\t          }\n704\t        });\n705\t    },\n706\t\n707\t    stop() {\n708\t      running = false;\n709\t      if (timeoutId) {\n710\t        clearTimeout(timeoutId);\n711\t        timeoutId = null;\n712\t      }\n713\t      logger.info(\"closecall clock stopped\");\n714\t    },\n715\t\n716\t    get isRunning() {\n717\t      return running;\n718\t    },\n719\t"}]},"parent_tool_use_id":null,"session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"44fe9c45-d605-4550-8e57-5780bf974915","timestamp":"2026-04-03T19:05:33.819Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/worker/closecall-clock.ts","content":"  async function tick(): Promise<void> {\n    const t0 = performance.now();\n    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n\n    // Step 1: Capture boundary price (poll Hermes until fresh)\n    await captureBoundaryPrice(boundaryTs);\n\n    // Step 2: Discover + settle all open rounds whose candle has closed\n    const openRounds = await discoverOpenRounds();\n\n    for (const { pda, minuteTs, round } of openRounds) {\n      await settleRound(pda, minuteTs, round);\n    }\n\n    const elapsed = Math.round(performance.now() - t0);\n    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await tick();\n    } catch (err) {\n      logger.error(\"closecall clock loop error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      const delay = msUntilNextBoundary();\n      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n      timeoutId = setTimeout(loop, delay);\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Public interface\n  // -----------------------------------------------------------------------\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n\n      logger.info(\"closecall clock started\", {\n        serverKey: serverKeypair.publicKey.toBase58(),\n        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n      });\n\n      // Load latest boundary price from DB, then schedule first tick\n      loadLatestBoundaryFromDb()\n        .then(() => {\n          if (!running) return;\n          const delay = msUntilNextBoundary();\n          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n          timeoutId = setTimeout(loop, delay);\n        })\n        .catch((err) => {\n          logger.error(\"closecall clock: startup init failed\", {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          if (running) {\n            const delay = msUntilNextBoundary();\n            timeoutId = setTimeout(loop, delay);\n          }\n        });\n    },\n\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"closecall clock stopped\");\n    },\n\n    get isRunning() {\n      return running;\n    },\n","numLines":80,"startLine":640,"totalLines":727}}}
