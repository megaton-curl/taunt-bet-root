{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017ZXTG6xy3JKGvdUfK9bxpz","type":"tool_result","content":"0\t/**\n1\t * IDL-driven account decoder — single source of truth for all Solana account\n2\t * data access in the backend.\n3\t *\n4\t * Uses Anchor's BorshAccountsCoder to decode/encode accounts directly from\n5\t * the generated IDL JSON files, eliminating all hardcoded byte offsets.\n6\t */\n7\t\n8\timport anchor, { type Idl } from \"@coral-xyz/anchor\";\n9\t\n10\tconst { BorshAccountsCoder, BN } = anchor;\n11\timport { PublicKey } from \"@solana/web3.js\";\n12\timport {\n13\t  CoinflipIDL as coinflipIdl,\n14\t  ClosecallIDL as closecallIdl,\n15\t  LordofrngsIDL as lordIdl,\n16\t} from \"@taunt-bet/anchor-client\";\n17\t\n18\t// ---------------------------------------------------------------------------\n19\t// Coders (instantiated once at module load)\n20\t// ---------------------------------------------------------------------------\n21\t\n22\tconst coinflipCoder = new BorshAccountsCoder(coinflipIdl as Idl);\n23\tconst closecallCoder = new BorshAccountsCoder(closecallIdl as Idl);\n24\tconst lordCoder = new BorshAccountsCoder(lordIdl as Idl);\n25\t\n26\t// ---------------------------------------------------------------------------\n27\t// Type helpers\n28\t// ---------------------------------------------------------------------------\n29\t\n30\tfunction bnToBigInt(bn: InstanceType<typeof BN>): bigint {\n31\t  return BigInt(bn.toString());\n32\t}\n33\t\n34\t/**\n35\t * Anchor decodes Rust enums as { VariantName: {} }. Convert RoundPhase to\n36\t * the numeric value used throughout the backend.\n37\t */\n38\tfunction roundPhaseToNumber(phase: Record<string, object>): number {\n39\t  if (\"Waiting\" in phase) return 0;\n40\t  if (\"Active\" in phase) return 1;\n41\t  if (\"Locked\" in phase) return 2;\n42\t  if (\"Resolving\" in phase) return 3;\n43\t  if (\"Settled\" in phase) return 4;\n44\t  if (\"Refunded\" in phase) return 5;\n45\t  throw new Error(`Unknown RoundPhase variant: ${JSON.stringify(phase)}`);\n46\t}\n47\t\n48\t/** CloseCallPhase enum: Open=0, Settled=1, Refunded=2 */\n49\tfunction closeCallPhaseToNumber(phase: Record<string, object>): number {\n50\t  if (\"Open\" in phase) return 0;\n51\t  if (\"Settled\" in phase) return 1;\n52\t  if (\"Refunded\" in phase) return 2;\n53\t  throw new Error(`Unknown CloseCallPhase variant: ${JSON.stringify(phase)}`);\n54\t}\n55\t\n56\t/** Outcome enum: Pending=0, Green=1, Red=2, Refund=3 */\n57\tfunction outcomeToNumber(outcome: Record<string, object>): number {\n58\t  if (\"Pending\" in outcome) return 0;\n59\t  if (\"Green\" in outcome) return 1;\n60\t  if (\"Red\" in outcome) return 2;\n61\t  if (\"Refund\" in outcome) return 3;\n62\t  throw new Error(`Unknown Outcome variant: ${JSON.stringify(outcome)}`);\n63\t}\n64\t\n65\t// ---------------------------------------------------------------------------\n66\t// Exported interfaces (camelCase, BigInt instead of BN)\n67\t// ---------------------------------------------------------------------------\n68\t\n69\texport interface DecodedCoinflipMatch {\n70\t  creator: PublicKey;\n71\t  opponent: PublicKey;\n72\t  server: PublicKey;\n73\t  entryAmount: bigint;\n74\t  creatorSide: number;\n75\t  phase: number;\n76\t  commitment: number[];\n77\t  algorithmVer: number;\n78\t  targetSlot: bigint;\n79\t  resolveDeadline: bigint;\n80\t  resultHash: number[];\n81\t  result: number;\n82\t  winner: PublicKey;\n83\t  createdAt: bigint;\n84\t  matchId: number[];\n85\t  bump: number;\n86\t}\n87\t\n88\texport interface DecodedCoinflipConfig {\n89\t  authority: PublicKey;\n90\t  treasury: PublicKey;\n91\t  paused: boolean;\n92\t  bump: number;\n93\t}\n94\t\n95\texport interface DecodedJackpotRound {\n96\t  matchId: number[];\n97\t  server: PublicKey;\n98\t  phase: number;\n99\t  commitment: number[];"}]},"parent_tool_use_id":"toolu_017sWZHEt75rtcKF3tGqjVJe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"b407cfbe-4e7a-44b8-a1d1-2938e49d6112","timestamp":"2026-04-03T19:07:34.276Z"}
