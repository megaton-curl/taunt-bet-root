{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ALPDoxwLk67MjPET2X6bZ6","type":"tool_result","content":"1\t-- 004_closecall_rounds.sql — Close Call pari-mutuel rounds (oracle-resolved, Pyth price).\n2\t\n3\tCREATE TABLE closecall_rounds (\n4\t  round_id        TEXT         PRIMARY KEY,\n5\t  pda             TEXT         UNIQUE NOT NULL,\n6\t  server_key      TEXT         NOT NULL,\n7\t  phase           TEXT         NOT NULL DEFAULT 'open' CHECK (phase IN ('open', 'settled', 'refunded')),\n8\t  open_price      BIGINT       NOT NULL,\n9\t  open_price_expo INT          NOT NULL,\n10\t  close_price     BIGINT,\n11\t  outcome         TEXT         NOT NULL DEFAULT 'pending' CHECK (outcome IN ('pending', 'green', 'red', 'refund')),\n12\t  green_pool      BIGINT       NOT NULL DEFAULT 0,\n13\t  red_pool        BIGINT       NOT NULL DEFAULT 0,\n14\t  total_fee       BIGINT       NOT NULL DEFAULT 0,\n15\t  settle_tx       TEXT,\n16\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n17\t  settled_at      TIMESTAMPTZ\n18\t);\n19\t\n20\tCREATE INDEX idx_closecall_rounds_phase ON closecall_rounds (phase);\n21\tCREATE INDEX idx_closecall_rounds_settled_at ON closecall_rounds (settled_at DESC);\n22\tCREATE INDEX idx_cc_rounds_settled ON closecall_rounds (settled_at DESC) WHERE phase = 'settled';\n23\t"}]},"parent_tool_use_id":"toolu_012jf9LmiuJjw8ajAdHxfbKe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"0e2ea277-431e-4c41-bdc2-318e7a55ea08","timestamp":"2026-04-03T19:02:04.820Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011VLu9MwZ3ravASyBowYVdz","type":"tool_result","content":"1\t-- 007_game_entries.sql — Single source of truth for participation + stats + leaderboard.\n2\t--\n3\t-- Written at participation time (create/bet), updated at settlement via UPSERT.\n4\t-- Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\n5\t\n6\tCREATE TABLE game_entries (\n7\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n8\t  user_id         TEXT         NOT NULL,\n9\t  wallet          TEXT         NOT NULL,\n10\t  game            TEXT         NOT NULL CHECK (game IN ('coinflip', 'lord', 'closecall')),\n11\t  round_pda       TEXT         NOT NULL,\n12\t  match_id        TEXT         NOT NULL,\n13\t  amount_lamports BIGINT       NOT NULL CHECK (amount_lamports > 0),\n14\t  side            TEXT,\n15\t  is_winner       BOOLEAN,\n16\t  payout_lamports BIGINT       NOT NULL DEFAULT 0,\n17\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n18\t  settled_at      TIMESTAMPTZ,\n19\t  UNIQUE (wallet, round_pda)\n20\t);\n21\t\n22\tCREATE INDEX idx_game_entries_settled ON game_entries (settled_at DESC) WHERE settled_at IS NOT NULL;\n23\tCREATE INDEX idx_game_entries_game_settled ON game_entries (game, settled_at DESC) WHERE settled_at IS NOT NULL;\n24\tCREATE INDEX idx_game_entries_user_settled ON game_entries (user_id, settled_at DESC);\n25\tCREATE INDEX idx_game_entries_round_pda ON game_entries (round_pda);\n26\t"}]},"parent_tool_use_id":"toolu_012jf9LmiuJjw8ajAdHxfbKe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"a3cb53e7-1c5c-484b-bcc5-1ef7778a2c2b","timestamp":"2026-04-03T19:02:04.812Z"}
