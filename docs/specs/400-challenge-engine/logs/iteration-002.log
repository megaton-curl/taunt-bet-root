{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S2Fghzjbhpcsf9ovpevYZT","type":"tool_result","content":"200\t  }\n201\t\n202\t  async getBlockTime(_slot: number) {\n203\t    return Math.floor(Date.now() / 1000);\n204\t  }\n205\t\n206\t  async getBalance() {\n207\t    return 2 * LAMPORTS_PER_SOL;\n208\t  }\n209\t}\n210\t\n211\t// ---------------------------------------------------------------------------\n212\t// Account data builders\n213\t// ---------------------------------------------------------------------------\n214\t\n215\tasync function buildMatchAccountData(params: {\n216\t  creator: PublicKey;\n217\t  opponent: PublicKey;\n218\t  server: PublicKey;\n219\t  entryAmount: bigint;\n220\t  creatorSide: number;\n221\t  phase: number;\n222\t  commitment: Buffer;\n223\t  algorithmVer: number;\n224\t  targetSlot: bigint;\n225\t  resolveDeadline: bigint;\n226\t  matchId: Buffer;\n227\t}): Promise<Buffer> {\n228\t  return encodeCoinflipMatch({\n229\t    creator: params.creator,\n230\t    opponent: params.opponent,\n231\t    server: params.server,\n232\t    entryAmount: params.entryAmount,\n233\t    creatorSide: params.creatorSide,\n234\t    phase: params.phase,\n235\t    commitment: [...params.commitment],\n236\t    algorithmVer: params.algorithmVer,\n237\t    targetSlot: params.targetSlot,\n238\t    resolveDeadline: params.resolveDeadline,\n239\t    resultHash: new Array(32).fill(0),\n240\t    result: 0,\n241\t    winner: PublicKey.default,\n242\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n243\t    matchId: [...params.matchId],\n244\t    bump: 0,\n245\t  });\n246\t}\n247\t\n248\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n249\t  return encodeCoinflipConfig({\n250\t    authority: PublicKey.default,\n251\t    treasury,\n252\t    paused: false,\n253\t    bump: 0,\n254\t  });\n255\t}\n256\t\n257\t/**\n258\t * Build PlatformConfig account data matching the on-chain layout.\n259\t * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n260\t */\n261\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n262\t  const buf = Buffer.alloc(74);\n263\t  // discriminator (8 bytes) — zeroed is fine for mock\n264\t  // authority at offset 8 — use default\n265\t  PublicKey.default.toBuffer().copy(buf, 8);\n266\t  // treasury at offset 40\n267\t  treasury.toBuffer().copy(buf, 40);\n268\t  // fee_bps at offset 72\n269\t  buf.writeUInt16LE(feeBps, 72);\n270\t  return buf;\n271\t}\n272\t\n273\t// ---------------------------------------------------------------------------\n274\t// Test suite\n275\t// ---------------------------------------------------------------------------\n276\t\n277\tdescribe(\"Integration: create → join → settle lifecycle\", () => {\n278\t  let db: Db;\n279\t  let rawSql: ReturnType<typeof postgres>;\n280\t  let mockConn: MockConnection;\n281\t  let app: Hono;\n282\t\n283\t  const serverKeypair = Keypair.generate();\n284\t  const creatorKeypair = Keypair.generate();\n285\t  const opponentKeypair = Keypair.generate();\n286\t  const treasuryKeypair = Keypair.generate();\n287\t  const entropyKeypair = Keypair.generate();\n288\t  const entropyAccount = entropyKeypair.publicKey;\n289\t\n290\t  const entropyData = Buffer.alloc(32);\n291\t  entropyData[0] = 0xab;\n292\t  entropyData[1] = 0xcd;\n293\t  entropyData[15] = 0x42;\n294\t\n295\t  beforeAll(async () => {\n296\t    rawSql = makeSql();\n297\t    await rawSql`\n298\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n299\t    `;\n300\t    await rawSql`\n301\t      CREATE TABLE referral_codes (\n302\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n303\t        user_id TEXT NOT NULL UNIQUE,\n304\t        wallet TEXT NOT NULL UNIQUE,\n305\t        code TEXT NOT NULL UNIQUE,\n306\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n307\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n308\t      )\n309\t    `;\n310\t    await rawSql`\n311\t      CREATE TABLE referral_links (\n312\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n313\t        referrer_user_id TEXT NOT NULL,\n314\t        referee_user_id TEXT NOT NULL UNIQUE,\n315\t        referrer_wallet TEXT NOT NULL,\n316\t        referee_wallet TEXT NOT NULL,\n317\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n318\t      )\n319\t    `;\n320\t    await rawSql`\n321\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n322\t    `;\n323\t    await rawSql`\n324\t      CREATE TABLE referral_earnings (\n325\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n326\t        referrer_user_id TEXT NOT NULL,\n327\t        referee_user_id TEXT NOT NULL,\n328\t        referrer_wallet TEXT NOT NULL,\n329\t        referee_wallet TEXT NOT NULL,\n330\t        round_id TEXT NOT NULL,\n331\t        game_type TEXT NOT NULL,\n332\t        wager_lamports BIGINT NOT NULL,\n333\t        fee_lamports BIGINT NOT NULL,\n334\t        referrer_earned_lamports BIGINT NOT NULL,\n335\t        referrer_rate_bps INTEGER NOT NULL,\n336\t        referee_rebate_lamports BIGINT NOT NULL,\n337\t        referee_rebate_rate_bps INTEGER NOT NULL,\n338\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n339\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n340\t      )\n341\t    `;\n342\t    await rawSql`\n343\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n344\t    `;\n345\t    await rawSql`\n346\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n347\t    `;\n348\t    await rawSql`\n349\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n350\t    `;\n351\t    await rawSql`\n352\t      CREATE TABLE referral_claims (\n353\t        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n354\t        user_id TEXT NOT NULL,\n355\t        wallet TEXT NOT NULL,\n356\t        amount_lamports BIGINT NOT NULL,\n357\t        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n358\t        retry_count INTEGER NOT NULL DEFAULT 0,\n359\t        tx_signature TEXT,\n360\t        error TEXT,\n361\t        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n362\t        processed_at TIMESTAMPTZ\n363\t      )\n364\t    `;\n365\t    await rawSql`\n366\t      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n367\t    `;\n368\t    await rawSql`\n369\t      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n370\t    `;\n371\t    await rawSql`\n372\t      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n373\t    `;\n374\t    await rawSql`\n375\t      CREATE TABLE referral_kol_rates (\n376\t        user_id TEXT PRIMARY KEY,\n377\t        wallet TEXT NOT NULL UNIQUE,\n378\t        rate_bps INTEGER NOT NULL,\n379\t        set_by TEXT NOT NULL,\n380\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n381\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n382\t      )\n383\t    `;\n384\t    db = createDb(DATABASE_URL, rawSql);\n385\t  });\n386\t\n387\t  afterAll(async () => {\n388\t    await db.close();\n389\t    await rawSql.end();\n390\t  });\n391\t\n392\t  beforeEach(async () => {\n393\t    // Clean tables for isolation\n394\t    await rawSql`TRUNCATE rounds, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates RESTART IDENTITY CASCADE`;\n395\t\n396\t    // Reset PlatformConfig cache so each test reads from its own mock\n397\t    resetPlatformConfigCache();\n398\t\n399\t    // Fresh mock Connection\n400\t    mockConn = new MockConnection();\n401\t\n402\t    // Pre-populate mock with entropy and config accounts\n403\t    mockConn.setAccount(entropyAccount, entropyData);\n404\t\n405\t    const [configPda] = PublicKey.findProgramAddressSync(\n406\t      [Buffer.from(\"coinflip_config\")],\n407\t      COINFLIP_PROGRAM_ID,\n408\t    );\n409\t    mockConn.setAccount(\n410\t      configPda,\n411\t      await buildConfigAccountData(treasuryKeypair.publicKey),\n412\t      { owner: COINFLIP_PROGRAM_ID },\n413\t    );\n414\t\n415\t    // PlatformConfig account — settlement reads fee_bps from here\n416\t    const [platformConfigPda] = derivePlatformConfigPda();\n417\t    mockConn.setAccount(\n418\t      platformConfigPda,\n419\t      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n420\t      { owner: PLATFORM_PROGRAM_ID },\n421\t    );\n422\t\n423\t    // Build the Hono app (no rate limiting for tests)\n424\t    app = new Hono();\n425\t\n426\t    app.use(\n427\t      \"/coinflip/*\",\n428\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n429\t    );\n430\t\n431\t    app.route(\n432\t      \"/coinflip\",\n433\t      createCoinflipRoutes({\n434\t        db,\n435\t        connection: mockConn as unknown as Connection,\n436\t        serverKeypair,\n437\t      }),\n438\t    );\n439\t\n440\t    app.route(\"/rounds\", createRoundsRoutes({ db }));\n441\t  });\n442\t\n443\t  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n444\t    const wallet = creatorKeypair.publicKey.toBase58();\n445\t    const token = await makeJwt(wallet);\n446\t\n447\t    // ------------------------------------------------------------------\n448\t    // 1. POST /coinflip/create\n449\t    // ------------------------------------------------------------------\n450\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n451\t\n452\t    const createRes = await app.request(\"/coinflip/create\", {\n453\t      method: \"POST\",\n454\t      headers: {\n455\t        \"Content-Type\": \"application/json\",\n456\t        \"Authorization\": `Bearer ${token}`,\n457\t      },\n458\t      body: JSON.stringify(body),\n459\t    });\n460\t\n461\t    expect(createRes.status).toBe(200);\n462\t    const createJson = (await createRes.json()) as {\n463\t      transaction: string;\n464\t      matchPda: string;\n465\t      matchId: string;\n466\t      commitment: string;\n467\t      lastValidBlockHeight: number;\n468\t    };\n469\t    expect(createJson.transaction).toBeDefined();\n470\t    expect(createJson.matchPda).toBeDefined();\n471\t    expect(createJson.commitment).toBeDefined();\n472\t    expect(createJson.lastValidBlockHeight).toBeDefined();\n473\t\n474\t    const matchPda = createJson.matchPda;\n475\t    const commitmentHex = createJson.commitment;\n476\t    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n477\t\n478\t    // ------------------------------------------------------------------\n479\t    // 2. Verify DB state — round in \"created\" phase\n480\t    // ------------------------------------------------------------------\n481\t    const round = await db.getRoundByPda(matchPda);\n482\t    expect(round).toBeDefined();\n483\t    expect(round!.phase).toBe(\"created\");\n484\t    expect(round!.game).toBe(\"coinflip\");\n485\t    expect(round!.creator).toBe(wallet);\n486\t    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n487\t    expect(round!.side).toBe(SIDE_HEADS);\n488\t    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n489\t    expect(round!.secret).toBeDefined();\n490\t    expect(round!.secret.length).toBe(32);\n491\t\n492\t    // Verify operator event was logged\n493\t    const events =\n494\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n495\t    expect(events.length).toBe(1);\n496\t    expect(events[0]!.event_type).toBe(\"secret_generated\");\n497\t\n498\t    // ------------------------------------------------------------------\n499\t    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n500\t    // ------------------------------------------------------------------\n501\t    const matchPubkey = new PublicKey(matchPda);\n502\t    const targetSlot = 150n;\n503\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n504\t\n505\t    const matchAccountData = await buildMatchAccountData({\n506\t      creator: creatorKeypair.publicKey,\n507\t      opponent: opponentKeypair.publicKey,\n508\t      server: serverKeypair.publicKey,\n509\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n510\t      creatorSide: SIDE_HEADS,\n511\t      phase: PHASE_LOCKED,\n512\t      commitment: commitmentBuf,\n513\t      algorithmVer: 1,\n514\t      targetSlot,\n515\t      resolveDeadline,\n516\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n517\t    });\n518\t\n519\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n520\t      owner: COINFLIP_PROGRAM_ID,\n521\t    });\n522\t\n523\t    // Set current slot past target_slot so settlement triggers immediately\n524\t    mockConn.slot = 200;\n525\t\n526\t    // ------------------------------------------------------------------\n527\t    // 4. Create worker + retry settler, trigger poll\n528\t    // ------------------------------------------------------------------\n529\t    let settlePromise: Promise<void> | null = null;\n530\t\n531\t    const retrySettler = createRetrySettler({\n532\t      db,\n533\t      connection: mockConn as unknown as Connection,\n534\t      settleRound: (pda) =>\n535\t        settleMatch(\n536\t          {\n537\t            db,\n538\t            connection: mockConn as unknown as Connection,\n539\t            serverKeypair,\n540\t            entropyAccount,\n541\t            referralDefaultRateBps: 1000,\n542\t          },\n543\t          pda,\n544\t        ),\n545\t    });\n546\t\n547\t    const worker = createSettlementWorker({\n548\t      db,\n549\t      connection: mockConn as unknown as Connection,\n550\t      serverKey: serverKeypair.publicKey,\n551\t      pollIntervalMs: 60_000, // won't auto-poll\n552\t      onSettleReady: (pda) => {\n553\t        settlePromise = retrySettler.attemptSettle(pda);\n554\t        return settlePromise;\n555\t      },\n556\t    });\n557\t\n558\t    // Single poll cycle — should discover locked match and settle it\n559\t    await worker.poll();\n560\t    if (settlePromise) await settlePromise;\n561\t\n562\t    // ------------------------------------------------------------------\n563\t    // 5. Verify DB updated to \"settled\" with result data\n564\t    // ------------------------------------------------------------------\n565\t    const settled = await db.getRoundByPda(matchPda);\n566\t    expect(settled).toBeDefined();\n567\t    expect(settled!.phase).toBe(\"settled\");\n568\t    expect(settled!.settle_tx).toBeDefined();\n569\t    expect(settled!.result_hash).toBeDefined();\n570\t    expect(settled!.result_hash!.length).toBe(32);\n571\t    expect(settled!.result_side).toBeDefined();\n572\t    expect([0, 1]).toContain(settled!.result_side);\n573\t    expect(settled!.winner).toBeDefined();\n574\t\n575\t    // Winner should be one of the two players\n576\t    expect([\n577\t      creatorKeypair.publicKey.toBase58(),\n578\t      opponentKeypair.publicKey.toBase58(),\n579\t    ]).toContain(settled!.winner);\n580\t\n581\t    // Verify operator events trail\n582\t    const allEvents =\n583\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n584\t    const eventTypes = allEvents.map(\n585\t      (e) => (e as Record<string, unknown>).event_type,\n586\t    );\n587\t    expect(eventTypes).toContain(\"secret_generated\");\n588\t    expect(eventTypes).toContain(\"match_detected\");\n589\t    expect(eventTypes).toContain(\"settle_submitted\");\n590\t    expect(eventTypes).toContain(\"settle_confirmed\");\n591\t\n592\t    // ------------------------------------------------------------------\n593\t    // 6. GET /rounds/:pda — verify response includes secret\n594\t    // ------------------------------------------------------------------\n595\t    const roundsRes = await app.request(`/rounds/${matchPda}`);\n596\t    expect(roundsRes.status).toBe(200);\n597\t\n598\t    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n599\t    expect(roundsJson.pda).toBe(matchPda);\n600\t    expect(roundsJson.phase).toBe(\"settled\");\n601\t    expect(roundsJson.game).toBe(\"coinflip\");\n602\t    expect(roundsJson.creator).toBe(wallet);\n603\t    expect(roundsJson.commitment).toBe(commitmentHex);\n604\t\n605\t    // Settled round should include secret + verification payload\n606\t    expect(roundsJson.secret).toBeDefined();\n607\t    expect(typeof roundsJson.secret).toBe(\"string\");\n608\t    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n609\t    expect(roundsJson.resultHash).toBeDefined();\n610\t    expect(roundsJson.resultSide).toBeDefined();\n611\t    expect(roundsJson.winner).toBeDefined();\n612\t    expect(roundsJson.settleTx).toBeDefined();\n613\t\n614\t    // Verification object\n615\t    const verification = roundsJson.verification as Record<string, string>;\n616\t    expect(verification).toBeDefined();\n617\t    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n618\t    expect(verification.resultFormula).toContain(\"sha256(secret\");\n619\t    expect(verification.entropySource).toContain(\"SlotHashes\");\n620\t  });\n621\t\n622\t  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n623\t    const unknownPda = Keypair.generate().publicKey.toBase58();\n624\t    const res = await app.request(`/rounds/${unknownPda}`);\n625\t    expect(res.status).toBe(404);\n626\t  });\n627\t\n628\t  it(\"unsettled round does not expose secret\", async () => {\n629\t    const wallet = creatorKeypair.publicKey.toBase58();\n630\t    const token = await makeJwt(wallet);\n631\t\n632\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n633\t\n634\t    const res = await app.request(\"/coinflip/create\", {\n635\t      method: \"POST\",\n636\t      headers: {\n637\t        \"Content-Type\": \"application/json\",\n638\t        \"Authorization\": `Bearer ${token}`,\n639\t      },\n640\t      body: JSON.stringify(body),\n641\t    });\n642\t    expect(res.status).toBe(200);\n643\t    const json = (await res.json()) as { matchPda: string };\n644\t\n645\t    // GET the unsettled round\n646\t    const roundRes = await app.request(`/rounds/${json.matchPda}`);\n647\t    expect(roundRes.status).toBe(200);\n648\t    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n649\t    expect(roundJson.phase).toBe(\"created\");\n650\t    expect(roundJson.secret).toBeUndefined();\n651\t    expect(roundJson.resultHash).toBeUndefined();\n652\t    expect(roundJson.verification).toBeUndefined();\n653\t  });\n654\t\n655\t  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n656\t    const wallet = creatorKeypair.publicKey.toBase58();\n657\t    const token = await makeJwt(wallet);\n658\t\n659\t    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n660\t    const res1 = await app.request(\"/coinflip/create\", {\n661\t      method: \"POST\",\n662\t      headers: {\n663\t        \"Content-Type\": \"application/json\",\n664\t        \"Authorization\": `Bearer ${token}`,\n665\t      },\n666\t      body: JSON.stringify(body1),\n667\t    });\n668\t    expect(res1.status).toBe(200);\n669\t\n670\t    // Second request — different random matchId generated server-side\n671\t    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n672\t    const res2 = await app.request(\"/coinflip/create\", {\n673\t      method: \"POST\",\n674\t      headers: {\n675\t        \"Content-Type\": \"application/json\",\n676\t        \"Authorization\": `Bearer ${token}`,\n677\t      },\n678\t      body: JSON.stringify(body2),\n679\t    });\n680\t    expect(res2.status).toBe(200);\n681\t\n682\t    // Both should have different matchIds and PDAs\n683\t    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n684\t    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n685\t    expect(json1.matchPda).not.toBe(json2.matchPda);\n686\t    expect(json1.matchId).not.toBe(json2.matchId);\n687\t  });\n688\t\n689\t  it(\"settlement records referral earnings for referred player\", async () => {\n690\t    // Referrer is a third party; opponent is the referred player\n691\t    const referrerKeypair = Keypair.generate();\n692\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n693\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n694\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n695\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n696\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n697\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n698\t    const referrerUserId = referrerProfile.user_id;\n699\t    const opponentUserId = opponentProfile.user_id;"}]},"parent_tool_use_id":"toolu_017sWZHEt75rtcKF3tGqjVJe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"88a9f592-5a14-4a78-8a6c-4345a2421c86","timestamp":"2026-04-03T19:06:29.305Z"}
