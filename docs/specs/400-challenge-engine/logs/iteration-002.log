{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ADdijWxvmetN7AmvjUWG3Q","type":"tool_result","content":"1\t/* eslint-disable no-console */\n2\t/**\n3\t * Devnet E2E test for Close Call — player-initiated pari-mutuel flow.\n4\t *\n5\t * Tests use the backend API directly (not the UI) for the core lifecycle,\n6\t * with the wallet keypairs for signing transactions.\n7\t *\n8\t * Flow:\n9\t *   1. Setup — validate env, check wallets funded, check backend healthy\n10\t *   2. Player A bets GREEN via POST /closecall/bet, signs + submits tx\n11\t *   3. Player B bets RED via POST /closecall/bet, signs + submits tx\n12\t *   4. Wait for settlement (up to 120s)\n13\t *   5. Verify settlement outcome, closePrice, settleTx\n14\t *   6. Verify fairness results page via GET /rounds/by-id/:minuteTs\n15\t */\n16\timport { test, expect } from \"./fixtures\";\n17\timport {\n18\t  Connection,\n19\t  LAMPORTS_PER_SOL,\n20\t  PublicKey,\n21\t  Transaction,\n22\t} from \"@solana/web3.js\";\n23\timport type { Keypair } from \"@solana/web3.js\";\n24\timport { PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n25\timport {\n26\t  validateDevnetEnv,\n27\t  verifyFairnessBackend,\n28\t  type DevnetConfig,\n29\t} from \"./helpers/env\";\n30\timport { authenticate } from \"./helpers/auth\";\n31\t\n32\t// ── Constants ────────────────────────────────────────────────────────\n33\t\n34\tconst MIN_BALANCE_SOL = 0.1;\n35\t/** Wait up to 120s for settlement after candle close. */\n36\tconst SETTLEMENT_TIMEOUT_MS = 120_000;\n37\t/** Bet amount in lamports: 0.005 SOL. */\n38\tconst BET_AMOUNT_LAMPORTS = 5_000_000;\n39\t\n40\t// ── Types ────────────────────────────────────────────────────────────\n41\t\n42\tinterface BackendCloseCallRound {\n43\t  roundId: string;\n44\t  pda: string;\n45\t  phase: \"open\" | \"settled\" | \"refunded\";\n46\t  openPrice: number;\n47\t  openPriceExpo: number;\n48\t  closePrice: number | null;\n49\t  outcome: \"pending\" | \"green\" | \"red\" | \"refund\";\n50\t  greenPool: number;\n51\t  redPool: number;\n52\t  totalPool: number;\n53\t  totalFee: number;\n54\t  greenEntries: Array<{ player: string; amountLamports: number }>;\n55\t  redEntries: Array<{ player: string; amountLamports: number }>;\n56\t  greenCount: number;\n57\t  redCount: number;\n58\t  settleTx: string | null;\n59\t  createdAt: string;\n60\t  settledAt: string | null;\n61\t}\n62\t\n63\t// ── Backend API helpers ──────────────────────────────────────────────\n64\t\n65\tasync function fetchCurrentRound(\n66\t  config: DevnetConfig,\n67\t): Promise<BackendCloseCallRound | null> {\n68\t  const resp = await fetch(\n69\t    `${config.fairnessBackendUrl}/closecall/current-round`,\n70\t  );\n71\t  if (!resp.ok) return null;\n72\t  const data = (await resp.json()) as { round: BackendCloseCallRound | null };\n73\t  return data.round;\n74\t}\n75\t\n76\tasync function fetchHistory(\n77\t  config: DevnetConfig,\n78\t  limit = 5,\n79\t): Promise<BackendCloseCallRound[]> {\n80\t  const resp = await fetch(\n81\t    `${config.fairnessBackendUrl}/closecall/history?limit=${limit}`,\n82\t  );\n83\t  if (!resp.ok) return [];\n84\t  const data = (await resp.json()) as { rounds: BackendCloseCallRound[] };\n85\t  return data.rounds;\n86\t}\n87\t\n88\t/**\n89\t * Request a co-signed bet tx from the backend, deserialize it,\n90\t * sign with the player keypair, and submit to Solana.\n91\t */\n92\tasync function placeBetViaApi(\n93\t  config: DevnetConfig,\n94\t  connection: Connection,\n95\t  playerKeypair: Keypair,\n96\t  side: \"green\" | \"red\",\n97\t  amountLamports: number,\n98\t  accessToken: string,\n99\t): Promise<{ minuteTs: number; roundPda: string; signature: string }> {\n100\t  const resp = await fetch(`${config.fairnessBackendUrl}/closecall/bet`, {\n101\t    method: \"POST\",\n102\t    headers: {\n103\t      \"Content-Type\": \"application/json\",\n104\t      \"Authorization\": `Bearer ${accessToken}`,\n105\t    },\n106\t    body: JSON.stringify({\n107\t      playerPubkey: playerKeypair.publicKey.toBase58(),\n108\t      side,\n109\t      amountLamports,\n110\t    }),\n111\t  });\n112\t\n113\t  if (!resp.ok) {\n114\t    const body = await resp.json().catch(() => ({ error: \"unknown\" }));\n115\t    throw new Error(\n116\t      `POST /closecall/bet failed (${resp.status}): ${(body as { error?: string }).error ?? JSON.stringify(body)}`,\n117\t    );\n118\t  }\n119\t\n120\t  const data = (await resp.json()) as {\n121\t    transaction: string;\n122\t    minuteTs: number;\n123\t    roundPda: string;\n124\t  };\n125\t\n126\t  // Deserialize the partially-signed legacy transaction\n127\t  const txBuf = Buffer.from(data.transaction, \"base64\");\n128\t  const tx = Transaction.from(txBuf);\n129\t\n130\t  // Player signs their part\n131\t  tx.partialSign(playerKeypair);\n132\t\n133\t  // Submit to Solana\n134\t  const sig = await connection.sendRawTransaction(tx.serialize(), {\n135\t    skipPreflight: false,\n136\t  });\n137\t  const { blockhash, lastValidBlockHeight } =\n138\t    await connection.getLatestBlockhash();\n139\t  await connection.confirmTransaction(\n140\t    { signature: sig, blockhash, lastValidBlockHeight },\n141\t    \"confirmed\",\n142\t  );\n143\t\n144\t  return { minuteTs: data.minuteTs, roundPda: data.roundPda, signature: sig };\n145\t}\n146\t\n147\t/** Wait for a round to appear in history as settled/refunded. */\n148\tasync function waitForSettlement(\n149\t  config: DevnetConfig,\n150\t  roundId: string,"}]},"parent_tool_use_id":"toolu_012jf9LmiuJjw8ajAdHxfbKe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"3050c416-9ea3-4d9b-9448-cb096106e144","timestamp":"2026-04-03T19:01:56.631Z"}
