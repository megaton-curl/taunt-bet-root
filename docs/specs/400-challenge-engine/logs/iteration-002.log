ction makeSql() {\n39\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n40\t  // Dev container: postgres listens on Unix socket only\n41\t  return postgres({\n42\t    host: \"/var/run/postgresql\",\n43\t    user: \"vscode\",\n44\t    database: \"rng_utopia_dev\",\n45\t  });\n46\t}\n47\t\n48\tconst AMOUNT_LAMPORTS = 5_000_000;\n49\tconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n50\tconst SIDE_HEADS = 0;\n51\tconst PHASE_LOCKED = 1;\n52\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n53\t\n54\t// ---------------------------------------------------------------------------\n55\t// JWT helper\n56\t// ---------------------------------------------------------------------------\n57\t\n58\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n59\t  const now = Math.floor(Date.now() / 1000);\n60\t  return new SignJWT({ wallet })\n61\t    .setProtectedHeader({ alg: \"HS256\" })\n62\t    .setSubject(userId)\n63\t    .setIssuedAt(now)\n64\t    .setExpirationTime(now + 3600)\n65\t    .sign(JWT_SECRET);\n66\t}\n67\t\n68\tfunction userIdFromWallet(wallet: string) {\n69\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n70\t}\n71\t\n72\t// ---------------------------------------------------------------------------\n73\t// Mock Connection\n74\t// ---------------------------------------------------------------------------\n75\t\n76\t/**\n77\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n78\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n79\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n80\t */\n81\tclass MockConnection {"}]},"parent_tool_use_id":null,"session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"c397f148-7e31-4d1e-bc09-b4b69ae73427","timestamp":"2026-04-03T19:09:58.082Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests