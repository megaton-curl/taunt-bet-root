{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MiS8Pxw7Mw9NM1t1CvzsUM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KADX8FJaHkEvzcJgXgw4Rw","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","old_string":"    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n    // The first settle succeeded; a retry would be rejected by phase check before reaching\n    // the DB transaction. This test confirms the first call produces exactly 1 event.\n  });\n});","new_string":"    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n    // The first settle succeeded; a retry would be rejected by phase check before reaching\n    // the DB transaction. This test confirms the first call produces exactly 1 event.\n  });\n\n  it(\"closecall settlement emits game.settled event with correct payload shape\", async () => {\n    // Two players: one green, one red\n    const greenPlayer = Keypair.generate();\n    const redPlayer = Keypair.generate();\n    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());\n    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n\n    // Insert player profiles\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    // Create a round with minuteTs = 2 minutes ago (candle is closed)\n    const nowSec = Math.floor(Date.now() / 1000);\n    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n    const greenAmount = 5_000_000n;\n    const redAmount = 5_000_000n;\n    const openPrice = 69500_00n; // $69500.00 with expo -2\n\n    // Derive round PDA (seeds: [\"round\", minute_ts as LE i64, server pubkey])\n    const minuteTsBuf = Buffer.alloc(8);\n    minuteTsBuf.writeBigInt64LE(minuteTs);\n    const [roundPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n      CLOSECALL_PROGRAM_ID,\n    );\n\n    // Build on-chain round account data (phase=Open, with entries)\n    const roundAccountData = await encodeCloseCallRound({\n      minuteTs,\n      server: serverKeypair.publicKey,\n      phase: 0, // Open\n      greenEntries: [{ player: greenPlayer.publicKey, amountLamports: greenAmount }],\n      redEntries: [{ player: redPlayer.publicKey, amountLamports: redAmount }],\n      greenPool: greenAmount,\n      redPool: redAmount,\n      openPrice,\n      openPriceExpo: -2,\n      closePrice: 0n,\n      createdAt: minuteTs,\n      bettingEndsAt: minuteTs + 45n,\n      resolveDeadline: minuteTs + 300n,\n      outcome: 0, // Pending\n      totalFee: 0n,\n      bump: 0,\n    });\n\n    mockConn.setAccount(roundPda, roundAccountData, {\n      owner: CLOSECALL_PROGRAM_ID,\n    });\n\n    // Mock Hermes: returns a price > openPrice so outcome = green\n    const closePrice = 69600_00n; // $69600.00\n    const mockHermes: HermesFetcher = {\n      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n        price: closePrice,\n        expo: -2,\n        publishTime: Number(minuteTs) + 60, // after candle close\n        priceHuman: 69600.0,\n        vaaBase64: null,\n      }),\n    };\n\n    // Create clock worker with mock deps\n    const clock = createCloseCallClockWorker({\n      connection: mockConn as unknown as Connection,\n      serverKeypair,\n      db,\n      hermesFetcher: mockHermes,\n    });\n\n    // Call tick() — discovers the open round, captures boundary price, settles\n    await clock.tick();\n\n    // Verify game.settled event was emitted in event_queue\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n\n    const evt = events[0]!;\n    expect(evt.status).toBe(\"pending\");\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const payload = evt.payload as any;\n    expect(payload.roundId).toBe(String(Number(minuteTs)));\n    expect(payload.roundPda).toBe(roundPda.toBase58());\n    expect(payload.game).toBe(\"closecall\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n\n    // Players array — both players should be present\n    expect(payload.players).toHaveLength(2);\n    const greenP = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === greenPlayer.publicKey.toBase58(),\n    );\n    const redP = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === redPlayer.publicKey.toBase58(),\n    );\n    expect(greenP).toBeDefined();\n    expect(redP).toBeDefined();\n    expect(greenP.userId).toBe(greenUserId);\n    expect(redP.userId).toBe(redUserId);\n    // Amounts are string-encoded lamports\n    expect(greenP.amountLamports).toBe(String(greenAmount));\n    expect(redP.amountLamports).toBe(String(redAmount));\n    // Green wins (closePrice > openPrice)\n    expect(greenP.isWinner).toBe(true);\n    expect(redP.isWinner).toBe(false);\n    // Winner payout > 0, loser payout = \"0\"\n    expect(Number(greenP.payoutLamports)).toBeGreaterThan(0);\n    expect(redP.payoutLamports).toBe(\"0\");\n    // Fee = totalPool * 500 bps / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n    expect(payload.feeLamports).toBe(String(500_000));\n    // isCreator: first entry (green) is creator\n    expect(greenP.isCreator).toBe(true);\n    expect(redP.isCreator).toBe(false);\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":340,"cache_read_input_tokens":93728,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":340},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"dc0badda-df4c-4616-be5f-4f810931bf4a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KADX8FJaHkEvzcJgXgw4Rw","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"7d7ba149-aab1-4c41-9938-ed78f88e1fdc","timestamp":"2026-04-03T19:12:25.276Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","oldString":"    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n    // The first settle succeeded; a retry would be rejected by phase check before reaching\n    // the DB transaction. This test confirms the first call produces exactly 1 event.\n  });\n});","newString":"    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n    // The first settle succeeded; a retry would be rejected by phase check before reaching\n    // the DB transaction. This test confirms the first call produces exactly 1 event.\n  });\n\n  it(\"closecall settlement emits game.settled event with correct payload shape\", async () => {\n    // Two players: one green, one red\n    const greenPlayer = Keypair.generate();\n    const redPlayer = Keypair.generate();\n    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());\n    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n\n    // Insert player profiles\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    // Create a round with minuteTs = 2 minutes ago (candle is closed)\n    const nowSec = Math.floor(Date.now() / 1000);\n    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n    const greenAmount = 5_000_000n;\n    const redAmount = 5_000_000n;\n    const openPrice = 69500_00n; // $69500.00 with expo -2\n\n    // Derive round PDA (seeds: [\"round\", minute_ts as LE i64, server pubkey])\n    const minuteTsBuf = Buffer.alloc(8);\n    minuteTsBuf.writeBigInt64LE(minuteTs);\n    const [roundPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n      CLOSECALL_PROGRAM_ID,\n    );\n\n    // Build on-chain round account data (phase=Open, with entries)\n    const roundAccountData = await encodeCloseCallRound({\n      minuteTs,\n      server: serverKeypair.publicKey,\n      phase: 0, // Open\n      greenEntries: [{ player: greenPlayer.publicKey, amountLamports: greenAmount }],\n      redEntries: [{ player: redPlayer.publicKey, amountLamports: redAmount }],\n      greenPool: greenAmount,\n      redPool: redAmount,\n      openPrice,\n      openPriceExpo: -2,\n      closePrice: 0n,\n      createdAt: minuteTs,\n      bettingEndsAt: minuteTs + 45n,\n      resolveDeadline: minuteTs + 300n,\n      outcome: 0, // Pending\n      totalFee: 0n,\n      bump: 0,\n    });\n\n    mockConn.setAccount(roundPda, roundAccountData, {\n      owner: CLOSECALL_PROGRAM_ID,\n    });\n\n    // Mock Hermes: returns a price > openPrice so outcome = green\n    const closePrice = 69600_00n; // $69600.00\n    const mockHermes: HermesFetcher = {\n      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n        price: closePrice,\n        expo: -2,\n        publishTime: Number(minuteTs) + 60, // after candle close\n        priceHuman: 69600.0,\n        vaaBase64: null,\n      }),\n    };\n\n    // Create clock worker with mock deps\n    const clock = createCloseCallClockWorker({\n      connection: mockConn as unknown as Connection,\n      serverKeypair,\n      db,\n      hermesFetcher: mockHermes,\n    });\n\n    // Call tick() — discovers the open round, captures boundary price, settles\n    await clock.tick();\n\n    // Verify game.settled event was emitted in event_queue\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n\n    const evt = events[0]!;\n    expect(evt.status).toBe(\"pending\");\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const payload = evt.payload as any;\n    expect(payload.roundId).toBe(String(Number(minuteTs)));\n    expect(payload.roundPda).toBe(roundPda.toBase58());\n    expect(payload.game).toBe(\"closecall\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n\n    // Players array — both players should be present\n    expect(payload.players).toHaveLength(2);\n    const greenP = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === greenPlayer.publicKey.toBase58(),\n    );\n    const redP = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === redPlayer.publicKey.toBase58(),\n    );\n    expect(greenP).toBeDefined();\n    expect(redP).toBeDefined();\n    expect(greenP.userId).toBe(greenUserId);\n    expect(redP.userId).toBe(redUserId);\n    // Amounts are string-encoded lamports\n    expect(greenP.amountLamports).toBe(String(greenAmount));\n    expect(redP.amountLamports).toBe(String(redAmount));\n    // Green wins (closePrice > openPrice)\n    expect(greenP.isWinner).toBe(true);\n    expect(redP.isWinner).toBe(false);\n    // Winner payout > 0, loser payout = \"0\"\n    expect(Number(greenP.payoutLamports)).toBeGreaterThan(0);\n    expect(redP.payoutLamports).toBe(\"0\");\n    // Fee = totalPool * 500 bps / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n    expect(payload.feeLamports).toBe(String(500_000));\n    // isCreator: first entry (green) is creator\n    expect(greenP.isCreator).toBe(true);\n    expect(redP.isCreator).toBe(false);\n  });\n});","originalFile":"/**\n * Integration test: full create → join → settle lifecycle.\n *\n * Uses a mock Solana Connection to simulate on-chain state while exercising\n * the real HTTP endpoints, database, settlement worker, and retry logic\n * end-to-end. Auth uses JWT Bearer tokens (HS256).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"rng_utopia_dev\",\n  });\n}\n\nconst AMOUNT_LAMPORTS = 5_000_000;\nconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\nconst SIDE_HEADS = 0;\nconst PHASE_LOCKED = 1;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n\n// ---------------------------------------------------------------------------\n// JWT helper\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n// ---------------------------------------------------------------------------\n// Mock Connection\n// ---------------------------------------------------------------------------\n\n/**\n * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n */\nclass MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getSlot() {\n    return this._slot;\n  }\n\n  async getAccountInfo(pubkey: PublicKey) {\n    const acc = this._accounts.get(pubkey.toBase58());\n    if (!acc) return null;\n    return { ...acc, rentEpoch: 0 };\n  }\n\n  async getProgramAccounts(\n    programId: PublicKey,\n    config?: {\n      filters?: Array<\n        | { dataSize: number }\n        | { memcmp: { offset: number; bytes: string } }\n      >;\n    },\n  ) {\n    const results: Array<{\n      pubkey: PublicKey;\n      account: {\n        data: Buffer;\n        lamports: number;\n        owner: PublicKey;\n        executable: boolean;\n        rentEpoch: number;\n      };\n    }> = [];\n\n    for (const [key, acc] of this._accounts) {\n      if (!acc.owner.equals(programId)) continue;\n\n      let matches = true;\n      if (config?.filters) {\n        for (const filter of config.filters) {\n          if (\"dataSize\" in filter) {\n            if (acc.data.length !== filter.dataSize) {\n              matches = false;\n              break;\n            }\n          }\n          if (\"memcmp\" in filter) {\n            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n            const actual = acc.data.subarray(\n              filter.memcmp.offset,\n              filter.memcmp.offset + expected.length,\n            );\n            if (Buffer.compare(actual, expected) !== 0) {\n              matches = false;\n              break;\n            }\n          }\n        }\n      }\n\n      if (matches) {\n        results.push({\n          pubkey: new PublicKey(key),\n          account: { ...acc, rentEpoch: 0 },\n        });\n      }\n    }\n    return results;\n  }\n\n  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n    this.lastRawTx = Buffer.from(rawTx);\n    // Return a deterministic fake signature\n    return bs58.encode(Buffer.alloc(64, 0x01));\n  }\n\n  async confirmTransaction() {\n    return { value: { err: null }, context: { slot: this._slot } };\n  }\n\n  async getBlockTime(_slot: number) {\n    return Math.floor(Date.now() / 1000);\n  }\n\n  async getBalance() {\n    return 2 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Account data builders\n// ---------------------------------------------------------------------------\n\nasync function buildMatchAccountData(params: {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: Buffer;\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  matchId: Buffer;\n}): Promise<Buffer> {\n  return encodeCoinflipMatch({\n    creator: params.creator,\n    opponent: params.opponent,\n    server: params.server,\n    entryAmount: params.entryAmount,\n    creatorSide: params.creatorSide,\n    phase: params.phase,\n    commitment: [...params.commitment],\n    algorithmVer: params.algorithmVer,\n    targetSlot: params.targetSlot,\n    resolveDeadline: params.resolveDeadline,\n    resultHash: new Array(32).fill(0),\n    result: 0,\n    winner: PublicKey.default,\n    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n    matchId: [...params.matchId],\n    bump: 0,\n  });\n}\n\nasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n  return encodeCoinflipConfig({\n    authority: PublicKey.default,\n    treasury,\n    paused: false,\n    bump: 0,\n  });\n}\n\n/**\n * Build PlatformConfig account data matching the on-chain layout.\n * Layout: 8-byte discriminator + 32-byte authority + 32-byte treasury + 2-byte fee_bps (u16 LE)\n */\nfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n  const buf = Buffer.alloc(74);\n  // discriminator (8 bytes) — zeroed is fine for mock\n  // authority at offset 8 — use default\n  PublicKey.default.toBuffer().copy(buf, 8);\n  // treasury at offset 40\n  treasury.toBuffer().copy(buf, 40);\n  // fee_bps at offset 72\n  buf.writeUInt16LE(feeBps, 72);\n  return buf;\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Integration: create → join → settle lifecycle\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    await rawSql`\n      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n    `;\n    await rawSql`\n      CREATE TABLE referral_codes (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id TEXT NOT NULL UNIQUE,\n        wallet TEXT NOT NULL UNIQUE,\n        code TEXT NOT NULL UNIQUE,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE referral_links (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL UNIQUE,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_earnings (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        round_id TEXT NOT NULL,\n        game_type TEXT NOT NULL,\n        wager_lamports BIGINT NOT NULL,\n        fee_lamports BIGINT NOT NULL,\n        referrer_earned_lamports BIGINT NOT NULL,\n        referrer_rate_bps INTEGER NOT NULL,\n        referee_rebate_lamports BIGINT NOT NULL,\n        referee_rebate_rate_bps INTEGER NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_claims (\n        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        amount_lamports BIGINT NOT NULL,\n        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n        retry_count INTEGER NOT NULL DEFAULT 0,\n        tx_signature TEXT,\n        error TEXT,\n        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        processed_at TIMESTAMPTZ\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n    `;\n    await rawSql`\n      CREATE TABLE referral_kol_rates (\n        user_id TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL UNIQUE,\n        rate_bps INTEGER NOT NULL,\n        set_by TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean tables for isolation\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates RESTART IDENTITY CASCADE`;\n\n    // Reset PlatformConfig cache so each test reads from its own mock\n    resetPlatformConfigCache();\n\n    // Fresh mock Connection\n    mockConn = new MockConnection();\n\n    // Pre-populate mock with entropy and config accounts\n    mockConn.setAccount(entropyAccount, entropyData);\n\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"coinflip_config\")],\n      COINFLIP_PROGRAM_ID,\n    );\n    mockConn.setAccount(\n      configPda,\n      await buildConfigAccountData(treasuryKeypair.publicKey),\n      { owner: COINFLIP_PROGRAM_ID },\n    );\n\n    // PlatformConfig account — settlement reads fee_bps from here\n    const [platformConfigPda] = derivePlatformConfigPda();\n    mockConn.setAccount(\n      platformConfigPda,\n      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n      { owner: PLATFORM_PROGRAM_ID },\n    );\n\n    // Build the Hono app (no rate limiting for tests)\n    app = new Hono();\n\n    app.use(\n      \"/coinflip/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n\n    app.route(\n      \"/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/rounds\", createRoundsRoutes({ db }));\n  });\n\n  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    // ------------------------------------------------------------------\n    // 1. POST /coinflip/create\n    // ------------------------------------------------------------------\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      transaction: string;\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n      lastValidBlockHeight: number;\n    };\n    expect(createJson.transaction).toBeDefined();\n    expect(createJson.matchPda).toBeDefined();\n    expect(createJson.commitment).toBeDefined();\n    expect(createJson.lastValidBlockHeight).toBeDefined();\n\n    const matchPda = createJson.matchPda;\n    const commitmentHex = createJson.commitment;\n    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n\n    // ------------------------------------------------------------------\n    // 2. Verify DB state — round in \"created\" phase\n    // ------------------------------------------------------------------\n    const round = await db.getRoundByPda(matchPda);\n    expect(round).toBeDefined();\n    expect(round!.phase).toBe(\"created\");\n    expect(round!.game).toBe(\"coinflip\");\n    expect(round!.creator).toBe(wallet);\n    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n    expect(round!.side).toBe(SIDE_HEADS);\n    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n    expect(round!.secret).toBeDefined();\n    expect(round!.secret.length).toBe(32);\n\n    // Verify operator event was logged\n    const events =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n    expect(events.length).toBe(1);\n    expect(events[0]!.event_type).toBe(\"secret_generated\");\n\n    // ------------------------------------------------------------------\n    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n    // ------------------------------------------------------------------\n    const matchPubkey = new PublicKey(matchPda);\n    const targetSlot = 150n;\n    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot,\n      resolveDeadline,\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n\n    // Set current slot past target_slot so settlement triggers immediately\n    mockConn.slot = 200;\n\n    // ------------------------------------------------------------------\n    // 4. Create worker + retry settler, trigger poll\n    // ------------------------------------------------------------------\n    let settlePromise: Promise<void> | null = null;\n\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000, // won't auto-poll\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    // Single poll cycle — should discover locked match and settle it\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    // ------------------------------------------------------------------\n    // 5. Verify DB updated to \"settled\" with result data\n    // ------------------------------------------------------------------\n    const settled = await db.getRoundByPda(matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n    expect(settled!.settle_tx).toBeDefined();\n    expect(settled!.result_hash).toBeDefined();\n    expect(settled!.result_hash!.length).toBe(32);\n    expect(settled!.result_side).toBeDefined();\n    expect([0, 1]).toContain(settled!.result_side);\n    expect(settled!.winner).toBeDefined();\n\n    // Winner should be one of the two players\n    expect([\n      creatorKeypair.publicKey.toBase58(),\n      opponentKeypair.publicKey.toBase58(),\n    ]).toContain(settled!.winner);\n\n    // Verify operator events trail\n    const allEvents =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n    const eventTypes = allEvents.map(\n      (e) => (e as Record<string, unknown>).event_type,\n    );\n    expect(eventTypes).toContain(\"secret_generated\");\n    expect(eventTypes).toContain(\"match_detected\");\n    expect(eventTypes).toContain(\"settle_submitted\");\n    expect(eventTypes).toContain(\"settle_confirmed\");\n\n    // ------------------------------------------------------------------\n    // 6. GET /rounds/:pda — verify response includes secret\n    // ------------------------------------------------------------------\n    const roundsRes = await app.request(`/rounds/${matchPda}`);\n    expect(roundsRes.status).toBe(200);\n\n    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n    expect(roundsJson.pda).toBe(matchPda);\n    expect(roundsJson.phase).toBe(\"settled\");\n    expect(roundsJson.game).toBe(\"coinflip\");\n    expect(roundsJson.creator).toBe(wallet);\n    expect(roundsJson.commitment).toBe(commitmentHex);\n\n    // Settled round should include secret + verification payload\n    expect(roundsJson.secret).toBeDefined();\n    expect(typeof roundsJson.secret).toBe(\"string\");\n    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n    expect(roundsJson.resultHash).toBeDefined();\n    expect(roundsJson.resultSide).toBeDefined();\n    expect(roundsJson.winner).toBeDefined();\n    expect(roundsJson.settleTx).toBeDefined();\n\n    // Verification object\n    const verification = roundsJson.verification as Record<string, string>;\n    expect(verification).toBeDefined();\n    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n    expect(verification.resultFormula).toContain(\"sha256(secret\");\n    expect(verification.entropySource).toContain(\"SlotHashes\");\n  });\n\n  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n    const unknownPda = Keypair.generate().publicKey.toBase58();\n    const res = await app.request(`/rounds/${unknownPda}`);\n    expect(res.status).toBe(404);\n  });\n\n  it(\"unsettled round does not expose secret\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n\n    const res = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { matchPda: string };\n\n    // GET the unsettled round\n    const roundRes = await app.request(`/rounds/${json.matchPda}`);\n    expect(roundRes.status).toBe(200);\n    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n    expect(roundJson.phase).toBe(\"created\");\n    expect(roundJson.secret).toBeUndefined();\n    expect(roundJson.resultHash).toBeUndefined();\n    expect(roundJson.verification).toBeUndefined();\n  });\n\n  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const res1 = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body1),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second request — different random matchId generated server-side\n    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const res2 = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body2),\n    });\n    expect(res2.status).toBe(200);\n\n    // Both should have different matchIds and PDAs\n    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n    expect(json1.matchPda).not.toBe(json2.matchPda);\n    expect(json1.matchId).not.toBe(json2.matchId);\n  });\n\n  it(\"settlement records referral earnings for referred player\", async () => {\n    // Referrer is a third party; opponent is the referred player\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n    const referrerUserId = referrerProfile.user_id;\n    const opponentUserId = opponentProfile.user_id;\n    const creatorUserId = creatorProfile.user_id;\n\n    // Set up referral link: referrer → opponent (opponent is the referee)\n    await db.insertReferralCode(referrerUserId, referrerWallet, \"test-ref\");\n    await db.insertReferralLink({\n      referrerUserId,\n      refereeUserId: opponentUserId,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n\n    // 1. Create a coinflip match\n    const token = await makeJwt(creatorWallet, creatorUserId);\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    // 2. Simulate on-chain join (opponent joins the match)\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n    const targetSlot = 150n;\n    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot,\n      resolveDeadline,\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    // 3. Settle the match\n    let settlePromise: Promise<void> | null = null;\n\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    // 4. Verify match settled\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n\n    // 5. Verify referral earnings recorded for the opponent (the referee)\n    // Expected: wager=5_000_000, fee=5_000_000*500/10_000=250_000\n    //           referrer_earned=250_000*1000/10_000=25_000\n    //           referee_rebate=250_000*1000/10_000=25_000\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n    expect(earnings.length).toBe(1);\n\n    const earning = earnings[0]!;\n    expect(earning.referrer_user_id).toBe(referrerUserId);\n    expect(earning.referee_user_id).toBe(opponentUserId);\n    expect(earning.referrer_wallet).toBe(referrerWallet);\n    expect(earning.referee_wallet).toBe(opponentWallet);\n    expect(earning.round_id).toBe(createJson.matchId);\n    expect(earning.game_type).toBe(\"coinflip\");\n    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS); // 5_000_000\n    expect(Number(earning.fee_lamports)).toBe(250_000); // 5_000_000 * 500 / 10_000\n    expect(Number(earning.referrer_earned_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n\n    // Creator is NOT referred, so no earnings for creator\n    const creatorEarnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${creatorUserId}`;\n    expect(creatorEarnings.length).toBe(0);\n  });\n\n  it(\"settlement uses KOL custom rate for referrer earnings\", async () => {\n    // Referrer has a KOL rate of 2000 bps (20% of fee)\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n    const referrerUserId = referrerProfile.user_id;\n    const opponentUserId = opponentProfile.user_id;\n\n    // Set up referral link + KOL rate override\n    await db.insertReferralCode(referrerUserId, referrerWallet, \"kol-code\");\n    await db.insertReferralLink({\n      referrerUserId,\n      refereeUserId: opponentUserId,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n    await rawSql`INSERT INTO referral_kol_rates (user_id, wallet, rate_bps, set_by) VALUES (${referrerUserId}, ${referrerWallet}, 2000, 'admin')`;\n\n    // Create + settle a coinflip match\n    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise2: Promise<void> | null = null;\n\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise2 = retrySettler.attemptSettle(pda);\n        return settlePromise2;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise2) await settlePromise2;\n\n    // Verify settlement completed\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled!.phase).toBe(\"settled\");\n\n    // Verify KOL rate was used for referrer earning\n    // fee = 5_000_000 * 500 / 10_000 = 250_000\n    // referrer_earned = 250_000 * 2000 / 10_000 = 50_000 (KOL rate)\n    // referee_rebate = 250_000 * 1000 / 10_000 = 25_000 (always fixed 10%)\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentUserId}`;\n    expect(earnings.length).toBe(1);\n\n    const earning = earnings[0]!;\n    expect(Number(earning.referrer_earned_lamports)).toBe(50_000); // KOL: 2000 bps\n    expect(Number(earning.referrer_rate_bps)).toBe(2000);\n    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // Fixed 10%\n    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n  });\n\n  it(\"settlement emits game.settled event with correct payload shape\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    // Create profiles for both players so game entries + event payloads get user IDs\n    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    // Create round via API\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    // Simulate on-chain join — LOCKED match in mock\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n\n    // Transition DB round to \"locked\" (normally the settlement worker does this on join detection)\n    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n\n    // Settle directly\n    await settleMatch(\n      {\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n        entropyAccount,\n        referralDefaultRateBps: 1000,\n      },\n      createJson.matchPda,\n    );\n\n    // Verify game.settled event was emitted in event_queue\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n\n    const evt = events[0]!;\n    expect(evt.status).toBe(\"pending\");\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const payload = evt.payload as any;\n    expect(payload.roundId).toBe(createJson.matchId);\n    expect(payload.roundPda).toBe(createJson.matchPda);\n    expect(payload.game).toBe(\"coinflip\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n\n    // Players array\n    expect(payload.players).toHaveLength(2);\n    const creator = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === creatorKeypair.publicKey.toBase58(),\n    );\n    const opponent = payload.players.find(\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      (p: any) => p.wallet === opponentKeypair.publicKey.toBase58(),\n    );\n    expect(creator).toBeDefined();\n    expect(opponent).toBeDefined();\n    expect(creator.isCreator).toBe(true);\n    expect(opponent.isCreator).toBe(false);\n    expect(creator.userId).toBe(creatorUserId);\n    expect(opponent.userId).toBe(opponentUserId);\n    // Amounts are string-encoded lamports\n    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n    // Exactly one winner\n    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n    // Winner has payoutLamports > 0, loser has \"0\"\n    const winnerPlayer = creator.isWinner ? creator : opponent;\n    const loserPlayer = creator.isWinner ? opponent : creator;\n    expect(Number(winnerPlayer.payoutLamports)).toBeGreaterThan(0);\n    expect(loserPlayer.payoutLamports).toBe(\"0\");\n    // Fee = pool * 500 / 10000 = 10_000_000 * 500 / 10_000 = 500_000\n    expect(payload.feeLamports).toBe(String(500_000));\n  });\n\n  it(\"duplicate settlement retry produces duplicate game.settled event rows safely\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const createRes = await app.request(\"/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const commitmentBuf = Buffer.from(createJson.commitment, \"hex\");\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n\n    // Transition DB round to \"locked\"\n    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n\n    // First settle\n    await settleMatch(\n      {\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n        entropyAccount,\n        referralDefaultRateBps: 1000,\n      },\n      createJson.matchPda,\n    );\n\n    // Second settle attempt — should fail on phase check (already settled),\n    // but the first call already produced the event. Verify 1 event row exists.\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n\n    // The spec says \"Duplicate settlement retries may enqueue duplicate game.settled rows safely\n    // because downstream handlers dedupe on domain keys, not event_queue.id\"\n    // The event_queue table has no UNIQUE constraint on payload — duplicates are safe.\n    // The first settle succeeded; a retry would be rejected by phase check before reaching\n    // the DB transaction. This test confirms the first call produces exactly 1 event.\n  });\n});\n","structuredPatch":[{"oldStart":1136,"oldLines":4,"newStart":1136,"newLines":132,"lines":["     // The first settle succeeded; a retry would be rejected by phase check before reaching","     // the DB transaction. This test confirms the first call produces exactly 1 event.","   });","+","+  it(\"closecall settlement emits game.settled event with correct payload shape\", async () => {","+    // Two players: one green, one red","+    const greenPlayer = Keypair.generate();","+    const redPlayer = Keypair.generate();","+    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());","+    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());","+","+    // Insert player profiles","+    await rawSql`","+      INSERT INTO player_profiles (user_id, wallet, username)","+      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')","+      ON CONFLICT (user_id) DO NOTHING","+    `;","+    await rawSql`","+      INSERT INTO player_profiles (user_id, wallet, username)","+      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')","+      ON CONFLICT (user_id) DO NOTHING","+    `;","+","+    // Create a round with minuteTs = 2 minutes ago (candle is closed)","+    const nowSec = Math.floor(Date.now() / 1000);","+    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);","+    const greenAmount = 5_000_000n;","+    const redAmount = 5_000_000n;","+    const openPrice = 69500_00n; // $69500.00 with expo -2","+","+    // Derive round PDA (seeds: [\"round\", minute_ts as LE i64, server pubkey])","+    const minuteTsBuf = Buffer.alloc(8);","+    minuteTsBuf.writeBigInt64LE(minuteTs);","+    const [roundPda] = PublicKey.findProgramAddressSync(","+      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],","+      CLOSECALL_PROGRAM_ID,","+    );","+","+    // Build on-chain round account data (phase=Open, with entries)","+    const roundAccountData = await encodeCloseCallRound({","+      minuteTs,","+      server: serverKeypair.publicKey,","+      phase: 0, // Open","+      greenEntries: [{ player: greenPlayer.publicKey, amountLamports: greenAmount }],","+      redEntries: [{ player: redPlayer.publicKey, amountLamports: redAmount }],","+      greenPool: greenAmount,","+      redPool: redAmount,","+      openPrice,","+      openPriceExpo: -2,","+      closePrice: 0n,","+      createdAt: minuteTs,","+      bettingEndsAt: minuteTs + 45n,","+      resolveDeadline: minuteTs + 300n,","+      outcome: 0, // Pending","+      totalFee: 0n,","+      bump: 0,","+    });","+","+    mockConn.setAccount(roundPda, roundAccountData, {","+      owner: CLOSECALL_PROGRAM_ID,","+    });","+","+    // Mock Hermes: returns a price > openPrice so outcome = green","+    const closePrice = 69600_00n; // $69600.00","+    const mockHermes: HermesFetcher = {","+      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({","+        price: closePrice,","+        expo: -2,","+        publishTime: Number(minuteTs) + 60, // after candle close","+        priceHuman: 69600.0,","+        vaaBase64: null,","+      }),","+    };","+","+    // Create clock worker with mock deps","+    const clock = createCloseCallClockWorker({","+      connection: mockConn as unknown as Connection,","+      serverKeypair,","+      db,","+      hermesFetcher: mockHermes,","+    });","+","+    // Call tick() — discovers the open round, captures boundary price, settles","+    await clock.tick();","+","+    // Verify game.settled event was emitted in event_queue","+    const events = await rawSql`","+      SELECT * FROM event_queue WHERE event_type = 'game.settled'","+    `;","+    expect(events.length).toBe(1);","+","+    const evt = events[0]!;","+    expect(evt.status).toBe(\"pending\");","+","+    // eslint-disable-next-line @typescript-eslint/no-explicit-any","+    const payload = evt.payload as any;","+    expect(payload.roundId).toBe(String(Number(minuteTs)));","+    expect(payload.roundPda).toBe(roundPda.toBase58());","+    expect(payload.game).toBe(\"closecall\");","+    expect(payload.feeLamports).toBeDefined();","+    expect(payload.settledAt).toBeDefined();","+","+    // Players array — both players should be present","+    expect(payload.players).toHaveLength(2);","+    const greenP = payload.players.find(","+      // eslint-disable-next-line @typescript-eslint/no-explicit-any","+      (p: any) => p.wallet === greenPlayer.publicKey.toBase58(),","+    );","+    const redP = payload.players.find(","+      // eslint-disable-next-line @typescript-eslint/no-explicit-any","+      (p: any) => p.wallet === redPlayer.publicKey.toBase58(),","+    );","+    expect(greenP).toBeDefined();","+    expect(redP).toBeDefined();","+    expect(greenP.userId).toBe(greenUserId);","+    expect(redP.userId).toBe(redUserId);","+    // Amounts are string-encoded lamports","+    expect(greenP.amountLamports).toBe(String(greenAmount));","+    expect(redP.amountLamports).toBe(String(redAmount));","+    // Green wins (closePrice > openPrice)","+    expect(greenP.isWinner).toBe(true);","+    expect(redP.isWinner).toBe(false);","+    // Winner payout > 0, loser payout = \"0\"","+    expect(Number(greenP.payoutLamports)).toBeGreaterThan(0);","+    expect(redP.payoutLamports).toBe(\"0\");","+    // Fee = totalPool * 500 bps / 10000 = 10_000_000 * 500 / 10_000 = 500_000","+    expect(payload.feeLamports).toBe(String(500_000));","+    // isCreator: first entry (green) is creator","+    expect(greenP.isCreator).toBe(true);","+    expect(redP.isCreator).toBe(false);","+  });"," });"]}],"userModified":false,"replaceAll":false}}
