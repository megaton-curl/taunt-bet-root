{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0161tZ9WWGGPFTfKbVx4djRj","type":"tool_result","content":"1\tuse anchor_lang::prelude::*;\n2\t\n3\t/// Betting side in Close Call.\n4\t#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\n5\tpub enum BetSide {\n6\t    Green,\n7\t    Red,\n8\t}\n9\t\n10\t/// Round lifecycle phase.\n11\t#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\n12\tpub enum CloseCallPhase {\n13\t    /// Round is open for bets (first 30s of candle).\n14\t    Open,\n15\t    /// Outcome determined, payouts distributed.\n16\t    Settled,\n17\t    /// All bets refunded (invalid round, timeout, or force close).\n18\t    Refunded,\n19\t}\n20\t\n21\t/// Settlement outcome.\n22\t#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\n23\tpub enum Outcome {\n24\t    Pending,\n25\t    Green,\n26\t    Red,\n27\t    Refund,\n28\t}\n29\t\n30\t/// A single bet entry.\n31\t#[derive(AnchorSerialize, AnchorDeserialize, Clone, Debug, InitSpace)]\n32\tpub struct BetEntry {\n33\t    pub player: Pubkey,\n34\t    pub amount_lamports: u64,\n35\t}\n36\t\n37\t/// Global configuration for the Close Call program.\n38\t/// PDA seeds: [b\"closecall_config\"]\n39\t///\n40\t/// Fee destination and fee rate are read from PlatformConfig at settlement time.\n41\t#[account]\n42\t#[derive(InitSpace)]\n43\tpub struct CloseCallConfig {\n44\t    /// Admin authority (can update config, force close).\n45\t    pub authority: Pubkey,\n46\t    /// Pyth price feed ID for BTC/USD (32 bytes).\n47\t    pub pyth_feed_id: [u8; 32],\n48\t    /// Betting window duration in seconds (default 30).\n49\t    pub betting_window_secs: u32,\n50\t    /// Maximum entries per side (default 32).\n51\t    pub max_entries_per_side: u8,\n52\t    /// Whether the game is paused.\n53\t    pub paused: bool,\n54\t    /// Bump seed for PDA derivation.\n55\t    pub bump: u8,\n56\t}\n57\t\n58\t/// A Close Call round.\n59\t/// PDA seeds: [b\"cc_round\", &minute_ts.to_le_bytes()]\n60\t#[account]\n61\t#[derive(InitSpace)]\n62\tpub struct CloseCallRound {\n63\t    /// Minute-aligned Unix timestamp (e.g., 1773836280).\n64\t    /// Used as PDA seed — guarantees one round per minute.\n65\t    pub minute_ts: i64,\n66\t    /// Server wallet that paid rent and will settle.\n67\t    pub server: Pubkey,\n68\t    /// Current phase.\n69\t    pub phase: CloseCallPhase,\n70\t\n71\t    /// Green (bull) entries.\n72\t    #[max_len(32)]\n73\t    pub green_entries: Vec<BetEntry>,\n74\t    /// Red (bear) entries.\n75\t    #[max_len(32)]\n76\t    pub red_entries: Vec<BetEntry>,\n77\t    /// Total lamports in green pool.\n78\t    pub green_pool: u64,\n79\t    /// Total lamports in red pool.\n80\t    pub red_pool: u64,\n81\t\n82\t    /// Pyth open price at round creation (scaled integer).\n83\t    pub open_price: i64,\n84\t    /// Pyth price exponent at round creation.\n85\t    pub open_price_expo: i32,\n86\t    /// Pyth close price at settlement (0 until settled).\n87\t    pub close_price: i64,\n88\t\n89\t    /// Unix timestamp when round was created.\n90\t    pub created_at: i64,\n91\t    /// Unix timestamp when betting window closes.\n92\t    pub betting_ends_at: i64,\n93\t    /// Unix timestamp after which timeout_refund is available.\n94\t    pub resolve_deadline: i64,\n95\t\n96\t    /// Settlement outcome.\n97\t    pub outcome: Outcome,\n98\t    /// Fee collected (0 for refund rounds).\n99\t    pub total_fee: u64,\n100\t    /// Bump seed for PDA derivation.\n101\t    pub bump: u8,\n102\t}\n103\t\n104\t/// Event emitted when a player places a bet.\n105\t#[event]\n106\tpub struct BetPlaced {\n107\t    pub minute_ts: i64,\n108\t    pub player: Pubkey,\n109\t    pub side: u8,\n110\t    pub amount: u64,\n111\t}\n112\t\n113\t/// Event emitted when a round is refunded (timeout or force close).\n114\t#[event]\n115\tpub struct RoundRefunded {\n116\t    pub minute_ts: i64,\n117\t    pub player_count: u32,\n118\t}\n119\t\n120\t/// Event emitted when a round is settled.\n121\t#[event]\n122\tpub struct RoundSettled {\n123\t    pub minute_ts: i64,\n124\t    pub outcome: Outcome,\n125\t    pub open_price: i64,\n126\t    pub close_price: i64,\n127\t    pub green_pool: u64,\n128\t    pub red_pool: u64,\n129\t    pub total_fee: u64,\n130\t    pub num_winners: u8,\n131\t}\n132\t"}]},"parent_tool_use_id":"toolu_017sWZHEt75rtcKF3tGqjVJe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"863dd2c1-dd98-4f9c-90de-c22c8ce77903","timestamp":"2026-04-03T19:06:26.866Z"}
