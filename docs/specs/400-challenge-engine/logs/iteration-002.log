{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WJ1qTcgCjxPN1K3AevdgKq","type":"tool_result","content":"0\t/**\n1\t * Close Call clock worker — precise minute-boundary price capture + settlement.\n2\t *\n3\t * Scheduling:\n4\t *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n5\t *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n6\t *   - Caches the boundary price (both close of old candle, open of next)\n7\t *   - Settles any open rounds whose candle has closed\n8\t *   - Schedules next tick at (next minute + 1s)\n9\t *\n10\t * Rounds are created on-demand by the first bettor (via /closecall/bet).\n11\t * On start, loads the latest boundary price from DB to seed the cache.\n12\t */\n13\t\n14\timport { performance } from \"node:perf_hooks\";\n15\timport {\n16\t  Connection,\n17\t  Keypair,\n18\t  PublicKey,\n19\t  Transaction,\n20\t} from \"@solana/web3.js\";\n21\timport type { Db } from \"../db.js\";\n22\timport { logger } from \"../logger.js\";\n23\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n24\timport { getPlatformConfig } from \"../platform-config.js\";\n25\timport {\n26\t  buildCloseCallSettleRoundIx,\n27\t} from \"./settle-tx.js\";\n28\timport { emitEvent } from \"../queue/emit-event.js\";\n29\timport { EventTypes } from \"../queue/event-types.js\";\n30\timport {\n31\t  closeCallRoundDiscriminatorFilter,\n32\t  decodeCloseCallRound,\n33\t} from \"./account-decoder.js\";\n34\timport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n35\t\n36\t/** Close Call on-chain phase values */\n37\tconst PHASE_OPEN = 0;\n38\t\n39\t/** How long to wait after minute boundary before first Hermes poll (ms). */\n40\tconst BOUNDARY_OFFSET_MS = 1_000;\n41\t\n42\t/** Poll Hermes every 1s when waiting for boundary price. */\n43\tconst HERMES_POLL_INTERVAL_MS = 1_000;\n44\t\n45\t/** Max attempts to fetch a fresh boundary price (10s total). */\n46\tconst HERMES_MAX_RETRIES = 10;\n47\t\n48\t/** Maximum retry attempts for a single tx submission. */\n49\tconst MAX_TX_RETRIES = 3;\n50\tconst TX_RETRY_DELAY_MS = 2_000;\n51\t\n52\t// ---------------------------------------------------------------------------\n53\t// Types\n54\t// ---------------------------------------------------------------------------\n55\t\n56\texport interface BoundaryPrice {\n57\t  price: bigint;\n58\t  expo: number;\n59\t  minuteTs: number;"}]},"parent_tool_use_id":null,"session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"6f36bbb0-9653-4a78-98e4-728d6a2f0a16","timestamp":"2026-04-03T19:05:08.666Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/worker/closecall-clock.ts","content":"/**\n * Close Call clock worker — precise minute-boundary price capture + settlement.\n *\n * Scheduling:\n *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n *   - Caches the boundary price (both close of old candle, open of next)\n *   - Settles any open rounds whose candle has closed\n *   - Schedules next tick at (next minute + 1s)\n *\n * Rounds are created on-demand by the first bettor (via /closecall/bet).\n * On start, loads the latest boundary price from DB to seed the cache.\n */\n\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { getPlatformConfig } from \"../platform-config.js\";\nimport {\n  buildCloseCallSettleRoundIx,\n} from \"./settle-tx.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport {\n  closeCallRoundDiscriminatorFilter,\n  decodeCloseCallRound,\n} from \"./account-decoder.js\";\nimport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n\n/** Close Call on-chain phase values */\nconst PHASE_OPEN = 0;\n\n/** How long to wait after minute boundary before first Hermes poll (ms). */\nconst BOUNDARY_OFFSET_MS = 1_000;\n\n/** Poll Hermes every 1s when waiting for boundary price. */\nconst HERMES_POLL_INTERVAL_MS = 1_000;\n\n/** Max attempts to fetch a fresh boundary price (10s total). */\nconst HERMES_MAX_RETRIES = 10;\n\n/** Maximum retry attempts for a single tx submission. */\nconst MAX_TX_RETRIES = 3;\nconst TX_RETRY_DELAY_MS = 2_000;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface BoundaryPrice {\n  price: bigint;\n  expo: number;\n  minuteTs: number;","numLines":60,"startLine":0,"totalLines":727}}}
