{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015ocHPMCv5XgCkfaoroAvdY","type":"tool_result","content":"1\t/**\n2\t * Platform config reader — fetches fee_bps and treasury from the on-chain\n3\t * PlatformConfig account (owned by the platform program).\n4\t *\n5\t * Used by all settlement paths (coinflip, lord, closecall) so fee calculation\n6\t * and treasury routing come from a single authoritative source.\n7\t */\n8\t\n9\timport { Connection, PublicKey } from \"@solana/web3.js\";\n10\timport { PlatformIDL } from \"@taunt-bet/anchor-client\";\n11\t\n12\texport const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n13\t\n14\t/**\n15\t * Derive the PlatformConfig PDA.\n16\t * Seeds: [\"platform_config\"]\n17\t */\n18\texport function derivePlatformConfigPda(): [PublicKey, number] {\n19\t  return PublicKey.findProgramAddressSync(\n20\t    [Buffer.from(\"platform_config\")],\n21\t    PLATFORM_PROGRAM_ID,\n22\t  );\n23\t}\n24\t\n25\t/**\n26\t * Fetch PlatformConfig directly from on-chain account data.\n27\t *\n28\t * Account layout (after 8-byte Anchor discriminator):\n29\t *   offset  0..8   discriminator\n30\t *   offset  8..40  authority (Pubkey, 32 bytes)\n31\t *   offset 40..72  treasury  (Pubkey, 32 bytes)\n32\t *   offset 72..74  fee_bps   (u16 LE)\n33\t */\n34\texport async function fetchPlatformConfig(\n35\t  connection: Connection,\n36\t): Promise<{ feeBps: number; treasury: PublicKey }> {\n37\t  const [pda] = derivePlatformConfigPda();\n38\t  const info = await connection.getAccountInfo(pda);\n39\t  if (!info) {\n40\t    throw new Error(\n41\t      `PlatformConfig account not found at ${pda.toBase58()}`,\n42\t    );\n43\t  }\n44\t\n45\t  const data = info.data;\n46\t  const treasury = new PublicKey(data.subarray(40, 72));\n47\t  const feeBps = data.readUInt16LE(72);\n48\t\n49\t  return { feeBps, treasury };\n50\t}\n51\t\n52\t// ---------------------------------------------------------------------------\n53\t// Cached accessor — avoids repeated RPC calls within the same process\n54\t// ---------------------------------------------------------------------------\n55\t\n56\tlet _cache: { feeBps: number; treasury: PublicKey } | null = null;\n57\t\n58\t/**\n59\t * Return the cached PlatformConfig, fetching from RPC on first call.\n60\t * Cache lives for the process lifetime — restart the backend to pick up\n61\t * on-chain config changes.\n62\t */\n63\texport async function getPlatformConfig(\n64\t  connection: Connection,\n65\t): Promise<{ feeBps: number; treasury: PublicKey }> {\n66\t  if (_cache) return _cache;\n67\t  _cache = await fetchPlatformConfig(connection);\n68\t  return _cache;\n69\t}\n70\t\n71\t/** Clear the cached PlatformConfig — used in tests to reset between runs. */\n72\texport function resetPlatformConfigCache(): void {\n73\t  _cache = null;\n74\t}\n75\t"}]},"parent_tool_use_id":"toolu_017sWZHEt75rtcKF3tGqjVJe","session_id":"6eca57b8-16ed-4d78-a3fe-64a6180800ed","uuid":"23d8ee6c-6cb0-409d-a7ff-7bf36842084c","timestamp":"2026-04-03T19:06:06.778Z"}
