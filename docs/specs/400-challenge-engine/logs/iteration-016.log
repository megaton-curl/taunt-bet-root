{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EJCAcrnUkywbxJXdTJRnRE","type":"tool_result","content":"1\t/**\n2\t * Settlement worker — polls the chain for server-owned rounds that are ready\n3\t * for backend settlement across supported games.\n4\t */\n5\t\n6\timport { performance } from \"node:perf_hooks\";\n7\timport { Connection, PublicKey } from \"@solana/web3.js\";\n8\timport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\n9\timport type { Db } from \"../db.js\";\n10\timport { logger } from \"../logger.js\";\n11\timport {\n12\t  coinflipMatchSize,\n13\t  decodeCoinflipMatch,\n14\t  decodeLordRound,\n15\t  lordRoundDiscriminatorFilter,\n16\t} from \"./account-decoder.js\";\n17\t\n18\tconst PHASE_LOCKED_VALUE = 1;\n19\tconst LORD_PHASE_ACTIVE_VALUE = 1;\n20\t\n21\texport interface SettlementWorkerDeps {\n22\t  db: Db;\n23\t  connection: Connection;\n24\t  serverKey: PublicKey;\n25\t  pollIntervalMs: number;\n26\t  /** Called when a match is detected as ready for settlement (target_slot reached). */\n27\t  onSettleReady?: (pda: string) => Promise<void>;\n28\t  /** Called to check if a PDA is finalized (settled or permanently failed). */\n29\t  isFinalized?: (pda: string) => boolean;\n30\t}\n31\t\n32\texport interface SettlementWorker {\n33\t  start(): void;\n34\t  stop(): void;\n35\t  readonly isRunning: boolean;\n36\t  /** Run a single poll cycle (exposed for testing). */\n37\t  poll(): Promise<void>;\n38\t}\n39\t\n40\texport function createSettlementWorker(\n41\t  deps: SettlementWorkerDeps,\n42\t): SettlementWorker {\n43\t  const { db, connection, serverKey, pollIntervalMs } = deps;\n44\t  const discoveredPdas = new Set<string>();\n45\t  const readyPdas = new Set<string>();\n46\t  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n47\t  const undecodeablePdas = new Set<string>();\n48\t  let running = false;\n49\t  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n50\t\n51\t  async function handleDiscoveredRound(\n52\t    pda: string,\n53\t    targetSlot: bigint,\n54\t    currentSlot: number,\n55\t    slotTime: string | null,\n56\t  ): Promise<void> {\n57\t    const round = await db.getRoundByPda(pda);\n58\t    if (!round) {\n59\t      return;\n60\t    }\n61\t\n62\t    if (!discoveredPdas.has(pda)) {\n63\t      discoveredPdas.add(pda);\n64\t      if (round.phase === \"created\") {\n65\t        await db.updateRoundPhase(pda, \"locked\", {\n66\t          target_slot: targetSlot.toString(),\n67\t        });\n68\t        await db.insertOperatorEvent(pda, \"match_detected\", {\n69\t          targetSlot: targetSlot.toString(),\n70\t          currentSlot,\n71\t          game: round.game,\n72\t        });\n73\t        logger.info(\"settlement worker detected locked round\", {\n74\t          pda,\n75\t          creator: round.creator,\n76\t          targetSlot: targetSlot.toString(),\n77\t          currentSlot,\n78\t          slotTime,\n79\t          game: round.game,\n80\t        });"}]},"parent_tool_use_id":null,"session_id":"d57cf433-e8fe-4f4f-ba7f-c634be571ed8","uuid":"98f79200-3785-4a65-b139-5a92d612089c","timestamp":"2026-04-03T21:44:29.243Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/worker/settlement.ts","content":"/**\n * Settlement worker — polls the chain for server-owned rounds that are ready\n * for backend settlement across supported games.\n */\n\nimport { performance } from \"node:perf_hooks\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  coinflipMatchSize,\n  decodeCoinflipMatch,\n  decodeLordRound,\n  lordRoundDiscriminatorFilter,\n} from \"./account-decoder.js\";\n\nconst PHASE_LOCKED_VALUE = 1;\nconst LORD_PHASE_ACTIVE_VALUE = 1;\n\nexport interface SettlementWorkerDeps {\n  db: Db;\n  connection: Connection;\n  serverKey: PublicKey;\n  pollIntervalMs: number;\n  /** Called when a match is detected as ready for settlement (target_slot reached). */\n  onSettleReady?: (pda: string) => Promise<void>;\n  /** Called to check if a PDA is finalized (settled or permanently failed). */\n  isFinalized?: (pda: string) => boolean;\n}\n\nexport interface SettlementWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single poll cycle (exposed for testing). */\n  poll(): Promise<void>;\n}\n\nexport function createSettlementWorker(\n  deps: SettlementWorkerDeps,\n): SettlementWorker {\n  const { db, connection, serverKey, pollIntervalMs } = deps;\n  const discoveredPdas = new Set<string>();\n  const readyPdas = new Set<string>();\n  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n  const undecodeablePdas = new Set<string>();\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  async function handleDiscoveredRound(\n    pda: string,\n    targetSlot: bigint,\n    currentSlot: number,\n    slotTime: string | null,\n  ): Promise<void> {\n    const round = await db.getRoundByPda(pda);\n    if (!round) {\n      return;\n    }\n\n    if (!discoveredPdas.has(pda)) {\n      discoveredPdas.add(pda);\n      if (round.phase === \"created\") {\n        await db.updateRoundPhase(pda, \"locked\", {\n          target_slot: targetSlot.toString(),\n        });\n        await db.insertOperatorEvent(pda, \"match_detected\", {\n          targetSlot: targetSlot.toString(),\n          currentSlot,\n          game: round.game,\n        });\n        logger.info(\"settlement worker detected locked round\", {\n          pda,\n          creator: round.creator,\n          targetSlot: targetSlot.toString(),\n          currentSlot,\n          slotTime,\n          game: round.game,\n        });","numLines":80,"startLine":1,"totalLines":277}}}
