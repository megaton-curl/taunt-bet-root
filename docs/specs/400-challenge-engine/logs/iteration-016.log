{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TCEfJLVuo8BtDK5cX7fQLs","type":"tool_result","content":"1\t/**\n2\t * Admin API routes — reward config, reward pool, campaign/challenge CRUD,\n3\t * and admin-level management.\n4\t *\n5\t * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { Db } from \"../db.js\";\n10\t\n11\t// ---------------------------------------------------------------------------\n12\t// Known config keys — reject unknown keys with 400\n13\t// ---------------------------------------------------------------------------\n14\t\n15\tconst VALID_CONFIG_KEYS = new Set([\n16\t  \"points_per_dollar\",\n17\t  \"dogpile_default_multiplier\",\n18\t  \"reward_pool_fee_share\",\n19\t  \"points_crate_drop_rate\",\n20\t  \"sol_crate_drop_rate\",\n21\t  \"sol_crate_pool_pct\",\n22\t  \"sol_crate_min_value\",\n23\t  \"points_crate_min\",\n24\t  \"points_crate_max\",\n25\t  \"daily_challenge_count\",\n26\t  \"weekly_challenge_count\",\n27\t]);\n28\t\n29\t// ---------------------------------------------------------------------------\n30\t// Route factory\n31\t// ---------------------------------------------------------------------------\n32\t\n33\texport interface AdminRoutesDeps {\n34\t  db: Db;\n35\t  adminApiKey: string;\n36\t}\n37\t\n38\texport function createAdminRoutes(deps: AdminRoutesDeps) {\n39\t  const { db, adminApiKey } = deps;\n40\t  const app = new Hono();\n41\t\n42\t  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n43\t  app.use(\"*\", async (c, next) => {\n44\t    const key = c.req.header(\"X-Admin-Key\");\n45\t    if (!key || key !== adminApiKey) {\n46\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n47\t    }\n48\t    await next();\n49\t  });\n50\t\n51\t  // GET /reward-config — all config key-value pairs\n52\t  app.get(\"/reward-config\", async (c) => {\n53\t    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n54\t      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n55\t    `;\n56\t    const config: Record<string, { value: string; updatedAt: string }> = {};\n57\t    for (const row of rows) {\n58\t      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n59\t    }\n60\t    return c.json(config);\n61\t  });\n62\t\n63\t  // PUT /reward-config/:key — update a single config value\n64\t  app.put(\"/reward-config/:key\", async (c) => {\n65\t    const key = c.req.param(\"key\");\n66\t\n67\t    if (!VALID_CONFIG_KEYS.has(key)) {\n68\t      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n69\t    }\n70\t\n71\t    const body = await c.req.json<{ value?: string }>();\n72\t    if (body.value === undefined || body.value === null) {\n73\t      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n74\t    }\n75\t\n76\t    await db.rawSql`\n77\t      UPDATE reward_config\n78\t      SET value = ${String(body.value)}, updated_at = now()\n79\t      WHERE key = ${key}\n80\t    `;\n81\t\n82\t    return c.json({ key, value: String(body.value) });\n83\t  });\n84\t\n85\t  // GET /reward-pool — current pool state\n86\t  app.get(\"/reward-pool\", async (c) => {\n87\t    const rows = await db.rawSql<{\n88\t      balance_lamports: string;\n89\t      lifetime_funded: string;\n90\t      lifetime_paid: string;\n91\t      updated_at: string;\n92\t    }[]>`\n93\t      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n94\t      FROM reward_pool WHERE id = 1\n95\t    `;\n96\t    if (rows.length === 0) {\n97\t      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n98\t    }\n99\t    const pool = rows[0]!;\n100\t    return c.json({\n101\t      balanceLamports: pool.balance_lamports,\n102\t      lifetimeFunded: pool.lifetime_funded,\n103\t      lifetimePaid: pool.lifetime_paid,\n104\t      updatedAt: pool.updated_at,\n105\t    });\n106\t  });\n107\t\n108\t  // -------------------------------------------------------------------------\n109\t  // Campaign CRUD\n110\t  // -------------------------------------------------------------------------\n111\t\n112\t  const VALID_CAMPAIGN_TYPES = new Set([\"daily\", \"weekly\", \"onboarding\", \"dogpile\"]);\n113\t\n114\t  // POST /campaigns — create a campaign\n115\t  app.post(\"/campaigns\", async (c) => {\n116\t    const body = await c.req.json<{\n117\t      name?: string;\n118\t      campaignType?: string;\n119\t      startsAt?: string | null;\n120\t      endsAt?: string | null;\n121\t      config?: Record<string, unknown>;\n122\t    }>();\n123\t\n124\t    if (!body.name || typeof body.name !== \"string\") {\n125\t      return c.json({ error: \"MISSING_FIELD\", message: \"name is required\" }, 400);\n126\t    }\n127\t    if (!body.campaignType || !VALID_CAMPAIGN_TYPES.has(body.campaignType)) {\n128\t      return c.json(\n129\t        { error: \"INVALID_CAMPAIGN_TYPE\", message: `campaign_type must be one of: ${[...VALID_CAMPAIGN_TYPES].join(\", \")}` },\n130\t        400,\n131\t      );\n132\t    }\n133\t\n134\t    const startsAt = body.startsAt ?? null;\n135\t    const endsAt = body.endsAt ?? null;\n136\t    const config = JSON.stringify(body.config ?? {});\n137\t\n138\t    const rows = await db.rawSql<{ id: string; name: string; campaign_type: string; starts_at: string | null; ends_at: string | null; is_active: boolean; config: string; created_at: string }[]>`\n139\t      INSERT INTO campaigns (name, campaign_type, starts_at, ends_at, config)\n140\t      VALUES (${body.name}, ${body.campaignType}, ${startsAt}, ${endsAt}, ${config}::jsonb)\n141\t      RETURNING id, name, campaign_type, starts_at, ends_at, is_active, config, created_at\n142\t    `;\n143\t\n144\t    const row = rows[0]!;\n145\t    return c.json({\n146\t      id: row.id,\n147\t      name: row.name,\n148\t      campaignType: row.campaign_type,\n149\t      startsAt: row.starts_at,\n150\t      endsAt: row.ends_at,\n151\t      isActive: row.is_active,\n152\t      config: typeof row.config === \"string\" ? JSON.parse(row.config) : row.config,\n153\t      createdAt: row.created_at,\n154\t    }, 201);\n155\t  });\n156\t\n157\t  // PUT /campaigns/:id — update a campaign (soft-disable only, no delete)\n158\t  app.put(\"/campaigns/:id\", async (c) => {\n159\t    const id = c.req.param(\"id\");\n160\t\n161\t    const body = await c.req.json<{\n162\t      name?: string;\n163\t      startsAt?: string | null;\n164\t      endsAt?: string | null;\n165\t      isActive?: boolean;\n166\t      config?: Record<string, unknown>;\n167\t    }>();\n168\t\n169\t    // Build dynamic SET clauses\n170\t    const setClauses: string[] = [];\n171\t    const values: unknown[] = [];\n172\t\n173\t    if (body.name !== undefined) {\n174\t      values.push(body.name);\n175\t      setClauses.push(`name = $${values.length}`);\n176\t    }\n177\t    if (body.startsAt !== undefined) {\n178\t      values.push(body.startsAt);\n179\t      setClauses.push(`starts_at = $${values.length}`);\n180\t    }\n181\t    if (body.endsAt !== undefined) {\n182\t      values.push(body.endsAt);\n183\t      setClauses.push(`ends_at = $${values.length}`);\n184\t    }\n185\t    if (body.isActive !== undefined) {\n186\t      values.push(body.isActive);\n187\t      setClauses.push(`is_active = $${values.length}`);\n188\t    }\n189\t    if (body.config !== undefined) {\n190\t      values.push(JSON.stringify(body.config));\n191\t      setClauses.push(`config = $${values.length}::jsonb`);\n192\t    }\n193\t\n194\t    if (setClauses.length === 0) {\n195\t      return c.json({ error: \"NO_FIELDS\", message: \"No fields to update\" }, 400);\n196\t    }\n197\t\n198\t    values.push(id);\n199\t    const idPlaceholder = `$${values.length}`;\n200\t\n201\t    const query = `UPDATE campaigns SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, name, campaign_type, starts_at, ends_at, is_active, config, created_at`;\n202\t\n203\t    const rows = await db.rawSql.unsafe(query, values) as { id: string; name: string; campaign_type: string; starts_at: string | null; ends_at: string | null; is_active: boolean; config: string; created_at: string }[];\n204\t\n205\t    if (rows.length === 0) {\n206\t      return c.json({ error: \"NOT_FOUND\", message: `Campaign ${id} not found` }, 404);\n207\t    }\n208\t\n209\t    const row = rows[0]!;\n210\t    return c.json({\n211\t      id: row.id,\n212\t      name: row.name,\n213\t      campaignType: row.campaign_type,\n214\t      startsAt: row.starts_at,\n215\t      endsAt: row.ends_at,\n216\t      isActive: row.is_active,\n217\t      config: typeof row.config === \"string\" ? JSON.parse(row.config) : row.config,\n218\t      createdAt: row.created_at,\n219\t    });\n220\t  });\n221\t\n222\t  // -------------------------------------------------------------------------\n223\t  // Challenge CRUD\n224\t  // -------------------------------------------------------------------------\n225\t\n226\t  const VALID_SCOPES = new Set([\"any\", \"coinflip\", \"lord\", \"closecall\"]);\n227\t  const VALID_REWARD_TYPES = new Set([\"points\", \"crate\"]);\n228\t\n229\t  // POST /challenges — create a challenge in a campaign\n230\t  app.post(\"/challenges\", async (c) => {\n231\t    const body = await c.req.json<{\n232\t      campaignId?: number;\n233\t      title?: string;\n234\t      description?: string;\n235\t      action?: string;\n236\t      scope?: string;\n237\t      condition?: string;\n238\t      threshold?: number;\n239\t      rewardType?: string;\n240\t      rewardAmount?: number | null;\n241\t      prerequisiteId?: number | null;\n242\t      sortOrder?: number;\n243\t    }>();\n244\t\n245\t    if (!body.campaignId) {\n246\t      return c.json({ error: \"MISSING_FIELD\", message: \"campaignId is required\" }, 400);\n247\t    }\n248\t    if (!body.title || typeof body.title !== \"string\") {\n249\t      return c.json({ error: \"MISSING_FIELD\", message: \"title is required\" }, 400);\n250\t    }\n251\t    if (!body.action || typeof body.action !== \"string\") {\n252\t      return c.json({ error: \"MISSING_FIELD\", message: \"action is required\" }, 400);\n253\t    }\n254\t    if (!body.threshold || typeof body.threshold !== \"number\") {\n255\t      return c.json({ error: \"MISSING_FIELD\", message: \"threshold is required\" }, 400);\n256\t    }\n257\t    if (!body.rewardType || !VALID_REWARD_TYPES.has(body.rewardType)) {\n258\t      return c.json({ error: \"INVALID_REWARD_TYPE\", message: `reward_type must be one of: ${[...VALID_REWARD_TYPES].join(\", \")}` }, 400);\n259\t    }\n260\t    if (body.scope && !VALID_SCOPES.has(body.scope)) {\n261\t      return c.json({ error: \"INVALID_SCOPE\", message: `scope must be one of: ${[...VALID_SCOPES].join(\", \")}` }, 400);\n262\t    }\n263\t\n264\t    // Validate campaign exists\n265\t    const campRows = await db.rawSql<{ id: string }[]>`SELECT id FROM campaigns WHERE id = ${body.campaignId}`;\n266\t    if (campRows.length === 0) {\n267\t      return c.json({ error: \"CAMPAIGN_NOT_FOUND\", message: `Campaign ${body.campaignId} not found` }, 400);\n268\t    }\n269\t\n270\t    const scope = body.scope ?? \"any\";\n271\t    const condition = body.condition ?? \"count\";\n272\t    const description = body.description ?? null;\n273\t    const rewardAmount = body.rewardAmount ?? null;\n274\t    const prerequisiteId = body.prerequisiteId ?? null;\n275\t    const sortOrder = body.sortOrder ?? 0;\n276\t\n277\t    const rows = await db.rawSql<{\n278\t      id: string; campaign_id: string; title: string; description: string | null;\n279\t      action: string; scope: string; condition: string; threshold: number;\n280\t      reward_type: string; reward_amount: number | null; prerequisite_id: string | null;\n281\t      sort_order: number; is_active: boolean; created_at: string;\n282\t    }[]>`\n283\t      INSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order)\n284\t      VALUES (${body.campaignId}, ${body.title}, ${description}, ${body.action}, ${scope}, ${condition}, ${body.threshold}, ${body.rewardType}, ${rewardAmount}, ${prerequisiteId}, ${sortOrder})\n285\t      RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order, is_active, created_at\n286\t    `;\n287\t\n288\t    const row = rows[0]!;\n289\t    return c.json({\n290\t      id: row.id,\n291\t      campaignId: row.campaign_id,\n292\t      title: row.title,\n293\t      description: row.description,\n294\t      action: row.action,\n295\t      scope: row.scope,\n296\t      condition: row.condition,\n297\t      threshold: row.threshold,\n298\t      rewardType: row.reward_type,\n299\t      rewardAmount: row.reward_amount,\n300\t      prerequisiteId: row.prerequisite_id,\n301\t      sortOrder: row.sort_order,\n302\t      isActive: row.is_active,\n303\t      createdAt: row.created_at,\n304\t    }, 201);\n305\t  });\n306\t\n307\t  // PUT /challenges/:id — update a challenge (toggle is_active, update fields)\n308\t  app.put(\"/challenges/:id\", async (c) => {\n309\t    const id = c.req.param(\"id\");\n310\t\n311\t    const body = await c.req.json<{\n312\t      title?: string;\n313\t      description?: string | null;\n314\t      action?: string;\n315\t      scope?: string;\n316\t      condition?: string;\n317\t      threshold?: number;\n318\t      rewardType?: string;\n319\t      rewardAmount?: number | null;\n320\t      sortOrder?: number;\n321\t      isActive?: boolean;\n322\t    }>();\n323\t\n324\t    // Validate scope if provided\n325\t    if (body.scope !== undefined && !VALID_SCOPES.has(body.scope)) {\n326\t      return c.json({ error: \"INVALID_SCOPE\", message: `scope must be one of: ${[...VALID_SCOPES].join(\", \")}` }, 400);\n327\t    }\n328\t    // Validat