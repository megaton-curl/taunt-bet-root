n3143\t    expect(res.status).toBe(201);\n3144\t    const body = (await res.json()) as Record<string, any>;\n3145\t    expect(body.name).toBe(campName);\n3146\t    expect(body.campaignType).toBe(\"daily\");\n3147\t    expect(body.isActive).toBe(true);\n3148\t    expect(body.config).toEqual({ maxAssignments: 5 });\n3149\t    expect(body).toHaveProperty(\"id\");\n3150\t    expect(body).toHaveProperty(\"createdAt\");\n3151\t  });\n3152\t\n3153\t  it(\"POST /admin/campaigns rejects invalid campaign_type\", async () => {\n3154\t    const res = await adminApp.request(\"/admin/campaigns\", {\n3155\t      method: \"POST\",\n3156\t      headers: {\n3157\t        \"X-Admin-Key\": ADMIN_KEY,\n3158\t        \"Content-Type\": \"application/json\",\n3159\t      },\n3160\t      body: JSON.stringify({\n3161\t        name: `bad-type-${testSuffix}`,\n3162\t        campaignType: \"invalid_type\",\n3163\t      }),\n3164\t    });\n3165\t    expect(res.status).toBe(400);\n3166\t    const body = (await res.json()) as Record<string, any>;\n3167\t    expect(body.error).toBe(\"INVALID_CAMPAIGN_TYPE\");\n3168\t  });\n3169\t\n3170\t  it(\"PUT /admin/campaigns/:id updates campaign and toggles is_active\", async () => {\n3171\t    const campName = `update-camp-${testSuffix}`;\n3172\t    // Create a campaign first\n3173\t    const createRes = await adminApp.request(\"/admin/campaigns\", {\n3174\t      method: \"POST\",\n3175\t      headers: {\n3176\t        \"X-Admin-Key\": ADMIN_KEY,\n3177\t        \"Content-Type\": \"application/json\",\n3178\t      },\n3179\t      body: JSON.stringify({ name: campName, campaignType: \"weekly\" }),\n3180\t    });\n3181\t    const created = (await createRes.json()) as Record<string, any>;\n3182\t\n3183\t    const updatedName = `updated-camp-${testSuffix}`;\n3184\t    // Update: rename + deactivate\n3185\t    const res = await adminApp.request(`/admin/campaigns/${created.id}`, {\n3186\t      method: \"PUT\",\n3187\t      headers: {\n3188\t        \"X-Admin-Key\": ADMIN_KEY,\n3189\t        \"Content-Type\": \"application/json\",\n3190\t      },\n3191\t      body: JSON.stringify({ name: updatedName, isActive: false }),\n3192\t    });\n3193\t    expect(res.status).toBe(200);\n3194\t    const body = (await res.json()) as Record<string, any>;\n3195\t    expect(body.name).toBe(updatedName);\n3196\t    expect(body.isActive).toBe(false);\n3197\t    expect(body.campaignType).toBe(\"weekly\"); // unchanged\n3198\t\n3199\t    // Verify in DB\n3200\t    const dbRows = await rawSql`SELECT name, is_active FROM campaigns WHERE id = ${created.id}`;\n3201\t    expect(dbRows[0]!.name).toBe(updatedName);\n3202\t    expect(dbRows[0]!.is_active).toBe(false);\n3203\t  });\n3204\t\n3205\t  it(\"POST /admin/challenges creates a challenge in a campaign\", async () => {\n3206\t    // Create a campaign first\n3207\t    const campRes = await adminApp.request(\"/admin/campaigns\", {\n3208\t      method: \"POST\",\n3209\t      headers: {\n3210\t        \"X-Admin-Key\": ADMIN_KEY,\n3211\t        \"Content-Type\": \"application/json\",\n3212\t      },\n3213\t      body: JSON.stringify({ name: `chal-camp-${testSuffix}`, campaignType: \"daily\" }),\n3214\t    });\n3215\t    const camp = (await campRes.json()) as Record<string, any>;\n3216\t\n3217\t    // Create a challenge in it\n3218\t    const res = await adminApp.request(\"/admin/challenges\", {\n3219\t      method: \"POST\",\n3220\t      headers: {\n3221\t        \"X-Admin-Key\": ADMIN_KEY,\n3222\t        \"Content-Type\": \"application/json\",\n3223\t      },\n3224\t      body: JSON.stringify({\n3225\t        campaignId: Number(camp.id),\n3226\t        title: \"Win 3 coinflips\",\n3227\t        description: \"Win 3 coinflip games\",\n3228\t        action: \"game_won\",\n3229\t        scope: \"coinflip\",\n3230\t        threshold: 3,\n3231\t        rewardType: \"points\",\n3232\t        rewardAmount: 500,\n3233\t        sortOrder: 1,\n3234\t      }),\n3235\t    });\n3236\t    expect(res.status).toBe(201);\n3237\t    const body = (await res.json()) as Record<string, any>;\n3238\t    expect(body.title).toBe(\"Win 3 coinflips\");\n3239\t    expect(body.scope).toBe(\"coinflip\");\n3240\t    expect(body.action).toBe(\"game_won\");\n3241\t    expect(body.threshold).toBe(3);\n3242\t    expect(body.rewardType).toBe(\"points\");\n3243\t    expect(body.rewardAmount).toBe(500);\n3244\t    expect(body.isActive).toBe(true);\n3245\t    expect(body.campaignId).toBe(String(camp.id));\n3246\t  });\n3247\t\n3248\t  it(\"POST /admin/challenges rejects invalid scope\", async () => {\n3249\t    // Use an existing seeded campaign (daily)\n3250\t    const camps = await rawSql`SELECT id FROM campaigns WHERE campaign_type = 'daily' LIMIT 1`;\n3251\t    const campId = camps[0]!.id;\n3252\t\n3253\t    const res = await adminApp.request(\"/admin/challenges\", {\n3254\t      method: \"POST\",\n3255\t      headers: {\n3256\t        \"X-Admin-Key\": ADMIN_KEY,\n3257\t        \"Content-Type\": \"application/json\",\n3258\t      },\n3259\t      body: JSON.stringify({\n3260\t        campaignId: Number(campId),\n3261\t        title: \"Bad scope challenge\",\n3262\t        action: \"game_completed\",\n3263\t        scope: \"poker\",\n3264\t        threshold: 1,\n3265\t        rewardType: \"points\",\n3266\t      }),\n3267\t    });\n3268\t    expect(res.status).toBe(400);\n3269\t    const body = (await res.json()) as Record<string, any>;\n3270\t    expect(body.error).toBe(\"INVALID_SCOPE\");\n3271\t  });\n3272\t\n3273\t  it(\"POST /admin/challenges rejects nonexistent campaign\", async () => {\n3274\t    const res = await adminApp.request(\"/admin/challenges\", {\n3275\t      method: \"POST\",\n3276\t      headers: {\n3277\t        \"X-Admin-Key\": ADMIN_KEY,\n3278\t        \"Content-Type\": \"application/json\",\n3279\t      },\n3280\t      body: JSON.stringify({\n3281\t        campaignId: 99999,\n3282\t        title: \"Orphan challenge\",\n3283\t        action: \"game_completed\",\n3284\t        threshold: 1,\n3285\t        rewardType: \"points\",\n3286\t      }),\n3287\t    });\n3288\t    expect(res.status).toBe(400);\n3289\t    const body = (await res.json()) as Record<string, any>;\n3290\t    expect(body.error).toBe(\"CAMPAIGN_NOT_FOUND\");\n3291\t  });\n3292\t\n3293\t  it(\"PUT /admin/challenges/:id updates challenge fields\", async () => {\n3294\t    // Create campaign + challenge\n3295\t    const campRes = await adminApp.request(\"/admin/campaigns\", {\n3296\t      method: \"POST\",\n3297\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n3298\t      body: JSON.stringify({ name: `upd-chal-camp-${testSuffix}`, campaignType: \"daily\" }),\n3299\t    });\n3300\t    const camp = (await campRes.json()) as Record<string, any>;\n3301\t\n3302\t    const chalRes = await adminApp.request(\"/admin/challenges\", {\n3303\t      method: \"POST\",\n3304\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n3305\t      body: JSON.stringify({\n3306\t        campaignId: Number(camp.id),\n3307\t        title: \"Original title\",\n3308\t        action: \"game_completed\",\n3309\t        threshold: 5,\n3310\t        rewardType: \"crate\",\n3311\t      }),\n3312\t    });\n3313\t    const chal = (await chalRes.json()) as Record<string, any>;\n3314\t\n3315\t    // Update title + deactivate\n3316\t    const res = await adminApp.request(`/admin/challenges/${chal.id}`, {\n3317\t      method: \"PUT\",\n3318\t      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n3319\t      body: JSON.stringify({ title: \"Updated title\", isActive: false }),\n3320\t    });\n3321\t    expect(res.status).toBe(200);\n3322\t    const body = (await res.json()) as Record<string, any>;\n3323\t    expect(body.title).toBe(\"Updated title\");\n3324\t    expect(body.isActive).toBe(false);\n3325\t    expect(body.threshold).toBe(5); // unchanged\n3326\t\n3327\t    // Verify deactivated challenge not returned by active query\n3328\t    const dbRows = await rawSql`SELECT is_active FROM challenges WHERE id = ${chal.id}`;\n3329\t    expect(dbRows[0]!.is_active).toBe(false);\n3330\t  });"}]},"parent_tool_use_id":null,"session_id":"d57cf433-e8fe-4f4f-ba7f-c634be571ed8","uuid":"078fdb41-291f-4d38-9b3b-23fc83633009","timestamp":"2026-04-03T21:43:59.237Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"\ndescribe(\"Admin API: campaign + challenge CRUD\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let adminApp: Hono;\n\n  const ADMIN_KEY = \"test-admin-key-secret\";\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  let testSuffix: string;\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n    // Use unique suffix per test run to avoid name collision with seeded data\n    testSuffix = Date.now().toString(36) + Math.random().toString(36).slice(2, 6);\n\n    adminApp = new Hono();\n    adminApp.route(\"/admin\", createAdminRoutes({ db, adminApiKey: ADMIN_KEY }));\n  });\n\n  it(\"POST /admin/campaigns creates a campaign and returns it\", async () => {\n    const campName = `test-campaign-${testSuffix}`;\n    const res = await adminApp.request(\"/admin/campaigns\", {\n      method: \"POST\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({\n        name: campName,\n        campaignType: \"daily\",\n        config: { maxAssignments: 5 },\n      }),\n    });\n    expect(res.status).toBe(201);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.name).toBe(campName);\n    expect(body.campaignType).toBe(\"daily\");\n    expect(body.isActive).toBe(true);\n    expect(body.config).toEqual({ maxAssignments: 5 });\n    expect(body).toHaveProperty(\"id\");\n    expect(body).toHaveProperty(\"createdAt\");\n  });\n\n  it(\"POST /admin/campaigns rejects invalid campaign_type\", async () => {\n    const res = await adminApp.request(\"/admin/campaigns\", {\n      method: \"POST\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({\n        name: `bad-type-${testSuffix}`,\n        campaignType: \"invalid_type\",\n      }),\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"INVALID_CAMPAIGN_TYPE\");\n  });\n\n  it(\"PUT /admin/campaigns/:id updates campaign and toggles is_active\", async () => {\n    const campName = `update-camp-${testSuffix}`;\n    // Create a campaign first\n    const createRes = await adminApp.request(\"/admin/campaigns\", {\n      method: \"POST\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ name: campName, campaignType: \"weekly\" }),\n    });\n    const created = (await createRes.json()) as Record<string, any>;\n\n    const updatedName = `updated-camp-${testSuffix}`;\n    // Update: rename + deactivate\n    const res = await adminApp.request(`/admin/campaigns/${created.id}`, {\n      method: \"PUT\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ name: updatedName, isActive: false }),\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.name).toBe(updatedName);\n    expect(body.isActive).toBe(false);\n    expect(body.campaignType).toBe(\"weekly\"); // unchanged\n\n    // Verify in DB\n    const dbRows = await rawSql`SELECT name, is_active FROM campaigns WHERE id = ${created.id}`;\n    expect(dbRows[0]!.name).toBe(updatedName);\n    expect(dbRows[0]!.is_active).toBe(false);\n  });\n\n  it(\"POST /admin/challenges creates a challenge in a campaign\", async () => {\n    // Create a campaign first\n    const campRes = await adminApp.request(\"/admin/campaigns\", {\n      method: \"POST\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ name: `chal-camp-${testSuffix}`, campaignType: \"daily\" }),\n    });\n    const camp = (await campRes.json()) as Record<string, any>;\n\n    // Create a challenge in it\n    const res = await adminApp.request(\"/admin/challenges\", {\n      method: \"POST\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({\n        campaignId: Number(camp.id),\n        title: \"Win 3 coinflips\",\n        description: \"Win 3 coinflip games\",\n        action: \"game_won\",\n        scope: \"coinflip\",\n        threshold: 3,\n        rewardType: \"points\",\n        rewardAmount: 500,\n        sortOrder: 1,\n      }),\n    });\n    expect(res.status).toBe(201);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.title).toBe(\"Win 3 coinflips\");\n    expect(body.scope).toBe(\"coinflip\");\n    expect(body.action).toBe(\"game_won\");\n    expect(body.threshold).toBe(3);\n    expect(body.rewardType).toBe(\"points\");\n    expect(body.rewardAmount).toBe(500);\n    expect(body.isActive).toBe(true);\n    expect(body.campaignId).toBe(String(camp.id));\n  });\n\n  it(\"POST /admin/challenges rejects invalid scope\", async () => {\n    // Use an existing seeded campaign (daily)\n    const camps = await rawSql`SELECT id FROM campaigns WHERE campaign_type = 'daily' LIMIT 1`;\n    const campId = camps[0]!.id;\n\n    const res = await adminApp.request(\"/admin/challenges\", {\n      method: \"POST\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({\n        campaignId: Number(campId),\n        title: \"Bad scope challenge\",\n        action: \"game_completed\",\n        scope: \"poker\",\n        threshold: 1,\n        rewardType: \"points\",\n      }),\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"INVALID_SCOPE\");\n  });\n\n  it(\"POST /admin/challenges rejects nonexistent campaign\", async () => {\n    const res = await adminApp.request(\"/admin/challenges\", {\n      method: \"POST\",\n      headers: {\n        \"X-Admin-Key\": ADMIN_KEY,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({\n        campaignId: 99999,\n        title: \"Orphan challenge\",\n        action: \"game_completed\",\n        threshold: 1,\n        rewardType: \"points\",\n      }),\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.error).toBe(\"CAMPAIGN_NOT_FOUND\");\n  });\n\n  it(\"PUT /admin/challenges/:id updates challenge fields\", async () => {\n    // Create campaign + challenge\n    const campRes = await adminApp.request(\"/admin/campaigns\", {\n      method: \"POST\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ name: `upd-chal-camp-${testSuffix}`, campaignType: \"daily\" }),\n    });\n    const camp = (await campRes.json()) as Record<string, any>;\n\n    const chalRes = await adminApp.request(\"/admin/challenges\", {\n      method: \"POST\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        campaignId: Number(camp.id),\n        title: \"Original title\",\n        action: \"game_completed\",\n        threshold: 5,\n        rewardType: \"crate\",\n      }),\n    });\n    const chal = (await chalRes.json()) as Record<string, any>;\n\n    // Update title + deactivate\n    const res = await adminApp.request(`/admin/challenges/${chal.id}`, {\n      method: \"PUT\",\n      headers: { \"X-Admin-Key\": ADMIN_KEY, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Updated title\", isActive: false }),\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.title).toBe(\"Updated title\");\n    expect(body.isActive).toBe(false);\n    expect(body.threshold).toBe(5); // unchanged\n\n    // Verify deactivated challenge not returned by active query\n    const dbRows = await rawSql`SELECT is_active FROM challenges WHERE id = ${chal.id}`;\n    expect(dbRows[0]!.is_active).toBe(false);\n  });","numLines":231,"startLine":3100,"totalLines":3332}}}
