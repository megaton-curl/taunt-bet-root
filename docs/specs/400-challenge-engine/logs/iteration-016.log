{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KTFKW3RkkVG3oaum9LeXea","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014McZAbtQLuQvxuwVJ9PZsY","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/services/backend/src/worker/dogpile-worker.ts","content":"/**\n * Dogpile status worker — periodic poll that transitions dogpile_events:\n *   scheduled → active  when now() >= starts_at\n *   active   → ended    when now() >= ends_at\n */\n\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface DogpileWorkerDeps {\n  db: Db;\n  pollIntervalMs?: number;\n}\n\nexport interface DogpileWorker {\n  start(): void;\n  stop(): void;\n  /** Run a single tick (exposed for testing). */\n  tick(): Promise<{ activated: number; ended: number }>;\n}\n\nexport function createDogpileWorker(deps: DogpileWorkerDeps): DogpileWorker {\n  const { db, pollIntervalMs = 10_000 } = deps;\n  let intervalId: ReturnType<typeof setInterval> | null = null;\n\n  async function tick(): Promise<{ activated: number; ended: number }> {\n    // Transition scheduled → active\n    const activated = await db.rawSql<{ id: string }[]>`\n      UPDATE dogpile_events\n      SET status = 'active'\n      WHERE status = 'scheduled' AND starts_at <= now()\n      RETURNING id\n    `;\n\n    // Transition active → ended\n    const ended = await db.rawSql<{ id: string }[]>`\n      UPDATE dogpile_events\n      SET status = 'ended'\n      WHERE status = 'active' AND ends_at <= now()\n      RETURNING id\n    `;\n\n    if (activated.length > 0) {\n      logger.info(\"dogpile: activated events\", { ids: activated.map((r) => r.id) });\n    }\n    if (ended.length > 0) {\n      logger.info(\"dogpile: ended events\", { ids: ended.map((r) => r.id) });\n    }\n\n    return { activated: activated.length, ended: ended.length };\n  }\n\n  return {\n    start() {\n      if (intervalId) return;\n      logger.info(\"Dogpile worker started\", { pollIntervalMs });\n      intervalId = setInterval(() => {\n        tick().catch((err) => {\n          logger.error(\"dogpile worker tick failed\", {\n            error: err instanceof Error ? err.message : String(err),\n          });\n        });\n      }, pollIntervalMs);\n    },\n    stop() {\n      if (intervalId) {\n        clearInterval(intervalId);\n        intervalId = null;\n      }\n    },\n    tick,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1933,"cache_read_input_tokens":70885,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1933},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d57cf433-e8fe-4f4f-ba7f-c634be571ed8","uuid":"659b7166-4472-4106-be75-902ba010a3a8"}
