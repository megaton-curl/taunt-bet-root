multiplier, campaign_id)","+      VALUES (${startsAt.toISOString()}, ${endsAt.toISOString()}, ${multiplier}, ${campaignId})","+      RETURNING id, starts_at, ends_at, multiplier, status, campaign_id, created_at","+    `;","+","+    const row = rows[0]!;","+    return c.json({","+      id: row.id,","+      startsAt: row.starts_at,","+      endsAt: row.ends_at,","+      multiplier: Number(row.multiplier),","+      status: row.status,","+      campaignId: row.campaign_id,","+      createdAt: row.created_at,","+    }, 201);","+  });","+","+  // PUT /dogpile/:id — cancel a scheduled/future event (cannot modify active events)","+  app.put(\"/dogpile/:id\", async (c) => {","+    const id = c.req.param(\"id\");","+","+    const body = await c.req.json<{ status?: string }>();","+","+    if (!body.status || body.status !== \"cancelled\") {","+      return c.json(","+        { error: \"INVALID_ACTION\", message: \"Only status: 'cancelled' is supported\" },","+        400,","+      );","+    }","+","+    // Check current status","+    const existing = await db.rawSql<{ id: string; status: string }[]>`","+      SELECT id, status FROM dogpile_events WHERE id = ${id}","+    `;","+","+    if (existing.length === 0) {","+      return c.json({ error: \"NOT_FOUND\", message: `Dogpile event ${id} not found` }, 404);","+    }","+","+    const current = existing[0]!;","+    if (current.status === \"active\") {","+      return c.json(","+        { error: \"CANNOT_MODIFY_ACTIVE\", message: \"Cannot cancel an active dogpile event\" },","+        409,","+      );","+    }","+    if (current.status === \"ended\" || current.status === \"cancelled\") {","+      return c.json(","+        { error: \"ALREADY_TERMINAL\", message: `Event is already ${current.status}` },","+        409,","+      );","+    }","+","+    const rows = await db.rawSql<{","+      id: string; starts_at: string; ends_at: string;","+      multiplier: string; status: string; campaign_id: string | null; created_at: string;","+    }[]>`","+      UPDATE dogpile_events SET status = 'cancelled'","+      WHERE id = ${id}","+      RETURNING id, starts_at, ends_at, multiplier, status, campaign_id, created_at","+    `;","+","+    const row = rows[0]!;","+    return c.json({","+      id: row.id,","+      startsAt: row.starts_at,","+      endsAt: row.ends_at,","+      multiplier: Number(row.multiplier),","+      status: row.status,","+      campaignId: row.campaign_id,","+      createdAt: row.created_at,","+    });","+  });","+","+  // GET /dogpile — list all dogpile events (optional status filter)","+  app.get(\"/dogpile\", async (c) => {","+    const statusFilter = c.req.query(\"status\");","+","+    let rows: {","+      id: string; starts_at: string; ends_at: string;","+      multiplier: string; status: string; campaign_id: string | null; created_at: string;","+    }[];","+","+    if (statusFilter) {","+      rows = await db.rawSql`","+        SELECT id, starts_at, ends_at, multiplier, status, campaign_id, created_at","+        FROM dogpile_events","+        WHERE status = ${statusFilter}","+        ORDER BY starts_at DESC","+      `;","+    } else {","+      rows = await db.rawSql`","+        SELECT id, starts_at, ends_at, multiplier, status, campaign_id, created_at","+        FROM dogpile_events","+        ORDER BY starts_at DESC","+      `;","+    }","+","+    const items = rows.map((row) => ({","+      id: row.id,","+      startsAt: row.starts_at,","+      endsAt: row.ends_at,","+      multiplier: Number(row.multiplier),","+      status: row.status,","+      campaignId: row.campaign_id,","+      createdAt: row.created_at,","+    }));","+","+    return c.json({ items });","+  });","+","   return app;"," }"]}],"userModified":false,"replaceAll":false}}
