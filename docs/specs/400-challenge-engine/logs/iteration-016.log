{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012q94Vt7YrtRJxy7sUhtPqg","type":"tool_result","content":"1\t/**\n2\t * Dogpile routes — public endpoints for dogpile event status and schedule.\n3\t *\n4\t * GET /current   — active dogpile event, or next scheduled, or null\n5\t * GET /schedule  — upcoming dogpile events ordered by starts_at\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { AppEnv } from \"../hono-env.js\";\n10\timport type { Db } from \"../db.js\";\n11\timport { logger } from \"../logger.js\";\n12\t\n13\t// ---------------------------------------------------------------------------\n14\t// Types\n15\t// ---------------------------------------------------------------------------\n16\t\n17\texport interface DogpileRoutesDeps {\n18\t  db: Db;\n19\t}\n20\t\n21\tinterface DogpileEventRow {\n22\t  id: string;\n23\t  multiplier: string;\n24\t  starts_at: Date;\n25\t  ends_at: Date;\n26\t  status: string;\n27\t  campaign_id: string | null;\n28\t}\n29\t\n30\t// ---------------------------------------------------------------------------\n31\t// Route factory\n32\t// ---------------------------------------------------------------------------\n33\t\n34\texport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n35\t  const { db } = deps;\n36\t  const app = new Hono<AppEnv>();\n37\t\n38\t  // GET /current — active event > next scheduled > null\n39\t  app.get(\"/current\", async (c) => {\n40\t    try {\n41\t      // Try active first\n42\t      const active = await db.rawSql<DogpileEventRow[]>`\n43\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n44\t        FROM dogpile_events\n45\t        WHERE status = 'active'\n46\t        ORDER BY starts_at ASC\n47\t        LIMIT 1\n48\t      `;\n49\t\n50\t      if (active.length > 0) {\n51\t        const e = active[0]!;\n52\t        return c.json({\n53\t          id: Number(e.id),\n54\t          multiplier: Number(e.multiplier),\n55\t          startsAt: e.starts_at.toISOString(),\n56\t          endsAt: e.ends_at.toISOString(),\n57\t          status: \"active\",\n58\t          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n59\t        });\n60\t      }\n61\t\n62\t      // Try next scheduled\n63\t      const scheduled = await db.rawSql<DogpileEventRow[]>`\n64\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n65\t        FROM dogpile_events\n66\t        WHERE status = 'scheduled'\n67\t          AND starts_at > now()\n68\t        ORDER BY starts_at ASC\n69\t        LIMIT 1\n70\t      `;\n71\t\n72\t      if (scheduled.length > 0) {\n73\t        const e = scheduled[0]!;\n74\t        return c.json({\n75\t          id: Number(e.id),\n76\t          multiplier: Number(e.multiplier),\n77\t          startsAt: e.starts_at.toISOString(),\n78\t          endsAt: e.ends_at.toISOString(),\n79\t          status: \"scheduled\",\n80\t          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n81\t        });\n82\t      }\n83\t\n84\t      return c.json(null);\n85\t    } catch (err) {\n86\t      logger.error(\"dogpile/current failed\", {\n87\t        error: err instanceof Error ? err.message : String(err),\n88\t      });\n89\t      return c.json({ error: \"Failed to fetch dogpile status\" }, 500);\n90\t    }\n91\t  });\n92\t\n93\t  // GET /schedule — upcoming events ordered by starts_at\n94\t  app.get(\"/schedule\", async (c) => {\n95\t    try {\n96\t      const rows = await db.rawSql<DogpileEventRow[]>`\n97\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n98\t        FROM dogpile_events\n99\t        WHERE status IN ('scheduled', 'active')\n100\t        ORDER BY starts_at ASC\n101\t      `;\n102\t\n103\t      const items = rows.map((e: DogpileEventRow) => ({\n104\t        id: Number(e.id),\n105\t        multiplier: Number(e.multiplier),\n106\t        startsAt: e.starts_at.toISOString(),\n107\t        endsAt: e.ends_at.toISOString(),\n108\t        status: e.status,\n109\t      }));\n110\t\n111\t      return c.json({ items });\n112\t    } catch (err) {\n113\t      logger.error(\"dogpile/schedule failed\", {\n114\t        error: err instanceof Error ? err.message : String(err),\n115\t      });\n116\t      return c.json({ error: \"Failed to fetch dogpile schedule\" }, 500);\n117\t    }\n118\t  });\n119\t\n120\t  return app;\n121\t}\n122\t"}]},"parent_tool_use_id":null,"session_id":"d57cf433-e8fe-4f4f-ba7f-c634be571ed8","uuid":"1140bda4-51ed-4f42-9755-27e419be111c","timestamp":"2026-04-03T21:43:37.475Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/routes/dogpile.ts","content":"/**\n * Dogpile routes — public endpoints for dogpile event status and schedule.\n *\n * GET /current   — active dogpile event, or next scheduled, or null\n * GET /schedule  — upcoming dogpile events ordered by starts_at\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface DogpileRoutesDeps {\n  db: Db;\n}\n\ninterface DogpileEventRow {\n  id: string;\n  multiplier: string;\n  starts_at: Date;\n  ends_at: Date;\n  status: string;\n  campaign_id: string | null;\n}\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  // GET /current — active event > next scheduled > null\n  app.get(\"/current\", async (c) => {\n    try {\n      // Try active first\n      const active = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'active'\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (active.length > 0) {\n        const e = active[0]!;\n        return c.json({\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"active\",\n          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n        });\n      }\n\n      // Try next scheduled\n      const scheduled = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'scheduled'\n          AND starts_at > now()\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (scheduled.length > 0) {\n        const e = scheduled[0]!;\n        return c.json({\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"scheduled\",\n          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n        });\n      }\n\n      return c.json(null);\n    } catch (err) {\n      logger.error(\"dogpile/current failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch dogpile status\" }, 500);\n    }\n  });\n\n  // GET /schedule — upcoming events ordered by starts_at\n  app.get(\"/schedule\", async (c) => {\n    try {\n      const rows = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status IN ('scheduled', 'active')\n        ORDER BY starts_at ASC\n      `;\n\n      const items = rows.map((e: DogpileEventRow) => ({\n        id: Number(e.id),\n        multiplier: Number(e.multiplier),\n        startsAt: e.starts_at.toISOString(),\n        endsAt: e.ends_at.toISOString(),\n        status: e.status,\n      }));\n\n      return c.json({ items });\n    } catch (err) {\n      logger.error(\"dogpile/schedule failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch dogpile schedule\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":122,"startLine":1,"totalLines":122}}}
