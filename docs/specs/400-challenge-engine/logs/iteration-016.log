{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Thp4wMeKyDkHNTFKCF6uA5","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createChallengeRoutes } from \"./routes/challenges.js\";\n21\timport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\n22\timport { createDogpileRoutes } from \"./routes/dogpile.js\";\n23\timport { createAdminRoutes } from \"./routes/admin.js\";\n24\timport { createInternalRoutes } from \"./routes/internal.js\";\n25\timport { swaggerUI } from \"@hono/swagger-ui\";\n26\timport { spec } from \"./openapi.js\";\n27\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n28\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n29\timport { createSettlementWorker } from \"./worker/settlement.js\";\n30\timport { settleRound } from \"./worker/settle-tx.js\";\n31\timport { createRetrySettler } from \"./worker/retry.js\";\n32\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n33\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n34\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n35\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n36\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n37\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n38\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n39\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n40\timport { fetchSolPrice } from \"./routes/price.js\";\n41\timport { logger } from \"./logger.js\";\n42\t\n43\tconst config = loadConfig();\n44\t\n45\t// Single postgres pool shared by game DB, auth DB, and all workers\n46\tconst sql = postgres(config.databaseUrl);\n47\tconst db = createDb(config.databaseUrl, sql);\n48\tconst authDb = createAuthDb(sql);\n49\t\n50\tconst connection = new Connection(config.rpcUrl, {\n51\t  commitment: \"confirmed\",\n52\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n53\t});\n54\t\n55\tconst app = new Hono();\n56\t\n57\tapp.use(\n58\t  \"*\",\n59\t  cors({\n60\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n61\t    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n62\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\", \"X-Admin-Key\"],\n63\t  }),\n64\t);\n65\t\n66\t// Request logging — correlate frontend fetch timing with server-side processing\n67\tapp.use(\"*\", async (c, next) => {\n68\t  const start = Date.now();\n69\t  await next();\n70\t  const ms = Date.now() - start;\n71\t  const method = c.req.method;\n72\t  const path = c.req.path;\n73\t  // Skip noisy health checks and OPTIONS preflight\n74\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n75\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n76\t});\n77\t\n78\t// API docs — Swagger UI + raw OpenAPI spec\n79\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n80\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n81\t\n82\t// Auth routes — no JWT middleware (these are the login endpoints)\n83\t// Lighter rate limiting by IP for auth endpoints\n84\tapp.use(\n85\t  \"/auth/*\",\n86\t  createRateLimitMiddleware({\n87\t    perWallet: 20,\n88\t    global: config.rateLimitGlobal,\n89\t    windowMs: 60_000,\n90\t  }),\n91\t);\n92\t\n93\tapp.route(\n94\t  \"/auth\",\n95\t  createAuthRoutes({\n96\t    authDb,\n97\t    db,\n98\t    jwtSecret: config.jwtSecret,\n99\t    cluster: config.cluster,\n100\t    challengeTtlSeconds: config.challengeTtlSeconds,\n101\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n102\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n103\t  }),\n104\t);\n105\t\n106\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n107\tapp.use(\n108\t  \"/profile/*\",\n109\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n110\t);\n111\tapp.route(\"/profile\", createProfileRoutes({ db }));\n112\t\n113\t// Public profile routes — no auth required\n114\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n115\t\n116\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n117\tapp.use(\n118\t  \"/referral/*\",\n119\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n120\t);\n121\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n122\t\n123\t// JWT auth middleware for game endpoints\n124\tapp.use(\n125\t  \"/coinflip/*\",\n126\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n127\t);\n128\tapp.use(\n129\t  \"/lord/*\",\n130\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n131\t);\n132\t\n133\t// Rate limiting — per-wallet and global limits on POST requests\n134\tapp.use(\n135\t  \"/coinflip/*\",\n136\t  createRateLimitMiddleware({\n137\t    perWallet: config.rateLimitPerWallet,\n138\t    global: config.rateLimitGlobal,\n139\t    windowMs: 60_000,\n140\t  }),\n141\t);\n142\tapp.use(\n143\t  \"/lord/*\",\n144\t  createRateLimitMiddleware({\n145\t    perWallet: config.rateLimitPerWallet,\n146\t    global: config.rateLimitGlobal,\n147\t    windowMs: 60_000,\n148\t  }),\n149\t);\n150\t\n151\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n152\tconst entropyAccount = new PublicKey(config.entropyAccount);\n153\tconst retrySettler = createRetrySettler({\n154\t  db,\n155\t  connection,\n156\t  settleRound: (pda) =>\n157\t    settleRound(\n158\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n159\t      pda,\n160\t    ),\n161\t});\n162\t\n163\t// PDA watcher — WebSocket-based instant join detection\n164\tconst pdaWatcher = createPdaWatcher({\n165\t  connection,\n166\t  serverKey: config.serverKeypair.publicKey,\n167\t  db,\n168\t  onJoinDetected: async (pda, targetSlot) => {\n169\t    // Update DB phase if still in 'created'\n170\t    const round = await db.getRoundByPda(pda);\n171\t    if (round && round.phase === \"created\") {\n172\t      await db.updateRoundPhase(pda, \"locked\", {\n173\t        target_slot: targetSlot.toString(),\n174\t      });\n175\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n176\t        targetSlot: targetSlot.toString(),\n177\t        source: \"pda-watcher\",\n178\t        game: round.game,\n179\t      });\n180\t    }\n181\t\n182\t    // Check if target slot already passed — settle immediately if so\n183\t    const currentSlot = await connection.getSlot();\n184\t    if (BigInt(currentSlot) >= targetSlot) {\n185\t      await retrySettler.attemptSettle(pda);\n186\t      pdaWatcher.unwatch(pda);\n187\t    }\n188\t    // If target slot not reached yet, poll worker will pick it up next cycle\n189\t  },\n190\t});\n191\t\n192\tconst worker = createSettlementWorker({\n193\t  db,\n194\t  connection,\n195\t  serverKey: config.serverKeypair.publicKey,\n196\t  pollIntervalMs: config.workerPollIntervalMs,\n197\t  onSettleReady: async (pda) => {\n198\t    await retrySettler.attemptSettle(pda);\n199\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n200\t  },\n201\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n202\t});\n203\tworker.start();\n204\t\n205\t// Close Call clock worker — fetches boundary prices + settles open rounds\n206\t// Rounds are created on-demand by players via /closecall/bet\n207\tconst closeCallClock = createCloseCallClockWorker({\n208\t  connection,\n209\t  serverKeypair: config.serverKeypair,\n210\t  db,\n211\t});\n212\tcloseCallClock.start();\n213\t\n214\t// Register event handlers before starting the worker\n215\tregisterHandler(\n216\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n217\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n218\t);\n219\tregisterHandler(\n220\t  EventTypes.GAME_SETTLED,\n221\t  createGameSettledHandler({ db }),\n222\t);\n223\tregisterHandler(\n224\t  EventTypes.REWARD_POOL_FUND,\n225\t  createRewardPoolFundHandler({ db }),\n226\t);\n227\tregisterHandler(\n228\t  EventTypes.POINTS_GRANT,\n229\t  createPointsGrantHandler({\n230\t    db,\n231\t    getSolPrice: async () => {\n232\t      const result = await fetchSolPrice();\n233\t      return result?.price ?? null;\n234\t    },\n235\t  }),\n236\t);\n237\tregisterHandler(\n238\t  EventTypes.CRATE_DROP,\n239\t  createCrateDropHandler({ db }),\n240\t);\n241\t\n242\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n243\tconst eventWorker = createEventWorker(sql, {\n244\t  pollIntervalMs: config.eventQueuePollMs,\n245\t});\n246\teventWorker.start();\n247\tlogger.info(\"Event queue worker started\", {\n248\t  pollIntervalMs: config.eventQueuePollMs,\n249\t});\n250\t\n251\t// Game-specific routes\n252\tapp.route(\n253\t  \"/coinflip\",\n254\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n255\t);\n256\tapp.route(\n257\t  \"/lord\",\n258\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n259\t);\n260\t\n261\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n262\tapp.use(\n263\t  \"/closecall/bet\",\n264\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n265\t);\n266\tapp.use(\n267\t  \"/closecall/bet\",\n268\t  createRateLimitMiddleware({\n269\t    perWallet: config.rateLimitPerWallet,\n270\t    global: config.rateLimitGlobal,\n271\t    windowMs: 60_000,\n272\t  }),\n273\t);\n274\t\n275\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n276\tapp.route(\"/closecall\", createCloseCallRoutes({\n277\t  db,\n278\t  connection,\n279\t  serverKeypair: config.serverKeypair,\n280\t  clockWorker: closeCallClock,\n281\t}));\n282\t\n283\t// Challenge routes — authenticated GET endpoints (require JWT on all methods)\n284\tapp.use(\n285\t  \"/challenges/*\",\n286\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n287\t);\n288\tapp.route(\"/challenges\", createChallengeRoutes({ db }));\n289\t\n290\t// Points routes — authenticated GET endpoints (require JWT on all methods)\n291\tapp.use(\n292\t  \"/points/*\",\n293\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n294\t);\n295\tapp.route(\"/points\", createPointsRoutes({ db }));\n296\t\n297\t// Crate routes — authenticated GET endpoints (require JWT on all methods)\n298\tapp.use(\n299\t  \"/crates/*\",\n300\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n301\t);\n302\tapp.route(\"/crates\", createCrateRoutes({ db }));\n303\t\n304\t// Dogpile routes — public, no auth\n305\tapp.route(\"/dogpile\", createDogpileRoutes({ db }));\n306\t\n307\t// Admin API routes — requires ADMIN_API_KEY env var\n308\tif (config.adminApiKey) {\n309\t  app.route(\"/admin\", createAdminRoutes({ db, adminApiKey: config.adminApiKey }));\n310\t  logger.info(\"Admin API routes enabled at /admin\");\n311\t}\n312\t\n313\t// Leaderboard routes — public, no auth\n314\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n315\t\n316\t// Price routes — public, no auth\n317\tapp.route(\"/price\", createPriceRoutes());\n318\t\n319\t// Round verification routes\n320\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n321\t\n322\t// Health endpoint — wired after worker exists so we can query its status\n323\tapp.route(\n324\t  \"/health\",\n325\t  createHealthRoutes({\n326\t    db,\n327\t    sql,\n328\t    isWorkerRunning: () => worker.isRunning,\n329\t  }),\n330\t);\n331\t\n332\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n333\tif (config.adminToken) {\n334\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n335\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n336\t}\n337\t\n338\tconst port = config.port;\n339\tlogger.info(\"fairness-backend started\", { port });\n340\t\n341\tserve({\n342\t  fetch: app.fetch,\n343\t  port,\n344\t  hostname: \"0.0.0.0\",\n345\t});\n346\t\n347\texport default {\n348\t  port,\n349\t  fetch: app.fetch,\n350\t};\n351\t"}]},"parent_tool_use_id":null,"session_id":"d57cf433-e8fe-4f4f-ba7f-c634be571ed8","uuid":"9fa13fc4-9c76-42fc-87f0-4d8ca6c8e617","timestamp":"2026-04-03T21:43:38.438Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { cors } from \"hono/cors\";\nimport { serve } from \"@hono/node-server\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport postgres from \"postgres\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createAuthDb } from \"./auth-db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createLordRoutes } from \"./routes/lord-create.js\";\nimport { createRoundsRoutes } from \"./routes/rounds.js\";\nimport { createCloseCallRoutes } from \"./routes/closecall.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createProfileRoutes } from \"./routes/profile.js\";\nimport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\nimport { createPriceRoutes } from \"./routes/price.js\";\nimport { createAuthRoutes } from \"./routes/auth.js\";\nimport { createReferralRoutes } from \"./routes/referral.js\";\nimport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\nimport { createChallengeRoutes } from \"./routes/challenges.js\";\nimport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\nimport { createDogpileRoutes } from \"./routes/dogpile.js\";\nimport { createAdminRoutes } from \"./routes/admin.js\";\nimport { createInternalRoutes } from \"./routes/internal.js\";\nimport { swaggerUI } from \"@hono/swagger-ui\";\nimport { spec } from \"./openapi.js\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\nimport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\nimport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\nimport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\nimport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\nimport { fetchSolPrice } from \"./routes/price.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Single postgres pool shared by game DB, auth DB, and all workers\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl, sql);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new Hono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\", \"X-Admin-Key\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// API docs — Swagger UI + raw OpenAPI spec\napp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\napp.get(\"/openapi.json\", (c) => c.json(spec));\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    db,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// Profile routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/profile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/profile\", createProfileRoutes({ db }));\n\n// Public profile routes — no auth required\napp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n\n// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\napp.use(\n  \"/referral/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n\n// JWT auth middleware for game endpoints\napp.use(\n  \"/coinflip/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/lord/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/coinflip/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\napp.use(\n  \"/lord/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  db,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Close Call clock worker — fetches boundary prices + settles open rounds\n// Rounds are created on-demand by players via /closecall/bet\nconst closeCallClock = createCloseCallClockWorker({\n  connection,\n  serverKeypair: config.serverKeypair,\n  db,\n});\ncloseCallClock.start();\n\n// Register event handlers before starting the worker\nregisterHandler(\n  EventTypes.REFERRAL_CLAIM_REQUESTED,\n  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\nregisterHandler(\n  EventTypes.GAME_SETTLED,\n  createGameSettledHandler({ db }),\n);\nregisterHandler(\n  EventTypes.REWARD_POOL_FUND,\n  createRewardPoolFundHandler({ db }),\n);\nregisterHandler(\n  EventTypes.POINTS_GRANT,\n  createPointsGrantHandler({\n    db,\n    getSolPrice: async () => {\n      const result = await fetchSolPrice();\n      return result?.price ?? null;\n    },\n  }),\n);\nregisterHandler(\n  EventTypes.CRATE_DROP,\n  createCrateDropHandler({ db }),\n);\n\n// Event queue worker — processes async side-effects (rewards, notifications, etc.)\nconst eventWorker = createEventWorker(sql, {\n  pollIntervalMs: config.eventQueuePollMs,\n});\neventWorker.start();\nlogger.info(\"Event queue worker started\", {\n  pollIntervalMs: config.eventQueuePollMs,\n});\n\n// Game-specific routes\napp.route(\n  \"/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/lord\",\n  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\napp.use(\n  \"/closecall/bet\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/closecall/bet\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Close Call routes (read endpoints are public, /bet is auth'd above)\napp.route(\"/closecall\", createCloseCallRoutes({\n  db,\n  connection,\n  serverKeypair: config.serverKeypair,\n  clockWorker: closeCallClock,\n}));\n\n// Challenge routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/challenges/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/challenges\", createChallengeRoutes({ db }));\n\n// Points routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/points/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/points\", createPointsRoutes({ db }));\n\n// Crate routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/crates/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/crates\", createCrateRoutes({ db }));\n\n// Dogpile routes — public, no auth\napp.route(\"/dogpile\", createDogpileRoutes({ db }));\n\n// Admin API routes — requires ADMIN_API_KEY env var\nif (config.adminApiKey) {\n  app.route(\"/admin\", createAdminRoutes({ db, adminApiKey: config.adminApiKey }));\n  logger.info(\"Admin API routes enabled at /admin\");\n}\n\n// Leaderboard routes — public, no auth\napp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n\n// Price routes — public, no auth\napp.route(\"/price\", createPriceRoutes());\n\n// Round verification routes\napp.route(\"/rounds\", createRoundsRoutes({ db }));\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    db,\n    sql,\n    isWorkerRunning: () => worker.isRunning,\n  }),\n);\n\n// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\nif (config.adminToken) {\n  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n}\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", { port });\n\nserve({\n  fetch: app.fetch,\n  port,\n  hostname: \"0.0.0.0\",\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":351,"startLine":1,"totalLines":351}}}
