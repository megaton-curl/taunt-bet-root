{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q51DF9dcCBHVVVprc8W5qz","type":"tool_result","content":"1\t/**\n2\t * Event queue worker — polls the event_queue table and dispatches events\n3\t * to registered handlers.\n4\t *\n5\t * Uses the same setTimeout(loop, interval) pattern as the settlement worker.\n6\t * Claims events with FOR UPDATE SKIP LOCKED for safe concurrency.\n7\t */\n8\t\n9\timport type postgres from \"postgres\";\n10\timport { logger } from \"../logger.js\";\n11\timport { getHandler } from \"./handler-registry.js\";\n12\t\n13\texport interface EventWorkerOptions {\n14\t  pollIntervalMs?: number; // default: 1500\n15\t  batchSize?: number; // default: 10\n16\t}\n17\t\n18\texport interface EventWorker {\n19\t  start(): void;\n20\t  /** Stops the worker. Resolves once the current in-flight poll (if any) completes. */\n21\t  stop(): Promise<void>;\n22\t  readonly isRunning: boolean;\n23\t  /** Exposed for testing — runs one poll cycle. */\n24\t  poll(): Promise<void>;\n25\t}\n26\t\n27\tinterface EventRow {\n28\t  id: string;\n29\t  event_type: string;\n30\t  payload: Record<string, unknown>;\n31\t  status: string;\n32\t  attempts: number;\n33\t  max_attempts: number;\n34\t  scheduled_at: Date;\n35\t  started_at: Date | null;\n36\t  completed_at: Date | null;\n37\t  error: string | null;\n38\t  created_at: Date;\n39\t}\n40\t\n41\texport function createEventWorker(\n42\t  sql: postgres.Sql,\n43\t  options?: EventWorkerOptions,\n44\t): EventWorker {\n45\t  const pollIntervalMs = options?.pollIntervalMs ?? 1500;\n46\t  const batchSize = options?.batchSize ?? 10;\n47\t\n48\t  let running = false;\n49\t  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n50\t  let inflightPoll: Promise<void> | null = null;\n51\t\n52\t  async function poll(): Promise<void> {\n53\t    // Claim a batch of pending events atomically\n54\t    const events = await sql<EventRow[]>`\n55\t      UPDATE event_queue\n56\t      SET status = 'processing', started_at = now()\n57\t      WHERE id IN (\n58\t        SELECT id FROM event_queue\n59\t        WHERE status = 'pending' AND scheduled_at <= now()\n60\t        ORDER BY scheduled_at\n61\t        LIMIT ${batchSize}\n62\t        FOR UPDATE SKIP LOCKED\n63\t      )\n64\t      RETURNING *\n65\t    `;\n66\t\n67\t    for (const event of events) {\n68\t      const handler = getHandler(event.event_type);\n69\t\n70\t      if (!handler) {\n71\t        // No handler registered — mark dead immediately\n72\t        await sql`\n73\t          UPDATE event_queue\n74\t          SET status = 'dead',\n75\t              error = ${\"no handler registered for: \" + event.event_type},\n76\t              completed_at = now()\n77\t          WHERE id = ${event.id}\n78\t        `;\n79\t        logger.warn(\"MANUAL REVIEW NEEDED: unhandled event type\", {\n80\t          eventId: event.id,\n81\t          eventType: event.event_type,\n82\t          transition: \"processing → dead\",\n83\t        });\n84\t        continue;\n85\t      }\n86\t\n87\t      try {\n88\t        await handler(event.payload);\n89\t\n90\t        // Success — mark completed\n91\t        await sql`\n92\t          UPDATE event_queue\n93\t          SET status = 'completed', completed_at = now()\n94\t          WHERE id = ${event.id}\n95\t        `;\n96\t        logger.info(\"event processed\", {\n97\t          eventId: event.id,\n98\t          eventType: event.event_type,\n99\t          transition: \"processing → completed\",\n100\t        });\n101\t      } catch (err) {\n102\t        // Failure handling — increment attempts and decide retry vs dead\n103\t        const attempts = event.attempts + 1;\n104\t        const errorMessage = err instanceof Error ? err.message : String(err);\n105\t\n106\t        if (attempts >= event.max_attempts) {\n107\t          // Exceeded max attempts — mark dead\n108\t          await sql`\n109\t            UPDATE event_queue\n110\t            SET status = 'dead',\n111\t                attempts = ${attempts},\n112\t                error = ${errorMessage},\n113\t                completed_at = now()\n114\t            WHERE id = ${event.id}\n115\t          `;\n116\t          logger.warn(\"MANUAL REVIEW NEEDED: event exhausted retries\", {\n117\t            eventId: event.id,\n118\t            eventType: event.event_type,\n119\t            attempts,\n120\t            maxAttempts: event.max_attempts,\n121\t            error: errorMessage,\n122\t            transition: \"processing → dead\",\n123\t          });\n124\t        } else {\n125\t          // Retry with exponential backoff\n126\t          const backoffSeconds = getBackoffSeconds(attempts);\n127\t          await sql`\n128\t            UPDATE event_queue\n129\t            SET status = 'pending',\n130\t                attempts = ${attempts},\n131\t                error = ${errorMessage},\n132\t                scheduled_at = now() + ${backoffSeconds + \" seconds\"}::interval\n133\t            WHERE id = ${event.id}\n134\t          `;\n135\t          logger.error(\"event handler failed, scheduling retry\", {\n136\t            eventId: event.id,\n137\t            eventType: event.event_type,\n138\t            attempts,\n139\t            maxAttempts: event.max_attempts,\n140\t            retryInSeconds: backoffSeconds,\n141\t            error: errorMessage,\n142\t            transition: \"processing → pending\",\n143\t          });\n144\t        }\n145\t      }\n146\t    }\n147\t  }\n148\t\n149\t  async function loop(): Promise<void> {\n150\t    if (!running) return;\n151\t    try {\n152\t      inflightPoll = poll();\n153\t      await inflightPoll;\n154\t    } catch (err) {\n155\t      logger.error(\"event queue worker poll error\", {\n156\t        error: err instanceof Error ? err.message : String(err),\n157\t      });\n158\t    } finally {\n159\t      inflightPoll = null;\n160\t    }\n161\t    if (running) {\n162\t      timeoutId = setTimeout(loop, pollIntervalMs);\n163\t    }\n164\t  }\n165\t\n166\t  return {\n167\t    start() {\n168\t      if (running) return;\n169\t      running = true;\n170\t      logger.info(\"event queue worker started\", { pollIntervalMs, batchSize });\n171\t      loop();\n172\t    },\n173\t    async stop() {\n174\t      running = false;\n175\t      if (timeoutId) {\n176\t        clearTimeout(timeoutId);\n177\t        timeoutId = null;\n178\t      }\n179\t      // Wait for in-flight poll to finish so no work is cut short\n180\t      if (inflightPoll) {\n181\t        await inflightPoll;\n182\t      }\n183\t      logger.info(\"event queue worker stopped\");\n184\t    },\n185\t    get isRunning() {\n186\t      return running;\n187\t    },\n188\t    poll,\n189\t  };\n190\t}\n191\t\n192\t/** Exponential backoff: attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s */\n193\texport function getBackoffSeconds(attempt: number): number {\n194\t  switch (attempt) {\n195\t    case 1:\n196\t      return 5;\n197\t    case 2:\n198\t      return 30;\n199\t    default:\n200\t      return 300;\n201\t  }\n202\t}\n203\t"}]},"parent_tool_use_id":"toolu_01JdQuGjXRPpkWLbNTnG6YkG","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"7ad720dc-a1c3-4eeb-910e-0de91e308ecc","timestamp":"2026-04-03T20:43:12.392Z"}
