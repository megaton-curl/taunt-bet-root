{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012dxydAp6KHkPnxVe76Kon7","type":"tool_result","content":"1\t/**\n2\t * Referral routes — code management, linking, stats, earnings, and claims.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport type postgres from \"postgres\";\n7\timport type { AppEnv } from \"../hono-env.js\";\n8\timport type { Db } from \"../db.js\";\n9\timport type { Config } from \"../config.js\";\n10\timport { logger } from \"../logger.js\";\n11\timport { emitEvent } from \"../queue/emit-event.js\";\n12\timport { EventTypes } from \"../queue/event-types.js\";\n13\t\n14\texport interface ReferralRoutesDeps {\n15\t  db: Db;\n16\t  sql: postgres.Sql;\n17\t  config: Config;\n18\t}\n19\t\n20\t/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\n21\tconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n22\t\n23\texport function createReferralRoutes(deps: ReferralRoutesDeps) {\n24\t  const { db, sql, config } = deps;\n25\t  const app = new Hono<AppEnv>();\n26\t\n27\t  // POST /code — set the player's referral code (permanent, cannot be changed)\n28\t  app.post(\"/code\", async (c) => {\n29\t    const userId = c.get(\"userId\");\n30\t    if (!userId) {\n31\t      return c.json({ error: \"Authentication required\" }, 401);\n32\t    }\n33\t    const profile = await db.getProfileByUserId(userId);\n34\t    if (!profile) {\n35\t      return c.json({ error: \"Profile not found\" }, 404);\n36\t    }\n37\t    const wallet = profile.wallet;\n38\t\n39\t    let body: { code?: unknown };\n40\t    try {\n41\t      body = await c.req.json();\n42\t    } catch {\n43\t      return c.json({ error: \"Invalid request body\" }, 400);\n44\t    }\n45\t\n46\t    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n47\t\n48\t    if (!CODE_REGEX.test(code)) {\n49\t      return c.json(\n50\t        {\n51\t          error: {\n52\t            code: \"INVALID_CODE\",\n53\t            message:\n54\t              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n55\t          },\n56\t        },\n57\t        400,\n58\t      );\n59\t    }\n60\t\n61\t    // Check if the user already has a code — codes are permanent\n62\t    const ownCode = await db.getReferralCodeByUserId(userId);\n63\t    if (ownCode) {\n64\t      return c.json(\n65\t        {\n66\t          error: {\n67\t            code: \"CODE_ALREADY_SET\",\n68\t            message: \"You already have a referral code. Codes cannot be changed.\",\n69\t            retryable: false,\n70\t          },\n71\t        },\n72\t        409,\n73\t      );\n74\t    }\n75\t\n76\t    // Check if this code is already taken by another user\n77\t    const existing = await db.getReferralCodeByCode(code);\n78\t    if (existing && existing.user_id !== userId) {\n79\t      return c.json(\n80\t        {\n81\t          error: {\n82\t            code: \"CODE_TAKEN\",\n83\t            message: \"This referral code is already in use\",\n84\t            retryable: false,\n85\t          },\n86\t        },\n87\t        409,\n88\t      );\n89\t    }\n90\t\n91\t    try {\n92\t      const result = await db.insertReferralCode(userId, wallet, code);\n93\t      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n94\t      return c.json({\n95\t        code: result.code,\n96\t      });\n97\t    } catch (err) {\n98\t      // Handle race condition: another wallet grabbed the code between check and insert\n99\t      const msg = err instanceof Error ? err.message : String(err);\n100\t      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n101\t        return c.json(\n102\t          {\n103\t            error: {\n104\t              code: \"CODE_TAKEN\",\n105\t              message: \"This referral code is already in use\",\n106\t              retryable: false,\n107\t            },\n108\t          },\n109\t          409,\n110\t        );\n111\t      }\n112\t      logger.error(\"Failed to set referral code\", {\n113\t        err: String(err),\n114\t        userId,\n115\t        wallet,\n116\t      });\n117\t      return c.json({ error: \"Failed to set referral code\" }, 500);\n118\t    }\n119\t  });\n120\t"}]},"parent_tool_use_id":"toolu_01WnnsxD6PGcCqynR9abaSne","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"4676d4cc-d7a2-43ba-a0d1-7e7360f411b6","timestamp":"2026-04-03T20:42:44.559Z"}
