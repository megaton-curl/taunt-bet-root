{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G2PpC6Xt8fBVb5kJYXa3U1","type":"tool_result","content":"100\t    logger.info(\"auth challenge issued\", { wallet: body.wallet, nonce });\n101\t\n102\t    return c.json({\n103\t      nonce,\n104\t      message,\n105\t      expiresAt: expiresAt.toISOString(),\n106\t    });\n107\t  });\n108\t\n109\t  // POST /verify — consume challenge, verify signature, issue tokens\n110\t  app.post(\"/verify\", async (c) => {\n111\t    let body: { nonce: string; wallet: string; signature: string };\n112\t    try {\n113\t      body = await c.req.json();\n114\t      if (\n115\t        typeof body.nonce !== \"string\" ||\n116\t        typeof body.wallet !== \"string\" ||\n117\t        typeof body.signature !== \"string\"\n118\t      ) {\n119\t        return c.json({ error: \"nonce, wallet, and signature are required\" }, 400);\n120\t      }\n121\t    } catch {\n122\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n123\t    }\n124\t\n125\t    // Atomically consume the challenge\n126\t    const challenge = await authDb.consumeChallenge(body.nonce);\n127\t    if (!challenge) {\n128\t      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n129\t        nonce: body.nonce,\n130\t        wallet: body.wallet,\n131\t      });\n132\t      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n133\t    }\n134\t\n135\t    // Verify wallet matches challenge\n136\t    if (challenge.wallet !== body.wallet) {\n137\t      logger.warn(\"auth verify rejected: wallet mismatch\", {\n138\t        nonce: body.nonce,\n139\t        challengeWallet: challenge.wallet,\n140\t        requestWallet: body.wallet,\n141\t      });\n142\t      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n143\t    }\n144\t\n145\t    // Verify Ed25519 signature over the challenge message\n146\t    let sigBytes: Uint8Array;\n147\t    let pubkeyBytes: Uint8Array;\n148\t    try {\n149\t      sigBytes = bs58.decode(body.signature);\n150\t      pubkeyBytes = bs58.decode(body.wallet);\n151\t    } catch {\n152\t      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n153\t    }\n154\t\n155\t    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n156\t      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n157\t    }\n158\t\n159\t    const messageBytes = new TextEncoder().encode(challenge.message);\n160\t    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n161\t    if (!valid) {\n162\t      logger.warn(\"auth verify rejected: signature verification failed\", {\n163\t        wallet: body.wallet,\n164\t      });\n165\t      return c.json({ error: \"Invalid signature\" }, 401);\n166\t    }\n167\t\n168\t    let profile;\n169\t    try {\n170\t      profile = await db.getProfileByWallet(body.wallet);\n171\t      if (!profile) {\n172\t        profile = await db.createPlayerProfile(body.wallet);\n173\t        logger.info(\"player profile auto-created\", { wallet: body.wallet, userId: profile.user_id });\n174\t      }\n175\t    } catch (e) {\n176\t      logger.error(\"profile creation failed\", { wallet: body.wallet, error: e });\n177\t      return c.json({ error: \"Failed to establish player profile\" }, 500);\n178\t    }\n179\t\n180\t    // Issue JWT access token\n181\t    const now = Math.floor(Date.now() / 1000);\n182\t    const accessToken = await issueAccessToken(\n183\t      jwtSecret,\n184\t      profile.user_id,\n185\t      now,\n186\t      accessTokenTtlSeconds,\n187\t    );\n188\t\n189\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n190\t\n191\t    // Generate opaque refresh token\n192\t    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n193\t    const refreshTokenHash = hashToken(refreshTokenRaw);\n194\t    const familyId = randomBytes(16).toString(\"hex\");\n195\t    const refreshExpiresAt = new Date(\n196\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n197\t    );\n198\t\n199\t    await authDb.insertRefreshToken(\n200\t      profile.user_id,\n201\t      body.wallet,\n202\t      refreshTokenHash,\n203\t      familyId,\n204\t      refreshExpiresAt,\n205\t    );\n206\t\n207\t    logger.info(\"auth session created\", { wallet: body.wallet, userId: profile.user_id });\n208\t\n209\t    return c.json({\n210\t      accessToken,\n211\t      accessExpiresAt,\n212\t      refreshToken: refreshTokenRaw,\n213\t      refreshExpiresAt: refreshExpiresAt.toISOString(),\n214\t    });\n215\t  });\n216\t\n217\t  // POST /refresh — rotate refresh token, issue new access token\n218\t  app.post(\"/refresh\", async (c) => {\n219\t    let body: { refreshToken: string };\n220\t    try {\n221\t      body = await c.req.json();\n222\t      if (typeof body.refreshToken !== \"string\") {\n223\t        return c.json({ error: \"refreshToken is required\" }, 400);\n224\t      }\n225\t    } catch {\n226\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n227\t    }\n228\t\n229\t    const tokenHash = hashToken(body.refreshToken);\n230\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n231\t\n232\t    if (!stored) {\n233\t      logger.warn(\"auth refresh rejected: token not found\");\n234\t      return c.json({ error: \"Invalid refresh token\" }, 401);\n235\t    }\n236\t\n237\t    // Reuse detection: if the token was already revoked, someone replayed it.\n238\t    // Revoke the entire family as a precaution.\n239\t    if (stored.revoked) {\n240\t      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n241\t        userId: stored.user_id,\n242\t        wallet: stored.wallet,\n243\t        familyId: stored.family_id,\n244\t      });\n245\t      await authDb.revokeTokenFamily(stored.family_id);\n246\t      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n247\t    }\n248\t\n249\t    // Check expiry\n250\t    if (new Date() > stored.expires_at) {\n251\t      logger.warn(\"auth refresh rejected: token expired\", {\n252\t        userId: stored.user_id,\n253\t        wallet: stored.wallet,\n254\t      });\n255\t      await authDb.revokeRefreshToken(stored.id);\n256\t      return c.json({ error: \"Refresh token expired\" }, 401);\n257\t    }\n258\t\n259\t    // Revoke old token\n260\t    await authDb.revokeRefreshToken(stored.id);\n261\t\n262\t    // Issue new access token\n263\t    const now = Math.floor(Date.now() / 1000);\n264\t    const accessToken = await issueAccessToken(\n265\t      jwtSecret,\n266\t      stored.user_id,\n267\t      now,\n268\t      accessTokenTtlSeconds,\n269\t    );\n270\t\n271\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n272\t\n273\t    // Issue new refresh token in the same family\n274\t    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n275\t    const newRefreshHash = hashToken(newRefreshRaw);\n276\t    const newRefreshExpiresAt = new Date(\n277\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n278\t    );\n279\t\n280\t    await authDb.insertRefreshToken(\n281\t      stored.user_id,\n282\t      stored.wallet,\n283\t      newRefreshHash,\n284\t      stored.family_id,\n285\t      newRefreshExpiresAt,\n286\t    );\n287\t\n288\t    logger.debug(\"auth token refreshed\", { userId: stored.user_id, wallet: stored.wallet });\n289\t\n290\t    return c.json({\n291\t      accessToken,\n292\t      accessExpiresAt,\n293\t      refreshToken: newRefreshRaw,\n294\t      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n295\t    });\n296\t  });\n297\t\n298\t  // POST /logout — revoke refresh token\n299\t  app.post(\"/logout\", async (c) => {"}]},"parent_tool_use_id":"toolu_01WnnsxD6PGcCqynR9abaSne","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"8ed80ecb-5721-4d6d-8d30-5312db8869ac","timestamp":"2026-04-03T20:42:36.768Z"}
