{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KQbtmYRo3jQZ7dqUxEhkLt","type":"tool_result","content":"400\t    // Clean tables for isolation\n401\t    await rawSql`TRUNCATE rounds, closecall_rounds, closecall_candles, operator_events, event_queue, game_entries, transactions, player_profiles, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, reward_pool_fundings, point_grants, player_points, dogpile_events, crate_drops, progress_events, challenge_assignments, bonus_completions RESTART IDENTITY CASCADE`;\n402\t    // Reset reward_pool balance to zero (keep singleton row from migration seed)\n403\t    await rawSql`UPDATE reward_pool SET balance_lamports = 0, lifetime_funded = 0, lifetime_paid = 0, updated_at = now() WHERE id = 1`;\n404\t\n405\t    // Reset PlatformConfig cache so each test reads from its own mock\n406\t    resetPlatformConfigCache();\n407\t\n408\t    // Fresh mock Connection\n409\t    mockConn = new MockConnection();\n410\t\n411\t    // Pre-populate mock with entropy and config accounts\n412\t    mockConn.setAccount(entropyAccount, entropyData);\n413\t\n414\t    const [configPda] = PublicKey.findProgramAddressSync(\n415\t      [Buffer.from(\"coinflip_config\")],\n416\t      COINFLIP_PROGRAM_ID,\n417\t    );\n418\t    mockConn.setAccount(\n419\t      configPda,\n420\t      await buildConfigAccountData(treasuryKeypair.publicKey),\n421\t      { owner: COINFLIP_PROGRAM_ID },\n422\t    );\n423\t\n424\t    // PlatformConfig account — settlement reads fee_bps from here\n425\t    const [platformConfigPda] = derivePlatformConfigPda();\n426\t    mockConn.setAccount(\n427\t      platformConfigPda,\n428\t      buildPlatformConfigData(treasuryKeypair.publicKey, 500), // 500 bps = 5%\n429\t      { owner: PLATFORM_PROGRAM_ID },\n430\t    );\n431\t\n432\t    // Build the Hono app (no rate limiting for tests)\n433\t    app = new Hono();\n434\t\n435\t    app.use(\n436\t      \"/coinflip/*\",\n437\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n438\t    );\n439\t\n440\t    app.route(\n441\t      \"/coinflip\",\n442\t      createCoinflipRoutes({\n443\t        db,\n444\t        connection: mockConn as unknown as Connection,\n445\t        serverKeypair,\n446\t      }),\n447\t    );\n448\t\n449\t    app.route(\"/rounds\", createRoundsRoutes({ db }));\n450\t  });\n451\t\n452\t  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n453\t    const wallet = creatorKeypair.publicKey.toBase58();\n454\t    const token = await makeJwt(wallet);\n455\t\n456\t    // ------------------------------------------------------------------\n457\t    // 1. POST /coinflip/create\n458\t    // ------------------------------------------------------------------\n459\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n460\t\n461\t    const createRes = await app.request(\"/coinflip/create\", {\n462\t      method: \"POST\",\n463\t      headers: {\n464\t        \"Content-Type\": \"application/json\",\n465\t        \"Authorization\": `Bearer ${token}`,\n466\t      },\n467\t      body: JSON.stringify(body),\n468\t    });\n469\t\n470\t    expect(createRes.status).toBe(200);\n471\t    const createJson = (await createRes.json()) as {\n472\t      transaction: string;\n473\t      matchPda: string;\n474\t      matchId: string;\n475\t      commitment: string;\n476\t      lastValidBlockHeight: number;\n477\t    };\n478\t    expect(createJson.transaction).toBeDefined();\n479\t    expect(createJson.matchPda).toBeDefined();\n480\t    expect(createJson.commitment).toBeDefined();\n481\t    expect(createJson.lastValidBlockHeight).toBeDefined();\n482\t\n483\t    const matchPda = createJson.matchPda;\n484\t    const commitmentHex = createJson.commitment;\n485\t    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n486\t\n487\t    // ------------------------------------------------------------------\n488\t    // 2. Verify DB state — round in \"created\" phase\n489\t    // ------------------------------------------------------------------\n490\t    const round = await db.getRoundByPda(matchPda);\n491\t    expect(round).toBeDefined();\n492\t    expect(round!.phase).toBe(\"created\");\n493\t    expect(round!.game).toBe(\"coinflip\");\n494\t    expect(round!.creator).toBe(wallet);\n495\t    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n496\t    expect(round!.side).toBe(SIDE_HEADS);\n497\t    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n498\t    expect(round!.secret).toBeDefined();\n499\t    expect(round!.secret.length).toBe(32);\n500\t\n501\t    // Verify operator event was logged\n502\t    const events =\n503\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n504\t    expect(events.length).toBe(1);\n505\t    expect(events[0]!.event_type).toBe(\"secret_generated\");\n506\t\n507\t    // ------------------------------------------------------------------\n508\t    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n509\t    // ------------------------------------------------------------------\n510\t    const matchPubkey = new PublicKey(matchPda);\n511\t    const targetSlot = 150n;\n512\t    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n513\t\n514\t    const matchAccountData = await buildMatchAccountData({\n515\t      creator: creatorKeypair.publicKey,\n516\t      opponent: opponentKeypair.publicKey,\n517\t      server: serverKeypair.publicKey,\n518\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n519\t      creatorSide: SIDE_HEADS,\n520\t      phase: PHASE_LOCKED,\n521\t      commitment: commitmentBuf,\n522\t      algorithmVer: 1,\n523\t      targetSlot,\n524\t      resolveDeadline,\n525\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n526\t    });\n527\t\n528\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n529\t      owner: COINFLIP_PROGRAM_ID,\n530\t    });\n531\t\n532\t    // Set current slot past target_slot so settlement triggers immediately\n533\t    mockConn.slot = 200;\n534\t\n535\t    // ------------------------------------------------------------------\n536\t    // 4. Create worker + retry settler, trigger poll\n537\t    // ------------------------------------------------------------------\n538\t    let settlePromise: Promise<void> | null = null;\n539\t\n540\t    const retrySettler = createRetrySettler({\n541\t      db,\n542\t      connection: mockConn as unknown as Connection,\n543\t      settleRound: (pda) =>\n544\t        settleMatch(\n545\t          {\n546\t            db,\n547\t            connection: mockConn as unknown as Connection,\n548\t            serverKeypair,\n549\t            entropyAccount,"}]},"parent_tool_use_id":"toolu_01KK69n8KaMQMkhjuBrdEk9C","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"d1994164-c994-4005-947c-bfe87a5b1c9e","timestamp":"2026-04-03T20:42:44.682Z"}
