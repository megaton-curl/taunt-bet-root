   }\n200\t      logger.error(\"coinflip create failed: round insert error\", {\n201\t        wallet: body.wallet,\n202\t        matchPda: matchPdaStr,\n203\t        matchId: matchId.toString(\"hex\"),\n204\t        error: err instanceof Error ? err.message : String(err),\n205\t      });\n206\t      throw err;\n207\t    }\n208\t\n209\t    // 9. Write participation-time game entry (visible before settlement)\n210\t    try {\n211\t      if (profile) {\n212\t        await db.upsertGameEntry({\n213\t          userId: profile.user_id,\n214\t          wallet: body.wallet,\n215\t          game: \"coinflip\",\n216\t          roundPda: matchPdaStr,\n217\t          matchId: matchId.toString(\"hex\"),\n218\t          amountLamports: body.amountLamports,\n219\t          side: body.side === 0 ? \"heads\" : \"tails\",\n220\t        });\n221\t      }\n222\t    } catch (err) {\n223\t      // Non-fatal — entry will be created at settlement if this fails\n224\t      logger.warn(\"coinflip create: game_entry insert failed\", {\n225\t        error: err instanceof Error ? err.message : String(err),\n226\t      });\n227\t    }\n228\t\n229\t    // 10. Write operator event\n230\t    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n231\t      creator: body.wallet,\n232\t      amountLamports: body.amountLamports,\n233\t      side: body.side,\n234\t      matchId: matchId.toString(\"hex\"),\n235\t    });\n236\t\n237\t    // 9b. Subscribe to PDA for instant join detection via WebSocket\n238\t    pdaWatcher?.watch(matchPdaStr);\n239\t\n240\t    logger.info(\"coinflip create prepared\", {\n241\t      wallet: body.wallet,\n242\t      matchPda: matchPdaStr,\n243\t      matchId: matchId.toString(\"hex\"),\n244\t      amountLamports: body.amountLamports,\n245\t      side: body.side,\n246\t      lastValidBlockHeight,\n247\t    });\n248\t\n249\t    // 10. Return response"}]},"parent_tool_use_id":"toolu_01WnnsxD6PGcCqynR9abaSne","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid