01\t\n302\t  beforeAll(async () => {\n303\t    rawSql = makeSql();\n304\t    await rawSql`\n305\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n306\t    `;\n307\t    await rawSql`\n308\t      CREATE TABLE referral_codes (\n309\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n310\t        user_id TEXT NOT NULL UNIQUE,\n311\t        wallet TEXT NOT NULL UNIQUE,\n312\t        code TEXT NOT NULL UNIQUE,\n313\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n314\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n315\t      )\n316\t    `;\n317\t    await rawSql`\n318\t      CREATE TABLE referral_links (\n319\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n320\t        referrer_user_id TEXT NOT NULL,\n321\t        referee_user_id TEXT NOT NULL UNIQUE,\n322\t        referrer_wallet TEXT NOT NULL,\n323\t        referee_wallet TEXT NOT NULL,\n324\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n325\t      )\n326\t    `;\n327\t    await rawSql`\n328\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n329\t    `;\n330\t    await rawSql`\n331\t      CREATE TABLE referral_earnings (\n332\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n333\t        referrer_user_id TEXT NOT NULL,\n334\t        referee_user_id TEXT NOT NULL,\n335\t        referrer_wallet TEXT NOT NULL,\n336\t        referee_wallet TEXT NOT NULL,\n337\t        round_id TEXT NOT NULL,\n338\t        game_type TEXT NOT NULL,\n339\t        wager_lamports BIGINT NOT NULL,\n340\t        fee_lamports BIGINT NOT NULL,\n341\t        referrer_earned_lamports BIGINT NOT NULL,\n342\t        referrer_rate_bps INTEGER NOT NULL,\n343\t        referee_rebate_lamports BIGINT NOT NULL,\n344\t        referee_rebate_rate_bps INTEGER NOT NULL,\n345\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n346\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n347\t      )\n348\t    `;\n349\t    await rawSql`\n350\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n351\t    `;\n352\t    await rawSql`\n353\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n354\t    `;\n355\t    await rawSql`\n356\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n357\t    `;\n358\t    await rawSql`\n359\t      CREATE TABLE referral_claims (\n360\t        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n361\t        user_id TEXT NOT NULL,\n362\t        wallet TEXT NOT NULL,\n363\t        amount_lamports BIGINT NOT NULL,\n364\t        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n365\t        retry_count INTEGER NOT NULL DEFAULT 0,\n366\t        tx_signature TEXT,\n367\t        error TEXT,\n368\t        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n369\t        processed_at TIMESTAMPTZ\n370\t      )\n371\t    `;\n372\t    await rawSql`\n373\t      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n374\t    `;\n375\t    await rawSql`\n376\t      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n377\t    `;\n378\t    await rawSql`\n379\t      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n380\t    `;\n381\t    await rawSql`\n382\t      CREATE TABLE referral_kol_rates (\n383\t        user_id TEXT PRIMARY KEY,\n384\t        wallet TEXT NOT NULL UNIQUE,\n385\t        rate_bps INTEGER NOT NULL,\n386\t        set_by TEXT NOT NULL,\n387\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n388\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n389\t      )\n390\t    `;\n391\t    db = createDb(DATABASE_URL, rawSql);\n392\t  });\n3