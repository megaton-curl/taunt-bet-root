{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EmuNo9QVdCrqGmNuoszGWR","type":"tool_result","content":"100\t  lastRawTx: Buffer | null = null;\n101\t\n102\t  set slot(s: number) {\n103\t    this._slot = s;\n104\t  }\n105\t  get slot() {\n106\t    return this._slot;\n107\t  }\n108\t\n109\t  setAccount(\n110\t    pubkey: PublicKey,\n111\t    data: Buffer,\n112\t    opts?: { lamports?: number; owner?: PublicKey },\n113\t  ) {\n114\t    this._accounts.set(pubkey.toBase58(), {\n115\t      data,\n116\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n117\t      owner: opts?.owner ?? SystemProgram.programId,\n118\t      executable: false,\n119\t    });\n120\t  }\n121\t\n122\t  removeAccount(pubkey: PublicKey) {\n123\t    this._accounts.delete(pubkey.toBase58());\n124\t  }\n125\t\n126\t  async getLatestBlockhash() {\n127\t    return {\n128\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n129\t      lastValidBlockHeight: 999_999,\n130\t    };\n131\t  }\n132\t\n133\t  async getSlot() {\n134\t    return this._slot;\n135\t  }\n136\t\n137\t  async getAccountInfo(pubkey: PublicKey) {\n138\t    const acc = this._accounts.get(pubkey.toBase58());\n139\t    if (!acc) return null;\n140\t    return { ...acc, rentEpoch: 0 };\n141\t  }\n142\t\n143\t  async getProgramAccounts(\n144\t    programId: PublicKey,\n145\t    config?: {\n146\t      filters?: Array<\n147\t        | { dataSize: number }\n148\t        | { memcmp: { offset: number; bytes: string } }\n149\t      >;\n150\t    },\n151\t  ) {\n152\t    const results: Array<{\n153\t      pubkey: PublicKey;\n154\t      account: {\n155\t        data: Buffer;\n156\t        lamports: number;\n157\t        owner: PublicKey;\n158\t        executable: boolean;\n159\t        rentEpoch: number;\n160\t      };\n161\t    }> = [];\n162\t\n163\t    for (const [key, acc] of this._accounts) {\n164\t      if (!acc.owner.equals(programId)) continue;\n165\t\n166\t      let matches = true;\n167\t      if (config?.filters) {\n168\t        for (const filter of config.filters) {\n169\t          if (\"dataSize\" in filter) {\n170\t            if (acc.data.length !== filter.dataSize) {\n171\t              matches = false;\n172\t              break;\n173\t            }\n174\t          }\n175\t          if (\"memcmp\" in filter) {\n176\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n177\t            const actual = acc.data.subarray(\n178\t              filter.memcmp.offset,\n179\t              filter.memcmp.offset + expected.length,\n180\t            );\n181\t            if (Buffer.compare(actual, expected) !== 0) {\n182\t              matches = false;\n183\t              break;\n184\t            }\n185\t          }\n186\t        }\n187\t      }\n188\t\n189\t      if (matches) {\n190\t        results.push({\n191\t          pubkey: new PublicKey(key),\n192\t          account: { ...acc, rentEpoch: 0 },\n193\t        });\n194\t      }\n195\t    }\n196\t    return results;\n197\t  }\n198\t\n199\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n200\t    this.lastRawTx = Buffer.from(rawTx);\n201\t    // Return a deterministic fake signature\n202\t    return bs58.encode(Buffer.alloc(64, 0x01));\n203\t  }\n204\t\n205\t  async confirmTransaction() {\n206\t    return { value: { err: null }, context: { slot: this._slot } };\n207\t  }\n208\t\n209\t  async getBlockTime(_slot: number) {\n210\t    return Math.floor(Date.now() / 1000);\n211\t  }\n212\t\n213\t  async getBalance() {\n214\t    return 2 * LAMPORTS_PER_SOL;\n215\t  }\n216\t}\n217\t\n218\t// ---------------------------------------------------------------------------\n219\t// Account data builders\n220\t// ---------------------------------------------------------------------------\n221\t\n222\tasync function buildMatchAccountData(params: {\n223\t  creator: PublicKey;\n224\t  opponent: PublicKey;\n225\t  server: PublicKey;\n226\t  entryAmount: bigint;\n227\t  creatorSide: number;\n228\t  phase: number;\n229\t  commitment: Buffer;\n230\t  algorithmVer: number;\n231\t  targetSlot: bigint;\n232\t  resolveDeadline: bigint;\n233\t  matchId: Buffer;\n234\t}): Promise<Buffer> {\n235\t  return encodeCoinflipMatch({\n236\t    creator: params.creator,\n237\t    opponent: params.opponent,\n238\t    server: params.server,\n239\t    entryAmount: params.entryAmount,\n240\t    creatorSide: params.creatorSide,\n241\t    phase: params.phase,\n242\t    commitment: [...params.commitment],\n243\t    algorithmVer: params.algorithmVer,\n244\t    targetSlot: params.targetSlot,\n245\t    resolveDeadline: params.resolveDeadline,\n246\t    resultHash: new Array(32).fill(0),\n247\t    result: 0,\n248\t    winner: PublicKey.default,\n249\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),"}]},"parent_tool_use_id":"toolu_01KK69n8KaMQMkhjuBrdEk9C","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"48d9c8c0-a651-42c7-8470-88ed076a167c","timestamp":"2026-04-03T20:42:40.276Z"}
