{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SfppGfy1DdtnDFWHAUe5G6","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createInternalRoutes } from \"./routes/internal.js\";\n21\timport { swaggerUI } from \"@hono/swagger-ui\";\n22\timport { spec } from \"./openapi.js\";\n23\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n24\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n25\timport { createSettlementWorker } from \"./worker/settlement.js\";\n26\timport { settleRound } from \"./worker/settle-tx.js\";\n27\timport { createRetrySettler } from \"./worker/retry.js\";\n28\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n29\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n30\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n31\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n32\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n33\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n34\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n35\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n36\timport { fetchSolPrice } from \"./routes/price.js\";\n37\timport { logger } from \"./logger.js\";\n38\t\n39\tconst config = loadConfig();\n40\t\n41\t// Single postgres pool shared by game DB, auth DB, and all workers\n42\tconst sql = postgres(config.databaseUrl);\n43\tconst db = createDb(config.databaseUrl, sql);\n44\tconst authDb = createAuthDb(sql);\n45\t\n46\tconst connection = new Connection(config.rpcUrl, {\n47\t  commitment: \"confirmed\",\n48\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n49\t});\n50\t\n51\tconst app = new Hono();\n52\t\n53\tapp.use(\n54\t  \"*\",\n55\t  cors({\n56\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n57\t    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n58\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n59\t  }),\n60\t);\n61\t\n62\t// Request logging — correlate frontend fetch timing with server-side processing\n63\tapp.use(\"*\", async (c, next) => {\n64\t  const start = Date.now();\n65\t  await next();\n66\t  const ms = Date.now() - start;\n67\t  const method = c.req.method;\n68\t  const path = c.req.path;\n69\t  // Skip noisy health checks and OPTIONS preflight\n70\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n71\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n72\t});\n73\t\n74\t// API docs — Swagger UI + raw OpenAPI spec\n75\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n76\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n77\t\n78\t// Auth routes — no JWT middleware (these are the login endpoints)\n79\t// Lighter rate limiting by IP for auth endpoints\n80\tapp.use(\n81\t  \"/auth/*\",\n82\t  createRateLimitMiddleware({\n83\t    perWallet: 20,\n84\t    global: config.rateLimitGlobal,\n85\t    windowMs: 60_000,\n86\t  }),\n87\t);\n88\t\n89\tapp.route(\n90\t  \"/auth\",\n91\t  createAuthRoutes({\n92\t    authDb,\n93\t    db,\n94\t    jwtSecret: config.jwtSecret,\n95\t    cluster: config.cluster,\n96\t    challengeTtlSeconds: config.challengeTtlSeconds,\n97\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n98\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n99\t  }),\n100\t);\n101\t\n102\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n103\tapp.use(\n104\t  \"/profile/*\",\n105\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n106\t);\n107\tapp.route(\"/profile\", createProfileRoutes({ db }));\n108\t\n109\t// Public profile routes — no auth required\n110\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n111\t\n112\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n113\tapp.use(\n114\t  \"/referral/*\",\n115\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n116\t);\n117\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n118\t\n119\t// JWT auth middleware for game endpoints\n120\tapp.use(\n121\t  \"/coinflip/*\",\n122\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n123\t);\n124\tapp.use(\n125\t  \"/lord/*\",\n126\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n127\t);\n128\t\n129\t// Rate limiting — per-wallet and global limits on POST requests\n130\tapp.use(\n131\t  \"/coinflip/*\",\n132\t  createRateLimitMiddleware({\n133\t    perWallet: config.rateLimitPerWallet,\n134\t    global: config.rateLimitGlobal,\n135\t    windowMs: 60_000,\n136\t  }),\n137\t);\n138\tapp.use(\n139\t  \"/lord/*\",\n140\t  createRateLimitMiddleware({\n141\t    perWallet: config.rateLimitPerWallet,\n142\t    global: config.rateLimitGlobal,\n143\t    windowMs: 60_000,\n144\t  }),\n145\t);\n146\t\n147\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n148\tconst entropyAccount = new PublicKey(config.entropyAccount);\n149\tconst retrySettler = createRetrySettler({\n150\t  db,\n151\t  connection,\n152\t  settleRound: (pda) =>\n153\t    settleRound(\n154\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n155\t      pda,\n156\t    ),\n157\t});\n158\t\n159\t// PDA watcher — WebSocket-based instant join detection\n160\tconst pdaWatcher = createPdaWatcher({\n161\t  connection,\n162\t  serverKey: config.serverKeypair.publicKey,\n163\t  db,\n164\t  onJoinDetected: async (pda, targetSlot) => {\n165\t    // Update DB phase if still in 'created'\n166\t    const round = await db.getRoundByPda(pda);\n167\t    if (round && round.phase === \"created\") {\n168\t      await db.updateRoundPhase(pda, \"locked\", {\n169\t        target_slot: targetSlot.toString(),\n170\t      });\n171\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n172\t        targetSlot: targetSlot.toString(),\n173\t        source: \"pda-watcher\",\n174\t        game: round.game,\n175\t      });\n176\t    }\n177\t\n178\t    // Check if target slot already passed — settle immediately if so\n179\t    const currentSlot = await connection.getSlot();\n180\t    if (BigInt(currentSlot) >= targetSlot) {\n181\t      await retrySettler.attemptSettle(pda);\n182\t      pdaWatcher.unwatch(pda);\n183\t    }\n184\t    // If target slot not reached yet, poll worker will pick it up next cycle\n185\t  },\n186\t});\n187\t\n188\tconst worker = createSettlementWorker({\n189\t  db,\n190\t  connection,\n191\t  serverKey: config.serverKeypair.publicKey,\n192\t  pollIntervalMs: config.workerPollIntervalMs,\n193\t  onSettleReady: async (pda) => {\n194\t    await retrySettler.attemptSettle(pda);\n195\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n196\t  },\n197\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n198\t});\n199\tworker.start();\n200\t\n201\t// Close Call clock worker — fetches boundary prices + settles open rounds\n202\t// Rounds are created on-demand by players via /closecall/bet\n203\tconst closeCallClock = createCloseCallClockWorker({\n204\t  connection,\n205\t  serverKeypair: config.serverKeypair,\n206\t  db,\n207\t});\n208\tcloseCallClock.start();\n209\t\n210\t// Register event handlers before starting the worker\n211\tregisterHandler(\n212\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n213\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n214\t);\n215\tregisterHandler(\n216\t  EventTypes.GAME_SETTLED,\n217\t  createGameSettledHandler({ db }),\n218\t);\n219\tregisterHandler(\n220\t  EventTypes.REWARD_POOL_FUND,\n221\t  createRewardPoolFundHandler({ db }),\n222\t);\n223\tregisterHandler(\n224\t  EventTypes.POINTS_GRANT,\n225\t  createPointsGrantHandler({\n226\t    db,\n227\t    getSolPrice: async () => {\n228\t      const result = await fetchSolPrice();\n229\t      return result?.price ?? null;\n230\t    },\n231\t  }),\n232\t);\n233\tregisterHandler(\n234\t  EventTypes.CRATE_DROP,\n235\t  createCrateDropHandler({ db }),\n236\t);\n237\t\n238\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n239\tconst eventWorker = createEventWorker(sql, {\n240\t  pollIntervalMs: config.eventQueuePollMs,\n241\t});\n242\teventWorker.start();\n243\tlogger.info(\"Event queue worker started\", {\n244\t  pollIntervalMs: config.eventQueuePollMs,\n245\t});\n246\t\n247\t// Game-specific routes\n248\tapp.route(\n249\t  \"/coinflip\",\n250\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n251\t);\n252\tapp.route(\n253\t  \"/lord\",\n254\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n255\t);\n256\t\n257\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n258\tapp.use(\n259\t  \"/closecall/bet\",\n260\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n261\t);\n262\tapp.use(\n263\t  \"/closecall/bet\",\n264\t  createRateLimitMiddleware({\n265\t    perWallet: config.rateLimitPerWallet,\n266\t    global: config.rateLimitGlobal,\n267\t    windowMs: 60_000,\n268\t  }),\n269\t);\n270\t\n271\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n272\tapp.route(\"/closecall\", createCloseCallRoutes({\n273\t  db,\n274\t  connection,\n275\t  serverKeypair: config.serverKeypair,\n276\t  clockWorker: closeCallClock,\n277\t}));\n278\t\n279\t// Leaderboard routes — public, no auth\n280\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n281\t\n282\t// Price routes — public, no auth\n283\tapp.route(\"/price\", createPriceRoutes());\n284\t\n285\t// Round verification routes\n286\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n287\t\n288\t// Health endpoint — wired after worker exists so we can query its status\n289\tapp.route(\n290\t  \"/health\",\n291\t  createHealthRoutes({\n292\t    db,\n293\t    sql,\n294\t    isWorkerRunning: () => worker.isRunning,\n295\t  }),\n296\t);\n297\t\n298\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n299\tif (config.adminToken) {\n300\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n301\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n302\t}\n303\t\n304\tconst port = config.port;\n305\tlogger.info(\"fairness-backend started\", { port });\n306\t\n307\tserve({\n308\t  fetch: app.fetch,\n309\t  port,\n310\t  hostname: \"0.0.0.0\",\n311\t});\n312\t\n313\texport default {\n314\t  port,\n315\t  fetch: app.fetch,\n316\t};\n317\t"}]},"parent_tool_use_id":null,"session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"a3b067a4-f577-48ed-949c-b17d830c0867","timestamp":"2026-04-03T20:44:52.263Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { cors } from \"hono/cors\";\nimport { serve } from \"@hono/node-server\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport postgres from \"postgres\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createAuthDb } from \"./auth-db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createLordRoutes } from \"./routes/lord-create.js\";\nimport { createRoundsRoutes } from \"./routes/rounds.js\";\nimport { createCloseCallRoutes } from \"./routes/closecall.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createProfileRoutes } from \"./routes/profile.js\";\nimport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\nimport { createPriceRoutes } from \"./routes/price.js\";\nimport { createAuthRoutes } from \"./routes/auth.js\";\nimport { createReferralRoutes } from \"./routes/referral.js\";\nimport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\nimport { createInternalRoutes } from \"./routes/internal.js\";\nimport { swaggerUI } from \"@hono/swagger-ui\";\nimport { spec } from \"./openapi.js\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\nimport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\nimport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\nimport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\nimport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\nimport { fetchSolPrice } from \"./routes/price.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Single postgres pool shared by game DB, auth DB, and all workers\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl, sql);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new Hono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// API docs — Swagger UI + raw OpenAPI spec\napp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\napp.get(\"/openapi.json\", (c) => c.json(spec));\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    db,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// Profile routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/profile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/profile\", createProfileRoutes({ db }));\n\n// Public profile routes — no auth required\napp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n\n// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\napp.use(\n  \"/referral/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n\n// JWT auth middleware for game endpoints\napp.use(\n  \"/coinflip/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/lord/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/coinflip/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\napp.use(\n  \"/lord/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  db,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Close Call clock worker — fetches boundary prices + settles open rounds\n// Rounds are created on-demand by players via /closecall/bet\nconst closeCallClock = createCloseCallClockWorker({\n  connection,\n  serverKeypair: config.serverKeypair,\n  db,\n});\ncloseCallClock.start();\n\n// Register event handlers before starting the worker\nregisterHandler(\n  EventTypes.REFERRAL_CLAIM_REQUESTED,\n  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\nregisterHandler(\n  EventTypes.GAME_SETTLED,\n  createGameSettledHandler({ db }),\n);\nregisterHandler(\n  EventTypes.REWARD_POOL_FUND,\n  createRewardPoolFundHandler({ db }),\n);\nregisterHandler(\n  EventTypes.POINTS_GRANT,\n  createPointsGrantHandler({\n    db,\n    getSolPrice: async () => {\n      const result = await fetchSolPrice();\n      return result?.price ?? null;\n    },\n  }),\n);\nregisterHandler(\n  EventTypes.CRATE_DROP,\n  createCrateDropHandler({ db }),\n);\n\n// Event queue worker — processes async side-effects (rewards, notifications, etc.)\nconst eventWorker = createEventWorker(sql, {\n  pollIntervalMs: config.eventQueuePollMs,\n});\neventWorker.start();\nlogger.info(\"Event queue worker started\", {\n  pollIntervalMs: config.eventQueuePollMs,\n});\n\n// Game-specific routes\napp.route(\n  \"/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/lord\",\n  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\napp.use(\n  \"/closecall/bet\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/closecall/bet\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Close Call routes (read endpoints are public, /bet is auth'd above)\napp.route(\"/closecall\", createCloseCallRoutes({\n  db,\n  connection,\n  serverKeypair: config.serverKeypair,\n  clockWorker: closeCallClock,\n}));\n\n// Leaderboard routes — public, no auth\napp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n\n// Price routes — public, no auth\napp.route(\"/price\", createPriceRoutes());\n\n// Round verification routes\napp.route(\"/rounds\", createRoundsRoutes({ db }));\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    db,\n    sql,\n    isWorkerRunning: () => worker.isRunning,\n  }),\n);\n\n// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\nif (config.adminToken) {\n  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n}\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", { port });\n\nserve({\n  fetch: app.fetch,\n  port,\n  hostname: \"0.0.0.0\",\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":317,"startLine":1,"totalLines":317}}}
