{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RxHtqSMgs5bDbTFCW1TB77","type":"tool_result","content":"1\t/**\n2\t * Auth routes: challenge/verify/refresh/logout for JWT session management.\n3\t */\n4\t\n5\timport { Hono } from \"hono\";\n6\timport { randomBytes, createHash } from \"node:crypto\";\n7\timport nacl from \"tweetnacl\";\n8\timport bs58 from \"bs58\";\n9\timport { SignJWT } from \"jose\";\n10\timport type { AuthDb } from \"../auth-db.js\";\n11\timport type { Db } from \"../db.js\";\n12\timport { logger } from \"../logger.js\";\n13\t\n14\texport interface AuthRoutesDeps {\n15\t  authDb: AuthDb;\n16\t  db: Db;\n17\t  jwtSecret: Uint8Array;\n18\t  cluster: string;\n19\t  challengeTtlSeconds: number;\n20\t  accessTokenTtlSeconds: number;\n21\t  refreshTokenTtlDays: number;\n22\t}\n23\t\n24\tfunction hashToken(token: string): Buffer {\n25\t  return createHash(\"sha256\").update(token).digest();\n26\t}\n27\t\n28\tfunction issueAccessToken(\n29\t  jwtSecret: Uint8Array,\n30\t  userId: string,\n31\t  now: number,\n32\t  accessTokenTtlSeconds: number,\n33\t): Promise<string> {\n34\t  return new SignJWT({})\n35\t    .setProtectedHeader({ alg: \"HS256\" })\n36\t    .setSubject(userId)\n37\t    .setIssuedAt(now)\n38\t    .setExpirationTime(now + accessTokenTtlSeconds)\n39\t    .sign(jwtSecret);\n40\t}\n41\t\n42\tfunction buildSignInMessage(\n43\t  wallet: string,\n44\t  cluster: string,\n45\t  nonce: string,\n46\t  issuedAt: string,\n47\t  expiresAt: string,\n48\t): string {\n49\t  return [\n50\t    \"Sign in to RNG Utopia\",\n51\t    `Wallet: ${wallet}`,\n52\t    `Cluster: ${cluster}`,\n53\t    `Nonce: ${nonce}`,\n54\t    `Issued At: ${issuedAt}`,\n55\t    `Expires At: ${expiresAt}`,\n56\t    \"This signature creates a backend session for gameplay actions.\",\n57\t    \"It does not approve a blockchain transaction.\",\n58\t  ].join(\"\\n\");\n59\t}\n60\t\n61\texport function createAuthRoutes(deps: AuthRoutesDeps): Hono {\n62\t  const {\n63\t    authDb,\n64\t    db,\n65\t    jwtSecret,\n66\t    cluster,\n67\t    challengeTtlSeconds,\n68\t    accessTokenTtlSeconds,\n69\t    refreshTokenTtlDays,\n70\t  } = deps;\n71\t\n72\t  const app = new Hono();\n73\t\n74\t  // POST /challenge — generate nonce + human-readable message\n75\t  app.post(\"/challenge\", async (c) => {\n76\t    let body: { wallet: string };\n77\t    try {\n78\t      body = await c.req.json();\n79\t      if (typeof body.wallet !== \"string\" || body.wallet.length === 0) {\n80\t        return c.json({ error: \"wallet is required\" }, 400);\n81\t      }\n82\t    } catch {\n83\t      return c.json({ error: \"Invalid JSON body\" }, 400);\n84\t    }\n85\t\n86\t    const nonce = randomBytes(32).toString(\"hex\");\n87\t    const now = new Date();\n88\t    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n89\t\n90\t    const message = buildSignInMessage(\n91\t      body.wallet,\n92\t      cluster,\n93\t      nonce,\n94\t      now.toISOString(),\n95\t      expiresAt.toISOString(),\n96\t    );\n97\t\n98\t    await authDb.insertChallenge(nonce, body.wallet, cluster, message, expiresAt);\n99\t\n100\t    logger.info(\"auth challenge issued\", { wallet: body.wallet, nonce });"}]},"parent_tool_use_id":"toolu_01WnnsxD6PGcCqynR9abaSne","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"e6948db7-3df3-4127-a455-bf5ddbad2cd1","timestamp":"2026-04-03T20:42:35.020Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ro665JUXM4FnSCAJbi8skR","type":"tool_result","content":"1\t/**\n2\t * Onboarding chain progression — auto-assigns the next onboarding step\n3\t * when a player completes an onboarding challenge.\n4\t *\n5\t * Onboarding challenges are linked via `prerequisite_id`. Completing step N\n6\t * triggers assignment of step N+1 (if it exists and hasn't been assigned yet).\n7\t */\n8\t\n9\timport type { Db } from \"../../db.js\";\n10\timport { logger } from \"../../logger.js\";\n11\t\n12\t// ---------------------------------------------------------------------------\n13\t// Types\n14\t// ---------------------------------------------------------------------------\n15\t\n16\tinterface NextStep {\n17\t  id: string;\n18\t  threshold: number;\n19\t}\n20\t\n21\t// ---------------------------------------------------------------------------\n22\t// DB helpers\n23\t// ---------------------------------------------------------------------------\n24\t\n25\t/**\n26\t * Find the next onboarding challenge whose `prerequisite_id` matches\n27\t * the just-completed challenge.\n28\t */\n29\texport async function getNextOnboardingStep(\n30\t  db: Db,\n31\t  completedChallengeId: string,\n32\t): Promise<NextStep | null> {\n33\t  const rows = await db.rawSql<NextStep[]>`\n34\t    SELECT id, threshold\n35\t    FROM challenges\n36\t    WHERE prerequisite_id = ${completedChallengeId}\n37\t      AND is_active = true\n38\t    LIMIT 1\n39\t  `;\n40\t  return rows[0] ?? null;\n41\t}\n42\t\n43\t/**\n44\t * Create a challenge assignment. Returns false if a row for this\n45\t * (user_id, challenge_id, period_key) already exists (idempotency via UNIQUE).\n46\t */\n47\texport async function createAssignment(\n48\t  db: Db,\n49\t  userId: string,\n50\t  challengeId: string,\n51\t  periodKey: string,\n52\t  target: number,\n53\t  expiresAt: string | null,\n54\t): Promise<boolean> {\n55\t  const rows = await db.rawSql<{ id: string }[]>`\n56\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n57\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n58\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n59\t    RETURNING id\n60\t  `;\n61\t  return rows.length > 0;\n62\t}\n63\t\n64\t// ---------------------------------------------------------------------------\n65\t// Main\n66\t// ---------------------------------------------------------------------------\n67\t\n68\t/**\n69\t * After an onboarding assignment is completed, check if there's a next step\n70\t * in the chain and auto-assign it.\n71\t *\n72\t * Called from game-settled handler within the completion transaction.\n73\t */\n74\texport async function advanceOnboardingChain(\n75\t  db: Db,\n76\t  userId: string,\n77\t  completedChallengeId: string,\n78\t  periodKey: string,\n79\t): Promise<void> {\n80\t  // Only process onboarding assignments\n81\t  if (periodKey !== \"onboarding\") return;\n82\t\n83\t  const nextStep = await getNextOnboardingStep(db, completedChallengeId);\n84\t  if (!nextStep) {\n85\t    logger.debug(\"onboarding: no next step (chain complete)\", {\n86\t      userId,\n87\t      completedChallengeId,\n88\t    });\n89\t    return;\n90\t  }\n91\t\n92\t  const created = await createAssignment(\n93\t    db,\n94\t    userId,\n95\t    nextStep.id,\n96\t    \"onboarding\",\n97\t    nextStep.threshold,\n98\t    null,\n99\t  );\n100\t\n101\t  if (created) {\n102\t    logger.info(\"onboarding: next step assigned\", {\n103\t      userId,\n104\t      completedChallengeId,\n105\t      nextChallengeId: nextStep.id,\n106\t    });\n107\t  } else {\n108\t    logger.debug(\"onboarding: next step already assigned (idempotent)\", {\n109\t      userId,\n110\t      nextChallengeId: nextStep.id,\n111\t    });\n112\t  }\n113\t}\n114\t"}]},"parent_tool_use_id":"toolu_01JdQuGjXRPpkWLbNTnG6YkG","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"40b51ac3-772a-4fb8-b972-f00bbaa8f5f0","timestamp":"2026-04-03T20:42:35.048Z"}
