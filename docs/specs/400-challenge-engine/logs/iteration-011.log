{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DPU9h8Ke7PUu8QykB87beh","type":"tool_result","content":"550\t            referralDefaultRateBps: 1000,\n551\t          },\n552\t          pda,\n553\t        ),\n554\t    });\n555\t\n556\t    const worker = createSettlementWorker({\n557\t      db,\n558\t      connection: mockConn as unknown as Connection,\n559\t      serverKey: serverKeypair.publicKey,\n560\t      pollIntervalMs: 60_000, // won't auto-poll\n561\t      onSettleReady: (pda) => {\n562\t        settlePromise = retrySettler.attemptSettle(pda);\n563\t        return settlePromise;\n564\t      },\n565\t    });\n566\t\n567\t    // Single poll cycle — should discover locked match and settle it\n568\t    await worker.poll();\n569\t    if (settlePromise) await settlePromise;\n570\t\n571\t    // ------------------------------------------------------------------\n572\t    // 5. Verify DB updated to \"settled\" with result data\n573\t    // ------------------------------------------------------------------\n574\t    const settled = await db.getRoundByPda(matchPda);\n575\t    expect(settled).toBeDefined();\n576\t    expect(settled!.phase).toBe(\"settled\");\n577\t    expect(settled!.settle_tx).toBeDefined();\n578\t    expect(settled!.result_hash).toBeDefined();\n579\t    expect(settled!.result_hash!.length).toBe(32);\n580\t    expect(settled!.result_side).toBeDefined();\n581\t    expect([0, 1]).toContain(settled!.result_side);\n582\t    expect(settled!.winner).toBeDefined();\n583\t\n584\t    // Winner should be one of the two players\n585\t    expect([\n586\t      creatorKeypair.publicKey.toBase58(),\n587\t      opponentKeypair.publicKey.toBase58(),\n588\t    ]).toContain(settled!.winner);\n589\t\n590\t    // Verify operator events trail\n591\t    const allEvents =\n592\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n593\t    const eventTypes = allEvents.map(\n594\t      (e) => (e as Record<string, unknown>).event_type,\n595\t    );\n596\t    expect(eventTypes).toContain(\"secret_generated\");\n597\t    expect(eventTypes).toContain(\"match_detected\");\n598\t    expect(eventTypes).toContain(\"settle_submitted\");\n599\t    expect(eventTypes).toContain(\"settle_confirmed\");\n600\t\n601\t    // ------------------------------------------------------------------\n602\t    // 6. GET /rounds/:pda — verify response includes secret\n603\t    // ------------------------------------------------------------------\n604\t    const roundsRes = await app.request(`/rounds/${matchPda}`);\n605\t    expect(roundsRes.status).toBe(200);\n606\t\n607\t    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n608\t    expect(roundsJson.pda).toBe(matchPda);\n609\t    expect(roundsJson.phase).toBe(\"settled\");\n610\t    expect(roundsJson.game).toBe(\"coinflip\");\n611\t    expect(roundsJson.creator).toBe(wallet);\n612\t    expect(roundsJson.commitment).toBe(commitmentHex);\n613\t\n614\t    // Settled round should include secret + verification payload\n615\t    expect(roundsJson.secret).toBeDefined();\n616\t    expect(typeof roundsJson.secret).toBe(\"string\");\n617\t    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n618\t    expect(roundsJson.resultHash).toBeDefined();\n619\t    expect(roundsJson.resultSide).toBeDefined();\n620\t    expect(roundsJson.winner).toBeDefined();\n621\t    expect(roundsJson.settleTx).toBeDefined();\n622\t\n623\t    // Verification object\n624\t    const verification = roundsJson.verification as Record<string, string>;\n625\t    expect(verification).toBeDefined();\n626\t    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n627\t    expect(verification.resultFormula).toContain(\"sha256(secret\");\n628\t    expect(verification.entropySource).toContain(\"SlotHashes\");\n629\t  });\n630\t\n631\t  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n632\t    const unknownPda = Keypair.generate().publicKey.toBase58();\n633\t    const res = await app.request(`/rounds/${unknownPda}`);\n634\t    expect(res.status).toBe(404);\n635\t  });\n636\t\n637\t  it(\"unsettled round does not expose secret\", async () => {\n638\t    const wallet = creatorKeypair.publicKey.toBase58();\n639\t    const token = await makeJwt(wallet);\n640\t\n641\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n642\t\n643\t    const res = await app.request(\"/coinflip/create\", {\n644\t      method: \"POST\",\n645\t      headers: {\n646\t        \"Content-Type\": \"application/json\",\n647\t        \"Authorization\": `Bearer ${token}`,\n648\t      },\n649\t      body: JSON.stringify(body),\n650\t    });\n651\t    expect(res.status).toBe(200);\n652\t    const json = (await res.json()) as { matchPda: string };\n653\t\n654\t    // GET the unsettled round\n655\t    const roundRes = await app.request(`/rounds/${json.matchPda}`);\n656\t    expect(roundRes.status).toBe(200);\n657\t    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n658\t    expect(roundJson.phase).toBe(\"created\");\n659\t    expect(roundJson.secret).toBeUndefined();\n660\t    expect(roundJson.resultHash).toBeUndefined();\n661\t    expect(roundJson.verification).toBeUndefined();\n662\t  });\n663\t\n664\t  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n665\t    const wallet = creatorKeypair.publicKey.toBase58();\n666\t    const token = await makeJwt(wallet);\n667\t\n668\t    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n669\t    const res1 = await app.request(\"/coinflip/create\", {\n670\t      method: \"POST\",\n671\t      headers: {\n672\t        \"Content-Type\": \"application/json\",\n673\t        \"Authorization\": `Bearer ${token}`,\n674\t      },\n675\t      body: JSON.stringify(body1),\n676\t    });\n677\t    expect(res1.status).toBe(200);\n678\t\n679\t    // Second request — different random matchId generated server-side\n680\t    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n681\t    const res2 = await app.request(\"/coinflip/create\", {\n682\t      method: \"POST\",\n683\t      headers: {\n684\t        \"Content-Type\": \"application/json\",\n685\t        \"Authorization\": `Bearer ${token}`,\n686\t      },\n687\t      body: JSON.stringify(body2),\n688\t    });\n689\t    expect(res2.status).toBe(200);\n690\t\n691\t    // Both should have different matchIds and PDAs\n692\t    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n693\t    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n694\t    expect(json1.matchPda).not.toBe(json2.matchPda);\n695\t    expect(json1.matchId).not.toBe(json2.matchId);\n696\t  });\n697\t\n698\t  it(\"settlement records referral earnings for referred player\", async () => {\n699\t    // Referrer is a third party; opponent is the referred player"}]},"parent_tool_use_id":"toolu_01KK69n8KaMQMkhjuBrdEk9C","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"5cbd12d3-32a8-4c7e-b634-5245c0cafd89","timestamp":"2026-04-03T20:42:46.764Z"}
