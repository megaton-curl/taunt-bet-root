{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017m6vBk9uRBD4vxud3jBGh5","type":"tool_result","content":"1\t/**\n2\t * GET /health — operational health endpoint.\n3\t *\n4\t * Returns service version, server pubkey, SOL balance, DB connectivity,\n5\t * worker running status, unsettled round count, and oldest unsettled age.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type postgres from \"postgres\";\n10\timport type { Db } from \"../db.js\";\n11\timport { getQueueDepth } from \"../queue/health.js\";\n12\t\n13\texport interface HealthDeps {\n14\t  db: Db;\n15\t  sql: postgres.Sql;\n16\t  isWorkerRunning: () => boolean;\n17\t}\n18\t\n19\texport function createHealthRoutes(deps: HealthDeps): Hono {\n20\t  const { db, sql, isWorkerRunning } = deps;\n21\t  const app = new Hono();\n22\t\n23\t  app.get(\"/\", async (c) => {\n24\t    // Optional flags — extended queries are opt-in so unauthenticated\n25\t    // polling (load balancers, uptime bots) doesn't hit the DB unnecessarily.\n26\t    const verbose = c.req.query(\"verbose\") === \"1\";\n27\t\n28\t    let dbConnected = false;\n29\t    let unsettledCount = 0;\n30\t    let oldestUnsettledAge = 0;\n31\t\n32\t    // Check DB connectivity + query unsettled stats\n33\t    try {\n34\t      const stats = await db.getUnsettledStats();\n35\t      dbConnected = true;\n36\t      unsettledCount = stats.count;\n37\t      oldestUnsettledAge = stats.oldestAgeSeconds;\n38\t    } catch {\n39\t      dbConnected = false;\n40\t    }\n41\t\n42\t    const response: Record<string, unknown> = {\n43\t      status: \"ok\",\n44\t      version: \"0.1.0\",\n45\t      dbConnected,\n46\t      workerRunning: isWorkerRunning(),\n47\t      unsettledCount,\n48\t      oldestUnsettledAge,\n49\t    };\n50\t\n51\t    // Event queue depth — only when ?verbose=1 (extra DB query)\n52\t    if (verbose) {\n53\t      try {\n54\t        response.eventQueue = await getQueueDepth(sql);\n55\t      } catch {\n56\t        response.eventQueue = { pending: 0, processing: 0, dead: 0, completed: 0 };\n57\t      }\n58\t    }\n59\t\n60\t    return c.json(response);\n61\t  });\n62\t\n63\t  return app;\n64\t}\n65\t"}]},"parent_tool_use_id":"toolu_01WnnsxD6PGcCqynR9abaSne","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"71708765-bac6-4cb6-95ed-3cf23c3d30e5","timestamp":"2026-04-03T20:42:46.552Z"}
