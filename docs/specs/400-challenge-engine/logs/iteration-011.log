{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NeUDKBy6nhDQjmrCY7vZA8","type":"tool_result","content":"60\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n61\t\n62\t// ---------------------------------------------------------------------------\n63\t// JWT helper\n64\t// ---------------------------------------------------------------------------\n65\t\n66\tasync function makeJwt(wallet: string, userId = userIdFromWallet(wallet)) {\n67\t  const now = Math.floor(Date.now() / 1000);\n68\t  return new SignJWT({ wallet })\n69\t    .setProtectedHeader({ alg: \"HS256\" })\n70\t    .setSubject(userId)\n71\t    .setIssuedAt(now)\n72\t    .setExpirationTime(now + 3600)\n73\t    .sign(JWT_SECRET);\n74\t}\n75\t\n76\tfunction userIdFromWallet(wallet: string) {\n77\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n78\t}\n79\t\n80\t// ---------------------------------------------------------------------------\n81\t// Mock Connection\n82\t// ---------------------------------------------------------------------------\n83\t\n84\t/**\n85\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n86\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n87\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n88\t */\n89\tclass MockConnection {\n90\t  private _slot = 200;\n91\t  private _accounts = new Map<\n92\t    string,\n93\t    {\n94\t      data: Buffer;\n95\t      lamports: number;\n96\t      owner: PublicKey;\n97\t      executable: boolean;\n98\t    }\n99\t  >();\n100\t  lastRawTx: Buffer | null = null;\n101\t\n102\t  set slot(s: number) {\n103\t    this._slot = s;\n104\t  }\n105\t  get slot() {\n106\t    return this._slot;\n107\t  }\n108\t\n109\t  setAccount(\n110\t    pubkey: PublicKey,\n111\t    data: Buffer,\n112\t    opts?: { lamports?: number; owner?: PublicKey },\n113\t  ) {\n114\t    this._accounts.set(pubkey.toBase58(), {\n115\t      data,\n116\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n117\t      owner: opts?.owner ?? SystemProgram.programId,\n118\t      executable: false,\n119\t    });\n120\t  }\n121\t\n122\t  removeAccount(pubkey: PublicKey) {\n123\t    this._accounts.delete(pubkey.toBase58());\n124\t  }\n125\t\n126\t  async getLatestBlockhash() {\n127\t    return {\n128\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n129\t      lastValidBlockHeight: 999_999,\n130\t    };\n131\t  }\n132\t\n133\t  async getSlot() {\n134\t    return this._slot;\n135\t  }\n136\t\n137\t  async getAccountInfo(pubkey: PublicKey) {\n138\t    const acc = this._accounts.get(pubkey.toBase58());\n139\t    if (!acc) return null;\n140\t    return { ...acc, rentEpoch: 0 };\n141\t  }\n142\t\n143\t  async getProgramAccounts(\n144\t    programId: PublicKey,\n145\t    config?: {\n146\t      filters?: Array<\n147\t        | { dataSize: number }\n148\t        | { memcmp: { offset: number; bytes: string } }\n149\t      >;\n150\t    },\n151\t  ) {\n152\t    const results: Array<{\n153\t      pubkey: PublicKey;\n154\t      account: {\n155\t        data: Buffer;\n156\t        lamports: number;\n157\t        owner: PublicKey;\n158\t        executable: boolean;\n159\t        rentEpoch: number;"}]},"parent_tool_use_id":"toolu_01KK69n8KaMQMkhjuBrdEk9C","session_id":"59720d7a-048c-45e3-b4dd-63ce0cb4da31","uuid":"381ad739-2761-4213-ab30-265c0ea2f2a8","timestamp":"2026-04-03T20:42:48.716Z"}
