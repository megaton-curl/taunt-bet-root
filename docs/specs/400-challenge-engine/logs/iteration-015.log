","+","+    const setClauses: string[] = [];","+    const values: unknown[] = [];","+","+    if (body.title !== undefined) {","+      values.push(body.title);","+      setClauses.push(`title = $${values.length}`);","+    }","+    if (body.description !== undefined) {","+      values.push(body.description);","+      setClauses.push(`description = $${values.length}`);","+    }","+    if (body.action !== undefined) {","+      values.push(body.action);","+      setClauses.push(`action = $${values.length}`);","+    }","+    if (body.scope !== undefined) {","+      values.push(body.scope);","+      setClauses.push(`scope = $${values.length}`);","+    }","+    if (body.condition !== undefined) {","+      values.push(body.condition);","+      setClauses.push(`condition = $${values.length}`);","+    }","+    if (body.threshold !== undefined) {","+      values.push(body.threshold);","+      setClauses.push(`threshold = $${values.length}`);","+    }","+    if (body.rewardType !== undefined) {","+      values.push(body.rewardType);","+      setClauses.push(`reward_type = $${values.length}`);","+    }","+    if (body.rewardAmount !== undefined) {","+      values.push(body.rewardAmount);","+      setClauses.push(`reward_amount = $${values.length}`);","+    }","+    if (body.sortOrder !== undefined) {","+      values.push(body.sortOrder);","+      setClauses.push(`sort_order = $${values.length}`);","+    }","+    if (body.isActive !== undefined) {","+      values.push(body.isActive);","+      setClauses.push(`is_active = $${values.length}`);","+    }","+","+    if (setClauses.length === 0) {","+      return c.json({ error: \"NO_FIELDS\", message: \"No fields to update\" }, 400);","+    }","+","+    values.push(id);","+    const idPlaceholder = `$${values.length}`;","+","+    const query = `UPDATE challenges SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order, is_active, created_at`;","+","+    const rows = await db.rawSql<{","+      id: string; campaign_id: string; title: string; description: string | null;","+      action: string; scope: string; condition: string; threshold: number;","+      reward_type: string; reward_amount: number | null; prerequisite_id: string | null;","+      sort_order: number; is_active: boolean; created_at: string;","+    }[]>(","+      [query] as unknown as TemplateStringsArray,","+      ...values,","+    );","+","+    if (rows.length === 0) {","+      return c.json({ error: \"NOT_FOUND\", message: `Challenge ${id} not found` }, 404);","+    }","+","+    const row = rows[0]!;","+    return c.json({","+      id: row.id,","+      campaignId: row.campaign_id,","+      title: row.title,","+      description: row.description,","+      action: row.action,","+      scope: row.scope,","+      condition: row.condition,","+      threshold: row.threshold,","+      rewardType: row.reward_type,","+      rewardAmount: row.reward_amount,","+      prerequisiteId: row.prerequisite_id,","+      sortOrder: row.sort_order,","+      isActive: row.is_active,","+      createdAt: row.created_at,","+    });","+  });","+","   return app;"," }"]}],"userModified":false,"replaceAll":false}}
