{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JbhUZJjzDomMiSwRRNy5wR","type":"tool_result","content":"1\timport { Hono } from \"hono\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createCoinflipRoutes } from \"./routes/create.js\";\n10\timport { createLordRoutes } from \"./routes/lord-create.js\";\n11\timport { createRoundsRoutes } from \"./routes/rounds.js\";\n12\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n13\timport { createHealthRoutes } from \"./routes/health.js\";\n14\timport { createProfileRoutes } from \"./routes/profile.js\";\n15\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createChallengeRoutes } from \"./routes/challenges.js\";\n21\timport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\n22\timport { createDogpileRoutes } from \"./routes/dogpile.js\";\n23\timport { createAdminRoutes } from \"./routes/admin.js\";\n24\timport { createInternalRoutes } from \"./routes/internal.js\";\n25\timport { swaggerUI } from \"@hono/swagger-ui\";\n26\timport { spec } from \"./openapi.js\";\n27\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n28\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n29\timport { createSettlementWorker } from \"./worker/settlement.js\";\n30\timport { settleRound } from \"./worker/settle-tx.js\";\n31\timport { createRetrySettler } from \"./worker/retry.js\";\n32\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n33\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n34\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n35\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n36\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n37\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n38\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n39\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n40\timport { fetchSolPrice } from \"./routes/price.js\";\n41\timport { logger } from \"./logger.js\";\n42\t\n43\tconst config = loadConfig();\n44\t\n45\t// Single postgres pool shared by game DB, auth DB, and all workers\n46\tconst sql = postgres(config.databaseUrl);\n47\tconst db = createDb(config.databaseUrl, sql);\n48\tconst authDb = createAuthDb(sql);\n49\t\n50\tconst connection = new Connection(config.rpcUrl, {\n51\t  commitment: \"confirmed\",\n52\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n53\t});\n54\t\n55\tconst app = new Hono();\n56\t\n57\tapp.use(\n58\t  \"*\",\n59\t  cors({\n60\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n61\t    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n62\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\", \"X-Admin-Key\"],\n63\t  }),\n64\t);\n65\t\n66\t// Request logging — correlate frontend fetch timing with server-side processing\n67\tapp.use(\"*\", async (c, next) => {\n68\t  const start = Date.now();\n69\t  await next();\n70\t  const ms = Date.now() - start;\n71\t  const method = c.req.method;\n72\t  const path = c.req.path;\n73\t  // Skip noisy health checks and OPTIONS preflight\n74\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n75\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n76\t});\n77\t\n78\t// API docs — Swagger UI + raw OpenAPI spec\n79\tapp.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n80\tapp.get(\"/openapi.json\", (c) => c.json(spec));\n81\t\n82\t// Auth routes — no JWT middleware (these are the login endpoints)\n83\t// Lighter rate limiting by IP for auth endpoints\n84\tapp.use(\n85\t  \"/auth/*\",\n86\t  createRateLimitMiddleware({\n87\t    perWallet: 20,\n88\t    global: config.rateLimitGlobal,\n89\t    windowMs: 60_000,\n90\t  }),\n91\t);\n92\t\n93\tapp.route(\n94\t  \"/auth\",\n95\t  createAuthRoutes({\n96\t    authDb,\n97\t    db,\n98\t    jwtSecret: config.jwtSecret,\n99\t    cluster: config.cluster,\n100\t    challengeTtlSeconds: config.challengeTtlSeconds,\n101\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n102\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n103\t  }),\n104\t);\n105\t\n106\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n107\tapp.use(\n108\t  \"/profile/*\",\n109\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n110\t);\n111\tapp.route(\"/profile\", createProfileRoutes({ db }));\n112\t\n113\t// Public profile routes — no auth required\n114\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n115\t\n116\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n117\tapp.use(\n118\t  \"/referral/*\",\n119\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n120\t);\n121\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n122\t\n123\t// JWT auth middleware for game endpoints\n124\tapp.use(\n125\t  \"/coinflip/*\",\n126\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n127\t);\n128\tapp.use(\n129\t  \"/lord/*\",\n130\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n131\t);\n132\t\n133\t// Rate limiting — per-wallet and global limits on POST requests\n134\tapp.use(\n135\t  \"/coinflip/*\",\n136\t  createRateLimitMiddleware({\n137\t    perWallet: config.rateLimitPerWallet,\n138\t    global: config.rateLimitGlobal,\n139\t    windowMs: 60_000,\n140\t  }),\n141\t);\n142\tapp.use(\n143\t  \"/lord/*\",\n144\t  createRateLimitMiddleware({\n145\t    perWallet: config.rateLimitPerWallet,\n146\t    global: config.rateLimitGlobal,\n147\t    windowMs: 60_000,\n148\t  }),\n149\t);\n150\t\n151\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n152\tconst entropyAccount = new PublicKey(config.entropyAccount);\n153\tconst retrySettler = createRetrySettler({\n154\t  db,\n155\t  connection,\n156\t  settleRound: (pda) =>\n157\t    settleRound(\n158\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n159\t      pda,\n160\t    ),\n161\t});\n162\t\n163\t// PDA watcher — WebSocket-based instant join detection\n164\tconst pdaWatcher = createPdaWatcher({\n165\t  connection,\n166\t  serverKey: config.serverKeypair.publicKey,\n167\t  db,\n168\t  onJoinDetected: async (pda, targetSlot) => {\n169\t    // Update DB phase if still in 'created'\n170\t    const round = await db.getRoundByPda(pda);\n171\t    if (round && round.phase === \"created\") {\n172\t      await db.updateRoundPhase(pda, \"locked\", {\n173\t        target_slot: targetSlot.toString(),\n174\t      });\n175\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n176\t        targetSlot: targetSlot.toString(),\n177\t        source: \"pda-watcher\",\n178\t        game: round.game,\n179\t      });\n180\t    }\n181\t\n182\t    // Check if target slot already passed — settle immediately if so\n183\t    const currentSlot = await connection.getSlot();\n184\t    if (BigInt(currentSlot) >= targetSlot) {\n185\t      await retrySettler.attemptSettle(pda);\n186\t      pdaWatcher.unwatch(pda);\n187\t    }\n188\t    // If target slot not reached yet, poll worker will pick it up next cycle\n189\t  },\n190\t});\n191\t\n192\tconst worker = createSettlementWorker({\n193\t  db,\n194\t  connection,\n195\t  serverKey: config.serverKeypair.publicKey,\n196\t  pollIntervalMs: config.workerPollIntervalMs,\n197\t  onSettleReady: async (pda) => {\n198\t    await retrySettler.attemptSettle(pda);\n199\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n200\t  },\n201\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n202\t});\n203\tworker.start();\n204\t\n205\t// Close Call clock worker — fetches boundary prices + settles open rounds\n206\t// Rounds are created on-demand by players via /closecall/bet\n207\tconst closeCallClock = createCloseCallClockWorker({\n208\t  connection,\n209\t  serverKeypair: config.serverKeypair,\n210\t  db,\n211\t});\n212\tcloseCallClock.start();\n213\t\n214\t// Register event handlers before starting the worker\n215\tregisterHandler(\n216\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n217\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n218\t);\n219\tregisterHandler(\n220\t  EventTypes.GAME_SETTLED,\n221\t  createGameSettledHandler({ db }),\n222\t);\n223\tregisterHandler(\n224\t  EventTypes.REWARD_POOL_FUND,\n225\t  createRewardPoolFundHandler({ db }),\n226\t);\n227\tregisterHandler(\n228\t  EventTypes.POINTS_GRANT,\n229\t  createPointsGrantHandler({\n230\t    db,\n231\t    getSolPrice: async () => {\n232\t      const result = await fetchSolPrice();\n233\t      return result?.price ?? null;\n234\t    },\n235\t  }),\n236\t);\n237\tregisterHandler(\n238\t  EventTypes.CRATE_DROP,\n239\t  createCrateDropHandler({ db }),\n240\t);\n241\t\n242\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n243\tconst eventWorker = createEventWorker(sql, {\n244\t  pollIntervalMs: config.eventQueuePollMs,\n245\t});\n246\teventWorker.start();\n247\tlogger.info(\"Event queue worker started\", {\n248\t  pollIntervalMs: config.eventQueuePollMs,\n249\t});\n250\t\n251\t// Game-specific routes\n252\tapp.route(\n253\t  \"/coinflip\",\n254\t  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n255\t);\n256\tapp.route(\n257\t  \"/lord\",\n258\t  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n259\t);\n260\t\n261\t// Close Call — JWT + rate limiting on POST /bet (co-signs with server keypair)\n262\tapp.use(\n263\t  \"/closecall/bet\",\n264\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n265\t);\n266\tapp.use(\n267\t  \"/closecall/bet\",\n268\t  createRateLimitMiddleware({\n269\t    perWallet: config.rateLimitPerWallet,\n270\t    global: config.rateLimitGlobal,\n271\t    windowMs: 60_000,\n272\t  }),\n273\t);\n274\t\n275\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n276\tapp.route(\"/closecall\", createCloseCallRoutes({\n277\t  db,\n278\t  connection,\n279\t  serverKeypair: config.serverKeypair,\n280\t  clockWorker: closeCallClock,\n281\t}));\n282\t\n283\t// Challenge routes — authenticated GET endpoints (require JWT on all methods)\n284\tapp.use(\n285\t  \"/challenges/*\",\n286\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n287\t);\n288\tapp.route(\"/challenges\", createChallengeRoutes({ db }));\n289\t\n290\t// Points routes — authenticated GET endpoints (require JWT on all methods)\n291\tapp.use(\n292\t  \"/points/*\",\n293\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n294\t);\n295\tapp.route(\"/points\", createPointsRoutes({ db }));\n296\t\n297\t// Crate routes — authenticated GET endpoints (require JWT on all methods)\n298\tapp.use(\n299\t  \"/crates/*\",\n300\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n301\t);\n302\tapp.route(\"/crates\", createCrateRoutes({ db }));\n303\t\n304\t// Dogpile routes — public, no auth\n305\tapp.route(\"/dogpile\", createDogpileRoutes({ db }));\n306\t\n307\t// Admin API routes — requires ADMIN_API_KEY env var\n308\tif (config.adminApiKey) {\n309\t  app.route(\"/admin\", createAdminRoutes({ db, adminApiKey: config.adminApiKey }));\n310\t  logger.info(\"Admin API routes enabled at /admin\");\n311\t}\n312\t\n313\t// Leaderboard routes — public, no auth\n314\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n315\t\n316\t// Price routes — public, no auth\n317\tapp.route(\"/price\", createPriceRoutes());\n318\t\n319\t// Round verification routes\n320\tapp.route(\"/rounds\", createRoundsRoutes({ db }));\n321\t\n322\t// Health endpoint — wired after worker exists so we can query its status\n323\tapp.route(\n324\t  \"/health\",\n325\t  createHealthRoutes({\n326\t    db,\n327\t    sql,\n328\t    isWorkerRunning: () => worker.isRunning,\n329\t  }),\n330\t);\n331\t\n332\t// Internal admin routes — only registered when ADMIN_TOKEN is set (dev/devnet only)\n333\tif (config.adminToken) {\n334\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n335\t  logger.warn(\"Admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n336\t}\n337\t\n338\tconst port = config.port;\n339\tlogger.info(\"fairness-backend started\", { port });\n340\t\n341\tserve({\n342\t  fetch: app.fetch,\n343\t  port,\n344\t  hostname: \"0.0.0.0\",\n345\t});\n346\t\n347\texport default {\n348\t  port,\n349\t  fetch: app.fetch,\n350\t};\n351\t"}]},"parent_tool_use_id":"toolu_015TJQD3EdyhEgcmW3AiSVRA","session_id":"423a191d-c5dd-4ced-a84f-1e1163851ef2","uuid":"43c68c50-01d2-4c42-9229-ac75aaa489f0","timestamp":"2026-04-03T21:23:53.776Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018Kw9G638B2BVVtbrheUNRm","type":"tool_result","content":"1\t/**\n2\t * Challenge routes — player-facing challenge/quest endpoints.\n3\t *\n4\t * GET /mine           — returns active daily, weekly, and onboarding challenges\n5\t *                       with lazy assignment on first call per period.\n6\t * GET /mine/history   — paginated completed challenge assignments.\n7\t */\n8\t\n9\timport { Hono } from \"hono\";\n10\timport type { AppEnv } from \"../hono-env.js\";\n11\timport type { Db } from \"../db.js\";\n12\timport { logger } from \"../logger.js\";\n13\timport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n14\t\n15\t// ---------------------------------------------------------------------------\n16\t// Types\n17\t// ---------------------------------------------------------------------------\n18\t\n19\texport interface ChallengeRoutesDeps {\n20\t  db: Db;\n21\t}\n22\t\n23\tinterface ChallengeRow {\n24\t  id: string;\n25\t  campaign_id: string;\n26\t  title: string;\n27\t  description: string;\n28\t  action: string;\n29\t  scope: string;\n30\t  condition: string;\n31\t  threshold: number;\n32\t  reward_type: string;\n33\t  reward_amount: number | null;\n34\t  sort_order: number;\n35\t  prerequisite_id: string | null;\n36\t}\n37\t\n38\tinterface AssignmentRow {\n39\t  id: string;\n40\t  challenge_id: string;\n41\t  period_key: string;\n42\t  status: string;\n43\t  progress: number;\n44\t  target: number;\n45\t  expires_at: string | null;\n46\t  completed_at: string | null;\n47\t  title: string;\n48\t  description: string;\n49\t  reward_type: string;\n50\t  reward_amount: number | null;\n51\t  campaign_type: string;\n52\t}\n53\t\n54\tinterface CompletionBonusRow {\n55\t  id: string;\n56\t  title: string;\n57\t  required_count: number;\n58\t  reward_type: string;\n59\t  reward_amount: number | null;\n60\t}\n61\t\n62\tinterface BonusCompletionRow {\n63\t  id: string;\n64\t}\n65\t\n66\t// ---------------------------------------------------------------------------\n67\t// Period key helpers\n68\t// ---------------------------------------------------------------------------\n69\t\n70\t/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\n71\texport function dailyPeriodKey(now?: Date): string {\n72\t  const d = now ?? new Date();\n73\t  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n74\t}\n75\t\n76\t/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\n77\texport function weeklyPeriodKey(now?: Date): string {\n78\t  const d = now ?? new Date();\n79\t  // ISO week calculation\n80\t  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n81\t  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n82\t  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n83\t  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n84\t  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n85\t}\n86\t\n87\t/** Returns midnight UTC of the next day (daily reset). */\n88\texport function dailyResetsAt(now?: Date): string {\n89\t  const d = now ?? new Date();\n90\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n91\t  return next.toISOString();\n92\t}\n93\t\n94\t/** Returns midnight UTC of next Monday (weekly reset). */\n95\texport function weeklyResetsAt(now?: Date): string {\n96\t  const d = now ?? new Date();\n97\t  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n98\t  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n99\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n100\t  return next.toISOString();\n101\t}\n102\t\n103\t// ---------------------------------------------------------------------------\n104\t// DB helpers\n105\t// ---------------------------------------------------------------------------\n106\t\n107\t/** Expire stale assignments (expires_at < now AND status='active'). */\n108\tasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n109\t  await db.rawSql`\n110\t    UPDATE challenge_assignments\n111\t    SET status = 'expired'\n112\t    WHERE user_id = ${userId}\n113\t      AND status = 'active'\n114\t      AND expires_at IS NOT NULL\n115\t      AND expires_at < now()\n116\t  `;\n117\t}\n118\t\n119\t/** Get assignments for a user in a given period, joined with challenge metadata. */\n120\tasync function getAssignmentsForPeriod(\n121\t  db: Db,\n122\t  userId: string,\n123\t  periodKey: string,\n124\t): Promise<AssignmentRow[]> {\n125\t  return db.rawSql<AssignmentRow[]>`\n126\t    SELECT\n127\t      ca.id,\n128\t      ca.challenge_id,\n129\t      ca.period_key,\n130\t      ca.status,\n131\t      ca.progress,\n132\t      ca.target,\n133\t      ca.expires_at,\n134\t      ca.completed_at,\n135\t      c.title,\n136\t      c.description,\n137\t      c.reward_type,\n138\t      c.reward_amount,\n139\t      camp.campaign_type\n140\t    FROM challenge_assignments ca\n141\t    JOIN challenges c ON c.id = ca.challenge_id\n142\t    JOIN campaigns camp ON camp.id = c.campaign_id\n143\t    WHERE ca.user_id = ${userId}\n144\t      AND ca.period_key = ${periodKey}\n145\t    ORDER BY c.sort_order ASC\n146\t  `;\n147\t}\n148\t\n149\t/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\n150\tasync function getActiveChallengesBySort(\n151\t  db: Db,\n152\t  campaignId: string,\n153\t  limit: number,\n154\t): Promise<ChallengeRow[]> {\n155\t  return db.rawSql<ChallengeRow[]>`\n156\t    SELECT id, campaign_id, title, description, action, scope, condition,\n157\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n158\t    FROM challenges\n159\t    WHERE campaign_id = ${campaignId}\n160\t      AND is_active = true\n161\t    ORDER BY sort_order ASC\n162\t    LIMIT ${limit}\n163\t  `;\n164\t}\n165\t\n166\t/** Get the campaign ID for a given campaign type. */\n167\tasync function getCampaignByType(\n168\t  db: Db,\n169\t  campaignType: string,\n170\t): Promise<{ id: string } | null> {\n171\t  const rows = await db.rawSql<{ id: string }[]>`\n172\t    SELECT id FROM campaigns\n173\t    WHERE campaign_type = ${campaignType}\n174\t      AND is_active = true\n175\t    LIMIT 1\n176\t  `;\n177\t  return rows[0] ?? null;\n178\t}\n179\t\n180\t/** Get all onboarding assignments for a user (any status). */\n181\tasync function getOnboardingAssignments(\n182\t  db: Db,\n183\t  userId: string,\n184\t): Promise<AssignmentRow[]> {\n185\t  return db.rawSql<AssignmentRow[]>`\n186\t    SELECT\n187\t      ca.id,\n188\t      ca.challenge_id,\n189\t      ca.period_key,\n190\t      ca.status,\n191\t      ca.progress,\n192\t      ca.target,\n193\t      ca.expires_at,\n194\t      ca.completed_at,\n195\t      c.title,\n196\t      c.description,\n197\t      c.reward_type,\n198\t      c.reward_amount,\n199\t      camp.campaign_type\n200\t    FROM challenge_assignments ca\n201\t    JOIN challenges c ON c.id = ca.challenge_id\n202\t    JOIN campaigns camp ON camp.id = c.campaign_id\n203\t    WHERE ca.user_id = ${userId}\n204\t      AND ca.period_key = 'onboarding'\n205\t    ORDER BY c.sort_order ASC\n206\t  `;\n207\t}\n208\t\n209\t/** Get all onboarding challenge templates (ordered by chain). */\n210\tasync function getOnboardingChallenges(\n211\t  db: Db,\n212\t  campaignId: string,\n213\t): Promise<ChallengeRow[]> {\n214\t  return db.rawSql<ChallengeRow[]>`\n215\t    SELECT id, campaign_id, title, description, action, scope, condition,\n216\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n217\t    FROM challenges\n218\t    WHERE campaign_id = ${campaignId}\n219\t      AND is_active = true\n220\t    ORDER BY sort_order ASC\n221\t  `;\n222\t}\n223\t\n224\t/** Get completion bonuses for a campaign. */\n225\tasync function getCompletionBonusesForCampaign(\n226\t  db: Db,\n227\t  campaignId: string,\n228\t): Promise<CompletionBonusRow[]> {\n229\t  return db.rawSql<CompletionBonusRow[]>`\n230\t    SELECT id, title, required_count, reward_type, reward_amount\n231\t    FROM completion_bonuses\n232\t    WHERE campaign_id = ${campaignId}\n233\t      AND is_active = true\n234\t  `;\n235\t}\n236\t\n237\t/** Check if a bonus was completed for a user in a given period. */\n238\tasync function getBonusCompletion(\n239\t  db: Db,\n240\t  userId: string,\n241\t  bonusId: string,\n242\t  periodKey: string,\n243\t): Promise<BonusCompletionRow | null> {\n244\t  const rows = await db.rawSql<BonusCompletionRow[]>`\n245\t    SELECT id FROM bonus_completions\n246\t    WHERE user_id = ${userId}\n247\t      AND bonus_id = ${bonusId}\n248\t      AND period_key = ${periodKey}\n249\t    LIMIT 1\n250\t  `;\n251\t  return rows[0] ?? null;\n252\t}\n253\t\n254\t/** Count completed assignments for a user in a period+campaign. */\n255\tasync function countCompleted(\n256\t  db: Db,\n257\t  userId: string,\n258\t  periodKey: string,\n259\t  campaignId: string,\n260\t): Promise<number> {\n261\t  const rows = await db.rawSql<{ count: string }[]>`\n262\t    SELECT COUNT(*)::TEXT AS count\n263\t    FROM challenge_assignments ca\n264\t    JOIN challenges c ON c.id = ca.challenge_id\n265\t    WHERE ca.user_id = ${userId}\n266\t      AND ca.period_key = ${periodKey}\n267\t      AND ca.status = 'completed'\n268\t      AND c.campaign_id = ${campaignId}\n269\t  `;\n270\t  return Number(rows[0]!.count);\n271\t}\n272\t\n273\t/** Create an assignment (idempotent via UNIQUE). */\n274\tasync function createAssignment(\n275\t  db: Db,\n276\t  userId: string,\n277\t  challengeId: string,\n278\t  periodKey: string,\n279\t  target: number,\n280\t  expiresAt: string | null,\n281\t): Promise<void> {\n282\t  await db.rawSql`\n283\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n284\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n285\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n286\t  `;\n287\t}\n288\t\n289\t// ---------------------------------------------------------------------------\n290\t// Helpers\n291\t// ---------------------------------------------------------------------------\n292\t\n293\t/** Parse and clamp a numeric query param. Returns `defaultVal` if missing/invalid. */\n294\tfunction parseIntParam(raw: string | undefined, defaultVal: number, max: number): number {\n295\t  if (!raw) return defaultVal;\n296\t  const parsed = parseInt(raw, 10);\n297\t  if (isNaN(parsed) || parsed < 1) return defaultVal;\n298\t  return Math.min(parsed, max);\n299\t}\n300\t\n301\t// ---------------------------------------------------------------------------\n302\t// Route factory\n303\t// ---------------------------------------------------------------------------\n304\t\n305\texport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n306\t  const { db } = deps;\n307\t  const app = new Hono<AppEnv>();\n308\t\n309\t  app.get(\"/mine\", async (c) => {\n310\t    const userId = c.get(\"userId\");\n311\t    if (!userId) {\n312\t      return c.json({ error: \"Authentication required\" }, 401);\n313\t    }\n314\t\n315\t    try {\n316\t      const now = new Date();\n317\t\n318\t      // 1. Expire stale assignments\n319\t      await expireStaleAssignments(db, userId);\n320\t\n321\t      // 2. Compute current period keys\n322\t      const dailyKey = dailyPeriodKey(now);\n323\t      const weeklyKey = weeklyPeriodKey(now);\n324\t\n325\t      // 3. Read config for challenge counts\n326\t      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n327\t      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n328\t      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n329\t      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n330\t\n331\t      // 4. Look up campaign IDs\n332\t      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n333\t        getCampaignByType(db, \"daily\"),\n334\t        getCampaignByType(db, \"weekly\"),\n335\t        getCampaignByType(db, \"onboarding\"),\n336\t      ]);\n337\t\n338\t      // 5. Lazy assignment — daily\n339\t      let dailyAssignments = dailyCampaign\n340\t        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n341\t        : [];\n342\t\n343\t      if (dailyAssignments.length === 0 && dailyCampaign) {\n344\t        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n345\t        const dailyExpires = dailyResetsAt(now);\n346\t        for (const t of templates) {\n347\t          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n348\t        }\n349\t        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n350\t      }\n351\t\n352\t      // 6. Lazy assignment — weekly\n353\t      let weeklyAssignments = weeklyCampaign\n354\t        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n355\t        : [];\n356\t\n357\t      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n358\t        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n359\t        const weeklyExpires = weeklyResetsAt(now);\n360\t        for (const t of templates) {\n361\t          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n362\t        }\n363\t        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n364\t      }\n365\t\n366\t      // 7. Lazy assignment — onboarding\n367\t      let onboardingAssignments = onboardingCampaign\n368\t        ? await getOnboardingAssignments(db, userId)\n369\t        : [];\n370\t\n371\t      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n372\t        // Assign first step (prerequisite_id IS NULL)\n373\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n374\t        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n375\t        if (firstStep) {\n376\t          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n377\t          onboardingAssignments = await getOnboardingAssignments(db, userId);\n378\t        }\n379\t      }\n380\t\n381\t      // 8. Build bonus status for daily\n382\t      let dailyBonus: object | null = null;\n383\t      if (dailyCampaign) {\n384\t        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n385\t        if (bonuses.length > 0) {\n386\t          const bonus = bonuses[0]!;\n387\t          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n388\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n389\t          dailyBonus = {\n390\t            title: bonus.title,\n391\t            required: bonus.required_count,\n392\t            completed: completedCount,\n393\t            status: bonusCompletion ? \"completed\" : \"active\",\n394\t            reward: {\n395\t              type: bonus.reward_type,\n396\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n397\t            },\n398\t          };\n399\t        }\n400\t      }\n401\t\n402\t      // 9. Build bonus status for weekly\n403\t      let weeklyBonus: object | null = null;\n404\t      if (weeklyCampaign) {\n405\t        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n406\t        if (bonuses.length > 0) {\n407\t          const bonus = bonuses[0]!;\n408\t          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n409\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n410\t          weeklyBonus = {\n411\t            title: bonus.title,\n412\t            required: bonus.required_count,\n413\t            completed: completedCount,\n414\t            status: bonusCompletion ? \"completed\" : \"active\",\n415\t            reward: {\n416\t              type: bonus.reward_type,\n417\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n418\t            },\n419\t          };\n420\t        }\n421\t      }\n422\t\n423\t      // 10. Build onboarding section\n424\t      let onboarding: object | null = null;\n425\t      if (onboardingCampaign) {\n426\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n427\t        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n428\t        const completedIds = new Set(\n429\t          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n430\t        );\n431\t        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n432\t\n433\t        if (allCompleted) {\n434\t          onboarding = null;\n435\t        } else {\n436\t          const steps = allSteps.map((step) => {\n437\t            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n438\t            const isAssigned = assignedIds.has(step.id);\n439\t            const locked = !isAssigned;\n440\t            return {\n441\t              id: Number(step.id),\n442\t              title: step.title,\n443\t              description: step.description,\n444\t              progress: assignment ? assignment.progress : 0,\n445\t              target: step.threshold,\n446\t              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n447\t              reward: {\n448\t                type: step.reward_type,\n449\t                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n450\t              },\n451\t              completedAt: assignment?.completed_at ?? null,\n452\t              locked,\n453\t            };\n454\t          });\n455\t          onboarding = { steps, completed: false };\n456\t        }\n457\t      }\n458\t\n459\t      // 11. Format response\n460\t      const formatChallenge = (a: AssignmentRow) => ({\n461\t        id: Number(a.id),\n462\t        title: a.title,\n463\t        description: a.description,\n464\t        progress: a.progress,\n465\t        target: a.target,\n466\t        status: a.status as \"active\" | \"completed\" | \"expired\",\n467\t        reward: {\n468\t          type: a.reward_type,\n469\t          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n470\t        },\n471\t        completedAt: a.completed_at ?? null,\n472\t      });\n473\t\n474\t      return c.json({\n475\t        daily: {\n476\t          challenges: dailyAssignments.map(formatChallenge),\n477\t          bonus: dailyBonus,\n478\t          resetsAt: dailyResetsAt(now),\n479\t        },\n480\t        weekly: {\n481\t          challenges: weeklyAssignments.map(formatChallenge),\n482\t          bonus: weeklyBonus,\n483\t          resetsAt: weeklyResetsAt(now),\n484\t        },\n485\t        onboarding,\n486\t      });\n487\t    } catch (err) {\n488\t      logger.error(\"challenges/mine failed\", {\n489\t        userId,\n490\t        error: err instanceof Error ? err.message : String(err),\n491\t      });\n492\t      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n493\t    }\n494\t  });\n495\t\n496\t  // GET /mine/history — paginated completed challenge assignments\n497\t  app.get(\"/mine/history\", async (c) => {\n498\t    const userId = c.get(\"userId\");\n499\t    if (!userId) {\n500\t      return c.json({ error: \"Authentication required\" }, 401);\n501\t    }\n502\t\n503\t    const cursor = c.req.query(\"cursor\") || undefined;\n504\t    const limit = parseIntParam(c.req.query(\"limit\"), 20, 50);\n505\t\n506\t    try {\n507\t      const cursorFilter = cursor\n508\t        ? db.rawSql`AND ca.id < ${cursor}`\n509\t        : db.rawSql``;\n510\t\n511\t      const rows = await db.rawSql<\n512\t        {\n513\t          id: string;\n514\t          title: string;\n515\t          description: string;\n516\t          completed_at: Date;\n517\t          reward_type: string;\n518\t          reward_amount: number | null;\n519\t        }[]\n520\t      >`\n521\t        SELECT\n522\t          ca.id,\n523\t          c.title,\n524\t          c.description,\n525\t          ca.completed_at,\n526\t          c.reward_type,\n527\t          c.reward_amount\n528\t        FROM challenge_assignments ca\n529\t        JOIN challenges c ON c.id = ca.challenge_id\n530\t        WHERE ca.user_id = ${userId}\n531\t          AND ca.status = 'completed'\n532\t          ${cursorFilter}\n533\t        ORDER BY ca.id DESC\n534\t        LIMIT ${limit}\n535\t      `;\n536\t\n537\t      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n538\t        id: Number(r.id),\n539\t        title: r.title,\n540\t        description: r.description,\n541\t        completedAt: r.completed_at.toISOString(),\n542\t        reward: {\n543\t          type: r.reward_type,\n544\t          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n545\t        },\n546\t      }));\n547\t\n548\t      const nextCursor =\n549\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n550\t\n551\t      return c.json({ items, nextCursor });\n552\t    } catch (err) {\n553\t      logger.error(\"challenges/mine/history failed\", {\n554\t        userId,\n555\t        error: err instanceof Error ? err.message : String(err),\n556\t      });\n557\t      return c.json({ error: \"Failed to fetch challenge history\" }, 500);\n558\t    }\n559\t  });\n560\t\n561\t  return app;\n562\t}\n563\t"}]},"parent_tool_use_id":"toolu_015TJQD3EdyhEgcmW3AiSVRA","session_id":"423a191d-c5dd-4ced-a84f-1e1163851ef2","uuid":"2cce5a86-8ec6-40ff-988d-dcd72011f441","timestamp":"2026-04-03T21:23:53.927Z"}
