n-Key returns 401\", async () => {\n3016\t    const res = await adminApp.request(\"/admin/reward-config\", {\n3017\t      method: \"GET\",\n3018\t      headers: { \"X-Admin-Key\": \"wrong-key\" },\n3019\t    });\n3020\t    expect(res.status).toBe(401);\n3021\t    const body = (await res.json()) as Record<string, any>;\n3022\t    expect(body.error).toBe(\"UNAUTHORIZED\");\n3023\t  });\n3024\t\n3025\t  it(\"GET /admin/reward-config returns all seeded defaults\", async () => {\n3026\t    const res = await adminApp.request(\"/admin/reward-config\", {\n3027\t      method: \"GET\",\n3028\t      headers: { \"X-Admin-Key\": ADMIN_KEY },\n3029\t    });\n3030\t    expect(res.status).toBe(200);\n3031\t    const body = (await res.json()) as Record<string, any>;\n3032\t\n3033\t    // Verify all 11 seeded keys present\n3034\t    expect(Object.keys(body)).toHaveLength(11);\n3035\t    expect(body.points_per_dollar.value).toBe(\"500\");\n3036\t    expect(body.reward_pool_fee_share.value).toBe(\"0.20\");\n3037\t    expect(body.sol_crate_drop_rate.value).toBe(\"0.01\");\n3038\t    expect(body.daily_challenge_count.value).toBe(\"3\");\n3039\t    // Each entry has updatedAt\n3040\t    expect(body.points_per_dollar).toHaveProperty(\"updatedAt\");\n3041\t  });\n3042\t\n3043\t  it(\"PUT /admin/reward-config/:key updates value\", async () => {\n3044\t    const res = await adminApp.request(\"/admin/reward-config/points_per_dollar\", {\n3045\t      method: \"PUT\",\n3046\t      headers: {\n3047\t        \"X-Admin-Key\": ADMIN_KEY,\n3048\t        \"Content-Type\": \"application/json\",\n3049\t      },\n3050\t      body: JSON.stringify({ value: \"1000\" }),\n3051\t    });\n3052\t    expect(res.status).toBe(200);\n3053\t    const body = (await res.json()) as Record<string, any>;\n3054\t    expect(body.key).toBe(\"points_per_dollar\");\n3055\t    expect(body.value).toBe(\"1000\");\n3056\t\n3057\t    // Verify persisted\n3058\t    const verify = await adminApp.request(\"/admin/reward-config\", {\n