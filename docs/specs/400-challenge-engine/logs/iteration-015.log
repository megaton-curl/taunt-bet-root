{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ELeHRWNLmqjTdaQVhxBrkr","type":"tool_result","content":"0\t/**\n1\t * Integration test: full create → join → settle lifecycle.\n2\t *\n3\t * Uses a mock Solana Connection to simulate on-chain state while exercising\n4\t * the real HTTP endpoints, database, settlement worker, and retry logic\n5\t * end-to-end. Auth uses JWT Bearer tokens (HS256).\n6\t */\n7\t\n8\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n9\timport { Hono } from \"hono\";\n10\timport {\n11\t  Keypair,\n12\t  PublicKey,\n13\t  SystemProgram,\n14\t  LAMPORTS_PER_SOL,\n15\t} from \"@solana/web3.js\";\n16\timport type { Connection } from \"@solana/web3.js\";\n17\timport bs58 from \"bs58\";\n18\timport { SignJWT } from \"jose\";\n19\timport postgres from \"postgres\";\n20\timport { createDb, type Db } from \"../db.js\";\n21\timport { createCoinflipRoutes } from \"../routes/create.js\";\n22\timport { createRoundsRoutes } from \"../routes/rounds.js\";\n23\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n24\timport { createSettlementWorker } from \"../worker/settlement.js\";\n25\timport { settleMatch } from \"../worker/settle-tx.js\";\n26\timport { createRetrySettler } from \"../worker/retry.js\";\n27\timport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n28\timport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\n29\timport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\n30\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n31\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n32\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n33\timport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\n34\timport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\n35\timport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\n36\timport { createGameSettledHandler } from \"../queue/handlers/game-settled.js\";\n37\timport { createChallengeRoutes, dailyPeriodKey, weeklyPeriodKey } from \"../routes/challenges.js\";\n38\timport { createPointsRoutes, createCrateRoutes } from \"../routes/points.js\";\n39\timport { createDogpileRoutes } from \"../routes/dogpile.js\";\n40\timport { createAdminRoutes } from \"../routes/admin.js\";\n41\t\n42\t// ---------------------------------------------------------------------------\n43\t// Constants\n44\t// ---------------------------------------------------------------------------\n45\t\n46\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n47\t\n48\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n49\tfunction makeSql() {\n50\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n51\t  // Dev container: postgres listens on Unix socket only\n52\t  return postgres({\n53\t    host: \"/var/run/postgresql\",\n54\t    user: \"vscode\",\n55\t    database: \"rng_utopia_dev\",\n56\t  });\n57\t}\n58\t\n59\tconst AMOUNT_LAMPORTS = 5_000_000;"}]},"parent_tool_use_id":null,"session_id":"423a191d-c5dd-4ced-a84f-1e1163851ef2","uuid":"46c16eb4-2ebb-45ac-b6b2-c79b408dcafe","timestamp":"2026-04-03T21:24:25.396Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/services/backend/src/__tests__/integration.test.ts","content":"/**\n * Integration test: full create → join → settle lifecycle.\n *\n * Uses a mock Solana Connection to simulate on-chain state while exercising\n * the real HTTP endpoints, database, settlement worker, and retry logic\n * end-to-end. Auth uses JWT Bearer tokens (HS256).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport { PLATFORM_PROGRAM_ID, derivePlatformConfigPda, resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCoinflipMatch, encodeCoinflipConfig, encodeCloseCallRound } from \"../worker/account-decoder.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\nimport { createRewardPoolFundHandler } from \"../queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"../queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"../queue/handlers/crate-drop.js\";\nimport { createGameSettledHandler } from \"../queue/handlers/game-settled.js\";\nimport { createChallengeRoutes, dailyPeriodKey, weeklyPeriodKey } from \"../routes/challenges.js\";\nimport { createPointsRoutes, createCrateRoutes } from \"../routes/points.js\";\nimport { createDogpileRoutes } from \"../routes/dogpile.js\";\nimport { createAdminRoutes } from \"../routes/admin.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"rng_utopia_dev\",\n  });\n}\n\nconst AMOUNT_LAMPORTS = 5_000_000;","numLines":60,"startLine":0,"totalLines":3096}}}
