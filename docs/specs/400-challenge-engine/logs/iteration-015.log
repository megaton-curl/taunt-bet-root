created_at: string;\n    }[];","originalFile":"/**\n * Admin API routes — reward config, reward pool, campaign/challenge CRUD,\n * and admin-level management.\n *\n * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n */\n\nimport { Hono } from \"hono\";\nimport type { Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Known config keys — reject unknown keys with 400\n// ---------------------------------------------------------------------------\n\nconst VALID_CONFIG_KEYS = new Set([\n  \"points_per_dollar\",\n  \"dogpile_default_multiplier\",\n  \"reward_pool_fee_share\",\n  \"points_crate_drop_rate\",\n  \"sol_crate_drop_rate\",\n  \"sol_crate_pool_pct\",\n  \"sol_crate_min_value\",\n  \"points_crate_min\",\n  \"points_crate_max\",\n  \"daily_challenge_count\",\n  \"weekly_challenge_count\",\n]);\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport interface AdminRoutesDeps {\n  db: Db;\n  adminApiKey: string;\n}\n\nexport function createAdminRoutes(deps: AdminRoutesDeps) {\n  const { db, adminApiKey } = deps;\n  const app = new Hono();\n\n  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n  app.use(\"*\", async (c, next) => {\n    const key = c.req.header(\"X-Admin-Key\");\n    if (!key || key !== adminApiKey) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    await next();\n  });\n\n  // GET /reward-config — all config key-value pairs\n  app.get(\"/reward-config\", async (c) => {\n    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n    `;\n    const config: Record<string, { value: string; updatedAt: string }> = {};\n    for (const row of rows) {\n      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n    }\n    return c.json(config);\n  });\n\n  // PUT /reward-config/:key — update a single config value\n  app.put(\"/reward-config/:key\", async (c) => {\n    const key = c.req.param(\"key\");\n\n    if (!VALID_CONFIG_KEYS.has(key)) {\n      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n    }\n\n    const body = await c.req.json<{ value?: string }>();\n    if (body.value === undefined || body.value === null) {\n      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n    }\n\n    await db.rawSql`\n      UPDATE reward_config\n      SET value = ${String(body.value)}, updated_at = now()\n      WHERE key = ${key}\n    `;\n\n    return c.json({ key, value: String(body.value) });\n  });\n\n  // GET /reward-pool — current pool state\n  app.get(\"/reward-pool\", async (c) => {\n    const rows = await db.rawSql<{\n      balance_lamports: string;\n      lifetime_funded: string;\n      lifetime_paid: string;\n      updated_at: string;\n    }[]>`\n      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n      FROM reward_pool WHERE id = 1\n    `;\n    if (rows.length === 0) {\n      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n    }\n    const pool = rows[0]!;\n    return c.json({\n      balanceLamports: pool.balance_lamports,\n      lifetimeFunded: pool.lifetime_funded,\n      lifetimePaid: pool.lifetime_paid,\n      updatedAt: pool.updated_at,\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // Campaign CRUD\n  // -------------------------------------------------------------------------\n\n  const VALID_CAMPAIGN_TYPES = new Set([\"daily\", \"weekly\", \"onboarding\", \"dogpile\"]);\n\n  // POST /campaigns — create a campaign\n  app.post(\"/campaigns\", async (c) => {\n    const body = await c.req.json<{\n      name?: string;\n      campaignType?: string;\n      startsAt?: string | null;\n      endsAt?: string | null;\n      config?: Record<string, unknown>;\n    }>();\n\n    if (!body.name || typeof body.name !== \"string\") {\n      return c.json({ error: \"MISSING_FIELD\", message: \"name is required\" }, 400);\n    }\n    if (!body.campaignType || !VALID_CAMPAIGN_TYPES.has(body.campaignType)) {\n      return c.json(\n        { error: \"INVALID_CAMPAIGN_TYPE\", message: `campaign_type must be one of: ${[...VALID_CAMPAIGN_TYPES].join(\", \")}` },\n        400,\n      );\n    }\n\n    const startsAt = body.startsAt ?? null;\n    const endsAt = body.endsAt ?? null;\n    const config = JSON.stringify(body.config ?? {});\n\n    const rows = await db.rawSql<{ id: string; name: string; campaign_type: string; starts_at: string | null; ends_at: string | null; is_active: boolean; config: string; created_at: string }[]>`\n      INSERT INTO campaigns (name, campaign_type, starts_at, ends_at, config)\n      VALUES (${body.name}, ${body.campaignType}, ${startsAt}, ${endsAt}, ${config}::jsonb)\n      RETURNING id, name, campaign_type, starts_at, ends_at, is_active, config, created_at\n    `;\n\n    const row = rows[0]!;\n    return c.json({\n      id: row.id,\n      name: row.name,\n      campaignType: row.campaign_type,\n      startsAt: row.starts_at,\n      endsAt: row.ends_at,\n      isActive: row.is_active,\n      config: typeof row.config === \"string\" ? JSON.parse(row.config) : row.config,\n      createdAt: row.created_at,\n    }, 201);\n  });\n\n  // PUT /campaigns/:id — update a campaign (soft-disable only, no delete)\n  app.put(\"/campaigns/:id\", async (c) => {\n    const id = c.req.param(\"id\");\n\n    const body = await c.req.json<{\n      name?: string;\n      startsAt?: string | null;\n      endsAt?: string | null;\n      isActive?: boolean;\n      config?: Record<string, unknown>;\n    }>();\n\n    // Build dynamic SET clauses\n    const setClauses: string[] = [];\n    const values: unknown[] = [];\n\n    if (body.name !== undefined) {\n      values.push(body.name);\n      setClauses.push(`name = $${values.length}`);\n    }\n    if (body.startsAt !== undefined) {\n      values.push(body.startsAt);\n      setClauses.push(`starts_at = $${values.length}`);\n    }\n    if (body.endsAt !== undefined) {\n      values.push(body.endsAt);\n      setClauses.push(`ends_at = $${values.length}`);\n    }\n    if (body.isActive !== undefined) {\n      values.push(body.isActive);\n      setClauses.push(`is_active = $${values.length}`);\n    }\n    if (body.config !== undefined) {\n      values.push(JSON.stringify(body.config));\n      setClauses.push(`config = $${values.length}::jsonb`);\n    }\n\n    if (setClauses.length === 0) {\n      return c.json({ error: \"NO_FIELDS\", message: \"No fields to update\" }, 400);\n    }\n\n    values.push(id);\n    const idPlaceholder = `$${values.length}`;\n\n    const query = `UPDATE campaigns SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, name, campaign_type, starts_at, ends_at, is_active, config, created_at`;\n\n    const rows = await db.rawSql.unsafe(query, values) as { id: string; name: string; campaign_type: string; starts_at: string | null; ends_at: string | null; is_active: boolean; config: string; created_at: string }[];\n\n    if (rows.length === 0) {\n      return c.json({ error: \"NOT_FOUND\", message: `Campaign ${id} not found` }, 404);\n    }\n\n    const row = rows[0]!;\n    return c.json({\n      id: row.id,\n      name: row.name,\n      campaignType: row.campaign_type,\n      startsAt: row.starts_at,\n      endsAt: row.ends_at,\n      isActive: row.is_active,\n      config: typeof row.config === \"string\" ? JSON.parse(row.config) : row.config,\n      createdAt: row.created_at,\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // Challenge CRUD\n  // -------------------------------------------------------------------------\n\n  const VALID_SCOPES = new Set([\"any\", \"coinflip\", \"lord\", \"closecall\"]);\n  const VALID_REWARD_TYPES = new Set([\"points\", \"crate\"]);\n\n  // POST /challenges — create a challenge in a campaign\n  app.post(\"/challenges\", async (c) => {\n    const body = await c.req.json<{\n      campaignId?: number;\n      title?: string;\n      description?: string;\n      action?: string;\n      scope?: string;\n      condition?: string;\n      threshold?: number;\n      rewardType?: string;\n      rewardAmount?: number | null;\n      prerequisiteId?: number | null;\n      sortOrder?: number;\n    }>();\n\n    if (!body.campaignId) {\n      return c.json({ error: \"MISSING_FIELD\", message: \"campaignId is required\" }, 400);\n    }\n    if (!body.title || typeof body.title !== \"string\") {\n      return c.json({ error: \"MISSING_FIELD\", message: \"title is required\" }, 400);\n    }\n    if (!body.action || typeof body.action !== \"string\") {\n      return c.json({ error: \"MISSING_FIELD\", message: \"action is required\" }, 400);\n    }\n    if (!body.threshold || typeof body.threshold !== \"number\") {\n      return c.json({ error: \"MISSING_FIELD\", message: \"threshold is required\" }, 400);\n    }\n    if (!body.rewardType || !VALID_REWARD_TYPES.has(body.rewardType)) {\n      return c.json({ error: \"INVALID_REWARD_TYPE\", message: `reward_type must be one of: ${[...VALID_REWARD_TYPES].join(\", \")}` }, 400);\n    }\n    if (body.scope && !VALID_SCOPES.has(body.scope)) {\n      return c.json({ error: \"INVALID_SCOPE\", message: `scope must be one of: ${[...VALID_SCOPES].join(\", \")}` }, 400);\n    }\n\n    // Validate campaign exists\n    const campRows = await db.rawSql<{ id: string }[]>`SELECT id FROM campaigns WHERE id = ${body.campaignId}`;\n    if (campRows.length === 0) {\n      return c.json({ error: \"CAMPAIGN_NOT_FOUND\", message: `Campaign ${body.campaignId} not found` }, 400);\n    }\n\n    const scope = body.scope ?? \"any\";\n    const condition = body.condition ?? \"count\";\n    const description = body.description ?? null;\n    const rewardAmount = body.rewardAmount ?? null;\n    const prerequisiteId = body.prerequisiteId ?? null;\n    const sortOrder = body.sortOrder ?? 0;\n\n    const rows = await db.rawSql<{\n      id: string; campaign_id: string; title: string; description: string | null;\n      action: string; scope: string; condition: string; threshold: number;\n      reward_type: string; reward_amount: number | null; prerequisite_id: string | null;\n      sort_order: number; is_active: boolean; created_at: string;\n    }[]>`\n      INSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order)\n      VALUES (${body.campaignId}, ${body.title}, ${description}, ${body.action}, ${scope}, ${condition}, ${body.threshold}, ${body.rewardType}, ${rewardAmount}, ${prerequisiteId}, ${sortOrder})\n      RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order, is_active, created_at\n    `;\n\n    const row = rows[0]!;\n    return c.json({\n      id: row.id,\n      campaignId: row.campaign_id,\n      title: row.title,\n      description: row.description,\n      action: row.action,\n      scope: row.scope,\n      condition: row.condition,\n      threshold: row.threshold,\n      rewardType: row.reward_type,\n      rewardAmount: row.reward_amount,\n      prerequisiteId: row.prerequisite_id,\n      sortOrder: row.sort_order,\n      isActive: row.is_active,\n      createdAt: row.created_at,\n    }, 201);\n  });\n\n  // PUT /challenges/:id — update a challenge (toggle is_active, update fields)\n  app.put(\"/challenges/:id\", async (c) => {\n    const id = c.req.param(\"id\");\n\n    const body = await c.req.json<{\n      title?: string;\n      description?: string | null;\n      action?: string;\n      scope?: string;\n      condition?: string;\n      threshold?: number;\n      rewardType?: string;\n      rewardAmount?: number | null;\n      sortOrder?: number;\n      isActive?: boolean;\n    }>();\n\n    // Validate scope if provided\n    if (body.scope !== undefined && !VALID_SCOPES.has(body.scope)) {\n      return c.json({ error: \"INVALID_SCOPE\", message: `scope must be one of: ${[...VALID_SCOPES].join(\", \")}` }, 400);\n    }\n    // Validate rewardType if provided\n    if (body.rewardType !== undefined && !VALID_REWARD_TYPES.has(body.rewardType)) {\n      return c.json({ error: \"INVALID_REWARD_TYPE\", message: `reward_type must be one of: ${[...VALID_REWARD_TYPES].join(\", \")}` }, 400);\n    }\n\n    const setClauses: string[] = [];\n    const values: unknown[] = [];\n\n    if (body.title !== undefined) {\n      values.push(body.title);\n      setClauses.push(`title = $${values.length}`);\n    }\n    if (body.description !== undefined) {\n      values.push(body.description);\n      setClauses.push(`description = $${values.length}`);\n    }\n    if (body.action !== undefined) {\n      values.push(body.action);\n      setClauses.push(`action = $${values.length}`);\n    }\n    if (body.scope !== undefined) {\n      values.push(body.scope);\n      setClauses.push(`scope = $${values.length}`);\n    }\n    if (body.condition !== undefined) {\n      values.push(body.condition);\n      setClauses.push(`condition = $${values.length}`);\n    }\n    if (body.threshold !== undefined) {\n      values.push(body.threshold);\n      setClauses.push(`threshold = $${values.length}`);\n    }\n    if (body.rewardType !== undefined) {\n      values.push(body.rewardType);\n      setClauses.push(`reward_type = $${values.length}`);\n    }\n    if (body.rewardAmount !== undefined) {\n      values.push(body.rewardAmount);\n      setClauses.push(`reward_amount = $${values.length}`);\n    }\n    if (body.sortOrder !== undefined) {\n      values.push(body.sortOrder);\n      setClauses.push(`sort_order = $${values.length}`);\n    }\n    if (body.isActive !== undefined) {\n      values.push(body.isActive);\n      setClauses.push(`is_active = $${values.length}`);\n    }\n\n    if (setClauses.length === 0) {\n      return c.json({ error: \"NO_FIELDS\", message: \"No fields to update\" }, 400);\n    }\n\n    values.push(id);\n    const idPlaceholder = `$${values.length}`;\n\n    const query = `UPDATE challenges SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order, is_active, created_at`;\n\n    const rows = await db.rawSql<{\n      id: string; campaign_id: string; title: string; description: string | null;\n      action: string; scope: string; condition: string; threshold: number;\n      reward_type: string; reward_amount: number | null; prerequisite_id: string | null;\n      sort_order: number; is_active: boolean; created_at: string;\n    }[]>(\n      [query] as unknown as TemplateStringsArray,\n      ...values,\n    );\n\n    if (rows.length === 0) {\n      return c.json({ error: \"NOT_FOUND\", message: `Challenge ${id} not found` }, 404);\n    }\n\n    const row = rows[0]!;\n    return c.json({\n      id: row.id,\n      campaignId: row.campaign_id,\n      title: row.title,\n      description: row.description,\n      action: row.action,\n      scope: row.scope,\n      condition: row.condition,\n      threshold: row.threshold,\n      rewardType: row.reward_type,\n      rewardAmount: row.reward_amount,\n      prerequisiteId: row.prerequisite_id,\n      sortOrder: row.sort_order,\n      isActive: row.is_active,\n      createdAt: row.created_at,\n    });\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":383,"oldLines":15,"newStart":383,"newLines":12,"lines":[" ","     const query = `UPDATE challenges SET ${setClauses.join(\", \")} WHERE id = ${idPlaceholder} RETURNING id, campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amoun