   134→  complete: 3,\n   135→};\n   136→\n   137→export interface CoinflipState {\n   138→  pool: PublicKey;\n   139→  player1: PublicKey;\n   140→  player2: PublicKey | null;\n   141→  player1Side: CoinSide;\n   142→  result: CoinSide | null;\n   143→  phase: CoinflipPhase;\n   144→  createdAt: Date;\n   145→  joinedAt: Date | null;\n   146→  flippedAt: Date | null;\n   147→  joinTimeoutSecs: number;\n   148→}\n   149→\n   150→export interface CoinflipMatch {\n   151→  pool: Pool;\n   152→  state: CoinflipState;\n   153→  player1Entry: PlayerEntry;\n   154→  player2Entry: PlayerEntry | null;\n   155→}\n   156→\n   157→// ============ Legacy Types (for backwards compatibility) ============\n   158→\n   159→/** @deprecated Use Pool instead */\n   160→export interface PoolState {\n   161→  roundId: string;\n   162→  gameId: string;\n   163→  tier: Tier;\n   164→  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n   165→  entries: LegacyPlayerEntry[];\n   166→  totalPool: number;\n   167→  createdAt: number;\n   168→  settledAt?: number;\n   169→  outcome?: unknown;\n   170→}\n   171→\n   172→/** @deprecated Use PlayerEntry instead */\n   173→export interface LegacyPlayerEntry {\n   174→  playerId: string;\n   175→  publicKey: string;\n   176→  tier: Tier;\n   177→  amount: number;\n   178→  timestamp: number;\n   179→  side?: \"green\" | \"red\";\n   180→  cashoutMultiplier?: number;\n   181→}\n   182→\n   183→// ============ Game IDs ============\n   184→\n   185→export const GAME_IDS = {\n   186→  COINFLIP: \"coinflip\",\n   187→  LORD_OF_RNGS: \"lord-of-rngs\",\n   188→  CRASH: \"crash\",\n   189→  CLOSE_CALL: \"close-call\",\n   190→  SLOTS: \"slots\",\n   191→  GAME_OF_TRADES: \"game-of-trades\",\n   192→  TUG_OF_EARN: \"tug-of-earn\",\n   193→  CHART_COURSE: \"chart-course\",\n   194→} as const;\n   195→\n   196→export type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n   197→\n   198→// ============ XP System ============\n   199→\n   200→export const XP_BY_TIER: Record<Tier, { participation: number; win: number }> = {\n   201→  iron: { participation: 1, win: 3 },\n   202→  bronze: { participation: 1, win: 3 },\n   203→  silver: { participation: 10, win: 30 },\n   204→  gold: { participation: 25, win: 75 },\n   205→  platinum: { participation: 50, win: 150 },\n   206→  diamond: { participation: 100, win: 300 },\n   207→};\n   208→\n   209→// ============ Fee Constants ============\n   210→\n   211→export const FEE_CONSTANTS = {\n   212→  TOTAL_BPS: 300, // 3%\n   213→  PLATFORM_REVENUE_BPS: 200, // 2.0%\n   214→  CASHBACK_POOL_BPS: 50, // 0.5%\n   215→  REWARDS_BUDGET_BPS: 50, // 0.5%\n   216→} as const;\n   217→"}]},"parent_tool_use_id":null,"session_id":"7aeeab11-0053-463c-9811-f720a3b5ccf5","uuid":"377124e3-38fe-4a85-a591-2ca1cf421032","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/types.ts","content":"import { PublicKey } from \"@solana/web3.js\";\n\n// ============ Tier System ============\n\nexport type Tier = \"iron\" | \"bronze\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n\nexport const TIER_VALUES: Record<Tier, number> = {\n  iron: 0,\n  bronze: 1,\n  silver: 2,\n  gold: 3,\n  platinum: 4,\n  diamond: 5,\n};\n\nexport const TIER_AMOUNTS: Record<Tier, number> = {\n  iron: 0.005,\n  bronze: 0.01,\n  silver: 0.1,\n  gold: 0.25,\n  platinum: 0.5,\n  diamond: 1,\n};\n\nexport const TIER_AMOUNTS_LAMPORTS: Record<Tier, number> = {\n  iron: 5_000_000,\n  bronze: 10_000_000,\n  silver: 100_000_000,\n  gold: 250_000_000,\n  platinum: 500_000_000,\n  diamond: 1_000_000_000,\n};\n\n// ============ Pool State ============\n\nexport type PoolPhase = \"waiting\" | \"locked\" | \"resolving\" | \"settled\" | \"cancelled\";\n\nexport const POOL_PHASE_VALUES: Record<PoolPhase, number> = {\n  waiting: 0,\n  locked: 1,\n  resolving: 2,\n  settled: 3,\n  cancelled: 4,\n};\n\nexport interface Pool {\n  poolId: Uint8Array;\n  gameId: string;\n  roundId: number;\n  tier: Tier;\n  entryAmount: number;\n  phase: PoolPhase;\n  totalPool: number;\n  playerCount: number;\n  maxPlayers: number;\n  createdAt: Date;\n  lockedAt: Date | null;\n  settledAt: Date | null;\n  feeBps: number;\n  vrfRequest: PublicKey | null;\n  randomness: Uint8Array | null;\n  winner: PublicKey | null;\n  authority: PublicKey;\n  treasury: PublicKey;\n  carryoverAmount: number;\n  carryoverFromRound: number;\n}\n\n// ============ Player Entry ============\n\nexport type Side = \"none\" | \"green\" | \"red\";\n\nexport const SIDE_VALUES: Record<Side, number> = {\n  none: 0,\n  green: 1,\n  red: 2,\n};\n\nexport interface PlayerEntry {\n  pool: PublicKey;\n  player: PublicKey;\n  amount: number;\n  enteredAt: Date;\n  sequence: number;\n  side: Side;\n  cashoutMultiplier: number | null;\n  cashedOutAt: Date | null;\n  claimed: boolean;\n  payout: number;\n  won: boolean;\n  xpParticipation: number;\n  xpWin: number;\n}\n\n// ============ Game Config ============\n\nexport interface GameConfig {\n  gameId: string;\n  paused: boolean;\n  minBet: number;\n  maxBet: number;\n  feeBps: number;\n  enabledTiers: Tier[];\n  minPlayers: number;\n  maxPlayers: number;\n  roundDurationSecs: number;\n  bettingWindowSecs: number;\n  vrfQueue: PublicKey;\n  authority: PublicKey;\n  treasury: PublicKey;\n  currentRound: number;\n  totalRounds: number;\n  totalVolume: number;\n  totalFees: number;\n  version: number;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\n// ============ Coinflip ============\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type CoinflipPhase = \"created\" | \"ready\" | \"flipping\" | \"complete\";\n\nexport const COIN_SIDE_VALUES: Record<CoinSide, number> = {\n  heads: 1,\n  tails: 2,\n};\n\nexport const COINFLIP_PHASE_VALUES: Record<CoinflipPhase, number> = {\n  created: 0,\n  ready: 1,\n  flipping: 2,\n  complete: 3,\n};\n\nexport interface CoinflipState {\n  pool: PublicKey;\n  player1: PublicKey;\n  player2: PublicKey | null;\n  player1Side: CoinSide;\n  result: CoinSide | null;\n  phase: CoinflipPhase;\n  createdAt: Date;\n  joinedAt: Date | null;\n  flippedAt: Date | null;\n  joinTimeoutSecs: number;\n}\n\nexport interface CoinflipMatch {\n  pool: Pool;\n  state: CoinflipState;\n  player1Entry: PlayerEntry;\n  player2Entry: PlayerEntry | null;\n}\n\n// ============ Legacy Types (for backwards compatibility) ============\n\n/** @deprecated Use Pool instead */\nexport interface PoolState {\n  roundId: string;\n  gameId: string;\n  tier: Tier;\n  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n  entries: LegacyPlayerEntry[];\n  totalPool: number;\n  createdAt: number;\n  settledAt?: number;\n  outcome?: unknown;\n}\n\n/** @deprecated Use PlayerEntry instead */\nexport interface LegacyPlayerEntry {\n  playerId: string;\n  publicKey: string;\n  tier: Tier;\n  amount: number;\n  timestamp: number;\n  side?: \"green\" | \"red\";\n  cashoutMultiplier?: number;\n}\n\n// ============ Game IDs ============\n\nexport const GAME_IDS = {\n  COINFLIP: \"coinflip\",\n  LORD_OF_RNGS: \"lord-of-rngs\",\n  CRASH: \"crash\",\n  CLOSE_CALL: \"close-call\",\n  SLOTS: \"slots\",\n  GAME_OF_TRADES: \"game-of-trades\",\n  TUG_OF_EARN: \"tug-of-earn\",\n  CHART_COURSE: \"chart-course\",\n} as const;\n\nexport type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n\n// ============ XP System ============\n\nexport const XP_BY_TIER: Record<Tier, { participation: number; win: number }> = {\n  iron: { participation: 1, win: 3 },\n  bronze: { participation: 1, win: 3 },\n  silver: { participation: 10, win: 30 },\n  gold: { participation: 25, win: 75 },\n  platinum: { participation: 50, win: 150 },\n  diamond: { participation: 100, win: 300 },\n};\n\n// ============ Fee Constants ============\n\nexport const FEE_CONSTANTS = {\n  TOTAL_BPS: 300, // 3%\n  PLATFORM_REVENUE_BPS: 200, // 2.0%\n  CASHBACK_POOL_BPS: 50, // 0.5%\n  REWARDS_BUDGET_BPS: 50, // 0.5%\n} as const;\n","numLines":217,"startLine":1,"totalLines":217}}}
