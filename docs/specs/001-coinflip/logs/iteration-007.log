 153→\n   154→  return new TransactionInstruction({\n   155→    keys: [\n   156→      { pubkey: authority, isSigner: true, isWritable: true },\n   157→      { pubkey: poolPDA, isSigner: false, isWritable: true },\n   158→      { pubkey: coinflipStatePDA, isSigner: false, isWritable: true },\n   159→      // VRF accounts added by ephemeral_vrf_sdk\n   160→    ],\n   161→    programId: PROGRAM_IDS.COINFLIP_SYSTEM,\n   162→    data: Buffer.alloc(8), // Just discriminator for flip\n   163→  });\n   164→}\n   165→\n   166→export interface ClaimPayoutParams {\n   167→  player: PublicKey;\n   168→  poolPDA: PublicKey;\n   169→}\n   170→\n   171→/**\n   172→ * Build instruction to claim winnings\n   173→ */\n   174→export function buildClaimPayoutInstruction(\n   175→  params: ClaimPayoutParams\n   176→): TransactionInstruction {\n   177→  const { player, poolPDA } = params;\n   178→\n   179→  const [playerEntryPDA] = derivePlayerEntryPDA(poolPDA, player);\n   180→\n   181→  return new TransactionInstruction({\n   182→    keys: [\n   183→      { pubkey: player, isSigner: true, isWritable: true },\n   184→      { pubkey: poolPDA, isSigner: false, isWritable: true },\n   185→      { pubkey: playerEntryPDA, isSigner: false, isWritable: true },\n   186→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   187→    ],\n   188→    programId: PROGRAM_IDS.COINFLIP_SYSTEM,\n   189→    data: Buffer.alloc(8), // Just discriminator for claim\n   190→  });\n   191→}\n   192→\n   193→// ============ Helper Functions ============\n   194→\n   195→/**\n   196→ * Calculate the entry amount for a tier in lamports\n   197→ */\n   198→export function getEntryAmount(tier: Tier): number {\n   199→  return TIER_AMOUNTS_LAMPORTS[tier];\n   200→}\n   201→\n   202→/**\n   203→ * Calculate potential payout (winner gets total minus 3% fee)\n   204→ */\n   205→export function calculatePotentialPayout(tier: Tier): number {\n   206→  const entryAmount = TIER_AMOUNTS_LAMPORTS[tier];\n   207→  const totalPool = entryAmount * 2; // Two players\n   208→  const fee = Math.floor(totalPool * 0.03);\n   209→  return totalPool - fee;\n   210→}\n   211→\n   212→/**\n   213→ * Get the opposite coin side\n   214→ */\n   215→export function getOppositeSide(side: CoinSide): CoinSide {\n   216→  return side === \"heads\" ? \"tails\" : \"heads\";\n   217→}\n   218→\n   219→/**\n   220→ * Determine winner from randomness bytes\n   221→ */\n   222→export function determineWinnerFromRandomness(\n   223→  randomness: Uint8Array,\n   224→  player1Side: CoinSide\n   225→): { result: CoinSide; player1Wins: boolean } {\n   226→  // Match the on-chain logic: first byte % 2\n   227→  const firstByte = randomness[0] ?? 0;\n   228→  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n   229→  const player1Wins = player1Side === result;\n   230→  return { result, player1Wins };\n   231→}\n   232→\n   233→// ============ Match Status Helpers ============\n   234→\n   235→export function isMatchWaitingForPlayer2(match: CoinflipMatch): boolean {\n   236→  return match.state.phase === \"created\" && match.pool.playerCount === 1;\n   237→}\n   238→\n   239→export function isMatchReadyToFlip(match: CoinflipMatch): boolean {\n   240→  return match.state.phase === \"ready\" && match.pool.playerCount === 2;\n   241→}\n   242→\n   243→export function isMatchComplete(match: CoinflipMatch): boolean {\n   244→  return match.state.phase === \"complete\";\n   245→}\n   246→\n   247→export function canJoinMatch(match: CoinflipMatch, player: PublicKey): boolean {\n   248→  if (!isMatchWaitingForPlayer2(match)) return false;\n   249→  // Can't join own match\n   250→  if (match.state.player1.equals(player)) return false;\n   251→  // Check timeout\n   252→  const elapsed = Date.now() - match.state.createdAt.getTime();\n   253→  if (elapsed > match.state.joinTimeoutSecs * 1000) return false;\n   254→  return true;\n   255→}\n   256→\n   257→export function canClaimPayout(match: CoinflipMatch, player: PublicKey): boolean {\n   258→  if (!isMatchComplete(match)) return false;\n   259→\n   260→  const entry =\n   261→    match.player1Entry.player.equals(player)\n   262→      ? match.player1Entry\n   263→      : match.player2Entry?.player.equals(player)\n   264→        ? match.player2Entry\n   265→        : null;\n   266→\n   267→  if (!entry) return false;\n   268→  if (entry.claimed) return false;\n   269→  if (entry.payout === 0) return false;\n   270→\n   271→  return true;\n   272→}\n   273→"}]},"parent_tool_use_id":null,"session_id":"7aeeab11-0053-463c-9811-f720a3b5ccf5","uuid":"deb4653e-e3df-46f7-a8fc-95bde573f805","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/coinflip.ts","content":"import { PublicKey, TransactionInstruction, SystemProgram } from \"@solana/web3.js\";\nimport {\n  Tier,\n  CoinSide,\n  CoinflipMatch,\n  TIER_VALUES,\n  TIER_AMOUNTS_LAMPORTS,\n  COIN_SIDE_VALUES,\n} from \"./types\";\n\n// Program IDs - Replace with actual deployed addresses\n// Note: Using System Program ID as placeholder for development\n// These will be replaced with actual deployed program addresses\nconst PLACEHOLDER = new PublicKey(\"11111111111111111111111111111111\");\n\nexport const PROGRAM_IDS = {\n  WORLD: new PublicKey(\"WorLD15A7CrDwLcLy4fRqtpp25TUDMmPqGjdS3HPXM3\"),\n  POOL_COMPONENT: PLACEHOLDER,\n  PLAYER_ENTRY_COMPONENT: PLACEHOLDER,\n  GAME_CONFIG_COMPONENT: PLACEHOLDER,\n  COINFLIP_STATE_COMPONENT: PLACEHOLDER,\n  COINFLIP_SYSTEM: PLACEHOLDER,\n};\n\n// ============ PDA Derivation ============\n\nexport function derivePoolPDA(\n  gameId: string,\n  roundId: number,\n  tier: Tier\n): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [\n      Buffer.from(\"pool\"),\n      Buffer.from(gameId.padEnd(16, \"\\0\")),\n      Buffer.from(new BigUint64Array([BigInt(roundId)]).buffer),\n      Buffer.from([TIER_VALUES[tier]]),\n    ],\n    PROGRAM_IDS.POOL_COMPONENT\n  );\n}\n\nexport function deriveCoinflipStatePDA(poolPDA: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip\"), poolPDA.toBuffer()],\n    PROGRAM_IDS.COINFLIP_STATE_COMPONENT\n  );\n}\n\nexport function derivePlayerEntryPDA(\n  poolPDA: PublicKey,\n  player: PublicKey\n): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"entry\"), poolPDA.toBuffer(), player.toBuffer()],\n    PROGRAM_IDS.PLAYER_ENTRY_COMPONENT\n  );\n}\n\nexport function deriveGameConfigPDA(gameId: string): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"config\"), Buffer.from(gameId.padEnd(16, \"\\0\"))],\n    PROGRAM_IDS.GAME_CONFIG_COMPONENT\n  );\n}\n\n// ============ Instruction Builders ============\n\nexport interface CreateCoinflipMatchParams {\n  player: PublicKey;\n  tier: Tier;\n  side: CoinSide;\n  roundId: number;\n}\n\n/**\n * Build instruction to create a new coinflip match\n */\nexport function buildCreateMatchInstruction(\n  params: CreateCoinflipMatchParams\n): TransactionInstruction {\n  const { player, tier, side, roundId } = params;\n\n  const [poolPDA] = derivePoolPDA(\"coinflip\", roundId, tier);\n  const [coinflipStatePDA] = deriveCoinflipStatePDA(poolPDA);\n  const [playerEntryPDA] = derivePlayerEntryPDA(poolPDA, player);\n  const [gameConfigPDA] = deriveGameConfigPDA(\"coinflip\");\n\n  // Instruction data: [discriminator(8), tier(1), side(1)]\n  const data = Buffer.alloc(10);\n  // Note: Actual discriminator depends on Anchor IDL\n  data.writeUint8(TIER_VALUES[tier], 8);\n  data.writeUint8(COIN_SIDE_VALUES[side], 9);\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: player, isSigner: true, isWritable: true },\n      { pubkey: poolPDA, isSigner: false, isWritable: true },\n      { pubkey: coinflipStatePDA, isSigner: false, isWritable: true },\n      { pubkey: playerEntryPDA, isSigner: false, isWritable: true },\n      { pubkey: gameConfigPDA, isSigner: false, isWritable: false },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: PROGRAM_IDS.COINFLIP_SYSTEM,\n    data,\n  });\n}\n\nexport interface JoinCoinflipMatchParams {\n  player: PublicKey;\n  poolPDA: PublicKey;\n}\n\n/**\n * Build instruction to join an existing coinflip match\n */\nexport function buildJoinMatchInstruction(\n  params: JoinCoinflipMatchParams\n): TransactionInstruction {\n  const { player, poolPDA } = params;\n\n  const [coinflipStatePDA] = deriveCoinflipStatePDA(poolPDA);\n  const [playerEntryPDA] = derivePlayerEntryPDA(poolPDA, player);\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: player, isSigner: true, isWritable: true },\n      { pubkey: poolPDA, isSigner: false, isWritable: true },\n      { pubkey: coinflipStatePDA, isSigner: false, isWritable: true },\n      { pubkey: playerEntryPDA, isSigner: false, isWritable: true },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: PROGRAM_IDS.COINFLIP_SYSTEM,\n    data: Buffer.alloc(8), // Just discriminator for join\n  });\n}\n\nexport interface FlipCoinParams {\n  authority: PublicKey;\n  poolPDA: PublicKey;\n}\n\n/**\n * Build instruction to flip the coin (triggers VRF)\n */\nexport function buildFlipCoinInstruction(\n  params: FlipCoinParams\n): TransactionInstruction {\n  const { authority, poolPDA } = params;\n\n  const [coinflipStatePDA] = deriveCoinflipStatePDA(poolPDA);\n  // Note: VRF accounts would be added by the SDK\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: authority, isSigner: true, isWritable: true },\n      { pubkey: poolPDA, isSigner: false, isWritable: true },\n      { pubkey: coinflipStatePDA, isSigner: false, isWritable: true },\n      // VRF accounts added by ephemeral_vrf_sdk\n    ],\n    programId: PROGRAM_IDS.COINFLIP_SYSTEM,\n    data: Buffer.alloc(8), // Just discriminator for flip\n  });\n}\n\nexport interface ClaimPayoutParams {\n  player: PublicKey;\n  poolPDA: PublicKey;\n}\n\n/**\n * Build instruction to claim winnings\n */\nexport function buildClaimPayoutInstruction(\n  params: ClaimPayoutParams\n): TransactionInstruction {\n  const { player, poolPDA } = params;\n\n  const [playerEntryPDA] = derivePlayerEntryPDA(poolPDA, player);\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: player, isSigner: true, isWritable: true },\n      { pubkey: poolPDA, isSigner: false, isWritable: true },\n      { pubkey: playerEntryPDA, isSigner: false, isWritable: true },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: PROGRAM_IDS.COINFLIP_SYSTEM,\n    data: Buffer.alloc(8), // Just discriminator for claim\n  });\n}\n\n// ============ Helper Functions ============\n\n/**\n * Calculate the entry amount for a tier in lamports\n */\nexport function getEntryAmount(tier: Tier): number {\n  return TIER_AMOUNTS_LAMPORTS[tier];\n}\n\n/**\n * Calculate potential payout (winner gets total minus 3% fee)\n */\nexport function calculatePotentialPayout(tier: Tier): number {\n  const entryAmount = TIER_AMOUNTS_LAMPORTS[tier];\n  const totalPool = entryAmount * 2; // Two players\n  const fee = Math.floor(totalPool * 0.03);\n  return totalPool - fee;\n}\n\n/**\n * Get the opposite coin side\n */\nexport function getOppositeSide(side: CoinSide): CoinSide {\n  return side === \"heads\" ? \"tails\" : \"heads\";\n}\n\n/**\n * Determine winner from randomness bytes\n */\nexport function determineWinnerFromRandomness(\n  randomness: Uint8Array,\n  player1Side: CoinSide\n): { result: CoinSide; player1Wins: boolean } {\n  // Match the on-chain logic: first byte % 2\n  const firstByte = randomness[0] ?? 0;\n  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n  const player1Wins = player1Side === result;\n  return { result, player1Wins };\n}\n\n// ============ Match Status Helpers ============\n\nexport function isMatchWaitingForPlayer2(match: CoinflipMatch): boolean {\n  return match.state.phase === \"created\" && match.pool.playerCount === 1;\n}\n\nexport function isMatchReadyToFlip(match: CoinflipMatch): boolean {\n  return match.state.phase === \"ready\" && match.pool.playerCount === 2;\n}\n\nexport function isMatchComplete(match: CoinflipMatch): boolean {\n  return match.state.phase === \"complete\";\n}\n\nexport function canJoinMatch(match: CoinflipMatch, player: PublicKey): boolean {\n  if (!isMatchWaitingForPlayer2(match)) return false;\n  // Can't join own match\n  if (match.state.player1.equals(player)) return false;\n  // Check timeout\n  const elapsed = Date.now() - match.state.createdAt.getTime();\n  if (elapsed > match.state.joinTimeoutSecs * 1000) return false;\n  return true;\n}\n\nexport function canClaimPayout(match: CoinflipMatch, player: PublicKey): boolean {\n  if (!isMatchComplete(match)) return false;\n\n  const entry =\n    match.player1Entry.player.equals(player)\n      ? match.player1Entry\n      : match.player2Entry?.player.equals(player)\n        ? match.player2Entry\n        : null;\n\n  if (!entry) return false;\n  if (entry.claimed) return false;\n  if (entry.payout === 0) return false;\n\n  return true;\n}\n","numLines":273,"startLine":1,"totalLines":273}}}
