{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013ncFYLJuJWjE8xyJ27xAek","type":"tool_result","content":"     1→const PLATFORM_FEE_BPS = 300; // 3%\n     2→\n     3→/**\n     4→ * Calculate pari-mutuel payout for a player\n     5→ * NOTE: This is for UI display/verification only. On-chain is authoritative.\n     6→ */\n     7→export function calculatePariMutuelPayout(\n     8→  playerBet: number,\n     9→  winningPool: number,\n    10→  totalPool: number,\n    11→  feeBps: number = PLATFORM_FEE_BPS\n    12→): number {\n    13→  if (winningPool === 0) return 0;\n    14→\n    15→  const feeMultiplier = 1 - feeBps / 10000;\n    16→  const poolAfterFees = totalPool * feeMultiplier;\n    17→  const playerShare = playerBet / winningPool;\n    18→\n    19→  return poolAfterFees * playerShare;\n    20→}\n    21→\n    22→/**\n    23→ * Calculate winner-takes-all payout\n    24→ * NOTE: This is for UI display/verification only. On-chain is authoritative.\n    25→ */\n    26→export function calculateWinnerPayout(\n    27→  totalPool: number,\n    28→  feeBps: number = PLATFORM_FEE_BPS\n    29→): number {\n    30→  const feeMultiplier = 1 - feeBps / 10000;\n    31→  return totalPool * feeMultiplier;\n    32→}\n    33→\n    34→/**\n    35→ * Verify that payouts + fees = total pool (invariant check)\n    36→ */\n    37→export function verifyPayoutInvariant(\n    38→  payouts: number[],\n    39→  fees: number,\n    40→  totalPool: number,\n    41→  tolerance: number = 0.000001\n    42→): boolean {\n    43→  const totalPayouts = payouts.reduce((sum, p) => sum + p, 0);\n    44→  return Math.abs(totalPayouts + fees - totalPool) < tolerance;\n    45→}\n    46→"}]},"parent_tool_use_id":null,"session_id":"7aeeab11-0053-463c-9811-f720a3b5ccf5","uuid":"2d4b787f-9a30-45df-8fa3-cbf5eee71a6d","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/payouts.ts","content":"const PLATFORM_FEE_BPS = 300; // 3%\n\n/**\n * Calculate pari-mutuel payout for a player\n * NOTE: This is for UI display/verification only. On-chain is authoritative.\n */\nexport function calculatePariMutuelPayout(\n  playerBet: number,\n  winningPool: number,\n  totalPool: number,\n  feeBps: number = PLATFORM_FEE_BPS\n): number {\n  if (winningPool === 0) return 0;\n\n  const feeMultiplier = 1 - feeBps / 10000;\n  const poolAfterFees = totalPool * feeMultiplier;\n  const playerShare = playerBet / winningPool;\n\n  return poolAfterFees * playerShare;\n}\n\n/**\n * Calculate winner-takes-all payout\n * NOTE: This is for UI display/verification only. On-chain is authoritative.\n */\nexport function calculateWinnerPayout(\n  totalPool: number,\n  feeBps: number = PLATFORM_FEE_BPS\n): number {\n  const feeMultiplier = 1 - feeBps / 10000;\n  return totalPool * feeMultiplier;\n}\n\n/**\n * Verify that payouts + fees = total pool (invariant check)\n */\nexport function verifyPayoutInvariant(\n  payouts: number[],\n  fees: number,\n  totalPool: number,\n  tolerance: number = 0.000001\n): boolean {\n  const totalPayouts = payouts.reduce((sum, p) => sum + p, 0);\n  return Math.abs(totalPayouts + fees - totalPool) < tolerance;\n}\n","numLines":46,"startLine":1,"totalLines":46}}}
