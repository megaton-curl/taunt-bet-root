talPool * 0.03);\n  return totalPool - fee;\n}\n\n/**\n * Get the opposite coin side\n */\nexport function getOppositeSide(side: CoinSide): CoinSide {\n  return side === \"heads\" ? \"tails\" : \"heads\";\n}\n\n/**\n * Determine winner from randomness bytes\n */\nexport function determineWinnerFromRandomness(\n  randomness: Uint8Array,\n  player1Side: CoinSide\n): { result: CoinSide; player1Wins: boolean } {\n  // Match the on-chain logic: first byte % 2\n  const firstByte = randomness[0] ?? 0;\n  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n  const player1Wins = player1Side === result;\n  return { result, player1Wins };\n}\n","structuredPatch":[{"oldStart":1,"oldLines":195,"newStart":1,"newLines":45,"lines":["-import { PublicKey, TransactionInstruction, SystemProgram } from \"@solana/web3.js\";","+import { PublicKey } from \"@solana/web3.js\";"," import {","   Tier,","   CoinSide,","-  CoinflipMatch,","-  TIER_VALUES,","   TIER_AMOUNTS_LAMPORTS,","-  COIN_SIDE_VALUES,"," } from \"./types\";"," ","-// Program IDs - Replace with actual deployed addresses","-// Note: Using System Program ID as placeholder for development","-// These will be replaced with actual deployed program addresses","-const PLACEHOLDER = new PublicKey(\"11111111111111111111111111111111\");","+// ============ Program IDs ============"," ","+export const COINFLIP_PROGRAM_ID = new PublicKey(","+  \"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\"","+);","+","+/** @deprecated Use COINFLIP_PROGRAM_ID instead */"," export const PROGRAM_IDS = {","-  WORLD: new PublicKey(\"WorLD15A7CrDwLcLy4fRqtpp25TUDMmPqGjdS3HPXM3\"),","-  POOL_COMPONENT: PLACEHOLDER,","-  PLAYER_ENTRY_COMPONENT: PLACEHOLDER,","-  GAME_CONFIG_COMPONENT: PLACEHOLDER,","-  COINFLIP_STATE_COMPONENT: PLACEHOLDER,","-  COINFLIP_SYSTEM: PLACEHOLDER,","+  COINFLIP: COINFLIP_PROGRAM_ID,"," };"," "," // ============ PDA Derivation ============"," ","-export function derivePoolPDA(","-  gameId: string,","-  roundId: numb