{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RPAnzEJYLAzv9MGh4HKjHd","type":"tool_result","content":"     1→import { defineConfig, devices } from \"@playwright/test\";\n     2→\n     3→/**\n     4→ * Playwright config for real wallet mode tests.\n     5→ * Starts the dev server with VITE_MOCK_MODE=false and VITE_RPC_URL pointing to devnet.\n     6→ */\n     7→export default defineConfig({\n     8→  testDir: \"./e2e\",\n     9→  fullyParallel: true,\n    10→  forbidOnly: !!process.env.CI,\n    11→  retries: 0,\n    12→  workers: 1,\n    13→  reporter: \"list\",\n    14→\n    15→  use: {\n    16→    baseURL: \"http://localhost:3001\",\n    17→    screenshot: \"off\",\n    18→    trace: \"off\",\n    19→    ...devices[\"Desktop Chrome\"],\n    20→    viewport: { width: 1280, height: 1080 },\n    21→  },\n    22→\n    23→  projects: [\n    24→    {\n    25→      name: \"chromium\",\n    26→      testMatch: \"real/**/*.spec.ts\",\n    27→      use: { ...devices[\"Desktop Chrome\"], viewport: { width: 1280, height: 1080 } },\n    28→    },\n    29→  ],\n    30→\n    31→  webServer: {\n    32→    command: \"npx vite --port 3001\",\n    33→    url: \"http://localhost:3001\",\n    34→    reuseExistingServer: !process.env.CI,\n    35→    timeout: 30_000,\n    36→    env: {\n    37→      VITE_MOCK_MODE: \"false\",\n    38→      VITE_RPC_URL: \"https://api.devnet.solana.com\",\n    39→    },\n    40→  },\n    41→});\n    42→"}]},"parent_tool_use_id":"toolu_01YbfrVz4zgSc3heh6Np4AHd","session_id":"f244d339-d9e0-4d86-97fb-bcb906c0be01","uuid":"3ea89de0-a8cb-4e7f-b536-c708b1e789a5"}
