{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019PGPVLsKmLk1Tc1CZLEmVK","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"826f8699-8fd9-4c25-b0a1-b4fd4925d7c0","uuid":"f7135b88-06f4-4ff3-b3fa-1cea4af357a9","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts","oldString":"export function buildCreateMatchInstruction(\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): { instruction: TransactionInstruction; matchPda: PublicKey } {\n  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n  const [matchPda] = getMatchPda(creator);\n  const [configPda] = getConfigPda();\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const instruction = program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  // instruction() returns a Promise<TransactionInstruction>, but we return\n  // it synchronously wrapped — callers must await the instruction.\n  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n}\n\nexport async function buildCreateMatchTx(","newString":"export async function buildCreateMatchTx(","originalFile":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  COIN_SIDE_VALUES,\n  TIER_AMOUNTS,\n  type Tier,\n  type CoinSide,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n);\n\n// Orao VRF program (on-chain VRF provider)\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n\n// ============ PDA Derivation ============\n\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n/** Orao VRF network state PDA (stores config + treasury). */\nfunction getOraoNetworkStatePda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n/** Orao VRF randomness PDA derived from a 32-byte seed. */\nfunction getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ============ Program Instance ============\n\nfunction getCoinflipProgram(connection: Connection): Program<Coinflip> {\n  // Read-only provider (no wallet needed for queries)\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n}\n\n// ============ On-Chain Account Types ============\n\n/** Anchor enum variant representation — one key with empty object value. */\ntype RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n  | { resolving: object } | { settled: object } | { refunded: object };\n\ninterface OnChainMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  tier: number;\n  entryAmount: { toNumber(): number };\n  creatorSide: number;\n  phase: RoundPhaseVariant;\n  result: number;\n  winner: PublicKey;\n  claimed: boolean;\n  createdAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  bump: number;\n}\n\n// ============ Converters ============\n\nfunction tierFromIndex(index: number): Tier {\n  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n  return tiers[index] ?? \"iron\";\n}\n\nfunction sideFromIndex(index: number): CoinSide {\n  return index === 0 ? \"heads\" : \"tails\";\n}\n\nfunction isPhase(phase: RoundPhaseVariant, name: string): boolean {\n  return name in phase;\n}\n\nfunction phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n  if (isPhase(phase, \"waiting\")) return \"created\";\n  if (isPhase(phase, \"locked\")) return \"ready\";\n  if (isPhase(phase, \"settled\")) return \"complete\";\n  return \"created\";\n}\n\nconst DEFAULT_PUBKEY = PublicKey.default;\n\nfunction isDefaultPubkey(key: PublicKey): boolean {\n  return key.equals(DEFAULT_PUBKEY);\n}\n\nexport function onChainMatchToUI(\n  matchPda: PublicKey,\n  data: OnChainMatch\n): UIMatch {\n  const tier = tierFromIndex(data.tier);\n  const creatorSide = sideFromIndex(data.creatorSide);\n  const hasOpponent = !isDefaultPubkey(data.opponent);\n  const phase = phaseToUI(data.phase);\n  const isSettled = isPhase(data.phase, \"settled\");\n\n  const entryAmountSol = TIER_AMOUNTS[tier];\n  const totalPool = entryAmountSol * 2;\n  const payoutAmount = totalPool * 0.97;\n\n  const lockedAt = data.lockedAt.toNumber();\n\n  return {\n    id: matchPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    player1: data.creator.toBase58(),\n    player1Side: creatorSide,\n    player2: hasOpponent ? data.opponent.toBase58() : null,\n    player2Side: hasOpponent\n      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n      : null,\n    phase,\n    createdAt: Date.now(),\n    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n    result: isSettled ? sideFromIndex(data.result) : null,\n    winner: isSettled && !isDefaultPubkey(data.winner)\n      ? data.winner.toBase58()\n      : null,\n    claimed: data.claimed,\n    payoutAmount,\n    seedHash: \"\",\n  };\n}\n\n// ============ Account Queries ============\n\nexport async function fetchAllOpenMatches(\n  connection: Connection\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const accounts = await program.account.coinflipMatch.all();\n\n  return accounts\n    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n    .map((acc) =>\n      onChainMatchToUI(\n        acc.publicKey,\n        acc.account as unknown as OnChainMatch\n      )\n    );\n}\n\n/**\n * Fetch all matches where playerPubkey is creator OR opponent,\n * claimed == false, and phase is non-terminal (not refunded).\n * Uses memcmp filters for efficient on-chain filtering.\n *\n * Account layout offsets (after 8-byte discriminator):\n *   creator:  8   (32 bytes)\n *   opponent: 40  (32 bytes)\n *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n */\nexport async function fetchClaimableMatches(\n  connection: Connection,\n  playerPubkey: PublicKey\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const playerBase58 = playerPubkey.toBase58();\n\n  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n\n  const [asCreator, asOpponent] = await Promise.all([\n    program.account.coinflipMatch.all([\n      { memcmp: { offset: 8, bytes: playerBase58 } },\n      claimedFalseFilter,\n    ]),\n    program.account.coinflipMatch.all([\n      { memcmp: { offset: 40, bytes: playerBase58 } },\n      claimedFalseFilter,\n    ]),\n  ]);\n\n  // Merge and deduplicate by public key\n  const seen = new Set<string>();\n  const matches: UIMatch[] = [];\n\n  for (const acc of [...asCreator, ...asOpponent]) {\n    const key = acc.publicKey.toBase58();\n    if (seen.has(key)) continue;\n    seen.add(key);\n\n    const data = acc.account as unknown as OnChainMatch;\n    // Skip terminal phase (refunded)\n    if (isPhase(data.phase, \"refunded\")) continue;\n\n    matches.push(onChainMatchToUI(acc.publicKey, data));\n  }\n\n  return matches;\n}\n\nexport async function fetchMatchByCreator(\n  connection: Connection,\n  creator: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    // Account doesn't exist\n    return null;\n  }\n}\n\nexport async function fetchMatch(\n  connection: Connection,\n  matchPda: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    return null;\n  }\n}\n\n// ============ Instruction Builders ============\n\nexport function buildCreateMatchInstruction(\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): { instruction: TransactionInstruction; matchPda: PublicKey } {\n  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n  const [matchPda] = getMatchPda(creator);\n  const [configPda] = getConfigPda();\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const instruction = program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  // instruction() returns a Promise<TransactionInstruction>, but we return\n  // it synchronously wrapped — callers must await the instruction.\n  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n}\n\nexport async function buildCreateMatchTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n  const [configPda] = getConfigPda();\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const ix = await program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, matchPda };\n}\n\nexport async function buildJoinMatchTx(\n  connection: Connection,\n  opponent: PublicKey,\n  matchCreator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n  const oraoNetworkState = getOraoNetworkStatePda();\n  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n\n  const ix = await program.methods\n    .joinMatch()\n    .accountsStrict({\n      opponent,\n      coinflipMatch: matchPda,\n      config: configPda,\n      oraoProgram: ORAO_VRF_PROGRAM_ID,\n      oraoNetworkState,\n      oraoTreasury,\n      oraoRandom,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = opponent;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildCancelMatchTx(\n  connection: Connection,\n  creator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const ix = await program.methods\n    .cancelMatch()\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildTimeoutCancelTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n\n  // Derive randomness account from match PDA (VRF seed = match PDA key)\n  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n\n  const ix = await program.methods\n    .timeoutCancel()\n    .accountsStrict({\n      caller,\n      creator: matchCreator,\n      opponent,\n      coinflipMatch: matchPda,\n      randomnessAccount,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get treasury address\n  const config = await program.account.coinflipConfig.fetch(configPda);\n  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n\n  // Derive randomness account from match PDA (VRF seed = match PDA key)\n  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n\n  // Derive player profile PDAs for CPI\n  const PLATFORM_PROGRAM_ID = new PublicKey(\n    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n  );\n  const [creatorProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  const [opponentProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n\n  const ix = await program.methods\n    .claimPayout()\n    .accountsStrict({\n      caller,\n      coinflipMatch: matchPda,\n      config: configPda,\n      treasury,\n      creator: matchCreator,\n      opponent,\n      randomnessAccount,\n      creatorProfile,\n      opponentProfile,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n","structuredPatch":[{"oldStart":261,"oldLines":33,"newStart":261,"newLines":6,"lines":[" "," // ============ Instruction Builders ============"," ","-export function buildCreateMatchInstruction(","-  creator: PublicKey,","-  tier: Tier,","-  side: CoinSide","-): { instruction: TransactionInstruction; matchPda: PublicKey } {","-  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));","-  const [matchPda] = getMatchPda(creator);","-  const [configPda] = getConfigPda();","-","-  const tierIndex = TIER_VALUES[tier];","-  const sideIndex = COIN_SIDE_VALUES[side];","-","-  const instruction = program.methods","-    .createMatch(tierIndex, sideIndex)","-    .accountsStrict({","-      creator,","-      coinflipMatch: matchPda,","-      config: configPda,","-      systemProgram: SystemProgram.programId,","-    })","-    .instruction();","-","-  // instruction() returns a Promise<TransactionInstruction>, but we return","-  // it synchronously wrapped — callers must await the instruction.","-  return { instruction: instruction as unknown as TransactionInstruction, matchPda };","-}","-"," export async function buildCreateMatchTx(","   connection: Connection,","   creator: PublicKey,"]}],"userModified":false,"replaceAll":false}}
