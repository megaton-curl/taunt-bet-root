ier;\n  status?: \"open\" | \"all\";\n}\n\nexport interface CreateMatchParams {\n  tier: Tier;\n  side: CoinSide;\n}\n\nexport interface JoinMatchParams {\n  matchId: string;\n}\n","structuredPatch":[{"oldStart":3,"oldLines":9,"newStart":3,"newLines":6,"lines":[" export type CoinSide = \"heads\" | \"tails\";"," export type CoinflipPhase = \"created\" | \"ready\" | \"countdown\" | \"flipping\" | \"complete\";"," ","-/**","- * Simplified match type for UI/mock mode (doesn't require PublicKey)","- */"," export interface UIMatch {","   id: string;","   tier: Tier;"]}],"userModified":false,"replaceAll":false}}
