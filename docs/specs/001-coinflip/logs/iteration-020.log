{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DE4ASADw53ZXqoYCp1hTuR","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→  type TransactionInstruction,\n     8→} from \"@solana/web3.js\";\n     9→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n    10→import {\n    11→  TIER_VALUES,\n    12→  COIN_SIDE_VALUES,\n    13→  TIER_AMOUNTS,\n    14→  type Tier,\n    15→  type CoinSide,\n    16→} from \"@rng-utopia/game-engine/browser\";\n    17→import type { UIMatch } from \"../types\";\n    18→\n    19→// ============ Constants ============\n    20→\n    21→const COINFLIP_PROGRAM_ID = new PublicKey(\n    22→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    23→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    24→);\n    25→\n    26→// Orao VRF program (on-chain VRF provider)\n    27→const ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n    28→\n    29→// ============ PDA Derivation ============\n    30→\n    31→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    32→  return PublicKey.findProgramAddressSync(\n    33→    [Buffer.from(\"match\"), creator.toBuffer()],\n    34→    COINFLIP_PROGRAM_ID\n    35→  );\n    36→}\n    37→\n    38→export function getConfigPda(): [PublicKey, number] {\n    39→  return PublicKey.findProgramAddressSync(\n    40→    [Buffer.from(\"coinflip_config\")],\n    41→    COINFLIP_PROGRAM_ID\n    42→  );\n    43→}\n    44→\n    45→/** Orao VRF network state PDA (stores config + treasury). */\n    46→function getOraoNetworkStatePda(): PublicKey {\n    47→  const [pda] = PublicKey.findProgramAddressSync(\n    48→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    49→    ORAO_VRF_PROGRAM_ID\n    50→  );\n    51→  return pda;\n    52→}\n    53→\n    54→/** Orao VRF randomness PDA derived from a 32-byte seed. */\n    55→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    56→  const [pda] = PublicKey.findProgramAddressSync(\n    57→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    58→    ORAO_VRF_PROGRAM_ID\n    59→  );\n    60→  return pda;\n    61→}\n    62→\n    63→// ============ Program Instance ============\n    64→\n    65→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    66→  // Read-only provider (no wallet needed for queries)\n    67→  const provider = new AnchorProvider(\n    68→    connection,\n    69→    {} as AnchorProvider[\"wallet\"],\n    70→    { commitment: \"confirmed\" }\n    71→  );\n    72→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    73→}\n    74→\n    75→// ============ On-Chain Account Types ============\n    76→\n    77→/** Anchor enum variant representation — one key with empty object value. */\n    78→type RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n    79→  | { resolving: object } | { settled: object } | { refunded: object };\n    80→\n    81→interface OnChainMatch {\n    82→  creator: PublicKey;\n    83→  opponent: PublicKey;\n    84→  tier: number;\n    85→  entryAmount: { toNumber(): number };\n    86→  creatorSide: number;\n    87→  phase: RoundPhaseVariant;\n    88→  result: number;\n    89→  winner: PublicKey;\n    90→  claimed: boolean;\n    91→  createdAt: { toNumber(): number };\n    92→  lockedAt: { toNumber(): number };\n    93→  resolveDeadline: { toNumber(): number };\n    94→  vrfRequestKey: PublicKey;\n    95→  bump: number;\n    96→}\n    97→\n    98→// ============ Converters ============\n    99→\n   100→function tierFromIndex(index: number): Tier {\n   101→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   102→  return tiers[index] ?? \"iron\";\n   103→}\n   104→\n   105→function sideFromIndex(index: number): CoinSide {\n   106→  return index === 0 ? \"heads\" : \"tails\";\n   107→}\n   108→\n   109→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   110→  return name in phase;\n   111→}\n   112→\n   113→function phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n   114→  if (isPhase(phase, \"waiting\")) return \"created\";\n   115→  if (isPhase(phase, \"locked\")) return \"ready\";\n   116→  if (isPhase(phase, \"settled\")) return \"complete\";\n   117→  return \"created\";\n   118→}\n   119→\n   120→const DEFAULT_PUBKEY = PublicKey.default;\n   121→\n   122→function isDefaultPubkey(key: PublicKey): boolean {\n   123→  return key.equals(DEFAULT_PUBKEY);\n   124→}\n   125→\n   126→export function onChainMatchToUI(\n   127→  matchPda: PublicKey,\n   128→  data: OnChainMatch\n   129→): UIMatch {\n   130→  const tier = tierFromIndex(data.tier);\n   131→  const creatorSide = sideFromIndex(data.creatorSide);\n   132→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   133→  const phase = phaseToUI(data.phase);\n   134→  const isSettled = isPhase(data.phase, \"settled\");\n   135→\n   136→  const entryAmountSol = TIER_AMOUNTS[tier];\n   137→  const totalPool = entryAmountSol * 2;\n   138→  const payoutAmount = totalPool * 0.97;\n   139→\n   140→  const lockedAt = data.lockedAt.toNumber();\n   141→\n   142→  return {\n   143→    id: matchPda.toBase58(),\n   144→    tier,\n   145→    entryAmount: entryAmountSol,\n   146→    player1: data.creator.toBase58(),\n   147→    player1Side: creatorSide,\n   148→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   149→    player2Side: hasOpponent\n   150→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   151→      : null,\n   152→    phase,\n   153→    createdAt: Date.now(),\n   154→    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n   155→    result: isSettled ? sideFromIndex(data.result) : null,\n   156→    winner: isSettled && !isDefaultPubkey(data.winner)\n   157→      ? data.winner.toBase58()\n   158→      : null,\n   159→    claimed: data.claimed,\n   160→    payoutAmount,\n   161→    seedHash: \"\",\n   162→  };\n   163→}\n   164→\n   165→// ============ Account Queries ============\n   166→\n   167→export async function fetchAllOpenMatches(\n   168→  connection: Connection\n   169→): Promise<UIMatch[]> {\n   170→  const program = getCoinflipProgram(connection);\n   171→  const accounts = await program.account.coinflipMatch.all();\n   172→\n   173→  return accounts\n   174→    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n   175→    .map((acc) =>\n   176→      onChainMatchToUI(\n   177→        acc.publicKey,\n   178→        acc.account as unknown as OnChainMatch\n   179→      )\n   180→    );\n   181→}\n   182→\n   183→/**\n   184→ * Fetch all matches where playerPubkey is creator OR opponent,\n   185→ * claimed == false, and phase is non-terminal (not refunded).\n   186→ * Uses memcmp filters for efficient on-chain filtering.\n   187→ *\n   188→ * Account layout offsets (after 8-byte discriminator):\n   189→ *   creator:  8   (32 bytes)\n   190→ *   opponent: 40  (32 bytes)\n   191→ *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n   192→ */\n   193→export async function fetchClaimableMatches(\n   194→  connection: Connection,\n   195→  playerPubkey: PublicKey\n   196→): Promise<UIMatch[]> {\n   197→  const program = getCoinflipProgram(connection);\n   198→  const playerBase58 = playerPubkey.toBase58();\n   199→\n   200→  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n   201→  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n   202→\n   203→  const [asCreator, asOpponent] = await Promise.all([\n   204→    program.account.coinflipMatch.all([\n   205→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   206→      claimedFalseFilter,\n   207→    ]),\n   208→    program.account.coinflipMatch.all([\n   209→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   210→      claimedFalseFilter,\n   211→    ]),\n   212→  ]);\n   213→\n   214→  // Merge and deduplicate by public key\n   215→  const seen = new Set<string>();\n   216→  const matches: UIMatch[] = [];\n   217→\n   218→  for (const acc of [...asCreator, ...asOpponent]) {\n   219→    const key = acc.publicKey.toBase58();\n   220→    if (seen.has(key)) continue;\n   221→    seen.add(key);\n   222→\n   223→    const data = acc.account as unknown as OnChainMatch;\n   224→    // Skip terminal phase (refunded)\n   225→    if (isPhase(data.phase, \"refunded\")) continue;\n   226→\n   227→    matches.push(onChainMatchToUI(acc.publicKey, data));\n   228→  }\n   229→\n   230→  return matches;\n   231→}\n   232→\n   233→export async function fetchMatchByCreator(\n   234→  connection: Connection,\n   235→  creator: PublicKey\n   236→): Promise<UIMatch | null> {\n   237→  const program = getCoinflipProgram(connection);\n   238→  const [matchPda] = getMatchPda(creator);\n   239→\n   240→  try {\n   241→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   242→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   243→  } catch {\n   244→    // Account doesn't exist\n   245→    return null;\n   246→  }\n   247→}\n   248→\n   249→export async function fetchMatch(\n   250→  connection: Connection,\n   251→  matchPda: PublicKey\n   252→): Promise<UIMatch | null> {\n   253→  const program = getCoinflipProgram(connection);\n   254→\n   255→  try {\n   256→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   257→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   258→  } catch {\n   259→    return null;\n   260→  }\n   261→}\n   262→\n   263→// ============ Instruction Builders ============\n   264→\n   265→export function buildCreateMatchInstruction(\n   266→  creator: PublicKey,\n   267→  tier: Tier,\n   268→  side: CoinSide\n   269→): { instruction: TransactionInstruction; matchPda: PublicKey } {\n   270→  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n   271→  const [matchPda] = getMatchPda(creator);\n   272→  const [configPda] = getConfigPda();\n   273→\n   274→  const tierIndex = TIER_VALUES[tier];\n   275→  const sideIndex = COIN_SIDE_VALUES[side];\n   276→\n   277→  const instruction = program.methods\n   278→    .createMatch(tierIndex, sideIndex)\n   279→    .accountsStrict({\n   280→      creator,\n   281→      coinflipMatch: matchPda,\n   282→      config: configPda,\n   283→      systemProgram: SystemProgram.programId,\n   284→    })\n   285→    .instruction();\n   286→\n   287→  // instruction() returns a Promise<TransactionInstruction>, but we return\n   288→  // it synchronously wrapped — callers must await the instruction.\n   289→  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n   290→}\n   291→\n   292→export async function buildCreateMatchTx(\n   293→  connection: Connection,\n   294→  creator: PublicKey,\n   295→  tier: Tier,\n   296→  side: CoinSide\n   297→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   298→  const program = getCoinflipProgram(connection);\n   299→  const [matchPda] = getMatchPda(creator);\n   300→  const [configPda] = getConfigPda();\n   301→\n   302→  const tierIndex = TIER_VALUES[tier];\n   303→  const sideIndex = COIN_SIDE_VALUES[side];\n   304→\n   305→  const ix = await program.methods\n   306→    .createMatch(tierIndex, sideIndex)\n   307→    .accountsStrict({\n   308→      creator,\n   309→      coinflipMatch: matchPda,\n   310→      config: configPda,\n   311→      systemProgram: SystemProgram.programId,\n   312→    })\n   313→    .instruction();\n   314→\n   315→  const tx = new Transaction().add(ix);\n   316→  tx.feePayer = creator;\n   317→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   318→\n   319→  return { transaction: tx, matchPda };\n   320→}\n   321→\n   322→export async function buildJoinMatchTx(\n   323→  connection: Connection,\n   324→  opponent: PublicKey,\n   325→  matchCreator: PublicKey\n   326→): Promise<Transaction> {\n   327→  const program = getCoinflipProgram(connection);\n   328→  const [matchPda] = getMatchPda(matchCreator);\n   329→  const [configPda] = getConfigPda();\n   330→\n   331→  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n   332→  const oraoNetworkState = getOraoNetworkStatePda();\n   333→  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n   334→  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n   335→  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n   336→  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n   337→  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n   338→\n   339→  const ix = await program.methods\n   340→    .joinMatch()\n   341→    .accountsStrict({\n   342→      opponent,\n   343→      coinflipMatch: matchPda,\n   344→      config: configPda,\n   345→      oraoProgram: ORAO_VRF_PROGRAM_ID,\n   346→      oraoNetworkState,\n   347→      oraoTreasury,\n   348→      oraoRandom,\n   349→      systemProgram: SystemProgram.programId,\n   350→    })\n   351→    .instruction();\n   352→\n   353→  const tx = new Transaction().add(ix);\n   354→  tx.feePayer = opponent;\n   355→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   356→\n   357→  return tx;\n   358→}\n   359→\n   360→export async function buildCancelMatchTx(\n   361→  connection: Connection,\n   362→  creator: PublicKey\n   363→): Promise<Transaction> {\n   364→  const program = getCoinflipProgram(connection);\n   365→  const [matchPda] = getMatchPda(creator);\n   366→\n   367→  const ix = await program.methods\n   368→    .cancelMatch()\n   369→    .accountsStrict({\n   370→      creator,\n   371→      coinflipMatch: matchPda,\n   372→      systemProgram: SystemProgram.programId,\n   373→    })\n   374→    .instruction();\n   375→\n   376→  const tx = new Transaction().add(ix);\n   377→  tx.feePayer = creator;\n   378→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   379→\n   380→  return tx;\n   381→}\n   382→\n   383→export async function buildTimeoutCancelTx(\n   384→  connection: Connection,\n   385→  caller: PublicKey,\n   386→  matchCreator: PublicKey,\n   387→  opponent: PublicKey\n   388→): Promise<Transaction> {\n   389→  const program = getCoinflipProgram(connection);\n   390→  const [matchPda] = getMatchPda(matchCreator);\n   391→\n   392→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   393→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   394→\n   395→  const ix = await program.methods\n   396→    .timeoutCancel()\n   397→    .accountsStrict({\n   398→      caller,\n   399→      creator: matchCreator,\n   400→      opponent,\n   401→      coinflipMatch: matchPda,\n   402→      randomnessAccount,\n   403→    })\n   404→    .instruction();\n   405→\n   406→  const tx = new Transaction().add(ix);\n   407→  tx.feePayer = caller;\n   408→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   409→\n   410→  return tx;\n   411→}\n   412→\n   413→export async function buildClaimPayoutTx(\n   414→  connection: Connection,\n   415→  caller: PublicKey,\n   416→  matchCreator: PublicKey,\n   417→  opponent: PublicKey\n   418→): Promise<Transaction> {\n   419→  const program = getCoinflipProgram(connection);\n   420→  const [matchPda] = getMatchPda(matchCreator);\n   421→  const [configPda] = getConfigPda();\n   422→\n   423→  // Fetch config to get treasury address\n   424→  const config = await program.account.coinflipConfig.fetch(configPda);\n   425→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   426→\n   427→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   428→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   429→\n   430→  // Derive player profile PDAs for CPI\n   431→  const PLATFORM_PROGRAM_ID = new PublicKey(\n   432→    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n   433→      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n   434→  );\n   435→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   436→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   437→    PLATFORM_PROGRAM_ID\n   438→  );\n   439→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   440→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   441→    PLATFORM_PROGRAM_ID\n   442→  );\n   443→\n   444→  const ix = await program.methods\n   445→    .claimPayout()\n   446→    .accountsStrict({\n   447→      caller,\n   448→      coinflipMatch: matchPda,\n   449→      config: configPda,\n   450→      treasury,\n   451→      creator: matchCreator,\n   452→      opponent,\n   453→      randomnessAccount,\n   454→      creatorProfile,\n   455→      opponentProfile,\n   456→      platformProgram: PLATFORM_PROGRAM_ID,\n   457→      systemProgram: SystemProgram.programId,\n   458→    })\n   459→    .instruction();\n   460→\n   461→  const tx = new Transaction().add(ix);\n   462→  tx.feePayer = caller;\n   463→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   464→\n   465→  return tx;\n   466→}\n   467→"}]},"parent_tool_use_id":null,"session_id":"826f8699-8fd9-4c25-b0a1-b4fd4925d7c0","uuid":"128a14a1-2a9d-4a7e-9704-629665e585a9","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts","content":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  type TransactionInstruction,\n} from \"@solana/web3.js\";\nimport { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  COIN_SIDE_VALUES,\n  TIER_AMOUNTS,\n  type Tier,\n  type CoinSide,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n);\n\n// Orao VRF program (on-chain VRF provider)\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n\n// ============ PDA Derivation ============\n\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n/** Orao VRF network state PDA (stores config + treasury). */\nfunction getOraoNetworkStatePda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n/** Orao VRF randomness PDA derived from a 32-byte seed. */\nfunction getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ============ Program Instance ============\n\nfunction getCoinflipProgram(connection: Connection): Program<Coinflip> {\n  // Read-only provider (no wallet needed for queries)\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n}\n\n// ============ On-Chain Account Types ============\n\n/** Anchor enum variant representation — one key with empty object value. */\ntype RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n  | { resolving: object } | { settled: object } | { refunded: object };\n\ninterface OnChainMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  tier: number;\n  entryAmount: { toNumber(): number };\n  creatorSide: number;\n  phase: RoundPhaseVariant;\n  result: number;\n  winner: PublicKey;\n  claimed: boolean;\n  createdAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  bump: number;\n}\n\n// ============ Converters ============\n\nfunction tierFromIndex(index: number): Tier {\n  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n  return tiers[index] ?? \"iron\";\n}\n\nfunction sideFromIndex(index: number): CoinSide {\n  return index === 0 ? \"heads\" : \"tails\";\n}\n\nfunction isPhase(phase: RoundPhaseVariant, name: string): boolean {\n  return name in phase;\n}\n\nfunction phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n  if (isPhase(phase, \"waiting\")) return \"created\";\n  if (isPhase(phase, \"locked\")) return \"ready\";\n  if (isPhase(phase, \"settled\")) return \"complete\";\n  return \"created\";\n}\n\nconst DEFAULT_PUBKEY = PublicKey.default;\n\nfunction isDefaultPubkey(key: PublicKey): boolean {\n  return key.equals(DEFAULT_PUBKEY);\n}\n\nexport function onChainMatchToUI(\n  matchPda: PublicKey,\n  data: OnChainMatch\n): UIMatch {\n  const tier = tierFromIndex(data.tier);\n  const creatorSide = sideFromIndex(data.creatorSide);\n  const hasOpponent = !isDefaultPubkey(data.opponent);\n  const phase = phaseToUI(data.phase);\n  const isSettled = isPhase(data.phase, \"settled\");\n\n  const entryAmountSol = TIER_AMOUNTS[tier];\n  const totalPool = entryAmountSol * 2;\n  const payoutAmount = totalPool * 0.97;\n\n  const lockedAt = data.lockedAt.toNumber();\n\n  return {\n    id: matchPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    player1: data.creator.toBase58(),\n    player1Side: creatorSide,\n    player2: hasOpponent ? data.opponent.toBase58() : null,\n    player2Side: hasOpponent\n      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n      : null,\n    phase,\n    createdAt: Date.now(),\n    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n    result: isSettled ? sideFromIndex(data.result) : null,\n    winner: isSettled && !isDefaultPubkey(data.winner)\n      ? data.winner.toBase58()\n      : null,\n    claimed: data.claimed,\n    payoutAmount,\n    seedHash: \"\",\n  };\n}\n\n// ============ Account Queries ============\n\nexport async function fetchAllOpenMatches(\n  connection: Connection\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const accounts = await program.account.coinflipMatch.all();\n\n  return accounts\n    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n    .map((acc) =>\n      onChainMatchToUI(\n        acc.publicKey,\n        acc.account as unknown as OnChainMatch\n      )\n    );\n}\n\n/**\n * Fetch all matches where playerPubkey is creator OR opponent,\n * claimed == false, and phase is non-terminal (not refunded).\n * Uses memcmp filters for efficient on-chain filtering.\n *\n * Account layout offsets (after 8-byte discriminator):\n *   creator:  8   (32 bytes)\n *   opponent: 40  (32 bytes)\n *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n */\nexport async function fetchClaimableMatches(\n  connection: Connection,\n  playerPubkey: PublicKey\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const playerBase58 = playerPubkey.toBase58();\n\n  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n\n  const [asCreator, asOpponent] = await Promise.all([\n    program.account.coinflipMatch.all([\n      { memcmp: { offset: 8, bytes: playerBase58 } },\n      claimedFalseFilter,\n    ]),\n    program.account.coinflipMatch.all([\n      { memcmp: { offset: 40, bytes: playerBase58 } },\n      claimedFalseFilter,\n    ]),\n  ]);\n\n  // Merge and deduplicate by public key\n  const seen = new Set<string>();\n  const matches: UIMatch[] = [];\n\n  for (const acc of [...asCreator, ...asOpponent]) {\n    const key = acc.publicKey.toBase58();\n    if (seen.has(key)) continue;\n    seen.add(key);\n\n    const data = acc.account as unknown as OnChainMatch;\n    // Skip terminal phase (refunded)\n    if (isPhase(data.phase, \"refunded\")) continue;\n\n    matches.push(onChainMatchToUI(acc.publicKey, data));\n  }\n\n  return matches;\n}\n\nexport async function fetchMatchByCreator(\n  connection: Connection,\n  creator: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    // Account doesn't exist\n    return null;\n  }\n}\n\nexport async function fetchMatch(\n  connection: Connection,\n  matchPda: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    return null;\n  }\n}\n\n// ============ Instruction Builders ============\n\nexport function buildCreateMatchInstruction(\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): { instruction: TransactionInstruction; matchPda: PublicKey } {\n  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n  const [matchPda] = getMatchPda(creator);\n  const [configPda] = getConfigPda();\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const instruction = program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  // instruction() returns a Promise<TransactionInstruction>, but we return\n  // it synchronously wrapped — callers must await the instruction.\n  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n}\n\nexport async function buildCreateMatchTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n  const [configPda] = getConfigPda();\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const ix = await program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, matchPda };\n}\n\nexport async function buildJoinMatchTx(\n  connection: Connection,\n  opponent: PublicKey,\n  matchCreator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n  const oraoNetworkState = getOraoNetworkStatePda();\n  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n\n  const ix = await program.methods\n    .joinMatch()\n    .accountsStrict({\n      opponent,\n      coinflipMatch: matchPda,\n      config: configPda,\n      oraoProgram: ORAO_VRF_PROGRAM_ID,\n      oraoNetworkState,\n      oraoTreasury,\n      oraoRandom,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = opponent;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildCancelMatchTx(\n  connection: Connection,\n  creator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const ix = await program.methods\n    .cancelMatch()\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildTimeoutCancelTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n\n  // Derive randomness account from match PDA (VRF seed = match PDA key)\n  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n\n  const ix = await program.methods\n    .timeoutCancel()\n    .accountsStrict({\n      caller,\n      creator: matchCreator,\n      opponent,\n      coinflipMatch: matchPda,\n      randomnessAccount,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get treasury address\n  const config = await program.account.coinflipConfig.fetch(configPda);\n  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n\n  // Derive randomness account from match PDA (VRF seed = match PDA key)\n  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n\n  // Derive player profile PDAs for CPI\n  const PLATFORM_PROGRAM_ID = new PublicKey(\n    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n  );\n  const [creatorProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  const [opponentProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n\n  const ix = await program.methods\n    .claimPayout()\n    .accountsStrict({\n      caller,\n      coinflipMatch: matchPda,\n      config: configPda,\n      treasury,\n      creator: matchCreator,\n      opponent,\n      randomnessAccount,\n      creatorProfile,\n      opponentProfile,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n","numLines":467,"startLine":1,"totalLines":467}}}
