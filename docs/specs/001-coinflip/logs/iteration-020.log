tring;\n    56→}\n    57→"}]},"parent_tool_use_id":null,"session_id":"826f8699-8fd9-4c25-b0a1-b4fd4925d7c0","uuid":"90af90c0-24ee-443f-a2ab-226ae8119f22","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/types.ts","content":"import type { Tier } from \"@rng-utopia/game-engine/browser\";\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type CoinflipPhase = \"created\" | \"ready\" | \"countdown\" | \"flipping\" | \"complete\";\n\n/**\n * Simplified match type for UI/mock mode (doesn't require PublicKey)\n */\nexport interface UIMatch {\n  id: string;\n  tier: Tier;\n  entryAmount: number; // in $\n\n  // Player 1 (creator)\n  player1: string; // wallet address\n  player1Side: CoinSide;\n\n  // Player 2 (joiner)\n  player2: string | null;\n  player2Side: CoinSide | null;\n\n  // Match state\n  phase: CoinflipPhase;\n  createdAt: number; // timestamp\n  lockedAt?: number; // when match entered LOCKED phase (ms)\n  countdownStartedAt?: number; // when countdown started\n  completedAt?: number;\n\n  // Result\n  result: CoinSide | null;\n  winner: string | null;\n\n  // Payout\n  claimed: boolean;\n  payoutAmount: number; // amount winner receives\n\n  // Provably Fair - VRF-based verification\n  seedHash: string; // SHA-256 hash of server seed (shown before flip)\n  serverSeed?: string; // Actual server seed (revealed only after settlement)\n  vrfProof?: string; // VRF proof for on-chain verification\n  blockHash?: string; // Solana blockhash used as entropy source\n}\n\nexport interface MatchFilter {\n  tier?: Tier;\n  status?: \"open\" | \"all\";\n}\n\nexport interface CreateMatchParams {\n  tier: Tier;\n  side: CoinSide;\n}\n\nexport interface JoinMatchParams {\n  matchId: string;\n}\n","numLines":57,"startLine":1,"totalLines":57}}}
