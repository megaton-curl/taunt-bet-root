{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PUbmczhh17RMu6WAotCLFR","type":"tool_result","content":"     1→import { useState } from \"react\";\n     2→import {\n     3→  GameLayout,\n     4→  TierSelector,\n     5→  TIER_COLORS,\n     6→  Modal,\n     7→  type HistoryEntry,\n     8→} from \"@rng-utopia/ui\";\n     9→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    10→import { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\n    11→import {\n    12→  CoinflipProvider,\n    13→  useCoinflip,\n    14→  CoinSideSelector,\n    15→  OpenMatchesList,\n    16→  ActiveMatchView,\n    17→  type UIMatch,\n    18→} from \"../features/coinflip\";\n    19→\n    20→function CoinflipPageContent() {\n    21→  const { connected, address, connect } = useWallet();\n    22→  const {\n    23→    activeMatch,\n    24→    openMatches,\n    25→    userHistory,\n    26→    selectedTier,\n    27→    selectedSide,\n    28→    loading,\n    29→    creating,\n    30→    joiningMatchId,\n    31→    setSelectedTier,\n    32→    setSelectedSide,\n    33→    createMatch,\n    34→    joinMatch,\n    35→    clearActiveMatch,\n    36→  } = useCoinflip();\n    37→\n    38→  // State for history detail modal\n    39→  const [selectedHistoryMatch, setSelectedHistoryMatch] = useState<UIMatch | null>(null);\n    40→\n    41→  // Side colors (match the CSS .side-heads / .side-tails)\n    42→  const SIDE_COLORS = {\n    43→    heads: \"#00cc88\",\n    44→    tails: \"#ff6644\",\n    45→  };\n    46→\n    47→  // Convert user history to HistoryEntry format\n    48→  const historyEntries: HistoryEntry[] = userHistory.map((match) => {\n    49→    const isWinner = match.winner === address;\n    50→    const isPlayer1 = match.player1 === address;\n    51→    const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    52→    const tierCapitalized = match.tier.charAt(0).toUpperCase() + match.tier.slice(1);\n    53→    const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n    54→    const tierColor = TIER_COLORS[match.tier];\n    55→    const outcomeColor = isWinner ? \"#39ff14\" : \"#d45d5d\";\n    56→\n    57→    return {\n    58→      roundId: match.id.slice(-6),\n    59→      result: (\n    60→        <span className=\"coinflip-history-result\">\n    61→          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n    62→            {yourSide?.toUpperCase() ?? \"?\"}\n    63→          </span>\n    64→          <span className=\"coinflip-history-result__separator\">|</span>\n    65→          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n    66→            {tierCapitalized}\n    67→          </span>\n    68→          <span className=\"coinflip-history-result__separator\">|</span>\n    69→          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n    70→            {isWinner ? \"WON\" : \"LOST\"}\n    71→          </span>\n    72→        </span>\n    73→      ),\n    74→      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n    75→      timestamp: new Date(match.completedAt ?? match.createdAt),\n    76→      verified: true,\n    77→      won: isWinner,\n    78→      onClick: () => setSelectedHistoryMatch(match),\n    79→    };\n    80→  });\n    81→\n    82→  // Calculate potential payout\n    83→  const potentialPayout = selectedTier\n    84→    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n    85→    : 0;\n    86→\n    87→  const handleCreateMatch = async () => {\n    88→    try {\n    89→      await createMatch();\n    90→    } catch (error) {\n    91→      console.error(\"Failed to create match:\", error);\n    92→    }\n    93→  };\n    94→\n    95→  const handleJoinMatch = async (matchId: string) => {\n    96→    try {\n    97→      await joinMatch(matchId);\n    98→    } catch (error) {\n    99→      console.error(\"Failed to join match:\", error);\n   100→    }\n   101→  };\n   102→\n   103→  // Sidebar content\n   104→  const sidebar = (\n   105→    <div className=\"coinflip-sidebar\">\n   106→      {!activeMatch ? (\n   107→        <>\n   108→          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n   109→\n   110→          {/* Tier Selection */}\n   111→          <div className=\"coinflip-sidebar__section\">\n   112→            <div className=\"coinflip-sidebar__label-row\">\n   113→              <label className=\"coinflip-sidebar__label\">\n   114→                Select Tier\n   115→                <img\n   116→                  src=\"https://cryptologos.cc/logos/solana-sol-logo.svg\"\n   117→                  alt=\"SOL\"\n   118→                  className=\"coinflip-sidebar__sol-icon\"\n   119→                />\n   120→              </label>\n   121→              <button\n   122→                type=\"button\"\n   123→                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n   124→                onClick={() => setSelectedTier(null)}\n   125→              >\n   126→                All\n   127→              </button>\n   128→            </div>\n   129→            <TierSelector\n   130→              selectedTier={selectedTier}\n   131→              onSelect={setSelectedTier}\n   132→            />\n   133→          </div>\n   134→\n   135→          {/* Side Selection */}\n   136→          <div className=\"coinflip-sidebar__section\">\n   137→            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n   138→            <CoinSideSelector\n   139→              selectedSide={selectedSide}\n   140→              onSelect={setSelectedSide}\n   141→              disabled={!connected}\n   142→            />\n   143→          </div>\n   144→\n   145→          {/* Summary */}\n   146→          {selectedTier && selectedSide && (\n   147→            <div className=\"coinflip-sidebar__summary\">\n   148→              <div className=\"coinflip-sidebar__row\">\n   149→                <span>Entry</span>\n   150→                <span>{TIER_AMOUNTS[selectedTier]} SOL</span>\n   151→              </div>\n   152→              <div className=\"coinflip-sidebar__row\">\n   153→                <span>Potential Payout</span>\n   154→                <span className=\"coinflip-sidebar__payout\">\n   155→                  {potentialPayout.toFixed(4)} SOL\n   156→                </span>\n   157→              </div>\n   158→            </div>\n   159→          )}\n   160→\n   161→          {/* Action Button */}\n   162→          {!connected ? (\n   163→            <button\n   164→              type=\"button\"\n   165→              className=\"coinflip-action-btn\"\n   166→              onClick={connect}\n   167→            >\n   168→              Connect Wallet\n   169→            </button>\n   170→          ) : (\n   171→            <button\n   172→              type=\"button\"\n   173→              className=\"coinflip-action-btn\"\n   174→              onClick={handleCreateMatch}\n   175→              disabled={!selectedTier || !selectedSide || creating}\n   176→            >\n   177→              {creating ? \"Creating...\" : \"Create Game\"}\n   178→            </button>\n   179→          )}\n   180→        </>\n   181→      ) : (\n   182→        <>\n   183→          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n   184→\n   185→          <div className=\"coinflip-sidebar__game-info\">\n   186→            <div className=\"coinflip-sidebar__row\">\n   187→              <span>Tier</span>\n   188→              <span\n   189→                className=\"coinflip-sidebar__tier\"\n   190→                style={{\n   191→                  color: TIER_COLORS[activeMatch.tier],\n   192→                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n   193→                }}\n   194→              >\n   195→                {activeMatch.tier}\n   196→              </span>\n   197→            </div>\n   198→            <div className=\"coinflip-sidebar__row\">\n   199→              <span>Your Side</span>\n   200→              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n   201→                {(activeMatch.player1 === address\n   202→                  ? activeMatch.player1Side\n   203→                  : activeMatch.player2Side\n   204→                )?.toUpperCase()}\n   205→              </span>\n   206→            </div>\n   207→            <div className=\"coinflip-sidebar__row\">\n   208→              <span>Entry</span>\n   209→              <span>{activeMatch.entryAmount} SOL</span>\n   210→            </div>\n   211→            <div className=\"coinflip-sidebar__row\">\n   212→              <span>Pot</span>\n   213→              <span className=\"coinflip-sidebar__pot\">{activeMatch.entryAmount * 2} SOL</span>\n   214→            </div>\n   215→            <div className=\"coinflip-sidebar__row\">\n   216→              <span>Status</span>\n   217→              <span className=\"coinflip-sidebar__status\">\n   218→                {activeMatch.phase === \"created\" && \"Waiting...\"}\n   219→                {activeMatch.phase === \"ready\" && \"Ready!\"}\n   220→                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n   221→                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n   222→                {activeMatch.phase === \"complete\" && \"Complete\"}\n   223→              </span>\n   224→            </div>\n   225→          </div>\n   226→\n   227→          {/* Round Fairness Info */}\n   228→          <div className=\"coinflip-sidebar__fairness\">\n   229→            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n   230→            <div className=\"coinflip-sidebar__fairness-row\">\n   231→              <span>Match ID</span>\n   232→              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n   233→                {activeMatch.id.slice(-8)}\n   234→              </span>\n   235→            </div>\n   236→            <div className=\"coinflip-sidebar__fairness-row\">\n   237→              <span>Seed Hash</span>\n   238→              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n   239→                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n   240→              </span>\n   241→            </div>\n   242→            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n   243→              <>\n   244→                <div className=\"coinflip-sidebar__fairness-row\">\n   245→                  <span>Server Seed</span>\n   246→                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n   247→                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n   248→                  </span>\n   249→                </div>\n   250→                {activeMatch.blockHash && (\n   251→                  <div className=\"coinflip-sidebar__fairness-row\">\n   252→                    <span>Block Hash</span>\n   253→                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n   254→                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n   255→                    </span>\n   256→                  </div>\n   257→                )}\n   258→              </>\n   259→            )}\n   260→          </div>\n   261→\n   262→          {activeMatch.phase === \"complete\" && (\n   263→            <button\n   264→              type=\"button\"\n   265→              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   266→              onClick={clearActiveMatch}\n   267→            >\n   268→              Back to Lobby\n   269→            </button>\n   270→          )}\n   271→        </>\n   272→      )}\n   273→    </div>\n   274→  );\n   275→\n   276→  // Helper to get side display for modal\n   277→  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n   278→    const side = isPlayer1 ? match.player1Side : match.player2Side;\n   279→    return side?.toUpperCase() ?? \"?\";\n   280→  };\n   281→\n   282→  return (\n   283→    <>\n   284→      <GameLayout\n   285→        gameName=\"Coinflip\"\n   286→        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n   287→        sidebar={sidebar}\n   288→        historyEntries={historyEntries}\n   289→        showHistory={true}\n   290→      >\n   291→        <div className=\"coinflip-main\">\n   292→          {/* Show active match or lobby */}\n   293→          {activeMatch ? (\n   294→            <ActiveMatchView\n   295→              match={activeMatch}\n   296→              currentUserAddress={address ?? \"\"}\n   297→            />\n   298→          ) : (\n   299→            <div className=\"coinflip-lobby\">\n   300→              <OpenMatchesList\n   301→                matches={openMatches}\n   302→                loading={loading}\n   303→                onJoin={handleJoinMatch}\n   304→                joiningMatchId={joiningMatchId}\n   305→                currentUserAddress={address}\n   306→                selectedTier={selectedTier}\n   307→                isConnected={connected}\n   308→              />\n   309→            </div>\n   310→          )}\n   311→        </div>\n   312→      </GameLayout>\n   313→\n   314→      {/* History Detail Modal */}\n   315→      <Modal\n   316→        isOpen={selectedHistoryMatch !== null}\n   317→        onClose={() => setSelectedHistoryMatch(null)}\n   318→        title=\"Match Details\"\n   319→      >\n   320→        {selectedHistoryMatch && (() => {\n   321→          const isPlayer1 = selectedHistoryMatch.player1 === address;\n   322→          const isWinner = selectedHistoryMatch.winner === address;\n   323→          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n   324→          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n   325→\n   326→          return (\n   327→            <div className=\"coinflip-history-modal\">\n   328→              {/* Match Stats */}\n   329→              <div className=\"coinflip-history-modal__section\">\n   330→                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n   331→                <div className=\"coinflip-history-modal__row\">\n   332→                  <span>Tier</span>\n   333→                  <span\n   334→                    style={{\n   335→                      color: TIER_COLORS[selectedHistoryMatch.tier],\n   336→                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n   337→                      textTransform: \"capitalize\",\n   338→                    }}\n   339→                  >\n   340→                    {selectedHistoryMatch.tier}\n   341→                  </span>\n   342→                </div>\n   343→                <div className=\"coinflip-history-modal__row\">\n   344→                  <span>Your Side</span>\n   345→                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n   346→                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n   347→                  </span>\n   348→                </div>\n   349→                <div className=\"coinflip-history-modal__row\">\n   350→                  <span>Entry</span>\n   351→                  <span>{selectedHistoryMatch.entryAmount} SOL</span>\n   352→                </div>\n   353→                <div className=\"coinflip-history-modal__row\">\n   354→                  <span>Total Pot</span>\n   355→                  <span className=\"coinflip-history-modal__highlight\">\n   356→                    {(selectedHistoryMatch.entryAmount * 2).toFixed(4)} SOL\n   357→                  </span>\n   358→                </div>\n   359→                <div className=\"coinflip-history-modal__row\">\n   360→                  <span>Result</span>\n   361→                  <span\n   362→                    style={{\n   363→                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n   364→                      textShadow: selectedHistoryMatch.result\n   365→                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n   366→                        : undefined,\n   367→                    }}\n   368→                  >\n   369→                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n   370→                  </span>\n   371→                </div>\n   372→                <div className=\"coinflip-history-modal__row\">\n   373→                  <span>Outcome</span>\n   374→                  <span\n   375→                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n   376→                    style={{ color: isWinner ? \"#39ff14\" : \"#d45d5d\" }}\n   377→                  >\n   378→                    {isWinner ? \"WON!\" : \"LOST\"}\n   379→                  </span>\n   380→                </div>\n   381→                <div className=\"coinflip-history-modal__row\">\n   382→                  <span>Payout</span>\n   383→                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n   384→                    {isWinner ? `+${selectedHistoryMatch.payoutAmount.toFixed(4)}` : `-${selectedHistoryMatch.entryAmount.toFixed(4)}`} SOL\n   385→                  </span>\n   386→                </div>\n   387→              </div>\n   388→\n   389→              {/* Match Fairness */}\n   390→              <div className=\"coinflip-history-modal__section\">\n   391→                <h4 className=\"coinflip-history-modal__section-title\">\n   392→                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n   393→                  Round Fairness\n   394→                </h4>\n   395→                <div className=\"coinflip-history-modal__row\">\n   396→                  <span>Match ID</span>\n   397→                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n   398→                    {selectedHistoryMatch.id}\n   399→                  </span>\n   400→                </div>\n   401→                <div className=\"coinflip-history-modal__row\">\n   402→                  <span>Seed Hash</span>\n   403→                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n   404→                    {selectedHistoryMatch.seedHash}\n   405→                  </span>\n   406→                </div>\n   407→                {selectedHistoryMatch.serverSeed && (\n   408→                  <div className=\"coinflip-history-modal__row\">\n   409→                    <span>Server Seed</span>\n   410→                    <span\n   411→                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n   412→                      title={selectedHistoryMatch.serverSeed}\n   413→                    >\n   414→                      {selectedHistoryMatch.serverSeed}\n   415→                    </span>\n   416→                  </div>\n   417→                )}\n   418→                {selectedHistoryMatch.blockHash && (\n   419→                  <div className=\"coinflip-history-modal__row\">\n   420→                    <span>Block Hash</span>\n   421→                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n   422→                      {selectedHistoryMatch.blockHash}\n   423→                    </span>\n   424→                  </div>\n   425→                )}\n   426→                {selectedHistoryMatch.vrfProof && (\n   427→                  <div className=\"coinflip-history-modal__row\">\n   428→                    <span>VRF Proof</span>\n   429→                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n   430→                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n   431→                    </span>\n   432→                  </div>\n   433→                )}\n   434→              </div>\n   435→\n   436→              {/* Verify Link */}\n   437→              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n   438→                Verify on Fairness Page →\n   439→              </a>\n   440→            </div>\n   441→          );\n   442→        })()}\n   443→      </Modal>\n   444→    </>\n   445→  );\n   446→}\n   447→\n   448→export function CoinflipPage() {\n   449→  return (\n   450→    <CoinflipProvider>\n   451→      <CoinflipPageContent />\n   452→    </CoinflipProvider>\n   453→  );\n   454→}\n   455→"}]},"parent_tool_use_id":null,"session_id":"44b168fb-5e34-4073-98cb-22d0c5867ea1","uuid":"57eb1453-fdca-4361-9fb7-482a52807c6a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/pages/CoinflipPage.tsx","content":"import { useState } from \"react\";\nimport {\n  GameLayout,\n  TierSelector,\n  TIER_COLORS,\n  Modal,\n  type HistoryEntry,\n} from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\nimport {\n  CoinflipProvider,\n  useCoinflip,\n  CoinSideSelector,\n  OpenMatchesList,\n  ActiveMatchView,\n  type UIMatch,\n} from \"../features/coinflip\";\n\nfunction CoinflipPageContent() {\n  const { connected, address, connect } = useWallet();\n  const {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    clearActiveMatch,\n  } = useCoinflip();\n\n  // State for history detail modal\n  const [selectedHistoryMatch, setSelectedHistoryMatch] = useState<UIMatch | null>(null);\n\n  // Side colors (match the CSS .side-heads / .side-tails)\n  const SIDE_COLORS = {\n    heads: \"#00cc88\",\n    tails: \"#ff6644\",\n  };\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((match) => {\n    const isWinner = match.winner === address;\n    const isPlayer1 = match.player1 === address;\n    const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    const tierCapitalized = match.tier.charAt(0).toUpperCase() + match.tier.slice(1);\n    const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n    const tierColor = TIER_COLORS[match.tier];\n    const outcomeColor = isWinner ? \"#39ff14\" : \"#d45d5d\";\n\n    return {\n      roundId: match.id.slice(-6),\n      result: (\n        <span className=\"coinflip-history-result\">\n          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n            {yourSide?.toUpperCase() ?? \"?\"}\n          </span>\n          <span className=\"coinflip-history-result__separator\">|</span>\n          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n            {tierCapitalized}\n          </span>\n          <span className=\"coinflip-history-result__separator\">|</span>\n          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {isWinner ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n      timestamp: new Date(match.completedAt ?? match.createdAt),\n      verified: true,\n      won: isWinner,\n      onClick: () => setSelectedHistoryMatch(match),\n    };\n  });\n\n  // Calculate potential payout\n  const potentialPayout = selectedTier\n    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n    : 0;\n\n  const handleCreateMatch = async () => {\n    try {\n      await createMatch();\n    } catch (error) {\n      console.error(\"Failed to create match:\", error);\n    }\n  };\n\n  const handleJoinMatch = async (matchId: string) => {\n    try {\n      await joinMatch(matchId);\n    } catch (error) {\n      console.error(\"Failed to join match:\", error);\n    }\n  };\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"coinflip-sidebar\">\n      {!activeMatch ? (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n\n          {/* Tier Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <div className=\"coinflip-sidebar__label-row\">\n              <label className=\"coinflip-sidebar__label\">\n                Select Tier\n                <img\n                  src=\"https://cryptologos.cc/logos/solana-sol-logo.svg\"\n                  alt=\"SOL\"\n                  className=\"coinflip-sidebar__sol-icon\"\n                />\n              </label>\n              <button\n                type=\"button\"\n                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n                onClick={() => setSelectedTier(null)}\n              >\n                All\n              </button>\n            </div>\n            <TierSelector\n              selectedTier={selectedTier}\n              onSelect={setSelectedTier}\n            />\n          </div>\n\n          {/* Side Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n            <CoinSideSelector\n              selectedSide={selectedSide}\n              onSelect={setSelectedSide}\n              disabled={!connected}\n            />\n          </div>\n\n          {/* Summary */}\n          {selectedTier && selectedSide && (\n            <div className=\"coinflip-sidebar__summary\">\n              <div className=\"coinflip-sidebar__row\">\n                <span>Entry</span>\n                <span>{TIER_AMOUNTS[selectedTier]} SOL</span>\n              </div>\n              <div className=\"coinflip-sidebar__row\">\n                <span>Potential Payout</span>\n                <span className=\"coinflip-sidebar__payout\">\n                  {potentialPayout.toFixed(4)} SOL\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Action Button */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={handleCreateMatch}\n              disabled={!selectedTier || !selectedSide || creating}\n            >\n              {creating ? \"Creating...\" : \"Create Game\"}\n            </button>\n          )}\n        </>\n      ) : (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n\n          <div className=\"coinflip-sidebar__game-info\">\n            <div className=\"coinflip-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"coinflip-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[activeMatch.tier],\n                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n                }}\n              >\n                {activeMatch.tier}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Your Side</span>\n              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n                {(activeMatch.player1 === address\n                  ? activeMatch.player1Side\n                  : activeMatch.player2Side\n                )?.toUpperCase()}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Entry</span>\n              <span>{activeMatch.entryAmount} SOL</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Pot</span>\n              <span className=\"coinflip-sidebar__pot\">{activeMatch.entryAmount * 2} SOL</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Status</span>\n              <span className=\"coinflip-sidebar__status\">\n                {activeMatch.phase === \"created\" && \"Waiting...\"}\n                {activeMatch.phase === \"ready\" && \"Ready!\"}\n                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n                {activeMatch.phase === \"complete\" && \"Complete\"}\n              </span>\n            </div>\n          </div>\n\n          {/* Round Fairness Info */}\n          <div className=\"coinflip-sidebar__fairness\">\n            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Match ID</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n                {activeMatch.id.slice(-8)}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Seed Hash</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n              </span>\n            </div>\n            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n              <>\n                <div className=\"coinflip-sidebar__fairness-row\">\n                  <span>Server Seed</span>\n                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n                  </span>\n                </div>\n                {activeMatch.blockHash && (\n                  <div className=\"coinflip-sidebar__fairness-row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n                    </span>\n                  </div>\n                )}\n              </>\n            )}\n          </div>\n\n          {activeMatch.phase === \"complete\" && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n              onClick={clearActiveMatch}\n            >\n              Back to Lobby\n            </button>\n          )}\n        </>\n      )}\n    </div>\n  );\n\n  // Helper to get side display for modal\n  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n    const side = isPlayer1 ? match.player1Side : match.player2Side;\n    return side?.toUpperCase() ?? \"?\";\n  };\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Coinflip\"\n        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"coinflip-main\">\n          {/* Show active match or lobby */}\n          {activeMatch ? (\n            <ActiveMatchView\n              match={activeMatch}\n              currentUserAddress={address ?? \"\"}\n            />\n          ) : (\n            <div className=\"coinflip-lobby\">\n              <OpenMatchesList\n                matches={openMatches}\n                loading={loading}\n                onJoin={handleJoinMatch}\n                joiningMatchId={joiningMatchId}\n                currentUserAddress={address}\n                selectedTier={selectedTier}\n                isConnected={connected}\n              />\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* History Detail Modal */}\n      <Modal\n        isOpen={selectedHistoryMatch !== null}\n        onClose={() => setSelectedHistoryMatch(null)}\n        title=\"Match Details\"\n      >\n        {selectedHistoryMatch && (() => {\n          const isPlayer1 = selectedHistoryMatch.player1 === address;\n          const isWinner = selectedHistoryMatch.winner === address;\n          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n\n          return (\n            <div className=\"coinflip-history-modal\">\n              {/* Match Stats */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Tier</span>\n                  <span\n                    style={{\n                      color: TIER_COLORS[selectedHistoryMatch.tier],\n                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n                      textTransform: \"capitalize\",\n                    }}\n                  >\n                    {selectedHistoryMatch.tier}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Entry</span>\n                  <span>{selectedHistoryMatch.entryAmount} SOL</span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Total Pot</span>\n                  <span className=\"coinflip-history-modal__highlight\">\n                    {(selectedHistoryMatch.entryAmount * 2).toFixed(4)} SOL\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Result</span>\n                  <span\n                    style={{\n                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n                      textShadow: selectedHistoryMatch.result\n                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n                        : undefined,\n                    }}\n                  >\n                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n                    style={{ color: isWinner ? \"#39ff14\" : \"#d45d5d\" }}\n                  >\n                    {isWinner ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Payout</span>\n                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n                    {isWinner ? `+${selectedHistoryMatch.payoutAmount.toFixed(4)}` : `-${selectedHistoryMatch.entryAmount.toFixed(4)}`} SOL\n                  </span>\n                </div>\n              </div>\n\n              {/* Match Fairness */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">\n                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n                  Round Fairness\n                </h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Match ID</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n                    {selectedHistoryMatch.id}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Seed Hash</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n                    {selectedHistoryMatch.seedHash}\n                  </span>\n                </div>\n                {selectedHistoryMatch.serverSeed && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Server Seed</span>\n                    <span\n                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n                      title={selectedHistoryMatch.serverSeed}\n                    >\n                      {selectedHistoryMatch.serverSeed}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.blockHash && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n                      {selectedHistoryMatch.blockHash}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.vrfProof && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>VRF Proof</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n                    </span>\n                  </div>\n                )}\n              </div>\n\n              {/* Verify Link */}\n              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n                Verify on Fairness Page →\n              </a>\n            </div>\n          );\n        })()}\n      </Modal>\n    </>\n  );\n}\n\nexport function CoinflipPage() {\n  return (\n    <CoinflipProvider>\n      <CoinflipPageContent />\n    </CoinflipProvider>\n  );\n}\n","numLines":455,"startLine":1,"totalLines":455}}}
