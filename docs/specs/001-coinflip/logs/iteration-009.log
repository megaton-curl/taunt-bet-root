Tier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendTransaction(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","structuredPatch":[{"oldStart":25,"oldLines":6,"newStart":25,"newLines":47,"lines":[" const RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env","   .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";"," ","+/** Parse Solana/wallet errors into user-friendly messages */","+function parseTransactionError(err: unknown): string {","+  const msg = err instanceof Error ? err.message : String(err);","+","+  // Wallet not connected","+  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {","+    return \"Wallet not connected. Please connect your wallet first.\";","+  }","+","+  // User rejected","+  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {","+    return \"Transaction cancelled by user.\";","+  }","+","+  // Insufficient funds (Solana runtime error)","+  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {","+    return \"Insufficient balance. You need more SOL to complete this transaction.\";","+  }","+","+  // Account already in use (match already exists)","+  if (msg.includes(\"already in use\")) {","+    return \"You already have an active match. Cancel it before creating a new one.\";","+  }","+","+  // Network / RPC errors","+  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {","+    return \"Network error. Please check your connection and try again.\";","+  }","+","+  // Anchor program errors","+  if (msg.includes(\"InvalidPhase\")) {","+    return \"This match is no longer available.\";","+  }","+  if (msg.includes(\"CannotJoinOwnMatch\")) {","+    return \"You cannot join your own match.\";","+  }","+","+  // Generic fallback","+  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;","+}","+"," interface CoinflipContextValue {","   // State","   activeMatch: UIMatch | null;"]},{"oldStart":40,"oldLines":6,"newStart":81,"newLines":10,"lines":["   claiming: boolean;","   joiningMatchId: string | null;"," ","+  // Error state","+  error: string | null;","+  clearError: () => void;","+","   // Actions","   setSelectedTier: (tier: Tier | null) => void;","   setSelectedSide: (side: CoinSide | null) => void;"]},{"oldStart":74,"oldLines":6,"newStart":119,"newLines":10,"lines":["   const [claiming, setClaiming] = useState(false);","   const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);"," ","+  // Error state","+  const [error, setError] = useState<string | null>(null);","+  const clearError = useCallback(() => setError(null), []);","+","   // Fetch open matches from on-chain","   const refreshMatches = useCallback(() => {","     fetchAllOpenMatches(connection)"]},{"oldStart":119,"oldLines":13,"newStart":168,"newLines":16,"lines":[" ","   const createMatch = useCallback(async () => {","     if (!connected || !publicKey) {","-      throw new Error(\"Wallet not connected\");","+      setError(\"Wallet not connected. Please connect your wallet first.\");","+      return;","     }","     if (!selectedTier || !selectedSide) {","-      throw new Error(\"Select tier and side first\");","+      setError(\"Select tier and side first.\");","+      return;","     }"," ","     setCreating(true);","+    setError(null);","     try {","       const { transaction, matchPda } = await buildCreateMatchTx(","         connection,"]},{"oldStart":144,"oldLines":6,"newStart":196,"newLines":8,"lines":[" ","       setSelectedSide(null);","       refreshMatches();","+    } catch (err) {","+      setError(parseTransactionError(err));","     } finally {","       setCreating(false);","     }"]},{"oldStart":152,"oldLines":17,"newStart":206,"newLines":20,"lines":["   const joinMatch = useCallback(","     async (matchId: string) => {","       if (!connected || !publicKey) {","-        throw new Error(\"Wallet not connected\");","+        setError(\"Wallet not connected. Please connect your wallet first.\");","+        return;","       }"," ","       setJoining(true);","       setJoiningMatchId(matchId);","+      setError(null);","       try {","         // matchId is the match PDA base58 — fetch to get the creator","         const matchPda = new PublicKey(matchId);","         const existingMatch = await fetchMatch(connection, matchPda);","         if (!existingMatch) {","-          throw new Error(\"Match not found\");","+          setError(\"Match not found. It may have been cancelled.\");","+          return;","         }"," ","         const matchCreator = new PublicKey(existingMatch.player1);"]},{"oldStart":181,"oldLines":6,"newStart":238,"newLines":8,"lines":["         }"," ","         refreshMatches();","+      } catch (err) {","+        setError(parseTransactionError(err));","       } finally {","         setJoining(false);","         setJoiningMatchId(null);"]},{"oldStart":191,"oldLines":21,"newStart":250,"newLines":29,"lines":[" ","   const cancelMatch = useCallback(async () => {","     if (!connected || !publicKey || !activeMatch) {","-      throw new Error(\"No active match to cancel\");","+      setError(\"No active match to cancel.\");","+      return;","     }"," ","-    const transaction = await buildCancelMatchTx(connection, publicKey);","-    await sendTransaction(transaction);","-    setActiveMatch(null);","-    refreshMatches();","+    setError(null);","+    try {","+      const transaction = await buildCancelMatchTx(connection, publicKey);","+      await sendTransaction(transaction);","+      setActiveMatch(null);","+      refreshMatches();","+    } catch (err) {","+      setError(parseTransactionError(err));","+    }","   }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);"," ","   const claimPayout = useCallback(async () => {","     if (!connected || !publicKey || !activeMatch) {","-      throw new Error(\"No active match to claim\");","+      setError(\"No active match to claim.\");","+      return;","     }"," ","     setClaiming(true);","+    setError(null);","     try {","       const matchCreator = new PublicKey(activeMatch.player1);","       const opponent = activeMatch.player2"]},{"oldStart":223,"oldLines":6,"newStart":290,"newLines":8,"lines":[" ","       // Update local state","       setActiveMatch({ ...activeMatch, claimed: true });","+    } catch (err) {","+      setError(parseTransactionError(err));","     } finally {","       setClaiming(false);","     }"]},{"oldStart":234,"oldLines":6,"newStart":303,"newLines":7,"lines":["   const clearActiveMatch = useCallback(() => {","     setActiveMatch(null);","     setUserClearedMatch(true);","+    setError(null);","     refreshMatches();","   }, [refreshMatches]);"," "]},{"oldStart":270,"oldLines":6,"newStart":340,"newLines":8,"lines":["     joining,","     claiming,","     joiningMatchId,","+    error,","+    clearError,","     setSelectedTier,","     setSelectedSide,","     createMatch,"]}],"originalFile":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\n// RPC endpoint — defaults to localhost for development\nconst RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n\n  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier || !selectedSide) {\n      throw new Error(\"Select tier and side first\");\n    }\n\n    setCreating(true);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          throw new Error(\"Match not found\");\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to cancel\");\n    }\n\n    const transaction = await buildCancelMatchTx(connection, publicKey);\n    await sendTransaction(transaction);\n    setActiveMatch(null);\n    refreshMatches();\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to claim\");\n    }\n\n    setClaiming(true);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n"}}
