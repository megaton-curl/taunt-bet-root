{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L4FkH6kMEDnWmU8Hqjs6pm","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→\n     3→// ============ Tier System ============\n     4→\n     5→export type Tier = \"iron\" | \"bronze\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n     6→\n     7→export const TIER_VALUES: Record<Tier, number> = {\n     8→  iron: 0,\n     9→  bronze: 1,\n    10→  silver: 2,\n    11→  gold: 3,\n    12→  platinum: 4,\n    13→  diamond: 5,\n    14→};\n    15→\n    16→export const TIER_AMOUNTS: Record<Tier, number> = {\n    17→  iron: 0.005,\n    18→  bronze: 0.01,\n    19→  silver: 0.1,\n    20→  gold: 0.25,\n    21→  platinum: 0.5,\n    22→  diamond: 1,\n    23→};\n    24→\n    25→export const TIER_AMOUNTS_LAMPORTS: Record<Tier, number> = {\n    26→  iron: 5_000_000,\n    27→  bronze: 10_000_000,\n    28→  silver: 100_000_000,\n    29→  gold: 250_000_000,\n    30→  platinum: 500_000_000,\n    31→  diamond: 1_000_000_000,\n    32→};\n    33→\n    34→// ============ Pool State ============\n    35→\n    36→export type PoolPhase = \"waiting\" | \"locked\" | \"resolving\" | \"settled\" | \"cancelled\";\n    37→\n    38→export const POOL_PHASE_VALUES: Record<PoolPhase, number> = {\n    39→  waiting: 0,\n    40→  locked: 1,\n    41→  resolving: 2,\n    42→  settled: 3,\n    43→  cancelled: 4,\n    44→};\n    45→\n    46→export interface Pool {\n    47→  poolId: Uint8Array;\n    48→  gameId: string;\n    49→  roundId: number;\n    50→  tier: Tier;\n    51→  entryAmount: number;\n    52→  phase: PoolPhase;\n    53→  totalPool: number;\n    54→  playerCount: number;\n    55→  maxPlayers: number;\n    56→  createdAt: Date;\n    57→  lockedAt: Date | null;\n    58→  settledAt: Date | null;\n    59→  feeBps: number;\n    60→  vrfRequest: PublicKey | null;\n    61→  randomness: Uint8Array | null;\n    62→  winner: PublicKey | null;\n    63→  authority: PublicKey;\n    64→  treasury: PublicKey;\n    65→  carryoverAmount: number;\n    66→  carryoverFromRound: number;\n    67→}\n    68→\n    69→// ============ Player Entry ============\n    70→\n    71→export type Side = \"none\" | \"green\" | \"red\";\n    72→\n    73→export const SIDE_VALUES: Record<Side, number> = {\n    74→  none: 0,\n    75→  green: 1,\n    76→  red: 2,\n    77→};\n    78→\n    79→export interface PlayerEntry {\n    80→  pool: PublicKey;\n    81→  player: PublicKey;\n    82→  amount: number;\n    83→  enteredAt: Date;\n    84→  sequence: number;\n    85→  side: Side;\n    86→  cashoutMultiplier: number | null;\n    87→  cashedOutAt: Date | null;\n    88→  claimed: boolean;\n    89→  payout: number;\n    90→  won: boolean;\n    91→  xpParticipation: number;\n    92→  xpWin: number;\n    93→}\n    94→\n    95→// ============ Game Config ============\n    96→\n    97→export interface GameConfig {\n    98→  gameId: string;\n    99→  paused: boolean;\n   100→  minBet: number;\n   101→  maxBet: number;\n   102→  feeBps: number;\n   103→  enabledTiers: Tier[];\n   104→  minPlayers: number;\n   105→  maxPlayers: number;\n   106→  roundDurationSecs: number;\n   107→  bettingWindowSecs: number;\n   108→  vrfQueue: PublicKey;\n   109→  authority: PublicKey;\n   110→  treasury: PublicKey;\n   111→  currentRound: number;\n   112→  totalRounds: number;\n   113→  totalVolume: number;\n   114→  totalFees: number;\n   115→  version: number;\n   116→  createdAt: Date;\n   117→  updatedAt: Date;\n   118→}\n   119→\n   120→// ============ Coinflip ============\n   121→\n   122→export type CoinSide = \"heads\" | \"tails\";\n   123→export type CoinflipPhase = \"created\" | \"ready\" | \"flipping\" | \"complete\";\n   124→\n   125→export const COIN_SIDE_VALUES: Record<CoinSide, number> = {\n   126→  heads: 0,\n   127→  tails: 1,\n   128→};\n   129→\n   130→export const COINFLIP_PHASE_VALUES: Record<CoinflipPhase, number> = {\n   131→  created: 0,\n   132→  ready: 1,\n   133→  flipping: 2,\n   134→  complete: 3,\n   135→};\n   136→\n   137→export interface CoinflipState {\n   138→  pool: PublicKey;\n   139→  player1: PublicKey;\n   140→  player2: PublicKey | null;\n   141→  player1Side: CoinSide;\n   142→  result: CoinSide | null;\n   143→  phase: CoinflipPhase;\n   144→  createdAt: Date;\n   145→  joinedAt: Date | null;\n   146→  flippedAt: Date | null;\n   147→  joinTimeoutSecs: number;\n   148→}\n   149→\n   150→export interface CoinflipMatch {\n   151→  pool: Pool;\n   152→  state: CoinflipState;\n   153→  player1Entry: PlayerEntry;\n   154→  player2Entry: PlayerEntry | null;\n   155→}\n   156→\n   157→// ============ Legacy Types (for backwards compatibility) ============\n   158→\n   159→/** @deprecated Use Pool instead */\n   160→export interface PoolState {\n   161→  roundId: string;\n   162→  gameId: string;\n   163→  tier: Tier;\n   164→  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n   165→  entries: LegacyPlayerEntry[];\n   166→  totalPool: number;\n   167→  createdAt: number;\n   168→  settledAt?: number;\n   169→  outcome?: unknown;\n   170→}\n   171→\n   172→/** @deprecated Use PlayerEntry instead */\n   173→export interface LegacyPlayerEntry {\n   174→  playerId: string;\n   175→  publicKey: string;\n   176→  tier: Tier;\n   177→  amount: number;\n   178→  timestamp: number;\n   179→  side?: \"green\" | \"red\";\n   180→  cashoutMultiplier?: number;\n   181→}\n   182→\n   183→// ============ Game IDs ============\n   184→\n   185→export const GAME_IDS = {\n   186→  COINFLIP: \"coinflip\",\n   187→  LORD_OF_RNGS: \"lord-of-rngs\",\n   188→  CRASH: \"crash\",\n   189→  CLOSE_CALL: \"close-call\",\n   190→  SLOTS: \"slots\",\n   191→  GAME_OF_TRADES: \"game-of-trades\",\n   192→  TUG_OF_EARN: \"tug-of-earn\",\n   193→  CHART_COURSE: \"chart-course\",\n   194→} as const;\n   195→\n   196→export type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n   197→\n   198→// ============ XP System ============\n   199→\n   200→export const XP_BY_TIER: Record<Tier, { participation: number; win: number }> = {\n   201→  iron: { participation: 1, win: 3 },\n   202→  bronze: { participation: 1, win: 3 },\n   203→  silver: { participation: 10, win: 30 },\n   204→  gold: { participation: 25, win: 75 },\n   205→  platinum: { participation: 50, win: 150 },\n   206→  diamond: { participation: 100, win: 300 },\n   207→};\n   208→\n   209→// ============ Fee Constants ============\n   210→\n   211→export const FEE_CONSTANTS = {\n   212→  TOTAL_BPS: 300, // 3%\n   213→  PLATFORM_REVENUE_BPS: 200, // 2.0%\n   214→  CASHBACK_POOL_BPS: 50, // 0.5%\n   215→  REWARDS_BUDGET_BPS: 50, // 0.5%\n   216→} as const;\n   217→"}]},"parent_tool_use_id":"toolu_01QyJM73L1B11qTd62pPZbvE","session_id":"44b168fb-5e34-4073-98cb-22d0c5867ea1","uuid":"2496ed4a-34aa-41bc-96c6-113d5cfadc84"}
