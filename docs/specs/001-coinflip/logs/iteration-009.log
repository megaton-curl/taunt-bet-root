{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DZ7bhZjPLyA3ADfYpAxo6i","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→  type TransactionInstruction,\n     8→} from \"@solana/web3.js\";\n     9→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n    10→import {\n    11→  TIER_VALUES,\n    12→  COIN_SIDE_VALUES,\n    13→  TIER_AMOUNTS,\n    14→  type Tier,\n    15→  type CoinSide,\n    16→} from \"@rng-utopia/game-engine/browser\";\n    17→import type { UIMatch } from \"../types\";\n    18→\n    19→// ============ Constants ============\n    20→\n    21→const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    22→\n    23→// On-chain phase constants\n    24→const PHASE_WAITING = 0;\n    25→const PHASE_LOCKED = 1;\n    26→const PHASE_SETTLED = 2;\n    27→\n    28→// ============ PDA Derivation ============\n    29→\n    30→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer()],\n    33→    COINFLIP_PROGRAM_ID\n    34→  );\n    35→}\n    36→\n    37→export function getConfigPda(): [PublicKey, number] {\n    38→  return PublicKey.findProgramAddressSync(\n    39→    [Buffer.from(\"coinflip_config\")],\n    40→    COINFLIP_PROGRAM_ID\n    41→  );\n    42→}\n    43→\n    44→// ============ Program Instance ============\n    45→\n    46→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    47→  // Read-only provider (no wallet needed for queries)\n    48→  const provider = new AnchorProvider(\n    49→    connection,\n    50→    {} as AnchorProvider[\"wallet\"],\n    51→    { commitment: \"confirmed\" }\n    52→  );\n    53→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    54→}\n    55→\n    56→// ============ On-Chain Account Types ============\n    57→\n    58→interface OnChainMatch {\n    59→  creator: PublicKey;\n    60→  opponent: PublicKey;\n    61→  tier: number;\n    62→  entryAmount: { toNumber(): number };\n    63→  creatorSide: number;\n    64→  phase: number;\n    65→  result: number;\n    66→  winner: PublicKey;\n    67→  claimed: boolean;\n    68→  bump: number;\n    69→}\n    70→\n    71→// ============ Converters ============\n    72→\n    73→function tierFromIndex(index: number): Tier {\n    74→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n    75→  return tiers[index] ?? \"iron\";\n    76→}\n    77→\n    78→function sideFromIndex(index: number): CoinSide {\n    79→  return index === 0 ? \"heads\" : \"tails\";\n    80→}\n    81→\n    82→function phaseToUI(phase: number): UIMatch[\"phase\"] {\n    83→  switch (phase) {\n    84→    case PHASE_WAITING:\n    85→      return \"created\";\n    86→    case PHASE_LOCKED:\n    87→      return \"ready\";\n    88→    case PHASE_SETTLED:\n    89→      return \"complete\";\n    90→    default:\n    91→      return \"created\";\n    92→  }\n    93→}\n    94→\n    95→const DEFAULT_PUBKEY = PublicKey.default;\n    96→\n    97→function isDefaultPubkey(key: PublicKey): boolean {\n    98→  return key.equals(DEFAULT_PUBKEY);\n    99→}\n   100→\n   101→export function onChainMatchToUI(\n   102→  matchPda: PublicKey,\n   103→  data: OnChainMatch\n   104→): UIMatch {\n   105→  const tier = tierFromIndex(data.tier);\n   106→  const creatorSide = sideFromIndex(data.creatorSide);\n   107→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   108→  const phase = phaseToUI(data.phase);\n   109→  const isSettled = data.phase === PHASE_SETTLED;\n   110→\n   111→  const entryAmountSol = TIER_AMOUNTS[tier];\n   112→  const totalPool = entryAmountSol * 2;\n   113→  const payoutAmount = totalPool * 0.97;\n   114→\n   115→  return {\n   116→    id: matchPda.toBase58(),\n   117→    tier,\n   118→    entryAmount: entryAmountSol,\n   119→    player1: data.creator.toBase58(),\n   120→    player1Side: creatorSide,\n   121→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   122→    player2Side: hasOpponent\n   123→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   124→      : null,\n   125→    phase,\n   126→    createdAt: Date.now(),\n   127→    result: isSettled ? sideFromIndex(data.result) : null,\n   128→    winner: isSettled && !isDefaultPubkey(data.winner)\n   129→      ? data.winner.toBase58()\n   130→      : null,\n   131→    claimed: data.claimed,\n   132→    payoutAmount,\n   133→    seedHash: \"\",\n   134→  };\n   135→}\n   136→\n   137→// ============ Account Queries ============\n   138→\n   139→export async function fetchAllOpenMatches(\n   140→  connection: Connection\n   141→): Promise<UIMatch[]> {\n   142→  const program = getCoinflipProgram(connection);\n   143→  const accounts = await program.account.coinflipMatch.all();\n   144→\n   145→  return accounts\n   146→    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n   147→    .map((acc) =>\n   148→      onChainMatchToUI(\n   149→        acc.publicKey,\n   150→        acc.account as unknown as OnChainMatch\n   151→      )\n   152→    );\n   153→}\n   154→\n   155→export async function fetchMatchByCreator(\n   156→  connection: Connection,\n   157→  creator: PublicKey\n   158→): Promise<UIMatch | null> {\n   159→  const program = getCoinflipProgram(connection);\n   160→  const [matchPda] = getMatchPda(creator);\n   161→\n   162→  try {\n   163→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   164→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   165→  } catch {\n   166→    // Account doesn't exist\n   167→    return null;\n   168→  }\n   169→}\n   170→\n   171→export async function fetchMatch(\n   172→  connection: Connection,\n   173→  matchPda: PublicKey\n   174→): Promise<UIMatch | null> {\n   175→  const program = getCoinflipProgram(connection);\n   176→\n   177→  try {\n   178→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   179→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   180→  } catch {\n   181→    return null;\n   182→  }\n   183→}\n   184→\n   185→// ============ Instruction Builders ============\n   186→\n   187→export function buildCreateMatchInstruction(\n   188→  creator: PublicKey,\n   189→  tier: Tier,\n   190→  side: CoinSide\n   191→): { instruction: TransactionInstruction; matchPda: PublicKey } {\n   192→  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n   193→  const [matchPda] = getMatchPda(creator);\n   194→\n   195→  const tierIndex = TIER_VALUES[tier];\n   196→  const sideIndex = COIN_SIDE_VALUES[side];\n   197→\n   198→  const instruction = program.methods\n   199→    .createMatch(tierIndex, sideIndex)\n   200→    .accountsStrict({\n   201→      creator,\n   202→      coinflipMatch: matchPda,\n   203→      systemProgram: SystemProgram.programId,\n   204→    })\n   205→    .instruction();\n   206→\n   207→  // instruction() returns a Promise<TransactionInstruction>, but we return\n   208→  // it synchronously wrapped — callers must await the instruction.\n   209→  // For now, build the transaction inline.\n   210→  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n   211→}\n   212→\n   213→export async function buildCreateMatchTx(\n   214→  connection: Connection,\n   215→  creator: PublicKey,\n   216→  tier: Tier,\n   217→  side: CoinSide\n   218→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   219→  const program = getCoinflipProgram(connection);\n   220→  const [matchPda] = getMatchPda(creator);\n   221→\n   222→  const tierIndex = TIER_VALUES[tier];\n   223→  const sideIndex = COIN_SIDE_VALUES[side];\n   224→\n   225→  const ix = await program.methods\n   226→    .createMatch(tierIndex, sideIndex)\n   227→    .accountsStrict({\n   228→      creator,\n   229→      coinflipMatch: matchPda,\n   230→      systemProgram: SystemProgram.programId,\n   231→    })\n   232→    .instruction();\n   233→\n   234→  const tx = new Transaction().add(ix);\n   235→  tx.feePayer = creator;\n   236→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   237→\n   238→  return { transaction: tx, matchPda };\n   239→}\n   240→\n   241→export async function buildJoinMatchTx(\n   242→  connection: Connection,\n   243→  opponent: PublicKey,\n   244→  matchCreator: PublicKey\n   245→): Promise<Transaction> {\n   246→  const program = getCoinflipProgram(connection);\n   247→  const [matchPda] = getMatchPda(matchCreator);\n   248→\n   249→  const ix = await program.methods\n   250→    .joinMatch()\n   251→    .accountsStrict({\n   252→      opponent,\n   253→      coinflipMatch: matchPda,\n   254→      systemProgram: SystemProgram.programId,\n   255→    })\n   256→    .instruction();\n   257→\n   258→  const tx = new Transaction().add(ix);\n   259→  tx.feePayer = opponent;\n   260→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   261→\n   262→  return tx;\n   263→}\n   264→\n   265→export async function buildCancelMatchTx(\n   266→  connection: Connection,\n   267→  creator: PublicKey\n   268→): Promise<Transaction> {\n   269→  const program = getCoinflipProgram(connection);\n   270→  const [matchPda] = getMatchPda(creator);\n   271→\n   272→  const ix = await program.methods\n   273→    .cancelMatch()\n   274→    .accountsStrict({\n   275→      creator,\n   276→      coinflipMatch: matchPda,\n   277→      systemProgram: SystemProgram.programId,\n   278→    })\n   279→    .instruction();\n   280→\n   281→  const tx = new Transaction().add(ix);\n   282→  tx.feePayer = creator;\n   283→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   284→\n   285→  return tx;\n   286→}\n   287→\n   288→export async function buildClaimPayoutTx(\n   289→  connection: Connection,\n   290→  winner: PublicKey,\n   291→  matchCreator: PublicKey,\n   292→  opponent: PublicKey\n   293→): Promise<Transaction> {\n   294→  const program = getCoinflipProgram(connection);\n   295→  const [matchPda] = getMatchPda(matchCreator);\n   296→  const [configPda] = getConfigPda();\n   297→\n   298→  // Fetch config to get treasury address\n   299→  const config = await program.account.coinflipConfig.fetch(configPda);\n   300→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   301→\n   302→  // Derive player profile PDAs for CPI\n   303→  const PLATFORM_PROGRAM_ID = new PublicKey(\"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\");\n   304→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   305→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   306→    PLATFORM_PROGRAM_ID\n   307→  );\n   308→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   309→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   310→    PLATFORM_PROGRAM_ID\n   311→  );\n   312→\n   313→  const ix = await program.methods\n   314→    .claimPayout()\n   315→    .accountsStrict({\n   316→      winner,\n   317→      coinflipMatch: matchPda,\n   318→      config: configPda,\n   319→      treasury,\n   320→      creator: matchCreator,\n   321→      creatorProfile,\n   322→      opponentProfile,\n   323→      platformProgram: PLATFORM_PROGRAM_ID,\n   324→      systemProgram: SystemProgram.programId,\n   325→    })\n   326→    .instruction();\n   327→\n   328→  const tx = new Transaction().add(ix);\n   329→  tx.feePayer = winner;\n   330→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   331→\n   332→  return tx;\n   333→}\n   334→"}]},"parent_tool_use_id":"toolu_01YAuPzw3ZszBedQhEyD9UUz","session_id":"44b168fb-5e34-4073-98cb-22d0c5867ea1","uuid":"5ac68f48-892b-4a4f-a90