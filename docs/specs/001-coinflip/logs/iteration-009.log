t(\"tails\")}\n        disabled={disabled || isLocked}\n      >\n        <div className=\"coinflip-side-btn__icon coinflip-side-btn__icon--tails\">\n          <RNGPixelArt variant=\"tails\" />\n        </div>\n        <span className=\"coinflip-side-btn__label\">Tails</span>\n      </button>\n    </div>\n  );\n}\n\nexport { RNGPixelArt };\n```\n\n---\n\n## 2. helpers.ts\n**Path:** `/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/helpers.ts`\n\n```typescript\nimport type { CoinSide } from \"../types\";\n\nexport function truncateAddress(address: string): string {\n  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n}\n\nexport function getOppositeSide(side: CoinSide): CoinSide {\n  return side === \"heads\" ? \"tails\" : \"heads\";\n}\n```\n\n---\n\n## 3. coinflip.ts\n**Path:** `/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/coinflip.ts`\n\n```typescript\nimport { PublicKey } from \"@solana/web3.js\";\nimport {\n  Tier,\n  CoinSide,\n  TIER_AMOUNTS_LAMPORTS,\n} from \"./types\";\n\n// ============ Program IDs ============\n\nexport const COINFLIP_PROGRAM_ID = new PublicKey(\n  \"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\"\n);\n\n/** @deprecated Use COINFLIP_PROGRAM_ID instead */\nexport const PROGRAM_IDS = {\n  COINFLIP: COINFLIP_PROGRAM_ID,\n};\n\n// ============ PDA Derivation ============\n\n/**\n * Derive the match PDA for a creator.\n * Seeds: [\"match\", creator.toBytes()]\n */\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n/**\n * Derive the global config PDA.\n * Seeds: [\"coinflip_config\"]\n */\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n// ============ Helper Functions ============\n\n/**\n * Calculate the entry amount for a tier in lamports\n */\nexport function getEntryAmount(tier: Tier): number {\n  return TIER_AMOUNTS_LAMPORTS[tier];\n}\n\n/**\n * Calculate potential payout (winner gets total minus 3% fee)\n */\nexport function calculatePotentialPayout(tier: Tier): number {\n  const entryAmount = TIER_AMOUNTS_LAMPORTS[tier];\n  const totalPool = entryAmount * 2; // Two players\n  const fee = Math.floor(totalPool * 0.03);\n  return totalPool - fee;\n}\n\n/**\n * Get the opposite coin side\n */\nexport function getOppositeSide(side: CoinSide): CoinSide {\n  return side === \"heads\" ? \"tails\" : \"heads\";\n}\n\n/**\n * Determine winner from randomness bytes\n */\nexport function determineWinnerFromRandomness(\n  randomness: Uint8Array,\n  player1Side: CoinSide\n): { result: CoinSide; player1Wins: boolean } {\n  // Match the on-chain logic: first byte % 2\n  const firstByte = randomness[0] ?? 0;\n  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n  const player1Wins = player1Side === result;\n  return { result, player1Wins };\n}\n```\n\n---\n\n## 4. types.ts\n**Path:** `/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/types.ts`\n\n```typescript\nimport { PublicKey } from \"@solana/web3.js\";\n\n// ============ Tier System ============\n\nexport type Tier = \"iron\" | \"bronze\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n\nexport const TIER_VALUES: Record<Tier, number> = {\n  iron: 0,\n  bronze: 1,\n  silver: 2,\n  gold: 3,\n  platinum: 4,\n  diamond: 5,\n};\n\nexport const TIER_AMOUNTS: Record<Tier, number> = {\n  iron: 0.005,\n  bronze: 0.01,\n  silver: 0.1,\n  gold: 0.25,\n  platinum: 0.5,\n  diamond: 1,\n};\n\nexport const TIER_AMOUNTS_LAMPORTS: Record<Tier, number> = {\n  iron: 5_000_000,\n  bronze: 10_000_000,\n  silver: 100_000_000,\n  gold: 250_000_000,\n  platinum: 500_000_000,\n  diamond: 1_000_000_000,\n};\n\n// ============ Pool State ============\n\nexport type PoolPhase = \"waiting\" | \"locked\" | \"resolving\" | \"settled\" | \"cancelled\";\n\nexport const POOL_PHASE_VALUES: Record<PoolPhase, number> = {\n  waiting: 0,\n  locked: 1,\n  resolving: 2,\n  settled: 3,\n  cancelled: 4,\n};\n\nexport interface Pool {\n  poolId: Uint8Array;\n  gameId: string;\n  roundId: number;\n  tier: Tier;\n  entryAmount: number;\n  phase: PoolPhase;\n  totalPool: number;\n  playerCount: number;\n  maxPlayers: number;\n  createdAt: Date;\n  lockedAt: Date | null;\n  settledAt: Date | null;\n  feeBps: number;\n  vrfRequest: PublicKey | null;\n  randomness: Uint8Array | null;\n  winner: PublicKey | null;\n  authority: PublicKey;\n  treasury: PublicKey;\n  carryoverAmount: number;\n  carryoverFromRound: number;\n}\n\n// ============ Player Entry ============\n\nexport type Side = \"none\" | \"green\" | \"red\";\n\nexport const SIDE_VALUES: Record<Side, number> = {\n  none: 0,\n  green: 1,\n  red: 2,\n};\n\nexport interface PlayerEntry {\n  pool: PublicKey;\n  player: PublicKey;\n  amount: number;\n  enteredAt: Date;\n  sequence: number;\n  side: Side;\n  cashoutMultiplier: number | null;\n  cashedOutAt: Date | null;\n  claimed: boolean;\n  payout: number;\n  won: boolean;\n  xpParticipation: number;\n  xpWin: number;\n}\n\n// ============ Game Config ============\n\nexport interface GameConfig {\n  gameId: string;\n  paused: boolean;\n  minBet: number;\n  maxBet: number;\n  feeBps: number;\n  enabledTiers: Tier[];\n  minPlayers: number;\n  maxPlayers: number;\n  roundDurationSecs: number;\n  bettingWindowSecs: number;\n  vrfQueue: PublicKey;\n  authority: PublicKey;\n  treasury: PublicKey;\n  currentRound: number;\n  totalRounds: number;\n  totalVolume: number;\n  totalFees: number;\n  version: number;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\n// ============ Coinflip ============\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type CoinflipPhase = \"created\" | \"ready\" | \"flipping\" | \"complete\";\n\nexport const COIN_SIDE_VALUES: Record<CoinSide, number> = {\n  heads: 0,\n  tails: 1,\n};\n\nexport const COINFLIP_PHASE_VALUES: Record<CoinflipPhase, number> = {\n  created: 0,\n  ready: 1,\n  flipping: 2,\n  complete: 3,\n};\n\nexport interface CoinflipState {\n  pool: PublicKey;\n  player1: PublicKey;\n  player2: PublicKey | null;\n  player1Side: CoinSide;\n  result: CoinSide | null;\n  phase: CoinflipPhase;\n  createdAt: Date;\n  joinedAt: Date | null;\n  flippedAt: Date | null;\n  joinTimeoutSecs: number;\n}\n\nexport interface CoinflipMatch {\n  pool: Pool;\n  state: CoinflipState;\n  player1Entry: PlayerEntry;\n  player2Entry: PlayerEntry | null;\n}\n\n// ============ Legacy Types (for backwards compatibility) ============\n\n/** @deprecated Use Pool instead */\nexport interface PoolState {\n  roundId: string;\n  gameId: string;\n  tier: Tier;\n  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n  entries: LegacyPlayerEntry[];\n  totalPool: number;\n  createdAt: number;\n  settledAt?: number;\n  outcome?: unknown;\n}\n\n/** @deprecated Use PlayerEntry instead */\nexport interface LegacyPlayerEntry {\n  playerId: string;\n  publicKey: string;\n  tier: Tier;\n  amount: number;\n  timestamp: number;\n  side?: \"green\" | \"red\";\n  cashoutMultiplier?: number;\n}\n\n// ============ Game IDs ============\n\nexport const GAME_IDS = {\n  COINFLIP: \"coinflip\",\n  LORD_OF_RNGS: \"lord-of-rngs\",\n  CRASH: \"crash\",\n  CLOSE_CALL: \"close-call\",\n  SLOTS: \"slots\",\n  GAME_OF_TRADES: \"game-of-trades\",\n  TUG_OF_EARN: \"tug-of-earn\",\n  CHART_COURSE: \"chart-course\",\n} as const;\n\nexport type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n\n// ============ XP System ============\n\nexport const XP_BY_TIER: Record<Tier, { participation: number; win: number }> = {\n  iron: { participation: 1, win: 3 },\n  bronze: { participation: 1, win: 3 },\n  silver: { participation: 10, win: 30 },\n  gold: { participation: 25, win: 75 },\n  platinum: { participation: 50, win: 150 },\n  diamond: { participation: 100, win: 300 },\n};\n\n// ============ Fee Constants ============\n\nexport const FEE_CONSTANTS = {\n  TOTAL_BPS: 300, // 3%\n  PLATFORM_REVENUE_BPS: 200, // 2.0%\n  CASHBACK_POOL_BPS: 50, // 0.5%\n  REWARDS_BUDGET_BPS: 50, // 0.5%\n} as const;\n```\n\n---\n\n## 5. payouts.ts\n**Path:** `/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/payouts.ts`\n\n```typescript\nconst PLATFORM_FEE_BPS = 300; // 3%\n\n/**\n * Calculate pari-mutuel payout for a player\n * NOTE: This is for UI display/verification only. On-chain is authoritative.\n */\nexport function calculatePariMutuelPayout(\n  playerBet: number,\n  winningPool: number,\n  totalPool: number,\n  feeBps: number = PLATFORM_FEE_BPS\n): number {\n  if (winningPool === 0) return 0;\n\n  const feeMultiplier = 1 - feeBps / 10000;\n  const poolAfterFees = totalPool * feeMultiplier;\n  const playerShare = playerBet / winningPool;\n\n  return poolAfterFees * playerShare;\n}\n\n/**\n * Calculate winner-takes-all payout\n * NOTE: This is for UI display/verification only. On-chain is authoritative.\n */\nexport function calculateWinnerPayout(\n  totalPool: number,\n  feeBps: number = PLATFORM_FEE_BPS\n): number {\n  const feeMultiplier = 1 - feeBps / 10000;\n  return totalPool * feeMultiplier;\n}\n\n/**\n * Verify that payouts + fees = total pool (invariant check)\n */\nexport function verifyPayoutInvariant(\n  payouts: number[],\n  fees: number,\n  totalPool: number,\n  tolerance: number = 0.000001\n): boolean {\n  const totalPayouts = payouts.reduce((sum, p) => sum + p, 0);\n  return Math.abs(totalPayouts + fees - totalPool) < tolerance;\n}\n```\n\n---\n\n## 6. index.ts\n**Path:** `/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/index.ts`\n\n```typescript\n// Round state machine\nexport { RoundStateMachine, type RoundState, type RoundPhase } from \"./RoundStateMachine\";\n\n// Payout calculations (UI-side, verification only - on-chain is authoritative)\nexport {\n  calculatePariMutuelPayout,\n  calculateWinnerPayout,\n  verifyPayoutInvariant,\n} from \"./payouts\";\n\n// Event emitter for UI updates\nexport { GameEventEmitter, type GameEvent, type GameEventType } from \"./GameEventEmitter\";\n\n// Legacy instruction builders (deprecated - use game-specific modules)\nexport { buildEntryInstruction, buildCashoutInstruction } from \"./instructions\";\n\n// Types\nexport type {\n  Tier,\n  Pool,\n  PoolPhase,\n  PlayerEntry,\n  Side,\n  GameConfig,\n  GameId,\n  // Coinflip types\n  CoinSide,\n  CoinflipPhase,\n  CoinflipState,\n  CoinflipMatch,\n  // Legacy types\n  PoolState,\n  LegacyPlayerEntry,\n} from \"./types\";\n\nexport {\n  TIER_VALUES,\n  TIER_AMOUNTS,\n  TIER_AMOUNTS_LAMPORTS,\n  POOL_PHASE_VALUES,\n  SIDE_VALUES,\n  COIN_SIDE_VALUES,\n  COINFLIP_PHASE_VALUES,\n  GAME_IDS,\n  XP_BY_TIER,\n  FEE_CONSTANTS,\n} from \"./types\";\n\n// Coinflip game client\nexport {\n  COINFLIP_PROGRAM_ID,\n  PROGRAM_IDS,\n  getMatchPda,\n  getConfigPda,\n  getEntryAmount,\n  calculatePotentialPayout,\n  getOppositeSide,\n  determineWinnerFromRandomness,\n} from \"./coinflip\";\n```"}],"totalDurationMs":29512,"totalTokens":30068,"totalToolUseCount":6,"usage":{"input_tokens":7,"cache_creation_input_tokens":6281,"cache_read_input_tokens":19268,"output_tokens":4512,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":6281,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YAuPzw3ZszBedQhEyD9UUz","type":"tool_result","content":[{"type":"text","text":"Here are the complete contents of all six files you requested:\n\n---\n\n## 1. OpenMatchesList.tsx\n\n```typescript\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\nimport { MatchCard } from \"./MatchCard\";\n\ninterface OpenMatchesListProps {\n  matches: UIMatch[];\n  loading: boolean;\n  onJoin: (matchId: string) => void;\n  joiningMatchId: string | null;\n  currentUserAddress: string | null;\n  selectedTier: Tier | null;\n  isConnected: boolean;\n}\n\nexport function OpenMatchesList({\n  matches,\n  loading,\n  onJoin,\n  joiningMatchId,\n  currentUserAddress,\n  selectedTier,\n  isConnected,\n}: OpenMatchesListProps) {\n  // Filter by tier if selected\n  const filteredMatches = selectedTier\n    ? matches.filter((m) => m.tier === selectedTier)\n    : matches;\n\n  if (loading) {\n    return (\n      <div className=\"coinflip-matches coinflip-matches--loading\">\n        <div className=\"coinflip-matches__spinner\" />\n        <p>Loading games...</p>\n      </div>\n    );\n  }\n\n  if (filteredMatches.length === 0) {\n    return (\n      <div className=\"coinflip-matches coinflip-matches--empty\">\n        <p className=\"coinflip-matches__empty-text\">\n          {selectedTier\n            ? `No open ${selectedTier} games`\n            : \"No open games available\"}\n        </p>\n        <p className=\"coinflip-matches__empty-hint\">\n          Create a game or wait for someone to create one\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"coinflip-matches\">\n      <div className=\"coinflip-matches__header\">\n        <h3 className=\"coinflip-matches__title\">Open Games</h3>\n        <span className=\"coinflip-matches__count\">\n          {filteredMatches.length} available\n        </span>\n      </div>\n\n      <div className=\"coinflip-matches__list\">\n        {filteredMatches.map((match) => {\n          const isOwn = currentUserAddress === match.player1;\n          const canJoin = isConnected && !isOwn;\n\n          return (\n            <MatchCard\n              key={match.id}\n              match={match}\n              onJoin={() => onJoin(match.id)}\n              isOwn={isOwn}\n              canJoin={canJoin}\n              joining={joiningMatchId === match.id}\n            />\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n```\n\n---\n\n## 2. CoinflipContext.tsx\n\n```typescript\nimport {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\n// RPC endpoint — defaults to localhost for development\nconst RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n\n  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier || !selectedSide) {\n      throw new Error(\"Select tier and side first\");\n    }\n\n    setCreating(true);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          throw new Error(\"Match not found\");\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to cancel\");\n    }\n\n    const transaction = await buildCancelMatchTx(connection, publicKey);\n    await sendTransaction(transaction);\n    setActiveMatch(null);\n    refreshMatches();\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to claim\");\n    }\n\n    setClaiming(true);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n```\n\n---\n\n## 3. chain.ts\n\n```typescript\nimport { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  type TransactionInstruction,\n} from \"@solana/web3.js\";\nimport { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  COIN_SIDE_VALUES,\n  TIER_AMOUNTS,\n  type Tier,\n  type CoinSide,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n\n// On-chain phase constants\nconst PHASE_WAITING = 0;\nconst PHASE_LOCKED = 1;\nconst PHASE_SETTLED = 2;\n\n// ============ PDA Derivation ============\n\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n// ============ Program Instance ============\n\nfunction getCoinflipProgram(connection: Connection): Program<Coinflip> {\n  // Read-only provider (no wallet needed for queries)\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n}\n\n// ============ On-Chain Account Types ============\n\ninterface OnChainMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  tier: number;\n  entryAmount: { toNumber(): number };\n  creatorSide: number;\n  phase: number;\n  result: number;\n  winner: PublicKey;\n  claimed: boolean;\n  bump: number;\n}\n\n// ============ Converters ============\n\nfunction tierFromIndex(index: number): Tier {\n  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n  return tiers[index] ?? \"iron\";\n}\n\nfunction sideFromIndex(index: number): CoinSide {\n  return index === 0 ? \"heads\" : \"tails\";\n}\n\nfunction phaseToUI(phase: number): UIMatch[\"phase\"] {\n  switch (phase) {\n    case PHASE_WAITING:\n      return \"created\";\n    case PHASE_LOCKED:\n      return \"ready\";\n    case PHASE_SETTLED:\n      return \"complete\";\n    default:\n      return \"created\";\n  }\n}\n\nconst DEFAULT_PUBKEY = PublicKey.default;\n\nfunction isDefaultPubkey(key: PublicKey): boolean {\n  return key.equals(DEFAULT_PUBKEY);\n}\n\nexport function onChainMatchToUI(\n  matchPda: PublicKey,\n  data: OnChainMatch\n): UIMatch {\n  const tier = tierFromIndex(data.tier);\n  const creatorSide = sideFromIndex(data.creatorSide);\n  const hasOpponent = !isDefaultPubkey(data.opponent);\n  const phase = phaseToUI(data.phase);\n  const isSettled = data.phase === PHASE_SETTLED;\n\n  const entryAmountSol = TIER_AMOUNTS[tier];\n  const totalPool = entryAmountSol * 2;\n  const payoutAmount = totalPool * 0.97;\n\n  return {\n    id: matchPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    player1: data.creator.toBase58(),\n    player1Side: creatorSide,\n    player2: hasOpponent ? data.opponent.toBase58() : null,\n    player2Side: hasOpponent\n      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n      : null,\n    phase,\n    createdAt: Date.now(),\n    result: isSettled ? sideFromIndex(data.result) : null,\n    winner: isSettled && !isDefaultPubkey(data.winner)\n      ? data.winner.toBase58()\n      : null,\n    claimed: data.claimed,\n    payoutAmount,\n    seedHash: \"\",\n  };\n}\n\n// ============ Account Queries ============\n\nexport async function fetchAllOpenMatches(\n  connection: Connection\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const accounts = await program.account.coinflipMatch.all();\n\n  return accounts\n    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n    .map((acc) =>\n      onChainMatchToUI(\n        acc.publicKey,\n        acc.account as unknown as OnChainMatch\n      )\n    );\n}\n\nexport async function fetchMatchByCreator(\n  connection: Connection,\n  creator: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    // Account doesn't exist\n    return null;\n  }\n}\n\nexport async function fetchMatch(\n  connection: Connection,\n  matchPda: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    return null;\n  }\n}\n\n// ============ Instruction Builders ============\n\nexport function buildCreateMatchInstruction(\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): { instruction: TransactionInstruction; matchPda: PublicKey } {\n  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n  const [matchPda] = getMatchPda(creator);\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const instruction = program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  // instruction() returns a Promise<TransactionInstruction>, but we return\n  // it synchronously wrapped — callers must await the instruction.\n  // For now, build the transaction inline.\n  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n}\n\nexport async function buildCreateMatchTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const ix = await program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, matchPda };\n}\n\nexport async function buildJoinMatchTx(\n  connection: Connection,\n  opponent: PublicKey,\n  matchCreator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n\n  const ix = await program.methods\n    .joinMatch()\n    .accountsStrict({\n      opponent,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = opponent;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildCancelMatchTx(\n  connection: Connection,\n  creator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const ix = await program.methods\n    .cancelMatch()\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  winner: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get treasury address\n  const config = await program.account.coinflipConfig.fetch(configPda);\n  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n\n  // Derive player profile PDAs for CPI\n  const PLATFORM_PROGRAM_ID = new PublicKey(\"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\");\n  const [creatorProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  const [opponentProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n\n  const ix = await program.methods\n    .claimPayout()\n    .accountsStrict({\n      winner,\n      coinflipMatch: matchPda,\n      config: configPda,\n      treasury,\n      creator: matchCreator,\n      creatorProfile,\n      opponentProfile,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = winner;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n```\n\n---\n\n## 4. types.ts\n\n```typescript\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type CoinflipPhase = \"created\" | \"ready\" | \"countdown\" | \"flipping\" | \"complete\";\n\n/**\n * Simplified match type for UI/mock mode (doesn't require PublicKey)\n */\nexport interface UIMatch {\n  id: string;\n  tier: Tier;\n  entryAmount: number; // in SOL\n\n  // Player 1 (creator)\n  player1: string; // wallet address\n  player1Side: CoinSide;\n\n  // Player 2 (joiner)\n  player2: string | null;\n  player2Side: CoinSide | null;\n\n  // Match state\n  phase: CoinflipPhase;\n  createdAt: number; // timestamp\n  countdownStartedAt?: number; // when countdown started\n  completedAt?: number;\n\n  // Result\n  result: CoinSide | null;\n  winner: string | null;\n\n  // Payout\n  claimed: boolean;\n  payoutAmount: number; // amount winner receives\n\n  // Provably Fair - VRF-based verification\n  seedHash: string; // SHA-256 hash of server seed (shown before flip)\n  serverSeed?: string; // Actual server seed (revealed only after settlement)\n  vrfProof?: string; // VRF proof for on-chain verification\n  blockHash?: string; // Solana blockhash used as entropy source\n}\n\nexport interface MatchFilter {\n  tier?: Tier;\n  status?: \"open\" | \"all\";\n}\n\nexport interface CreateMatchParams {\n  tier: Tier;\n  side: CoinSide;\n}\n\nexport interface JoinMatchParams {\n  matchId: string;\n}\n```\n\n---\n\n## 5. MatchCard.tsx\n\n```typescript\nimport type { UIMatch } from \"../types\";\nimport { TIER_COLORS } from \"@rng-utopia/ui\";\nimport { PlayerAvatar, getDisplayName } from \"../../player-profile\";\n\ninterface MatchCardProps {\n  match: UIMatch;\n  onJoin?: () => void;\n  isOwn?: boolean;\n  canJoin?: boolean;\n  joining?: boolean;\n}\n\nexport function MatchCard({\n  match,\n  onJoin,\n  isOwn = false,\n  canJoin = true,\n  joining = false,\n}: MatchCardProps) {\n  const timeAgo = getTimeAgo(match.createdAt);\n\n  return (\n    <div className={`coinflip-match-card ${isOwn ? \"coinflip-match-card--own\" : \"\"}`}>\n      <div className=\"coinflip-match-card__creator\">\n        <PlayerAvatar address={match.player1} size=\"sm\" enableMiniProfile={false} />\n        <div className=\"coinflip-match-card__info\">\n          <span className=\"coinflip-match-card__address\">\n            {getDisplayName(match.player1)}\n          </span>\n          <span className=\"coinflip-match-card__time\">{timeAgo}</span>\n        </div>\n      </div>\n\n      <div className=\"coinflip-match-card__bet\">\n        <div\n          className={`coinflip-match-card__side coinflip-match-card__side--${match.player1Side}`}\n        >\n          <span className=\"coinflip-match-card__rng\">RNG</span>\n        </div>\n        <div className=\"coinflip-match-card__amount\">\n          {match.entryAmount} SOL\n        </div>\n        <div\n          className=\"coinflip-match-card__tier\"\n          style={{\n            color: TIER_COLORS[match.tier],\n            textShadow: `0 0 8px ${TIER_COLORS[match.tier]}`\n          }}\n        >\n          {match.tier}\n        </div>\n      </div>\n\n      <div className=\"coinflip-match-card__actions\">\n        {!isOwn && onJoin && (\n          <button\n            type=\"button\"\n            className=\"coinflip-match-card__join-btn\"\n            onClick={onJoin}\n            disabled={!canJoin || joining}\n          >\n            {joining ? \"Joining...\" : \"Join\"}\n          </button>\n        )}\n        {isOwn && (\n          <span className=\"coinflip-match-card__status\">Waiting...</span>\n        )}\n      </div>\n    </div>\n  );\n}\n\nfunction getTimeAgo(timestamp: number): string {\n  const seconds = Math.floor((Date.now() - timestamp) / 1000);\n\n  if (seconds < 60) return `${seconds}s ago`;\n  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;\n  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;\n  return `${Math.floor(seconds / 86400)}d ago`;\n}\n```\n\n---\n\n## 6. index.ts\n\n```typescript\n// Context & Hooks\nexport { CoinflipProvider, useCoinflip } from \"./context/CoinflipContext\";\n\n// Components\nexport {\n  CoinSideSelector,\n  CoinAnimation,\n  MatchCard,\n  OpenMatchesList,\n  ActiveMatchView,\n} from \"./components\";\n\n// Types\nexport type { UIMatch, CoinSide, CoinflipPhase } from \"./types\";\n\n// Utils\nexport { truncateAddress } from \"./utils/helpers\";\n```\n\n---\n\nAll six files have been read and are presented above in full. This gives you a complete picture of:\n- The lobby browser UI components (OpenMatchesList, MatchCard)\n- The Coinflip context managing state and wallet integration (CoinflipContext)\n- The on-chain utilities for building transactions and fetching match data (chain.ts)\n- The TypeScript type definitions (types.ts)\n- The module exports (index.ts)"},{"type":"text","text":"agentId: adb2af1 (for resuming to continue this agent's work if needed)\n<usage>total_tokens: 37458\ntool_uses: 6\nduration_ms: 47588</usage>"}]}]},"parent_tool_use_id":null,"session_id":"44b168fb-5e34-4073-98cb-22d0c5867ea1","uuid":"58cb8635-2642-496a-a2d5-83487c5de78e","tool_use_result":{"status":"completed","prompt":"Read the following files and return their complete contents. I need to understand the current lobby browser implementation and the chain utilities:\n\n1. `sources/rng-utopia/apps/platform/src/features/coinflip/components/OpenMatchesList.tsx`\n2. `sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx`\n3. `sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts`\n4. `sources/rng-utopia/apps/platform/src/features/coinflip/types.ts`\n5. `sources/rng-utopia/apps/platform/src/features/coinflip/components/MatchCard.tsx`\n6. `sources/rng-utopia/apps/platform/src/features/coinflip/index.ts`\n\nReturn all content in full.","agentId":"adb2af1","content":[{"type":"text","text":"Here are the complete contents of all six files you requested:\n\n---\n\n## 1. OpenMatchesList.tsx\n\n```typescript\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\nimport { MatchCard } from \"./MatchCard\";\n\ninterface OpenMatchesListProps {\n  matches: UIMatch[];\n  loading: boolean;\n  onJoin: (matchId: string) => void;\n  joiningMatchId: string | null;\n  currentUserAddress: string | null;\n  selectedTier: Tier | null;\n  isConnected: boolean;\n}\n\nexport function OpenMatchesList({\n  matches,\n  loading,\n  onJoin,\n  joiningMatchId,\n  currentUserAddress,\n  selectedTier,\n  isConnected,\n}: OpenMatchesListProps) {\n  // Filter by tier if selected\n  const filteredMatches = selectedTier\n    ? matches.filter((m) => m.tier === selectedTier)\n    : matches;\n\n  if (loading) {\n    return (\n      <div className=\"coinflip-matches coinflip-matches--loading\">\n        <div className=\"coinflip-matches__spinner\" />\n        <p>Loading games...</p>\n      </div>\n    );\n  }\n\n  if (filteredMatches.length === 0) {\n    return (\n      <div className=\"coinflip-matches coinflip-matches--empty\">\n        <p className=\"coinflip-matches__empty-text\">\n          {selectedTier\n            ? `No open ${selectedTier} games`\n            : \"No open games available\"}\n        </p>\n        <p className=\"coinflip-matches__empty-hint\">\n          Create a game or wait for someone to create one\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"coinflip-matches\">\n      <div className=\"coinflip-matches__header\">\n        <h3 className=\"coinflip-matches__title\">Open Games</h3>\n        <span className=\"coinflip-matches__count\">\n          {filteredMatches.length} available\n        </span>\n      </div>\n\n      <div className=\"coinflip-matches__list\">\n        {filteredMatches.map((match) => {\n          const isOwn = currentUserAddress === match.player1;\n          const canJoin = isConnected && !isOwn;\n\n          return (\n            <MatchCard\n              key={match.id}\n              match={match}\n              onJoin={() => onJoin(match.id)}\n              isOwn={isOwn}\n              canJoin={canJoin}\n              joining={joiningMatchId === match.id}\n            />\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n```\n\n---\n\n## 2. CoinflipContext.tsx\n\n```typescript\nimport {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\n// RPC endpoint — defaults to localhost for development\nconst RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n\n  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier || !selectedSide) {\n      throw new Error(\"Select tier and side first\");\n    }\n\n    setCreating(true);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          throw new Error(\"Match not found\");\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to cancel\");\n    }\n\n    const transaction = await buildCancelMatchTx(connection, publicKey);\n    await sendTransaction(transaction);\n    setActiveMatch(null);\n    refreshMatches();\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to claim\");\n    }\n\n    setClaiming(true);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n```\n\n---\n\n## 3. chain.ts\n\n```typescript\nimport { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  type TransactionInstruction,\n} from \"@solana/web3.js\";\nimport { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  COIN_SIDE_VALUES,\n  TIER_AMOUNTS,\n  type Tier,\n  type CoinSide,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n\n// On-chain phase constants\nconst PHASE_WAITING = 0;\nconst PHASE_LOCKED = 1;\nconst PHASE_SETTLED = 2;\n\n// ============ PDA Derivation ============\n\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n// ============ Program Instance ============\n\nfunction getCoinflipProgram(connection: Connection): Program<Coinflip> {\n  // Read-only provider (no wallet needed for queries)\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n}\n\n// ============ On-Chain Account Types ============\n\ninterface OnChainMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  tier: number;\n  entryAmount: { toNumber(): number };\n  creatorSide: number;\n  phase: number;\n  result: number;\n  winner: PublicKey;\n  claimed: boolean;\n  bump: number;\n}\n\n// ============ Converters ============\n\nfunction tierFromIndex(index: number): Tier {\n  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n  return tiers[index] ?? \"iron\";\n}\n\nfunction sideFromIndex(index: number): CoinSide {\n  return index === 0 ? \"heads\" : \"tails\";\n}\n\nfunction phaseToUI(phase: number): UIMatch[\"phase\"] {\n  switch (phase) {\n    case PHASE_WAITING:\n      return \"created\";\n    case PHASE_LOCKED:\n      return \"ready\";\n    case PHASE_SETTLED:\n      return \"complete\";\n    default:\n      return \"created\";\n  }\n}\n\nconst DEFAULT_PUBKEY = PublicKey.default;\n\nfunction isDefaultPubkey(key: PublicKey): boolean {\n  return key.equals(DEFAULT_PUBKEY);\n}\n\nexport function onChainMatchToUI(\n  matchPda: PublicKey,\n  data: OnChainMatch\n): UIMatch {\n  const tier = tierFromIndex(data.tier);\n  const creatorSide = sideFromIndex(data.creatorSide);\n  const hasOpponent = !isDefaultPubkey(data.opponent);\n  const phase = phaseToUI(data.phase);\n  const isSettled = data.phase === PHASE_SETTLED;\n\n  const entryAmountSol = TIER_AMOUNTS[tier];\n  const totalPool = entryAmountSol * 2;\n  const payoutAmount = totalPool * 0.97;\n\n  return {\n    id: matchPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    player1: data.creator.toBase58(),\n    player1Side: creatorSide,\n    player2: hasOpponent ? data.opponent.toBase58() : null,\n    player2Side: hasOpponent\n      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n      : null,\n    phase,\n    createdAt: Date.now(),\n    result: isSettled ? sideFromIndex(data.result) : null,\n    winner: isSettled && !isDefaultPubkey(data.winner)\n      ? data.winner.toBase58()\n      : null,\n    claimed: data.claimed,\n    payoutAmount,\n    seedHash: \"\",\n  };\n}\n\n// ============ Account Queries ============\n\nexport async function fetchAllOpenMatches(\n  connection: Connection\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const accounts = await program.account.coinflipMatch.all();\n\n  return accounts\n    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n    .map((acc) =>\n      onChainMatchToUI(\n        acc.publicKey,\n        acc.account as unknown as OnChainMatch\n      )\n    );\n}\n\nexport async function fetchMatchByCreator(\n  connection: Connection,\n  creator: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    // Account doesn't exist\n    return null;\n  }\n}\n\nexport async function fetchMatch(\n  connection: Connection,\n  matchPda: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    return null;\n  }\n}\n\n// ============ Instruction Builders ============\n\nexport function buildCreateMatchInstruction(\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): { instruction: TransactionInstruction; matchPda: PublicKey } {\n  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n  const [matchPda] = getMatchPda(creator);\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const instruction = program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  // instruction() returns a Promise<TransactionInstruction>, but we return\n  // it synchronously wrapped — callers must await the instruction.\n  // For now, build the transaction inline.\n  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n}\n\nexport async function buildCreateMatchTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const ix = await program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, matchPda };\n}\n\nexport async function buildJoinMatchTx(\n  connection: Connection,\n  opponent: PublicKey,\n  matchCreator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n\n  const ix = await program.methods\n    .joinMatch()\n    .accountsStrict({\n      opponent,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = opponent;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildCancelMatchTx(\n  connection: Connection,\n  creator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const ix = await program.methods\n    .cancelMatch()\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  winner: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get treasury address\n  const config = await program.account.coinflipConfig.fetch(configPda);\n  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n\n  // Derive player profile PDAs for CPI\n  const PLATFORM_PROGRAM_ID = new PublicKey(\"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\");\n  const [creatorProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  const [opponentProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n\n  const ix = await program.methods\n    .claimPayout()\n    .accountsStrict({\n      winner,\n      coinflipMatch: matchPda,\n      config: configPda,\n      treasury,\n      creator: matchCreator,\n      creatorProfile,\n      opponentProfile,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = winner;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n```\n\n---\n\n## 4. types.ts\n\n```typescript\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type CoinflipPhase = \"created\" | \"ready\" | \"countdown\" | \"flipping\" | \"complete\";\n\n/**\n * Simplified match type for UI/mock mode (doesn't require PublicKey)\n */\nexport interface UIMatch {\n  id: string;\n  tier: Tier;\n  entryAmount: number; // in SOL\n\n  // Player 1 (creator)\n  player1: string; // wallet address\n  player1Side: CoinSide;\n\n  // Player 2 (joiner)\n  player2: string | null;\n  player2Side: CoinSide | null;\n\n  // Match state\n  phase: CoinflipPhase;\n  createdAt: number; // timestamp\n  countdownStartedAt?: number; // when countdown started\n  completedAt?: number;\n\n  // Result\n  result: CoinSide | null;\n  winner: string | null;\n\n  // Payout\n  claimed: boolean;\n  payoutAmount: number; // amount winner receives\n\n  // Provably Fair - VRF-based verification\n  seedHash: string; // SHA-256 hash of server seed (shown before flip)\n  serverSeed?: string; // Actual server seed (revealed only after settlement)\n  vrfProof?: string; // VRF proof for on-chain verification\n  blockHash?: string; // Solana blockhash used as entropy source\n}\n\nexport interface MatchFilter {\n  tier?: Tier;\n  status?: \"open\" | \"all\";\n}\n\nexport interface CreateMatchParams {\n  tier: Tier;\n  side: CoinSide;\n}\n\nexport interface JoinMatchParams {\n  matchId: string;\n}\n```\n\n---\n\n## 5. MatchCard.tsx\n\n```typescript\nimport type { UIMatch } from \"../types\";\nimport { TIER_COLORS } from \"@rng-utopia/ui\";\nimport { PlayerAvatar, getDisplayName } from \"../../player-profile\";\n\ninterface MatchCardProps {\n  match: UIMatch;\n  onJoin?: () => void;\n  isOwn?: boolean;\n  canJoin?: boolean;\n  joining?: boolean;\n}\n\nexport function MatchCard({\n  match,\n  onJoin,\n  isOwn = false,\n  canJoin = true,\n  joining = false,\n}: MatchCardProps) {\n  const timeAgo = getTimeAgo(match.createdAt);\n\n  return (\n    <div className={`coinflip-match-card ${isOwn ? \"coinflip-match-card--own\" : \"\"}`}>\n      <div className=\"coinflip-match-card__creator\">\n        <PlayerAvatar address={match.player1} size=\"sm\" enableMiniProfile={false} />\n        <div className=\"coinflip-match-card__info\">\n          <span className=\"coinflip-match-card__address\">\n            {getDisplayName(match.player1)}\n          </span>\n          <span className=\"coinflip-match-card__time\">{timeAgo}</span>\n        </div>\n      </div>\n\n      <div className=\"coinflip-match-card__bet\">\n        <div\n          className={`coinflip-match-card__side coinflip-match-card__side--${match.player1Side}`}\n        >\n          <span className=\"coinflip-match-card__rng\">RNG</span>\n        </div>\n        <div className=\"coinflip-match-card__amount\">\n          {match.entryAmount} SOL\n        </div>\n        <div\n          className=\"coinflip-match-card__tier\"\n          style={{\n            color: TIER_COLORS[match.tier],\n            textShadow: `0 0 8px ${TIER_COLORS[match.tier]}`\n          }}\n        >\n          {match.tier}\n        </div>\n      </div>\n\n      <div className=\"coinflip-match-card__actions\">\n        {!isOwn && onJoin && (\n          <button\n            type=\"button\"\n            className=\"coinflip-match-card__join-btn\"\n            onClick={onJoin}\n            disabled={!canJoin || joining}\n          >\n            {joining ? \"Joining...\" : \"Join\"}\n          </button>\n        )}\n        {isOwn && (\n          <span className=\"coinflip-match-card__status\">Waiting...</span>\n        )}\n      </div>\n    </div>\n  );\n}\n\nfunction getTimeAgo(timestamp: number): string {\n  const seconds = Math.floor((Date.now() - timestamp) / 1000);\n\n  if (seconds < 60) return `${seconds}s ago`;\n  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;\n  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;\n  return `${Math.floor(seconds / 86400)}d ago`;\n}\n```\n\n---\n\n## 6. index.ts\n\n```typescript\n// Context & Hooks\nexport { CoinflipProvider, useCoinflip } from \"./context/CoinflipContext\";\n\n// Components\nexport {\n  CoinSideSelector,\n  CoinAnimation,\n  MatchCard,\n  OpenMatchesList,\n  ActiveMatchView,\n} from \"./components\";\n\n// Types\nexport type { UIMatch, CoinSide, CoinflipPhase } from \"./types\";\n\n// Utils\nexport { truncateAddress } from \"./utils/helpers\";\n```\n\n---\n\nAll six files have been read and are presented above in full. This gives you a complete picture of:\n- The lobby browser UI components (OpenMatchesList, MatchCard)\n- The Coinflip context managing state and wallet integration (CoinflipContext)\n- The on-chain utilities for building transactions and fetching match data (chain.ts)\n- The TypeScript type definitions (types.ts)\n- The module exports (index.ts)"}],"totalDurationMs":47588,"totalTokens":37458,"totalToolUseCount":6,"usage":{"input_tokens":7,"cache_creation_input_tokens":10646,"cache_read_input_tokens":19304,"output_tokens":7501,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":10646,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}}}
