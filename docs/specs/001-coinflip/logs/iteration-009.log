{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NdWL2V1dao5d5BSnzbJXVm","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useMemo,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { Connection, PublicKey } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchMatchByCreator,\n    16→  fetchMatch,\n    17→  buildCreateMatchTx,\n    18→  buildJoinMatchTx,\n    19→  buildCancelMatchTx,\n    20→  buildClaimPayoutTx,\n    21→} from \"../utils/chain\";\n    22→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    23→\n    24→// RPC endpoint — defaults to localhost for development\n    25→const RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    26→  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n    27→\n    28→interface CoinflipContextValue {\n    29→  // State\n    30→  activeMatch: UIMatch | null;\n    31→  openMatches: UIMatch[];\n    32→  userHistory: UIMatch[];\n    33→  selectedTier: Tier | null;\n    34→  selectedSide: CoinSide | null;\n    35→\n    36→  // Loading states\n    37→  loading: boolean;\n    38→  creating: boolean;\n    39→  joining: boolean;\n    40→  claiming: boolean;\n    41→  joiningMatchId: string | null;\n    42→\n    43→  // Actions\n    44→  setSelectedTier: (tier: Tier | null) => void;\n    45→  setSelectedSide: (side: CoinSide | null) => void;\n    46→  createMatch: () => Promise<void>;\n    47→  joinMatch: (matchId: string) => Promise<void>;\n    48→  cancelMatch: () => Promise<void>;\n    49→  claimPayout: () => Promise<void>;\n    50→  clearActiveMatch: () => void;\n    51→  refreshMatches: () => void;\n    52→}\n    53→\n    54→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n    55→\n    56→export function CoinflipProvider({ children }: { children: ReactNode }) {\n    57→  const { connected, publicKey, sendTransaction } = useWallet();\n    58→\n    59→  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n    60→\n    61→  // Selection state\n    62→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n    63→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n    64→\n    65→  // Match state\n    66→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n    67→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n    68→  const [userHistory] = useState<UIMatch[]>([]);\n    69→\n    70→  // Loading states\n    71→  const [loading, setLoading] = useState(true);\n    72→  const [creating, setCreating] = useState(false);\n    73→  const [joining, setJoining] = useState(false);\n    74→  const [claiming, setClaiming] = useState(false);\n    75→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n    76→\n    77→  // Fetch open matches from on-chain\n    78→  const refreshMatches = useCallback(() => {\n    79→    fetchAllOpenMatches(connection)\n    80→      .then((matches) => {\n    81→        setOpenMatches(matches);\n    82→        setLoading(false);\n    83→      })\n    84→      .catch(() => {\n    85→        setLoading(false);\n    86→      });\n    87→  }, [connection]);\n    88→\n    89→  // Initial load\n    90→  useEffect(() => {\n    91→    setLoading(true);\n    92→    refreshMatches();\n    93→  }, [refreshMatches]);\n    94→\n    95→  // Poll for match updates\n    96→  useEffect(() => {\n    97→    const interval = setInterval(() => {\n    98→      refreshMatches();\n    99→\n   100→      // If there's an active match, refresh it too\n   101→      if (activeMatch) {\n   102→        const matchPda = new PublicKey(activeMatch.id);\n   103→        fetchMatch(connection, matchPda)\n   104→          .then((updated) => {\n   105→            if (updated) {\n   106→              setActiveMatch(updated);\n   107→            } else {\n   108→              // Match account closed (claimed or cancelled)\n   109→              setActiveMatch(null);\n   110→            }\n   111→          })\n   112→          .catch(() => {\n   113→            // Ignore polling errors\n   114→          });\n   115→      }\n   116→    }, 5000);\n   117→    return () => clearInterval(interval);\n   118→  }, [refreshMatches, activeMatch, connection]);\n   119→\n   120→  const createMatch = useCallback(async () => {\n   121→    if (!connected || !publicKey) {\n   122→      throw new Error(\"Wallet not connected\");\n   123→    }\n   124→    if (!selectedTier || !selectedSide) {\n   125→      throw new Error(\"Select tier and side first\");\n   126→    }\n   127→\n   128→    setCreating(true);\n   129→    try {\n   130→      const { transaction, matchPda } = await buildCreateMatchTx(\n   131→        connection,\n   132→        publicKey,\n   133→        selectedTier,\n   134→        selectedSide\n   135→      );\n   136→\n   137→      await sendTransaction(transaction);\n   138→\n   139→      // Fetch the created match from on-chain\n   140→      const match = await fetchMatch(connection, matchPda);\n   141→      if (match) {\n   142→        setActiveMatch(match);\n   143→      }\n   144→\n   145→      setSelectedSide(null);\n   146→      refreshMatches();\n   147→    } finally {\n   148→      setCreating(false);\n   149→    }\n   150→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n   151→\n   152→  const joinMatch = useCallback(\n   153→    async (matchId: string) => {\n   154→      if (!connected || !publicKey) {\n   155→        throw new Error(\"Wallet not connected\");\n   156→      }\n   157→\n   158→      setJoining(true);\n   159→      setJoiningMatchId(matchId);\n   160→      try {\n   161→        // matchId is the match PDA base58 — fetch to get the creator\n   162→        const matchPda = new PublicKey(matchId);\n   163→        const existingMatch = await fetchMatch(connection, matchPda);\n   164→        if (!existingMatch) {\n   165→          throw new Error(\"Match not found\");\n   166→        }\n   167→\n   168→        const matchCreator = new PublicKey(existingMatch.player1);\n   169→        const transaction = await buildJoinMatchTx(\n   170→          connection,\n   171→          publicKey,\n   172→          matchCreator\n   173→        );\n   174→\n   175→        await sendTransaction(transaction);\n   176→\n   177→        // Fetch updated match\n   178→        const updated = await fetchMatch(connection, matchPda);\n   179→        if (updated) {\n   180→          setActiveMatch(updated);\n   181→        }\n   182→\n   183→        refreshMatches();\n   184→      } finally {\n   185→        setJoining(false);\n   186→        setJoiningMatchId(null);\n   187→      }\n   188→    },\n   189→    [connected, publicKey, connection, sendTransaction, refreshMatches]\n   190→  );\n   191→\n   192→  const cancelMatch = useCallback(async () => {\n   193→    if (!connected || !publicKey || !activeMatch) {\n   194→      throw new Error(\"No active match to cancel\");\n   195→    }\n   196→\n   197→    const transaction = await buildCancelMatchTx(connection, publicKey);\n   198→    await sendTransaction(transaction);\n   199→    setActiveMatch(null);\n   200→    refreshMatches();\n   201→  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n   202→\n   203→  const claimPayout = useCallback(async () => {\n   204→    if (!connected || !publicKey || !activeMatch) {\n   205→      throw new Error(\"No active match to claim\");\n   206→    }\n   207→\n   208→    setClaiming(true);\n   209→    try {\n   210→      const matchCreator = new PublicKey(activeMatch.player1);\n   211→      const opponent = activeMatch.player2\n   212→        ? new PublicKey(activeMatch.player2)\n   213→        : PublicKey.default;\n   214→\n   215→      const transaction = await buildClaimPayoutTx(\n   216→        connection,\n   217→        publicKey,\n   218→        matchCreator,\n   219→        opponent\n   220→      );\n   221→\n   222→      await sendTransaction(transaction);\n   223→\n   224→      // Update local state\n   225→      setActiveMatch({ ...activeMatch, claimed: true });\n   226→    } finally {\n   227→      setClaiming(false);\n   228→    }\n   229→  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n   230→\n   231→  // Track if user explicitly cleared the match\n   232→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   233→\n   234→  const clearActiveMatch = useCallback(() => {\n   235→    setActiveMatch(null);\n   236→    setUserClearedMatch(true);\n   237→    refreshMatches();\n   238→  }, [refreshMatches]);\n   239→\n   240→  // Check for existing active match on wallet connect\n   241→  useEffect(() => {\n   242→    if (publicKey && !activeMatch && !userClearedMatch) {\n   243→      fetchMatchByCreator(connection, publicKey)\n   244→        .then((match) => {\n   245→          if (match) {\n   246→            setActiveMatch(match);\n   247→          }\n   248→        })\n   249→        .catch(() => {\n   250→          // No active match found\n   251→        });\n   252→    }\n   253→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   254→\n   255→  // Reset userClearedMatch when creating or joining a new match\n   256→  useEffect(() => {\n   257→    if (activeMatch) {\n   258→      setUserClearedMatch(false);\n   259→    }\n   260→  }, [activeMatch]);\n   261→\n   262→  const value: CoinflipContextValue = {\n   263→    activeMatch,\n   264→    openMatches,\n   265→    userHistory,\n   266→    selectedTier,\n   267→    selectedSide,\n   268→    loading,\n   269→    creating,\n   270→    joining,\n   271→    claiming,\n   272→    joiningMatchId,\n   273→    setSelectedTier,\n   274→    setSelectedSide,\n   275→    createMatch,\n   276→    joinMatch,\n   277→    cancelMatch,\n   278→    claimPayout,\n   279→    clearActiveMatch,\n   280→    refreshMatches,\n   281→  };\n   282→\n   283→  return (\n   284→    <CoinflipContext.Provider value={value}>\n   285→      {children}\n   286→    </CoinflipContext.Provider>\n   287→  );\n   288→}\n   289→\n   290→export function useCoinflip(): CoinflipContextValue {\n   291→  const context = useContext(CoinflipContext);\n   292→  if (!context) {\n   293→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   294→  }\n   295→  return context;\n   296→}\n   297→"}]},"parent_tool_use_id":"toolu_01YAuPzw3ZszBedQhEyD9UUz","session_id":"44b168fb-5e34-4073-98cb-22d0c5867ea1","uuid":"17217f13-249f-4221-96a4-adf35283248a"}
