n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    clearActiveMatch,\n  } = useCoinflip();","originalFile":"import { useState } from \"react\";\nimport {\n  GameLayout,\n  TierSelector,\n  TIER_COLORS,\n  Modal,\n  type HistoryEntry,\n} from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\nimport {\n  CoinflipProvider,\n  useCoinflip,\n  CoinSideSelector,\n  OpenMatchesList,\n  ActiveMatchView,\n  type UIMatch,\n} from \"../features/coinflip\";\n\nfunction CoinflipPageContent() {\n  const { connected, address, connect } = useWallet();\n  const {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    clearActiveMatch,\n  } = useCoinflip();\n\n  // State for history detail modal\n  const [selectedHistoryMatch, setSelectedHistoryMatch] = useState<UIMatch | null>(null);\n\n  // Side colors (match the CSS .side-heads / .side-tails)\n  const SIDE_COLORS = {\n    heads: \"#00cc88\",\n    tails: \"#ff6644\",\n  };\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((match) => {\n    const isWinner = match.winner === address;\n    const isPlayer1 = match.player1 === address;\n    const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    const tierCapitalized = match.tier.charAt(0).toUpperCase() + match.tier.slice(1);\n    const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n    const tierColor = TIER_COLORS[match.tier];\n    const outcomeColor = isWinner ? \"#39ff14\" : \"#d45d5d\";\n\n    return {\n      roundId: match.id.slice(-6),\n      result: (\n        <span className=\"coinflip-history-result\">\n          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n            {yourSide?.toUpperCase() ?? \"?\"}\n          </span>\n          <span className=\"coinflip-history-result__separator\">|</span>\n          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n            {tierCapitalized}\n          </span>\n          <span className=\"coinflip-history-result__separator\">|</span>\n          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {isWinner ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n      timestamp: new Date(match.completedAt ?? match.createdAt),\n      verified: true,\n      won: isWinner,\n      onClick: () => setSelectedHistoryMatch(match),\n    };\n  });\n\n  // Calculate potential payout\n  const potentialPayout = selectedTier\n    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n    : 0;\n\n  const handleCreateMatch = async () => {\n    try {\n      await createMatch();\n    } catch (error) {\n      console.error(\"Failed to create match:\", error);\n    }\n  };\n\n  const handleJoinMatch = async (matchId: string) => {\n    try {\n      await joinMatch(matchId);\n    } catch (error) {\n      console.error(\"Failed to join match:\", error);\n    }\n  };\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"coinflip-sidebar\">\n      {!activeMatch ? (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n\n          {/* Tier Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <div className=\"coinflip-sidebar__label-row\">\n              <label className=\"coinflip-sidebar__label\">\n                Select Tier\n                <img\n                  src=\"https://cryptologos.cc/logos/solana-sol-logo.svg\"\n                  alt=\"SOL\"\n                  className=\"coinflip-sidebar__sol-icon\"\n                />\n              </label>\n              <button\n                type=\"button\"\n                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n                onClick={() => setSelectedTier(null)}\n              >\n                All\n              </button>\n            </div>\n            <TierSelector\n              selectedTier={selectedTier}\n              onSelect={setSelectedTier}\n            />\n          </div>\n\n          {/* Side Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n            <CoinSideSelector\n              selectedSide={selectedSide}\n              onSelect={setSelectedSide}\n              disabled={!connected}\n            />\n          </div>\n\n          {/* Summary */}\n          {selectedTier && selectedSide && (\n            <div className=\"coinflip-sidebar__summary\">\n              <div className=\"coinflip-sidebar__row\">\n                <span>Entry</span>\n                <span>{TIER_AMOUNTS[selectedTier]} SOL</span>\n              </div>\n              <div className=\"coinflip-sidebar__row\">\n                <span>Potential Payout</span>\n                <span className=\"coinflip-sidebar__payout\">\n                  {potentialPayout.toFixed(4)} SOL\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Action Button */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={handleCreateMatch}\n              disabled={!selectedTier || !selectedSide || creating}\n            >\n              {creating ? \"Creating...\" : \"Create Game\"}\n            </button>\n          )}\n        </>\n      ) : (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n\n          <div className=\"coinflip-sidebar__game-info\">\n            <div className=\"coinflip-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"coinflip-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[activeMatch.tier],\n                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n                }}\n              >\n                {activeMatch.tier}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Your Side</span>\n              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n                {(activeMatch.player1 === address\n                  ? activeMatch.player1Side\n                  : activeMatch.player2Side\n                )?.toUpperCase()}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Entry</span>\n              <span>{activeMatch.entryAmount} SOL</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Pot</span>\n              <span className=\"coinflip-sidebar__pot\">{activeMatch.entryAmount * 2} SOL</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Status</span>\n              <span className=\"coinflip-sidebar__status\">\n                {activeMatch.phase === \"created\" && \"Waiting...\"}\n                {activeMatch.phase === \"ready\" && \"Ready!\"}\n                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n                {activeMatch.phase === \"complete\" && \"Complete\"}\n              </span>\n            </div>\n          </div>\n\n          {/* Round Fairness Info */}\n          <div className=\"coinflip-sidebar__fairness\">\n            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Match ID</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n                {activeMatch.id.slice(-8)}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Seed Hash</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n              </span>\n            </div>\n            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n              <>\n                <div className=\"coinflip-sidebar__fairness-row\">\n                  <span>Server Seed</span>\n                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n                  </span>\n                </div>\n                {activeMatch.blockHash && (\n                  <div className=\"coinflip-sidebar__fairness-row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n                    </span>\n                  </div>\n                )}\n              </>\n            )}\n          </div>\n\n          {activeMatch.phase === \"complete\" && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n              onClick={clearActiveMatch}\n            >\n              Back to Lobby\n            </button>\n          )}\n        </>\n      )}\n    </div>\n  );\n\n  // Helper to get side display for modal\n  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n    const side = isPlayer1 ? match.player1Side : match.player2Side;\n    return side?.toUpperCase() ?? \"?\";\n  };\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Coinflip\"\n        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"coinflip-main\">\n          {/* Show active match or lobby */}\n          {activeMatch ? (\n            <ActiveMatchView\n              match={activeMatch}\n              currentUserAddress={address ?? \"\"}\n            />\n          ) : (\n            <div className=\"coinflip-lobby\">\n              <OpenMatchesList\n                matches={openMatches}\n                loading={loading}\n                onJoin={handleJoinMatch}\n                joiningMatchId={joiningMatchId}\n                currentUserAddress={address}\n                selectedTier={selectedTier}\n                isConnected={connected}\n              />\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* History Detail Modal */}\n      <Modal\n        isOpen={selectedHistoryMatch !== null}\n        onClose={() => setSelectedHistoryMatch(null)}\n        title=\"Match Details\"\n      >\n        {selectedHistoryMatch && (() => {\n          const isPlayer1 = selectedHistoryMatch.player1 === address;\n          const isWinner = selectedHistoryMatch.winner === address;\n          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n\n          return (\n            <div className=\"coinflip-history-modal\">\n              {/* Match Stats */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Tier</span>\n                  <span\n                    style={{\n                      color: TIER_COLORS[selectedHistoryMatch.tier],\n                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n                      textTransform: \"capitalize\",\n                    }}\n                  >\n                    {selectedHistoryMatch.tier}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Entry</span>\n                  <span>{selectedHistoryMatch.entryAmount} SOL</span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Total Pot</span>\n                  <span className=\"coinflip-history-modal__highlight\">\n                    {(selectedHistoryMatch.entryAmount * 2).toFixed(4)} SOL\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Result</span>\n                  <span\n                    style={{\n                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n                      textShadow: selectedHistoryMatch.result\n                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n                        : undefined,\n                    }}\n                  >\n                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n                    style={{ color: isWinner ? \"#39ff14\" : \"#d45d5d\" }}\n                  >\n                    {isWinner ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Payout</span>\n                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n                    {isWinner ? `+${selectedHistoryMatch.payoutAmount.toFixed(4)}` : `-${selectedHistoryMatch.entryAmount.toFixed(4)}`} SOL\n                  </span>\n                </div>\n              </div>\n\n              {/* Match Fairness */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">\n                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n                  Round Fairness\n                </h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Match ID</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n                    {selectedHistoryMatch.id}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Seed Hash</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n                    {selectedHistoryMatch.seedHash}\n                  </span>\n                </div>\n                {selectedHistoryMatch.serverSeed && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Server Seed</span>\n                    <span\n                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n                      title={selectedHistoryMatch.serverSeed}\n                    >\n                      {selectedHistoryMatch.serverSeed}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.blockHash && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n                      {selectedHistoryMatch.blockHash}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.vrfProof && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>VRF Proof</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n                    </span>\n                  </div>\n                )}\n              </div>\n\n              {/* Verify Link */}\n              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n                Verify on Fairness Page →\n              </a>\n            </div>\n          );\n        })()}\n      </Modal>\n    </>\n  );\n}\n\nexport function CoinflipPage() {\n  return (\n    <CoinflipProvider>\n      <CoinflipPageContent />\n    </CoinflipProvider>\n  );\n}\n","structuredPatch":[{"oldStart":3,"oldLines":6,"newStart":3,"newLines":7,"lines":["   GameLayout,","   TierSelector,","   TIER_COLORS,","+  Toast,","   Modal,","   type HistoryEntry,"," } from \"@rng-utopia/ui\";"]},{"oldStart":28,"oldLines":6,"newStart":29,"newLines":8,"lines":["     loading,","     creating,","     joiningMatchId,","+    error,","+    clearError,","     setSelectedTier,","     setSelectedSide,","     createMatch,"]}],"userModified":false,"replaceAll":false}}
