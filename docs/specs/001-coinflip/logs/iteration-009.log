{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012zehyAUEYNqHCUNytv9NPX","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useMemo,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { Connection, PublicKey } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchMatchByCreator,\n    16→  fetchMatch,\n    17→  buildCreateMatchTx,\n    18→  buildJoinMatchTx,\n    19→  buildCancelMatchTx,\n    20→  buildClaimPayoutTx,\n    21→} from \"../utils/chain\";\n    22→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    23→\n    24→// RPC endpoint — defaults to localhost for development\n    25→const RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    26→  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n    27→\n    28→interface CoinflipContextValue {\n    29→  // State\n    30→  activeMatch: UIMatch | null;\n    31→  openMatches: UIMatch[];\n    32→  userHistory: UIMatch[];\n    33→  selectedTier: Tier | null;\n    34→  selectedSide: CoinSide | null;\n    35→\n    36→  // Loading states\n    37→  loading: boolean;\n    38→  creating: boolean;\n    39→  joining: boolean;\n    40→  claiming: boolean;\n    41→  joiningMatchId: string | null;\n    42→\n    43→  // Actions\n    44→  setSelectedTier: (tier: Tier | null) => void;\n    45→  setSelectedSide: (side: CoinSide | null) => void;\n    46→  createMatch: () => Promise<void>;\n    47→  joinMatch: (matchId: string) => Promise<void>;\n    48→  cancelMatch: () => Promise<void>;\n    49→  claimPayout: () => Promise<void>;\n    50→  clearActiveMatch: () => void;\n    51→  refreshMatches: () => void;\n    52→}\n    53→\n    54→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n    55→\n    56→export function CoinflipProvider({ children }: { children: ReactNode }) {\n    57→  const { connected, publicKey, sendTransaction } = useWallet();\n    58→\n    59→  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n    60→\n    61→  // Selection state\n    62→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n    63→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n    64→\n    65→  // Match state\n    66→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n    67→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n    68→  const [userHistory] = useState<UIMatch[]>([]);\n    69→\n    70→  // Loading states\n    71→  const [loading, setLoading] = useState(true);\n    72→  const [creating, setCreating] = useState(false);\n    73→  const [joining, setJoining] = useState(false);\n    74→  const [claiming, setClaiming] = useState(false);\n    75→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n    76→\n    77→  // Fetch open matches from on-chain\n    78→  const refreshMatches = useCallback(() => {\n    79→    fetchAllOpenMatches(connection)\n    80→      .then((matches) => {\n    81→        setOpenMatches(matches);\n    82→        setLoading(false);\n    83→      })\n    84→      .catch(() => {\n    85→        setLoading(false);\n    86→      });\n    87→  }, [connection]);\n    88→\n    89→  // Initial load\n    90→  useEffect(() => {\n    91→    setLoading(true);\n    92→    refreshMatches();\n    93→  }, [refreshMatches]);\n    94→\n    95→  // Poll for match updates\n    96→  useEffect(() => {\n    97→    const interval = setInterval(() => {\n    98→      refreshMatches();\n    99→\n   100→      // If there's an active match, refresh it too\n   101→      if (activeMatch) {\n   102→        const matchPda = new PublicKey(activeMatch.id);\n   103→        fetchMatch(connection, matchPda)\n   104→          .then((updated) => {\n   105→            if (updated) {\n   106→              setActiveMatch(updated);\n   107→            } else {\n   108→              // Match account closed (claimed or cancelled)\n   109→              setActiveMatch(null);\n   110→            }\n   111→          })\n   112→          .catch(() => {\n   113→            // Ignore polling errors\n   114→          });\n   115→      }\n   116→    }, 5000);\n   117→    return () => clearInterval(interval);\n   118→  }, [refreshMatches, activeMatch, connection]);\n   119→\n   120→  const createMatch = useCallback(async () => {\n   121→    if (!connected || !publicKey) {\n   122→      throw new Error(\"Wallet not connected\");\n   123→    }\n   124→    if (!selectedTier || !selectedSide) {\n   125→      throw new Error(\"Select tier and side first\");\n   126→    }\n   127→\n   128→    setCreating(true);\n   129→    try {\n   130→      const { transaction, matchPda } = await buildCreateMatchTx(\n   131→        connection,\n   132→        publicKey,\n   133→        selectedTier,\n   134→        selectedSide\n   135→      );\n   136→\n   137→      await sendTransaction(transaction);\n   138→\n   139→      // Fetch the created match from on-chain\n   140→      const match = await fetchMatch(connection, matchPda);\n   141→      if (match) {\n   142→        setActiveMatch(match);\n   143→      }\n   144→\n   145→      setSelectedSide(null);\n   146→      refreshMatches();\n   147→    } finally {\n   148→      setCreating(false);\n   149→    }\n   150→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n   151→\n   152→  const joinMatch = useCallback(\n   153→    async (matchId: string) => {\n   154→      if (!connected || !publicKey) {\n   155→        throw new Error(\"Wallet not connected\");\n   156→      }\n   157→\n   158→      setJoining(true);\n   159→      setJoiningMatchId(matchId);\n   160→      try {\n   161→        // matchId is the match PDA base58 — fetch to get the creator\n   162→        const matchPda = new PublicKey(matchId);\n   163→        const existingMatch = await fetchMatch(connection, matchPda);\n   164→        if (!existingMatch) {\n   165→          throw new Error(\"Match not found\");\n   166→        }\n   167→\n   168→        const matchCreator = new PublicKey(existingMatch.player1);\n   169→        const transaction = await buildJoinMatchTx(\n   170→          connection,\n   171→          publicKey,\n   172→          matchCreator\n   173→        );\n   174→\n   175→        await sendTransaction(transaction);\n   176→\n   177→        // Fetch updated match\n   178→        const updated = await fetchMatch(connection, matchPda);\n   179→        if (updated) {\n   180→          setActiveMatch(updated);\n   181→        }\n   182→\n   183→        refreshMatches();\n   184→      } finally {\n   185→        setJoining(false);\n   186→        setJoiningMatchId(null);\n   187→      }\n   188→    },\n   189→    [connected, publicKey, connection, sendTransaction, refreshMatches]\n   190→  );\n   191→\n   192→  const cancelMatch = useCallback(async () => {\n   193→    if (!connected || !publicKey || !activeMatch) {\n   194→      throw new Error(\"No active match to cancel\");\n   195→    }\n   196→\n   197→    const transaction = await buildCancelMatchTx(connection, publicKey);\n   198→    await sendTransaction(transaction);\n   199→    setActiveMatch(null);\n   200→    refreshMatches();\n   201→  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n   202→\n   203→  const claimPayout = useCallback(async () => {\n   204→    if (!connected || !publicKey || !activeMatch) {\n   205→      throw new Error(\"No active match to claim\");\n   206→    }\n   207→\n   208→    setClaiming(true);\n   209→    try {\n   210→      const matchCreator = new PublicKey(activeMatch.player1);\n   211→      const opponent = activeMatch.player2\n   212→        ? new PublicKey(activeMatch.player2)\n   213→        : PublicKey.default;\n   214→\n   215→      const transaction = await buildClaimPayoutTx(\n   216→        connection,\n   217→        publicKey,\n   218→        matchCreator,\n   219→        opponent\n   220→      );\n   221→\n   222→      await sendTransaction(transaction);\n   223→\n   224→      // Update local state\n   225→      setActiveMatch({ ...activeMatch, claimed: true });\n   226→    } finally {\n   227→      setClaiming(false);\n   228→    }\n   229→  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n   230→\n   231→  // Track if user explicitly cleared the match\n   232→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   233→\n   234→  const clearActiveMatch = useCallback(() => {\n   235→    setActiveMatch(null);\n   236→    setUserClearedMatch(true);\n   237→    refreshMatches();\n   238→  }, [refreshMatches]);\n   239→\n   240→  // Check for existing active match on wallet connect\n   241→  useEffect(() => {\n   242→    if (publicKey && !activeMatch && !userClearedMatch) {\n   243→      fetchMatchByCreator(connection, publicKey)\n   244→        .then((match) => {\n   245→          if (match) {\n   246→            setActiveMatch(match);\n   247→          }\n   248→        })\n   249→        .catch(() => {\n   250→          // No active match found\n   251→        });\n   252→    }\n   253→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   254→\n   255→  // Reset userClearedMatch when creating or joining a new match\n   256→  useEffect(() => {\n   257→    if (activeMatch) {\n   258→      setUserClearedMatch(false);\n   259→    }\n   260→  }, [activeMatch]);\n   261→\n   262→  const value: CoinflipContextValue = {\n   263→    activeMatch,\n   264→    openMatches,\n   265→    userHistory,\n   266→    selectedTier,\n   267→    selectedSide,\n   268→    loading,\n   269→    creating,\n   270→    joining,\n   271→    claiming,\n   272→    joiningMatchId,\n   273→    setSelectedTier,\n   274→    setSelectedSide,\n   275→    createMatch,\n   276→    joinMatch,\n   277→    cancelMatch,\n   278→    claimPayout,\n   279→    clearActiveMatch,\n   280→    refreshMatches,\n   281→  };\n   282→\n   283→  return (\n   284→    <CoinflipContext.Provider value={value}>\n   285→      {children}\n   286→    </CoinflipContext.Provider>\n   287→  );\n   288→}\n   289→\n   290→export function useCoinflip(): CoinflipContextValue {\n   291→  const context = useContext(CoinflipContext);\n   292→  if (!context) {\n   293→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   294→  }\n   295→  return context;\n   296→}\n   297→"}]},"parent_tool_use_id":null,"session_id":"44b168fb-5e34-4073-98cb-22d0c5867ea1","uuid":"582ae9a1-1dc3-45c2-8c77-e7ebf8a80347","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\n// RPC endpoint — defaults to localhost for development\nconst RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n\n  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier || !selectedSide) {\n      throw new Error(\"Select tier and side first\");\n    }\n\n    setCreating(true);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          throw new Error(\"Match not found\");\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to cancel\");\n    }\n\n    const transaction = await buildCancelMatchTx(connection, publicKey);\n    await sendTransaction(transaction);\n    setActiveMatch(null);\n    refreshMatches();\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to claim\");\n    }\n\n    setClaiming(true);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":297,"startLine":1,"totalLines":297}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_013M98msEnAQehGnVBJaZo5n","type":"message","role":"assistant","content":[{"type":"text","text":"Now I'll add error state to the context and user-friendly error parsing for common Solana transaction errors. I'll also update the CoinflipPage to display errors."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3592,"cache_read_input_tokens":65855,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3592},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"44b168fb-5e34-4073-98cb-22d0c5867ea1","uuid":"5a2ec60a-1404-4474-87cd-15b062c1a7de"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_013M98msEnAQehGnVBJaZo5n","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WKv2ApFHFG8nykFEH8Jycb","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\n// RPC endpoint — defaults to localhost for development\nconst RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n\n/** Parse Solana/wallet errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  // Wallet not connected\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n\n  // User rejected\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n\n  // Insufficient funds (Solana runtime error)\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n\n  // Account already in use (match already exists)\n  if (msg.includes(\"already in use\")) {\n    return \"You already have an active match. Cancel it before creating a new one.\";\n  }\n\n  // Network / RPC errors\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n\n  // Anchor program errors\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This match is no longer available.\";\n  }\n  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    return \"You cannot join your own match.\";\n  }\n\n  // Generic fallback\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n\n  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendTransaction(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3592,"cache_read_input_tokens":65855,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3592},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"44b168fb-5e34-4073-98cb-22d0c5867ea1","uuid":"8c92b7cf-33e4-41c7-9ed1-5bcfc1672a6e"}
