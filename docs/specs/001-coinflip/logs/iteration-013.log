{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VEUk8EiBKxAKjQQDNfcKLW","type":"tool_result","content":"     1→import type { UIMatch } from \"../types\";\n     2→import { TIER_COLORS } from \"@rng-utopia/ui\";\n     3→import { PlayerAvatar, getDisplayName } from \"../../player-profile\";\n     4→\n     5→interface MatchCardProps {\n     6→  match: UIMatch;\n     7→  onJoin?: () => void;\n     8→  isOwn?: boolean;\n     9→  canJoin?: boolean;\n    10→  joining?: boolean;\n    11→}\n    12→\n    13→export function MatchCard({\n    14→  match,\n    15→  onJoin,\n    16→  isOwn = false,\n    17→  canJoin = true,\n    18→  joining = false,\n    19→}: MatchCardProps) {\n    20→  const timeAgo = getTimeAgo(match.createdAt);\n    21→\n    22→  return (\n    23→    <div className={`coinflip-match-card ${isOwn ? \"coinflip-match-card--own\" : \"\"}`}>\n    24→      <div className=\"coinflip-match-card__creator\">\n    25→        <PlayerAvatar address={match.player1} size=\"sm\" />\n    26→        <div className=\"coinflip-match-card__info\">\n    27→          <span className=\"coinflip-match-card__address\">\n    28→            {getDisplayName(match.player1)}\n    29→          </span>\n    30→          <span className=\"coinflip-match-card__time\">{timeAgo}</span>\n    31→        </div>\n    32→      </div>\n    33→\n    34→      <div className=\"coinflip-match-card__bet\">\n    35→        <div\n    36→          className={`coinflip-match-card__side coinflip-match-card__side--${match.player1Side}`}\n    37→        >\n    38→          <img\n    39→            src={match.player1Side === \"heads\" ? \"/sprites/green-shield.png\" : \"/sprites/red-shield.png\"}\n    40→            alt={match.player1Side}\n    41→            className=\"coinflip-match-card__shield-sprite\"\n    42→          />\n    43→        </div>\n    44→        <div\n    45→          className=\"coinflip-match-card__amount\"\n    46→          style={{ color: TIER_COLORS[match.tier] }}\n    47→        >\n    48→          {\"$\"}{match.entryAmount}\n    49→        </div>\n    50→      </div>\n    51→\n    52→      <div className=\"coinflip-match-card__actions\">\n    53→        {!isOwn && onJoin && (\n    54→          <button\n    55→            type=\"button\"\n    56→            className=\"coinflip-match-card__join-btn\"\n    57→            onClick={onJoin}\n    58→            disabled={!canJoin || joining}\n    59→          >\n    60→            {joining ? \"Joining...\" : \"Join\"}\n    61→          </button>\n    62→        )}\n    63→        {isOwn && (\n    64→          <span className=\"coinflip-match-card__status\">Waiting...</span>\n    65→        )}\n    66→      </div>\n    67→    </div>\n    68→  );\n    69→}\n    70→\n    71→function getTimeAgo(timestamp: number): string {\n    72→  const seconds = Math.floor((Date.now() - timestamp) / 1000);\n    73→\n    74→  if (seconds < 60) return `${seconds}s ago`;\n    75→  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;\n    76→  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;\n    77→  return `${Math.floor(seconds / 86400)}d ago`;\n    78→}\n    79→"}]},"parent_tool_use_id":null,"session_id":"73651d8d-ca1a-4f9e-b9b7-f2b958b23ec2","uuid":"cd8367fc-18e1-4f76-bac1-0c28abee80a2","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/components/MatchCard.tsx","content":"import type { UIMatch } from \"../types\";\nimport { TIER_COLORS } from \"@rng-utopia/ui\";\nimport { PlayerAvatar, getDisplayName } from \"../../player-profile\";\n\ninterface MatchCardProps {\n  match: UIMatch;\n  onJoin?: () => void;\n  isOwn?: boolean;\n  canJoin?: boolean;\n  joining?: boolean;\n}\n\nexport function MatchCard({\n  match,\n  onJoin,\n  isOwn = false,\n  canJoin = true,\n  joining = false,\n}: MatchCardProps) {\n  const timeAgo = getTimeAgo(match.createdAt);\n\n  return (\n    <div className={`coinflip-match-card ${isOwn ? \"coinflip-match-card--own\" : \"\"}`}>\n      <div className=\"coinflip-match-card__creator\">\n        <PlayerAvatar address={match.player1} size=\"sm\" />\n        <div className=\"coinflip-match-card__info\">\n          <span className=\"coinflip-match-card__address\">\n            {getDisplayName(match.player1)}\n          </span>\n          <span className=\"coinflip-match-card__time\">{timeAgo}</span>\n        </div>\n      </div>\n\n      <div className=\"coinflip-match-card__bet\">\n        <div\n          className={`coinflip-match-card__side coinflip-match-card__side--${match.player1Side}`}\n        >\n          <img\n            src={match.player1Side === \"heads\" ? \"/sprites/green-shield.png\" : \"/sprites/red-shield.png\"}\n            alt={match.player1Side}\n            className=\"coinflip-match-card__shield-sprite\"\n          />\n        </div>\n        <div\n          className=\"coinflip-match-card__amount\"\n          style={{ color: TIER_COLORS[match.tier] }}\n        >\n          {\"$\"}{match.entryAmount}\n        </div>\n      </div>\n\n      <div className=\"coinflip-match-card__actions\">\n        {!isOwn && onJoin && (\n          <button\n            type=\"button\"\n            className=\"coinflip-match-card__join-btn\"\n            onClick={onJoin}\n            disabled={!canJoin || joining}\n          >\n            {joining ? \"Joining...\" : \"Join\"}\n          </button>\n        )}\n        {isOwn && (\n          <span className=\"coinflip-match-card__status\">Waiting...</span>\n        )}\n      </div>\n    </div>\n  );\n}\n\nfunction getTimeAgo(timestamp: number): string {\n  const seconds = Math.floor((Date.now() - timestamp) / 1000);\n\n  if (seconds < 60) return `${seconds}s ago`;\n  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;\n  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;\n  return `${Math.floor(seconds / 86400)}d ago`;\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
