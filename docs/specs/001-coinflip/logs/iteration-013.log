{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016jsqC4p8FhXfHGQK6E4rrZ","type":"tool_result","content":"     1→import { useState } from \"react\";\n     2→import {\n     3→  GameLayout,\n     4→  TierSelector,\n     5→  TIER_COLORS,\n     6→  Toast,\n     7→  Modal,\n     8→  type HistoryEntry,\n     9→} from \"@rng-utopia/ui\";\n    10→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    11→import { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\n    12→import {\n    13→  CoinflipProvider,\n    14→  useCoinflip,\n    15→  CoinSideSelector,\n    16→  OpenMatchesList,\n    17→  ActiveMatchView,\n    18→  type UIMatch,\n    19→} from \"../features/coinflip\";\n    20→\n    21→function CoinflipPageContent() {\n    22→  const { connected, address, connect } = useWallet();\n    23→  const {\n    24→    activeMatch,\n    25→    openMatches,\n    26→    userHistory,\n    27→    selectedTier,\n    28→    selectedSide,\n    29→    loading,\n    30→    creating,\n    31→    joiningMatchId,\n    32→    error,\n    33→    clearError,\n    34→    setSelectedTier,\n    35→    setSelectedSide,\n    36→    createMatch,\n    37→    joinMatch,\n    38→    claiming,\n    39→    cancelMatch,\n    40→    timeoutCancel,\n    41→    claimPayout,\n    42→    clearActiveMatch,\n    43→  } = useCoinflip();\n    44→\n    45→  // State for history detail modal\n    46→  const [selectedHistoryMatch, setSelectedHistoryMatch] = useState<UIMatch | null>(null);\n    47→\n    48→  // Side colors (match the CSS .side-heads / .side-tails)\n    49→  const SIDE_COLORS = {\n    50→    heads: \"#45b058\",\n    51→    tails: \"#e09030\",\n    52→  };\n    53→\n    54→  // Convert user history to HistoryEntry format\n    55→  const historyEntries: HistoryEntry[] = userHistory.map((match) => {\n    56→    const isWinner = match.winner === address;\n    57→    const isPlayer1 = match.player1 === address;\n    58→    const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    59→    const tierCapitalized = match.tier.charAt(0).toUpperCase() + match.tier.slice(1);\n    60→    const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n    61→    const tierColor = TIER_COLORS[match.tier];\n    62→    const outcomeColor = isWinner ? \"#45b058\" : \"#d45d5d\";\n    63→\n    64→    return {\n    65→      roundId: match.id.slice(-6),\n    66→      result: (\n    67→        <span className=\"coinflip-history-result\">\n    68→          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n    69→            {yourSide?.toUpperCase() ?? \"?\"}\n    70→          </span>\n    71→          <span className=\"coinflip-history-result__separator\">|</span>\n    72→          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n    73→            {tierCapitalized}\n    74→          </span>\n    75→          <span className=\"coinflip-history-result__separator\">|</span>\n    76→          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n    77→            {isWinner ? \"WON\" : \"LOST\"}\n    78→          </span>\n    79→        </span>\n    80→      ),\n    81→      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n    82→      timestamp: new Date(match.completedAt ?? match.createdAt),\n    83→      verified: true,\n    84→      won: isWinner,\n    85→      onClick: () => setSelectedHistoryMatch(match),\n    86→    };\n    87→  });\n    88→\n    89→  // Calculate potential payout\n    90→  const potentialPayout = selectedTier\n    91→    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n    92→    : 0;\n    93→\n    94→  const handleCreateMatch = () => {\n    95→    createMatch();\n    96→  };\n    97→\n    98→  const handleJoinMatch = (matchId: string) => {\n    99→    joinMatch(matchId);\n   100→  };\n   101→\n   102→  // Sidebar content\n   103→  const sidebar = (\n   104→    <div className=\"coinflip-sidebar\">\n   105→      {!activeMatch ? (\n   106→        <>\n   107→          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n   108→\n   109→          {/* Tier Selection */}\n   110→          <div className=\"coinflip-sidebar__section\">\n   111→            <div className=\"coinflip-sidebar__label-row\">\n   112→              <label className=\"coinflip-sidebar__label\">\n   113→                Select Tier\n   114→              </label>\n   115→              <button\n   116→                type=\"button\"\n   117→                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n   118→                onClick={() => setSelectedTier(null)}\n   119→              >\n   120→                All\n   121→              </button>\n   122→            </div>\n   123→            <TierSelector\n   124→              selectedTier={selectedTier}\n   125→              onSelect={setSelectedTier}\n   126→            />\n   127→          </div>\n   128→\n   129→          {/* Side Selection */}\n   130→          <div className=\"coinflip-sidebar__section\">\n   131→            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n   132→            <CoinSideSelector\n   133→              selectedSide={selectedSide}\n   134→              onSelect={setSelectedSide}\n   135→              disabled={!connected}\n   136→            />\n   137→          </div>\n   138→\n   139→          {/* Summary */}\n   140→          {selectedTier && selectedSide && (\n   141→            <div className=\"coinflip-sidebar__summary\">\n   142→              <div className=\"coinflip-sidebar__row\">\n   143→                <span>Entry</span>\n   144→                <span>{`$${TIER_AMOUNTS[selectedTier]}`}</span>\n   145→              </div>\n   146→              <div className=\"coinflip-sidebar__row\">\n   147→                <span>Potential Payout</span>\n   148→                <span className=\"coinflip-sidebar__payout\">\n   149→                  {`$${potentialPayout.toFixed(2)}`}\n   150→                </span>\n   151→              </div>\n   152→            </div>\n   153→          )}\n   154→\n   155→          {/* Action Button */}\n   156→          {!connected ? (\n   157→            <button\n   158→              type=\"button\"\n   159→              className=\"coinflip-action-btn\"\n   160→              onClick={connect}\n   161→            >\n   162→              Connect Wallet\n   163→            </button>\n   164→          ) : (\n   165→            <button\n   166→              type=\"button\"\n   167→              className=\"coinflip-action-btn\"\n   168→              onClick={handleCreateMatch}\n   169→              disabled={!selectedTier || !selectedSide || creating}\n   170→            >\n   171→              {creating ? \"Creating...\" : \"Create Game\"}\n   172→            </button>\n   173→          )}\n   174→        </>\n   175→      ) : (\n   176→        <>\n   177→          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n   178→\n   179→          <div className=\"coinflip-sidebar__game-info\">\n   180→            <div className=\"coinflip-sidebar__row\">\n   181→              <span>Tier</span>\n   182→              <span\n   183→                className=\"coinflip-sidebar__tier\"\n   184→                style={{\n   185→                  color: TIER_COLORS[activeMatch.tier],\n   186→                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n   187→                }}\n   188→              >\n   189→                {activeMatch.tier}\n   190→              </span>\n   191→            </div>\n   192→            <div className=\"coinflip-sidebar__row\">\n   193→              <span>Your Side</span>\n   194→              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n   195→                {(activeMatch.player1 === address\n   196→                  ? activeMatch.player1Side\n   197→                  : activeMatch.player2Side\n   198→                )?.toUpperCase()}\n   199→              </span>\n   200→            </div>\n   201→            <div className=\"coinflip-sidebar__row\">\n   202→              <span>Entry</span>\n   203→              <span>{`$${activeMatch.entryAmount}`}</span>\n   204→            </div>\n   205→            <div className=\"coinflip-sidebar__row\">\n   206→              <span>Pot</span>\n   207→              <span className=\"coinflip-sidebar__pot\">{`$${activeMatch.entryAmount * 2}`}</span>\n   208→            </div>\n   209→            <div className=\"coinflip-sidebar__row\">\n   210→              <span>Status</span>\n   211→              <span className=\"coinflip-sidebar__status\">\n   212→                {activeMatch.phase === \"created\" && \"Waiting...\"}\n   213→                {activeMatch.phase === \"ready\" && \"Ready!\"}\n   214→                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n   215→                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n   216→                {activeMatch.phase === \"complete\" && \"Complete\"}\n   217→              </span>\n   218→            </div>\n   219→          </div>\n   220→\n   221→          {/* Round Fairness Info */}\n   222→          <div className=\"coinflip-sidebar__fairness\">\n   223→            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n   224→            <div className=\"coinflip-sidebar__fairness-row\">\n   225→              <span>Match ID</span>\n   226→              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n   227→                {activeMatch.id.slice(-8)}\n   228→              </span>\n   229→            </div>\n   230→            <div className=\"coinflip-sidebar__fairness-row\">\n   231→              <span>Seed Hash</span>\n   232→              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n   233→                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n   234→              </span>\n   235→            </div>\n   236→            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n   237→              <>\n   238→                <div className=\"coinflip-sidebar__fairness-row\">\n   239→                  <span>Server Seed</span>\n   240→                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n   241→                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n   242→                  </span>\n   243→                </div>\n   244→                {activeMatch.blockHash && (\n   245→                  <div className=\"coinflip-sidebar__fairness-row\">\n   246→                    <span>Block Hash</span>\n   247→                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n   248→                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n   249→                    </span>\n   250→                  </div>\n   251→                )}\n   252→              </>\n   253→            )}\n   254→          </div>\n   255→\n   256→          {activeMatch.phase === \"complete\" && !activeMatch.claimed && (\n   257→            <button\n   258→              type=\"button\"\n   259→              className=\"coinflip-action-btn\"\n   260→              onClick={claimPayout}\n   261→              disabled={claiming}\n   262→            >\n   263→              {claiming\n   264→                ? \"Settling...\"\n   265→                : activeMatch.winner === address\n   266→                  ? \"Claim Payout\"\n   267→                  : \"Settle & Return\"}\n   268→            </button>\n   269→          )}\n   270→          {activeMatch.phase === \"complete\" && activeMatch.claimed && (\n   271→            <button\n   272→              type=\"button\"\n   273→              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   274→              onClick={clearActiveMatch}\n   275→            >\n   276→              Back to Lobby\n   277→            </button>\n   278→          )}\n   279→        </>\n   280→      )}\n   281→    </div>\n   282→  );\n   283→\n   284→  // Helper to get side display for modal\n   285→  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n   286→    const side = isPlayer1 ? match.player1Side : match.player2Side;\n   287→    return side?.toUpperCase() ?? \"?\";\n   288→  };\n   289→\n   290→  return (\n   291→    <>\n   292→      <GameLayout\n   293→        gameName=\"Coinflip\"\n   294→        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n   295→        sidebar={sidebar}\n   296→        historyEntries={historyEntries}\n   297→        showHistory={true}\n   298→      >\n   299→        <div className=\"coinflip-main\">\n   300→          {/* Show active match or lobby */}\n   301→          {activeMatch ? (\n   302→            <ActiveMatchView\n   303→              match={activeMatch}\n   304→              currentUserAddress={address ?? \"\"}\n   305→              onCancel={activeMatch.phase === \"created\" ? cancelMatch : undefined}\n   306→              onTimeoutCancel={timeoutCancel}\n   307→              onClaim={claimPayout}\n   308→              onClearMatch={clearActiveMatch}\n   309→              claiming={claiming}\n   310→            />\n   311→          ) : (\n   312→            <div className=\"coinflip-lobby\">\n   313→              <OpenMatchesList\n   314→                matches={openMatches}\n   315→                loading={loading}\n   316→                onJoin={handleJoinMatch}\n   317→                joiningMatchId={joiningMatchId}\n   318→                currentUserAddress={address}\n   319→                selectedTier={selectedTier}\n   320→                isConnected={connected}\n   321→              />\n   322→            </div>\n   323→          )}\n   324→        </div>\n   325→      </GameLayout>\n   326→\n   327→      {/* Error Toast */}\n   328→      {error && (\n   329→        <div className=\"coinflip-error-toast\">\n   330→          <Toast variant=\"error\" message={error} onClose={clearError} />\n   331→        </div>\n   332→      )}\n   333→\n   334→      {/* History Detail Modal */}\n   335→      <Modal\n   336→        isOpen={selectedHistoryMatch !== null}\n   337→        onClose={() => setSelectedHistoryMatch(null)}\n   338→        title=\"Match Details\"\n   339→      >\n   340→        {selectedHistoryMatch && (() => {\n   341→          const isPlayer1 = selectedHistoryMatch.player1 === address;\n   342→          const isWinner = selectedHistoryMatch.winner === address;\n   343→          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n   344→          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n   345→\n   346→          return (\n   347→            <div className=\"coinflip-history-modal\">\n   348→              {/* Match Stats */}\n   349→              <div className=\"coinflip-history-modal__section\">\n   350→                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n   351→                <div className=\"coinflip-history-modal__row\">\n   352→                  <span>Tier</span>\n   353→                  <span\n   354→                    style={{\n   355→                      color: TIER_COLORS[selectedHistoryMatch.tier],\n   356→                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n   357→                      textTransform: \"capitalize\",\n   358→                    }}\n   359→                  >\n   360→                    {selectedHistoryMatch.tier}\n   361→                  </span>\n   362→                </div>\n   363→                <div className=\"coinflip-history-modal__row\">\n   364→                  <span>Your Side</span>\n   365→                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n   366→                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n   367→                  </span>\n   368→                </div>\n   369→                <div className=\"coinflip-history-modal__row\">\n   370→                  <span>Entry</span>\n   371→                  <span>{`$${selectedHistoryMatch.entryAmount}`}</span>\n   372→                </div>\n   373→                <div className=\"coinflip-history-modal__row\">\n   374→                  <span>Total Pot</span>\n   375→                  <span className=\"coinflip-history-modal__highlight\">\n   376→                    {`$${(selectedHistoryMatch.entryAmount * 2).toFixed(2)}`}\n   377→                  </span>\n   378→                </div>\n   379→                <div className=\"coinflip-history-modal__row\">\n   380→                  <span>Result</span>\n   381→                  <span\n   382→                    style={{\n   383→                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n   384→                      textShadow: selectedHistoryMatch.result\n   385→                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n   386→                        : undefined,\n   387→                    }}\n   388→                  >\n   389→                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n   390→                  </span>\n   391→                </div>\n   392→                <div className=\"coinflip-history-modal__row\">\n   393→                  <span>Outcome</span>\n   394→                  <span\n   395→                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n   396→                    style={{ color: isWinner ? \"#45b058\" : \"#d45d5d\" }}\n   397→                  >\n   398→                    {isWinner ? \"WON!\" : \"LOST\"}\n   399→                  </span>\n   400→                </div>\n   401→                <div className=\"coinflip-history-modal__row\">\n   402→                  <span>Payout</span>\n   403→                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n   404→                    {isWinner ? `+$${selectedHistoryMatch.payoutAmount.toFixed(2)}` : `-$${selectedHistoryMatch.entryAmount.toFixed(2)}`}\n   405→                  </span>\n   406→                </div>\n   407→              </div>\n   408→\n   409→              {/* Match Fairness */}\n   410→              <div className=\"coinflip-history-modal__section\">\n   411→                <h4 className=\"coinflip-history-modal__section-title\">\n   412→                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n   413→                  Round Fairness\n   414→                </h4>\n   415→                <div className=\"coinflip-history-modal__row\">\n   416→                  <span>Match ID</span>\n   417→                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n   418→                    {selectedHistoryMatch.id}\n   419→                  </span>\n   420→                </div>\n   421→                <div className=\"coinflip-history-modal__row\">\n   422→                  <span>Seed Hash</span>\n   423→                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n   424→                    {selectedHistoryMatch.seedHash}\n   425→                  </span>\n   426→                </div>\n   427→                {selectedHistoryMatch.serverSeed && (\n   428→                  <div className=\"coinflip-history-modal__row\">\n   429→                    <span>Server Seed</span>\n   430→                    <span\n   431→                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n   432→                      title={selectedHistoryMatch.serverSeed}\n   433→                    >\n   434→                      {selectedHistoryMatch.serverSeed}\n   435→                    </span>\n   436→                  </div>\n   437→                )}\n   438→                {selectedHistoryMatch.blockHash && (\n   439→                  <div className=\"coinflip-history-modal__row\">\n   440→                    <span>Block Hash</span>\n   441→                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n   442→                      {selectedHistoryMatch.blockHash}\n   443→                    </span>\n   444→                  </div>\n   445→                )}\n   446→                {selectedHistoryMatch.vrfProof && (\n   447→                  <div className=\"coinflip-history-modal__row\">\n   448→                    <span>VRF Proof</span>\n   449→                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n   450→                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n   451→                    </span>\n   452→                  </div>\n   453→                )}\n   454→              </div>\n   455→\n   456→              {/* Verify Link */}\n   457→              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n   458→                Verify on Fairness Page →\n   459→              </a>\n   460→            </div>\n   461→          );\n   462→        })()}\n   463→      </Modal>\n   464→    </>\n   465→  );\n   466→}\n   467→\n   468→export function CoinflipPage() {\n   469→  return (\n   470→    <CoinflipProvider>\n   471→      <CoinflipPageContent />\n   472→    </CoinflipProvider>\n   473→  );\n   474→}\n   475→"}]},"parent_tool_use_id":null,"session_id":"73651d8d-ca1a-4f9e-b9b7-f2b958b23ec2","uuid":"a37d6ceb-efb5-4351-b8f6-8cc09aef4cc0","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/pages/CoinflipPage.tsx","content":"import { useState } from \"react\";\nimport {\n  GameLayout,\n  TierSelector,\n  TIER_COLORS,\n  Toast,\n  Modal,\n  type HistoryEntry,\n} from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\nimport {\n  CoinflipProvider,\n  useCoinflip,\n  CoinSideSelector,\n  OpenMatchesList,\n  ActiveMatchView,\n  type UIMatch,\n} from \"../features/coinflip\";\n\nfunction CoinflipPageContent() {\n  const { connected, address, connect } = useWallet();\n  const {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    claiming,\n    cancelMatch,\n    timeoutCancel,\n    claimPayout,\n    clearActiveMatch,\n  } = useCoinflip();\n\n  // State for history detail modal\n  const [selectedHistoryMatch, setSelectedHistoryMatch] = useState<UIMatch | null>(null);\n\n  // Side colors (match the CSS .side-heads / .side-tails)\n  const SIDE_COLORS = {\n    heads: \"#45b058\",\n    tails: \"#e09030\",\n  };\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((match) => {\n    const isWinner = match.winner === address;\n    const isPlayer1 = match.player1 === address;\n    const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    const tierCapitalized = match.tier.charAt(0).toUpperCase() + match.tier.slice(1);\n    const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n    const tierColor = TIER_COLORS[match.tier];\n    const outcomeColor = isWinner ? \"#45b058\" : \"#d45d5d\";\n\n    return {\n      roundId: match.id.slice(-6),\n      result: (\n        <span className=\"coinflip-history-result\">\n          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n            {yourSide?.toUpperCase() ?? \"?\"}\n          </span>\n          <span className=\"coinflip-history-result__separator\">|</span>\n          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n            {tierCapitalized}\n          </span>\n          <span className=\"coinflip-history-result__separator\">|</span>\n          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {isWinner ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n      timestamp: new Date(match.completedAt ?? match.createdAt),\n      verified: true,\n      won: isWinner,\n      onClick: () => setSelectedHistoryMatch(match),\n    };\n  });\n\n  // Calculate potential payout\n  const potentialPayout = selectedTier\n    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n    : 0;\n\n  const handleCreateMatch = () => {\n    createMatch();\n  };\n\n  const handleJoinMatch = (matchId: string) => {\n    joinMatch(matchId);\n  };\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"coinflip-sidebar\">\n      {!activeMatch ? (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n\n          {/* Tier Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <div className=\"coinflip-sidebar__label-row\">\n              <label className=\"coinflip-sidebar__label\">\n                Select Tier\n              </label>\n              <button\n                type=\"button\"\n                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n                onClick={() => setSelectedTier(null)}\n              >\n                All\n              </button>\n            </div>\n            <TierSelector\n              selectedTier={selectedTier}\n              onSelect={setSelectedTier}\n            />\n          </div>\n\n          {/* Side Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n            <CoinSideSelector\n              selectedSide={selectedSide}\n              onSelect={setSelectedSide}\n              disabled={!connected}\n            />\n          </div>\n\n          {/* Summary */}\n          {selectedTier && selectedSide && (\n            <div className=\"coinflip-sidebar__summary\">\n              <div className=\"coinflip-sidebar__row\">\n                <span>Entry</span>\n                <span>{`$${TIER_AMOUNTS[selectedTier]}`}</span>\n              </div>\n              <div className=\"coinflip-sidebar__row\">\n                <span>Potential Payout</span>\n                <span className=\"coinflip-sidebar__payout\">\n                  {`$${potentialPayout.toFixed(2)}`}\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Action Button */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={handleCreateMatch}\n              disabled={!selectedTier || !selectedSide || creating}\n            >\n              {creating ? \"Creating...\" : \"Create Game\"}\n            </button>\n          )}\n        </>\n      ) : (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n\n          <div className=\"coinflip-sidebar__game-info\">\n            <div className=\"coinflip-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"coinflip-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[activeMatch.tier],\n                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n                }}\n              >\n                {activeMatch.tier}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Your Side</span>\n              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n                {(activeMatch.player1 === address\n                  ? activeMatch.player1Side\n                  : activeMatch.player2Side\n                )?.toUpperCase()}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Entry</span>\n              <span>{`$${activeMatch.entryAmount}`}</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Pot</span>\n              <span className=\"coinflip-sidebar__pot\">{`$${activeMatch.entryAmount * 2}`}</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Status</span>\n              <span className=\"coinflip-sidebar__status\">\n                {activeMatch.phase === \"created\" && \"Waiting...\"}\n                {activeMatch.phase === \"ready\" && \"Ready!\"}\n                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n                {activeMatch.phase === \"complete\" && \"Complete\"}\n              </span>\n            </div>\n          </div>\n\n          {/* Round Fairness Info */}\n          <div className=\"coinflip-sidebar__fairness\">\n            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Match ID</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n                {activeMatch.id.slice(-8)}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Seed Hash</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n              </span>\n            </div>\n            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n              <>\n                <div className=\"coinflip-sidebar__fairness-row\">\n                  <span>Server Seed</span>\n                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n                  </span>\n                </div>\n                {activeMatch.blockHash && (\n                  <div className=\"coinflip-sidebar__fairness-row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n                    </span>\n                  </div>\n                )}\n              </>\n            )}\n          </div>\n\n          {activeMatch.phase === \"complete\" && !activeMatch.claimed && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={claimPayout}\n              disabled={claiming}\n            >\n              {claiming\n                ? \"Settling...\"\n                : activeMatch.winner === address\n                  ? \"Claim Payout\"\n                  : \"Settle & Return\"}\n            </button>\n          )}\n          {activeMatch.phase === \"complete\" && activeMatch.claimed && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n              onClick={clearActiveMatch}\n            >\n              Back to Lobby\n            </button>\n          )}\n        </>\n      )}\n    </div>\n  );\n\n  // Helper to get side display for modal\n  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n    const side = isPlayer1 ? match.player1Side : match.player2Side;\n    return side?.toUpperCase() ?? \"?\";\n  };\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Coinflip\"\n        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"coinflip-main\">\n          {/* Show active match or lobby */}\n          {activeMatch ? (\n            <ActiveMatchView\n              match={activeMatch}\n              currentUserAddress={address ?? \"\"}\n              onCancel={activeMatch.phase === \"created\" ? cancelMatch : undefined}\n              onTimeoutCancel={timeoutCancel}\n              onClaim={claimPayout}\n              onClearMatch={clearActiveMatch}\n              claiming={claiming}\n            />\n          ) : (\n            <div className=\"coinflip-lobby\">\n              <OpenMatchesList\n                matches={openMatches}\n                loading={loading}\n                onJoin={handleJoinMatch}\n                joiningMatchId={joiningMatchId}\n                currentUserAddress={address}\n                selectedTier={selectedTier}\n                isConnected={connected}\n              />\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* Error Toast */}\n      {error && (\n        <div className=\"coinflip-error-toast\">\n          <Toast variant=\"error\" message={error} onClose={clearError} />\n        </div>\n      )}\n\n      {/* History Detail Modal */}\n      <Modal\n        isOpen={selectedHistoryMatch !== null}\n        onClose={() => setSelectedHistoryMatch(null)}\n        title=\"Match Details\"\n      >\n        {selectedHistoryMatch && (() => {\n          const isPlayer1 = selectedHistoryMatch.player1 === address;\n          const isWinner = selectedHistoryMatch.winner === address;\n          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n\n          return (\n            <div className=\"coinflip-history-modal\">\n              {/* Match Stats */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Tier</span>\n                  <span\n                    style={{\n                      color: TIER_COLORS[selectedHistoryMatch.tier],\n                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n                      textTransform: \"capitalize\",\n                    }}\n                  >\n                    {selectedHistoryMatch.tier}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Entry</span>\n                  <span>{`$${selectedHistoryMatch.entryAmount}`}</span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Total Pot</span>\n                  <span className=\"coinflip-history-modal__highlight\">\n                    {`$${(selectedHistoryMatch.entryAmount * 2).toFixed(2)}`}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Result</span>\n                  <span\n                    style={{\n                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n                      textShadow: selectedHistoryMatch.result\n                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n                        : undefined,\n                    }}\n                  >\n                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n                    style={{ color: isWinner ? \"#45b058\" : \"#d45d5d\" }}\n                  >\n                    {isWinner ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Payout</span>\n                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n                    {isWinner ? `+$${selectedHistoryMatch.payoutAmount.toFixed(2)}` : `-$${selectedHistoryMatch.entryAmount.toFixed(2)}`}\n                  </span>\n                </div>\n              </div>\n\n              {/* Match Fairness */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">\n                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n                  Round Fairness\n                </h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Match ID</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n                    {selectedHistoryMatch.id}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Seed Hash</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n                    {selectedHistoryMatch.seedHash}\n                  </span>\n                </div>\n                {selectedHistoryMatch.serverSeed && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Server Seed</span>\n                    <span\n                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n                      title={selectedHistoryMatch.serverSeed}\n                    >\n                      {selectedHistoryMatch.serverSeed}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.blockHash && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n                      {selectedHistoryMatch.blockHash}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.vrfProof && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>VRF Proof</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n                    </span>\n                  </div>\n                )}\n              </div>\n\n              {/* Verify Link */}\n              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n                Verify on Fairness Page →\n              </a>\n            </div>\n          );\n        })()}\n      </Modal>\n    </>\n  );\n}\n\nexport function CoinflipPage() {\n  return (\n    <CoinflipProvider>\n      <CoinflipPageContent />\n    </CoinflipProvider>\n  );\n}\n","numLines":475,"startLine":1,"totalLines":475}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FVZafpEE48zLJzVkMGjeRH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01F75dQcCzrHy2jCJWPZv6X1","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":13453,"cache_read_input_tokens":37253,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":13453},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"73651d8d-ca1a-4f9e-b9b7-f2b958b23ec2","uuid":"94ec2976-4722-4a08-b242-17aa2d115576"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F75dQcCzrHy2jCJWPZv6X1","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→  type TransactionInstruction,\n     8→} from \"@solana/web3.js\";\n     9→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n    10→import {\n    11→  TIER_VALUES,\n    12→  COIN_SIDE_VALUES,\n    13→  TIER_AMOUNTS,\n    14→  type Tier,\n    15→  type CoinSide,\n    16→} from \"@rng-utopia/game-engine/browser\";\n    17→import type { UIMatch } from \"../types\";\n    18→\n    19→// ============ Constants ============\n    20→\n    21→const COINFLIP_PROGRAM_ID = new PublicKey(\n    22→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    23→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    24→);\n    25→\n    26→// Orao VRF program (on-chain VRF provider)\n    27→const ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n    28→\n    29→// ============ PDA Derivation ============\n    30→\n    31→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    32→  return PublicKey.findProgramAddressSync(\n    33→    [Buffer.from(\"match\"), creator.toBuffer()],\n    34→    COINFLIP_PROGRAM_ID\n    35→  );\n    36→}\n    37→\n    38→export function getConfigPda(): [PublicKey, number] {\n    39→  return PublicKey.findProgramAddressSync(\n    40→    [Buffer.from(\"coinflip_config\")],\n    41→    COINFLIP_PROGRAM_ID\n    42→  );\n    43→}\n    44→\n    45→/** Orao VRF network state PDA (stores config + treasury). */\n    46→function getOraoNetworkStatePda(): PublicKey {\n    47→  const [pda] = PublicKey.findProgramAddressSync(\n    48→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    49→    ORAO_VRF_PROGRAM_ID\n    50→  );\n    51→  return pda;\n    52→}\n    53→\n    54→/** Orao VRF randomness PDA derived from a 32-byte seed. */\n    55→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    56→  const [pda] = PublicKey.findProgramAddressSync(\n    57→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    58→    ORAO_VRF_PROGRAM_ID\n    59→  );\n    60→  return pda;\n    61→}\n    62→\n    63→// ============ Program Instance ============\n    64→\n    65→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    66→  // Read-only provider (no wallet needed for queries)\n    67→  const provider = new AnchorProvider(\n    68→    connection,\n    69→    {} as AnchorProvider[\"wallet\"],\n    70→    { commitment: \"confirmed\" }\n    71→  );\n    72→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    73→}\n    74→\n    75→// ============ On-Chain Account Types ============\n    76→\n    77→/** Anchor enum variant representation — one key with empty object value. */\n    78→type RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n    79→  | { resolving: object } | { settled: object } | { refunded: object };\n    80→\n    81→interface OnChainMatch {\n    82→  creator: PublicKey;\n    83→  opponent: PublicKey;\n    84→  tier: number;\n    85→  entryAmount: { toNumber(): number };\n    86→  creatorSide: number;\n    87→  phase: RoundPhaseVariant;\n    88→  result: number;\n    89→  winner: PublicKey;\n    90→  claimed: boolean;\n    91→  createdAt: { toNumber(): number };\n    92→  lockedAt: { toNumber(): number };\n    93→  resolveDeadline: { toNumber(): number };\n    94→  vrfRequestKey: PublicKey;\n    95→  bump: number;\n    96→}\n    97→\n    98→// ============ Converters ============\n    99→\n   100→function tierFromIndex(index: number): Tier {\n   101→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   102→  return tiers[index] ?? \"iron\";\n   103→}\n   104→\n   105→function sideFromIndex(index: number): CoinSide {\n   106→  return index === 0 ? \"heads\" : \"tails\";\n   107→}\n   108→\n   109→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   110→  return name in phase;\n   111→}\n   112→\n   113→function phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n   114→  if (isPhase(phase, \"waiting\")) return \"created\";\n   115→  if (isPhase(phase, \"locked\")) return \"ready\";\n   116→  if (isPhase(phase, \"settled\")) return \"complete\";\n   117→  return \"created\";\n   118→}\n   119→\n   120→const DEFAULT_PUBKEY = PublicKey.default;\n   121→\n   122→function isDefaultPubkey(key: PublicKey): boolean {\n   123→  return key.equals(DEFAULT_PUBKEY);\n   124→}\n   125→\n   126→export function onChainMatchToUI(\n   127→  matchPda: PublicKey,\n   128→  data: OnChainMatch\n   129→): UIMatch {\n   130→  const tier = tierFromIndex(data.tier);\n   131→  const creatorSide = sideFromIndex(data.creatorSide);\n   132→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   133→  const phase = phaseToUI(data.phase);\n   134→  const isSettled = isPhase(data.phase, \"settled\");\n   135→\n   136→  const entryAmountSol = TIER_AMOUNTS[tier];\n   137→  const totalPool = entryAmountSol * 2;\n   138→  const payoutAmount = totalPool * 0.97;\n   139→\n   140→  const lockedAt = data.lockedAt.toNumber();\n   141→\n   142→  return {\n   143→    id: matchPda.toBase58(),\n   144→    tier,\n   145→    entryAmount: entryAmountSol,\n   146→    player1: data.creator.toBase58(),\n   147→    player1Side: creatorSide,\n   148→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   149→    player2Side: hasOpponent\n   150→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   151→      : null,\n   152→    phase,\n   153→    createdAt: Date.now(),\n   154→    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n   155→    result: isSettled ? sideFromIndex(data.result) : null,\n   156→    winner: isSettled && !isDefaultPubkey(data.winner)\n   157→      ? data.winner.toBase58()\n   158→      : null,\n   159→    claimed: data.claimed,\n   160→    payoutAmount,\n   161→    seedHash: \"\",\n   162→  };\n   163→}\n   164→\n   165→// ============ Account Queries ============\n   166→\n   167→export async function fetchAllOpenMatches(\n   168→  connection: Connection\n   169→): Promise<UIMatch[]> {\n   170→  const program = getCoinflipProgram(connection);\n   171→  const accounts = await program.account.coinflipMatch.all();\n   172→\n   173→  return accounts\n   174→    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n   175→    .map((acc) =>\n   176→      onChainMatchToUI(\n   177→        acc.publicKey,\n   178→        acc.account as unknown as OnChainMatch\n   179→      )\n   180→    );\n   181→}\n   182→\n   183→/**\n   184→ * Fetch all matches where playerPubkey is creator OR opponent,\n   185→ * claimed == false, and phase is non-terminal (not refunded).\n   186→ * Uses memcmp filters for efficient on-chain filtering.\n   187→ *\n   188→ * Account layout offsets (after 8-byte discriminator):\n   189→ *   creator:  8   (32 bytes)\n   190→ *   opponent: 40  (32 bytes)\n   191→ *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n   192→ */\n   193→export async function fetchClaimableMatches(\n   194→  connection: Connection,\n   195→  playerPubkey: PublicKey\n   196→): Promise<UIMatch[]> {\n   197→  const program = getCoinflipProgram(connection);\n   198→  const playerBase58 = playerPubkey.toBase58();\n   199→\n   200→  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n   201→  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n   202→\n   203→  const [asCreator, asOpponent] = await Promise.all([\n   204→    program.account.coinflipMatch.all([\n   205→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   206→      claimedFalseFilter,\n   207→    ]),\n   208→    program.account.coinflipMatch.all([\n   209→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   210→      claimedFalseFilter,\n   211→    ]),\n   212→  ]);\n   213→\n   214→  // Merge and deduplicate by public key\n   215→  const seen = new Set<string>();\n   216→  const matches: UIMatch[] = [];\n   217→\n   218→  for (const acc of [...asCreator, ...asOpponent]) {\n   219→    const key = acc.publicKey.toBase58();\n   220→    if (seen.has(key)) continue;\n   221→    seen.add(key);\n   222→\n   223→    const data = acc.account as unknown as OnChainMatch;\n   224→    // Skip terminal phase (refunded)\n   225→    if (isPhase(data.phase, \"refunded\")) continue;\n   226→\n   227→    matches.push(onChainMatchToUI(acc.publicKey, data));\n   228→  }\n   229→\n   230→  return matches;\n   231→}\n   232→\n   233→export async function fetchMatchByCreator(\n   234→  connection: Connection,\n   235→  creator: PublicKey\n   236→): Promise<UIMatch | null> {\n   237→  const program = getCoinflipProgram(connection);\n   238→  const [matchPda] = getMatchPda(creator);\n   239→\n   240→  try {\n   241→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   242→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   243→  } catch {\n   244→    // Account doesn't exist\n   245→    return null;\n   246→  }\n   247→}\n   248→\n   249→export async function fetchMatch(\n   250→  connection: Connection,\n   251→  matchPda: PublicKey\n   252→): Promise<UIMatch | null> {\n   253→  const program = getCoinflipProgram(connection);\n   254→\n   255→  try {\n   256→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   257→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   258→  } catch {\n   259→    return null;\n   260→  }\n   261→}\n   262→\n   263→// ============ Instruction Builders ============\n   264→\n   265→export function buildCreateMatchInstruction(\n   266→  creator: PublicKey,\n   267→  tier: Tier,\n   268→  side: CoinSide\n   269→): { instruction: TransactionInstruction; matchPda: PublicKey } {\n   270→  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n   271→  const [matchPda] = getMatchPda(creator);\n   272→  const [configPda] = getConfigPda();\n   273→\n   274→  const tierIndex = TIER_VALUES[tier];\n   275→  const sideIndex = COIN_SIDE_VALUES[side];\n   276→\n   277→  const instruction = program.methods\n   278→    .createMatch(tierIndex, sideIndex)\n   279→    .accountsStrict({\n   280→      creator,\n   281→      coinflipMatch: matchPda,\n   282→      config: configPda,\n   283→      systemProgram: SystemProgram.programId,\n   284→    })\n   285→    .instruction();\n   286→\n   287→  // instruction() returns a Promise<TransactionInstruction>, but we return\n   288→  // it synchronously wrapped — callers must await the instruction.\n   289→  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n   290→}\n   291→\n   292→export async function buildCreateMatchTx(\n   293→  connection: Connection,\n   294→  creator: PublicKey,\n   295→  tier: Tier,\n   296→  side: CoinSide\n   297→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   298→  const program = getCoinflipProgram(connection);\n   299→  const [matchPda] = getMatchPda(creator);\n   300→  const [configPda] = getConfigPda();\n   301→\n   302→  const tierIndex = TIER_VALUES[tier];\n   303→  const sideIndex = COIN_SIDE_VALUES[side];\n   304→\n   305→  const ix = await program.methods\n   306→    .createMatch(tierIndex, sideIndex)\n   307→    .accountsStrict({\n   308→      creator,\n   309→      coinflipMatch: matchPda,\n   310→      config: configPda,\n   311→      systemProgram: SystemProgram.programId,\n   312→    })\n   313→    .instruction();\n   314→\n   315→  const tx = new Transaction().add(ix);\n   316→  tx.feePayer = creator;\n   317→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   318→\n   319→  return { transaction: tx, matchPda };\n   320→}\n   321→\n   322→export async function buildJoinMatchTx(\n   323→  connection: Connection,\n   324→  opponent: PublicKey,\n   325→  matchCreator: PublicKey\n   326→): Promise<Transaction> {\n   327→  const program = getCoinflipProgram(connection);\n   328→  const [matchPda] = getMatchPda(matchCreator);\n   329→  const [configPda] = getConfigPda();\n   330→\n   331→  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n   332→  const oraoNetworkState = getOraoNetworkStatePda();\n   333→  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n   334→  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n   335→  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n   336→  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n   337→  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n   338→\n   339→  const ix = await program.methods\n   340→    .joinMatch()\n   341→    .accountsStrict({\n   342→      opponent,\n   343→      coinflipMatch: matchPda,\n   344→      config: configPda,\n   345→      oraoProgram: ORAO_VRF_PROGRAM_ID,\n   346→      oraoNetworkState,\n   347→      oraoTreasury,\n   348→      oraoRandom,\n   349→      systemProgram: SystemProgram.programId,\n   350→    })\n   351→    .instruction();\n   352→\n   353→  const tx = new Transaction().add(ix);\n   354→  tx.feePayer = opponent;\n   355→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   356→\n   357→  return tx;\n   358→}\n   359→\n   360→export async function buildCancelMatchTx(\n   361→  connection: Connection,\n   362→  creator: PublicKey\n   363→): Promise<Transaction> {\n   364→  const program = getCoinflipProgram(connection);\n   365→  const [matchPda] = getMatchPda(creator);\n   366→\n   367→  const ix = await program.methods\n   368→    .cancelMatch()\n   369→    .accountsStrict({\n   370→      creator,\n   371→      coinflipMatch: matchPda,\n   372→      systemProgram: SystemProgram.programId,\n   373→    })\n   374→    .instruction();\n   375→\n   376→  const tx = new Transaction().add(ix);\n   377→  tx.feePayer = creator;\n   378→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   379→\n   380→  return tx;\n   381→}\n   382→\n   383→export async function buildTimeoutCancelTx(\n   384→  connection: Connection,\n   385→  caller: PublicKey,\n   386→  matchCreator: PublicKey,\n   387→  opponent: PublicKey\n   388→): Promise<Transaction> {\n   389→  const program = getCoinflipProgram(connection);\n   390→  const [matchPda] = getMatchPda(matchCreator);\n   391→\n   392→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   393→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   394→\n   395→  const ix = await program.methods\n   396→    .timeoutCancel()\n   397→    .accountsStrict({\n   398→      caller,\n   399→      creator: matchCreator,\n   400→      opponent,\n   401→      coinflipMatch: matchPda,\n   402→      randomnessAccount,\n   403→    })\n   404→    .instruction();\n   405→\n   406→  const tx = new Transaction().add(ix);\n   407→  tx.feePayer = caller;\n   408→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   409→\n   410→  return tx;\n   411→}\n   412→\n   413→export async function buildClaimPayoutTx(\n   414→  connection: Connection,\n   415→  caller: PublicKey,\n   416→  matchCreator: PublicKey,\n   417→  opponent: PublicKey\n   418→): Promise<Transaction> {\n   419→  const program = getCoinflipProgram(connection);\n   420→  const [matchPda] = getMatchPda(matchCreator);\n   421→  const [configPda] = getConfigPda();\n   422→\n   423→  // Fetch config to get treasury address\n   424→  const config = await program.account.coinflipConfig.fetch(configPda);\n   425→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   426→\n   427→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   428→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   429→\n   430→  // Derive player profile PDAs for CPI\n   431→  const PLATFORM_PROGRAM_ID = new PublicKey(\n   432→    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n   433→      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n   434→  );\n   435→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   436→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   437→    PLATFORM_PROGRAM_ID\n   438→  );\n   439→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   440→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   441→    PLATFORM_PROGRAM_ID\n   442→  );\n   443→\n   444→  const ix = await program.methods\n   445→    .claimPayout()\n   446→    .accountsStrict({\n   447→      caller,\n   448→      coinflipMatch: matchPda,\n   449→      config: configPda,\n   450→      treasury,\n   451→      creator: matchCreator,\n   452→      opponent,\n   453→      randomnessAccount,\n   454→      creatorProfile,\n   455→      opponentProfile,\n   456→      platformProgram: PLATFORM_PROGRAM_ID,\n   457→      systemProgram: SystemProgram.programId,\n   458→    })\n   459→    .instruction();\n   460→\n   461→  const tx = new Transaction().add(ix);\n   462→  tx.feePayer = caller;\n   463→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   464→\n   465→  return tx;\n   466→}\n   467→"}]},"parent_tool_use_id":null,"session_id":"73651d8d-ca1a-4f9e-b9b7-f2b958b23ec2","uuid":"ccc0746b-5565-4ea5-9e0a-9e8aafe27c16","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts","content":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  type TransactionInstruction,\n} from \"@solana/web3.js\";\nimport { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  COIN_SIDE_VALUES,\n  TIER_AMOUNTS,\n  type Tier,\n  type CoinSide,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n);\n\n// Orao VRF program (on-chain VRF provider)\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n\n// ============ PDA Derivation ============\n\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n/** Orao VRF network state PDA (stores config + treasury). */\nfunction getOraoNetworkStatePda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n/** Orao VRF randomness PDA derived from a 32-byte seed. */\nfunction getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    ORAO_VRF_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ============ Program Instance ============\n\nfunction getCoinflipProgram(connection: Connection): Program<Coinflip> {\n  // Read-only provider (no wallet needed for queries)\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n}\n\n// ============ On-Chain Account Types ============\n\n/** Anchor enum variant representation — one key with empty object value. */\ntype RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n  | { resolving: object } | { settled: object } | { refunded: object };\n\ninterface OnChainMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  tier: number;\n  entryAmount: { toNumber(): number };\n  creatorSide: number;\n  phase: RoundPhaseVariant;\n  result: number;\n  winner: PublicKey;\n  claimed: boolean;\n  createdAt: { toNumber(): number };\n  lockedAt: { toNumber(): number };\n  resolveDeadline: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n  bump: number;\n}\n\n// ============ Converters ============\n\nfunction tierFromIndex(index: number): Tier {\n  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n  return tiers[index] ?? \"iron\";\n}\n\nfunction sideFromIndex(index: number): CoinSide {\n  return index === 0 ? \"heads\" : \"tails\";\n}\n\nfunction isPhase(phase: RoundPhaseVariant, name: string): boolean {\n  return name in phase;\n}\n\nfunction phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n  if (isPhase(phase, \"waiting\")) return \"created\";\n  if (isPhase(phase, \"locked\")) return \"ready\";\n  if (isPhase(phase, \"settled\")) return \"complete\";\n  return \"created\";\n}\n\nconst DEFAULT_PUBKEY = PublicKey.default;\n\nfunction isDefaultPubkey(key: PublicKey): boolean {\n  return key.equals(DEFAULT_PUBKEY);\n}\n\nexport function onChainMatchToUI(\n  matchPda: PublicKey,\n  data: OnChainMatch\n): UIMatch {\n  const tier = tierFromIndex(data.tier);\n  const creatorSide = sideFromIndex(data.creatorSide);\n  const hasOpponent = !isDefaultPubkey(data.opponent);\n  const phase = phaseToUI(data.phase);\n  const isSettled = isPhase(data.phase, \"settled\");\n\n  const entryAmountSol = TIER_AMOUNTS[tier];\n  const totalPool = entryAmountSol * 2;\n  const payoutAmount = totalPool * 0.97;\n\n  const lockedAt = data.lockedAt.toNumber();\n\n  return {\n    id: matchPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    player1: data.creator.toBase58(),\n    player1Side: creatorSide,\n    player2: hasOpponent ? data.opponent.toBase58() : null,\n    player2Side: hasOpponent\n      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n      : null,\n    phase,\n    createdAt: Date.now(),\n    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n    result: isSettled ? sideFromIndex(data.result) : null,\n    winner: isSettled && !isDefaultPubkey(data.winner)\n      ? data.winner.toBase58()\n      : null,\n    claimed: data.claimed,\n    payoutAmount,\n    seedHash: \"\",\n  };\n}\n\n// ============ Account Queries ============\n\nexport async function fetchAllOpenMatches(\n  connection: Connection\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const accounts = await program.account.coinflipMatch.all();\n\n  return accounts\n    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n    .map((acc) =>\n      onChainMatchToUI(\n        acc.publicKey,\n        acc.account as unknown as OnChainMatch\n      )\n    );\n}\n\n/**\n * Fetch all matches where playerPubkey is creator OR opponent,\n * claimed == false, and phase is non-terminal (not refunded).\n * Uses memcmp filters for efficient on-chain filtering.\n *\n * Account layout offsets (after 8-byte discriminator):\n *   creator:  8   (32 bytes)\n *   opponent: 40  (32 bytes)\n *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n */\nexport async function fetchClaimableMatches(\n  connection: Connection,\n  playerPubkey: PublicKey\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const playerBase58 = playerPubkey.toBase58();\n\n  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n\n  const [asCreator, asOpponent] = await Promise.all([\n    program.account.coinflipMatch.all([\n      { memcmp: { offset: 8, bytes: playerBase58 } },\n      claimedFalseFilter,\n    ]),\n    program.account.coinflipMatch.all([\n      { memcmp: { offset: 40, bytes: playerBase58 } },\n      claimedFalseFilter,\n    ]),\n  ]);\n\n  // Merge and deduplicate by public key\n  const seen = new Set<string>();\n  const matches: UIMatch[] = [];\n\n  for (const acc of [...asCreator, ...asOpponent]) {\n    const key = acc.publicKey.toBase58();\n    if (seen.has(key)) continue;\n    seen.add(key);\n\n    const data = acc.account as unknown as OnChainMatch;\n    // Skip terminal phase (refunded)\n    if (isPhase(data.phase, \"refunded\")) continue;\n\n    matches.push(onChainMatchToUI(acc.publicKey, data));\n  }\n\n  return matches;\n}\n\nexport async function fetchMatchByCreator(\n  connection: Connection,\n  creator: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    // Account doesn't exist\n    return null;\n  }\n}\n\nexport async function fetchMatch(\n  connection: Connection,\n  matchPda: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    return null;\n  }\n}\n\n// ============ Instruction Builders ============\n\nexport function buildCreateMatchInstruction(\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): { instruction: TransactionInstruction; matchPda: PublicKey } {\n  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n  const [matchPda] = getMatchPda(creator);\n  const [configPda] = getConfigPda();\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const instruction = program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  // instruction() returns a Promise<TransactionInstruction>, but we return\n  // it synchronously wrapped — callers must await the instruction.\n  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n}\n\nexport async function buildCreateMatchTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n  const [configPda] = getConfigPda();\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const ix = await program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, matchPda };\n}\n\nexport async function buildJoinMatchTx(\n  connection: Connection,\n  opponent: PublicKey,\n  matchCreator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n  const oraoNetworkState = getOraoNetworkStatePda();\n  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n\n  const ix = await program.methods\n    .joinMatch()\n    .accountsStrict({\n      opponent,\n      coinflipMatch: matchPda,\n      config: configPda,\n      oraoProgram: ORAO_VRF_PROGRAM_ID,\n      oraoNetworkState,\n      oraoTreasury,\n      oraoRandom,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = opponent;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildCancelMatchTx(\n  connection: Connection,\n  creator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const ix = await program.methods\n    .cancelMatch()\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildTimeoutCancelTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n\n  // Derive randomness account from match PDA (VRF seed = match PDA key)\n  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n\n  const ix = await program.methods\n    .timeoutCancel()\n    .accountsStrict({\n      caller,\n      creator: matchCreator,\n      opponent,\n      coinflipMatch: matchPda,\n      randomnessAccount,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get treasury address\n  const config = await program.account.coinflipConfig.fetch(configPda);\n  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n\n  // Derive randomness account from match PDA (VRF seed = match PDA key)\n  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n\n  // Derive player profile PDAs for CPI\n  const PLATFORM_PROGRAM_ID = new PublicKey(\n    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n  );\n  const [creatorProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  const [opponentProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n\n  const ix = await program.methods\n    .claimPayout()\n    .accountsStrict({\n      caller,\n      coinflipMatch: matchPda,\n      config: configPda,\n      treasury,\n      creator: matchCreator,\n      opponent,\n      randomnessAccount,\n      creatorProfile,\n      opponentProfile,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n","numLines":467,"startLine":1,"totalLines":467}}}
