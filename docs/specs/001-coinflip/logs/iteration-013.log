{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U6DpWZjsRJxYTe4413XmQx","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey, type Transaction } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchMatchByCreator,\n    16→  fetchMatch,\n    17→  getMatchPda,\n    18→  buildCreateMatchTx,\n    19→  buildJoinMatchTx,\n    20→  buildCancelMatchTx,\n    21→  buildTimeoutCancelTx,\n    22→  buildClaimPayoutTx,\n    23→} from \"../utils/chain\";\n    24→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    25→\n    26→/** Parse Solana/wallet errors into user-friendly messages */\n    27→function parseTransactionError(err: unknown): string {\n    28→  const msg = err instanceof Error ? err.message : String(err);\n    29→\n    30→  // Wallet not connected\n    31→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    32→    return \"Wallet not connected. Please connect your wallet first.\";\n    33→  }\n    34→\n    35→  // User rejected\n    36→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    37→    return \"Transaction cancelled by user.\";\n    38→  }\n    39→\n    40→  // Insufficient funds (Solana runtime error)\n    41→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    42→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    43→  }\n    44→\n    45→  // Account already in use (match already exists)\n    46→  if (msg.includes(\"already in use\")) {\n    47→    return \"You already have an active match. Cancel it before creating a new one.\";\n    48→  }\n    49→\n    50→  // Network / RPC errors\n    51→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    52→    return \"Network error. Please check your connection and try again.\";\n    53→  }\n    54→\n    55→  // Anchor program errors\n    56→  if (msg.includes(\"InvalidPhase\")) {\n    57→    return \"This match is no longer available.\";\n    58→  }\n    59→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    60→    return \"You cannot join your own match.\";\n    61→  }\n    62→\n    63→  // Simulation / preflight failures\n    64→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    65→    return \"Transaction simulation failed. The match may no longer be available.\";\n    66→  }\n    67→\n    68→  // Blockhash expiry\n    69→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    70→    return \"Transaction expired. Please try again.\";\n    71→  }\n    72→\n    73→  // Generic fallback — log full error for debugging\n    74→  console.error(\"[coinflip] unhandled transaction error:\", err);\n    75→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    76→}\n    77→\n    78→interface CoinflipContextValue {\n    79→  // State\n    80→  activeMatch: UIMatch | null;\n    81→  openMatches: UIMatch[];\n    82→  userHistory: UIMatch[];\n    83→  selectedTier: Tier | null;\n    84→  selectedSide: CoinSide | null;\n    85→\n    86→  // Loading states\n    87→  loading: boolean;\n    88→  creating: boolean;\n    89→  joining: boolean;\n    90→  claiming: boolean;\n    91→  joiningMatchId: string | null;\n    92→\n    93→  // Error state\n    94→  error: string | null;\n    95→  clearError: () => void;\n    96→\n    97→  // Actions\n    98→  setSelectedTier: (tier: Tier | null) => void;\n    99→  setSelectedSide: (side: CoinSide | null) => void;\n   100→  createMatch: () => Promise<void>;\n   101→  joinMatch: (matchId: string) => Promise<void>;\n   102→  cancelMatch: () => Promise<void>;\n   103→  timeoutCancel: () => Promise<void>;\n   104→  claimPayout: () => Promise<void>;\n   105→  clearActiveMatch: () => void;\n   106→  refreshMatches: () => void;\n   107→}\n   108→\n   109→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n   110→\n   111→export function CoinflipProvider({ children }: { children: ReactNode }) {\n   112→  const { connected, publicKey, sendTransaction } = useWallet();\n   113→  const { connection } = useConnection();\n   114→  const { refresh: refreshBalance } = useBalance();\n   115→\n   116→  // Selection state\n   117→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   118→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   119→\n   120→  // Match state\n   121→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   122→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   123→  const [userHistory] = useState<UIMatch[]>([]);\n   124→\n   125→  // Loading states\n   126→  const [loading, setLoading] = useState(true);\n   127→  const [creating, setCreating] = useState(false);\n   128→  const [joining, setJoining] = useState(false);\n   129→  const [claiming, setClaiming] = useState(false);\n   130→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   131→\n   132→  // Error state\n   133→  const [error, setError] = useState<string | null>(null);\n   134→  const clearError = useCallback(() => setError(null), []);\n   135→\n   136→  // Timer ref for flip animation delay (ready→flipping→complete)\n   137→  const flipTimerRef = useRef<number | null>(null);\n   138→\n   139→  // Ref to prevent polling races from restoring a dismissed match.\n   140→  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n   141→  // from the previous poll interval may resolve and call setActiveMatch,\n   142→  // putting them back on the match view. This ref blocks that.\n   143→  const dismissedMatchRef = useRef<string | null>(null);\n   144→\n   145→  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n   146→  const sendAndConfirm = useCallback(\n   147→    async (transaction: Transaction): Promise<string> => {\n   148→      const { blockhash, lastValidBlockHeight } =\n   149→        await connection.getLatestBlockhash(\"confirmed\");\n   150→      const signature = await sendTransaction(transaction);\n   151→      await connection.confirmTransaction(\n   152→        { signature, blockhash, lastValidBlockHeight },\n   153→        \"confirmed\",\n   154→      );\n   155→      await refreshBalance();\n   156→      return signature;\n   157→    },\n   158→    [connection, sendTransaction, refreshBalance],\n   159→  );\n   160→\n   161→  // Fetch open matches from on-chain\n   162→  const refreshMatches = useCallback(() => {\n   163→    fetchAllOpenMatches(connection)\n   164→      .then((matches) => {\n   165→        setOpenMatches(matches);\n   166→        setLoading(false);\n   167→      })\n   168→      .catch(() => {\n   169→        setLoading(false);\n   170→      });\n   171→  }, [connection]);\n   172→\n   173→  // Initial load\n   174→  useEffect(() => {\n   175→    setLoading(true);\n   176→    refreshMatches();\n   177→  }, [refreshMatches]);\n   178→\n   179→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   180→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   181→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   182→\n   183→  useEffect(() => {\n   184→    const interval = setInterval(() => {\n   185→      refreshMatches();\n   186→\n   187→      // If there's an active match, refresh it too (skip during flip animation)\n   188→      if (activeMatch && activeMatch.phase !== \"flipping\") {\n   189→        const matchPda = new PublicKey(activeMatch.id);\n   190→        fetchMatch(connection, matchPda)\n   191→          .then((updated) => {\n   192→            // If user dismissed this match while fetch was in flight, ignore\n   193→            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n   194→\n   195→            if (updated) {\n   196→              // Intercept ready→complete: insert 3s flip animation first\n   197→              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n   198→                setActiveMatch({ ...updated, phase: \"flipping\" });\n   199→                flipTimerRef.current = window.setTimeout(() => {\n   200→                  flipTimerRef.current = null;\n   201→                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n   202→                  setActiveMatch((current) =>\n   203→                    current?.phase === \"flipping\" ? updated : current\n   204→                  );\n   205→                }, 3000);\n   206→              } else {\n   207→                setActiveMatch(updated);\n   208→              }\n   209→            } else {\n   210→              // Match account closed (claimed or cancelled)\n   211→              setActiveMatch(null);\n   212→            }\n   213→          })\n   214→          .catch(() => {\n   215→            // Ignore polling errors\n   216→          });\n   217→      }\n   218→    }, pollInterval);\n   219→    return () => clearInterval(interval);\n   220→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   221→\n   222→  // Cleanup flip timer on unmount\n   223→  useEffect(() => {\n   224→    return () => {\n   225→      if (flipTimerRef.current !== null) {\n   226→        clearTimeout(flipTimerRef.current);\n   227→      }\n   228→    };\n   229→  }, []);\n   230→\n   231→  const createMatch = useCallback(async () => {\n   232→    if (!connected || !publicKey) {\n   233→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   234→      return;\n   235→    }\n   236→    if (!selectedTier || !selectedSide) {\n   237→      setError(\"Select tier and side first.\");\n   238→      return;\n   239→    }\n   240→\n   241→    setCreating(true);\n   242→    setError(null);\n   243→    try {\n   244→      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n   245→      const [matchPda] = getMatchPda(publicKey);\n   246→      const existing = await fetchMatch(connection, matchPda);\n   247→      if (existing) {\n   248→        if (existing.phase === \"complete\") {\n   249→          // Match is settled — show it so user can settle (winner claims, loser closes)\n   250→          setActiveMatch(existing);\n   251→          dismissedMatchRef.current = null;\n   252→          setError(\"Settle your previous match first.\");\n   253→        } else {\n   254→          // Match still in progress\n   255→          setActiveMatch(existing);\n   256→          dismissedMatchRef.current = null;\n   257→          setError(\"You already have an active match.\");\n   258→        }\n   259→        return;\n   260→      }\n   261→\n   262→      const { transaction } = await buildCreateMatchTx(\n   263→        connection,\n   264→        publicKey,\n   265→        selectedTier,\n   266→        selectedSide\n   267→      );\n   268→\n   269→      await sendAndConfirm(transaction);\n   270→\n   271→      // Clear dismissed ref — this is a new intentional match\n   272→      dismissedMatchRef.current = null;\n   273→\n   274→      // Fetch the created match from on-chain\n   275→      const match = await fetchMatch(connection, matchPda);\n   276→      if (match) {\n   277→        setActiveMatch(match);\n   278→      }\n   279→\n   280→      setSelectedSide(null);\n   281→      refreshMatches();\n   282→    } catch (err) {\n   283→      setError(parseTransactionError(err));\n   284→    } finally {\n   285→      setCreating(false);\n   286→    }\n   287→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n   288→\n   289→  const joinMatch = useCallback(\n   290→    async (matchId: string) => {\n   291→      if (!connected || !publicKey) {\n   292→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   293→        return;\n   294→      }\n   295→\n   296→      setJoining(true);\n   297→      setJoiningMatchId(matchId);\n   298→      setError(null);\n   299→      try {\n   300→        // matchId is the match PDA base58 — fetch to get the creator\n   301→        const matchPda = new PublicKey(matchId);\n   302→        const existingMatch = await fetchMatch(connection, matchPda);\n   303→        if (!existingMatch) {\n   304→          setError(\"Match not found. It may have been cancelled.\");\n   305→          return;\n   306→        }\n   307→\n   308→        const matchCreator = new PublicKey(existingMatch.player1);\n   309→        const transaction = await buildJoinMatchTx(\n   310→          connection,\n   311→          publicKey,\n   312→          matchCreator\n   313→        );\n   314→\n   315→        await sendAndConfirm(transaction);\n   316→\n   317→        // Clear dismissed ref — this is a new intentional match\n   318→        dismissedMatchRef.current = null;\n   319→\n   320→        // Fetch updated match\n   321→        const updated = await fetchMatch(connection, matchPda);\n   322→        if (updated) {\n   323→          setActiveMatch(updated);\n   324→        }\n   325→\n   326→        refreshMatches();\n   327→      } catch (err) {\n   328→        setError(parseTransactionError(err));\n   329→      } finally {\n   330→        setJoining(false);\n   331→        setJoiningMatchId(null);\n   332→      }\n   333→    },\n   334→    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n   335→  );\n   336→\n   337→  const cancelMatch = useCallback(async () => {\n   338→    if (!connected || !publicKey || !activeMatch) {\n   339→      setError(\"No active match to cancel.\");\n   340→      return;\n   341→    }\n   342→\n   343→    setError(null);\n   344→    try {\n   345→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   346→      await sendAndConfirm(transaction);\n   347→      setActiveMatch(null);\n   348→      refreshMatches();\n   349→    } catch (err) {\n   350→      setError(parseTransactionError(err));\n   351→    }\n   352→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   353→\n   354→  const timeoutCancel = useCallback(async () => {\n   355→    if (!connected || !publicKey || !activeMatch) {\n   356→      setError(\"No active match to cancel.\");\n   357→      return;\n   358→    }\n   359→    if (!activeMatch.player2) {\n   360→      setError(\"Match has no opponent.\");\n   361→      return;\n   362→    }\n   363→\n   364→    setError(null);\n   365→    try {\n   366→      const matchCreator = new PublicKey(activeMatch.player1);\n   367→      const opponent = new PublicKey(activeMatch.player2);\n   368→\n   369→      const transaction = await buildTimeoutCancelTx(\n   370→        connection,\n   371→        publicKey,\n   372→        matchCreator,\n   373→        opponent\n   374→      );\n   375→      await sendAndConfirm(transaction);\n   376→      setActiveMatch(null);\n   377→      refreshMatches();\n   378→    } catch (err) {\n   379→      setError(parseTransactionError(err));\n   380→    }\n   381→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   382→\n   383→  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   384→   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n   385→  const claimPayout = useCallback(async () => {\n   386→    if (!connected || !publicKey || !activeMatch) {\n   387→      setError(\"No active match to claim.\");\n   388→      return;\n   389→    }\n   390→    if (!activeMatch.player2) {\n   391→      setError(\"Match has no opponent yet.\");\n   392→      return;\n   393→    }\n   394→\n   395→    setClaiming(true);\n   396→    setError(null);\n   397→    try {\n   398→      const matchCreator = new PublicKey(activeMatch.player1);\n   399→      const opponent = new PublicKey(activeMatch.player2);\n   400→\n   401→      const transaction = await buildClaimPayoutTx(\n   402→        connection,\n   403→        publicKey,   // caller (either player — winner derived on-chain from VRF)\n   404→        matchCreator,\n   405→        opponent\n   406→      );\n   407→\n   408→      await sendAndConfirm(transaction);\n   409→\n   410→      // Match PDA is now closed — clear local state\n   411→      dismissedMatchRef.current = activeMatch.id;\n   412→      setActiveMatch(null);\n   413→      refreshMatches();\n   414→    } catch (err) {\n   415→      setError(parseTransactionError(err));\n   416→    } finally {\n   417→      setClaiming(false);\n   418→    }\n   419→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   420→\n   421→  // Track if user explicitly cleared the match\n   422→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   423→\n   424→  const clearActiveMatch = useCallback(() => {\n   425→    // Record the dismissed match ID so in-flight polls don't restore it\n   426→    dismissedMatchRef.current = activeMatch?.id ?? null;\n   427→    setActiveMatch(null);\n   428→    setUserClearedMatch(true);\n   429→    setError(null);\n   430→    refreshMatches();\n   431→  }, [activeMatch, refreshMatches]);\n   432→\n   433→  // Check for existing active match on wallet connect\n   434→  useEffect(() => {\n   435→    if (publicKey && !activeMatch && !userClearedMatch) {\n   436→      fetchMatchByCreator(connection, publicKey)\n   437→        .then((match) => {\n   438→          if (match) {\n   439→            // Don't restore a match the user explicitly dismissed\n   440→            if (dismissedMatchRef.current === match.id) return;\n   441→            setActiveMatch(match);\n   442→          }\n   443→        })\n   444→        .catch(() => {\n   445→          // No active match found\n   446→        });\n   447→    }\n   448→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   449→\n   450→  // Reset userClearedMatch when creating or joining a new match\n   451→  useEffect(() => {\n   452→    if (activeMatch) {\n   453→      setUserClearedMatch(false);\n   454→    }\n   455→  }, [activeMatch]);\n   456→\n   457→  const value: CoinflipContextValue = {\n   458→    activeMatch,\n   459→    openMatches,\n   460→    userHistory,\n   461→    selectedTier,\n   462→    selectedSide,\n   463→    loading,\n   464→    creating,\n   465→    joining,\n   466→    claiming,\n   467→    joiningMatchId,\n   468→    error,\n   469→    clearError,\n   470→    setSelectedTier,\n   471→    setSelectedSide,\n   472→    createMatch,\n   473→    joinMatch,\n   474→    cancelMatch,\n   475→    timeoutCancel,\n   476→    claimPayout,\n   477→    clearActiveMatch,\n   478→    refreshMatches,\n   479→  };\n   480→\n   481→  return (\n   482→    <CoinflipContext.Provider value={value}>\n   483→      {children}\n   484→    </CoinflipContext.Provider>\n   485→  );\n   486→}\n   487→\n   488→export function useCoinflip(): CoinflipContextValue {\n   489→  const context = useContext(CoinflipContext);\n   490→  if (!context) {\n   491→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   492→  }\n   493→  return context;\n   494→}\n   495→"}]},"parent_tool_use_id":null,"session_id":"73651d8d-ca1a-4f9e-b9b7-f2b958b23ec2","uuid":"5781b863-b29b-4ce1-8cd8-e17c78d52689","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { PublicKey, type Transaction } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  getMatchPda,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildTimeoutCancelTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse Solana/wallet errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  // Wallet not connected\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n\n  // User rejected\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n\n  // Insufficient funds (Solana runtime error)\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n\n  // Account already in use (match already exists)\n  if (msg.includes(\"already in use\")) {\n    return \"You already have an active match. Cancel it before creating a new one.\";\n  }\n\n  // Network / RPC errors\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n\n  // Anchor program errors\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This match is no longer available.\";\n  }\n  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    return \"You cannot join your own match.\";\n  }\n\n  // Simulation / preflight failures\n  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    return \"Transaction simulation failed. The match may no longer be available.\";\n  }\n\n  // Blockhash expiry\n  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    return \"Transaction expired. Please try again.\";\n  }\n\n  // Generic fallback — log full error for debugging\n  console.error(\"[coinflip] unhandled transaction error:\", err);\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  timeoutCancel: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Timer ref for flip animation delay (ready→flipping→complete)\n  const flipTimerRef = useRef<number | null>(null);\n\n  // Ref to prevent polling races from restoring a dismissed match.\n  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n  // from the previous poll interval may resolve and call setActiveMatch,\n  // putting them back on the match view. This ref blocks that.\n  const dismissedMatchRef = useRef<string | null>(null);\n\n  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n      const signature = await sendTransaction(transaction);\n      await connection.confirmTransaction(\n        { signature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      await refreshBalance();\n      return signature;\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too (skip during flip animation)\n      if (activeMatch && activeMatch.phase !== \"flipping\") {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            // If user dismissed this match while fetch was in flight, ignore\n            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n\n            if (updated) {\n              // Intercept ready→complete: insert 3s flip animation first\n              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n                setActiveMatch({ ...updated, phase: \"flipping\" });\n                flipTimerRef.current = window.setTimeout(() => {\n                  flipTimerRef.current = null;\n                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n                  setActiveMatch((current) =>\n                    current?.phase === \"flipping\" ? updated : current\n                  );\n                }, 3000);\n              } else {\n                setActiveMatch(updated);\n              }\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection, pollInterval]);\n\n  // Cleanup flip timer on unmount\n  useEffect(() => {\n    return () => {\n      if (flipTimerRef.current !== null) {\n        clearTimeout(flipTimerRef.current);\n      }\n    };\n  }, []);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n      const [matchPda] = getMatchPda(publicKey);\n      const existing = await fetchMatch(connection, matchPda);\n      if (existing) {\n        if (existing.phase === \"complete\") {\n          // Match is settled — show it so user can settle (winner claims, loser closes)\n          setActiveMatch(existing);\n          dismissedMatchRef.current = null;\n          setError(\"Settle your previous match first.\");\n        } else {\n          // Match still in progress\n          setActiveMatch(existing);\n          dismissedMatchRef.current = null;\n          setError(\"You already have an active match.\");\n        }\n        return;\n      }\n\n      const { transaction } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendAndConfirm(transaction);\n\n      // Clear dismissed ref — this is a new intentional match\n      dismissedMatchRef.current = null;\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendAndConfirm(transaction);\n\n        // Clear dismissed ref — this is a new intentional match\n        dismissedMatchRef.current = null;\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendAndConfirm(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  const timeoutCancel = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n    if (!activeMatch.player2) {\n      setError(\"Match has no opponent.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = new PublicKey(activeMatch.player2);\n\n      const transaction = await buildTimeoutCancelTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n      await sendAndConfirm(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n    if (!activeMatch.player2) {\n      setError(\"Match has no opponent yet.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = new PublicKey(activeMatch.player2);\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,   // caller (either player — winner derived on-chain from VRF)\n        matchCreator,\n        opponent\n      );\n\n      await sendAndConfirm(transaction);\n\n      // Match PDA is now closed — clear local state\n      dismissedMatchRef.current = activeMatch.id;\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    // Record the dismissed match ID so in-flight polls don't restore it\n    dismissedMatchRef.current = activeMatch?.id ?? null;\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [activeMatch, refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            // Don't restore a match the user explicitly dismissed\n            if (dismissedMatchRef.current === match.id) return;\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    timeoutCancel,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":495,"startLine":1,"totalLines":495}}}
