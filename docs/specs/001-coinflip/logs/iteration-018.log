{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012zqnVBnTDx5MDz62a4uj6c","type":"tool_result","content":"     1→import { useState, useEffect } from \"react\";\n     2→import type { UIMatch } from \"../types\";\n     3→import type { VerificationResult } from \"../utils/verification\";\n     4→import { CoinAnimation } from \"./CoinAnimation\";\n     5→import { getOppositeSide } from \"../utils/helpers\";\n     6→import { PlayerAvatarCompact } from \"../../player-profile\";\n     7→\n     8→const LOCK_TIMEOUT_MS = 120_000; // 2 minutes\n     9→\n    10→interface ActiveMatchViewProps {\n    11→  match: UIMatch;\n    12→  currentUserAddress: string;\n    13→  onCancel?: () => void;\n    14→  onTimeoutCancel?: () => void;\n    15→  onClaim?: () => void;\n    16→  onClearMatch?: () => void;\n    17→  cancelling?: boolean;\n    18→  claiming?: boolean;\n    19→  // Verification\n    20→  claimTxSignature?: string | null;\n    21→  verificationResult?: VerificationResult | null;\n    22→  verifying?: boolean;\n    23→  onVerify?: () => void;\n    24→}\n    25→\n    26→export function ActiveMatchView({\n    27→  match,\n    28→  currentUserAddress,\n    29→  onCancel,\n    30→  onTimeoutCancel,\n    31→  onClaim,\n    32→  onClearMatch,\n    33→  cancelling,\n    34→  claiming,\n    35→  claimTxSignature,\n    36→  verificationResult,\n    37→  verifying,\n    38→  onVerify,\n    39→}: ActiveMatchViewProps) {\n    40→  const isPlayer1 = match.player1 === currentUserAddress;\n    41→  const isWinner = match.winner === currentUserAddress;\n    42→\n    43→  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    44→  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n    45→  const opponent = isPlayer1 ? match.player2 : match.player1;\n    46→\n    47→  // Track whether lock timeout has elapsed (for timeout cancel button)\n    48→  const [lockTimedOut, setLockTimedOut] = useState(false);\n    49→  const [cancellingTimeout, setCancellingTimeout] = useState(false);\n    50→\n    51→  useEffect(() => {\n    52→    if (match.phase !== \"ready\" || !match.lockedAt) {\n    53→      // For legacy matches with no lockedAt, show cancel immediately\n    54→      setLockTimedOut(match.phase === \"ready\");\n    55→      return;\n    56→    }\n    57→\n    58→    const remaining = match.lockedAt + LOCK_TIMEOUT_MS - Date.now();\n    59→    if (remaining <= 0) {\n    60→      setLockTimedOut(true);\n    61→      return;\n    62→    }\n    63→\n    64→    setLockTimedOut(false);\n    65→    const timer = setTimeout(() => setLockTimedOut(true), remaining);\n    66→    return () => clearTimeout(timer);\n    67→  }, [match.phase, match.lockedAt]);\n    68→\n    69→  // Countdown timer\n    70→  const [countdown, setCountdown] = useState(3);\n    71→\n    72→  useEffect(() => {\n    73→    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n    74→      // Always start at 3\n    75→      setCountdown(3);\n    76→\n    77→      const updateCountdown = () => {\n    78→        const elapsed = Date.now() - match.countdownStartedAt!;\n    79→        // Each number shows for exactly 1 second:\n    80→        // 0-999ms: show 3\n    81→        // 1000-1999ms: show 2\n    82→        // 2000-2999ms: show 1\n    83→        if (elapsed < 1000) {\n    84→          setCountdown(3);\n    85→        } else if (elapsed < 2000) {\n    86→          setCountdown(2);\n    87→        } else {\n    88→          setCountdown(1);\n    89→        }\n    90→      };\n    91→\n    92→      const interval = setInterval(updateCountdown, 50);\n    93→      return () => {\n    94→        clearInterval(interval);\n    95→        // Reset for next countdown\n    96→        setCountdown(3);\n    97→      };\n    98→    }\n    99→  }, [match.phase, match.countdownStartedAt]);\n   100→\n   101→  return (\n   102→    <div className=\"coinflip-active-match\">\n   103→      {/* Waiting for opponent */}\n   104→      {match.phase === \"created\" && (\n   105→        <div className=\"coinflip-active-match__waiting\">\n   106→          <h3 className=\"coinflip-active-match__title\">Waiting for Opponent</h3>\n   107→          <div className=\"coinflip-active-match__info\">\n   108→            <p>\n   109→              Your side: <strong className={`side-${match.player1Side}`}>\n   110→                {match.player1Side.toUpperCase()}\n   111→              </strong>\n   112→            </p>\n   113→            <p>Entry: <strong>{\"$\"}{match.entryAmount}</strong></p>\n   114→          </div>\n   115→          <div className=\"coinflip-waiting__spinner\" />\n   116→          <p className=\"coinflip-active-match__hint\">\n   117→            Someone will join soon...\n   118→          </p>\n   119→          {onCancel && (\n   120→            <button\n   121→              type=\"button\"\n   122→              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   123→              onClick={onCancel}\n   124→              disabled={cancelling}\n   125→            >\n   126→              {cancelling ? \"Cancelling...\" : \"Cancel Match\"}\n   127→            </button>\n   128→          )}\n   129→        </div>\n   130→      )}\n   131→\n   132→      {/* Ready / Countdown */}\n   133→      {(match.phase === \"ready\" || match.phase === \"countdown\") && (\n   134→        <div className=\"coinflip-active-match__playing\">\n   135→          <h3 className=\"coinflip-active-match__title\">\n   136→            {match.phase === \"ready\" && \"Game Ready!\"}\n   137→            {match.phase === \"countdown\" && (\n   138→              <span className=\"coinflip-countdown-inline\">\n   139→                Flipping in... <span className=\"coinflip-countdown-inline__number\">{countdown}</span>\n   140→              </span>\n   141→            )}\n   142→          </h3>\n   143→\n   144→          <div className=\"coinflip-active-match__players\">\n   145→            <div className=\"coinflip-player coinflip-player--you\">\n   146→              <span className=\"coinflip-player__label\">\n   147→                <PlayerAvatarCompact address={currentUserAddress} />\n   148→              </span>\n   149→              <span className={`coinflip-player__side side-${yourSide}`}>\n   150→                {yourSide?.toUpperCase()}\n   151→              </span>\n   152→            </div>\n   153→\n   154→            <span className=\"coinflip-active-match__vs\">VS</span>\n   155→\n   156→            <div className=\"coinflip-player coinflip-player--opponent\">\n   157→              <span className=\"coinflip-player__label\">\n   158→                {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n   159→              </span>\n   160→              <span className={`coinflip-player__side side-${opponentSide}`}>\n   161→                {opponentSide?.toUpperCase()}\n   162→              </span>\n   163→            </div>\n   164→          </div>\n   165→\n   166→          {/* Static coin for ready/countdown phases */}\n   167→          <CoinAnimation\n   168→            isFlipping={false}\n   169→            result={null}\n   170→            initialSide={yourSide ?? \"heads\"}\n   171→            size=\"lg\"\n   172→          />\n   173→\n   174→          {/* Timeout cancel — shown when VRF hasn't resolved within 2 min */}\n   175→          {match.phase === \"ready\" && lockTimedOut && onTimeoutCancel && (\n   176→            <div className=\"coinflip-active-match__timeout\">\n   177→              <p className=\"coinflip-active-match__hint\">\n   178→                Resolution timed out.\n   179→              </p>\n   180→              <button\n   181→                type=\"button\"\n   182→                className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   183→                onClick={async () => {\n   184→                  setCancellingTimeout(true);\n   185→                  try { await onTimeoutCancel(); } finally { setCancellingTimeout(false); }\n   186→                }}\n   187→                disabled={cancellingTimeout}\n   188→              >\n   189→                {cancellingTimeout ? \"Cancelling...\" : \"Cancel & Refund\"}\n   190→              </button>\n   191→            </div>\n   192→          )}\n   193→\n   194→        </div>\n   195→      )}\n   196→\n   197→      {/* Flipping / Complete - same container so coin persists through transition */}\n   198→      {(match.phase === \"flipping\" || match.phase === \"complete\") && (\n   199→        <div className=\"coinflip-active-match__playing\">\n   200→          <h3 className={`coinflip-active-match__title ${\n   201→            match.phase === \"complete\" ? (isWinner ? \"coinflip-active-match__title--won\" : \"coinflip-active-match__title--lost\") : \"\"\n   202→          }`}>\n   203→            {match.phase === \"flipping\" && \"Flipping!\"}\n   204→            {match.phase === \"complete\" && isWinner && \"You Won!\"}\n   205→            {match.phase === \"complete\" && !isWinner && (\n   206→              <span className=\"coinflip-lose-title\">\n   207→                You Lost{\" \"}\n   208→                <span className=\"coinflip-lose-title__heart\">💔</span>\n   209→                <span className=\"coinflip-lose-title__shards\">\n   210→                  {[...Array(5)].map((_, i) => (\n   211→                    <span key={i} className=\"coinflip-lose-title__shard\" style={{ '--shard-index': i } as React.CSSProperties}>◆</span>\n   212→                  ))}\n   213→                </span>\n   214→              </span>\n   215→            )}\n   216→          </h3>\n   217→\n   218→          {/* Players info during flipping */}\n   219→          {match.phase === \"flipping\" && (\n   220→            <div className=\"coinflip-active-match__players\">\n   221→              <div className=\"coinflip-player coinflip-player--you\">\n   222→                <span className=\"coinflip-player__label\">\n   223→                  <PlayerAvatarCompact address={currentUserAddress} />\n   224→                </span>\n   225→                <span className={`coinflip-player__side side-${yourSide}`}>\n   226→                  {yourSide?.toUpperCase()}\n   227→                </span>\n   228→              </div>\n   229→\n   230→              <span className=\"coinflip-active-match__vs\">VS</span>\n   231→\n   232→              <div className=\"coinflip-player coinflip-player--opponent\">\n   233→                <span className=\"coinflip-player__label\">\n   234→                  {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n   235→                </span>\n   236→                <span className={`coinflip-player__side side-${opponentSide}`}>\n   237→                  {opponentSide?.toUpperCase()}\n   238→                </span>\n   239→              </div>\n   240→            </div>\n   241→          )}\n   242→\n   243→          {/* Single coin that persists through flipping → complete */}\n   244→          <CoinAnimation\n   245→            isFlipping={match.phase === \"flipping\"}\n   246→            result={match.result}\n   247→            initialSide={yourSide ?? \"heads\"}\n   248→            size=\"lg\"\n   249→          />\n   250→\n   251→          {/* Result info during complete */}\n   252→          {match.phase === \"complete\" && (\n   253→            <>\n   254→              {/* Win Animation - Arcade star burst */}\n   255→              {isWinner && (\n   256→                <div className=\"coinflip-win-animation\">\n   257→                  <div className=\"coinflip-win-animation__stars\">\n   258→                    {[...Array(8)].map((_, i) => (\n   259→                      <span key={i} className=\"coinflip-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n   260→                    ))}\n   261→                  </div>\n   262→                  <div className=\"coinflip-win-animation__coins\">\n   263→                    {[...Array(6)].map((_, i) => (\n   264→                      <span key={i} className=\"coinflip-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n   265→                    ))}\n   266→                  </div>\n   267→                </div>\n   268→              )}\n   269→\n   270→              <div\n   271→                className={`coinflip-result ${\n   272→                  isWinner ? \"coinflip-result--won\" : \"coinflip-result--lost\"\n   273→                }`}\n   274→              >\n   275→                <p className=\"coinflip-result__outcome\">\n   276→                  Result: <strong\n   277→                    style={{\n   278→                      color: match.result === \"heads\" ? \"#45b058\" : \"#e09030\",\n   279→                      textShadow: `0 0 6px ${match.result === \"heads\" ? \"#45b058\" : \"#e09030\"}`\n   280→                    }}\n   281→                  >{match.result?.toUpperCase()}</strong>\n   282→                </p>\n   283→                {isWinner && (\n   284→                  <p className=\"coinflip-result__payout\">\n   285→                    Payout: <strong>{\"$\"}{match.payoutAmount.toFixed(4)}</strong>\n   286→                  </p>\n   287→                )}\n   288→              </div>\n   289→\n   290→              {/* Action buttons */}\n   291→              <div className=\"coinflip-active-match__actions\">\n   292→                {!match.claimed && onClaim && (\n   293→                  <button\n   294→                    type=\"button\"\n   295→                    className=\"coinflip-action-btn\"\n   296→                    onClick={onClaim}\n   297→                    disabled={claiming}\n   298→                  >\n   299→                    {claiming\n   300→                      ? \"Settling...\"\n   301→                      : isWinner\n   302→                        ? \"Claim Payout\"\n   303→                        : \"Settle & Return to Lobby\"}\n   304→                  </button>\n   305→                )}\n   306→                {match.claimed && (\n   307→                  <div className=\"coinflip-active-match__post-claim\">\n   308→                    {onVerify && claimTxSignature && (\n   309→                      <button\n   310→                        type=\"button\"\n   311→                        className=\"coinflip-action-btn\"\n   312→                        onClick={onVerify}\n   313→                        disabled={verifying || !!verificationResult}\n   314→                      >\n   315→                        {verifying ? \"Verifying...\" : verificationResult ? \"Verified\" : \"Verify Fairness\"}\n   316→                      </button>\n   317→                    )}\n   318→                    {onClearMatch && (\n   319→                      <button\n   320→                        type=\"button\"\n   321→                        className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   322→                        onClick={onClearMatch}\n   323→                      >\n   324→                        Back to Lobby\n   325→                      </button>\n   326→                    )}\n   327→                  </div>\n   328→                )}\n   329→              </div>\n   330→\n   331→              {/* Verification panel — shown after verifyMatch completes */}\n   332→              {verificationResult && (\n   333→                <div className=\"coinflip-verification\">\n   334→                  <h4 className=\"coinflip-verification__title\">\n   335→                    Fairness Verification\n   336→                  </h4>\n   337→                  <div className={`coinflip-verification__badge ${verificationResult.verified ? \"coinflip-verification__badge--verified\" : \"coinflip-verification__badge--failed\"}`}>\n   338→                    {verificationResult.verified ? \"Verified\" : \"Failed\"}\n   339→                  </div>\n   340→                  <div className=\"coinflip-verification__rows\">\n   341→                    <div className=\"coinflip-verification__row\">\n   342→                      <span>Claim TX</span>\n   343→                      <span className=\"coinflip-verification__hash\" title={claimTxSignature ?? \"\"}>\n   344→                        {claimTxSignature ? `${claimTxSignature.slice(0, 8)}...${claimTxSignature.slice(-8)}` : \"—\"}\n   345→                      </span>\n   346→                    </div>\n   347→                    <div className=\"coinflip-verification__row\">\n   348→                      <span>Randomness</span>\n   349→                      <span className=\"coinflip-verification__hash\" title={verificationResult.randomnessHex}>\n   350→                        {verificationResult.randomnessHex.slice(0, 16)}...\n   351→                      </span>\n   352→                    </div>\n   353→                    <div className=\"coinflip-verification__row\">\n   354→                      <span>Derived Result</span>\n   355→                      <span className={`side-${verificationResult.derivedResult}`}>\n   356→                        {verificationResult.derivedResult.toUpperCase()}\n   357→                      </span>\n   358→                    </div>\n   359→                    <div className=\"coinflip-verification__row\">\n   360→                      <span>Winner</span>\n   361→                      <span className=\"coinflip-verification__hash\" title={verificationResult.winner}>\n   362→                        {verificationResult.winner.slice(0, 4)}...{verificationResult.winner.slice(-4)}\n   363→                      </span>\n   364→                    </div>\n   365→                    <div className=\"coinflip-verification__row\">\n   366→                      <span>VRF Fulfilled</span>\n   367→                      <span className={verificationResult.vrfFulfilled ? \"coinflip-verification__check\" : \"coinflip-verification__cross\"}>\n   368→                        {verificationResult.vrfFulfilled ? \"Yes\" : \"No\"}\n   369→                      </span>\n   370→                    </div>\n   371→                  </div>\n   372→                  <a href=\"/fairness\" className=\"coinflip-verification__link\">\n   373→                    Full Verification Page\n   374→                  </a>\n   375→                </div>\n   376→              )}\n   377→\n   378→            </>\n   379→          )}\n   380→        </div>\n   381→      )}\n   382→    </div>\n   383→  );\n   384→}\n   385→"}]},"parent_tool_use_id":null,"session_id":"13b31efc-e570-4147-9b51-463305fcfba1","uuid":"06770714-1e23-4a29-9f5b-0e1e1246e0b0","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/components/ActiveMatchView.tsx","content":"import { useState, useEffect } from \"react\";\nimport type { UIMatch } from \"../types\";\nimport type { VerificationResult } from \"../utils/verification\";\nimport { CoinAnimation } from \"./CoinAnimation\";\nimport { getOppositeSide } from \"../utils/helpers\";\nimport { PlayerAvatarCompact } from \"../../player-profile\";\n\nconst LOCK_TIMEOUT_MS = 120_000; // 2 minutes\n\ninterface ActiveMatchViewProps {\n  match: UIMatch;\n  currentUserAddress: string;\n  onCancel?: () => void;\n  onTimeoutCancel?: () => void;\n  onClaim?: () => void;\n  onClearMatch?: () => void;\n  cancelling?: boolean;\n  claiming?: boolean;\n  // Verification\n  claimTxSignature?: string | null;\n  verificationResult?: VerificationResult | null;\n  verifying?: boolean;\n  onVerify?: () => void;\n}\n\nexport function ActiveMatchView({\n  match,\n  currentUserAddress,\n  onCancel,\n  onTimeoutCancel,\n  onClaim,\n  onClearMatch,\n  cancelling,\n  claiming,\n  claimTxSignature,\n  verificationResult,\n  verifying,\n  onVerify,\n}: ActiveMatchViewProps) {\n  const isPlayer1 = match.player1 === currentUserAddress;\n  const isWinner = match.winner === currentUserAddress;\n\n  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n  const opponent = isPlayer1 ? match.player2 : match.player1;\n\n  // Track whether lock timeout has elapsed (for timeout cancel button)\n  const [lockTimedOut, setLockTimedOut] = useState(false);\n  const [cancellingTimeout, setCancellingTimeout] = useState(false);\n\n  useEffect(() => {\n    if (match.phase !== \"ready\" || !match.lockedAt) {\n      // For legacy matches with no lockedAt, show cancel immediately\n      setLockTimedOut(match.phase === \"ready\");\n      return;\n    }\n\n    const remaining = match.lockedAt + LOCK_TIMEOUT_MS - Date.now();\n    if (remaining <= 0) {\n      setLockTimedOut(true);\n      return;\n    }\n\n    setLockTimedOut(false);\n    const timer = setTimeout(() => setLockTimedOut(true), remaining);\n    return () => clearTimeout(timer);\n  }, [match.phase, match.lockedAt]);\n\n  // Countdown timer\n  const [countdown, setCountdown] = useState(3);\n\n  useEffect(() => {\n    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n      // Always start at 3\n      setCountdown(3);\n\n      const updateCountdown = () => {\n        const elapsed = Date.now() - match.countdownStartedAt!;\n        // Each number shows for exactly 1 second:\n        // 0-999ms: show 3\n        // 1000-1999ms: show 2\n        // 2000-2999ms: show 1\n        if (elapsed < 1000) {\n          setCountdown(3);\n        } else if (elapsed < 2000) {\n          setCountdown(2);\n        } else {\n          setCountdown(1);\n        }\n      };\n\n      const interval = setInterval(updateCountdown, 50);\n      return () => {\n        clearInterval(interval);\n        // Reset for next countdown\n        setCountdown(3);\n      };\n    }\n  }, [match.phase, match.countdownStartedAt]);\n\n  return (\n    <div className=\"coinflip-active-match\">\n      {/* Waiting for opponent */}\n      {match.phase === \"created\" && (\n        <div className=\"coinflip-active-match__waiting\">\n          <h3 className=\"coinflip-active-match__title\">Waiting for Opponent</h3>\n          <div className=\"coinflip-active-match__info\">\n            <p>\n              Your side: <strong className={`side-${match.player1Side}`}>\n                {match.player1Side.toUpperCase()}\n              </strong>\n            </p>\n            <p>Entry: <strong>{\"$\"}{match.entryAmount}</strong></p>\n          </div>\n          <div className=\"coinflip-waiting__spinner\" />\n          <p className=\"coinflip-active-match__hint\">\n            Someone will join soon...\n          </p>\n          {onCancel && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n              onClick={onCancel}\n              disabled={cancelling}\n            >\n              {cancelling ? \"Cancelling...\" : \"Cancel Match\"}\n            </button>\n          )}\n        </div>\n      )}\n\n      {/* Ready / Countdown */}\n      {(match.phase === \"ready\" || match.phase === \"countdown\") && (\n        <div className=\"coinflip-active-match__playing\">\n          <h3 className=\"coinflip-active-match__title\">\n            {match.phase === \"ready\" && \"Game Ready!\"}\n            {match.phase === \"countdown\" && (\n              <span className=\"coinflip-countdown-inline\">\n                Flipping in... <span className=\"coinflip-countdown-inline__number\">{countdown}</span>\n              </span>\n            )}\n          </h3>\n\n          <div className=\"coinflip-active-match__players\">\n            <div className=\"coinflip-player coinflip-player--you\">\n              <span className=\"coinflip-player__label\">\n                <PlayerAvatarCompact address={currentUserAddress} />\n              </span>\n              <span className={`coinflip-player__side side-${yourSide}`}>\n                {yourSide?.toUpperCase()}\n              </span>\n            </div>\n\n            <span className=\"coinflip-active-match__vs\">VS</span>\n\n            <div className=\"coinflip-player coinflip-player--opponent\">\n              <span className=\"coinflip-player__label\">\n                {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n              </span>\n              <span className={`coinflip-player__side side-${opponentSide}`}>\n                {opponentSide?.toUpperCase()}\n              </span>\n            </div>\n          </div>\n\n          {/* Static coin for ready/countdown phases */}\n          <CoinAnimation\n            isFlipping={false}\n            result={null}\n            initialSide={yourSide ?? \"heads\"}\n            size=\"lg\"\n          />\n\n          {/* Timeout cancel — shown when VRF hasn't resolved within 2 min */}\n          {match.phase === \"ready\" && lockTimedOut && onTimeoutCancel && (\n            <div className=\"coinflip-active-match__timeout\">\n              <p className=\"coinflip-active-match__hint\">\n                Resolution timed out.\n              </p>\n              <button\n                type=\"button\"\n                className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n                onClick={async () => {\n                  setCancellingTimeout(true);\n                  try { await onTimeoutCancel(); } finally { setCancellingTimeout(false); }\n                }}\n                disabled={cancellingTimeout}\n              >\n                {cancellingTimeout ? \"Cancelling...\" : \"Cancel & Refund\"}\n              </button>\n            </div>\n          )}\n\n        </div>\n      )}\n\n      {/* Flipping / Complete - same container so coin persists through transition */}\n      {(match.phase === \"flipping\" || match.phase === \"complete\") && (\n        <div className=\"coinflip-active-match__playing\">\n          <h3 className={`coinflip-active-match__title ${\n            match.phase === \"complete\" ? (isWinner ? \"coinflip-active-match__title--won\" : \"coinflip-active-match__title--lost\") : \"\"\n          }`}>\n            {match.phase === \"flipping\" && \"Flipping!\"}\n            {match.phase === \"complete\" && isWinner && \"You Won!\"}\n            {match.phase === \"complete\" && !isWinner && (\n              <span className=\"coinflip-lose-title\">\n                You Lost{\" \"}\n                <span className=\"coinflip-lose-title__heart\">💔</span>\n                <span className=\"coinflip-lose-title__shards\">\n                  {[...Array(5)].map((_, i) => (\n                    <span key={i} className=\"coinflip-lose-title__shard\" style={{ '--shard-index': i } as React.CSSProperties}>◆</span>\n                  ))}\n                </span>\n              </span>\n            )}\n          </h3>\n\n          {/* Players info during flipping */}\n          {match.phase === \"flipping\" && (\n            <div className=\"coinflip-active-match__players\">\n              <div className=\"coinflip-player coinflip-player--you\">\n                <span className=\"coinflip-player__label\">\n                  <PlayerAvatarCompact address={currentUserAddress} />\n                </span>\n                <span className={`coinflip-player__side side-${yourSide}`}>\n                  {yourSide?.toUpperCase()}\n                </span>\n              </div>\n\n              <span className=\"coinflip-active-match__vs\">VS</span>\n\n              <div className=\"coinflip-player coinflip-player--opponent\">\n                <span className=\"coinflip-player__label\">\n                  {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n                </span>\n                <span className={`coinflip-player__side side-${opponentSide}`}>\n                  {opponentSide?.toUpperCase()}\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Single coin that persists through flipping → complete */}\n          <CoinAnimation\n            isFlipping={match.phase === \"flipping\"}\n            result={match.result}\n            initialSide={yourSide ?? \"heads\"}\n            size=\"lg\"\n          />\n\n          {/* Result info during complete */}\n          {match.phase === \"complete\" && (\n            <>\n              {/* Win Animation - Arcade star burst */}\n              {isWinner && (\n                <div className=\"coinflip-win-animation\">\n                  <div className=\"coinflip-win-animation__stars\">\n                    {[...Array(8)].map((_, i) => (\n                      <span key={i} className=\"coinflip-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n                    ))}\n                  </div>\n                  <div className=\"coinflip-win-animation__coins\">\n                    {[...Array(6)].map((_, i) => (\n                      <span key={i} className=\"coinflip-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n                    ))}\n                  </div>\n                </div>\n              )}\n\n              <div\n                className={`coinflip-result ${\n                  isWinner ? \"coinflip-result--won\" : \"coinflip-result--lost\"\n                }`}\n              >\n                <p className=\"coinflip-result__outcome\">\n                  Result: <strong\n                    style={{\n                      color: match.result === \"heads\" ? \"#45b058\" : \"#e09030\",\n                      textShadow: `0 0 6px ${match.result === \"heads\" ? \"#45b058\" : \"#e09030\"}`\n                    }}\n                  >{match.result?.toUpperCase()}</strong>\n                </p>\n                {isWinner && (\n                  <p className=\"coinflip-result__payout\">\n                    Payout: <strong>{\"$\"}{match.payoutAmount.toFixed(4)}</strong>\n                  </p>\n                )}\n              </div>\n\n              {/* Action buttons */}\n              <div className=\"coinflip-active-match__actions\">\n                {!match.claimed && onClaim && (\n                  <button\n                    type=\"button\"\n                    className=\"coinflip-action-btn\"\n                    onClick={onClaim}\n                    disabled={claiming}\n                  >\n                    {claiming\n                      ? \"Settling...\"\n                      : isWinner\n                        ? \"Claim Payout\"\n                        : \"Settle & Return to Lobby\"}\n                  </button>\n                )}\n                {match.claimed && (\n                  <div className=\"coinflip-active-match__post-claim\">\n                    {onVerify && claimTxSignature && (\n                      <button\n                        type=\"button\"\n                        className=\"coinflip-action-btn\"\n                        onClick={onVerify}\n                        disabled={verifying || !!verificationResult}\n                      >\n                        {verifying ? \"Verifying...\" : verificationResult ? \"Verified\" : \"Verify Fairness\"}\n                      </button>\n                    )}\n                    {onClearMatch && (\n                      <button\n                        type=\"button\"\n                        className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n                        onClick={onClearMatch}\n                      >\n                        Back to Lobby\n                      </button>\n                    )}\n                  </div>\n                )}\n              </div>\n\n              {/* Verification panel — shown after verifyMatch completes */}\n              {verificationResult && (\n                <div className=\"coinflip-verification\">\n                  <h4 className=\"coinflip-verification__title\">\n                    Fairness Verification\n                  </h4>\n                  <div className={`coinflip-verification__badge ${verificationResult.verified ? \"coinflip-verification__badge--verified\" : \"coinflip-verification__badge--failed\"}`}>\n                    {verificationResult.verified ? \"Verified\" : \"Failed\"}\n                  </div>\n                  <div className=\"coinflip-verification__rows\">\n                    <div className=\"coinflip-verification__row\">\n                      <span>Claim TX</span>\n                      <span className=\"coinflip-verification__hash\" title={claimTxSignature ?? \"\"}>\n                        {claimTxSignature ? `${claimTxSignature.slice(0, 8)}...${claimTxSignature.slice(-8)}` : \"—\"}\n                      </span>\n                    </div>\n                    <div className=\"coinflip-verification__row\">\n                      <span>Randomness</span>\n                      <span className=\"coinflip-verification__hash\" title={verificationResult.randomnessHex}>\n                        {verificationResult.randomnessHex.slice(0, 16)}...\n                      </span>\n                    </div>\n                    <div className=\"coinflip-verification__row\">\n                      <span>Derived Result</span>\n                      <span className={`side-${verificationResult.derivedResult}`}>\n                        {verificationResult.derivedResult.toUpperCase()}\n                      </span>\n                    </div>\n                    <div className=\"coinflip-verification__row\">\n                      <span>Winner</span>\n                      <span className=\"coinflip-verification__hash\" title={verificationResult.winner}>\n                        {verificationResult.winner.slice(0, 4)}...{verificationResult.winner.slice(-4)}\n                      </span>\n                    </div>\n                    <div className=\"coinflip-verification__row\">\n                      <span>VRF Fulfilled</span>\n                      <span className={verificationResult.vrfFulfilled ? \"coinflip-verification__check\" : \"coinflip-verification__cross\"}>\n                        {verificationResult.vrfFulfilled ? \"Yes\" : \"No\"}\n                      </span>\n                    </div>\n                  </div>\n                  <a href=\"/fairness\" className=\"coinflip-verification__link\">\n                    Full Verification Page\n                  </a>\n                </div>\n              )}\n\n            </>\n          )}\n        </div>\n      )}\n    </div>\n  );\n}\n","numLines":385,"startLine":1,"totalLines":385}}}
