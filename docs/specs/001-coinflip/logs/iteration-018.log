{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QGsDhLJfdhVRP9ksoFhv1u","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey, type Transaction } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchClaimableMatches,\n    16→  fetchMatchByCreator,\n    17→  fetchMatch,\n    18→  getMatchPda,\n    19→  buildCreateMatchTx,\n    20→  buildJoinMatchTx,\n    21→  buildCancelMatchTx,\n    22→  buildTimeoutCancelTx,\n    23→  buildClaimPayoutTx,\n    24→} from \"../utils/chain\";\n    25→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    26→\n    27→/** Parse Solana/wallet errors into user-friendly messages */\n    28→function parseTransactionError(err: unknown): string {\n    29→  const msg = err instanceof Error ? err.message : String(err);\n    30→\n    31→  // Wallet not connected\n    32→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    33→    return \"Wallet not connected. Please connect your wallet first.\";\n    34→  }\n    35→\n    36→  // User rejected\n    37→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    38→    return \"Transaction cancelled by user.\";\n    39→  }\n    40→\n    41→  // Insufficient funds (Solana runtime error)\n    42→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    43→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    44→  }\n    45→\n    46→  // Account already in use (match already exists)\n    47→  if (msg.includes(\"already in use\")) {\n    48→    return \"You already have an active match. Cancel it before creating a new one.\";\n    49→  }\n    50→\n    51→  // Network / RPC errors\n    52→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    53→    return \"Network error. Please check your connection and try again.\";\n    54→  }\n    55→\n    56→  // Anchor program errors\n    57→  if (msg.includes(\"InvalidPhase\")) {\n    58→    return \"This match is no longer available.\";\n    59→  }\n    60→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    61→    return \"You cannot join your own match.\";\n    62→  }\n    63→\n    64→  // Simulation / preflight failures\n    65→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    66→    return \"Transaction simulation failed. The match may no longer be available.\";\n    67→  }\n    68→\n    69→  // Blockhash expiry\n    70→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    71→    return \"Transaction expired. Please try again.\";\n    72→  }\n    73→\n    74→  // Generic fallback — log full error for debugging\n    75→  console.error(\"[coinflip] unhandled transaction error:\", err);\n    76→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    77→}\n    78→\n    79→interface CoinflipContextValue {\n    80→  // State\n    81→  activeMatch: UIMatch | null;\n    82→  openMatches: UIMatch[];\n    83→  claimableMatches: UIMatch[];\n    84→  userHistory: UIMatch[];\n    85→  selectedTier: Tier | null;\n    86→  selectedSide: CoinSide | null;\n    87→\n    88→  // Loading states\n    89→  loading: boolean;\n    90→  creating: boolean;\n    91→  joining: boolean;\n    92→  claiming: boolean;\n    93→  joiningMatchId: string | null;\n    94→\n    95→  // Error state\n    96→  error: string | null;\n    97→  clearError: () => void;\n    98→\n    99→  // Verification\n   100→  lastClaimSignature: string | null;\n   101→\n   102→  // Actions\n   103→  setSelectedTier: (tier: Tier | null) => void;\n   104→  setSelectedSide: (side: CoinSide | null) => void;\n   105→  createMatch: () => Promise<void>;\n   106→  joinMatch: (matchId: string) => Promise<void>;\n   107→  cancelMatch: () => Promise<void>;\n   108→  timeoutCancel: () => Promise<void>;\n   109→  claimPayout: () => Promise<void>;\n   110→  clearActiveMatch: () => void;\n   111→  selectMatch: (match: UIMatch) => void;\n   112→  refreshMatches: () => void;\n   113→}\n   114→\n   115→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n   116→\n   117→export function CoinflipProvider({ children }: { children: ReactNode }) {\n   118→  const { connected, publicKey, sendTransaction } = useWallet();\n   119→  const { connection } = useConnection();\n   120→  const { refresh: refreshBalance } = useBalance();\n   121→\n   122→  // Selection state\n   123→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   124→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   125→\n   126→  // Match state\n   127→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   128→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   129→  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n   130→  const [userHistory] = useState<UIMatch[]>([]);\n   131→\n   132→  // Loading states\n   133→  const [loading, setLoading] = useState(true);\n   134→  const [creating, setCreating] = useState(false);\n   135→  const [joining, setJoining] = useState(false);\n   136→  const [claiming, setClaiming] = useState(false);\n   137→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   138→\n   139→  // Error state\n   140→  const [error, setError] = useState<string | null>(null);\n   141→  const clearError = useCallback(() => setError(null), []);\n   142→\n   143→  // Verification — last claim tx signature for fairness verification\n   144→  const [lastClaimSignature, setLastClaimSignature] = useState<string | null>(null);\n   145→\n   146→  // Timer ref for flip animation delay (ready→flipping→complete)\n   147→  const flipTimerRef = useRef<number | null>(null);\n   148→\n   149→  // Ref to prevent polling races from restoring a dismissed match.\n   150→  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n   151→  // from the previous poll interval may resolve and call setActiveMatch,\n   152→  // putting them back on the match view. This ref blocks that.\n   153→  const dismissedMatchRef = useRef<string | null>(null);\n   154→\n   155→  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n   156→  const sendAndConfirm = useCallback(\n   157→    async (transaction: Transaction): Promise<string> => {\n   158→      const { blockhash, lastValidBlockHeight } =\n   159→        await connection.getLatestBlockhash(\"confirmed\");\n   160→      const signature = await sendTransaction(transaction);\n   161→      await connection.confirmTransaction(\n   162→        { signature, blockhash, lastValidBlockHeight },\n   163→        \"confirmed\",\n   164→      );\n   165→      await refreshBalance();\n   166→      return signature;\n   167→    },\n   168→    [connection, sendTransaction, refreshBalance],\n   169→  );\n   170→\n   171→  // Fetch open matches (and claimable matches when wallet connected) from on-chain\n   172→  const refreshMatches = useCallback(() => {\n   173→    fetchAllOpenMatches(connection)\n   174→      .then((matches) => {\n   175→        setOpenMatches(matches);\n   176→        setLoading(false);\n   177→      })\n   178→      .catch(() => {\n   179→        setLoading(false);\n   180→      });\n   181→\n   182→    if (publicKey) {\n   183→      fetchClaimableMatches(connection, publicKey)\n   184→        .then(setClaimableMatches)\n   185→        .catch(() => {});\n   186→    }\n   187→  }, [connection, publicKey]);\n   188→\n   189→  // Initial load\n   190→  useEffect(() => {\n   191→    setLoading(true);\n   192→    refreshMatches();\n   193→  }, [refreshMatches]);\n   194→\n   195→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   196→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   197→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   198→\n   199→  useEffect(() => {\n   200→    const interval = setInterval(() => {\n   201→      refreshMatches();\n   202→\n   203→      // If there's an active match, refresh it too (skip during flip animation\n   204→      // and when already claimed — PDA is closed on-chain)\n   205→      if (activeMatch && activeMatch.phase !== \"flipping\" && !activeMatch.claimed) {\n   206→        const matchPda = new PublicKey(activeMatch.id);\n   207→        fetchMatch(connection, matchPda)\n   208→          .then((updated) => {\n   209→            // If user dismissed this match while fetch was in flight, ignore\n   210→            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n   211→\n   212→            if (updated) {\n   213→              // Intercept ready→complete: insert 3s flip animation first\n   214→              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n   215→                setActiveMatch({ ...updated, phase: \"flipping\" });\n   216→                flipTimerRef.current = window.setTimeout(() => {\n   217→                  flipTimerRef.current = null;\n   218→                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n   219→                  setActiveMatch((current) =>\n   220→                    current?.phase === \"flipping\" ? updated : current\n   221→                  );\n   222→                }, 3000);\n   223→              } else {\n   224→                setActiveMatch(updated);\n   225→              }\n   226→            } else {\n   227→              // Match account closed (claimed or cancelled)\n   228→              setActiveMatch(null);\n   229→            }\n   230→          })\n   231→          .catch(() => {\n   232→            // Ignore polling errors\n   233→          });\n   234→      }\n   235→    }, pollInterval);\n   236→    return () => clearInterval(interval);\n   237→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   238→\n   239→  // Cleanup flip timer on unmount\n   240→  useEffect(() => {\n   241→    return () => {\n   242→      if (flipTimerRef.current !== null) {\n   243→        clearTimeout(flipTimerRef.current);\n   244→      }\n   245→    };\n   246→  }, []);\n   247→\n   248→  const createMatch = useCallback(async () => {\n   249→    if (!connected || !publicKey) {\n   250→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   251→      return;\n   252→    }\n   253→    if (!selectedTier || !selectedSide) {\n   254→      setError(\"Select tier and side first.\");\n   255→      return;\n   256→    }\n   257→\n   258→    setCreating(true);\n   259→    setError(null);\n   260→    try {\n   261→      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n   262→      const [matchPda] = getMatchPda(publicKey);\n   263→      const existing = await fetchMatch(connection, matchPda);\n   264→      if (existing) {\n   265→        if (existing.phase === \"complete\") {\n   266→          // Match is settled — show it so user can settle (winner claims, loser closes)\n   267→          setActiveMatch(existing);\n   268→          dismissedMatchRef.current = null;\n   269→          setError(\"Settle your previous match first.\");\n   270→        } else {\n   271→          // Match still in progress\n   272→          setActiveMatch(existing);\n   273→          dismissedMatchRef.current = null;\n   274→          setError(\"You already have an active match.\");\n   275→        }\n   276→        return;\n   277→      }\n   278→\n   279→      const { transaction } = await buildCreateMatchTx(\n   280→        connection,\n   281→        publicKey,\n   282→        selectedTier,\n   283→        selectedSide\n   284→      );\n   285→\n   286→      await sendAndConfirm(transaction);\n   287→\n   288→      // Clear dismissed ref — this is a new intentional match\n   289→      dismissedMatchRef.current = null;\n   290→\n   291→      // Fetch the created match from on-chain\n   292→      const match = await fetchMatch(connection, matchPda);\n   293→      if (match) {\n   294→        setActiveMatch(match);\n   295→      }\n   296→\n   297→      setSelectedSide(null);\n   298→      refreshMatches();\n   299→    } catch (err) {\n   300→      setError(parseTransactionError(err));\n   301→    } finally {\n   302→      setCreating(false);\n   303→    }\n   304→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n   305→\n   306→  const joinMatch = useCallback(\n   307→    async (matchId: string) => {\n   308→      if (!connected || !publicKey) {\n   309→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   310→        return;\n   311→      }\n   312→\n   313→      setJoining(true);\n   314→      setJoiningMatchId(matchId);\n   315→      setError(null);\n   316→      try {\n   317→        // matchId is the match PDA base58 — fetch to get the creator\n   318→        const matchPda = new PublicKey(matchId);\n   319→        const existingMatch = await fetchMatch(connection, matchPda);\n   320→        if (!existingMatch) {\n   321→          setError(\"Match not found. It may have been cancelled.\");\n   322→          return;\n   323→        }\n   324→\n   325→        const matchCreator = new PublicKey(existingMatch.player1);\n   326→        const transaction = await buildJoinMatchTx(\n   327→          connection,\n   328→          publicKey,\n   329→          matchCreator\n   330→        );\n   331→\n   332→        await sendAndConfirm(transaction);\n   333→\n   334→        // Clear dismissed ref — this is a new intentional match\n   335→        dismissedMatchRef.current = null;\n   336→\n   337→        // Fetch updated match\n   338→        const updated = await fetchMatch(connection, matchPda);\n   339→        if (updated) {\n   340→          setActiveMatch(updated);\n   341→        }\n   342→\n   343→        refreshMatches();\n   344→      } catch (err) {\n   345→        setError(parseTransactionError(err));\n   346→      } finally {\n   347→        setJoining(false);\n   348→        setJoiningMatchId(null);\n   349→      }\n   350→    },\n   351→    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n   352→  );\n   353→\n   354→  const cancelMatch = useCallback(async () => {\n   355→    if (!connected || !publicKey || !activeMatch) {\n   356→      setError(\"No active match to cancel.\");\n   357→      return;\n   358→    }\n   359→\n   360→    setError(null);\n   361→    try {\n   362→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   363→      await sendAndConfirm(transaction);\n   364→      setActiveMatch(null);\n   365→      refreshMatches();\n   366→    } catch (err) {\n   367→      setError(parseTransactionError(err));\n   368→    }\n   369→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   370→\n   371→  const timeoutCancel = useCallback(async () => {\n   372→    if (!connected || !publicKey || !activeMatch) {\n   373→      setError(\"No active match to cancel.\");\n   374→      return;\n   375→    }\n   376→    if (!activeMatch.player2) {\n   377→      setError(\"Match has no opponent.\");\n   378→      return;\n   379→    }\n   380→\n   381→    setError(null);\n   382→    try {\n   383→      const matchCreator = new PublicKey(activeMatch.player1);\n   384→      const opponent = new PublicKey(activeMatch.player2);\n   385→\n   386→      const transaction = await buildTimeoutCancelTx(\n   387→        connection,\n   388→        publicKey,\n   389→        matchCreator,\n   390→        opponent\n   391→      );\n   392→      await sendAndConfirm(transaction);\n   393→      setActiveMatch(null);\n   394→      refreshMatches();\n   395→    } catch (err) {\n   396→      setError(parseTransactionError(err));\n   397→    }\n   398→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   399→\n   400→  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   401→   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n   402→  const claimPayout = useCallback(async () => {\n   403→    if (!connected || !publicKey || !activeMatch) {\n   404→      setError(\"No active match to claim.\");\n   405→      return;\n   406→    }\n   407→    if (!activeMatch.player2) {\n   408→      setError(\"Match has no opponent yet.\");\n   409→      return;\n   410→    }\n   411→\n   412→    setClaiming(true);\n   413→    setError(null);\n   414→    try {\n   415→      const matchCreator = new PublicKey(activeMatch.player1);\n   416→      const opponent = new PublicKey(activeMatch.player2);\n   417→\n   418→      const transaction = await buildClaimPayoutTx(\n   419→        connection,\n   420→        publicKey,   // caller (either player — winner derived on-chain from VRF)\n   421→        matchCreator,\n   422→        opponent\n   423→      );\n   424→\n   425→      const signature = await sendAndConfirm(transaction);\n   426→\n   427→      // Match PDA is now closed on-chain. Keep activeMatch locally with\n   428→      // claimed=true so the user can verify fairness before returning to lobby.\n   429→      setLastClaimSignature(signature);\n   430→      setActiveMatch((prev) => prev ? { ...prev, claimed: true } : null);\n   431→      refreshMatches();\n   432→    } catch (err) {\n   433→      setError(parseTransactionError(err));\n   434→    } finally {\n   435→      setClaiming(false);\n   436→    }\n   437→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   438→\n   439→  // Track if user explicitly cleared the match\n   440→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   441→\n   442→  /** Open a match from the claimable list in ActiveMatchView. */\n   443→  const selectMatch = useCallback((match: UIMatch) => {\n   444→    dismissedMatchRef.current = null;\n   445→    setActiveMatch(match);\n   446→    setUserClearedMatch(false);\n   447→  }, []);\n   448→\n   449→  const clearActiveMatch = useCallback(() => {\n   450→    // Record the dismissed match ID so in-flight polls don't restore it\n   451→    dismissedMatchRef.current = activeMatch?.id ?? null;\n   452→    setActiveMatch(null);\n   453→    setLastClaimSignature(null);\n   454→    setUserClearedMatch(true);\n   455→    setError(null);\n   456→    refreshMatches();\n   457→  }, [activeMatch, refreshMatches]);\n   458→\n   459→  // Check for existing active match on wallet connect\n   460→  useEffect(() => {\n   461→    if (publicKey && !activeMatch && !userClearedMatch) {\n   462→      fetchMatchByCreator(connection, publicKey)\n   463→        .then((match) => {\n   464→          if (match) {\n   465→            // Don't restore a match the user explicitly dismissed\n   466→            if (dismissedMatchRef.current === match.id) return;\n   467→            setActiveMatch(match);\n   468→          }\n   469→        })\n   470→        .catch(() => {\n   471→          // No active match found\n   472→        });\n   473→    }\n   474→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   475→\n   476→  // Reset userClearedMatch when creating or joining a new match\n   477→  useEffect(() => {\n   478→    if (activeMatch) {\n   479→      setUserClearedMatch(false);\n   480→    }\n   481→  }, [activeMatch]);\n   482→\n   483→  const value: CoinflipContextValue = {\n   484→    activeMatch,\n   485→    openMatches,\n   486→    claimableMatches,\n   487→    userHistory,\n   488→    selectedTier,\n   489→    selectedSide,\n   490→    loading,\n   491→    creating,\n   492→    joining,\n   493→    claiming,\n   494→    joiningMatchId,\n   495→    error,\n   496→    clearError,\n   497→    lastClaimSignature,\n   498→    setSelectedTier,\n   499→    setSelectedSide,\n   500→    createMatch,\n   501→    joinMatch,\n   502→    cancelMatch,\n   503→    timeoutCancel,\n   504→    claimPayout,\n   505→    clearActiveMatch,\n   506→    selectMatch,\n   507→    refreshMatches,\n   508→  };\n   509→\n   510→  return (\n   511→    <CoinflipContext.Provider value={value}>\n   512→      {children}\n   513→    </CoinflipContext.Provider>\n   514→  );\n   515→}\n   516→\n   517→export function useCoinflip(): CoinflipContextValue {\n   518→  const context = useContext(CoinflipContext);\n   519→  if (!context) {\n   520→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   521→  }\n   522→  return context;\n   523→}\n   524→"}]},"parent_tool_use_id":null,"session_id":"13b31efc-e570-4147-9b51-463305fcfba1","uuid":"ca58473b-0aad-4558-bd8a-58a868efbaee","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { PublicKey, type Transaction } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchClaimableMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  getMatchPda,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildTimeoutCancelTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse Solana/wallet errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  // Wallet not connected\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n\n  // User rejected\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n\n  // Insufficient funds (Solana runtime error)\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n\n  // Account already in use (match already exists)\n  if (msg.includes(\"already in use\")) {\n    return \"You already have an active match. Cancel it before creating a new one.\";\n  }\n\n  // Network / RPC errors\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n\n  // Anchor program errors\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This match is no longer available.\";\n  }\n  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    return \"You cannot join your own match.\";\n  }\n\n  // Simulation / preflight failures\n  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    return \"Transaction simulation failed. The match may no longer be available.\";\n  }\n\n  // Blockhash expiry\n  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    return \"Transaction expired. Please try again.\";\n  }\n\n  // Generic fallback — log full error for debugging\n  console.error(\"[coinflip] unhandled transaction error:\", err);\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  claimableMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Verification\n  lastClaimSignature: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  timeoutCancel: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  selectMatch: (match: UIMatch) => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Verification — last claim tx signature for fairness verification\n  const [lastClaimSignature, setLastClaimSignature] = useState<string | null>(null);\n\n  // Timer ref for flip animation delay (ready→flipping→complete)\n  const flipTimerRef = useRef<number | null>(null);\n\n  // Ref to prevent polling races from restoring a dismissed match.\n  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n  // from the previous poll interval may resolve and call setActiveMatch,\n  // putting them back on the match view. This ref blocks that.\n  const dismissedMatchRef = useRef<string | null>(null);\n\n  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n      const signature = await sendTransaction(transaction);\n      await connection.confirmTransaction(\n        { signature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      await refreshBalance();\n      return signature;\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // Fetch open matches (and claimable matches when wallet connected) from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n\n    if (publicKey) {\n      fetchClaimableMatches(connection, publicKey)\n        .then(setClaimableMatches)\n        .catch(() => {});\n    }\n  }, [connection, publicKey]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too (skip during flip animation\n      // and when already claimed — PDA is closed on-chain)\n      if (activeMatch && activeMatch.phase !== \"flipping\" && !activeMatch.claimed) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            // If user dismissed this match while fetch was in flight, ignore\n            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n\n            if (updated) {\n              // Intercept ready→complete: insert 3s flip animation first\n              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n                setActiveMatch({ ...updated, phase: \"flipping\" });\n                flipTimerRef.current = window.setTimeout(() => {\n                  flipTimerRef.current = null;\n                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n                  setActiveMatch((current) =>\n                    current?.phase === \"flipping\" ? updated : current\n                  );\n                }, 3000);\n              } else {\n                setActiveMatch(updated);\n              }\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection, pollInterval]);\n\n  // Cleanup flip timer on unmount\n  useEffect(() => {\n    return () => {\n      if (flipTimerRef.current !== null) {\n        clearTimeout(flipTimerRef.current);\n      }\n    };\n  }, []);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n      const [matchPda] = getMatchPda(publicKey);\n      const existing = await fetchMatch(connection, matchPda);\n      if (existing) {\n        if (existing.phase === \"complete\") {\n          // Match is settled — show it so user can settle (winner claims, loser closes)\n          setActiveMatch(existing);\n          dismissedMatchRef.current = null;\n          setError(\"Settle your previous match first.\");\n        } else {\n          // Match still in progress\n          setActiveMatch(existing);\n          dismissedMatchRef.current = null;\n          setError(\"You already have an active match.\");\n        }\n        return;\n      }\n\n      const { transaction } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendAndConfirm(transaction);\n\n      // Clear dismissed ref — this is a new intentional match\n      dismissedMatchRef.current = null;\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendAndConfirm(transaction);\n\n        // Clear dismissed ref — this is a new intentional match\n        dismissedMatchRef.current = null;\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendAndConfirm(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  const timeoutCancel = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n    if (!activeMatch.player2) {\n      setError(\"Match has no opponent.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = new PublicKey(activeMatch.player2);\n\n      const transaction = await buildTimeoutCancelTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n      await sendAndConfirm(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n    if (!activeMatch.player2) {\n      setError(\"Match has no opponent yet.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = new PublicKey(activeMatch.player2);\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,   // caller (either player — winner derived on-chain from VRF)\n        matchCreator,\n        opponent\n      );\n\n      const signature = await sendAndConfirm(transaction);\n\n      // Match PDA is now closed on-chain. Keep activeMatch locally with\n      // claimed=true so the user can verify fairness before returning to lobby.\n      setLastClaimSignature(signature);\n      setActiveMatch((prev) => prev ? { ...prev, claimed: true } : null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  /** Open a match from the claimable list in ActiveMatchView. */\n  const selectMatch = useCallback((match: UIMatch) => {\n    dismissedMatchRef.current = null;\n    setActiveMatch(match);\n    setUserClearedMatch(false);\n  }, []);\n\n  const clearActiveMatch = useCallback(() => {\n    // Record the dismissed match ID so in-flight polls don't restore it\n    dismissedMatchRef.current = activeMatch?.id ?? null;\n    setActiveMatch(null);\n    setLastClaimSignature(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [activeMatch, refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            // Don't restore a match the user explicitly dismissed\n            if (dismissedMatchRef.current === match.id) return;\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    claimableMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    lastClaimSignature,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    timeoutCancel,\n    claimPayout,\n    clearActiveMatch,\n    selectMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":524,"startLine":1,"totalLines":524}}}
