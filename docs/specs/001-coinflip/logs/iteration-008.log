{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N4CWooUk2F4GTmRnYqNyu6","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  type ReactNode,\n     8→} from \"react\";\n     9→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    10→import type { UIMatch, CoinSide } from \"../types\";\n    11→import {\n    12→  createMockMatch,\n    13→  joinMockMatch,\n    14→  claimMockPayout,\n    15→  getOpenMatches,\n    16→  getUserMatches,\n    17→  subscribeToMatch,\n    18→  generateMockOpenMatches,\n    19→  getMockMatch,\n    20→} from \"../utils/mock-simulation\";\n    21→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    22→\n    23→interface CoinflipContextValue {\n    24→  // State\n    25→  activeMatch: UIMatch | null;\n    26→  openMatches: UIMatch[];\n    27→  userHistory: UIMatch[];\n    28→  selectedTier: Tier | null;\n    29→  selectedSide: CoinSide | null;\n    30→\n    31→  // Loading states\n    32→  loading: boolean;\n    33→  creating: boolean;\n    34→  joining: boolean;\n    35→  claiming: boolean;\n    36→  joiningMatchId: string | null;\n    37→\n    38→  // Actions\n    39→  setSelectedTier: (tier: Tier | null) => void;\n    40→  setSelectedSide: (side: CoinSide | null) => void;\n    41→  createMatch: () => Promise<void>;\n    42→  joinMatch: (matchId: string) => Promise<void>;\n    43→  claimPayout: () => Promise<void>;\n    44→  clearActiveMatch: () => void;\n    45→  refreshMatches: () => void;\n    46→}\n    47→\n    48→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n    49→\n    50→export function CoinflipProvider({ children }: { children: ReactNode }) {\n    51→  const { connected, address } = useWallet();\n    52→\n    53→  // Selection state\n    54→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n    55→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n    56→\n    57→  // Match state\n    58→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n    59→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n    60→  const [userHistory, setUserHistory] = useState<UIMatch[]>([]);\n    61→\n    62→  // Loading states\n    63→  const [loading, setLoading] = useState(true);\n    64→  const [creating, setCreating] = useState(false);\n    65→  const [joining, setJoining] = useState(false);\n    66→  const [claiming, setClaiming] = useState(false);\n    67→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n    68→\n    69→  // Define refreshMatches before effects that use it\n    70→  const refreshMatches = useCallback(() => {\n    71→    const open = getOpenMatches();\n    72→    setOpenMatches(open);\n    73→\n    74→    if (address) {\n    75→      const history = getUserMatches(address)\n    76→        .filter((m) => m.phase === \"complete\")\n    77→        .sort((a, b) => (b.completedAt ?? b.createdAt) - (a.completedAt ?? a.createdAt));\n    78→      setUserHistory(history);\n    79→    }\n    80→  }, [address]);\n    81→\n    82→  // Initialize mock matches\n    83→  useEffect(() => {\n    84→    setLoading(true);\n    85→    // Generate random number of initial open matches (up to 30)\n    86→    const randomCount = Math.floor(Math.random() * 30) + 1;\n    87→    generateMockOpenMatches(randomCount);\n    88→    refreshMatches();\n    89→    setLoading(false);\n    90→  }, [refreshMatches]);\n    91→\n    92→  // Poll for match updates\n    93→  useEffect(() => {\n    94→    const interval = setInterval(() => {\n    95→      refreshMatches();\n    96→    }, 5000);\n    97→    return () => clearInterval(interval);\n    98→  }, [refreshMatches]);\n    99→\n   100→  // Subscribe to active match updates\n   101→  useEffect(() => {\n   102→    if (!activeMatch) return;\n   103→\n   104→    const unsubscribe = subscribeToMatch(activeMatch.id, (updated) => {\n   105→      setActiveMatch(updated);\n   106→\n   107→      // If match is complete, refresh history\n   108→      if (updated.phase === \"complete\") {\n   109→        // Small delay to ensure store is fully updated\n   110→        setTimeout(() => refreshMatches(), 100);\n   111→      }\n   112→    });\n   113→\n   114→    return unsubscribe;\n   115→  }, [activeMatch?.id, refreshMatches]);\n   116→\n   117→  const createMatch = useCallback(async () => {\n   118→    if (!connected || !address) {\n   119→      throw new Error(\"Wallet not connected\");\n   120→    }\n   121→    if (!selectedTier || !selectedSide) {\n   122→      throw new Error(\"Select tier and side first\");\n   123→    }\n   124→\n   125→    setCreating(true);\n   126→    try {\n   127→      // Simulate transaction delay\n   128→      await new Promise((resolve) => setTimeout(resolve, 500));\n   129→\n   130→      const match = createMockMatch(address, selectedTier, selectedSide);\n   131→      setActiveMatch(match);\n   132→\n   133→      // Clear selection\n   134→      setSelectedSide(null);\n   135→\n   136→      // Refresh matches list\n   137→      refreshMatches();\n   138→    } finally {\n   139→      setCreating(false);\n   140→    }\n   141→  }, [connected, address, selectedTier, selectedSide, refreshMatches]);\n   142→\n   143→  const joinMatch = useCallback(\n   144→    async (matchId: string) => {\n   145→      if (!connected || !address) {\n   146→        throw new Error(\"Wallet not connected\");\n   147→      }\n   148→\n   149→      setJoining(true);\n   150→      setJoiningMatchId(matchId);\n   151→      try {\n   152→        // Simulate transaction delay\n   153→        await new Promise((resolve) => setTimeout(resolve, 500));\n   154→\n   155→        const match = joinMockMatch(matchId, address);\n   156→        setActiveMatch(match);\n   157→\n   158→        // Refresh matches list\n   159→        refreshMatches();\n   160→      } finally {\n   161→        setJoining(false);\n   162→        setJoiningMatchId(null);\n   163→      }\n   164→    },\n   165→    [connected, address, refreshMatches]\n   166→  );\n   167→\n   168→  const claimPayout = useCallback(async () => {\n   169→    if (!connected || !address || !activeMatch) {\n   170→      throw new Error(\"No active match to claim\");\n   171→    }\n   172→\n   173→    setClaiming(true);\n   174→    try {\n   175→      // Simulate transaction delay\n   176→      await new Promise((resolve) => setTimeout(resolve, 500));\n   177→\n   178→      const updated = claimMockPayout(activeMatch.id, address);\n   179→      setActiveMatch(updated);\n   180→    } finally {\n   181→      setClaiming(false);\n   182→    }\n   183→  }, [connected, address, activeMatch]);\n   184→\n   185→  // Track if user explicitly cleared the match\n   186→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   187→\n   188→  const clearActiveMatch = useCallback(() => {\n   189→    setActiveMatch(null);\n   190→    setUserClearedMatch(true);\n   191→    // Refresh to update history with completed match\n   192→    refreshMatches();\n   193→  }, [refreshMatches]);\n   194→\n   195→  // Check for existing active match on wallet connect\n   196→  useEffect(() => {\n   197→    if (address && !activeMatch && !userClearedMatch) {\n   198→      const userMatches = getUserMatches(address);\n   199→      const active = userMatches.find(\n   200→        (m) => m.phase !== \"complete\" || (m.phase === \"complete\" && !m.claimed && m.winner === address)\n   201→      );\n   202→      if (active) {\n   203→        // Re-fetch to ensure we have latest state\n   204→        const latest = getMockMatch(active.id);\n   205→        if (latest) {\n   206→          setActiveMatch(latest);\n   207→        }\n   208→      }\n   209→    }\n   210→  }, [address, activeMatch, userClearedMatch]);\n   211→\n   212→  // Reset userClearedMatch when creating or joining a new match\n   213→  useEffect(() => {\n   214→    if (activeMatch) {\n   215→      setUserClearedMatch(false);\n   216→    }\n   217→  }, [activeMatch]);\n   218→\n   219→  const value: CoinflipContextValue = {\n   220→    activeMatch,\n   221→    openMatches,\n   222→    userHistory,\n   223→    selectedTier,\n   224→    selectedSide,\n   225→    loading,\n   226→    creating,\n   227→    joining,\n   228→    claiming,\n   229→    joiningMatchId,\n   230→    setSelectedTier,\n   231→    setSelectedSide,\n   232→    createMatch,\n   233→    joinMatch,\n   234→    claimPayout,\n   235→    clearActiveMatch,\n   236→    refreshMatches,\n   237→  };\n   238→\n   239→  return (\n   240→    <CoinflipContext.Provider value={value}>\n   241→      {children}\n   242→    </CoinflipContext.Provider>\n   243→  );\n   244→}\n   245→\n   246→export function useCoinflip(): CoinflipContextValue {\n   247→  const context = useContext(CoinflipContext);\n   248→  if (!context) {\n   249→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   250→  }\n   251→  return context;\n   252→}\n   253→"}]},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"066fc3e7-c1d9-4b0f-aced-64784eab259d","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  type ReactNode,\n} from \"react\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  createMockMatch,\n  joinMockMatch,\n  claimMockPayout,\n  getOpenMatches,\n  getUserMatches,\n  subscribeToMatch,\n  generateMockOpenMatches,\n  getMockMatch,\n} from \"../utils/mock-simulation\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, address } = useWallet();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory, setUserHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Define refreshMatches before effects that use it\n  const refreshMatches = useCallback(() => {\n    const open = getOpenMatches();\n    setOpenMatches(open);\n\n    if (address) {\n      const history = getUserMatches(address)\n        .filter((m) => m.phase === \"complete\")\n        .sort((a, b) => (b.completedAt ?? b.createdAt) - (a.completedAt ?? a.createdAt));\n      setUserHistory(history);\n    }\n  }, [address]);\n\n  // Initialize mock matches\n  useEffect(() => {\n    setLoading(true);\n    // Generate random number of initial open matches (up to 30)\n    const randomCount = Math.floor(Math.random() * 30) + 1;\n    generateMockOpenMatches(randomCount);\n    refreshMatches();\n    setLoading(false);\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches]);\n\n  // Subscribe to active match updates\n  useEffect(() => {\n    if (!activeMatch) return;\n\n    const unsubscribe = subscribeToMatch(activeMatch.id, (updated) => {\n      setActiveMatch(updated);\n\n      // If match is complete, refresh history\n      if (updated.phase === \"complete\") {\n        // Small delay to ensure store is fully updated\n        setTimeout(() => refreshMatches(), 100);\n      }\n    });\n\n    return unsubscribe;\n  }, [activeMatch?.id, refreshMatches]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !address) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier || !selectedSide) {\n      throw new Error(\"Select tier and side first\");\n    }\n\n    setCreating(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      const match = createMockMatch(address, selectedTier, selectedSide);\n      setActiveMatch(match);\n\n      // Clear selection\n      setSelectedSide(null);\n\n      // Refresh matches list\n      refreshMatches();\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, address, selectedTier, selectedSide, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !address) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      try {\n        // Simulate transaction delay\n        await new Promise((resolve) => setTimeout(resolve, 500));\n\n        const match = joinMockMatch(matchId, address);\n        setActiveMatch(match);\n\n        // Refresh matches list\n        refreshMatches();\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, address, refreshMatches]\n  );\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !address || !activeMatch) {\n      throw new Error(\"No active match to claim\");\n    }\n\n    setClaiming(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      const updated = claimMockPayout(activeMatch.id, address);\n      setActiveMatch(updated);\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, address, activeMatch]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    // Refresh to update history with completed match\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (address && !activeMatch && !userClearedMatch) {\n      const userMatches = getUserMatches(address);\n      const active = userMatches.find(\n        (m) => m.phase !== \"complete\" || (m.phase === \"complete\" && !m.claimed && m.winner === address)\n      );\n      if (active) {\n        // Re-fetch to ensure we have latest state\n        const latest = getMockMatch(active.id);\n        if (latest) {\n          setActiveMatch(latest);\n        }\n      }\n    }\n  }, [address, activeMatch, userClearedMatch]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":253,"startLine":1,"totalLines":253}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Dp1Gdie5n8KuAEMuXnrkRc","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Y4yWMLG1guYqQ52rcs99QX","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\n// RPC endpoint — defaults to localhost for development\nconst RPC_URL = (import.meta as unknown as { env: Record<string, string | undefined> }).env\n  .VITE_RPC_URL ?? \"http://127.0.0.1:8899\";\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n\n  const connection = useMemo(() => new Connection(RPC_URL, \"confirmed\"), []);\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory, setUserHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Fetch open matches from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n  }, [connection]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too\n      if (activeMatch) {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            if (updated) {\n              setActiveMatch(updated);\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier || !selectedSide) {\n      throw new Error(\"Select tier and side first\");\n    }\n\n    setCreating(true);\n    try {\n      const { transaction, matchPda } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendTransaction(transaction);\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendTransaction, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          throw new Error(\"Match not found\");\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendTransaction(transaction);\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendTransaction, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to cancel\");\n    }\n\n    const transaction = await buildCancelMatchTx(connection, publicKey);\n    await sendTransaction(transaction);\n    setActiveMatch(null);\n    refreshMatches();\n  }, [connected, publicKey, activeMatch, connection, sendTransaction, refreshMatches]);\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      throw new Error(\"No active match to claim\");\n    }\n\n    setClaiming(true);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = activeMatch.player2\n        ? new PublicKey(activeMatch.player2)\n        : PublicKey.default;\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n\n      await sendTransaction(transaction);\n\n      // Update local state\n      setActiveMatch({ ...activeMatch, claimed: true });\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendTransaction]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2981,"cache_read_input_tokens":83794,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2981},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"767b005c-4e46-4532-8fd6-629840fdaea6"}
