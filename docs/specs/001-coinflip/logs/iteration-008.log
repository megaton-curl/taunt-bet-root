ray;\n  gameId: string;\n  roundId: number;\n  tier: Tier;\n  entryAmount: number;\n  phase: PoolPhase;\n  totalPool: number;\n  playerCount: number;\n  maxPlayers: number;\n  createdAt: Date;\n  lockedAt: Date | null;\n  settledAt: Date | null;\n  feeBps: number;\n  vrfRequest: PublicKey | null;\n  randomness: Uint8Array | null;\n  winner: PublicKey | null;\n  authority: PublicKey;\n  treasury: PublicKey;\n  carryoverAmount: number;\n  carryoverFromRound: number;\n}\n\n// ============ Player Entry ============\n\nexport type Side = \"none\" | \"green\" | \"red\";\n\nexport const SIDE_VALUES: Record<Side, number> = {\n  none: 0,\n  green: 1,\n  red: 2,\n};\n\nexport interface PlayerEntry {\n  pool: PublicKey;\n  player: PublicKey;\n  amount: number;\n  enteredAt: Date;\n  sequence: number;\n  side: Side;\n  cashoutMultiplier: number | null;\n  cashedOutAt: Date | null;\n  claimed: boolean;\n  payout: number;\n  won: boolean;\n  xpParticipation: number;\n  xpWin: number;\n}\n\n// ============ Game Config ============\n\nexport interface GameConfig {\n  gameId: string;\n  paused: boolean;\n  minBet: number;\n  maxBet: number;\n  feeBps: number;\n  enabledTiers: Tier[];\n  minPlayers: number;\n  maxPlayers: number;\n  roundDurationSecs: number;\n  bettingWindowSecs: number;\n  vrfQueue: PublicKey;\n  authority: PublicKey;\n  treasury: PublicKey;\n  currentRound: number;\n  totalRounds: number;\n  totalVolume: number;\n  totalFees: number;\n  version: number;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\n// ============ Coinflip ============\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type CoinflipPhase = \"created\" | \"ready\" | \"flipping\" | \"complete\";\n\nexport const COIN_SIDE_VALUES: Record<CoinSide, number> = {\n  heads: 0,\n  tails: 1,\n};\n\nexport const COINFLIP_PHASE_VALUES: Record<CoinflipPhase, number> = {\n  created: 0,\n  ready: 1,\n  flipping: 2,\n  complete: 3,\n};\n\nexport interface CoinflipState {\n  pool: PublicKey;\n  player1: PublicKey;\n  player2: PublicKey | null;\n  player1Side: CoinSide;\n  result: CoinSide | null;\n  phase: CoinflipPhase;\n  createdAt: Date;\n  joinedAt: Date | null;\n  flippedAt: Date | null;\n  joinTimeoutSecs: number;\n}\n\nexport interface CoinflipMatch {\n  pool: Pool;\n  state: CoinflipState;\n  player1Entry: PlayerEntry;\n  player2Entry: PlayerEntry | null;\n}\n\n// ============ Legacy Types (for backwards compatibility) ============\n\n/** @deprecated Use Pool instead */\nexport interface PoolState {\n  roundId: string;\n  gameId: string;\n  tier: Tier;\n  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n  entries: LegacyPlayerEntry[];\n  totalPool: number;\n  createdAt: number;\n  settledAt?: number;\n  outcome?: unknown;\n}\n\n/** @deprecated Use PlayerEntry instead */\nexport interface LegacyPlayerEntry {\n  playerId: string;\n  publicKey: string;\n  tier: Tier;\n  amount: number;\n  timestamp: number;\n  side?: \"green\" | \"red\";\n  cashoutMultiplier?: number;\n}\n\n// ============ Game IDs ============\n\nexport const GAME_IDS = {\n  COINFLIP: \"coinflip\",\n  LORD_OF_RNGS: \"lord-of-rngs\",\n  CRASH: \"crash\",\n  CLOSE_CALL: \"close-call\",\n  SLOTS: \"slots\",\n  GAME_OF_TRADES: \"game-of-trades\",\n  TUG_OF_EARN: \"tug-of-earn\",\n  CHART_COURSE: \"chart-course\",\n} as const;\n\nexport type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n\n// ============ XP System ============\n\nexport const XP_BY_TIER: Record<Tier, { participation: number; win: number }> = {\n  iron: { participation: 1, win: 3 },\n  bronze: { participation: 1, win: 3 },\n  silver: { participation: 10, win: 30 },\n  gold: { participation: 25, win: 75 },\n  platinum: { participation: 50, win: 150 },\n  diamond: { participation: 100, win: 300 },\n};\n\n// ============ Fee Constants ============\n\nexport const FEE_CONSTANTS = {\n  TOTAL_BPS: 300, // 3%\n  PLATFORM_REVENUE_BPS: 200, // 2.0%\n  CASHBACK_POOL_BPS: 50, // 0.5%\n  REWARDS_BUDGET_BPS: 50, // 0.5%\n} as const;\n","numLines":217,"startLine":1,"totalLines":217}}}
