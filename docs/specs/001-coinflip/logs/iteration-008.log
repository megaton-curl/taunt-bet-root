{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013ihFak57Yu29SLrakAYMog","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  type ReactNode,\n     8→} from \"react\";\n     9→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    10→import type { UIMatch, CoinSide } from \"../types\";\n    11→import {\n    12→  createMockMatch,\n    13→  joinMockMatch,\n    14→  claimMockPayout,\n    15→  getOpenMatches,\n    16→  getUserMatches,\n    17→  subscribeToMatch,\n    18→  generateMockOpenMatches,\n    19→  getMockMatch,\n    20→} from \"../utils/mock-simulation\";\n    21→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    22→\n    23→interface CoinflipContextValue {\n    24→  // State\n    25→  activeMatch: UIMatch | null;\n    26→  openMatches: UIMatch[];\n    27→  userHistory: UIMatch[];\n    28→  selectedTier: Tier | null;\n    29→  selectedSide: CoinSide | null;\n    30→\n    31→  // Loading states\n    32→  loading: boolean;\n    33→  creating: boolean;\n    34→  joining: boolean;\n    35→  claiming: boolean;\n    36→  joiningMatchId: string | null;\n    37→\n    38→  // Actions\n    39→  setSelectedTier: (tier: Tier | null) => void;\n    40→  setSelectedSide: (side: CoinSide | null) => void;\n    41→  createMatch: () => Promise<void>;\n    42→  joinMatch: (matchId: string) => Promise<void>;\n    43→  claimPayout: () => Promise<void>;\n    44→  clearActiveMatch: () => void;\n    45→  refreshMatches: () => void;\n    46→}\n    47→\n    48→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n    49→\n    50→export function CoinflipProvider({ children }: { children: ReactNode }) {\n    51→  const { connected, address } = useWallet();\n    52→\n    53→  // Selection state\n    54→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n    55→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n    56→\n    57→  // Match state\n    58→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n    59→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n    60→  const [userHistory, setUserHistory] = useState<UIMatch[]>([]);\n    61→\n    62→  // Loading states\n    63→  const [loading, setLoading] = useState(true);\n    64→  const [creating, setCreating] = useState(false);\n    65→  const [joining, setJoining] = useState(false);\n    66→  const [claiming, setClaiming] = useState(false);\n    67→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n    68→\n    69→  // Define refreshMatches before effects that use it\n    70→  const refreshMatches = useCallback(() => {\n    71→    const open = getOpenMatches();\n    72→    setOpenMatches(open);\n    73→\n    74→    if (address) {\n    75→      const history = getUserMatches(address)\n    76→        .filter((m) => m.phase === \"complete\")\n    77→        .sort((a, b) => (b.completedAt ?? b.createdAt) - (a.completedAt ?? a.createdAt));\n    78→      setUserHistory(history);\n    79→    }\n    80→  }, [address]);\n    81→\n    82→  // Initialize mock matches\n    83→  useEffect(() => {\n    84→    setLoading(true);\n    85→    // Generate random number of initial open matches (up to 30)\n    86→    const randomCount = Math.floor(Math.random() * 30) + 1;\n    87→    generateMockOpenMatches(randomCount);\n    88→    refreshMatches();\n    89→    setLoading(false);\n    90→  }, [refreshMatches]);\n    91→\n    92→  // Poll for match updates\n    93→  useEffect(() => {\n    94→    const interval = setInterval(() => {\n    95→      refreshMatches();\n    96→    }, 5000);\n    97→    return () => clearInterval(interval);\n    98→  }, [refreshMatches]);\n    99→\n   100→  // Subscribe to active match updates\n   101→  useEffect(() => {\n   102→    if (!activeMatch) return;\n   103→\n   104→    const unsubscribe = subscribeToMatch(activeMatch.id, (updated) => {\n   105→      setActiveMatch(updated);\n   106→\n   107→      // If match is complete, refresh history\n   108→      if (updated.phase === \"complete\") {\n   109→        // Small delay to ensure store is fully updated\n   110→        setTimeout(() => refreshMatches(), 100);\n   111→      }\n   112→    });\n   113→\n   114→    return unsubscribe;\n   115→  }, [activeMatch?.id, refreshMatches]);\n   116→\n   117→  const createMatch = useCallback(async () => {\n   118→    if (!connected || !address) {\n   119→      throw new Error(\"Wallet not connected\");\n   120→    }\n   121→    if (!selectedTier || !selectedSide) {\n   122→      throw new Error(\"Select tier and side first\");\n   123→    }\n   124→\n   125→    setCreating(true);\n   126→    try {\n   127→      // Simulate transaction delay\n   128→      await new Promise((resolve) => setTimeout(resolve, 500));\n   129→\n   130→      const match = createMockMatch(address, selectedTier, selectedSide);\n   131→      setActiveMatch(match);\n   132→\n   133→      // Clear selection\n   134→      setSelectedSide(null);\n   135→\n   136→      // Refresh matches list\n   137→      refreshMatches();\n   138→    } finally {\n   139→      setCreating(false);\n   140→    }\n   141→  }, [connected, address, selectedTier, selectedSide, refreshMatches]);\n   142→\n   143→  const joinMatch = useCallback(\n   144→    async (matchId: string) => {\n   145→      if (!connected || !address) {\n   146→        throw new Error(\"Wallet not connected\");\n   147→      }\n   148→\n   149→      setJoining(true);\n   150→      setJoiningMatchId(matchId);\n   151→      try {\n   152→        // Simulate transaction delay\n   153→        await new Promise((resolve) => setTimeout(resolve, 500));\n   154→\n   155→        const match = joinMockMatch(matchId, address);\n   156→        setActiveMatch(match);\n   157→\n   158→        // Refresh matches list\n   159→        refreshMatches();\n   160→      } finally {\n   161→        setJoining(false);\n   162→        setJoiningMatchId(null);\n   163→      }\n   164→    },\n   165→    [connected, address, refreshMatches]\n   166→  );\n   167→\n   168→  const claimPayout = useCallback(async () => {\n   169→    if (!connected || !address || !activeMatch) {\n   170→      throw new Error(\"No active match to claim\");\n   171→    }\n   172→\n   173→    setClaiming(true);\n   174→    try {\n   175→      // Simulate transaction delay\n   176→      await new Promise((resolve) => setTimeout(resolve, 500));\n   177→\n   178→      const updated = claimMockPayout(activeMatch.id, address);\n   179→      setActiveMatch(updated);\n   180→    } finally {\n   181→      setClaiming(false);\n   182→    }\n   183→  }, [connected, address, activeMatch]);\n   184→\n   185→  // Track if user explicitly cleared the match\n   186→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   187→\n   188→  const clearActiveMatch = useCallback(() => {\n   189→    setActiveMatch(null);\n   190→    setUserClearedMatch(true);\n   191→    // Refresh to update history with completed match\n   192→    refreshMatches();\n   193→  }, [refreshMatches]);\n   194→\n   195→  // Check for existing active match on wallet connect\n   196→  useEffect(() => {\n   197→    if (address && !activeMatch && !userClearedMatch) {\n   198→      const userMatches = getUserMatches(address);\n   199→      const active = userMatches.find(\n   200→        (m) => m.phase !== \"complete\" || (m.phase === \"complete\" && !m.claimed && m.winner === address)\n   201→      );\n   202→      if (active) {\n   203→        // Re-fetch to ensure we have latest state\n   204→        const latest = getMockMatch(active.id);\n   205→        if (latest) {\n   206→          setActiveMatch(latest);\n   207→        }\n   208→      }\n   209→    }\n   210→  }, [address, activeMatch, userClearedMatch]);\n   211→\n   212→  // Reset userClearedMatch when creating or joining a new match\n   213→  useEffect(() => {\n   214→    if (activeMatch) {\n   215→      setUserClearedMatch(false);\n   216→    }\n   217→  }, [activeMatch]);\n   218→\n   219→  const value: CoinflipContextValue = {\n   220→    activeMatch,\n   221→    openMatches,\n   222→    userHistory,\n   223→    selectedTier,\n   224→    selectedSide,\n   225→    loading,\n   226→    creating,\n   227→    joining,\n   228→    claiming,\n   229→    joiningMatchId,\n   230→    setSelectedTier,\n   231→    setSelectedSide,\n   232→    createMatch,\n   233→    joinMatch,\n   234→    claimPayout,\n   235→    clearActiveMatch,\n   236→    refreshMatches,\n   237→  };\n   238→\n   239→  return (\n   240→    <CoinflipContext.Provider value={value}>\n   241→      {children}\n   242→    </CoinflipContext.Provider>\n   243→  );\n   244→}\n   245→\n   246→export function useCoinflip(): CoinflipContextValue {\n   247→  const context = useContext(CoinflipContext);\n   248→  if (!context) {\n   249→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   250→  }\n   251→  return context;\n   252→}\n   253→"}]},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"51f6018e-46e4-4d88-8f17-1eab0bc53689","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  type ReactNode,\n} from \"react\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  createMockMatch,\n  joinMockMatch,\n  claimMockPayout,\n  getOpenMatches,\n  getUserMatches,\n  subscribeToMatch,\n  generateMockOpenMatches,\n  getMockMatch,\n} from \"../utils/mock-simulation\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, address } = useWallet();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [userHistory, setUserHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Define refreshMatches before effects that use it\n  const refreshMatches = useCallback(() => {\n    const open = getOpenMatches();\n    setOpenMatches(open);\n\n    if (address) {\n      const history = getUserMatches(address)\n        .filter((m) => m.phase === \"complete\")\n        .sort((a, b) => (b.completedAt ?? b.createdAt) - (a.completedAt ?? a.createdAt));\n      setUserHistory(history);\n    }\n  }, [address]);\n\n  // Initialize mock matches\n  useEffect(() => {\n    setLoading(true);\n    // Generate random number of initial open matches (up to 30)\n    const randomCount = Math.floor(Math.random() * 30) + 1;\n    generateMockOpenMatches(randomCount);\n    refreshMatches();\n    setLoading(false);\n  }, [refreshMatches]);\n\n  // Poll for match updates\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n    }, 5000);\n    return () => clearInterval(interval);\n  }, [refreshMatches]);\n\n  // Subscribe to active match updates\n  useEffect(() => {\n    if (!activeMatch) return;\n\n    const unsubscribe = subscribeToMatch(activeMatch.id, (updated) => {\n      setActiveMatch(updated);\n\n      // If match is complete, refresh history\n      if (updated.phase === \"complete\") {\n        // Small delay to ensure store is fully updated\n        setTimeout(() => refreshMatches(), 100);\n      }\n    });\n\n    return unsubscribe;\n  }, [activeMatch?.id, refreshMatches]);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !address) {\n      throw new Error(\"Wallet not connected\");\n    }\n    if (!selectedTier || !selectedSide) {\n      throw new Error(\"Select tier and side first\");\n    }\n\n    setCreating(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      const match = createMockMatch(address, selectedTier, selectedSide);\n      setActiveMatch(match);\n\n      // Clear selection\n      setSelectedSide(null);\n\n      // Refresh matches list\n      refreshMatches();\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, address, selectedTier, selectedSide, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !address) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      try {\n        // Simulate transaction delay\n        await new Promise((resolve) => setTimeout(resolve, 500));\n\n        const match = joinMockMatch(matchId, address);\n        setActiveMatch(match);\n\n        // Refresh matches list\n        refreshMatches();\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, address, refreshMatches]\n  );\n\n  const claimPayout = useCallback(async () => {\n    if (!connected || !address || !activeMatch) {\n      throw new Error(\"No active match to claim\");\n    }\n\n    setClaiming(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      const updated = claimMockPayout(activeMatch.id, address);\n      setActiveMatch(updated);\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, address, activeMatch]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  const clearActiveMatch = useCallback(() => {\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    // Refresh to update history with completed match\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (address && !activeMatch && !userClearedMatch) {\n      const userMatches = getUserMatches(address);\n      const active = userMatches.find(\n        (m) => m.phase !== \"complete\" || (m.phase === \"complete\" && !m.claimed && m.winner === address)\n      );\n      if (active) {\n        // Re-fetch to ensure we have latest state\n        const latest = getMockMatch(active.id);\n        if (latest) {\n          setActiveMatch(latest);\n        }\n      }\n    }\n  }, [address, activeMatch, userClearedMatch]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    claimPayout,\n    clearActiveMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":253,"startLine":1,"totalLines":253}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LU9DLD5j2cZLhDEFPyxPJC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GQXF58otuxDrqN4cfDozNY","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/types.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":8444,"cache_read_input_tokens":32382,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":8444},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"42121296-43d7-40c1-970e-5612bc7f074b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GQXF58otuxDrqN4cfDozNY","type":"tool_result","content":"     1→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n     2→\n     3→export type CoinSide = \"heads\" | \"tails\";\n     4→export type CoinflipPhase = \"created\" | \"ready\" | \"countdown\" | \"flipping\" | \"complete\";\n     5→\n     6→/**\n     7→ * Simplified match type for UI/mock mode (doesn't require PublicKey)\n     8→ */\n     9→export interface UIMatch {\n    10→  id: string;\n    11→  tier: Tier;\n    12→  entryAmount: number; // in SOL\n    13→\n    14→  // Player 1 (creator)\n    15→  player1: string; // wallet address\n    16→  player1Side: CoinSide;\n    17→\n    18→  // Player 2 (joiner)\n    19→  player2: string | null;\n    20→  player2Side: CoinSide | null;\n    21→\n    22→  // Match state\n    23→  phase: CoinflipPhase;\n    24→  createdAt: number; // timestamp\n    25→  countdownStartedAt?: number; // when countdown started\n    26→  completedAt?: number;\n    27→\n    28→  // Result\n    29→  result: CoinSide | null;\n    30→  winner: string | null;\n    31→\n    32→  // Payout\n    33→  claimed: boolean;\n    34→  payoutAmount: number; // amount winner receives\n    35→\n    36→  // Provably Fair - VRF-based verification\n    37→  seedHash: string; // SHA-256 hash of server seed (shown before flip)\n    38→  serverSeed?: string; // Actual server seed (revealed only after settlement)\n    39→  vrfProof?: string; // VRF proof for on-chain verification\n    40→  blockHash?: string; // Solana blockhash used as entropy source\n    41→}\n    42→\n    43→export interface MatchFilter {\n    44→  tier?: Tier;\n    45→  status?: \"open\" | \"all\";\n    46→}\n    47→\n    48→export interface CreateMatchParams {\n    49→  tier: Tier;\n    50→  side: CoinSide;\n    51→}\n    52→\n    53→export interface JoinMatchParams {\n    54→  matchId: string;\n    55→}\n    56→"}]},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"e0bbdfb9-0e42-4569-ac5c-1c5165e73f03","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/types.ts","content":"import type { Tier } from \"@rng-utopia/game-engine/browser\";\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type CoinflipPhase = \"created\" | \"ready\" | \"countdown\" | \"flipping\" | \"complete\";\n\n/**\n * Simplified match type for UI/mock mode (doesn't require PublicKey)\n */\nexport interface UIMatch {\n  id: string;\n  tier: Tier;\n  entryAmount: number; // in SOL\n\n  // Player 1 (creator)\n  player1: string; // wallet address\n  player1Side: CoinSide;\n\n  // Player 2 (joiner)\n  player2: string | null;\n  player2Side: CoinSide | null;\n\n  // Match state\n  phase: CoinflipPhase;\n  createdAt: number; // timestamp\n  countdownStartedAt?: number; // when countdown started\n  completedAt?: number;\n\n  // Result\n  result: CoinSide | null;\n  winner: string | null;\n\n  // Payout\n  claimed: boolean;\n  payoutAmount: number; // amount winner receives\n\n  // Provably Fair - VRF-based verification\n  seedHash: string; // SHA-256 hash of server seed (shown before flip)\n  serverSeed?: string; // Actual server seed (revealed only after settlement)\n  vrfProof?: string; // VRF proof for on-chain verification\n  blockHash?: string; // Solana blockhash used as entropy source\n}\n\nexport interface MatchFilter {\n  tier?: Tier;\n  status?: \"open\" | \"all\";\n}\n\nexport interface CreateMatchParams {\n  tier: Tier;\n  side: CoinSide;\n}\n\nexport interface JoinMatchParams {\n  matchId: string;\n}\n","numLines":56,"startLine":1,"totalLines":56}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LU9DLD5j2cZLhDEFPyxPJC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GiPZB37cWMn2TFNe1rjtZP","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/mock-simulation.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":8444,"cache_read_input_tokens":32382,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":8444},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"259ce7f3-a8eb-4a7d-8426-4c08abc32560"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GiPZB37cWMn2TFNe1rjtZP","type":"tool_result","content":"     1→import { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\n     2→import type { UIMatch, CoinSide } from \"../types\";\n     3→import { emitCoinflipComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\n     4→import { emitCoinflipResults } from \"../../player-profile/utils/profile-event-bus\";\n     5→\n     6→// ============ Mock Store ============\n     7→\n     8→interface MockStore {\n     9→  matches: Map<string, UIMatch>;\n    10→  listeners: Map<string, Set<(match: UIMatch) => void>>;\n    11→}\n    12→\n    13→const store: MockStore = {\n    14→  matches: new Map(),\n    15→  listeners: new Map(),\n    16→};\n    17→\n    18→// ============ Helpers ============\n    19→\n    20→function generateMatchId(): string {\n    21→  return `mock-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n    22→}\n    23→\n    24→function generateMockAddress(): string {\n    25→  const chars = \"123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz\";\n    26→  let addr = \"\";\n    27→  for (let i = 0; i < 44; i++) {\n    28→    addr += chars[Math.floor(Math.random() * chars.length)];\n    29→  }\n    30→  return addr;\n    31→}\n    32→\n    33→function truncateAddress(address: string): string {\n    34→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n    35→}\n    36→\n    37→// Generate a mock hex string (simulates SHA-256 hash or seed)\n    38→function generateMockHexString(length: number = 64): string {\n    39→  const chars = \"0123456789abcdef\";\n    40→  let result = \"\";\n    41→  for (let i = 0; i < length; i++) {\n    42→    result += chars[Math.floor(Math.random() * chars.length)];\n    43→  }\n    44→  return result;\n    45→}\n    46→\n    47→// Generate mock provably fair data\n    48→function generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string; vrfProof: string } {\n    49→  const serverSeed = generateMockHexString(64); // 256-bit seed\n    50→  const seedHash = generateMockHexString(64); // SHA-256 hash of server seed\n    51→  const blockHash = generateMockHexString(88); // Solana blockhash format\n    52→  const vrfProof = generateMockHexString(128); // VRF proof\n    53→  return { seedHash, serverSeed, blockHash, vrfProof };\n    54→}\n    55→\n    56→// Store for server seeds (revealed after settlement)\n    57→const serverSeeds = new Map<string, { serverSeed: string; blockHash: string; vrfProof: string }>();\n    58→\n    59→function getOppositeSide(side: CoinSide): CoinSide {\n    60→  return side === \"heads\" ? \"tails\" : \"heads\";\n    61→}\n    62→\n    63→function calculatePayout(tier: Tier): number {\n    64→  const entry = TIER_AMOUNTS[tier];\n    65→  const totalPool = entry * 2;\n    66→  return totalPool * 0.97; // 97% after 3% fee\n    67→}\n    68→\n    69→function notifyListeners(matchId: string, match: UIMatch): void {\n    70→  const listeners = store.listeners.get(matchId);\n    71→  if (listeners) {\n    72→    // Create a new object reference so React detects the state change\n    73→    const matchCopy = { ...match };\n    74→    listeners.forEach((cb) => cb(matchCopy));\n    75→  }\n    76→}\n    77→\n    78→// ============ Mock Match Operations ============\n    79→\n    80→export function createMockMatch(\n    81→  playerAddress: string,\n    82→  tier: Tier,\n    83→  side: CoinSide\n    84→): UIMatch {\n    85→  const id = generateMatchId();\n    86→  const fairnessData = generateFairnessData();\n    87→\n    88→  // Store the secret data to reveal later\n    89→  serverSeeds.set(id, {\n    90→    serverSeed: fairnessData.serverSeed,\n    91→    blockHash: fairnessData.blockHash,\n    92→    vrfProof: fairnessData.vrfProof,\n    93→  });\n    94→\n    95→  const match: UIMatch = {\n    96→    id,\n    97→    tier,\n    98→    entryAmount: TIER_AMOUNTS[tier],\n    99→    player1: playerAddress,\n   100→    player1Side: side,\n   101→    player2: null,\n   102→    player2Side: null,\n   103→    phase: \"created\",\n   104→    createdAt: Date.now(),\n   105→    result: null,\n   106→    winner: null,\n   107→    claimed: false,\n   108→    payoutAmount: calculatePayout(tier),\n   109→    seedHash: fairnessData.seedHash, // Public from the start\n   110→  };\n   111→\n   112→  store.matches.set(id, match);\n   113→\n   114→  // Emit wager placed event (triggers RNG buff chest drop check)\n   115→  emitWagerPlaced(\"coinflip\", id, playerAddress, TIER_AMOUNTS[tier]);\n   116→\n   117→  // Auto-simulate opponent joining after 3-10 seconds\n   118→  const delay = 3000 + Math.random() * 7000;\n   119→  setTimeout(() => simulateOpponentJoin(id), delay);\n   120→\n   121→  return match;\n   122→}\n   123→\n   124→export function simulateOpponentJoin(matchId: string): void {\n   125→  const match = store.matches.get(matchId);\n   126→  if (!match || match.phase !== \"created\") return;\n   127→\n   128→  // Add fake opponent\n   129→  match.player2 = generateMockAddress();\n   130→  match.player2Side = getOppositeSide(match.player1Side);\n   131→  match.phase = \"ready\";\n   132→\n   133→  store.matches.set(matchId, match);\n   134→  notifyListeners(matchId, match);\n   135→\n   136→  // Start countdown after brief delay\n   137→  setTimeout(() => startCountdown(matchId), 500);\n   138→}\n   139→\n   140→export function startCountdown(matchId: string): void {\n   141→  const match = store.matches.get(matchId);\n   142→  if (!match || match.phase !== \"ready\") return;\n   143→\n   144→  match.phase = \"countdown\";\n   145→  match.countdownStartedAt = Date.now();\n   146→\n   147→  store.matches.set(matchId, match);\n   148→  notifyListeners(matchId, match);\n   149→\n   150→  // After 3 seconds countdown, start flipping\n   151→  setTimeout(() => startFlipping(matchId), 3000);\n   152→}\n   153→\n   154→export function startFlipping(matchId: string): void {\n   155→  const match = store.matches.get(matchId);\n   156→  if (!match || match.phase !== \"countdown\") return;\n   157→\n   158→  // Determine result NOW (simulates VRF request) so animation lands on correct side\n   159→  const result: CoinSide = Math.random() < 0.5 ? \"heads\" : \"tails\";\n   160→  match.result = result;\n   161→  match.phase = \"flipping\";\n   162→\n   163→  store.matches.set(matchId, match);\n   164→  notifyListeners(matchId, match);\n   165→\n   166→  // Reveal winner after 3 seconds (flip animation time)\n   167→  setTimeout(() => resolveMatch(matchId), 3000);\n   168→}\n   169→\n   170→export function resolveMatch(matchId: string): void {\n   171→  const match = store.matches.get(matchId);\n   172→  if (!match || match.phase !== \"flipping\" || !match.result) return;\n   173→\n   174→  // Reveal the fairness data now that the match is settled\n   175→  const secrets = serverSeeds.get(matchId);\n   176→  if (secrets) {\n   177→    match.serverSeed = secrets.serverSeed;\n   178→    match.blockHash = secrets.blockHash;\n   179→    match.vrfProof = secrets.vrfProof;\n   180→  }\n   181→\n   182→  // Determine winner based on pre-determined result\n   183→  match.winner =\n   184→    match.result === match.player1Side\n   185→      ? match.player1\n   186→      : match.player2;\n   187→  match.phase = \"complete\";\n   188→  match.completedAt = Date.now();\n   189→\n   190→  store.matches.set(matchId, match);\n   191→  notifyListeners(matchId, match);\n   192→\n   193→  // Emit event for Boss Raid\n   194→  if (match.player2) {\n   195→    emitCoinflipComplete(matchId, match.player1, match.player2, match.entryAmount);\n   196→  }\n   197→\n   198→  // Emit event for Player Profile (XP and stats tracking)\n   199→  if (match.player2 && match.winner) {\n   200→    const loser = match.winner === match.player1 ? match.player2 : match.player1;\n   201→    emitCoinflipResults(\n   202→      match.id,\n   203→      match.winner,\n   204→      loser,\n   205→      match.entryAmount,\n   206→      match.payoutAmount,\n   207→      match.tier\n   208→    );\n   209→  }\n   210→}\n   211→\n   212→// Legacy function for compatibility\n   213→export function simulateVRF(matchId: string): void {\n   214→  startCountdown(matchId);\n   215→}\n   216→\n   217→export function joinMockMatch(matchId: string, playerAddress: string): UIMatch {\n   218→  const match = store.matches.get(matchId);\n   219→  if (!match) throw new Error(\"Match not found\");\n   220→  if (match.phase !== \"created\") throw new Error(\"Match not available\");\n   221→  if (match.player1 === playerAddress) throw new Error(\"Cannot join own match\");\n   222→\n   223→  // Join the match\n   224→  match.player2 = playerAddress;\n   225→  match.player2Side = getOppositeSide(match.player1Side);\n   226→  match.phase = \"ready\";\n   227→\n   228→  store.matches.set(matchId, match);\n   229→  notifyListeners(matchId, match);\n   230→\n   231→  // Emit wager placed event (triggers RNG buff chest drop check)\n   232→  emitWagerPlaced(\"coinflip\", matchId, playerAddress, match.entryAmount);\n   233→\n   234→  // Start countdown after brief delay\n   235→  setTimeout(() => startCountdown(matchId), 500);\n   236→\n   237→  return match;\n   238→}\n   239→\n   240→export function claimMockPayout(\n   241→  matchId: string,\n   242→  playerAddress: string\n   243→): UIMatch {\n   244→  const match = store.matches.get(matchId);\n   245→  if (!match) throw new Error(\"Match not found\");\n   246→  if (match.phase !== \"complete\") throw new Error(\"Match not complete\");\n   247→  if (match.winner !== playerAddress) throw new Error(\"You are not the winner\");\n   248→  if (match.claimed) throw new Error(\"Already claimed\");\n   249→\n   250→  match.claimed = true;\n   251→  store.matches.set(matchId, match);\n   252→  notifyListeners(matchId, match);\n   253→\n   254→  return match;\n   255→}\n   256→\n   257→export function getMockMatch(matchId: string): UIMatch | undefined {\n   258→  return store.matches.get(matchId);\n   259→}\n   260→\n   261→// ============ Match Subscription ============\n   262→\n   263→export function subscribeToMatch(\n   264→  matchId: string,\n   265→  callback: (match: UIMatch) => void\n   266→): () => void {\n   267→  if (!store.listeners.has(matchId)) {\n   268→    store.listeners.set(matchId, new Set());\n   269→  }\n   270→  store.listeners.get(matchId)!.add(callback);\n   271→\n   272→  return () => {\n   273→    store.listeners.get(matchId)?.delete(callback);\n   274→  };\n   275→}\n   276→\n   277→// ============ Open Matches ============\n   278→\n   279→const TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   280→\n   281→// Maximum open matches per tier to keep the list manageable\n   282→const MAX_MATCHES_PER_TIER = 12;\n   283→const MAX_TOTAL_MATCHES = 60; // 12 per tier × 6 tiers max\n   284→\n   285→export function generateMockOpenMatches(count: number = 5): UIMatch[] {\n   286→  const matches: UIMatch[] = [];\n   287→\n   288→  // Count existing open matches per tier\n   289→  const tierCounts: Record<Tier, number> = {\n   290→    iron: 0,\n   291→    bronze: 0,\n   292→    silver: 0,\n   293→    gold: 0,\n   294→    platinum: 0,\n   295→    diamond: 0,\n   296→  };\n   297→\n   298→  store.matches.forEach((match) => {\n   299→    if (match.phase === \"created\") {\n   300→      tierCounts[match.tier]++;\n   301→    }\n   302→  });\n   303→\n   304→  for (let i = 0; i < count; i++) {\n   305→    const tier = TIERS[Math.floor(Math.random() * TIERS.length)] ?? \"iron\";\n   306→\n   307→    // Skip if this tier is already at max\n   308→    if (tierCounts[tier] >= MAX_MATCHES_PER_TIER) {\n   309→      continue;\n   310→    }\n   311→\n   312→    const side: CoinSide = Math.random() < 0.5 ? \"heads\" : \"tails\";\n   313→\n   314→    const fairnessData = generateFairnessData();\n   315→    const matchId = generateMatchId();\n   316→\n   317→    // Store secret for later reveal\n   318→    serverSeeds.set(matchId, {\n   319→      serverSeed: fairnessData.serverSeed,\n   320→      blockHash: fairnessData.blockHash,\n   321→      vrfProof: fairnessData.vrfProof,\n   322→    });\n   323→\n   324→    const match: UIMatch = {\n   325→      id: matchId,\n   326→      tier,\n   327→      entryAmount: TIER_AMOUNTS[tier],\n   328→      player1: generateMockAddress(),\n   329→      player1Side: side,\n   330→      player2: null,\n   331→      player2Side: null,\n   332→      phase: \"created\",\n   333→      createdAt: Date.now() - Math.random() * 120000, // Random time in last 2 minutes\n   334→      result: null,\n   335→      winner: null,\n   336→      claimed: false,\n   337→      payoutAmount: calculatePayout(tier),\n   338→      seedHash: fairnessData.seedHash,\n   339→    };\n   340→\n   341→    store.matches.set(match.id, match);\n   342→    matches.push(match);\n   343→    tierCounts[tier]++;\n   344→  }\n   345→\n   346→  return matches;\n   347→}\n   348→\n   349→export function getOpenMatches(filter?: { tier?: Tier }): UIMatch[] {\n   350→  const matches: UIMatch[] = [];\n   351→\n   352→  store.matches.forEach((match) => {\n   353→    if (match.phase !== \"created\") return;\n   354→    if (filter?.tier && match.tier !== filter.tier) return;\n   355→    matches.push(match);\n   356→  });\n   357→\n   358→  // Sort by creation time (newest first)\n   359→  const sorted = matches.sort((a, b) => b.createdAt - a.createdAt);\n   360→\n   361→  // If filtering by tier, limit to MAX_MATCHES_PER_TIER\n   362→  // Otherwise limit to MAX_TOTAL_MATCHES\n   363→  const limit = filter?.tier ? MAX_MATCHES_PER_TIER : MAX_TOTAL_MATCHES;\n   364→  return sorted.slice(0, limit);\n   365→}\n   366→\n   367→export function getUserMatches(playerAddress: string): UIMatch[] {\n   368→  const matches: UIMatch[] = [];\n   369→\n   370→  store.matches.forEach((match) => {\n   371→    if (match.player1 === playerAddress || match.player2 === playerAddress) {\n   372→      matches.push(match);\n   373→    }\n   374→  });\n   375→\n   376→  // Sort by creation time (newest first)\n   377→  return matches.sort((a, b) => b.createdAt - a.createdAt);\n   378→}\n   379→\n   380→// ============ Utilities ============\n   381→\n   382→export { truncateAddress, getOppositeSide, calculatePayout };\n   383→"}]},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"14632f8a-c52f-4580-9bea-9da61d8f48d9","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/mock-simulation.ts","content":"import { TIER_AMOUNTS, type Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport { emitCoinflipComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\nimport { emitCoinflipResults } from \"../../player-profile/utils/profile-event-bus\";\n\n// ============ Mock Store ============\n\ninterface MockStore {\n  matches: Map<string, UIMatch>;\n  listeners: Map<string, Set<(match: UIMatch) => void>>;\n}\n\nconst store: MockStore = {\n  matches: new Map(),\n  listeners: new Map(),\n};\n\n// ============ Helpers ============\n\nfunction generateMatchId(): string {\n  return `mock-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n}\n\nfunction generateMockAddress(): string {\n  const chars = \"123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz\";\n  let addr = \"\";\n  for (let i = 0; i < 44; i++) {\n    addr += chars[Math.floor(Math.random() * chars.length)];\n  }\n  return addr;\n}\n\nfunction truncateAddress(address: string): string {\n  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n}\n\n// Generate a mock hex string (simulates SHA-256 hash or seed)\nfunction generateMockHexString(length: number = 64): string {\n  const chars = \"0123456789abcdef\";\n  let result = \"\";\n  for (let i = 0; i < length; i++) {\n    result += chars[Math.floor(Math.random() * chars.length)];\n  }\n  return result;\n}\n\n// Generate mock provably fair data\nfunction generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string; vrfProof: string } {\n  const serverSeed = generateMockHexString(64); // 256-bit seed\n  const seedHash = generateMockHexString(64); // SHA-256 hash of server seed\n  const blockHash = generateMockHexString(88); // Solana blockhash format\n  const vrfProof = generateMockHexString(128); // VRF proof\n  return { seedHash, serverSeed, blockHash, vrfProof };\n}\n\n// Store for server seeds (revealed after settlement)\nconst serverSeeds = new Map<string, { serverSeed: string; blockHash: string; vrfProof: string }>();\n\nfunction getOppositeSide(side: CoinSide): CoinSide {\n  return side === \"heads\" ? \"tails\" : \"heads\";\n}\n\nfunction calculatePayout(tier: Tier): number {\n  const entry = TIER_AMOUNTS[tier];\n  const totalPool = entry * 2;\n  return totalPool * 0.97; // 97% after 3% fee\n}\n\nfunction notifyListeners(matchId: string, match: UIMatch): void {\n  const listeners = store.listeners.get(matchId);\n  if (listeners) {\n    // Create a new object reference so React detects the state change\n    const matchCopy = { ...match };\n    listeners.forEach((cb) => cb(matchCopy));\n  }\n}\n\n// ============ Mock Match Operations ============\n\nexport function createMockMatch(\n  playerAddress: string,\n  tier: Tier,\n  side: CoinSide\n): UIMatch {\n  const id = generateMatchId();\n  const fairnessData = generateFairnessData();\n\n  // Store the secret data to reveal later\n  serverSeeds.set(id, {\n    serverSeed: fairnessData.serverSeed,\n    blockHash: fairnessData.blockHash,\n    vrfProof: fairnessData.vrfProof,\n  });\n\n  const match: UIMatch = {\n    id,\n    tier,\n    entryAmount: TIER_AMOUNTS[tier],\n    player1: playerAddress,\n    player1Side: side,\n    player2: null,\n    player2Side: null,\n    phase: \"created\",\n    createdAt: Date.now(),\n    result: null,\n    winner: null,\n    claimed: false,\n    payoutAmount: calculatePayout(tier),\n    seedHash: fairnessData.seedHash, // Public from the start\n  };\n\n  store.matches.set(id, match);\n\n  // Emit wager placed event (triggers RNG buff chest drop check)\n  emitWagerPlaced(\"coinflip\", id, playerAddress, TIER_AMOUNTS[tier]);\n\n  // Auto-simulate opponent joining after 3-10 seconds\n  const delay = 3000 + Math.random() * 7000;\n  setTimeout(() => simulateOpponentJoin(id), delay);\n\n  return match;\n}\n\nexport function simulateOpponentJoin(matchId: string): void {\n  const match = store.matches.get(matchId);\n  if (!match || match.phase !== \"created\") return;\n\n  // Add fake opponent\n  match.player2 = generateMockAddress();\n  match.player2Side = getOppositeSide(match.player1Side);\n  match.phase = \"ready\";\n\n  store.matches.set(matchId, match);\n  notifyListeners(matchId, match);\n\n  // Start countdown after brief delay\n  setTimeout(() => startCountdown(matchId), 500);\n}\n\nexport function startCountdown(matchId: string): void {\n  const match = store.matches.get(matchId);\n  if (!match || match.phase !== \"ready\") return;\n\n  match.phase = \"countdown\";\n  match.countdownStartedAt = Date.now();\n\n  store.matches.set(matchId, match);\n  notifyListeners(matchId, match);\n\n  // After 3 seconds countdown, start flipping\n  setTimeout(() => startFlipping(matchId), 3000);\n}\n\nexport function startFlipping(matchId: string): void {\n  const match = store.matches.get(matchId);\n  if (!match || match.phase !== \"countdown\") return;\n\n  // Determine result NOW (simulates VRF request) so animation lands on correct side\n  const result: CoinSide = Math.random() < 0.5 ? \"heads\" : \"tails\";\n  match.result = result;\n  match.phase = \"flipping\";\n\n  store.matches.set(matchId, match);\n  notifyListeners(matchId, match);\n\n  // Reveal winner after 3 seconds (flip animation time)\n  setTimeout(() => resolveMatch(matchId), 3000);\n}\n\nexport function resolveMatch(matchId: string): void {\n  const match = store.matches.get(matchId);\n  if (!match || match.phase !== \"flipping\" || !match.result) return;\n\n  // Reveal the fairness data now that the match is settled\n  const secrets = serverSeeds.get(matchId);\n  if (secrets) {\n    match.serverSeed = secrets.serverSeed;\n    match.blockHash = secrets.blockHash;\n    match.vrfProof = secrets.vrfProof;\n  }\n\n  // Determine winner based on pre-determined result\n  match.winner =\n    match.result === match.player1Side\n      ? match.player1\n      : match.player2;\n  match.phase = \"complete\";\n  match.completedAt = Date.now();\n\n  store.matches.set(matchId, match);\n  notifyListeners(matchId, match);\n\n  // Emit event for Boss Raid\n  if (match.player2) {\n    emitCoinflipComplete(matchId, match.player1, match.player2, match.entryAmount);\n  }\n\n  // Emit event for Player Profile (XP and stats tracking)\n  if (match.player2 && match.winner) {\n    const loser = match.winner === match.player1 ? match.player2 : match.player1;\n    emitCoinflipResults(\n      match.id,\n      match.winner,\n      loser,\n      match.entryAmount,\n      match.payoutAmount,\n      match.tier\n    );\n  }\n}\n\n// Legacy function for compatibility\nexport function simulateVRF(matchId: string): void {\n  startCountdown(matchId);\n}\n\nexport function joinMockMatch(matchId: string, playerAddress: string): UIMatch {\n  const match = store.matches.get(matchId);\n  if (!match) throw new Error(\"Match not found\");\n  if (match.phase !== \"created\") throw new Error(\"Match not available\");\n  if (match.player1 === playerAddress) throw new Error(\"Cannot join own match\");\n\n  // Join the match\n  match.player2 = playerAddress;\n  match.player2Side = getOppositeSide(match.player1Side);\n  match.phase = \"ready\";\n\n  store.matches.set(matchId, match);\n  notifyListeners(matchId, match);\n\n  // Emit wager placed event (triggers RNG buff chest drop check)\n  emitWagerPlaced(\"coinflip\", matchId, playerAddress, match.entryAmount);\n\n  // Start countdown after brief delay\n  setTimeout(() => startCountdown(matchId), 500);\n\n  return match;\n}\n\nexport function claimMockPayout(\n  matchId: string,\n  playerAddress: string\n): UIMatch {\n  const match = store.matches.get(matchId);\n  if (!match) throw new Error(\"Match not found\");\n  if (match.phase !== \"complete\") throw new Error(\"Match not complete\");\n  if (match.winner !== playerAddress) throw new Error(\"You are not the winner\");\n  if (match.claimed) throw new Error(\"Already claimed\");\n\n  match.claimed = true;\n  store.matches.set(matchId, match);\n  notifyListeners(matchId, match);\n\n  return match;\n}\n\nexport function getMockMatch(matchId: string): UIMatch | undefined {\n  return store.matches.get(matchId);\n}\n\n// ============ Match Subscription ============\n\nexport function subscribeToMatch(\n  matchId: string,\n  callback: (match: UIMatch) => void\n): () => void {\n  if (!store.listeners.has(matchId)) {\n    store.listeners.set(matchId, new Set());\n  }\n  store.listeners.get(matchId)!.add(callback);\n\n  return () => {\n    store.listeners.get(matchId)?.delete(callback);\n  };\n}\n\n// ============ Open Matches ============\n\nconst TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\n// Maximum open matches per tier to keep the list manageable\nconst MAX_MATCHES_PER_TIER = 12;\nconst MAX_TOTAL_MATCHES = 60; // 12 per tier × 6 tiers max\n\nexport function generateMockOpenMatches(count: number = 5): UIMatch[] {\n  const matches: UIMatch[] = [];\n\n  // Count existing open matches per tier\n  const tierCounts: Record<Tier, number> = {\n    iron: 0,\n    bronze: 0,\n    silver: 0,\n    gold: 0,\n    platinum: 0,\n    diamond: 0,\n  };\n\n  store.matches.forEach((match) => {\n    if (match.phase === \"created\") {\n      tierCounts[match.tier]++;\n    }\n  });\n\n  for (let i = 0; i < count; i++) {\n    const tier = TIERS[Math.floor(Math.random() * TIERS.length)] ?? \"iron\";\n\n    // Skip if this tier is already at max\n    if (tierCounts[tier] >= MAX_MATCHES_PER_TIER) {\n      continue;\n    }\n\n    const side: CoinSide = Math.random() < 0.5 ? \"heads\" : \"tails\";\n\n    const fairnessData = generateFairnessData();\n    const matchId = generateMatchId();\n\n    // Store secret for later reveal\n    serverSeeds.set(matchId, {\n      serverSeed: fairnessData.serverSeed,\n      blockHash: fairnessData.blockHash,\n      vrfProof: fairnessData.vrfProof,\n    });\n\n    const match: UIMatch = {\n      id: matchId,\n      tier,\n      entryAmount: TIER_AMOUNTS[tier],\n      player1: generateMockAddress(),\n      player1Side: side,\n      player2: null,\n      player2Side: null,\n      phase: \"created\",\n      createdAt: Date.now() - Math.random() * 120000, // Random time in last 2 minutes\n      result: null,\n      winner: null,\n      claimed: false,\n      payoutAmount: calculatePayout(tier),\n      seedHash: fairnessData.seedHash,\n    };\n\n    store.matches.set(match.id, match);\n    matches.push(match);\n    tierCounts[tier]++;\n  }\n\n  return matches;\n}\n\nexport function getOpenMatches(filter?: { tier?: Tier }): UIMatch[] {\n  const matches: UIMatch[] = [];\n\n  store.matches.forEach((match) => {\n    if (match.phase !== \"created\") return;\n    if (filter?.tier && match.tier !== filter.tier) return;\n    matches.push(match);\n  });\n\n  // Sort by creation time (newest first)\n  const sorted = matches.sort((a, b) => b.createdAt - a.createdAt);\n\n  // If filtering by tier, limit to MAX_MATCHES_PER_TIER\n  // Otherwise limit to MAX_TOTAL_MATCHES\n  const limit = filter?.tier ? MAX_MATCHES_PER_TIER : MAX_TOTAL_MATCHES;\n  return sorted.slice(0, limit);\n}\n\nexport function getUserMatches(playerAddress: string): UIMatch[] {\n  const matches: UIMatch[] = [];\n\n  store.matches.forEach((match) => {\n    if (match.player1 === playerAddress || match.player2 === playerAddress) {\n      matches.push(match);\n    }\n  });\n\n  // Sort by creation time (newest first)\n  return matches.sort((a, b) => b.createdAt - a.createdAt);\n}\n\n// ============ Utilities ============\n\nexport { truncateAddress, getOppositeSide, calculatePayout };\n","numLines":383,"startLine":1,"totalLines":383}}}
