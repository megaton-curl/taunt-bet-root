   134→  complete: 3,\n   135→};\n   136→\n   137→export interface CoinflipState {\n   138→  pool: PublicKey;\n   139→  player1: PublicKey;\n   140→  player2: PublicKey | null;\n   141→  player1Side: CoinSide;\n   142→  result: CoinSide | null;\n   143→  phase: CoinflipPhase;\n   144→  createdAt: Date;\n   145→  joinedAt: Date | null;\n   146→  flippedAt: Date | null;\n   147→  joinTimeoutSecs: number;\n   148→}\n   149→\n   150→export interface CoinflipMatch {\n   151→  pool: Pool;\n   152→  state: CoinflipState;\n   153→  player1Entry: PlayerEntry;\n   154→  player2Entry: PlayerEntry | null;\n   155→}\n   156→\n   157→// ============ Legacy Types (for backwards compatibility) ============\n   158→\n   159→/** @deprecated Use Pool instead */\n   160→export interface PoolState {\n   161→  roundId: string;\n   162→  gameId: string;\n   163→  tier: Tier;\n   164→  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n   165→  entries: LegacyPlayerEntry[];\n   166→  totalPool: number;\n   167→  createdAt: number;\n   168→  settledAt?: number;\n   169→  outcome?: unknown;\n   170→}\n   171→\n   172→/** @deprecated Use PlayerEntry instead */\n   173→export interface LegacyPlayerEntry {\n   174→  playerId: string;\n   175→  publicKey: string;\n   176→  tier: Tier;\n   177→  amount: number;\n   178→  timestamp: number;\n   179→  side?: \"green\" | \"red\";\n   180→  cashoutMultiplier?: number;\n   181→}\n   182→\n   183→// ============ Game IDs ============\n   184→\n   185→export const GAME_IDS = {\n   186→  COINFLIP: \"coinflip\",\n   187→  LORD_OF_RNGS: \"lord-of-rngs\",\n   188→  CRASH: \"crash\",\n   189→  CLOSE_CALL: \"close-call\",\n   190→  SLOTS: \"slots\",\n   191→  GAME_OF_TRADES: \"game-of-trades\",\n   192→  TUG_OF_EARN: \"tug-of-earn\",\n   193→  CHART_COURSE: \"chart-course\",\n   194→} as const;\n   195→\n   196→export type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n   197→\n   198→// ============ XP System ============\n   