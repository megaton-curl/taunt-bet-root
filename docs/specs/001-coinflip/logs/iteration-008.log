{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ee6rpw6rh43VYbsfD7ioL","type":"tool_result","content":"     1→import { useState, useEffect } from \"react\";\n     2→import type { UIMatch } from \"../types\";\n     3→import { CoinAnimation } from \"./CoinAnimation\";\n     4→import { getOppositeSide } from \"../utils/mock-simulation\";\n     5→import { PlayerAvatarCompact } from \"../../player-profile\";\n     6→\n     7→interface ActiveMatchViewProps {\n     8→  match: UIMatch;\n     9→  currentUserAddress: string;\n    10→}\n    11→\n    12→export function ActiveMatchView({\n    13→  match,\n    14→  currentUserAddress,\n    15→}: ActiveMatchViewProps) {\n    16→  const isPlayer1 = match.player1 === currentUserAddress;\n    17→  const isWinner = match.winner === currentUserAddress;\n    18→\n    19→  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    20→  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n    21→  const opponent = isPlayer1 ? match.player2 : match.player1;\n    22→\n    23→  // Countdown timer\n    24→  const [countdown, setCountdown] = useState(3);\n    25→\n    26→  useEffect(() => {\n    27→    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n    28→      // Always start at 3\n    29→      setCountdown(3);\n    30→\n    31→      const updateCountdown = () => {\n    32→        const elapsed = Date.now() - match.countdownStartedAt!;\n    33→        // Each number shows for exactly 1 second:\n    34→        // 0-999ms: show 3\n    35→        // 1000-1999ms: show 2\n    36→        // 2000-2999ms: show 1\n    37→        if (elapsed < 1000) {\n    38→          setCountdown(3);\n    39→        } else if (elapsed < 2000) {\n    40→          setCountdown(2);\n    41→        } else {\n    42→          setCountdown(1);\n    43→        }\n    44→      };\n    45→\n    46→      const interval = setInterval(updateCountdown, 50);\n    47→      return () => {\n    48→        clearInterval(interval);\n    49→        // Reset for next countdown\n    50→        setCountdown(3);\n    51→      };\n    52→    }\n    53→  }, [match.phase, match.countdownStartedAt]);\n    54→\n    55→  return (\n    56→    <div className=\"coinflip-active-match\">\n    57→      {/* Waiting for opponent */}\n    58→      {match.phase === \"created\" && (\n    59→        <div className=\"coinflip-active-match__waiting\">\n    60→          <h3 className=\"coinflip-active-match__title\">Waiting for Opponent</h3>\n    61→          <div className=\"coinflip-active-match__info\">\n    62→            <p>\n    63→              Your side: <strong className={`side-${match.player1Side}`}>\n    64→                {match.player1Side.toUpperCase()}\n    65→              </strong>\n    66→            </p>\n    67→            <p>Entry: <strong>{match.entryAmount} SOL</strong></p>\n    68→          </div>\n    69→          <div className=\"coinflip-waiting__spinner\" />\n    70→          <p className=\"coinflip-active-match__hint\">\n    71→            Someone will join soon...\n    72→          </p>\n    73→        </div>\n    74→      )}\n    75→\n    76→      {/* Ready / Countdown */}\n    77→      {(match.phase === \"ready\" || match.phase === \"countdown\") && (\n    78→        <div className=\"coinflip-active-match__playing\">\n    79→          <h3 className=\"coinflip-active-match__title\">\n    80→            {match.phase === \"ready\" && \"Game Ready!\"}\n    81→            {match.phase === \"countdown\" && (\n    82→              <span className=\"coinflip-countdown-inline\">\n    83→                Flipping in... <span className=\"coinflip-countdown-inline__number\">{countdown}</span>\n    84→              </span>\n    85→            )}\n    86→          </h3>\n    87→\n    88→          <div className=\"coinflip-active-match__players\">\n    89→            <div className=\"coinflip-player coinflip-player--you\">\n    90→              <span className=\"coinflip-player__label\">\n    91→                <PlayerAvatarCompact address={currentUserAddress} />\n    92→              </span>\n    93→              <span className={`coinflip-player__side side-${yourSide}`}>\n    94→                {yourSide?.toUpperCase()}\n    95→              </span>\n    96→            </div>\n    97→\n    98→            <span className=\"coinflip-active-match__vs\">VS</span>\n    99→\n   100→            <div className=\"coinflip-player coinflip-player--opponent\">\n   101→              <span className=\"coinflip-player__label\">\n   102→                {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n   103→              </span>\n   104→              <span className={`coinflip-player__side side-${opponentSide}`}>\n   105→                {opponentSide?.toUpperCase()}\n   106→              </span>\n   107→            </div>\n   108→          </div>\n   109→\n   110→          {/* Static coin for ready/countdown phases */}\n   111→          <CoinAnimation\n   112→            isFlipping={false}\n   113→            result={null}\n   114→            initialSide={yourSide ?? \"heads\"}\n   115→            size=\"lg\"\n   116→          />\n   117→\n   118→        </div>\n   119→      )}\n   120→\n   121→      {/* Flipping / Complete - same container so coin persists through transition */}\n   122→      {(match.phase === \"flipping\" || match.phase === \"complete\") && (\n   123→        <div className=\"coinflip-active-match__playing\">\n   124→          <h3 className={`coinflip-active-match__title ${\n   125→            match.phase === \"complete\" ? (isWinner ? \"coinflip-active-match__title--won\" : \"coinflip-active-match__title--lost\") : \"\"\n   126→          }`}>\n   127→            {match.phase === \"flipping\" && \"Flipping!\"}\n   128→            {match.phase === \"complete\" && isWinner && \"You Won!\"}\n   129→            {match.phase === \"complete\" && !isWinner && (\n   130→              <span className=\"coinflip-lose-title\">\n   131→                You Lost{\" \"}\n   132→                <span className=\"coinflip-lose-title__heart\">💔</span>\n   133→                <span className=\"coinflip-lose-title__shards\">\n   134→                  {[...Array(5)].map((_, i) => (\n   135→                    <span key={i} className=\"coinflip-lose-title__shard\" style={{ '--shard-index': i } as React.CSSProperties}>◆</span>\n   136→                  ))}\n   137→                </span>\n   138→              </span>\n   139→            )}\n   140→          </h3>\n   141→\n   142→          {/* Players info during flipping */}\n   143→          {match.phase === \"flipping\" && (\n   144→            <div className=\"coinflip-active-match__players\">\n   145→              <div className=\"coinflip-player coinflip-player--you\">\n   146→                <span className=\"coinflip-player__label\">\n   147→                  <PlayerAvatarCompact address={currentUserAddress} />\n   148→                </span>\n   149→                <span className={`coinflip-player__side side-${yourSide}`}>\n   150→                  {yourSide?.toUpperCase()}\n   151→                </span>\n   152→              </div>\n   153→\n   154→              <span className=\"coinflip-active-match__vs\">VS</span>\n   155→\n   156→              <div className=\"coinflip-player coinflip-player--opponent\">\n   157→                <span className=\"coinflip-player__label\">\n   158→                  {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n   159→                </span>\n   160→                <span className={`coinflip-player__side side-${opponentSide}`}>\n   161→                  {opponentSide?.toUpperCase()}\n   162→                </span>\n   163→              </div>\n   164→            </div>\n   165→          )}\n   166→\n   167→          {/* Single coin that persists through flipping → complete */}\n   168→          <CoinAnimation\n   169→            isFlipping={match.phase === \"flipping\"}\n   170→            result={match.result}\n   171→            initialSide={yourSide ?? \"heads\"}\n   172→            size=\"lg\"\n   173→          />\n   174→\n   175→          {/* Result info during complete */}\n   176→          {match.phase === \"complete\" && (\n   177→            <>\n   178→              {/* Win Animation - Arcade star burst */}\n   179→              {isWinner && (\n   180→                <div className=\"coinflip-win-animation\">\n   181→                  <div className=\"coinflip-win-animation__stars\">\n   182→                    {[...Array(8)].map((_, i) => (\n   183→                      <span key={i} className=\"coinflip-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n   184→                    ))}\n   185→                  </div>\n   186→                  <div className=\"coinflip-win-animation__coins\">\n   187→                    {[...Array(6)].map((_, i) => (\n   188→                      <span key={i} className=\"coinflip-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n   189→                    ))}\n   190→                  </div>\n   191→                </div>\n   192→              )}\n   193→\n   194→              <div\n   195→                className={`coinflip-result ${\n   196→                  isWinner ? \"coinflip-result--won\" : \"coinflip-result--lost\"\n   197→                }`}\n   198→              >\n   199→                <p className=\"coinflip-result__outcome\">\n   200→                  Result: <strong\n   201→                    style={{\n   202→                      color: match.result === \"heads\" ? \"#00cc88\" : \"#ff6644\",\n   203→                      textShadow: `0 0 6px ${match.result === \"heads\" ? \"#00cc88\" : \"#ff6644\"}`\n   204→                    }}\n   205→                  >{match.result?.toUpperCase()}</strong>\n   206→                </p>\n   207→                {isWinner && (\n   208→                  <p className=\"coinflip-result__payout\">\n   209→                    Payout: <strong>{match.payoutAmount.toFixed(4)} SOL</strong>\n   210→                  </p>\n   211→                )}\n   212→              </div>\n   213→\n   214→            </>\n   215→          )}\n   216→        </div>\n   217→      )}\n   218→    </div>\n   219→  );\n   220→}\n   221→"}]},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"c4ee2d09-9bb0-415f-8421-7d8404a6f1fe","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/components/ActiveMatchView.tsx","content":"import { useState, useEffect } from \"react\";\nimport type { UIMatch } from \"../types\";\nimport { CoinAnimation } from \"./CoinAnimation\";\nimport { getOppositeSide } from \"../utils/mock-simulation\";\nimport { PlayerAvatarCompact } from \"../../player-profile\";\n\ninterface ActiveMatchViewProps {\n  match: UIMatch;\n  currentUserAddress: string;\n}\n\nexport function ActiveMatchView({\n  match,\n  currentUserAddress,\n}: ActiveMatchViewProps) {\n  const isPlayer1 = match.player1 === currentUserAddress;\n  const isWinner = match.winner === currentUserAddress;\n\n  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n  const opponent = isPlayer1 ? match.player2 : match.player1;\n\n  // Countdown timer\n  const [countdown, setCountdown] = useState(3);\n\n  useEffect(() => {\n    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n      // Always start at 3\n      setCountdown(3);\n\n      const updateCountdown = () => {\n        const elapsed = Date.now() - match.countdownStartedAt!;\n        // Each number shows for exactly 1 second:\n        // 0-999ms: show 3\n        // 1000-1999ms: show 2\n        // 2000-2999ms: show 1\n        if (elapsed < 1000) {\n          setCountdown(3);\n        } else if (elapsed < 2000) {\n          setCountdown(2);\n        } else {\n          setCountdown(1);\n        }\n      };\n\n      const interval = setInterval(updateCountdown, 50);\n      return () => {\n        clearInterval(interval);\n        // Reset for next countdown\n        setCountdown(3);\n      };\n    }\n  }, [match.phase, match.countdownStartedAt]);\n\n  return (\n    <div className=\"coinflip-active-match\">\n      {/* Waiting for opponent */}\n      {match.phase === \"created\" && (\n        <div className=\"coinflip-active-match__waiting\">\n          <h3 className=\"coinflip-active-match__title\">Waiting for Opponent</h3>\n          <div className=\"coinflip-active-match__info\">\n            <p>\n              Your side: <strong className={`side-${match.player1Side}`}>\n                {match.player1Side.toUpperCase()}\n              </strong>\n            </p>\n            <p>Entry: <strong>{match.entryAmount} SOL</strong></p>\n          </div>\n          <div className=\"coinflip-waiting__spinner\" />\n          <p className=\"coinflip-active-match__hint\">\n            Someone will join soon...\n          </p>\n        </div>\n      )}\n\n      {/* Ready / Countdown */}\n      {(match.phase === \"ready\" || match.phase === \"countdown\") && (\n        <div className=\"coinflip-active-match__playing\">\n          <h3 className=\"coinflip-active-match__title\">\n            {match.phase === \"ready\" && \"Game Ready!\"}\n            {match.phase === \"countdown\" && (\n              <span className=\"coinflip-countdown-inline\">\n                Flipping in... <span className=\"coinflip-countdown-inline__number\">{countdown}</span>\n              </span>\n            )}\n          </h3>\n\n          <div className=\"coinflip-active-match__players\">\n            <div className=\"coinflip-player coinflip-player--you\">\n              <span className=\"coinflip-player__label\">\n                <PlayerAvatarCompact address={currentUserAddress} />\n              </span>\n              <span className={`coinflip-player__side side-${yourSide}`}>\n                {yourSide?.toUpperCase()}\n              </span>\n            </div>\n\n            <span className=\"coinflip-active-match__vs\">VS</span>\n\n            <div className=\"coinflip-player coinflip-player--opponent\">\n              <span className=\"coinflip-player__label\">\n                {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n              </span>\n              <span className={`coinflip-player__side side-${opponentSide}`}>\n                {opponentSide?.toUpperCase()}\n              </span>\n            </div>\n          </div>\n\n          {/* Static coin for ready/countdown phases */}\n          <CoinAnimation\n            isFlipping={false}\n            result={null}\n            initialSide={yourSide ?? \"heads\"}\n            size=\"lg\"\n          />\n\n        </div>\n      )}\n\n      {/* Flipping / Complete - same container so coin persists through transition */}\n      {(match.phase === \"flipping\" || match.phase === \"complete\") && (\n        <div className=\"coinflip-active-match__playing\">\n          <h3 className={`coinflip-active-match__title ${\n            match.phase === \"complete\" ? (isWinner ? \"coinflip-active-match__title--won\" : \"coinflip-active-match__title--lost\") : \"\"\n          }`}>\n            {match.phase === \"flipping\" && \"Flipping!\"}\n            {match.phase === \"complete\" && isWinner && \"You Won!\"}\n            {match.phase === \"complete\" && !isWinner && (\n              <span className=\"coinflip-lose-title\">\n                You Lost{\" \"}\n                <span className=\"coinflip-lose-title__heart\">💔</span>\n                <span className=\"coinflip-lose-title__shards\">\n                  {[...Array(5)].map((_, i) => (\n                    <span key={i} className=\"coinflip-lose-title__shard\" style={{ '--shard-index': i } as React.CSSProperties}>◆</span>\n                  ))}\n                </span>\n              </span>\n            )}\n          </h3>\n\n          {/* Players info during flipping */}\n          {match.phase === \"flipping\" && (\n            <div className=\"coinflip-active-match__players\">\n              <div className=\"coinflip-player coinflip-player--you\">\n                <span className=\"coinflip-player__label\">\n                  <PlayerAvatarCompact address={currentUserAddress} />\n                </span>\n                <span className={`coinflip-player__side side-${yourSide}`}>\n                  {yourSide?.toUpperCase()}\n                </span>\n              </div>\n\n              <span className=\"coinflip-active-match__vs\">VS</span>\n\n              <div className=\"coinflip-player coinflip-player--opponent\">\n                <span className=\"coinflip-player__label\">\n                  {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n                </span>\n                <span className={`coinflip-player__side side-${opponentSide}`}>\n                  {opponentSide?.toUpperCase()}\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Single coin that persists through flipping → complete */}\n          <CoinAnimation\n            isFlipping={match.phase === \"flipping\"}\n            result={match.result}\n            initialSide={yourSide ?? \"heads\"}\n            size=\"lg\"\n          />\n\n          {/* Result info during complete */}\n          {match.phase === \"complete\" && (\n            <>\n              {/* Win Animation - Arcade star burst */}\n              {isWinner && (\n                <div className=\"coinflip-win-animation\">\n                  <div className=\"coinflip-win-animation__stars\">\n                    {[...Array(8)].map((_, i) => (\n                      <span key={i} className=\"coinflip-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n                    ))}\n                  </div>\n                  <div className=\"coinflip-win-animation__coins\">\n                    {[...Array(6)].map((_, i) => (\n                      <span key={i} className=\"coinflip-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n                    ))}\n                  </div>\n                </div>\n              )}\n\n              <div\n                className={`coinflip-result ${\n                  isWinner ? \"coinflip-result--won\" : \"coinflip-result--lost\"\n                }`}\n              >\n                <p className=\"coinflip-result__outcome\">\n                  Result: <strong\n                    style={{\n                      color: match.result === \"heads\" ? \"#00cc88\" : \"#ff6644\",\n                      textShadow: `0 0 6px ${match.result === \"heads\" ? \"#00cc88\" : \"#ff6644\"}`\n                    }}\n                  >{match.result?.toUpperCase()}</strong>\n                </p>\n                {isWinner && (\n                  <p className=\"coinflip-result__payout\">\n                    Payout: <strong>{match.payoutAmount.toFixed(4)} SOL</strong>\n                  </p>\n                )}\n              </div>\n\n            </>\n          )}\n        </div>\n      )}\n    </div>\n  );\n}\n","numLines":221,"startLine":1,"totalLines":221}}}
