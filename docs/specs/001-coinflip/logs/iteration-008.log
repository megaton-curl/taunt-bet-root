{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015Cvpxc3MU6fsCuktDC5eds","type":"tool_result","content":"     1→// Browser-only exports - no Node.js dependencies (no Buffer usage)\n     2→// Use this entry point for browser apps that don't need blockchain instructions\n     3→\n     4→// Types (no Buffer dependencies)\n     5→export type {\n     6→  Tier,\n     7→  Pool,\n     8→  PoolPhase,\n     9→  PlayerEntry,\n    10→  Side,\n    11→  GameConfig,\n    12→  GameId,\n    13→  CoinSide,\n    14→  CoinflipPhase,\n    15→  CoinflipState,\n    16→  CoinflipMatch,\n    17→  PoolState,\n    18→  LegacyPlayerEntry,\n    19→} from \"./types\";\n    20→\n    21→export {\n    22→  TIER_VALUES,\n    23→  TIER_AMOUNTS,\n    24→  TIER_AMOUNTS_LAMPORTS,\n    25→  POOL_PHASE_VALUES,\n    26→  SIDE_VALUES,\n    27→  COIN_SIDE_VALUES,\n    28→  COINFLIP_PHASE_VALUES,\n    29→  GAME_IDS,\n    30→  XP_BY_TIER,\n    31→  FEE_CONSTANTS,\n    32→} from \"./types\";\n    33→\n    34→// Round state machine (browser-safe)\n    35→export { RoundStateMachine, type RoundState, type RoundPhase } from \"./RoundStateMachine\";\n    36→\n    37→// Payout calculations (browser-safe, verification only)\n    38→export {\n    39→  calculatePariMutuelPayout,\n    40→  calculateWinnerPayout,\n    41→  verifyPayoutInvariant,\n    42→} from \"./payouts\";\n    43→\n    44→// Event emitter (browser-safe)\n    45→export { GameEventEmitter, type GameEvent, type GameEventType } from \"./GameEventEmitter\";\n    46→"}]},"parent_tool_use_id":null,"session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"c47253a3-a921-4dcd-8e3e-004c3bc96b17","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/browser.ts","content":"// Browser-only exports - no Node.js dependencies (no Buffer usage)\n// Use this entry point for browser apps that don't need blockchain instructions\n\n// Types (no Buffer dependencies)\nexport type {\n  Tier,\n  Pool,\n  PoolPhase,\n  PlayerEntry,\n  Side,\n  GameConfig,\n  GameId,\n  CoinSide,\n  CoinflipPhase,\n  CoinflipState,\n  CoinflipMatch,\n  PoolState,\n  LegacyPlayerEntry,\n} from \"./types\";\n\nexport {\n  TIER_VALUES,\n  TIER_AMOUNTS,\n  TIER_AMOUNTS_LAMPORTS,\n  POOL_PHASE_VALUES,\n  SIDE_VALUES,\n  COIN_SIDE_VALUES,\n  COINFLIP_PHASE_VALUES,\n  GAME_IDS,\n  XP_BY_TIER,\n  FEE_CONSTANTS,\n} from \"./types\";\n\n// Round state machine (browser-safe)\nexport { RoundStateMachine, type RoundState, type RoundPhase } from \"./RoundStateMachine\";\n\n// Payout calculations (browser-safe, verification only)\nexport {\n  calculatePariMutuelPayout,\n  calculateWinnerPayout,\n  verifyPayoutInvariant,\n} from \"./payouts\";\n\n// Event emitter (browser-safe)\nexport { GameEventEmitter, type GameEvent, type GameEventType } from \"./GameEventEmitter\";\n","numLines":46,"startLine":1,"totalLines":46}}}
