{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G368iKNGimgrgU6iakKnRs","type":"tool_result","content":"     1→import { useState, useEffect, useRef } from \"react\";\n     2→import { BrowserRouter, Routes, Route, Link, useLocation } from \"react-router-dom\";\n     3→import { Header } from \"./components/Header\";\n     4→import { CoinflipPage } from \"./pages/CoinflipPage\";\n     5→import { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\n     6→import { CloseCallPage } from \"./pages/CloseCallPage\";\n     7→import { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\n     8→import { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\n     9→import { SolanaLogo } from \"./components/SolanaLogo\";\n    10→import { BossRaidProvider } from \"./features/boss-raid\";\n    11→import { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatarCompact } from \"./features/player-profile\";\n    12→import { QuestsProvider, ChestDropNotification } from \"./features/quests\";\n    13→import { QuestsPage } from \"./pages/QuestsPage\";\n    14→import { LootPage } from \"./pages/LootPage\";\n    15→\n    16→// Player icon for Lord of the RNGs visual\n    17→const PlayerIcon = () => (\n    18→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    19→    <circle cx=\"12\" cy=\"8\" r=\"4\" />\n    20→    <path d=\"M12 14c-6 0-8 3-8 6v2h16v-2c0-3-2-6-8-6z\" />\n    21→  </svg>\n    22→);\n    23→\n    24→export function App() {\n    25→  return (\n    26→    <BrowserRouter>\n    27→      <PlayerProfileProvider>\n    28→        <QuestsProvider>\n    29→          <BossRaidProvider>\n    30→            <AppContent />\n    31→            <MiniProfileModal />\n    32→            <ChestDropNotification />\n    33→          </BossRaidProvider>\n    34→        </QuestsProvider>\n    35→      </PlayerProfileProvider>\n    36→    </BrowserRouter>\n    37→  );\n    38→}\n    39→\n    40→// Mock RNG High Score data - highest win streak\n    41→const rngHighScore = {\n    42→  playerAddress: \"9jFVCryptoAce12HighScoreWinner7xK8fTKt\",\n    43→  winStreak: 12,\n    44→  winAmount: 24.5,\n    45→  solPrice: 124.25, // USD per SOL\n    46→};\n    47→\n    48→// Social icons\n    49→const XIcon = () => (\n    50→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    51→    <path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/>\n    52→  </svg>\n    53→);\n    54→\n    55→const TelegramIcon = () => (\n    56→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    57→    <path d=\"M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z\"/>\n    58→  </svg>\n    59→);\n    60→\n    61→// Chat icon SVG\n    62→const ChatIcon = () => (\n    63→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    64→    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    65→    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    66→    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    67→    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n    68→  </svg>\n    69→);\n    70→\n    71→// Footer component with terms and FAQ modals\n    72→function Footer() {\n    73→  const [showTerms, setShowTerms] = useState(false);\n    74→  const [showFAQ, setShowFAQ] = useState(false);\n    75→  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n    76→  const termsModalRef = useRef<HTMLDivElement>(null);\n    77→  const faqModalRef = useRef<HTMLDivElement>(null);\n    78→\n    79→  // Close modal on outside click\n    80→  useEffect(() => {\n    81→    if (!showTerms && !showFAQ) return;\n    82→\n    83→    const handleClickOutside = (e: MouseEvent) => {\n    84→      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n    85→        setShowTerms(false);\n    86→      }\n    87→      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n    88→        setShowFAQ(false);\n    89→      }\n    90→    };\n    91→\n    92→    document.addEventListener(\"mousedown\", handleClickOutside);\n    93→    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n    94→  }, [showTerms, showFAQ]);\n    95→\n    96→  // Close on escape\n    97→  useEffect(() => {\n    98→    if (!showTerms && !showFAQ) return;\n    99→\n   100→    const handleEscape = (e: KeyboardEvent) => {\n   101→      if (e.key === \"Escape\") {\n   102→        setShowTerms(false);\n   103→        setShowFAQ(false);\n   104→      }\n   105→    };\n   106→\n   107→    document.addEventListener(\"keydown\", handleEscape);\n   108→    return () => document.removeEventListener(\"keydown\", handleEscape);\n   109→  }, [showTerms, showFAQ]);\n   110→\n   111→  const toggleFAQSection = (section: string) => {\n   112→    setExpandedFAQ(expandedFAQ === section ? null : section);\n   113→  };\n   114→\n   115→  const faqSections = [\n   116→    {\n   117→      id: \"fees\",\n   118→      title: \"Platform Fees\",\n   119→      content: `RNG Utopia charges a 3% platform fee on all games. This means 97% of all wagered funds go directly to winners.\n   120→\n   121→Fee breakdown:\n   122→• 1% goes to player incentives (RNG Raid Boss reward pool, future promotions)\n   123→• 2% goes to platform treasury (server costs, development, operations)\n   124→\n   125→What you get:\n   126→• Winners receive: 97% of the pot\n   127→• No hidden fees or withdrawal charges\n   128→• Part of your wagers fund rewards you can win back through Raid Boss`\n   129→    },\n   130→    {\n   131→      id: \"raid-boss\",\n   132→      title: \"What is RNG Raid Boss?\",\n   133→      content: `RNG Raid Boss is a community reward mechanic where players collectively battle a boss by playing games.\n   134→\n   135→How it works:\n   136→• A new boss spawns every hour with a 50-minute active phase\n   137→• Every wager you make in any game deals \"damage\" to the boss\n   138→• The boss HP drains over time - it's always defeated when the timer ends\n   139→• When defeated, the reward pool is distributed to all participants\n   140→\n   141→Rewards:\n   142→• Your share is proportional to your damage contribution\n   143→• The reward pool grows from 1% of all wagers during the raid\n   144→• Higher total community damage = better loot tier = bigger multipliers\n   145→• Bonus loot is occasionally added for extra rewards\n   146→\n   147→Loot Tiers (based on total damage):\n   148→• Bronze: 0-10 SOL damage\n   149→• Silver: 10-50 SOL damage\n   150→• Gold: 50-150 SOL damage\n   151→• Platinum: 150-500 SOL damage\n   152→• Diamond: 500+ SOL damage`\n   153→    },\n   154→    {\n   155→      id: \"pvp\",\n   156→      title: \"Why PvP Games?\",\n   157→      content: `Unlike traditional house-edge gambling where you play against the casino, RNG Utopia is 100% player-vs-player. This creates a fundamentally fairer system:\n   158→\n   159→• No house edge exploiting players\n   160→• Prize pools come entirely from player wagers\n   161→• The platform only takes a small facilitation fee\n   162→• Better odds than any traditional casino\n   163→• Transparent, skill-independent wagering`\n   164→    },\n   165→    {\n   166→      id: \"tiers\",\n   167→      title: \"Wagering Tiers\",\n   168→      content: `RNG Utopia uses wagering tiers to match players with similar risk appetites together. Each tier has a fixed SOL amount - you play against others wagering the same amount.\n   169→\n   170→Available Tiers:\n   171→• Iron: 0.005 SOL\n   172→• Bronze: 0.01 SOL\n   173→• Silver: 0.1 SOL\n   174→• Gold: 0.25 SOL\n   175→• Platinum: 0.5 SOL\n   176→• Diamond: 1 SOL\n   177→\n   178→How it works:\n   179→• Each game has separate lobbies for each tier\n   180→• Select your tier before joining a game\n   181→• You're matched only with players in the same tier\n   182→• Everyone in the round wagers the exact same amount\n   183→\n   184→Benefits:\n   185→• Fair matchmaking - compete on equal footing\n   186→• Choose the risk level you're comfortable with\n   187→• No whales dominating smaller players`\n   188→    },\n   189→    {\n   190→      id: \"leaderboard\",\n   191→      title: \"Leaderboard System\",\n   192→      content: `Leaderboard system details coming soon.\n   193→\n   194→We're working on implementing competitive leaderboards to track and reward top players. Stay tuned for updates!`\n   195→    },\n   196→    {\n   197→      id: \"fairness\",\n   198→      title: \"On-Chain Fairness\",\n   199→      content: `All game outcomes are provably fair using cryptographic verification:\n   200→\n   201→Commit-Reveal Pattern (Crash, Close Call):\n   202→1. Server publishes a hash of its seed before betting\n   203→2. Solana blockhash becomes the public seed\n   204→3. After the round, server reveals its seed\n   205→4. Anyone can verify the outcome matches\n   206→\n   207→On-Chain VRF (Lord of RNGs, Coinflip):\n   208→1. Game requests randomness from VRF provider\n   209→2. VRF generates verifiable random bytes\n   210→3. Result and proof stored on Solana blockchain\n   211→4. Anyone can verify using blockchain explorer\n   212→\n   213→Visit the Fairness page in the header for verification tools.`\n   214→    },\n   215→    {\n   216→      id: \"rng-buff\",\n   217→      title: \"RNG Buff\",\n   218→      content: `The RNG Buff is a powerful temporary bonus granted to players who help defeat the Raid Boss before the timer expires.\n   219→\n   220→How to get the RNG Buff:\n   221→1. Participate in the hourly Raid Boss by wagering in any game\n   222→2. Your wagers deal \"damage\" to the boss\n   223→3. If the boss is defeated before time runs out, ALL participants receive the buff\n   224→4. The buff lasts for 1 hour (until the next raid starts)\n   225→\n   226→Buff Benefits:\n   227→• Golden glowing border on your avatar (visible to all players)\n   228→• Chance to drop treasure chests when wagering\n   229→• Drop chance scales with wager amount (1% base + 5% per SOL, max 25%)\n   230→\n   231→Visual Indicators:\n   232→• Golden pulsing border around your avatar everywhere in the app\n   233→• RNG Buff icon with countdown timer in your profile header\n   234→• Star icon with timer in the main header\n   235→\n   236→The buff expires when the next raid begins, so make the most of it!`\n   237→    },\n   238→    {\n   239→      id: \"treasure-chests\",\n   240→      title: \"Treasure Chests\",\n   241→      content: `Treasure chests are mystery rewards that contain XP and SOL prizes. Open them in the Loot page.\n   242→\n   243→How to earn chests:\n   244→• RNG Buff drops: Random chance when wagering with active RNG Buff\n   245→• Complete ALL daily quests: 1 chest\n   246→• Complete weekly quests: 1 chest per quest (3 total)\n   247→• Complete ALL weekly quests: +2 bonus chests (5 total)\n   248→\n   249→RNG Buff chest drop rates:\n   250→• Base chance: 1% per wager\n   251→• Bonus: +5% per 1 SOL wagered\n   252→• Maximum: 25% chance per wager\n   253→\n   254→Chest rarity (determined when opened):\n   255→• Common (50%): 50-100 XP, 0.001-0.005 SOL\n   256→• Uncommon (30%): 100-250 XP, 0.005-0.01 SOL\n   257→• Rare (15%): 250-500 XP, 0.01-0.025 SOL\n   258→• Epic (4%): 500-1000 XP, 0.025-0.05 SOL\n   259→• Legendary (1%): 1000-2500 XP, 0.05-0.1 SOL\n   260→\n   261→SOL rewards are paid from the platform treasury. May the RNG gods smile upon you!`\n   262→    },\n   263→  ];\n   264→\n   265→  return (\n   266→    <>\n   267→      <footer className=\"footer\">\n   268→        <div className=\"footer-content\">\n   269→          {/* Center: Brand & Links */}\n   270→          <div className=\"footer-section footer-section--center\">\n   271→            <p className=\"footer-brand\">RNG Utopia</p>\n   272→            <div className=\"footer-links\">\n   273→              <button\n   274→                type=\"button\"\n   275→                className=\"footer-link\"\n   276→                onClick={() => setShowTerms(true)}\n   277→              >\n   278→                Terms\n   279→              </button>\n   280→              <span className=\"footer-link-divider\">|</span>\n   281→              <button\n   282→                type=\"button\"\n   283→                className=\"footer-link\"\n   284→                onClick={() => setShowFAQ(true)}\n   285→              >\n   286→                FAQ\n   287→              </button>\n   288→            </div>\n   289→            <p className=\"footer-copyright\">© 2025 RNG Utopia. All rights reserved.</p>\n   290→          </div>\n   291→\n   292→          {/* Right: Social links */}\n   293→          <div className=\"footer-section footer-section--socials\">\n   294→            <a\n   295→              href=\"https://x.com/rngutopia\"\n   296→              target=\"_blank\"\n   297→              rel=\"noopener noreferrer\"\n   298→              className=\"footer-social\"\n   299→              title=\"Follow us on X\"\n   300→            >\n   301→              <XIcon />\n   302→            </a>\n   303→            <a\n   304→              href=\"https://t.me/rngutopia\"\n   305→              target=\"_blank\"\n   306→              rel=\"noopener noreferrer\"\n   307→              className=\"footer-social\"\n   308→              title=\"Join our Telegram\"\n   309→            >\n   310→              <TelegramIcon />\n   311→            </a>\n   312→          </div>\n   313→        </div>\n   314→      </footer>\n   315→\n   316→      {/* Terms Modal */}\n   317→      {showTerms && (\n   318→        <div className=\"footer-terms-overlay\">\n   319→          <div className=\"footer-terms-modal\" ref={termsModalRef}>\n   320→            <button\n   321→              type=\"button\"\n   322→              className=\"footer-terms-close\"\n   323→              onClick={() => setShowTerms(false)}\n   324→            >\n   325→              ×\n   326→            </button>\n   327→            <h3 className=\"footer-terms-title\">Terms of Use</h3>\n   328→            <div className=\"footer-terms-content\">\n   329→              <p>\n   330→                By accessing and using RNG Utopia, you confirm that you are not a citizen,\n   331→                resident, or located within any jurisdiction where online gambling is prohibited\n   332→                or restricted by law, including but not limited to: the United States,\n   333→                United Kingdom, France, Germany, Spain, the Netherlands, or any other\n   334→                jurisdiction with similar regulations.\n   335→              </p>\n   336→              <p>\n   337→                You are solely responsible for determining whether your use of this platform\n   338→                is lawful in your country or region of residence. RNG Utopia does not provide\n   339→                legal advice and assumes no liability for users who access the platform in\n   340→                violation of applicable laws.\n   341→              </p>\n   342→              <p>\n   343→                By continuing to use this service, you acknowledge and accept these terms.\n   344→              </p>\n   345→            </div>\n   346→            <button\n   347→              type=\"button\"\n   348→              className=\"footer-terms-accept\"\n   349→              onClick={() => setShowTerms(false)}\n   350→            >\n   351→              I Understand\n   352→            </button>\n   353→          </div>\n   354→        </div>\n   355→      )}\n   356→\n   357→      {/* FAQ Modal */}\n   358→      {showFAQ && (\n   359→        <div className=\"footer-faq-overlay\">\n   360→          <div className=\"footer-faq-modal\" ref={faqModalRef}>\n   361→            <button\n   362→              type=\"button\"\n   363→              className=\"footer-faq-close\"\n   364→              onClick={() => setShowFAQ(false)}\n   365→            >\n   366→              ×\n   367→            </button>\n   368→            <h3 className=\"footer-faq-title\">Frequently Asked Questions</h3>\n   369→            <div className=\"footer-faq-content\">\n   370→              {faqSections.map((section) => (\n   371→                <div key={section.id} className=\"faq-section\">\n   372→                  <button\n   373→                    type=\"button\"\n   374→                    className={`faq-section-header ${expandedFAQ === section.id ? \"expanded\" : \"\"}`}\n   375→                    onClick={() => toggleFAQSection(section.id)}\n   376→                  >\n   377→                    <span className=\"faq-section-title\">{section.title}</span>\n   378→                    <span className=\"faq-section-arrow\">{expandedFAQ === section.id ? \"−\" : \"+\"}</span>\n   379→                  </button>\n   380→                  {expandedFAQ === section.id && (\n   381→                    <div className=\"faq-section-content\">\n   382→                      {section.content.split(\"\\n\\n\").map((paragraph, idx) => (\n   383→                        <p key={idx}>{paragraph}</p>\n   384→                      ))}\n   385→                    </div>\n   386→                  )}\n   387→                </div>\n   388→              ))}\n   389→            </div>\n   390→            <button\n   391→              type=\"button\"\n   392→              className=\"footer-faq-close-btn\"\n   393→              onClick={() => setShowFAQ(false)}\n   394→            >\n   395→              Close\n   396→            </button>\n   397→          </div>\n   398→        </div>\n   399→      )}\n   400→    </>\n   401→  );\n   402→}\n   403→\n   404→// RNG High Score Panel - Only shown on homepage\n   405→function RngHighScorePanel() {\n   406→  const location = useLocation();\n   407→  if (location.pathname !== \"/\") return null;\n   408→\n   409→  return (\n   410→    <div className=\"rng-high-score\">\n   411→      <div className=\"rng-high-score-header\">\n   412→        <span className=\"trophy\">&#127942;</span>\n   413→        <span className=\"title\">RNG High Score</span>\n   414→        <span className=\"trophy\">&#127942;</span>\n   415→      </div>\n   416→      <div className=\"rng-high-score-content\">\n   417→        <div className=\"rng-player-info\">\n   418→          <PlayerAvatarCompact address={rngHighScore.playerAddress} />\n   419→        </div>\n   420→        <div className=\"rng-win-streak\">\n   421→          <span className=\"streak-label\">Win Streak:</span>\n   422→          <span className=\"streak-value\">{rngHighScore.winStreak}</span>\n   423→        </div>\n   424→      </div>\n   425→      <div className=\"rng-high-score-footer\">\n   426→        <SolanaLogo size={16} className=\"sol-icon\" />\n   427→        <span className=\"win-amount\">{rngHighScore.winAmount.toFixed(2)}</span>\n   428→        <span className=\"win-usd\">(${(rngHighScore.winAmount * rngHighScore.solPrice).toFixed(2)})</span>\n   429→      </div>\n   430→    </div>\n   431→  );\n   432→}\n   433→\n   434→function AppContent() {\n   435→  const [chatExpanded, setChatExpanded] = useState(false);\n   436→\n   437→  return (\n   438→    <div className=\"app\">\n   439→      {/* Shooting Stars */}\n   440→      <div className=\"shooting-star shooting-star--1\" />\n   441→      <div className=\"shooting-star shooting-star--2\" />\n   442→      <div className=\"shooting-star shooting-star--3\" />\n   443→      <div className=\"shooting-star shooting-star--4\" />\n   444→      <div className=\"shooting-star shooting-star--5\" />\n   445→\n   446→      <Header />\n   447→\n   448→      {/* Chat Section - Fixed Left Side (persists across pages) */}\n   449→      <div className={`chat-section ${chatExpanded ? \"expanded\" : \"\"}`}>\n   450→        <div className=\"chat-toggle-btn\" onClick={() => setChatExpanded(!chatExpanded)}>\n   451→          <ChatIcon />\n   452→        </div>\n   453→        <div className={`chat-panel ${chatExpanded ? \"expanded\" : \"\"}`}>\n   454→          <div className=\"chat-panel-header\">\n   455→            <h4>Global Chat</h4>\n   456→            <button className=\"chat-close\" onClick={() => setChatExpanded(false)}>×</button>\n   457→          </div>\n   458→          <div className=\"chat-messages\">\n   459→            <div className=\"chat-message\">\n   460→              <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   461→              <span className=\"text\">gg nice flip!</span>\n   462→            </div>\n   463→            <div className=\"chat-message\">\n   464→              <PlayerAvatarCompact address=\"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   465→              <span className=\"text\">who's ready for crash?</span>\n   466→            </div>\n   467→            <div className=\"chat-message\">\n   468→              <PlayerAvatarCompact address=\"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   469→              <span className=\"text\">close call is rigged lol jk</span>\n   470→            </div>\n   471→            <div className=\"chat-message\">\n   472→              <PlayerAvatarCompact address=\"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   473→              <span className=\"text\">just hit 5x on crash!</span>\n   474→            </div>\n   475→            <div className=\"chat-message\">\n   476→              <PlayerAvatarCompact address=\"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   477→              <span className=\"text\">coinflip is where it's at</span>\n   478→            </div>\n   479→            <div className=\"chat-message\">\n   480→              <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   481→              <span className=\"text\">how do I verify fairness?</span>\n   482→            </div>\n   483→          </div>\n   484→          <div className=\"chat-input-container\">\n   485→            <input\n   486→              type=\"text\"\n   487→              className=\"chat-input\"\n   488→              placeholder=\"Type a message...\"\n   489→            />\n   490→            <button className=\"chat-send-btn\">Send</button>\n   491→          </div>\n   492→        </div>\n   493→      </div>\n   494→\n   495→      <main className=\"main\">\n   496→          {/* RNG High Score - Only on homepage, positioned relative to main */}\n   497→          <RngHighScorePanel />\n   498→\n   499→          <Routes>\n   500→            <Route path=\"/\" element={<HomePage />} />\n   501→            <Route path=\"/coinflip\" element={<CoinflipPage />} />\n   502→            <Route path=\"/lord-of-rngs\" element={<LordOfRngsPage />} />\n   503→            <Route path=\"/close-call\" element={<CloseCallPage />} />\n   504→            <Route path=\"/crash\" element={<CryptoCrashPage />} />\n   505→            <Route path=\"/game-of-trades\" element={<GameOfTradesPage />} />\n   506→            <Route path=\"/profile\" element={<ProfilePage />} />\n   507→            <Route path=\"/loot\" element={<LootPage />} />\n   508→            <Route path=\"/quests\" element={<QuestsPage />} />\n   509→            <Route path=\"/fairness\" element={<FairnessPage />} />\n   510→            <Route path=\"*\" element={<NotFoundPage />} />\n   511→          </Routes>\n   512→        </main>\n   513→        <Footer />\n   514→      </div>\n   515→  );\n   516→}\n   517→\n   518→function HomePage() {\n   519→  return (\n   520→    <div className=\"home\">\n   521→      {/* Stats Bar */}\n   522→      <div className=\"stats-bar\">\n   523→        <div className=\"stat-item\">\n   524→          <span className=\"stat-value\">89</span>\n   525→          <span className=\"stat-label\">Players</span>\n   526→        </div>\n   527→        <div className=\"stat-divider\" />\n   528→        <div className=\"stat-item\">\n   529→          <span className=\"stat-value\">1,247</span>\n   530→          <span className=\"stat-label\">Bets Placed</span>\n   531→        </div>\n   532→        <div className=\"stat-divider\" />\n   533→        <div className=\"stat-item\">\n   534→          <span className=\"stat-value\">847.5 SOL</span>\n   535→          <span className=\"stat-label\">SOL Wagered</span>\n   536→        </div>\n   537→        <div className=\"stat-divider\" />\n   538→        <div className=\"stat-item\">\n   539→          <span className=\"stat-value\">412</span>\n   540→          <span className=\"stat-label\">Wins</span>\n   541→        </div>\n   542→      </div>\n   543→\n   544→      <div className=\"arcade-header\">\n   545→        <h2>Select Your Game</h2>\n   546→        <p className=\"subtitle\">Insert Conviction</p>\n   547→      </div>\n   548→\n   549→      <div className=\"games-grid\">\n   550→        <GameCard\n   551→          name=\"Coinflip\"\n   552→          description=\"Heads or Tails - 1v1 battles\"\n   553→          path=\"/coinflip\"\n   554→          visual=\"coinflip\"\n   555→        />\n   556→        <GameCard\n   557→          name=\"Lord of the RNGs\"\n   558→          description=\"Jackpot game - One RNG to win them all\"\n   559→          path=\"/lord-of-rngs\"\n   560→          visual=\"lotr\"\n   561→        />\n   562→        <GameCard\n   563→          name=\"Slots Utopia\"\n   564→          description=\"PvP Grid Slots - 100% Return To Players\"\n   565→          path=\"/slots\"\n   566→          visual=\"slots\"\n   567→          locked\n   568→        />\n   569→        <GameCard\n   570→          name=\"Close Call\"\n   571→          description=\"Predict the outcome of the live 1 min candle close: Green or Red\"\n   572→          path=\"/close-call\"\n   573→          visual=\"close-call\"\n   574→        />\n   575→        <GameCard\n   576→          name=\"Crypto Crash Simulator\"\n   577→          description=\"Cash out before the crash - with multiplayer survival mode\"\n   578→          path=\"/crash\"\n   579→          visual=\"crash\"\n   580→          hot\n   581→        />\n   582→        <GameCard\n   583→          name=\"Game of Trades\"\n   584→          description=\"Fast paced, 1 minute, multiplayer trading rounds. Best performance wins the pot\"\n   585→          path=\"/game-of-trades\"\n   586→          visual=\"trades\"\n   587→        />\n   588→        <GameCard\n   589→          name=\"Chart the Course\"\n   590→          description=\"Predict the price direction of the given asset\"\n   591→          path=\"/chart-the-course\"\n   592→          visual=\"chart\"\n   593→        />\n   594→        <GameCard\n   595→          name=\"Tug of Earn\"\n   596→          description=\"Team vs Team tug of war\"\n   597→          path=\"/tug-of-earn\"\n   598→          visual=\"tug\"\n   599→        />\n   600→      </div>\n   601→    </div>\n   602→  );\n   603→}\n   604→\n   605→interface GameCardProps {\n   606→  name: string;\n   607→  description: string;\n   608→  path: string;\n   609→  visual: \"close-call\" | \"crash\" | \"lotr\" | \"coinflip\" | \"trades\" | \"slots\" | \"chart\" | \"tug\";\n   610→  locked?: boolean;\n   611→  hot?: boolean;\n   612→}\n   613→\n   614→function GameCard({\n   615→  name,\n   616→  description,\n   617→  path,\n   618→  visual,\n   619→  locked = false,\n   620→  hot = false,\n   621→}: GameCardProps) {\n   622→  return (\n   623→    <Link\n   624→      to={locked ? \"#\" : path}\n   625→      className={`game-card ${locked ? \"locked\" : \"\"}`}\n   626→      onClick={(e) => locked && e.preventDefault()}\n   627→    >\n   628→      <div className=\"scanlines\" />\n   629→      {hot && <span className=\"hot-badge\">HOT</span>}\n   630→      {locked && <span className=\"lock-icon\">🔒</span>}\n   631→\n   632→      {/* Game Visual */}\n   633→      <div className=\"game-visual\">\n   634→        <GameVisual type={visual} />\n   635→      </div>\n   636→\n   637→      {/* Game Info */}\n   638→      <div className=\"game-info\">\n   639→        <h3>{name}</h3>\n   640→        <p className=\"game-description\">{description}</p>\n   641→        <div className=\"game-footer\">\n   642→          {locked ? (\n   643→            <span className=\"lock-badge\">Loyalty Required</span>\n   644→          ) : (\n   645→            <span className=\"play-text\">Enter Game</span>\n   646→          )}\n   647→        </div>\n   648→      </div>\n   649→    </Link>\n   650→  );\n   651→}\n   652→\n   653→function GameVisual({ type }: { type: string }) {\n   654→  switch (type) {\n   655→    case \"close-call\":\n   656→      // Pool bar with equal halves and wicks\n   657→      return (\n   658→        <div className=\"close-call-visual\">\n   659→          <div className=\"pool-container\">\n   660→            <span className=\"pool-label green\">GREEN POOL</span>\n   661→            {/* Top wick - green */}\n   662→            <div className=\"pool-wick pool-wick--green\" />\n   663→            {/* Green half */}\n   664→            <div className=\"pool-green\" />\n   665→            {/* Red half */}\n   666→            <div className=\"pool-red\" />\n   667→            {/* Bottom wick - red */}\n   668→            <div className=\"pool-wick pool-wick--red\" />\n   669→            <span className=\"pool-label red\">RED POOL</span>\n   670→          </div>\n   671→        </div>\n   672→      );\n   673→\n   674→    case \"crash\":\n   675→      // 4 ascending green candles + 1 large red engulfing candle (SVG candlesticks)\n   676→      return (\n   677→        <div className=\"crash-visual\">\n   678→          <svg viewBox=\"0 0 64 56\" fill=\"none\">\n   679→            {/* Green candle 1 - smallest */}\n   680→            <line x1=\"8\" y1=\"38\" x2=\"8\" y2=\"48\" stroke=\"#39ff14\" strokeWidth=\"1\" />\n   681→            <rect x=\"4\" y=\"40\" width=\"8\" height=\"6\" fill=\"#39ff14\" />\n   682→            {/* Green candle 2 */}\n   683→            <line x1=\"18\" y1=\"32\" x2=\"18\" y2=\"44\" stroke=\"#39ff14\" strokeWidth=\"1\" />\n   684→            <rect x=\"14\" y=\"34\" width=\"8\" height=\"8\" fill=\"#39ff14\" />\n   685→            {/* Green candle 3 */}\n   686→            <line x1=\"28\" y1=\"24\" x2=\"28\" y2=\"38\" stroke=\"#39ff14\" strokeWidth=\"1\" />\n   687→            <rect x=\"24\" y=\"26\" width=\"8\" height=\"10\" fill=\"#39ff14\" />\n   688→            {/* Green candle 4 */}\n   689→            <line x1=\"38\" y1=\"16\" x2=\"38\" y2=\"32\" stroke=\"#39ff14\" strokeWidth=\"1\" />\n   690→            <rect x=\"34\" y=\"18\" width=\"8\" height=\"12\" fill=\"#39ff14\" />\n   691→            {/* Red crash candle - large engulfing */}\n   692→            <line x1=\"52\" y1=\"8\" x2=\"52\" y2=\"52\" stroke=\"#ff2a6d\" strokeWidth=\"1\" />\n   693→            <rect x=\"46\" y=\"12\" width=\"12\" height=\"36\" fill=\"#ff2a6d\" />\n   694→          </svg>\n   695→        </div>\n   696→      );\n   697→\n   698→    case \"lotr\":\n   699→      // Golden player circles\n   700→      return (\n   701→        <div className=\"lotr-visual\">\n   702→          <div className=\"selection-arrow\" />\n   703→          <div className=\"lotr-container\">\n   704→            <div className=\"player-circle\">\n   705→              <PlayerIcon />\n   706→            </div>\n   707→            <div className=\"player-circle\">\n   708→              <PlayerIcon />\n   709→            </div>\n   710→            <div className=\"player-circle selected\">\n   711→              <PlayerIcon />\n   712→            </div>\n   713→            <div className=\"player-circle\">\n   714→              <PlayerIcon />\n   715→            </div>\n   716→            <div className=\"player-circle\">\n   717→              <PlayerIcon />\n   718→            </div>\n   719→          </div>\n   720→        </div>\n   721→      );\n   722→\n   723→    case \"coinflip\":\n   724→      // Two coins: heads (green) and tails (orange) with RNG text\n   725→      return (\n   726→        <div className=\"coinflip-visual\">\n   727→          <svg viewBox=\"0 0 72 48\" fill=\"none\">\n   728→            {/* Heads coin (green) */}\n   729→            <circle cx=\"22\" cy=\"24\" r=\"18\" fill=\"#00cc88\" />\n   730→            <circle cx=\"22\" cy=\"24\" r=\"18\" stroke=\"#009966\" strokeWidth=\"2\" />\n   731→            <circle cx=\"22\" cy=\"24\" r=\"14\" fill=\"#009966\" opacity=\"0.3\" />\n   732→            <text x=\"22\" y=\"28\" textAnchor=\"middle\" fontSize=\"8\" fontFamily=\"monospace\" fontWeight=\"bold\" fill=\"#001a0d\">RNG</text>\n   733→            {/* Tails coin (orange) - slightly overlapping */}\n   734→            <circle cx=\"50\" cy=\"24\" r=\"18\" fill=\"#ff6644\" />\n   735→            <circle cx=\"50\" cy=\"24\" r=\"18\" stroke=\"#cc4422\" strokeWidth=\"2\" />\n   736→            <circle cx=\"50\" cy=\"24\" r=\"14\" fill=\"#cc4422\" opacity=\"0.3\" />\n   737→            <text x=\"50\" y=\"28\" textAnchor=\"middle\" fontSize=\"8\" fontFamily=\"monospace\" fontWeight=\"bold\" fill=\"#1a0500\">RNG</text>\n   738→          </svg>\n   739→        </div>\n   740→      );\n   741→\n   742→    case \"trades\":\n   743→      // Multiple players' performance lines\n   744→      return (\n   745→        <div className=\"generic-visual\">\n   746→          <svg viewBox=\"0 0 64 64\" fill=\"none\" strokeWidth=\"2\">\n   747→            {/* Axes */}\n   748→            <line x1=\"8\" y1=\"56\" x2=\"56\" y2=\"56\" stroke=\"#606078\" />\n   749→            <line x1=\"8\" y1=\"8\" x2=\"8\" y2=\"56\" stroke=\"#606078\" />\n   750→            {/* Player 1 - Green, +45% */}\n   751→            <path d=\"M8 40 L18 38 L28 32 L38 28 L48 20 L56 14\" stroke=\"#4dd45d\" strokeWidth=\"2\" />\n   752→            <circle cx=\"56\" cy=\"14\" r=\"2\" fill=\"#4dd45d\" />\n   753→            {/* Player 2 - Cyan, +20% */}\n   754→            <path d=\"M8 42 L18 44 L28 40 L38 36 L48 34 L56 30\" stroke=\"#05d9e8\" strokeWidth=\"2\" />\n   755→            <circle cx=\"56\" cy=\"30\" r=\"2\" fill=\"#05d9e8\" />\n   756→            {/* Player 3 - Pink, -10% */}\n   757→            <path d=\"M8 38 L18 42 L28 46 L38 44 L48 48 L56 46\" stroke=\"#ff2a6d\" strokeWidth=\"2\" />\n   758→            <circle cx=\"56\" cy=\"46\" r=\"2\" fill=\"#ff2a6d\" />\n   759→            {/* Player 4 - Yellow, +5% */}\n   760→            <path d=\"M8 44 L18 46 L28 44 L38 42 L48 40 L56 38\" stroke=\"#ffd700\" strokeWidth=\"2\" />\n   761→            <circle cx=\"56\" cy=\"38\" r=\"2\" fill=\"#ffd700\" />\n   762→          </svg>\n   763→        </div>\n   764→      );\n   765→\n   766→    case \"slots\":\n   767→      return (\n   768→        <div className=\"generic-visual\">\n   769→          <svg viewBox=\"0 0 64 64\" fill=\"currentColor\" style={{ color: \"#d45da8\" }}>\n   770→            <rect x=\"4\" y=\"16\" width=\"18\" height=\"32\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" />\n   771→            <rect x=\"23\" y=\"16\" width=\"18\" height=\"32\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" />\n   772→            <rect x=\"42\" y=\"16\" width=\"18\" height=\"32\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" />\n   773→            <text x=\"13\" y=\"38\" textAnchor=\"middle\" fontSize=\"14\" fill=\"currentColor\">7</text>\n   774→            <text x=\"32\" y=\"38\" textAnchor=\"middle\" fontSize=\"14\" fill=\"currentColor\">7</text>\n   775→            <text x=\"51\" y=\"38\" textAnchor=\"middle\" fontSize=\"14\" fill=\"currentColor\">7</text>\n   776→          </svg>\n   777→        </div>\n   778→      );\n   779→\n   780→    case \"chart\":\n   781→      // Line chart with pink pivot points\n   782→      return (\n   783→        <div className=\"generic-visual\">\n   784→          <svg viewBox=\"0 0 64 64\" fill=\"none\" strokeWidth=\"2\">\n   785→            {/* Axes */}\n   786→            <line x1=\"8\" y1=\"56\" x2=\"56\" y2=\"56\" stroke=\"#606078\" />\n   787→            <line x1=\"8\" y1=\"8\" x2=\"8\" y2=\"56\" stroke=\"#606078\" />\n   788→            {/* Price line - cyan */}\n   789→            <path d=\"M8 48 L20 36 L32 44 L44 24 L56 16\" stroke=\"#05d9e8\" strokeWidth=\"2\" />\n   790→            {/* Pink pivot points */}\n   791→            <circle cx=\"8\" cy=\"48\" r=\"3\" fill=\"#ff2a6d\" />\n   792→            <circle cx=\"20\" cy=\"36\" r=\"3\" fill=\"#ff2a6d\" />\n   793→            <circle cx=\"32\" cy=\"44\" r=\"3\" fill=\"#ff2a6d\" />\n   794→            <circle cx=\"44\" cy=\"24\" r=\"3\" fill=\"#ff2a6d\" />\n   795→            <circle cx=\"56\" cy=\"16\" r=\"3\" fill=\"#ff2a6d\" />\n   796→          </svg>\n   797→        </div>\n   798→      );\n   799→\n   800→    case \"tug\":\n   801→      return (\n   802→        <div className=\"generic-visual\">\n   803→          <svg viewBox=\"0 0 64 64\" fill=\"currentColor\">\n   804→            <rect x=\"4\" y=\"28\" width=\"56\" height=\"8\" fill=\"#606078\" />\n   805→            <rect x=\"4\" y=\"28\" width=\"26\" height=\"8\" fill=\"#4dd45d\" />\n   806→            <rect x=\"34\" y=\"28\" width=\"26\" height=\"8\" fill=\"#d45d5d\" />\n   807→            <rect x=\"28\" y=\"24\" width=\"8\" height=\"16\" fill=\"#d4c44d\" />\n   808→            <circle cx=\"14\" cy=\"20\" r=\"8\" fill=\"#4dd45d\" />\n   809→            <circle cx=\"50\" cy=\"20\" r=\"8\" fill=\"#d45d5d\" />\n   810→          </svg>\n   811→        </div>\n   812→      );\n   813→\n   814→    default:\n   815→      return null;\n   816→  }\n   817→}\n   818→\n   819→// Fairness verification page\n   820→function FairnessPage() {\n   821→  const [activeTab, setActiveTab] = useState<'how' | 'verify' | 'seeds' | 'history'>('how');\n   822→  const [serverSeed, setServerSeed] = useState('');\n   823→  const [publicSeed, setPublicSeed] = useState('');\n   824→  const [roundId, setRoundId] = useState('');\n   825→  const [gameId, setGameId] = useState('crash');\n   826→  const [commitmentHash, setCommitmentHash] = useState('');\n   827→  const [verificationResult, setVerificationResult] = useState<{\n   828→    valid: boolean;\n   829→    message: string;\n   830→    crashPoint?: string;\n   831→  } | null>(null);\n   832→\n   833→  // SHA-256 hash function (using Web Crypto API)\n   834→  const sha256 = async (message: string): Promise<string> => {\n   835→    const encoder = new TextEncoder();\n   836→    const data = encoder.encode(message);\n   837→    const hashBuffer = await crypto.subtle.digest('SHA-256', data);\n   838→    const hashArray = Array.from(new Uint8Array(hashBuffer));\n   839→    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n   840→  };\n   841→\n   842→  // HMAC-SHA256 function\n   843→  const hmacSha256 = async (key: string, message: string): Promise<string> => {\n   844→    const encoder = new TextEncoder();\n   845→    const keyData = encoder.encode(key);\n   846→    const messageData = encoder.encode(message);\n   847→\n   848→    const cryptoKey = await crypto.subtle.importKey(\n   849→      'raw',\n   850→      keyData,\n   851→      { name: 'HMAC', hash: 'SHA-256' },\n   852→      false,\n   853→      ['sign']\n   854→    );\n   855→\n   856→    const signature = await crypto.subtle.sign('HMAC', cryptoKey, messageData);\n   857→    const hashArray = Array.from(new Uint8Array(signature));\n   858→    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n   859→  };\n   860→\n   861→  // Convert hash to crash point (standard algorithm)\n   862→  const hashToCrashPoint = (hash: string): number => {\n   863→    // Take first 13 hex characters (52 bits)\n   864→    const h = parseInt(hash.substring(0, 13), 16);\n   865→    // House edge: 1% (1 in 100 instant crash)\n   866→    const e = Math.pow(2, 52);\n   867→    const result = Math.floor((100 * e - h) / (e - h)) / 100;\n   868→    return Math.max(1.00, result);\n   869→  };\n   870→\n   871→  // Verify commitment\n   872→  const verifyCommitment = async () => {\n   873→    if (!serverSeed) {\n   874→      setVerificationResult({\n   875→        valid: false,\n   876→        message: 'Please enter a server seed'\n   877→      });\n   878→      return;\n   879→    }\n   880→\n   881→    const computedHash = await sha256(serverSeed);\n   882→\n   883→    if (commitmentHash) {\n   884→      const isValid = computedHash.toLowerCase() === commitmentHash.toLowerCase();\n   885→      setVerificationResult({\n   886→        valid: isValid,\n   887→        message: isValid\n   888→          ? 'Commitment verified! The server seed matches the published hash.'\n   889→          : 'Commitment FAILED! The server seed does not match the published hash.'\n   890→      });\n   891→    } else {\n   892→      setVerificationResult({\n   893→        valid: true,\n   894→        message: `Computed commitment hash: ${computedHash}`\n   895→      });\n   896→    }\n   897→  };\n   898→\n   899→  // Calculate crash point\n   900→  const calculateCrashPoint = async () => {\n   901→    if (!serverSeed || !publicSeed) {\n   902→      setVerificationResult({\n   903→        valid: false,\n   904→        message: 'Please enter both server seed and public seed'\n   905→      });\n   906→      return;\n   907→    }\n   908→\n   909→    // Combine seeds with round info\n   910→    const message = `${publicSeed}:${roundId}:${gameId}`;\n   911→    const hash = await hmacSha256(serverSeed, message);\n   912→    const crashPoint = hashToCrashPoint(hash);\n   913→\n   914→    setVerificationResult({\n   915→      valid: true,\n   916→      message: `Round outcome verified successfully.`,\n   917→      crashPoint: crashPoint.toFixed(2)\n   918→    });\n   919→  };\n   920→\n   921→  // Mock recent rounds data\n   922→  const recentRounds = [\n   923→    { id: '847291', game: 'Crash', result: '2.47x', commitment: 'a3f2...8e1c', verified: true },\n   924→    { id: '847290', game: 'Crash', result: '1.23x', commitment: 'b7e1...2f9a', verified: true },\n   925→    { id: '847289', game: 'Lord of the RNGs', result: 'Player_42', commitment: 'c9d3...7b4e', verified: true },\n   926→    { id: '847288', game: 'Close Call', result: 'GREEN', commitment: 'd2a8...1c5f', verified: true },\n   927→    { id: '847287', game: 'Coinflip', result: 'HEADS', commitment: 'e5f6...9d2b', verified: true },\n   928→  ];\n   929→\n   930→  // Mock active seeds\n   931→  const activeSeeds = [\n   932→    { game: 'Crash', tier: 'All', commitment: 'f1e2d3c4b5a6978...', status: 'Active', expiresIn: '2:34' },\n   933→    { game: 'Lord of the RNGs', tier: 'Gold', commitment: '9a8b7c6d5e4f321...', status: 'Betting', expiresIn: '0:45' },\n   934→    { game: 'Close Call', tier: 'All', commitment: '1a2b3c4d5e6f789...', status: 'Active', expiresIn: '0:12' },\n   935→  ];\n   936→\n   937→  return (\n   938→    <div className=\"fairness-page\">\n   939→      <div className=\"fairness-header\">\n   940→        <h2>Provably Fair Verification</h2>\n   941→        <p className=\"fairness-subtitle\">Every outcome is cryptographically verifiable</p>\n   942→      </div>\n   943→\n   944→      {/* Tab Navigation */}\n   945→      <div className=\"fairness-tabs\">\n   946→        <button\n   947→          className={`fairness-tab ${activeTab === 'how' ? 'active' : ''}`}\n   948→          onClick={() => setActiveTab('how')}\n   949→        >\n   950→          How It Works\n   951→        </button>\n   952→        <button\n   953→          className={`fairness-tab ${activeTab === 'verify' ? 'active' : ''}`}\n   954→          onClick={() => setActiveTab('verify')}\n   955→        >\n   956→          Verify Round\n   957→        </button>\n   958→        <button\n   959→          className={`fairness-tab ${activeTab === 'seeds' ? 'active' : ''}`}\n   960→          onClick={() => setActiveTab('seeds')}\n   961→        >\n   962→          Active Seeds\n   963→        </button>\n   964→        <button\n   965→          className={`fairness-tab ${activeTab === 'history' ? 'active' : ''}`}\n   966→          onClick={() => setActiveTab('history')}\n   967→        >\n   968→          History\n   969→        </button>\n   970→      </div>\n   971→\n   972→      {/* Tab Content */}\n   973→      <div className=\"fairness-content\">\n   974→        {activeTab === 'how' && (\n   975→          <div className=\"fairness-how\">\n   976→            <div className=\"fairness-section\">\n   977→              <h3>Why Provably Fair?</h3>\n   978→              <p>\n   979→                Traditional online games require you to trust that the house isn't cheating.\n   980→                Provably fair systems eliminate this trust requirement by using cryptographic\n   981→                commitments that can be independently verified by anyone.\n   982→              </p>\n   983→            </div>\n   984→\n   985→            <div className=\"fairness-section\">\n   986→              <h3>Pattern 1: Commit-Reveal + Blockhash</h3>\n   987→              <p className=\"pattern-label\">Used by: Crash, Close Call, Game of Trades</p>\n   988→              <div className=\"fairness-steps\">\n   989→                <div className=\"step\">\n   990→                  <span className=\"step-num\">1</span>\n   991→                  <div className=\"step-content\">\n   992→                    <strong>Before Betting Opens</strong>\n   993→                    <p>Server generates a random seed and publishes its SHA-256 hash (commitment)</p>\n   994→                  </div>\n   995→                </div>\n   996→                <div className=\"step\">\n   997→                  <span className=\"step-num\">2</span>\n   998→                  <div className=\"step-content\">\n   999→                    <strong>During Betting</strong>\n  1000→                    <p>Players place bets. The server cannot change its seed (hash is already public)</p>\n  1001→                  </div>\n  1002→                </div>\n  1003→                <div className=\"step\">\n  1004→                  <span className=\"step-num\">3</span>\n  1005→                  <div className=\"step-content\">\n  1006→                    <strong>At Round Start</strong>\n  1007→                    <p>A future Solana blockhash becomes the public seed (unpredictable by server)</p>\n  1008→                  </div>\n  1009→                </div>\n  1010→                <div className=\"step\">\n  1011→                  <span className=\"step-num\">4</span>\n  1012→                  <div className=\"step-content\">\n  1013→                    <strong>After Round</strong>\n  1014→                    <p>Server reveals its seed. Anyone can verify: SHA-256(seed) = commitment</p>\n  1015→                  </div>\n  1016→                </div>\n  1017→              </div>\n  1018→              <div className=\"formula-box\">\n  1019→                <code>outcome = HMAC-SHA256(serverSeed, publicSeed || roundId || gameId)</code>\n  1020→              </div>\n  1021→            </div>\n  1022→\n  1023→            <div className=\"fairness-section\">\n  1024→              <h3>Pattern 2: On-Chain VRF</h3>\n  1025→              <p className=\"pattern-label\">Used by: Lord of the RNGs, Coinflip, Tug of Earn</p>\n  1026→              <div className=\"fairness-steps\">\n  1027→                <div className=\"step\">\n  1028→                  <span className=\"step-num\">1</span>\n  1029→                  <div className=\"step-content\">\n  1030→                    <strong>Round Enters Resolution</strong>\n  1031→                    <p>The on-chain program requests randomness from a VRF provider</p>\n  1032→                  </div>\n  1033→                </div>\n  1034→                <div className=\"step\">\n  1035→                  <span className=\"step-num\">2</span>\n  1036→                  <div className=\"step-content\">\n  1037→                    <strong>VRF Fulfillment</strong>\n  1038→                    <p>Provider generates verifiable random bytes with a cryptographic proof</p>\n  1039→                  </div>\n  1040→                </div>\n  1041→                <div className=\"step\">\n  1042→                  <span className=\"step-num\">3</span>\n  1043→                  <div className=\"step-content\">\n  1044→                    <strong>On-Chain Verification</strong>\n  1045→                    <p>Program verifies the proof and uses the result for winner selection</p>\n  1046→                  </div>\n  1047→                </div>\n  1048→                <div className=\"step\">\n  1049→                  <span className=\"step-num\">4</span>\n  1050→                  <div className=\"step-content\">\n  1051→                    <strong>Permanent Record</strong>\n  1052→                    <p>Result and proof stored on-chain forever - viewable on Solana explorer</p>\n  1053→                  </div>\n  1054→                </div>\n  1055→              </div>\n  1056→            </div>\n  1057→\n  1058→            <div className=\"fairness-section\">\n  1059→              <h3>What Can't Be Manipulated</h3>\n  1060→              <div className=\"guarantees\">\n  1061→                <div className=\"guarantee\">\n  1062→                  <span className=\"check-icon\">✓</span>\n  1063→                  <span>Server cannot predict the blockhash used as public seed</span>\n  1064→                </div>\n  1065→                <div className=\"guarantee\">\n  1066→                  <span className=\"check-icon\">✓</span>\n  1067→                  <span>Server cannot change its seed after publishing the commitment</span>\n  1068→                </div>\n  1069→                <div className=\"guarantee\">\n  1070→                  <span className=\"check-icon\">✓</span>\n  1071→                  <span>VRF proofs are mathematically verifiable - forgery is impossible</span>\n  1072→                </div>\n  1073→                <div className=\"guarantee\">\n  1074→                  <span className=\"check-icon\">✓</span>\n  1075→                  <span>All settlement happens on-chain with public transaction history</span>\n  1076→                </div>\n  1077→              </div>\n  1078→            </div>\n  1079→          </div>\n  1080→        )}\n  1081→\n  1082→        {activeTab === 'verify' && (\n  1083→          <div className=\"fairness-verify\">\n  1084→            <div className=\"verify-section\">\n  1085→              <h3>Verify a Round</h3>\n  1086→              <p>Enter the seeds from a completed round to independently verify the outcome.</p>\n  1087→\n  1088→              <div className=\"verify-form\">\n  1089→                <div className=\"form-group\">\n  1090→                  <label>Game</label>\n  1091→                  <select\n  1092→                    value={gameId}\n  1093→                    onChange={(e) => setGameId(e.target.value)}\n  1094→                    className=\"verify-select\"\n  1095→                  >\n  1096→                    <option value=\"crash\">Crypto Crash Simulator</option>\n  1097→                    <option value=\"close-call\">Close Call</option>\n  1098→                    <option value=\"lord-of-rngs\">Lord of the RNGs</option>\n  1099→                    <option value=\"coinflip\">Coinflip</option>\n  1100→                    <option value=\"game-of-trades\">Game of Trades</option>\n  1101→                  </select>\n  1102→                </div>\n  1103→\n  1104→                <div className=\"form-group\">\n  1105→                  <label>Server Seed (revealed after round)</label>\n  1106→                  <input\n  1107→                    type=\"text\"\n  1108→                    value={serverSeed}\n  1109→                    onChange={(e) => setServerSeed(e.target.value)}\n  1110→                    placeholder=\"e.g., a1b2c3d4e5f6...\"\n  1111→                    className=\"verify-input\"\n  1112→                  />\n  1113→                </div>\n  1114→\n  1115→                <div className=\"form-group\">\n  1116→                  <label>Public Seed (Solana blockhash)</label>\n  1117→                  <input\n  1118→                    type=\"text\"\n  1119→                    value={publicSeed}\n  1120→                    onChange={(e) => setPublicSeed(e.target.value)}\n  1121→                    placeholder=\"e.g., 5eykt4UsFv8P8NJdTREpY1vzqKqZKvdpKuc147dw2N9d\"\n  1122→                    className=\"verify-input\"\n  1123→                  />\n  1124→                </div>\n  1125→\n  1126→                <div className=\"form-row\">\n  1127→                  <div className=\"form-group\">\n  1128→                    <label>Round ID</label>\n  1129→                    <input\n  1130→                      type=\"text\"\n  1131→                      value={roundId}\n  1132→                      onChange={(e) => setRoundId(e.target.value)}\n  1133→                      placeholder=\"e.g., 847291\"\n  1134→                      className=\"verify-input\"\n  1135→                    />\n  1136→                  </div>\n  1137→\n  1138→                  <div className=\"form-group\">\n  1139→                    <label>Commitment Hash (optional)</label>\n  1140→                    <input\n  1141→                      type=\"text\"\n  1142→                      value={commitmentHash}\n  1143→                      onChange={(e) => setCommitmentHash(e.target.value)}\n  1144→                      placeholder=\"SHA-256 hash to verify against\"\n  1145→                      className=\"verify-input\"\n  1146→                    />\n  1147→                  </div>\n  1148→                </div>\n  1149→\n  1150→                <div className=\"verify-buttons\">\n  1151→                  <button onClick={verifyCommitment} className=\"verify-action-btn\">\n  1152→                    Verify Commitment\n  1153→                  </button>\n  1154→                  <button onClick={calculateCrashPoint} className=\"verify-action-btn primary\">\n  1155→                    Calculate Outcome\n  1156→                  </button>\n  1157→                </div>\n  1158→\n  1159→                {verificationResult && (\n  1160→                  <div className={`verification-result ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n  1161→                    <div className=\"result-status\">\n  1162→                      <span className={`status-icon ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n  1163→                        {verificationResult.valid ? '✓' : '✗'}\n  1164→                      </span>\n  1165→                      <span className=\"status-text\">{verificationResult.message}</span>\n  1166→                    </div>\n  1167→                    {verificationResult.crashPoint && (\n  1168→                      <div className=\"result-value\">\n  1169→                        <span className=\"result-label\">Crash Point:</span>\n  1170→                        <span className=\"crash-point\">{verificationResult.crashPoint}x</span>\n  1171→                      </div>\n  1172→                    )}\n  1173→                  </div>\n  1174→                )}\n  1175→              </div>\n  1176→            </div>\n  1177→\n  1178→            <div className=\"verify-section\">\n  1179→              <h3>Quick Lookup</h3>\n  1180→              <p>Enter a round ID to fetch its verification data automatically.</p>\n  1181→              <div className=\"quick-lookup\">\n  1182→                <input\n  1183→                  type=\"text\"\n  1184→                  placeholder=\"Enter Round ID...\"\n  1185→                  className=\"verify-input\"\n  1186→                />\n  1187→                <button className=\"lookup-btn\">Lookup</button>\n  1188→              </div>\n  1189→            </div>\n  1190→          </div>\n  1191→        )}\n  1192→\n  1193→        {activeTab === 'seeds' && (\n  1194→          <div className=\"fairness-seeds\">\n  1195→            <h3>Active Commitments</h3>\n  1196→            <p>These are the current seed commitments for ongoing rounds. The actual seeds will be revealed after each round completes.</p>\n  1197→\n  1198→            <div className=\"seeds-table\">\n  1199→              <div className=\"seeds-header\">\n  1200→                <span>Game</span>\n  1201→                <span>Tier</span>\n  1202→                <span>Commitment Hash</span>\n  1203→                <span>Status</span>\n  1204→                <span>Time</span>\n  1205→              </div>\n  1206→              {activeSeeds.map((seed, i) => (\n  1207→                <div className=\"seed-row\" key={i}>\n  1208→                  <span className=\"seed-game\">{seed.game}</span>\n  1209→                  <span className=\"seed-tier\">{seed.tier}</span>\n  1210→                  <span className=\"seed-hash\">{seed.commitment}</span>\n  1211→                  <span className={`seed-status ${seed.status.toLowerCase()}`}>{seed.status}</span>\n  1212→                  <span className=\"seed-time\">{seed.expiresIn}</span>\n  1213→                </div>\n  1214→              ))}\n  1215→            </div>\n  1216→\n  1217→            <div className=\"seeds-info\">\n  1218→              <h4>Understanding Commitments</h4>\n  1219→              <p>\n  1220→                A commitment is the SHA-256 hash of the server's secret seed. It's published before\n  1221→                betting opens, ensuring the server cannot change its seed after seeing player bets.\n  1222→                After the round, you can verify that SHA-256(revealed_seed) equals the commitment.\n  1223→              </p>\n  1224→            </div>\n  1225→          </div>\n  1226→        )}\n  1227→\n  1228→        {activeTab === 'history' && (\n  1229→          <div className=\"fairness-history\">\n  1230→            <h3>Recent Verified Rounds</h3>\n  1231→            <p>All completed rounds with their verification status.</p>\n  1232→\n  1233→            <div className=\"history-table\">\n  1234→              <div className=\"history-header\">\n  1235→                <span>Round</span>\n  1236→                <span>Game</span>\n  1237→                <span>Result</span>\n  1238→                <span>Commitment</span>\n  1239→                <span>Status</span>\n  1240→                <span>Action</span>\n  1241→              </div>\n  1242→              {recentRounds.map((round) => (\n  1243→                <div className=\"history-row\" key={round.id}>\n  1244→                  <span className=\"round-id\">#{round.id}</span>\n  1245→                  <span className=\"round-game\">{round.game}</span>\n  1246→                  <span className=\"round-result\">{round.result}</span>\n  1247→                  <span className=\"round-commitment\">{round.commitment}</span>\n  1248→                  <span className={`round-status ${round.verified ? 'verified' : 'pending'}`}>\n  1249→                    {round.verified ? 'Verified' : 'Pending'}\n  1250→                  </span>\n  1251→                  <button className=\"round-verify-btn\">Verify</button>\n  1252→                </div>\n  1253→              ))}\n  1254→            </div>\n  1255→\n  1256→            <div className=\"history-pagination\">\n  1257→              <button className=\"page-btn\" disabled>Previous</button>\n  1258→              <span className=\"page-info\">Page 1 of 1</span>\n  1259→              <button className=\"page-btn\" disabled>Next</button>\n  1260→            </div>\n  1261→          </div>\n  1262→        )}\n  1263→      </div>\n  1264→    </div>\n  1265→  );\n  1266→}\n  1267→\n  1268→function NotFoundPage() {\n  1269→  return (\n  1270→    <div className=\"not-found\">\n  1271→      <div className=\"error-code\">\n  1272→        <span className=\"digit\">4</span>\n  1273→        <span className=\"digit zero\">0</span>\n  1274→        <span className=\"digit\">4</span>\n  1275→      </div>\n  1276→      <h2>Game Over</h2>\n  1277→      <p>The level you're looking for doesn't exist.</p>\n  1278→      <p className=\"hint\">Maybe try a different warp pipe?</p>\n  1279→      <Link to=\"/\" className=\"continue-btn\">\n  1280→        Continue?\n  1281→      </Link>\n  1282→    </div>\n  1283→  );\n  1284→}\n  1285→"}]},"parent_tool_use_id":"toolu_01YCTQuKBLEy2YtcyQ9ZrCui","session_id":"eb85923b-8763-4260-a88f-751dbcd29bcb","uuid":"1bd9281a-04be-4e28-b194-8733ff333377"}
