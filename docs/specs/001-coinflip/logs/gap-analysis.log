{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0146UmuCeC4RwjwkuWeJm1yh","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→#[error_code]\n     4→pub enum CoinflipError {\n     5→    /// 6100 (Anchor adds 6000 base offset)\n     6→    #[msg(\"Invalid side: must be 0 (Heads) or 1 (Tails)\")]\n     7→    InvalidSide = 100,\n     8→\n     9→    /// 6101\n    10→    #[msg(\"Invalid tier index\")]\n    11→    InvalidTier,\n    12→\n    13→    /// 6102\n    14→    #[msg(\"Match is not in the expected phase\")]\n    15→    InvalidPhase,\n    16→\n    17→    /// 6103\n    18→    #[msg(\"Insufficient funds for entry amount\")]\n    19→    InsufficientFunds,\n    20→\n    21→    /// 6104\n    22→    #[msg(\"Creator cannot join their own match\")]\n    23→    CannotJoinOwnMatch,\n    24→\n    25→    /// 6105\n    26→    #[msg(\"Only the oracle authority can resolve matches\")]\n    27→    UnauthorizedOracle,\n    28→\n    29→    /// 6106\n    30→    #[msg(\"Payout has already been claimed\")]\n    31→    AlreadyClaimed,\n    32→\n    33→    /// 6107\n    34→    #[msg(\"Only the winner can claim the payout\")]\n    35→    NotWinner,\n    36→\n    37→    /// 6108\n    38→    #[msg(\"Match can only be cancelled in WAITING phase\")]\n    39→    CannotCancel,\n    40→\n    41→    /// 6109\n    42→    #[msg(\"VRF randomness request failed\")]\n    43→    VrfRequestFailed,\n    44→\n    45→    /// 6110\n    46→    #[msg(\"Lock timeout has not elapsed yet\")]\n    47→    LockTimeoutNotElapsed,\n    48→\n    49→    /// 6111\n    50→    #[msg(\"Only the creator or opponent can cancel a timed-out match\")]\n    51→    UnauthorizedCaller,\n    52→}\n    53→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"06e7264f-e3b6-469d-8d07-f363d69ef41f"}
