{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LxAJSqhNh4WUrf2bb6vyDx","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::state::PlayerProfile;\n     4→\n     5→#[derive(Accounts)]\n     6→pub struct CreatePlayerProfile<'info> {\n     7→    /// The player creating their profile.\n     8→    #[account(mut)]\n     9→    pub player: Signer<'info>,\n    10→\n    11→    /// The player profile PDA (one per wallet).\n    12→    #[account(\n    13→        init,\n    14→        payer = player,\n    15→        space = 8 + PlayerProfile::INIT_SPACE,\n    16→        seeds = [b\"player_profile\", player.key().as_ref()],\n    17→        bump,\n    18→    )]\n    19→    pub profile: Account<'info, PlayerProfile>,\n    20→\n    21→    pub system_program: Program<'info, System>,\n    22→}\n    23→\n    24→pub fn handler(ctx: Context<CreatePlayerProfile>) -> Result<()> {\n    25→    let profile = &mut ctx.accounts.profile;\n    26→    profile.authority = ctx.accounts.player.key();\n    27→    profile.total_games = 0;\n    28→    profile.wins = 0;\n    29→    profile.total_wagered = 0;\n    30→    profile.total_won = 0;\n    31→    profile.bump = ctx.bumps.profile;\n    32→    Ok(())\n    33→}\n    34→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"f334911e-0c02-4e69-927c-5afd2d797dd4"}
