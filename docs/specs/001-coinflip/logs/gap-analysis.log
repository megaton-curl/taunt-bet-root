{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HnuUkZxjgsesK6UwL3VM6a","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Global platform configuration. Singleton PDA.\n     4→/// Seeds: [b\"platform_config\"]\n     5→#[account]\n     6→#[derive(InitSpace)]\n     7→pub struct PlatformConfig {\n     8→    /// The admin authority that can update config.\n     9→    pub authority: Pubkey,\n    10→    /// Treasury wallet that receives platform fees.\n    11→    pub treasury: Pubkey,\n    12→    /// Total fee in basis points (e.g., 300 = 3%).\n    13→    pub fee_bps: u16,\n    14→    /// Bump seed for PDA derivation.\n    15→    pub bump: u8,\n    16→}\n    17→\n    18→/// Player profile tracking game stats. One per wallet.\n    19→/// Seeds: [b\"player_profile\", wallet.as_ref()]\n    20→#[account]\n    21→#[derive(InitSpace)]\n    22→pub struct PlayerProfile {\n    23→    /// The wallet this profile belongs to.\n    24→    pub authority: Pubkey,\n    25→    /// Total number of games played.\n    26→    pub total_games: u64,\n    27→    /// Total wins.\n    28→    pub wins: u64,\n    29→    /// Total SOL wagered (in lamports).\n    30→    pub total_wagered: u64,\n    31→    /// Total SOL won (in lamports).\n    32→    pub total_won: u64,\n    33→    /// Bump seed for PDA derivation.\n    34→    pub bump: u8,\n    35→}\n    36→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"14dec41f-4340-4004-befa-58c709a89d7a"}
