{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hw4TJMCJr6BkXeGvQCVKrj","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→#[error_code]\n     4→pub enum PauseError {\n     5→    #[msg(\"Platform is paused\")]\n     6→    PlatformPaused,\n     7→    #[msg(\"Game is paused\")]\n     8→    GamePaused,\n     9→}\n    10→\n    11→/// Checks that neither the global platform nor the specific game is paused.\n    12→/// Global pause takes precedence over game pause.\n    13→pub fn check_not_paused(global_paused: bool, game_paused: bool) -> Result<()> {\n    14→    if global_paused {\n    15→        return Err(PauseError::PlatformPaused.into());\n    16→    }\n    17→    if game_paused {\n    18→        return Err(PauseError::GamePaused.into());\n    19→    }\n    20→    Ok(())\n    21→}\n    22→\n    23→#[cfg(test)]\n    24→mod tests {\n    25→    use super::*;\n    26→\n    27→    #[test]\n    28→    fn both_unpaused_ok() {\n    29→        assert!(check_not_paused(false, false).is_ok());\n    30→    }\n    31→\n    32→    #[test]\n    33→    fn global_paused_returns_platform_paused() {\n    34→        let err = check_not_paused(true, false).unwrap_err();\n    35→        assert!(err.to_string().contains(\"PlatformPaused\"));\n    36→    }\n    37→\n    38→    #[test]\n    39→    fn game_paused_returns_game_paused() {\n    40→        let err = check_not_paused(false, true).unwrap_err();\n    41→        assert!(err.to_string().contains(\"GamePaused\"));\n    42→    }\n    43→\n    44→    #[test]\n    45→    fn both_paused_returns_platform_paused_precedence() {\n    46→        let err = check_not_paused(true, true).unwrap_err();\n    47→        assert!(err.to_string().contains(\"PlatformPaused\"));\n    48→    }\n    49→}\n    50→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"15a36b6c-99c9-4a68-917b-721c9eb62650"}
