{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016migtZtdqDGmLPJw33LBjE","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::system_program;\n     3→\n     4→/// Error codes for escrow operations.\n     5→#[error_code]\n     6→pub enum EscrowError {\n     7→    /// The escrow PDA does not hold enough lamports for the requested transfer.\n     8→    #[msg(\"Insufficient escrow balance\")]\n     9→    InsufficientEscrowBalance,\n    10→}\n    11→\n    12→/// Transfers lamports from a PDA to a recipient using direct lamport manipulation.\n    13→///\n    14→/// This is the standard pattern for moving funds out of a program-owned PDA\n    15→/// (e.g., paying out a winner, refunding a player, sending fees to treasury).\n    16→///\n    17→/// # Example\n    18→/// ```ignore\n    19→/// transfer_lamports_from_pda(\n    20→///     &ctx.accounts.coinflip_match.to_account_info(),\n    21→///     &ctx.accounts.winner.to_account_info(),\n    22→///     payout_amount,\n    23→/// )?;\n    24→/// ```\n    25→pub fn transfer_lamports_from_pda(\n    26→    pda: &AccountInfo,\n    27→    recipient: &AccountInfo,\n    28→    amount: u64,\n    29→) -> Result<()> {\n    30→    let pda_balance = pda.lamports();\n    31→    require!(pda_balance >= amount, EscrowError::InsufficientEscrowBalance);\n    32→\n    33→    **pda.try_borrow_mut_lamports()? -= amount;\n    34→    **recipient.try_borrow_mut_lamports()? += amount;\n    35→\n    36→    Ok(())\n    37→}\n    38→\n    39→/// Transfers lamports from a signer to a PDA using system program CPI.\n    40→///\n    41→/// This is the standard pattern for depositing funds into an escrow PDA\n    42→/// (e.g., a player funding a match entry).\n    43→///\n    44→/// # Example\n    45→/// ```ignore\n    46→/// transfer_lamports_to_pda(\n    47→///     &ctx.accounts.creator.to_account_info(),\n    48→///     &ctx.accounts.coinflip_match.to_account_info(),\n    49→///     entry_amount,\n    50→///     &ctx.accounts.system_program.to_account_info(),\n    51→/// )?;\n    52→/// ```\n    53→pub fn transfer_lamports_to_pda<'a>(\n    54→    from: &AccountInfo<'a>,\n    55→    pda: &AccountInfo<'a>,\n    56→    amount: u64,\n    57→    system_program_info: &AccountInfo<'a>,\n    58→) -> Result<()> {\n    59→    system_program::transfer(\n    60→        CpiContext::new(\n    61→            system_program_info.clone(),\n    62→            system_program::Transfer {\n    63→                from: from.clone(),\n    64→                to: pda.clone(),\n    65→            },\n    66→        ),\n    67→        amount,\n    68→    )\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"8f5c96fc-ce15-4597-a840-df9ce12644f7"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_015DjQvRFZQZtcTNBa3yTcMq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AM9mW2fPeZcsmrqyyChn3K","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/vrf_orao.rs"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":5,"cache_creation_input_tokens":2863,"cache_read_input_tokens":42863,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2863},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"1be3490b-6cdd-471e-95f1-2569c94ea6d9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AM9mW2fPeZcsmrqyyChn3K","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Audit fields stored on match/round accounts for VRF traceability.\n     4→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, InitSpace)]\n     5→pub struct VrfAuditFields {\n     6→    /// Address of the Orao randomness PDA for this match/round.\n     7→    pub vrf_request_key: Pubkey,\n     8→    /// Unix timestamp when VRF was requested.\n     9→    pub vrf_requested_at: i64,\n    10→}\n    11→\n    12→/// Error codes for VRF operations.\n    13→#[error_code]\n    14→pub enum VrfError {\n    15→    /// Randomness has not been fulfilled by the VRF oracle.\n    16→    #[msg(\"VRF randomness not yet fulfilled\")]\n    17→    RandomnessNotFulfilled,\n    18→}\n    19→\n    20→/// Returns true if the 32-byte randomness is non-zero (i.e., fulfilled).\n    21→pub fn is_fulfilled(randomness: &[u8; 32]) -> bool {\n    22→    randomness.iter().any(|&b| b != 0)\n    23→}\n    24→\n    25→// ---------------------------------------------------------------------------\n    26→// Real Orao mode — CPI into Orao VRF program\n    27→// ---------------------------------------------------------------------------\n    28→\n    29→/// CPI into Orao VRF to request randomness.\n    30→#[cfg(not(feature = \"mock-vrf\"))]\n    31→pub fn request_orao_randomness<'info>(\n    32→    orao_program: &AccountInfo<'info>,\n    33→    network_state: &AccountInfo<'info>,\n    34→    treasury: &AccountInfo<'info>,\n    35→    random: &AccountInfo<'info>,\n    36→    payer: &AccountInfo<'info>,\n    37→    system_program: &AccountInfo<'info>,\n    38→    seed: [u8; 32],\n    39→) -> Result<()> {\n    40→    let cpi_accounts = orao_solana_vrf::cpi::accounts::RequestV2 {\n    41→        payer: payer.clone(),\n    42→        network_state: network_state.clone(),\n    43→        treasury: treasury.clone(),\n    44→        request: random.clone(),\n    45→        system_program: system_program.clone(),\n    46→    };\n    47→    let cpi_ctx = CpiContext::new(orao_program.clone(), cpi_accounts);\n    48→    orao_solana_vrf::cpi::request_v2(cpi_ctx, seed)\n    49→}\n    50→\n    51→/// Read fulfilled randomness from an Orao randomness account.\n    52→///\n    53→/// Deserializes the Orao `RandomnessAccountData` (supports both V1 and V2\n    54→/// accounts) and returns the first 32 bytes of the 64-byte randomness.\n    55→/// Returns an error if randomness has not been fulfilled yet.\n    56→#[cfg(not(feature = \"mock-vrf\"))]\n    57→pub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    58→    use anchor_lang::AccountDeserialize;\n    59→\n    60→    let data = randomness_account.try_borrow_data()?;\n    61→    let mut buf: &[u8] = &data;\n    62→    let account_data =\n    63→        orao_solana_vrf::state::RandomnessAccountData::try_deserialize_unchecked(&mut buf)?;\n    64→\n    65→    match account_data.fulfilled_randomness() {\n    66→        Some(randomness_64) => {\n    67→            let mut result = [0u8; 32];\n    68→            result.copy_from_slice(&randomness_64[..32]);\n    69→            Ok(result)\n    70→        }\n    71→        None => Err(error!(VrfError::RandomnessNotFulfilled)),\n    72→    }\n    73→}\n    74→\n    75→// ---------------------------------------------------------------------------\n    76→// Mock VRF mode — no Orao CPI, reads raw bytes from test account\n    77→// ---------------------------------------------------------------------------\n    78→\n    79→/// No-op in mock mode. Test authority writes mock randomness directly.\n    80→#[cfg(feature = \"mock-vrf\")]\n    81→pub fn request_orao_randomness<'info>(\n    82→    _orao_program: &AccountInfo<'info>,\n    83→    _network_state: &AccountInfo<'info>,\n    84→    _treasury: &AccountInfo<'info>,\n    85→    _random: &AccountInfo<'info>,\n    86→    _payer: &AccountInfo<'info>,\n    87→    _system_program: &AccountInfo<'info>,\n    88→    _seed: [u8; 32],\n    89→) -> Result<()> {\n    90→    Ok(())\n    91→}\n    92→\n    93→/// In mock mode, reads raw 32 bytes from account data as randomness.\n    94→/// All-zeros = unfulfilled (returns error).\n    95→#[cfg(feature = \"mock-vrf\")]\n    96→pub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    97→    let data = randomness_account.try_borrow_data()?;\n    98→    require!(data.len() >= 32, VrfError::RandomnessNotFulfilled);\n    99→\n   100→    let mut randomness = [0u8; 32];\n   101→    randomness.copy_from_slice(&data[..32]);\n   102→\n   103→    require!(is_fulfilled(&randomness), VrfError::RandomnessNotFulfilled);\n   104→    Ok(randomness)\n   105→}\n   106→\n   107→#[cfg(test)]\n   108→mod tests {\n   109→    use super::*;\n   110→\n   111→    #[test]\n   112→    fn test_is_fulfilled_all_zeros() {\n   113→        let zeros = [0u8; 32];\n   114→        assert!(!is_fulfilled(&zeros));\n   115→    }\n   116→\n   117→    #[test]\n   118→    fn test_is_fulfilled_non_zero() {\n   119→        let mut data = [0u8; 32];\n   120→        data[0] = 1;\n   121→        assert!(is_fulfilled(&data));\n   122→    }\n   123→\n   124→    #[test]\n   125→    fn test_is_fulfilled_all_ones() {\n   126→        let ones = [0xFF; 32];\n   127→        assert!(is_fulfilled(&ones));\n   128→    }\n   129→\n   130→    #[test]\n   131→    fn test_is_fulfilled_single_byte_set() {\n   132→        let mut data = [0u8; 32];\n   133→        data[31] = 42;\n   134→        assert!(is_fulfilled(&data));\n   135→    }\n   136→\n   137→    #[test]\n   138→    fn test_vrf_audit_fields_size() {\n   139→        // Pubkey (32) + i64 (8) = 40 bytes\n   140→        assert_eq!(<VrfAuditFields as anchor_lang::Space>::INIT_SPACE, 40);\n   141→    }\n   142→}\n   143→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"d114c95a-8dd8-43b3-a416-54a9848532f0"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_015DjQvRFZQZtcTNBa3yTcMq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015LRK6fV7ETNsZPpx1i1n4L","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/cpi.rs"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":5,"cache_creation_input_tokens":2863,"cache_read_input_tokens":42863,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2863},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"bfae87c2-ee84-4966-92b6-b9f5e6d886dd"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015LRK6fV7ETNsZPpx1i1n4L","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::solana_program::{\n     3→    instruction::{AccountMeta, Instruction},\n     4→    program::invoke_signed,\n     5→};\n     6→use solana_sha256_hasher::hashv;\n     7→\n     8→/// Calls the platform program's `update_player_profile` instruction via CPI.\n     9→///\n    10→/// If the profile account has no data (player hasn't created a profile), the call\n    11→/// is silently skipped — returns `Ok(())` without emitting a CPI.\n    12→///\n    13→/// This helper constructs the CPI instruction manually (discriminator + borsh args)\n    14→/// to avoid a circular dependency between `rng-shared` and `platform`.\n    15→///\n    16→/// # Arguments\n    17→///\n    18→/// * `platform_program` — The platform program account.\n    19→/// * `profile` — The player's profile PDA (mutable). Skipped if empty.\n    20→/// * `authority` — The game config PDA that signs the CPI.\n    21→/// * `signer_seeds` — Seeds for PDA signing (e.g., `&[b\"coinflip_config\", &[bump]]`).\n    22→/// * `total_games_delta` — Reserved; platform always increments by 1 per call.\n    23→/// * `wins_delta` — If > 0, player is marked as winner.\n    24→/// * `total_wagered_delta` — Lamports wagered in this game (maps to `wager_amount`).\n    25→/// * `total_won_delta` — Lamports won in this game (maps to `won_amount`, 0 if lost).\n    26→///\n    27→/// # Example\n    28→///\n    29→/// ```ignore\n    30→/// update_player_profile_cpi(\n    31→///     &ctx.accounts.platform_program,\n    32→///     &ctx.accounts.creator_profile,\n    33→///     &ctx.accounts.config.to_account_info(),\n    34→///     &[b\"coinflip_config\", &[config_bump]],\n    35→///     1,                    // total_games_delta\n    36→///     if is_winner { 1 } else { 0 }, // wins_delta\n    37→///     entry_amount,         // total_wagered_delta\n    38→///     if is_winner { payout } else { 0 }, // total_won_delta\n    39→/// )?;\n    40→/// ```\n    41→pub fn update_player_profile_cpi<'a>(\n    42→    platform_program: &AccountInfo<'a>,\n    43→    profile: &AccountInfo<'a>,\n    44→    authority: &AccountInfo<'a>,\n    45→    signer_seeds: &[&[u8]],\n    46→    _total_games_delta: u64,\n    47→    wins_delta: u64,\n    48→    total_wagered_delta: u64,\n    49→    total_won_delta: u64,\n    50→) -> Result<()> {\n    51→    // Guard: skip if profile hasn't been created yet\n    52→    if profile.data_is_empty() {\n    53→        return Ok(());\n    54→    }\n    55→\n    56→    // Map to platform program's actual parameters\n    57→    let wager_amount = total_wagered_delta;\n    58→    let won_amount = total_won_delta;\n    59→    let is_winner = wins_delta > 0;\n    60→\n    61→    // Discriminator = sha256(\"global:update_player_profile\")[0..8]\n    62→    let disc = hashv(&[b\"global:update_player_profile\"]);\n    63→\n    64→    // Instruction data: 8-byte discriminator + wager_amount(u64) + won_amount(u64) + is_winner(bool)\n    65→    let mut data = [0u8; 25];\n    66→    data[..8].copy_from_slice(&disc.to_bytes()[..8]);\n    67→    data[8..16].copy_from_slice(&wager_amount.to_le_bytes());\n    68→    data[16..24].copy_from_slice(&won_amount.to_le_bytes());\n    69→    data[24] = u8::from(is_winner);\n    70→\n    71→    let accounts = vec![\n    72→        AccountMeta::new_readonly(*authority.key, true), // caller (signer)\n    73→        AccountMeta::new(*profile.key, false),           // profile (mutable)\n    74→    ];\n    75→\n    76→    let ix = Instruction {\n    77→        program_id: *platform_program.key,\n    78→        accounts,\n    79→        data: data.to_vec(),\n    80→    };\n    81→\n    82→    invoke_signed(\n    83→        &ix,\n    84→        &[authority.clone(), profile.clone(), platform_program.clone()],\n    85→        &[signer_seeds],\n    86→    )?;\n    87→\n    88→    Ok(())\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"98eba131-7884-41f7-b8da-abf9df44a2d0"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01WuDiswrjE48hV954ctgswq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017t1tMHm3bR61jojynARcHu","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":7117,"cache_read_input_tokens":26288,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7117},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_018poVaiPCaLoVnRcXeMPPQ9","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"5808d2ec-1637-4d64-9ec3-23731ce57ac4"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017t1tMHm3bR61jojynARcHu","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey, type Transaction } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchClaimableMatches,\n    16→  fetchMatchByCreator,\n    17→  fetchMatch,\n    18→  getMatchPda,\n    19→  buildCreateMatchTx,\n    20→  buildJoinMatchTx,\n    21→  buildCancelMatchTx,\n    22→  buildTimeoutCancelTx,\n    23→  buildClaimPayoutTx,\n    24→} from \"../utils/chain\";\n    25→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    26→\n    27→/** Parse Solana/wallet errors into user-friendly messages */\n    28→function parseTransactionError(err: unknown): string {\n    29→  const msg = err instanceof Error ? err.message : String(err);\n    30→\n    31→  // Wallet not connected\n    32→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    33→    return \"Wallet not connected. Please connect your wallet first.\";\n    34→  }\n    35→\n    36→  // User rejected\n    37→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    38→    return \"Transaction cancelled by user.\";\n    39→  }\n    40→\n    41→  // Insufficient funds (Solana runtime error)\n    42→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    43→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    44→  }\n    45→\n    46→  // Account already in use (match already exists)\n    47→  if (msg.includes(\"already in use\")) {\n    48→    return \"You already have an active match. Cancel it before creating a new one.\";\n    49→  }\n    50→\n    51→  // Network / RPC errors\n    52→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    53→    return \"Network error. Please check your connection and try again.\";\n    54→  }\n    55→\n    56→  // Anchor program errors\n    57→  if (msg.includes(\"InvalidPhase\")) {\n    58→    return \"This match is no longer available.\";\n    59→  }\n    60→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    61→    return \"You cannot join your own match.\";\n    62→  }\n    63→\n    64→  // Simulation / preflight failures\n    65→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    66→    return \"Transaction simulation failed. The match may no longer be available.\";\n    67→  }\n    68→\n    69→  // Blockhash expiry\n    70→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    71→    return \"Transaction expired. Please try again.\";\n    72→  }\n    73→\n    74→  // Generic fallback — log full error for debugging\n    75→  console.error(\"[coinflip] unhandled transaction error:\", err);\n    76→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    77→}\n    78→\n    79→interface CoinflipContextValue {\n    80→  // State\n    81→  activeMatch: UIMatch | null;\n    82→  openMatches: UIMatch[];\n    83→  claimableMatches: UIMatch[];\n    84→  userHistory: UIMatch[];\n    85→  selectedTier: Tier | null;\n    86→  selectedSide: CoinSide | null;\n    87→\n    88→  // Loading states\n    89→  loading: boolean;\n    90→  creating: boolean;\n    91→  joining: boolean;\n    92→  claiming: boolean;\n    93→  joiningMatchId: string | null;\n    94→\n    95→  // Error state\n    96→  error: string | null;\n    97→  clearError: () => void;\n    98→\n    99→  // Verification\n   100→  lastClaimSignature: string | null;\n   101→\n   102→  // Actions\n   103→  setSelectedTier: (tier: Tier | null) => void;\n   104→  setSelectedSide: (side: CoinSide | null) => void;\n   105→  createMatch: () => Promise<void>;\n   106→  joinMatch: (matchId: string) => Promise<void>;\n   107→  cancelMatch: () => Promise<void>;\n   108→  timeoutCancel: () => Promise<void>;\n   109→  claimPayout: () => Promise<void>;\n   110→  clearActiveMatch: () => void;\n   111→  selectMatch: (match: UIMatch) => void;\n   112→  refreshMatches: () => void;\n   113→}\n   114→\n   115→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n   116→\n   117→export function CoinflipProvider({ children }: { children: ReactNode }) {\n   118→  const { connected, publicKey, sendTransaction } = useWallet();\n   119→  const { connection } = useConnection();\n   120→  const { refresh: refreshBalance } = useBalance();\n   121→\n   122→  // Selection state\n   123→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   124→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   125→\n   126→  // Match state\n   127→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   128→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   129→  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n   130→  const [userHistory] = useState<UIMatch[]>([]);\n   131→\n   132→  // Loading states\n   133→  const [loading, setLoading] = useState(true);\n   134→  const [creating, setCreating] = useState(false);\n   135→  const [joining, setJoining] = useState(false);\n   136→  const [claiming, setClaiming] = useState(false);\n   137→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   138→\n   139→  // Error state\n   140→  const [error, setError] = useState<string | null>(null);\n   141→  const clearError = useCallback(() => setError(null), []);\n   142→\n   143→  // Verification — last claim tx signature for fairness verification\n   144→  const [lastClaimSignature, setLastClaimSignature] = useState<string | null>(null);\n   145→\n   146→  // Timer ref for flip animation delay (ready→flipping→complete)\n   147→  const flipTimerRef = useRef<number | null>(null);\n   148→\n   149→  // Ref to prevent polling races from restoring a dismissed match.\n   150→  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n   151→  // from the previous poll interval may resolve and call setActiveMatch,\n   152→  // putting them back on the match view. This ref blocks that.\n   153→  const dismissedMatchRef = useRef<string | null>(null);\n   154→\n   155→  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n   156→  const sendAndConfirm = useCallback(\n   157→    async (transaction: Transaction): Promise<string> => {\n   158→      const { blockhash, lastValidBlockHeight } =\n   159→        await connection.getLatestBlockhash(\"confirmed\");\n   160→      const signature = await sendTransaction(transaction);\n   161→      await connection.confirmTransaction(\n   162→        { signature, blockhash, lastValidBlockHeight },\n   163→        \"confirmed\",\n   164→      );\n   165→      await refreshBalance();\n   166→      return signature;\n   167→    },\n   168→    [connection, sendTransaction, refreshBalance],\n   169→  );\n   170→\n   171→  // Fetch open matches (and claimable matches when wallet connected) from on-chain\n   172→  const refreshMatches = useCallback(() => {\n   173→    fetchAllOpenMatches(connection)\n   174→      .then((matches) => {\n   175→        setOpenMatches(matches);\n   176→        setLoading(false);\n   177→      })\n   178→      .catch(() => {\n   179→        setLoading(false);\n   180→      });\n   181→\n   182→    if (publicKey) {\n   183→      fetchClaimableMatches(connection, publicKey)\n   184→        .then(setClaimableMatches)\n   185→        .catch(() => {});\n   186→    }\n   187→  }, [connection, publicKey]);\n   188→\n   189→  // Initial load\n   190→  useEffect(() => {\n   191→    setLoading(true);\n   192→    refreshMatches();\n   193→  }, [refreshMatches]);\n   194→\n   195→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   196→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   197→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   198→\n   199→  useEffect(() => {\n   200→    const interval = setInterval(() => {\n   201→      refreshMatches();\n   202→\n   203→      // If there's an active match, refresh it too (skip during flip animation\n   204→      // and when already claimed — PDA is closed on-chain)\n   205→      if (activeMatch && activeMatch.phase !== \"flipping\" && !activeMatch.claimed) {\n   206→        const matchPda = new PublicKey(activeMatch.id);\n   207→        fetchMatch(connection, matchPda)\n   208→          .then((updated) => {\n   209→            // If user dismissed this match while fetch was in flight, ignore\n   210→            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n   211→\n   212→            if (updated) {\n   213→              // Intercept ready→complete: insert 3s flip animation first\n   214→              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n   215→                setActiveMatch({ ...updated, phase: \"flipping\" });\n   216→                flipTimerRef.current = window.setTimeout(() => {\n   217→                  flipTimerRef.current = null;\n   218→                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n   219→                  setActiveMatch((current) =>\n   220→                    current?.phase === \"flipping\" ? updated : current\n   221→                  );\n   222→                }, 3000);\n   223→              } else {\n   224→                setActiveMatch(updated);\n   225→              }\n   226→            } else {\n   227→              // Match account closed (claimed or cancelled)\n   228→              setActiveMatch(null);\n   229→            }\n   230→          })\n   231→          .catch(() => {\n   232→            // Ignore polling errors\n   233→          });\n   234→      }\n   235→    }, pollInterval);\n   236→    return () => clearInterval(interval);\n   237→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   238→\n   239→  // Cleanup flip timer on unmount\n   240→  useEffect(() => {\n   241→    return () => {\n   242→      if (flipTimerRef.current !== null) {\n   243→        clearTimeout(flipTimerRef.current);\n   244→      }\n   245→    };\n   246→  }, []);\n   247→\n   248→  const createMatch = useCallback(async () => {\n   249→    if (!connected || !publicKey) {\n   250→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   251→      return;\n   252→    }\n   253→    if (!selectedTier || !selectedSide) {\n   254→      setError(\"Select tier and side first.\");\n   255→      return;\n   256→    }\n   257→\n   258→    setCreating(true);\n   259→    setError(null);\n   260→    try {\n   261→      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n   262→      const [matchPda] = getMatchPda(publicKey);\n   263→      const existing = await fetchMatch(connection, matchPda);\n   264→      if (existing) {\n   265→        if (existing.phase === \"complete\") {\n   266→          // Match is settled — show it so user can settle (winner claims, loser closes)\n   267→          setActiveMatch(existing);\n   268→          dismissedMatchRef.current = null;\n   269→          setError(\"Settle your previous match first.\");\n   270→        } else {\n   271→          // Match still in progress\n   272→          setActiveMatch(existing);\n   273→          dismissedMatchRef.current = null;\n   274→          setError(\"You already have an active match.\");\n   275→        }\n   276→        return;\n   277→      }\n   278→\n   279→      const { transaction } = await buildCreateMatchTx(\n   280→        connection,\n   281→        publicKey,\n   282→        selectedTier,\n   283→        selectedSide\n   284→      );\n   285→\n   286→      await sendAndConfirm(transaction);\n   287→\n   288→      // Clear dismissed ref — this is a new intentional match\n   289→      dismissedMatchRef.current = null;\n   290→\n   291→      // Fetch the created match from on-chain\n   292→      const match = await fetchMatch(connection, matchPda);\n   293→      if (match) {\n   294→        setActiveMatch(match);\n   295→      }\n   296→\n   297→      setSelectedSide(null);\n   298→      refreshMatches();\n   299→    } catch (err) {\n   300→      setError(parseTransactionError(err));\n   301→    } finally {\n   302→      setCreating(false);\n   303→    }\n   304→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n   305→\n   306→  const joinMatch = useCallback(\n   307→    async (matchId: string) => {\n   308→      if (!connected || !publicKey) {\n   309→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   310→        return;\n   311→      }\n   312→\n   313→      setJoining(true);\n   314→      setJoiningMatchId(matchId);\n   315→      setError(null);\n   316→      try {\n   317→        // matchId is the match PDA base58 — fetch to get the creator\n   318→        const matchPda = new PublicKey(matchId);\n   319→        const existingMatch = await fetchMatch(connection, matchPda);\n   320→        if (!existingMatch) {\n   321→          setError(\"Match not found. It may have been cancelled.\");\n   322→          return;\n   323→        }\n   324→\n   325→        const matchCreator = new PublicKey(existingMatch.player1);\n   326→        const transaction = await buildJoinMatchTx(\n   327→          connection,\n   328→          publicKey,\n   329→          matchCreator\n   330→        );\n   331→\n   332→        await sendAndConfirm(transaction);\n   333→\n   334→        // Clear dismissed ref — this is a new intentional match\n   335→        dismissedMatchRef.current = null;\n   336→\n   337→        // Fetch updated match\n   338→        const updated = await fetchMatch(connection, matchPda);\n   339→        if (updated) {\n   340→          setActiveMatch(updated);\n   341→        }\n   342→\n   343→        refreshMatches();\n   344→      } catch (err) {\n   345→        setError(parseTransactionError(err));\n   346→      } finally {\n   347→        setJoining(false);\n   348→        setJoiningMatchId(null);\n   349→      }\n   350→    },\n   351→    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n   352→  );\n   353→\n   354→  const cancelMatch = useCallback(async () => {\n   355→    if (!connected || !publicKey || !activeMatch) {\n   356→      setError(\"No active match to cancel.\");\n   357→      return;\n   358→    }\n   359→\n   360→    setError(null);\n   361→    try {\n   362→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   363→      await sendAndConfirm(transaction);\n   364→      setActiveMatch(null);\n   365→      refreshMatches();\n   366→    } catch (err) {\n   367→      setError(parseTransactionError(err));\n   368→    }\n   369→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   370→\n   371→  const timeoutCancel = useCallback(async () => {\n   372→    if (!connected || !publicKey || !activeMatch) {\n   373→      setError(\"No active match to cancel.\");\n   374→      return;\n   375→    }\n   376→    if (!activeMatch.player2) {\n   377→      setError(\"Match has no opponent.\");\n   378→      return;\n   379→    }\n   380→\n   381→    setError(null);\n   382→    try {\n   383→      const matchCreator = new PublicKey(activeMatch.player1);\n   384→      const opponent = new PublicKey(activeMatch.player2);\n   385→\n   386→      const transaction = await buildTimeoutCancelTx(\n   387→        connection,\n   388→        publicKey,\n   389→        matchCreator,\n   390→        opponent\n   391→      );\n   392→      await sendAndConfirm(transaction);\n   393→      setActiveMatch(null);\n   394→      refreshMatches();\n   395→    } catch (err) {\n   396→      setError(parseTransactionError(err));\n   397→    }\n   398→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   399→\n   400→  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   401→   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n   402→  const claimPayout = useCallback(async () => {\n   403→    if (!connected || !publicKey || !activeMatch) {\n   404→      setError(\"No active match to claim.\");\n   405→      return;\n   406→    }\n   407→    if (!activeMatch.player2) {\n   408→      setError(\"Match has no opponent yet.\");\n   409→      return;\n   410→    }\n   411→\n   412→    setClaiming(true);\n   413→    setError(null);\n   414→    try {\n   415→      const matchCreator = new PublicKey(activeMatch.player1);\n   416→      const opponent = new PublicKey(activeMatch.player2);\n   417→\n   418→      const transaction = await buildClaimPayoutTx(\n   419→        connection,\n   420→        publicKey,   // caller (either player — winner derived on-chain from VRF)\n   421→        matchCreator,\n   422→        opponent\n   423→      );\n   424→\n   425→      const signature = await sendAndConfirm(transaction);\n   426→\n   427→      // Match PDA is now closed on-chain. Keep activeMatch locally with\n   428→      // claimed=true so the user can verify fairness before returning to lobby.\n   429→      setLastClaimSignature(signature);\n   430→      setActiveMatch((prev) => prev ? { ...prev, claimed: true } : null);\n   431→      refreshMatches();\n   432→    } catch (err) {\n   433→      setError(parseTransactionError(err));\n   434→    } finally {\n   435→      setClaiming(false);\n   436→    }\n   437→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   438→\n   439→  // Track if user explicitly cleared the match\n   440→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   441→\n   442→  /** Open a match from the claimable list in ActiveMatchView. */\n   443→  const selectMatch = useCallback((match: UIMatch) => {\n   444→    dismissedMatchRef.current = null;\n   445→    setActiveMatch(match);\n   446→    setUserClearedMatch(false);\n   447→  }, []);\n   448→\n   449→  const clearActiveMatch = useCallback(() => {\n   450→    // Record the dismissed match ID so in-flight polls don't restore it\n   451→    dismissedMatchRef.current = activeMatch?.id ?? null;\n   452→    setActiveMatch(null);\n   453→    setLastClaimSignature(null);\n   454→    setUserClearedMatch(true);\n   455→    setError(null);\n   456→    refreshMatches();\n   457→  }, [activeMatch, refreshMatches]);\n   458→\n   459→  // Check for existing active match on wallet connect\n   460→  useEffect(() => {\n   461→    if (publicKey && !activeMatch && !userClearedMatch) {\n   462→      fetchMatchByCreator(connection, publicKey)\n   463→        .then((match) => {\n   464→          if (match) {\n   465→            // Don't restore a match the user explicitly dismissed\n   466→            if (dismissedMatchRef.current === match.id) return;\n   467→            setActiveMatch(match);\n   468→          }\n   469→        })\n   470→        .catch(() => {\n   471→          // No active match found\n   472→        });\n   473→    }\n   474→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   475→\n   476→  // Reset userClearedMatch when creating or joining a new match\n   477→  useEffect(() => {\n   478→    if (activeMatch) {\n   479→      setUserClearedMatch(false);\n   480→    }\n   481→  }, [activeMatch]);\n   482→\n   483→  const value: CoinflipContextValue = {\n   484→    activeMatch,\n   485→    openMatches,\n   486→    claimableMatches,\n   487→    userHistory,\n   488→    selectedTier,\n   489→    selectedSide,\n   490→    loading,\n   491→    creating,\n   492→    joining,\n   493→    claiming,\n   494→    joiningMatchId,\n   495→    error,\n   496→    clearError,\n   497→    lastClaimSignature,\n   498→    setSelectedTier,\n   499→    setSelectedSide,\n   500→    createMatch,\n   501→    joinMatch,\n   502→    cancelMatch,\n   503→    timeoutCancel,\n   504→    claimPayout,\n   505→    clearActiveMatch,\n   506→    selectMatch,\n   507→    refreshMatches,\n   508→  };\n   509→\n   510→  return (\n   511→    <CoinflipContext.Provider value={value}>\n   512→      {children}\n   513→    </CoinflipContext.Provider>\n   514→  );\n   515→}\n   516→\n   517→export function useCoinflip(): CoinflipContextValue {\n   518→  const context = useContext(CoinflipContext);\n   519→  if (!context) {\n   520→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   521→  }\n   522→  return context;\n   523→}\n   524→"}]},"parent_tool_use_id":"toolu_018poVaiPCaLoVnRcXeMPPQ9","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"cc40cda6-37b1-40b7-883b-a442e32cd1d4"}
