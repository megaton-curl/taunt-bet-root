{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JKS3Wd9omxMcCBWAXNvTCe","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::fees::TOTAL_FEE_BPS;\n     3→\n     4→use crate::state::PlatformConfig;\n     5→\n     6→#[derive(Accounts)]\n     7→pub struct InitializePlatform<'info> {\n     8→    /// The admin who initializes the platform config.\n     9→    #[account(mut)]\n    10→    pub authority: Signer<'info>,\n    11→\n    12→    /// The singleton config PDA.\n    13→    #[account(\n    14→        init,\n    15→        payer = authority,\n    16→        space = 8 + PlatformConfig::INIT_SPACE,\n    17→        seeds = [b\"platform_config\"],\n    18→        bump,\n    19→    )]\n    20→    pub config: Account<'info, PlatformConfig>,\n    21→\n    22→    pub system_program: Program<'info, System>,\n    23→}\n    24→\n    25→pub fn handler(ctx: Context<InitializePlatform>, treasury: Pubkey) -> Result<()> {\n    26→    let config = &mut ctx.accounts.config;\n    27→    config.authority = ctx.accounts.authority.key();\n    28→    config.treasury = treasury;\n    29→    config.fee_bps = TOTAL_FEE_BPS;\n    30→    config.bump = ctx.bumps.config;\n    31→    Ok(())\n    32→}\n    33→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"342a4cd4-c5f6-48f5-8daa-fdf581726c70"}
