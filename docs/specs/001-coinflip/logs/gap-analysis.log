{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LMwSXmNTKPeMjzsa6fwqg3","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::lifecycle::RoundPhase;\n     3→\n     4→use crate::error::CoinflipError;\n     5→use crate::state::CoinflipMatch;\n     6→\n     7→#[derive(Accounts)]\n     8→pub struct CancelMatch<'info> {\n     9→    /// The creator cancelling their match.\n    10→    #[account(mut)]\n    11→    pub creator: Signer<'info>,\n    12→\n    13→    /// The match PDA (closed on cancel — escrow + rent refunded to creator).\n    14→    #[account(\n    15→        mut,\n    16→        close = creator,\n    17→        seeds = [b\"match\", creator.key().as_ref()],\n    18→        bump = coinflip_match.bump,\n    19→    )]\n    20→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    21→\n    22→    pub system_program: Program<'info, System>,\n    23→}\n    24→\n    25→pub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    26→    let coinflip_match = &ctx.accounts.coinflip_match;\n    27→\n    28→    // Cancel is only allowed from Waiting phase (before opponent joins).\n    29→    // Locked→Refunded is handled by timeout_cancel, not cancel.\n    30→    require!(\n    31→        coinflip_match.phase == RoundPhase::Waiting,\n    32→        CoinflipError::CannotCancel\n    33→    );\n    34→\n    35→    // Account is closed by Anchor's `close = creator` constraint —\n    36→    // all lamports (escrow + rent) are returned to creator.\n    37→\n    38→    Ok(())\n    39→}\n    40→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"33800c8b-9a13-43e9-856a-b4c293d866d9"}
