{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R3CZH2WTFs6cYDf1d7fKaM","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::state::PlayerProfile;\n     4→\n     5→#[derive(Accounts)]\n     6→#[instruction(wager_amount: u64, won_amount: u64, is_winner: bool)]\n     7→pub struct UpdatePlayerProfile<'info> {\n     8→    /// The game program (coinflip) calling via CPI.\n     9→    pub caller: Signer<'info>,\n    10→\n    11→    /// The player profile PDA to update.\n    12→    #[account(\n    13→        mut,\n    14→        seeds = [b\"player_profile\", profile.authority.as_ref()],\n    15→        bump = profile.bump,\n    16→    )]\n    17→    pub profile: Account<'info, PlayerProfile>,\n    18→}\n    19→\n    20→pub fn handler(\n    21→    ctx: Context<UpdatePlayerProfile>,\n    22→    wager_amount: u64,\n    23→    won_amount: u64,\n    24→    is_winner: bool,\n    25→) -> Result<()> {\n    26→    let profile = &mut ctx.accounts.profile;\n    27→    profile.total_games = profile.total_games.checked_add(1).unwrap();\n    28→    profile.total_wagered = profile.total_wagered.checked_add(wager_amount).unwrap();\n    29→    if is_winner {\n    30→        profile.wins = profile.wins.checked_add(1).unwrap();\n    31→        profile.total_won = profile.total_won.checked_add(won_amount).unwrap();\n    32→    }\n    33→    Ok(())\n    34→}\n    35→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"47aa664d-9eb6-4f2f-ae6c-688adb12b987"}
