{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DQ4TyK4EB3MSrSZkUrhsNm","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::is_valid_side;\n     3→use rng_shared::escrow::transfer_lamports_to_pda;\n     4→use rng_shared::lifecycle::RoundPhase;\n     5→use rng_shared::pause::check_not_paused;\n     6→use rng_shared::tiers::get_tier_amount;\n     7→\n     8→use crate::error::CoinflipError;\n     9→use crate::state::{CoinflipConfig, CoinflipMatch};\n    10→\n    11→#[derive(Accounts)]\n    12→pub struct CreateMatch<'info> {\n    13→    /// The player creating the match. Must sign and fund the escrow.\n    14→    #[account(mut)]\n    15→    pub creator: Signer<'info>,\n    16→\n    17→    /// The match PDA. Seeds enforce one active match per creator.\n    18→    #[account(\n    19→        init,\n    20→        payer = creator,\n    21→        space = 8 + CoinflipMatch::INIT_SPACE,\n    22→        seeds = [b\"match\", creator.key().as_ref()],\n    23→        bump,\n    24→    )]\n    25→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    26→\n    27→    /// The config PDA (read-only, for pause check).\n    28→    #[account(\n    29→        seeds = [b\"coinflip_config\"],\n    30→        bump = config.bump,\n    31→    )]\n    32→    pub config: Account<'info, CoinflipConfig>,\n    33→\n    34→    pub system_program: Program<'info, System>,\n    35→}\n    36→\n    37→pub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    38→    // Pause check: reject new matches when game is paused\n    39→    check_not_paused(false, ctx.accounts.config.paused)?;\n    40→\n    41→    require!(is_valid_side(side), CoinflipError::InvalidSide);\n    42→\n    43→    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n    44→\n    45→    // Transfer entry_amount from creator to match PDA (escrow)\n    46→    transfer_lamports_to_pda(\n    47→        &ctx.accounts.creator.to_account_info(),\n    48→        &ctx.accounts.coinflip_match.to_account_info(),\n    49→        entry_amount,\n    50→        &ctx.accounts.system_program.to_account_info(),\n    51→    )?;\n    52→\n    53→    let now = Clock::get()?.unix_timestamp;\n    54→\n    55→    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    56→    coinflip_match.creator = ctx.accounts.creator.key();\n    57→    coinflip_match.opponent = Pubkey::default();\n    58→    coinflip_match.tier = tier;\n    59→    coinflip_match.entry_amount = entry_amount;\n    60→    coinflip_match.creator_side = side;\n    61→    coinflip_match.phase = RoundPhase::Waiting;\n    62→    coinflip_match.result = 0;\n    63→    coinflip_match.winner = Pubkey::default();\n    64→    coinflip_match.claimed = false;\n    65→    coinflip_match.created_at = now;\n    66→    coinflip_match.locked_at = 0;\n    67→    coinflip_match.resolve_deadline = 0;\n    68→    coinflip_match.vrf_request_key = Pubkey::default();\n    69→    coinflip_match.bump = ctx.bumps.coinflip_match;\n    70→\n    71→    Ok(())\n    72→}\n    73→"}]},"parent_tool_use_id":"toolu_0167SZpHWYz888exQD88pRBj","session_id":"c8e2c010-62bf-4268-abe7-c7c2643456f8","uuid":"ef078939-9192-4e7d-93a9-36c892805177"}
