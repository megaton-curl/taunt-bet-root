{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B3EE1juVtu2XJRxJthGNbG","type":"tool_result","content":"     1→import { useState } from \"react\";\n     2→import {\n     3→  GameLayout,\n     4→  TierSelector,\n     5→  TIER_COLORS,\n     6→  Toast,\n     7→  Modal,\n     8→  type HistoryEntry,\n     9→} from \"@rng-utopia/ui\";\n    10→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    11→import { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\n    12→import {\n    13→  CoinflipProvider,\n    14→  useCoinflip,\n    15→  CoinSideSelector,\n    16→  OpenMatchesList,\n    17→  ActiveMatchView,\n    18→  type UIMatch,\n    19→} from \"../features/coinflip\";\n    20→\n    21→function CoinflipPageContent() {\n    22→  const { connected, address, connect } = useWallet();\n    23→  const {\n    24→    activeMatch,\n    25→    openMatches,\n    26→    claimableMatches,\n    27→    userHistory,\n    28→    selectedTier,\n    29→    selectedSide,\n    30→    loading,\n    31→    creating,\n    32→    joiningMatchId,\n    33→    error,\n    34→    clearError,\n    35→    setSelectedTier,\n    36→    setSelectedSide,\n    37→    createMatch,\n    38→    joinMatch,\n    39→    claiming,\n    40→    cancelMatch,\n    41→    timeoutCancel,\n    42→    claimPayout,\n    43→    clearActiveMatch,\n    44→    selectMatch,\n    45→  } = useCoinflip();\n    46→\n    47→  // State for history detail modal\n    48→  const [selectedHistoryMatch, setSelectedHistoryMatch] = useState<UIMatch | null>(null);\n    49→\n    50→  // Side colors (match the CSS .side-heads / .side-tails)\n    51→  const SIDE_COLORS = {\n    52→    heads: \"#45b058\",\n    53→    tails: \"#e09030\",\n    54→  };\n    55→\n    56→  // Convert user history to HistoryEntry format\n    57→  const historyEntries: HistoryEntry[] = userHistory.map((match) => {\n    58→    const isWinner = match.winner === address;\n    59→    const isPlayer1 = match.player1 === address;\n    60→    const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    61→    const tierCapitalized = match.tier.charAt(0).toUpperCase() + match.tier.slice(1);\n    62→    const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n    63→    const tierColor = TIER_COLORS[match.tier];\n    64→    const outcomeColor = isWinner ? \"#45b058\" : \"#d45d5d\";\n    65→\n    66→    return {\n    67→      roundId: match.id.slice(-6),\n    68→      result: (\n    69→        <span className=\"coinflip-history-result\">\n    70→          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n    71→            {yourSide?.toUpperCase() ?? \"?\"}\n    72→          </span>\n    73→          <span className=\"coinflip-history-result__separator\">|</span>\n    74→          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n    75→            {tierCapitalized}\n    76→          </span>\n    77→          <span className=\"coinflip-history-result__separator\">|</span>\n    78→          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n    79→            {isWinner ? \"WON\" : \"LOST\"}\n    80→          </span>\n    81→        </span>\n    82→      ),\n    83→      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n    84→      timestamp: new Date(match.completedAt ?? match.createdAt),\n    85→      verified: true,\n    86→      won: isWinner,\n    87→      onClick: () => setSelectedHistoryMatch(match),\n    88→    };\n    89→  });\n    90→\n    91→  // Calculate potential payout\n    92→  const potentialPayout = selectedTier\n    93→    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n    94→    : 0;\n    95→\n    96→  const handleCreateMatch = () => {\n    97→    createMatch();\n    98→  };\n    99→\n   100→  const handleJoinMatch = (matchId: string) => {\n   101→    joinMatch(matchId);\n   102→  };\n   103→\n   104→  // Sidebar content\n   105→  const sidebar = (\n   106→    <div className=\"coinflip-sidebar\">\n   107→      {!activeMatch ? (\n   108→        <>\n   109→          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n   110→\n   111→          {/* Tier Selection */}\n   112→          <div className=\"coinflip-sidebar__section\">\n   113→            <div className=\"coinflip-sidebar__label-row\">\n   114→              <label className=\"coinflip-sidebar__label\">\n   115→                Select Tier\n   116→              </label>\n   117→              <button\n   118→                type=\"button\"\n   119→                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n   120→                onClick={() => setSelectedTier(null)}\n   121→              >\n   122→                All\n   123→              </button>\n   124→            </div>\n   125→            <TierSelector\n   126→              selectedTier={selectedTier}\n   127→              onSelect={setSelectedTier}\n   128→            />\n   129→          </div>\n   130→\n   131→          {/* Side Selection */}\n   132→          <div className=\"coinflip-sidebar__section\">\n   133→            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n   134→            <CoinSideSelector\n   135→              selectedSide={selectedSide}\n   136→              onSelect={setSelectedSide}\n   137→              disabled={!connected}\n   138→            />\n   139→          </div>\n   140→\n   141→          {/* Summary */}\n   142→          {selectedTier && selectedSide && (\n   143→            <div className=\"coinflip-sidebar__summary\">\n   144→              <div className=\"coinflip-sidebar__row\">\n   145→                <span>Entry</span>\n   146→                <span>{`$${TIER_AMOUNTS[selectedTier]}`}</span>\n   147→              </div>\n   148→              <div className=\"coinflip-sidebar__row\">\n   149→                <span>Potential Payout</span>\n   150→                <span className=\"coinflip-sidebar__payout\">\n   151→                  {`$${potentialPayout.toFixed(2)}`}\n   152→                </span>\n   153→              </div>\n   154→            </div>\n   155→          )}\n   156→\n   157→          {/* Action Button */}\n   158→          {!connected ? (\n   159→            <button\n   160→              type=\"button\"\n   161→              className=\"coinflip-action-btn\"\n   162→              onClick={connect}\n   163→            >\n   164→              Connect Wallet\n   165→            </button>\n   166→          ) : (\n   167→            <button\n   168→              type=\"button\"\n   169→              className=\"coinflip-action-btn\"\n   170→              onClick={handleCreateMatch}\n   171→              disabled={!selectedTier || !selectedSide || creating}\n   172→            >\n   173→              {creating ? \"Creating...\" : \"Create Game\"}\n   174→            </button>\n   175→          )}\n   176→        </>\n   177→      ) : (\n   178→        <>\n   179→          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n   180→\n   181→          <div className=\"coinflip-sidebar__game-info\">\n   182→            <div className=\"coinflip-sidebar__row\">\n   183→              <span>Tier</span>\n   184→              <span\n   185→                className=\"coinflip-sidebar__tier\"\n   186→                style={{\n   187→                  color: TIER_COLORS[activeMatch.tier],\n   188→                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n   189→                }}\n   190→              >\n   191→                {activeMatch.tier}\n   192→              </span>\n   193→            </div>\n   194→            <div className=\"coinflip-sidebar__row\">\n   195→              <span>Your Side</span>\n   196→              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n   197→                {(activeMatch.player1 === address\n   198→                  ? activeMatch.player1Side\n   199→                  : activeMatch.player2Side\n   200→                )?.toUpperCase()}\n   201→              </span>\n   202→            </div>\n   203→            <div className=\"coinflip-sidebar__row\">\n   204→              <span>Entry</span>\n   205→              <span>{`$${activeMatch.entryAmount}`}</span>\n   206→            </div>\n   207→            <div className=\"coinflip-sidebar__row\">\n   208→              <span>Pot</span>\n   209→              <span className=\"coinflip-sidebar__pot\">{`$${activeMatch.entryAmount * 2}`}</span>\n   210→            </div>\n   211→            <div className=\"coinflip-sidebar__row\">\n   212→              <span>Status</span>\n   213→              <span className=\"coinflip-sidebar__status\">\n   214→                {activeMatch.phase === \"created\" && \"Waiting...\"}\n   215→                {activeMatch.phase === \"ready\" && \"Ready!\"}\n   216→                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n   217→                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n   218→                {activeMatch.phase === \"complete\" && \"Complete\"}\n   219→              </span>\n   220→            </div>\n   221→          </div>\n   222→\n   223→          {/* Round Fairness Info */}\n   224→          <div className=\"coinflip-sidebar__fairness\">\n   225→            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n   226→            <div className=\"coinflip-sidebar__fairness-row\">\n   227→              <span>Match ID</span>\n   228→              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n   229→                {activeMatch.id.slice(-8)}\n   230→              </span>\n   231→            </div>\n   232→            <div className=\"coinflip-sidebar__fairness-row\">\n   233→              <span>Seed Hash</span>\n   234→              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n   235→                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n   236→              </span>\n   237→            </div>\n   238→            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n   239→              <>\n   240→                <div className=\"coinflip-sidebar__fairness-row\">\n   241→                  <span>Server Seed</span>\n   242→                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n   243→                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n   244→                  </span>\n   245→                </div>\n   246→                {activeMatch.blockHash && (\n   247→                  <div className=\"coinflip-sidebar__fairness-row\">\n   248→                    <span>Block Hash</span>\n   249→                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n   250→                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n   251→                    </span>\n   252→                  </div>\n   253→                )}\n   254→              </>\n   255→            )}\n   256→          </div>\n   257→\n   258→          {activeMatch.phase === \"complete\" && !activeMatch.claimed && (\n   259→            <button\n   260→              type=\"button\"\n   261→              className=\"coinflip-action-btn\"\n   262→              onClick={claimPayout}\n   263→              disabled={claiming}\n   264→            >\n   265→              {claiming\n   266→                ? \"Settling...\"\n   267→                : activeMatch.winner === address\n   268→                  ? \"Claim Payout\"\n   269→                  : \"Settle & Return\"}\n   270→            </button>\n   271→          )}\n   272→          {activeMatch.phase === \"complete\" && activeMatch.claimed && (\n   273→            <button\n   274→              type=\"button\"\n   275→              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   276→              onClick={clearActiveMatch}\n   277→            >\n   278→              Back to Lobby\n   279→            </button>\n   280→          )}\n   281→        </>\n   282→      )}\n   283→    </div>\n   284→  );\n   285→\n   286→  // Helper to get side display for modal\n   287→  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n   288→    const side = isPlayer1 ? match.player1Side : match.player2Side;\n   289→    return side?.toUpperCase() ?? \"?\";\n   290→  };\n   291→\n   292→  return (\n   293→    <>\n   294→      <GameLayout\n   295→        gameName=\"Coinflip\"\n   296→        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n   297→        sidebar={sidebar}\n   298→        historyEntries={historyEntries}\n   299→        showHistory={true}\n   300→      >\n   301→        <div className=\"coinflip-main\">\n   302→          {/* Show active match or lobby */}\n   303→          {activeMatch ? (\n   304→            <ActiveMatchView\n   305→              match={activeMatch}\n   306→              currentUserAddress={address ?? \"\"}\n   307→              onCancel={activeMatch.phase === \"created\" ? cancelMatch : undefined}\n   308→              onTimeoutCancel={timeoutCancel}\n   309→              onClaim={claimPayout}\n   310→              onClearMatch={clearActiveMatch}\n   311→              claiming={claiming}\n   312→            />\n   313→          ) : (\n   314→            <div className=\"coinflip-lobby\">\n   315→              {/* Your Matches — claimable/active matches for the current player */}\n   316→              {connected && claimableMatches.length > 0 && (\n   317→                <div className=\"coinflip-matches coinflip-your-matches\">\n   318→                  <div className=\"coinflip-matches__header\">\n   319→                    <h3 className=\"coinflip-matches__title\">Your Matches</h3>\n   320→                    <span className=\"coinflip-matches__count\">\n   321→                      {claimableMatches.length} active\n   322→                    </span>\n   323→                  </div>\n   324→                  <div className=\"coinflip-matches__list\">\n   325→                    {claimableMatches.map((match) => {\n   326→                      const isCreator = match.player1 === address;\n   327→                      let actionLabel: string;\n   328→                      if (match.phase === \"complete\") {\n   329→                        actionLabel = match.winner === address ? \"Claim\" : \"Settle\";\n   330→                      } else if (match.phase === \"created\" && isCreator) {\n   331→                        actionLabel = \"Cancel\";\n   332→                      } else {\n   333→                        actionLabel = \"View\";\n   334→                      }\n   335→\n   336→                      return (\n   337→                        <div\n   338→                          key={match.id}\n   339→                          className=\"coinflip-match-card coinflip-match-card--claimable\"\n   340→                          onClick={() => selectMatch(match)}\n   341→                          role=\"button\"\n   342→                          tabIndex={0}\n   343→                          onKeyDown={(e) => { if (e.key === \"Enter\") selectMatch(match); }}\n   344→                        >\n   345→                          <div className=\"coinflip-match-card__bet\">\n   346→                            <div\n   347→                              className=\"coinflip-match-card__amount\"\n   348→                              style={{ color: TIER_COLORS[match.tier] }}\n   349→                            >\n   350→                              {\"$\"}{match.entryAmount}\n   351→                            </div>\n   352→                            <span className=\"coinflip-match-card__phase\">\n   353→                              {match.phase === \"created\" && \"Waiting\"}\n   354→                              {match.phase === \"ready\" && \"Locked\"}\n   355→                              {match.phase === \"complete\" && \"Settled\"}\n   356→                            </span>\n   357→                          </div>\n   358→                          <div className=\"coinflip-match-card__actions\">\n   359→                            <button\n   360→                              type=\"button\"\n   361→                              className=\"coinflip-match-card__join-btn\"\n   362→                              onClick={(e) => { e.stopPropagation(); selectMatch(match); }}\n   363→                            >\n   364→                              {actionLabel}\n   365→                            </button>\n   366→                          </div>\n   367→                        </div>\n   368→                      );\n   369→                    })}\n   370→                  </div>\n   371→                </div>\n   372→              )}\n   373→\n   374→              <OpenMatchesList\n   375→                matches={openMatches}\n   376→                loading={loading}\n   377→                onJoin={handleJoinMatch}\n   378→                joiningMatchId={joiningMatchId}\n   379→                currentUserAddress={address}\n   380→                selectedTier={selectedTier}\n   381→                isConnected={connected}\n   382→              />\n   383→            </div>\n   384→          )}\n   385→        </div>\n   386→      </GameLayout>\n   387→\n   388→      {/* Error Toast */}\n   389→      {error && (\n   390→        <div className=\"coinflip-error-toast\">\n   391→          <Toast variant=\"error\" message={error} onClose={clearError} />\n   392→        </div>\n   393→      )}\n   394→\n   395→      {/* History Detail Modal */}\n   396→      <Modal\n   397→        isOpen={selectedHistoryMatch !== null}\n   398→        onClose={() => setSelectedHistoryMatch(null)}\n   399→        title=\"Match Details\"\n   400→      >\n   401→        {selectedHistoryMatch && (() => {\n   402→          const isPlayer1 = selectedHistoryMatch.player1 === address;\n   403→          const isWinner = selectedHistoryMatch.winner === address;\n   404→          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n   405→          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n   406→\n   407→          return (\n   408→            <div className=\"coinflip-history-modal\">\n   409→              {/* Match Stats */}\n   410→              <div className=\"coinflip-history-modal__section\">\n   411→                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n   412→                <div className=\"coinflip-history-modal__row\">\n   413→                  <span>Tier</span>\n   414→                  <span\n   415→                    style={{\n   416→                      color: TIER_COLORS[selectedHistoryMatch.tier],\n   417→                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n   418→                      textTransform: \"capitalize\",\n   419→                    }}\n   420→                  >\n   421→                    {selectedHistoryMatch.tier}\n   422→                  </span>\n   423→                </div>\n   424→                <div className=\"coinflip-history-modal__row\">\n   425→                  <span>Your Side</span>\n   426→                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n   427→                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n   428→                  </span>\n   429→                </div>\n   430→                <div className=\"coinflip-history-modal__row\">\n   431→                  <span>Entry</span>\n   432→                  <span>{`$${selectedHistoryMatch.entryAmount}`}</span>\n   433→                </div>\n   434→                <div className=\"coinflip-history-modal__row\">\n   435→                  <span>Total Pot</span>\n   436→                  <span className=\"coinflip-history-modal__highlight\">\n   437→                    {`$${(selectedHistoryMatch.entryAmount * 2).toFixed(2)}`}\n   438→                  </span>\n   439→                </div>\n   440→                <div className=\"coinflip-history-modal__row\">\n   441→                  <span>Result</span>\n   442→                  <span\n   443→                    style={{\n   444→                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n   445→                      textShadow: selectedHistoryMatch.result\n   446→                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n   447→                        : undefined,\n   448→                    }}\n   449→                  >\n   450→                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n   451→                  </span>\n   452→                </div>\n   453→                <div className=\"coinflip-history-modal__row\">\n   454→                  <span>Outcome</span>\n   455→                  <span\n   456→                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n   457→                    style={{ color: isWinner ? \"#45b058\" : \"#d45d5d\" }}\n   458→                  >\n   459→                    {isWinner ? \"WON!\" : \"LOST\"}\n   460→                  </span>\n   461→                </div>\n   462→                <div className=\"coinflip-history-modal__row\">\n   463→                  <span>Payout</span>\n   464→                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n   465→                    {isWinner ? `+$${selectedHistoryMatch.payoutAmount.toFixed(2)}` : `-$${selectedHistoryMatch.entryAmount.toFixed(2)}`}\n   466→                  </span>\n   467→                </div>\n   468→              </div>\n   469→\n   470→              {/* Match Fairness */}\n   471→              <div className=\"coinflip-history-modal__section\">\n   472→                <h4 className=\"coinflip-history-modal__section-title\">\n   473→                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n   474→                  Round Fairness\n   475→                </h4>\n   476→                <div className=\"coinflip-history-modal__row\">\n   477→                  <span>Match ID</span>\n   478→                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n   479→                    {selectedHistoryMatch.id}\n   480→                  </span>\n   481→                </div>\n   482→                <div className=\"coinflip-history-modal__row\">\n   483→                  <span>Seed Hash</span>\n   484→                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n   485→                    {selectedHistoryMatch.seedHash}\n   486→                  </span>\n   487→                </div>\n   488→                {selectedHistoryMatch.serverSeed && (\n   489→                  <div className=\"coinflip-history-modal__row\">\n   490→                    <span>Server Seed</span>\n   491→                    <span\n   492→                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n   493→                      title={selectedHistoryMatch.serverSeed}\n   494→                    >\n   495→                      {selectedHistoryMatch.serverSeed}\n   496→                    </span>\n   497→                  </div>\n   498→                )}\n   499→                {selectedHistoryMatch.blockHash && (\n   500→                  <div className=\"coinflip-history-modal__row\">\n   501→                    <span>Block Hash</span>\n   502→                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n   503→                      {selectedHistoryMatch.blockHash}\n   504→                    </span>\n   505→                  </div>\n   506→                )}\n   507→                {selectedHistoryMatch.vrfProof && (\n   508→                  <div className=\"coinflip-history-modal__row\">\n   509→                    <span>VRF Proof</span>\n   510→                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n   511→                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n   512→                    </span>\n   513→                  </div>\n   514→                )}\n   515→              </div>\n   516→\n   517→              {/* Verify Link */}\n   518→              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n   519→                Verify on Fairness Page →\n   520→              </a>\n   521→            </div>\n   522→          );\n   523→        })()}\n   524→      </Modal>\n   525→    </>\n   526→  );\n   527→}\n   528→\n   529→export function CoinflipPage() {\n   530→  return (\n   531→    <CoinflipProvider>\n   532→      <CoinflipPageContent />\n   533→    </CoinflipProvider>\n   534→  );\n   535→}\n   536→"}]},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"ee9886fb-dc29-4868-bb6c-84f8c6df1f00","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/pages/CoinflipPage.tsx","content":"import { useState } from \"react\";\nimport {\n  GameLayout,\n  TierSelector,\n  TIER_COLORS,\n  Toast,\n  Modal,\n  type HistoryEntry,\n} from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { TIER_AMOUNTS } from \"@rng-utopia/game-engine/browser\";\nimport {\n  CoinflipProvider,\n  useCoinflip,\n  CoinSideSelector,\n  OpenMatchesList,\n  ActiveMatchView,\n  type UIMatch,\n} from \"../features/coinflip\";\n\nfunction CoinflipPageContent() {\n  const { connected, address, connect } = useWallet();\n  const {\n    activeMatch,\n    openMatches,\n    claimableMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    claiming,\n    cancelMatch,\n    timeoutCancel,\n    claimPayout,\n    clearActiveMatch,\n    selectMatch,\n  } = useCoinflip();\n\n  // State for history detail modal\n  const [selectedHistoryMatch, setSelectedHistoryMatch] = useState<UIMatch | null>(null);\n\n  // Side colors (match the CSS .side-heads / .side-tails)\n  const SIDE_COLORS = {\n    heads: \"#45b058\",\n    tails: \"#e09030\",\n  };\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((match) => {\n    const isWinner = match.winner === address;\n    const isPlayer1 = match.player1 === address;\n    const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    const tierCapitalized = match.tier.charAt(0).toUpperCase() + match.tier.slice(1);\n    const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n    const tierColor = TIER_COLORS[match.tier];\n    const outcomeColor = isWinner ? \"#45b058\" : \"#d45d5d\";\n\n    return {\n      roundId: match.id.slice(-6),\n      result: (\n        <span className=\"coinflip-history-result\">\n          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n            {yourSide?.toUpperCase() ?? \"?\"}\n          </span>\n          <span className=\"coinflip-history-result__separator\">|</span>\n          <span style={{ color: tierColor, textShadow: `0 0 4px ${tierColor}` }}>\n            {tierCapitalized}\n          </span>\n          <span className=\"coinflip-history-result__separator\">|</span>\n          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {isWinner ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n      timestamp: new Date(match.completedAt ?? match.createdAt),\n      verified: true,\n      won: isWinner,\n      onClick: () => setSelectedHistoryMatch(match),\n    };\n  });\n\n  // Calculate potential payout\n  const potentialPayout = selectedTier\n    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n    : 0;\n\n  const handleCreateMatch = () => {\n    createMatch();\n  };\n\n  const handleJoinMatch = (matchId: string) => {\n    joinMatch(matchId);\n  };\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"coinflip-sidebar\">\n      {!activeMatch ? (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n\n          {/* Tier Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <div className=\"coinflip-sidebar__label-row\">\n              <label className=\"coinflip-sidebar__label\">\n                Select Tier\n              </label>\n              <button\n                type=\"button\"\n                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n                onClick={() => setSelectedTier(null)}\n              >\n                All\n              </button>\n            </div>\n            <TierSelector\n              selectedTier={selectedTier}\n              onSelect={setSelectedTier}\n            />\n          </div>\n\n          {/* Side Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n            <CoinSideSelector\n              selectedSide={selectedSide}\n              onSelect={setSelectedSide}\n              disabled={!connected}\n            />\n          </div>\n\n          {/* Summary */}\n          {selectedTier && selectedSide && (\n            <div className=\"coinflip-sidebar__summary\">\n              <div className=\"coinflip-sidebar__row\">\n                <span>Entry</span>\n                <span>{`$${TIER_AMOUNTS[selectedTier]}`}</span>\n              </div>\n              <div className=\"coinflip-sidebar__row\">\n                <span>Potential Payout</span>\n                <span className=\"coinflip-sidebar__payout\">\n                  {`$${potentialPayout.toFixed(2)}`}\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Action Button */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={handleCreateMatch}\n              disabled={!selectedTier || !selectedSide || creating}\n            >\n              {creating ? \"Creating...\" : \"Create Game\"}\n            </button>\n          )}\n        </>\n      ) : (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n\n          <div className=\"coinflip-sidebar__game-info\">\n            <div className=\"coinflip-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"coinflip-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[activeMatch.tier],\n                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n                }}\n              >\n                {activeMatch.tier}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Your Side</span>\n              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n                {(activeMatch.player1 === address\n                  ? activeMatch.player1Side\n                  : activeMatch.player2Side\n                )?.toUpperCase()}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Entry</span>\n              <span>{`$${activeMatch.entryAmount}`}</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Pot</span>\n              <span className=\"coinflip-sidebar__pot\">{`$${activeMatch.entryAmount * 2}`}</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Status</span>\n              <span className=\"coinflip-sidebar__status\">\n                {activeMatch.phase === \"created\" && \"Waiting...\"}\n                {activeMatch.phase === \"ready\" && \"Ready!\"}\n                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n                {activeMatch.phase === \"complete\" && \"Complete\"}\n              </span>\n            </div>\n          </div>\n\n          {/* Round Fairness Info */}\n          <div className=\"coinflip-sidebar__fairness\">\n            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Match ID</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n                {activeMatch.id.slice(-8)}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Seed Hash</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n              </span>\n            </div>\n            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n              <>\n                <div className=\"coinflip-sidebar__fairness-row\">\n                  <span>Server Seed</span>\n                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n                  </span>\n                </div>\n                {activeMatch.blockHash && (\n                  <div className=\"coinflip-sidebar__fairness-row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n                    </span>\n                  </div>\n                )}\n              </>\n            )}\n          </div>\n\n          {activeMatch.phase === \"complete\" && !activeMatch.claimed && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={claimPayout}\n              disabled={claiming}\n            >\n              {claiming\n                ? \"Settling...\"\n                : activeMatch.winner === address\n                  ? \"Claim Payout\"\n                  : \"Settle & Return\"}\n            </button>\n          )}\n          {activeMatch.phase === \"complete\" && activeMatch.claimed && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n              onClick={clearActiveMatch}\n            >\n              Back to Lobby\n            </button>\n          )}\n        </>\n      )}\n    </div>\n  );\n\n  // Helper to get side display for modal\n  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n    const side = isPlayer1 ? match.player1Side : match.player2Side;\n    return side?.toUpperCase() ?? \"?\";\n  };\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Coinflip\"\n        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"coinflip-main\">\n          {/* Show active match or lobby */}\n          {activeMatch ? (\n            <ActiveMatchView\n              match={activeMatch}\n              currentUserAddress={address ?? \"\"}\n              onCancel={activeMatch.phase === \"created\" ? cancelMatch : undefined}\n              onTimeoutCancel={timeoutCancel}\n              onClaim={claimPayout}\n              onClearMatch={clearActiveMatch}\n              claiming={claiming}\n            />\n          ) : (\n            <div className=\"coinflip-lobby\">\n              {/* Your Matches — claimable/active matches for the current player */}\n              {connected && claimableMatches.length > 0 && (\n                <div className=\"coinflip-matches coinflip-your-matches\">\n                  <div className=\"coinflip-matches__header\">\n                    <h3 className=\"coinflip-matches__title\">Your Matches</h3>\n                    <span className=\"coinflip-matches__count\">\n                      {claimableMatches.length} active\n                    </span>\n                  </div>\n                  <div className=\"coinflip-matches__list\">\n                    {claimableMatches.map((match) => {\n                      const isCreator = match.player1 === address;\n                      let actionLabel: string;\n                      if (match.phase === \"complete\") {\n                        actionLabel = match.winner === address ? \"Claim\" : \"Settle\";\n                      } else if (match.phase === \"created\" && isCreator) {\n                        actionLabel = \"Cancel\";\n                      } else {\n                        actionLabel = \"View\";\n                      }\n\n                      return (\n                        <div\n                          key={match.id}\n                          className=\"coinflip-match-card coinflip-match-card--claimable\"\n                          onClick={() => selectMatch(match)}\n                          role=\"button\"\n                          tabIndex={0}\n                          onKeyDown={(e) => { if (e.key === \"Enter\") selectMatch(match); }}\n                        >\n                          <div className=\"coinflip-match-card__bet\">\n                            <div\n                              className=\"coinflip-match-card__amount\"\n                              style={{ color: TIER_COLORS[match.tier] }}\n                            >\n                              {\"$\"}{match.entryAmount}\n                            </div>\n                            <span className=\"coinflip-match-card__phase\">\n                              {match.phase === \"created\" && \"Waiting\"}\n                              {match.phase === \"ready\" && \"Locked\"}\n                              {match.phase === \"complete\" && \"Settled\"}\n                            </span>\n                          </div>\n                          <div className=\"coinflip-match-card__actions\">\n                            <button\n                              type=\"button\"\n                              className=\"coinflip-match-card__join-btn\"\n                              onClick={(e) => { e.stopPropagation(); selectMatch(match); }}\n                            >\n                              {actionLabel}\n                            </button>\n                          </div>\n                        </div>\n                      );\n                    })}\n                  </div>\n                </div>\n              )}\n\n              <OpenMatchesList\n                matches={openMatches}\n                loading={loading}\n                onJoin={handleJoinMatch}\n                joiningMatchId={joiningMatchId}\n                currentUserAddress={address}\n                selectedTier={selectedTier}\n                isConnected={connected}\n              />\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* Error Toast */}\n      {error && (\n        <div className=\"coinflip-error-toast\">\n          <Toast variant=\"error\" message={error} onClose={clearError} />\n        </div>\n      )}\n\n      {/* History Detail Modal */}\n      <Modal\n        isOpen={selectedHistoryMatch !== null}\n        onClose={() => setSelectedHistoryMatch(null)}\n        title=\"Match Details\"\n      >\n        {selectedHistoryMatch && (() => {\n          const isPlayer1 = selectedHistoryMatch.player1 === address;\n          const isWinner = selectedHistoryMatch.winner === address;\n          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n\n          return (\n            <div className=\"coinflip-history-modal\">\n              {/* Match Stats */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Tier</span>\n                  <span\n                    style={{\n                      color: TIER_COLORS[selectedHistoryMatch.tier],\n                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n                      textTransform: \"capitalize\",\n                    }}\n                  >\n                    {selectedHistoryMatch.tier}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Entry</span>\n                  <span>{`$${selectedHistoryMatch.entryAmount}`}</span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Total Pot</span>\n                  <span className=\"coinflip-history-modal__highlight\">\n                    {`$${(selectedHistoryMatch.entryAmount * 2).toFixed(2)}`}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Result</span>\n                  <span\n                    style={{\n                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n                      textShadow: selectedHistoryMatch.result\n                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n                        : undefined,\n                    }}\n                  >\n                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n                    style={{ color: isWinner ? \"#45b058\" : \"#d45d5d\" }}\n                  >\n                    {isWinner ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Payout</span>\n                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n                    {isWinner ? `+$${selectedHistoryMatch.payoutAmount.toFixed(2)}` : `-$${selectedHistoryMatch.entryAmount.toFixed(2)}`}\n                  </span>\n                </div>\n              </div>\n\n              {/* Match Fairness */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">\n                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n                  Round Fairness\n                </h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Match ID</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n                    {selectedHistoryMatch.id}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Seed Hash</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n                    {selectedHistoryMatch.seedHash}\n                  </span>\n                </div>\n                {selectedHistoryMatch.serverSeed && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Server Seed</span>\n                    <span\n                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n                      title={selectedHistoryMatch.serverSeed}\n                    >\n                      {selectedHistoryMatch.serverSeed}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.blockHash && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n                      {selectedHistoryMatch.blockHash}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.vrfProof && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>VRF Proof</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n                    </span>\n                  </div>\n                )}\n              </div>\n\n              {/* Verify Link */}\n              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n                Verify on Fairness Page →\n              </a>\n            </div>\n          );\n        })()}\n      </Modal>\n    </>\n  );\n}\n\nexport function CoinflipPage() {\n  return (\n    <CoinflipProvider>\n      <CoinflipPageContent />\n    </CoinflipProvider>\n  );\n}\n","numLines":536,"startLine":1,"totalLines":536}}}
