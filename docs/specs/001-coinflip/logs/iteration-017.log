{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FPMg671ix39i4AyJyDQWWt","type":"tool_result","content":"     1→import { useState, useEffect } from \"react\";\n     2→import type { UIMatch } from \"../types\";\n     3→import { CoinAnimation } from \"./CoinAnimation\";\n     4→import { getOppositeSide } from \"../utils/helpers\";\n     5→import { PlayerAvatarCompact } from \"../../player-profile\";\n     6→\n     7→const LOCK_TIMEOUT_MS = 120_000; // 2 minutes\n     8→\n     9→interface ActiveMatchViewProps {\n    10→  match: UIMatch;\n    11→  currentUserAddress: string;\n    12→  onCancel?: () => void;\n    13→  onTimeoutCancel?: () => void;\n    14→  onClaim?: () => void;\n    15→  onClearMatch?: () => void;\n    16→  cancelling?: boolean;\n    17→  claiming?: boolean;\n    18→}\n    19→\n    20→export function ActiveMatchView({\n    21→  match,\n    22→  currentUserAddress,\n    23→  onCancel,\n    24→  onTimeoutCancel,\n    25→  onClaim,\n    26→  onClearMatch,\n    27→  cancelling,\n    28→  claiming,\n    29→}: ActiveMatchViewProps) {\n    30→  const isPlayer1 = match.player1 === currentUserAddress;\n    31→  const isWinner = match.winner === currentUserAddress;\n    32→\n    33→  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    34→  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n    35→  const opponent = isPlayer1 ? match.player2 : match.player1;\n    36→\n    37→  // Track whether lock timeout has elapsed (for timeout cancel button)\n    38→  const [lockTimedOut, setLockTimedOut] = useState(false);\n    39→  const [cancellingTimeout, setCancellingTimeout] = useState(false);\n    40→\n    41→  useEffect(() => {\n    42→    if (match.phase !== \"ready\" || !match.lockedAt) {\n    43→      // For legacy matches with no lockedAt, show cancel immediately\n    44→      setLockTimedOut(match.phase === \"ready\");\n    45→      return;\n    46→    }\n    47→\n    48→    const remaining = match.lockedAt + LOCK_TIMEOUT_MS - Date.now();\n    49→    if (remaining <= 0) {\n    50→      setLockTimedOut(true);\n    51→      return;\n    52→    }\n    53→\n    54→    setLockTimedOut(false);\n    55→    const timer = setTimeout(() => setLockTimedOut(true), remaining);\n    56→    return () => clearTimeout(timer);\n    57→  }, [match.phase, match.lockedAt]);\n    58→\n    59→  // Countdown timer\n    60→  const [countdown, setCountdown] = useState(3);\n    61→\n    62→  useEffect(() => {\n    63→    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n    64→      // Always start at 3\n    65→      setCountdown(3);\n    66→\n    67→      const updateCountdown = () => {\n    68→        const elapsed = Date.now() - match.countdownStartedAt!;\n    69→        // Each number shows for exactly 1 second:\n    70→        // 0-999ms: show 3\n    71→        // 1000-1999ms: show 2\n    72→        // 2000-2999ms: show 1\n    73→        if (elapsed < 1000) {\n    74→          setCountdown(3);\n    75→        } else if (elapsed < 2000) {\n    76→          setCountdown(2);\n    77→        } else {\n    78→          setCountdown(1);\n    79→        }\n    80→      };\n    81→\n    82→      const interval = setInterval(updateCountdown, 50);\n    83→      return () => {\n    84→        clearInterval(interval);\n    85→        // Reset for next countdown\n    86→        setCountdown(3);\n    87→      };\n    88→    }\n    89→  }, [match.phase, match.countdownStartedAt]);\n    90→\n    91→  return (\n    92→    <div className=\"coinflip-active-match\">\n    93→      {/* Waiting for opponent */}\n    94→      {match.phase === \"created\" && (\n    95→        <div className=\"coinflip-active-match__waiting\">\n    96→          <h3 className=\"coinflip-active-match__title\">Waiting for Opponent</h3>\n    97→          <div className=\"coinflip-active-match__info\">\n    98→            <p>\n    99→              Your side: <strong className={`side-${match.player1Side}`}>\n   100→                {match.player1Side.toUpperCase()}\n   101→              </strong>\n   102→            </p>\n   103→            <p>Entry: <strong>{\"$\"}{match.entryAmount}</strong></p>\n   104→          </div>\n   105→          <div className=\"coinflip-waiting__spinner\" />\n   106→          <p className=\"coinflip-active-match__hint\">\n   107→            Someone will join soon...\n   108→          </p>\n   109→          {onCancel && (\n   110→            <button\n   111→              type=\"button\"\n   112→              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   113→              onClick={onCancel}\n   114→              disabled={cancelling}\n   115→            >\n   116→              {cancelling ? \"Cancelling...\" : \"Cancel Match\"}\n   117→            </button>\n   118→          )}\n   119→        </div>\n   120→      )}\n   121→\n   122→      {/* Ready / Countdown */}\n   123→      {(match.phase === \"ready\" || match.phase === \"countdown\") && (\n   124→        <div className=\"coinflip-active-match__playing\">\n   125→          <h3 className=\"coinflip-active-match__title\">\n   126→            {match.phase === \"ready\" && \"Game Ready!\"}\n   127→            {match.phase === \"countdown\" && (\n   128→              <span className=\"coinflip-countdown-inline\">\n   129→                Flipping in... <span className=\"coinflip-countdown-inline__number\">{countdown}</span>\n   130→              </span>\n   131→            )}\n   132→          </h3>\n   133→\n   134→          <div className=\"coinflip-active-match__players\">\n   135→            <div className=\"coinflip-player coinflip-player--you\">\n   136→              <span className=\"coinflip-player__label\">\n   137→                <PlayerAvatarCompact address={currentUserAddress} />\n   138→              </span>\n   139→              <span className={`coinflip-player__side side-${yourSide}`}>\n   140→                {yourSide?.toUpperCase()}\n   141→              </span>\n   142→            </div>\n   143→\n   144→            <span className=\"coinflip-active-match__vs\">VS</span>\n   145→\n   146→            <div className=\"coinflip-player coinflip-player--opponent\">\n   147→              <span className=\"coinflip-player__label\">\n   148→                {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n   149→              </span>\n   150→              <span className={`coinflip-player__side side-${opponentSide}`}>\n   151→                {opponentSide?.toUpperCase()}\n   152→              </span>\n   153→            </div>\n   154→          </div>\n   155→\n   156→          {/* Static coin for ready/countdown phases */}\n   157→          <CoinAnimation\n   158→            isFlipping={false}\n   159→            result={null}\n   160→            initialSide={yourSide ?? \"heads\"}\n   161→            size=\"lg\"\n   162→          />\n   163→\n   164→          {/* Timeout cancel — shown when VRF hasn't resolved within 2 min */}\n   165→          {match.phase === \"ready\" && lockTimedOut && onTimeoutCancel && (\n   166→            <div className=\"coinflip-active-match__timeout\">\n   167→              <p className=\"coinflip-active-match__hint\">\n   168→                Resolution timed out.\n   169→              </p>\n   170→              <button\n   171→                type=\"button\"\n   172→                className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   173→                onClick={async () => {\n   174→                  setCancellingTimeout(true);\n   175→                  try { await onTimeoutCancel(); } finally { setCancellingTimeout(false); }\n   176→                }}\n   177→                disabled={cancellingTimeout}\n   178→              >\n   179→                {cancellingTimeout ? \"Cancelling...\" : \"Cancel & Refund\"}\n   180→              </button>\n   181→            </div>\n   182→          )}\n   183→\n   184→        </div>\n   185→      )}\n   186→\n   187→      {/* Flipping / Complete - same container so coin persists through transition */}\n   188→      {(match.phase === \"flipping\" || match.phase === \"complete\") && (\n   189→        <div className=\"coinflip-active-match__playing\">\n   190→          <h3 className={`coinflip-active-match__title ${\n   191→            match.phase === \"complete\" ? (isWinner ? \"coinflip-active-match__title--won\" : \"coinflip-active-match__title--lost\") : \"\"\n   192→          }`}>\n   193→            {match.phase === \"flipping\" && \"Flipping!\"}\n   194→            {match.phase === \"complete\" && isWinner && \"You Won!\"}\n   195→            {match.phase === \"complete\" && !isWinner && (\n   196→              <span className=\"coinflip-lose-title\">\n   197→                You Lost{\" \"}\n   198→                <span className=\"coinflip-lose-title__heart\">💔</span>\n   199→                <span className=\"coinflip-lose-title__shards\">\n   200→                  {[...Array(5)].map((_, i) => (\n   201→                    <span key={i} className=\"coinflip-lose-title__shard\" style={{ '--shard-index': i } as React.CSSProperties}>◆</span>\n   202→                  ))}\n   203→                </span>\n   204→              </span>\n   205→            )}\n   206→          </h3>\n   207→\n   208→          {/* Players info during flipping */}\n   209→          {match.phase === \"flipping\" && (\n   210→            <div className=\"coinflip-active-match__players\">\n   211→              <div className=\"coinflip-player coinflip-player--you\">\n   212→                <span className=\"coinflip-player__label\">\n   213→                  <PlayerAvatarCompact address={currentUserAddress} />\n   214→                </span>\n   215→                <span className={`coinflip-player__side side-${yourSide}`}>\n   216→                  {yourSide?.toUpperCase()}\n   217→                </span>\n   218→              </div>\n   219→\n   220→              <span className=\"coinflip-active-match__vs\">VS</span>\n   221→\n   222→              <div className=\"coinflip-player coinflip-player--opponent\">\n   223→                <span className=\"coinflip-player__label\">\n   224→                  {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n   225→                </span>\n   226→                <span className={`coinflip-player__side side-${opponentSide}`}>\n   227→                  {opponentSide?.toUpperCase()}\n   228→                </span>\n   229→              </div>\n   230→            </div>\n   231→          )}\n   232→\n   233→          {/* Single coin that persists through flipping → complete */}\n   234→          <CoinAnimation\n   235→            isFlipping={match.phase === \"flipping\"}\n   236→            result={match.result}\n   237→            initialSide={yourSide ?? \"heads\"}\n   238→            size=\"lg\"\n   239→          />\n   240→\n   241→          {/* Result info during complete */}\n   242→          {match.phase === \"complete\" && (\n   243→            <>\n   244→              {/* Win Animation - Arcade star burst */}\n   245→              {isWinner && (\n   246→                <div className=\"coinflip-win-animation\">\n   247→                  <div className=\"coinflip-win-animation__stars\">\n   248→                    {[...Array(8)].map((_, i) => (\n   249→                      <span key={i} className=\"coinflip-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n   250→                    ))}\n   251→                  </div>\n   252→                  <div className=\"coinflip-win-animation__coins\">\n   253→                    {[...Array(6)].map((_, i) => (\n   254→                      <span key={i} className=\"coinflip-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n   255→                    ))}\n   256→                  </div>\n   257→                </div>\n   258→              )}\n   259→\n   260→              <div\n   261→                className={`coinflip-result ${\n   262→                  isWinner ? \"coinflip-result--won\" : \"coinflip-result--lost\"\n   263→                }`}\n   264→              >\n   265→                <p className=\"coinflip-result__outcome\">\n   266→                  Result: <strong\n   267→                    style={{\n   268→                      color: match.result === \"heads\" ? \"#45b058\" : \"#e09030\",\n   269→                      textShadow: `0 0 6px ${match.result === \"heads\" ? \"#45b058\" : \"#e09030\"}`\n   270→                    }}\n   271→                  >{match.result?.toUpperCase()}</strong>\n   272→                </p>\n   273→                {isWinner && (\n   274→                  <p className=\"coinflip-result__payout\">\n   275→                    Payout: <strong>{\"$\"}{match.payoutAmount.toFixed(4)}</strong>\n   276→                  </p>\n   277→                )}\n   278→              </div>\n   279→\n   280→              {/* Action buttons */}\n   281→              <div className=\"coinflip-active-match__actions\">\n   282→                {!match.claimed && onClaim && (\n   283→                  <button\n   284→                    type=\"button\"\n   285→                    className=\"coinflip-action-btn\"\n   286→                    onClick={onClaim}\n   287→                    disabled={claiming}\n   288→                  >\n   289→                    {claiming\n   290→                      ? \"Settling...\"\n   291→                      : isWinner\n   292→                        ? \"Claim Payout\"\n   293→                        : \"Settle & Return to Lobby\"}\n   294→                  </button>\n   295→                )}\n   296→                {match.claimed && onClearMatch && (\n   297→                  <button\n   298→                    type=\"button\"\n   299→                    className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   300→                    onClick={onClearMatch}\n   301→                  >\n   302→                    Back to Lobby\n   303→                  </button>\n   304→                )}\n   305→              </div>\n   306→\n   307→            </>\n   308→          )}\n   309→        </div>\n   310→      )}\n   311→    </div>\n   312→  );\n   313→}\n   314→"}]},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"b81b3d67-8023-4bd6-bdcc-4f04e20b7ab8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/components/ActiveMatchView.tsx","content":"import { useState, useEffect } from \"react\";\nimport type { UIMatch } from \"../types\";\nimport { CoinAnimation } from \"./CoinAnimation\";\nimport { getOppositeSide } from \"../utils/helpers\";\nimport { PlayerAvatarCompact } from \"../../player-profile\";\n\nconst LOCK_TIMEOUT_MS = 120_000; // 2 minutes\n\ninterface ActiveMatchViewProps {\n  match: UIMatch;\n  currentUserAddress: string;\n  onCancel?: () => void;\n  onTimeoutCancel?: () => void;\n  onClaim?: () => void;\n  onClearMatch?: () => void;\n  cancelling?: boolean;\n  claiming?: boolean;\n}\n\nexport function ActiveMatchView({\n  match,\n  currentUserAddress,\n  onCancel,\n  onTimeoutCancel,\n  onClaim,\n  onClearMatch,\n  cancelling,\n  claiming,\n}: ActiveMatchViewProps) {\n  const isPlayer1 = match.player1 === currentUserAddress;\n  const isWinner = match.winner === currentUserAddress;\n\n  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n  const opponent = isPlayer1 ? match.player2 : match.player1;\n\n  // Track whether lock timeout has elapsed (for timeout cancel button)\n  const [lockTimedOut, setLockTimedOut] = useState(false);\n  const [cancellingTimeout, setCancellingTimeout] = useState(false);\n\n  useEffect(() => {\n    if (match.phase !== \"ready\" || !match.lockedAt) {\n      // For legacy matches with no lockedAt, show cancel immediately\n      setLockTimedOut(match.phase === \"ready\");\n      return;\n    }\n\n    const remaining = match.lockedAt + LOCK_TIMEOUT_MS - Date.now();\n    if (remaining <= 0) {\n      setLockTimedOut(true);\n      return;\n    }\n\n    setLockTimedOut(false);\n    const timer = setTimeout(() => setLockTimedOut(true), remaining);\n    return () => clearTimeout(timer);\n  }, [match.phase, match.lockedAt]);\n\n  // Countdown timer\n  const [countdown, setCountdown] = useState(3);\n\n  useEffect(() => {\n    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n      // Always start at 3\n      setCountdown(3);\n\n      const updateCountdown = () => {\n        const elapsed = Date.now() - match.countdownStartedAt!;\n        // Each number shows for exactly 1 second:\n        // 0-999ms: show 3\n        // 1000-1999ms: show 2\n        // 2000-2999ms: show 1\n        if (elapsed < 1000) {\n          setCountdown(3);\n        } else if (elapsed < 2000) {\n          setCountdown(2);\n        } else {\n          setCountdown(1);\n        }\n      };\n\n      const interval = setInterval(updateCountdown, 50);\n      return () => {\n        clearInterval(interval);\n        // Reset for next countdown\n        setCountdown(3);\n      };\n    }\n  }, [match.phase, match.countdownStartedAt]);\n\n  return (\n    <div className=\"coinflip-active-match\">\n      {/* Waiting for opponent */}\n      {match.phase === \"created\" && (\n        <div className=\"coinflip-active-match__waiting\">\n          <h3 className=\"coinflip-active-match__title\">Waiting for Opponent</h3>\n          <div className=\"coinflip-active-match__info\">\n            <p>\n              Your side: <strong className={`side-${match.player1Side}`}>\n                {match.player1Side.toUpperCase()}\n              </strong>\n            </p>\n            <p>Entry: <strong>{\"$\"}{match.entryAmount}</strong></p>\n          </div>\n          <div className=\"coinflip-waiting__spinner\" />\n          <p className=\"coinflip-active-match__hint\">\n            Someone will join soon...\n          </p>\n          {onCancel && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n              onClick={onCancel}\n              disabled={cancelling}\n            >\n              {cancelling ? \"Cancelling...\" : \"Cancel Match\"}\n            </button>\n          )}\n        </div>\n      )}\n\n      {/* Ready / Countdown */}\n      {(match.phase === \"ready\" || match.phase === \"countdown\") && (\n        <div className=\"coinflip-active-match__playing\">\n          <h3 className=\"coinflip-active-match__title\">\n            {match.phase === \"ready\" && \"Game Ready!\"}\n            {match.phase === \"countdown\" && (\n              <span className=\"coinflip-countdown-inline\">\n                Flipping in... <span className=\"coinflip-countdown-inline__number\">{countdown}</span>\n              </span>\n            )}\n          </h3>\n\n          <div className=\"coinflip-active-match__players\">\n            <div className=\"coinflip-player coinflip-player--you\">\n              <span className=\"coinflip-player__label\">\n                <PlayerAvatarCompact address={currentUserAddress} />\n              </span>\n              <span className={`coinflip-player__side side-${yourSide}`}>\n                {yourSide?.toUpperCase()}\n              </span>\n            </div>\n\n            <span className=\"coinflip-active-match__vs\">VS</span>\n\n            <div className=\"coinflip-player coinflip-player--opponent\">\n              <span className=\"coinflip-player__label\">\n                {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n              </span>\n              <span className={`coinflip-player__side side-${opponentSide}`}>\n                {opponentSide?.toUpperCase()}\n              </span>\n            </div>\n          </div>\n\n          {/* Static coin for ready/countdown phases */}\n          <CoinAnimation\n            isFlipping={false}\n            result={null}\n            initialSide={yourSide ?? \"heads\"}\n            size=\"lg\"\n          />\n\n          {/* Timeout cancel — shown when VRF hasn't resolved within 2 min */}\n          {match.phase === \"ready\" && lockTimedOut && onTimeoutCancel && (\n            <div className=\"coinflip-active-match__timeout\">\n              <p className=\"coinflip-active-match__hint\">\n                Resolution timed out.\n              </p>\n              <button\n                type=\"button\"\n                className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n                onClick={async () => {\n                  setCancellingTimeout(true);\n                  try { await onTimeoutCancel(); } finally { setCancellingTimeout(false); }\n                }}\n                disabled={cancellingTimeout}\n              >\n                {cancellingTimeout ? \"Cancelling...\" : \"Cancel & Refund\"}\n              </button>\n            </div>\n          )}\n\n        </div>\n      )}\n\n      {/* Flipping / Complete - same container so coin persists through transition */}\n      {(match.phase === \"flipping\" || match.phase === \"complete\") && (\n        <div className=\"coinflip-active-match__playing\">\n          <h3 className={`coinflip-active-match__title ${\n            match.phase === \"complete\" ? (isWinner ? \"coinflip-active-match__title--won\" : \"coinflip-active-match__title--lost\") : \"\"\n          }`}>\n            {match.phase === \"flipping\" && \"Flipping!\"}\n            {match.phase === \"complete\" && isWinner && \"You Won!\"}\n            {match.phase === \"complete\" && !isWinner && (\n              <span className=\"coinflip-lose-title\">\n                You Lost{\" \"}\n                <span className=\"coinflip-lose-title__heart\">💔</span>\n                <span className=\"coinflip-lose-title__shards\">\n                  {[...Array(5)].map((_, i) => (\n                    <span key={i} className=\"coinflip-lose-title__shard\" style={{ '--shard-index': i } as React.CSSProperties}>◆</span>\n                  ))}\n                </span>\n              </span>\n            )}\n          </h3>\n\n          {/* Players info during flipping */}\n          {match.phase === \"flipping\" && (\n            <div className=\"coinflip-active-match__players\">\n              <div className=\"coinflip-player coinflip-player--you\">\n                <span className=\"coinflip-player__label\">\n                  <PlayerAvatarCompact address={currentUserAddress} />\n                </span>\n                <span className={`coinflip-player__side side-${yourSide}`}>\n                  {yourSide?.toUpperCase()}\n                </span>\n              </div>\n\n              <span className=\"coinflip-active-match__vs\">VS</span>\n\n              <div className=\"coinflip-player coinflip-player--opponent\">\n                <span className=\"coinflip-player__label\">\n                  {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n                </span>\n                <span className={`coinflip-player__side side-${opponentSide}`}>\n                  {opponentSide?.toUpperCase()}\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Single coin that persists through flipping → complete */}\n          <CoinAnimation\n            isFlipping={match.phase === \"flipping\"}\n            result={match.result}\n            initialSide={yourSide ?? \"heads\"}\n            size=\"lg\"\n          />\n\n          {/* Result info during complete */}\n          {match.phase === \"complete\" && (\n            <>\n              {/* Win Animation - Arcade star burst */}\n              {isWinner && (\n                <div className=\"coinflip-win-animation\">\n                  <div className=\"coinflip-win-animation__stars\">\n                    {[...Array(8)].map((_, i) => (\n                      <span key={i} className=\"coinflip-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n                    ))}\n                  </div>\n                  <div className=\"coinflip-win-animation__coins\">\n                    {[...Array(6)].map((_, i) => (\n                      <span key={i} className=\"coinflip-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n                    ))}\n                  </div>\n                </div>\n              )}\n\n              <div\n                className={`coinflip-result ${\n                  isWinner ? \"coinflip-result--won\" : \"coinflip-result--lost\"\n                }`}\n              >\n                <p className=\"coinflip-result__outcome\">\n                  Result: <strong\n                    style={{\n                      color: match.result === \"heads\" ? \"#45b058\" : \"#e09030\",\n                      textShadow: `0 0 6px ${match.result === \"heads\" ? \"#45b058\" : \"#e09030\"}`\n                    }}\n                  >{match.result?.toUpperCase()}</strong>\n                </p>\n                {isWinner && (\n                  <p className=\"coinflip-result__payout\">\n                    Payout: <strong>{\"$\"}{match.payoutAmount.toFixed(4)}</strong>\n                  </p>\n                )}\n              </div>\n\n              {/* Action buttons */}\n              <div className=\"coinflip-active-match__actions\">\n                {!match.claimed && onClaim && (\n                  <button\n                    type=\"button\"\n                    className=\"coinflip-action-btn\"\n                    onClick={onClaim}\n                    disabled={claiming}\n                  >\n                    {claiming\n                      ? \"Settling...\"\n                      : isWinner\n                        ? \"Claim Payout\"\n                        : \"Settle & Return to Lobby\"}\n                  </button>\n                )}\n                {match.claimed && onClearMatch && (\n                  <button\n                    type=\"button\"\n                    className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n                    onClick={onClearMatch}\n                  >\n                    Back to Lobby\n                  </button>\n                )}\n              </div>\n\n            </>\n          )}\n        </div>\n      )}\n    </div>\n  );\n}\n","numLines":314,"startLine":1,"totalLines":314}}}
