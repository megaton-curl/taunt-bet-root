{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V1xU4MdffnFcyHPpsRcZrK","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"51a2f191-b47b-462a-8583-a74044f06a98","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","oldString":"      await sendAndConfirm(transaction);\n\n      // Match PDA is now closed — clear local state\n      dismissedMatchRef.current = activeMatch.id;\n      setActiveMatch(null);\n      refreshMatches();","newString":"      const signature = await sendAndConfirm(transaction);\n\n      // Match PDA is now closed on-chain. Keep activeMatch locally with\n      // claimed=true so the user can verify fairness before returning to lobby.\n      setLastClaimSignature(signature);\n      setActiveMatch((prev) => prev ? { ...prev, claimed: true } : null);\n      refreshMatches();","originalFile":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { PublicKey, type Transaction } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchClaimableMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  getMatchPda,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildTimeoutCancelTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse Solana/wallet errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  // Wallet not connected\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n\n  // User rejected\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n\n  // Insufficient funds (Solana runtime error)\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n\n  // Account already in use (match already exists)\n  if (msg.includes(\"already in use\")) {\n    return \"You already have an active match. Cancel it before creating a new one.\";\n  }\n\n  // Network / RPC errors\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n\n  // Anchor program errors\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This match is no longer available.\";\n  }\n  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    return \"You cannot join your own match.\";\n  }\n\n  // Simulation / preflight failures\n  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    return \"Transaction simulation failed. The match may no longer be available.\";\n  }\n\n  // Blockhash expiry\n  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    return \"Transaction expired. Please try again.\";\n  }\n\n  // Generic fallback — log full error for debugging\n  console.error(\"[coinflip] unhandled transaction error:\", err);\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  claimableMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Verification\n  lastClaimSignature: string | null;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  timeoutCancel: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  selectMatch: (match: UIMatch) => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Verification — last claim tx signature for fairness verification\n  const [lastClaimSignature, setLastClaimSignature] = useState<string | null>(null);\n\n  // Timer ref for flip animation delay (ready→flipping→complete)\n  const flipTimerRef = useRef<number | null>(null);\n\n  // Ref to prevent polling races from restoring a dismissed match.\n  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n  // from the previous poll interval may resolve and call setActiveMatch,\n  // putting them back on the match view. This ref blocks that.\n  const dismissedMatchRef = useRef<string | null>(null);\n\n  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n      const signature = await sendTransaction(transaction);\n      await connection.confirmTransaction(\n        { signature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      await refreshBalance();\n      return signature;\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // Fetch open matches (and claimable matches when wallet connected) from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n\n    if (publicKey) {\n      fetchClaimableMatches(connection, publicKey)\n        .then(setClaimableMatches)\n        .catch(() => {});\n    }\n  }, [connection, publicKey]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too (skip during flip animation)\n      if (activeMatch && activeMatch.phase !== \"flipping\") {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            // If user dismissed this match while fetch was in flight, ignore\n            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n\n            if (updated) {\n              // Intercept ready→complete: insert 3s flip animation first\n              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n                setActiveMatch({ ...updated, phase: \"flipping\" });\n                flipTimerRef.current = window.setTimeout(() => {\n                  flipTimerRef.current = null;\n                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n                  setActiveMatch((current) =>\n                    current?.phase === \"flipping\" ? updated : current\n                  );\n                }, 3000);\n              } else {\n                setActiveMatch(updated);\n              }\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection, pollInterval]);\n\n  // Cleanup flip timer on unmount\n  useEffect(() => {\n    return () => {\n      if (flipTimerRef.current !== null) {\n        clearTimeout(flipTimerRef.current);\n      }\n    };\n  }, []);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n      const [matchPda] = getMatchPda(publicKey);\n      const existing = await fetchMatch(connection, matchPda);\n      if (existing) {\n        if (existing.phase === \"complete\") {\n          // Match is settled — show it so user can settle (winner claims, loser closes)\n          setActiveMatch(existing);\n          dismissedMatchRef.current = null;\n          setError(\"Settle your previous match first.\");\n        } else {\n          // Match still in progress\n          setActiveMatch(existing);\n          dismissedMatchRef.current = null;\n          setError(\"You already have an active match.\");\n        }\n        return;\n      }\n\n      const { transaction } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendAndConfirm(transaction);\n\n      // Clear dismissed ref — this is a new intentional match\n      dismissedMatchRef.current = null;\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendAndConfirm(transaction);\n\n        // Clear dismissed ref — this is a new intentional match\n        dismissedMatchRef.current = null;\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendAndConfirm(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  const timeoutCancel = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n    if (!activeMatch.player2) {\n      setError(\"Match has no opponent.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = new PublicKey(activeMatch.player2);\n\n      const transaction = await buildTimeoutCancelTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n      await sendAndConfirm(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n    if (!activeMatch.player2) {\n      setError(\"Match has no opponent yet.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = new PublicKey(activeMatch.player2);\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,   // caller (either player — winner derived on-chain from VRF)\n        matchCreator,\n        opponent\n      );\n\n      await sendAndConfirm(transaction);\n\n      // Match PDA is now closed — clear local state\n      dismissedMatchRef.current = activeMatch.id;\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  /** Open a match from the claimable list in ActiveMatchView. */\n  const selectMatch = useCallback((match: UIMatch) => {\n    dismissedMatchRef.current = null;\n    setActiveMatch(match);\n    setUserClearedMatch(false);\n  }, []);\n\n  const clearActiveMatch = useCallback(() => {\n    // Record the dismissed match ID so in-flight polls don't restore it\n    dismissedMatchRef.current = activeMatch?.id ?? null;\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [activeMatch, refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            // Don't restore a match the user explicitly dismissed\n            if (dismissedMatchRef.current === match.id) return;\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    claimableMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    timeoutCancel,\n    claimPayout,\n    clearActiveMatch,\n    selectMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","structuredPatch":[{"oldStart":421,"oldLines":11,"newStart":421,"newLines":12,"lines":["         opponent","       );"," ","-      await sendAndConfirm(transaction);","+      const signature = await sendAndConfirm(transaction);"," ","-      // Match PDA is now closed — clear local state","-      dismissedMatchRef.current = activeMatch.id;","-      setActiveMatch(null);","+      // Match PDA is now closed on-chain. Keep activeMatch locally with","+      // claimed=true so the user can verify fairness before returning to lobby.","+      setLastClaimSignature(signature);","+      setActiveMatch((prev) => prev ? { ...prev, claimed: true } : null);","       refreshMatches();","     } catch (err) {","       setError(parseTransactionError(err));"]}],"userModified":false,"replaceAll":false}}
