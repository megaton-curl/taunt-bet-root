{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015zP6Zmfr2qmVKUJAEqzJSo","type":"tool_result","content":"     1→import { Connection, PublicKey } from \"@solana/web3.js\";\n     2→import { BorshCoder, EventParser, type Idl } from \"@coral-xyz/anchor\";\n     3→import { CoinflipIDL } from \"@rng-utopia/anchor-client\";\n     4→\n     5→// ============ Constants ============\n     6→\n     7→const COINFLIP_PROGRAM_ID = new PublicKey(\n     8→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n     9→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    10→);\n    11→\n    12→// ============ Types ============\n    13→\n    14→export interface VerificationResult {\n    15→  verified: boolean;\n    16→  creator: string;\n    17→  opponent: string;\n    18→  winner: string;\n    19→  randomnessHex: string;\n    20→  derivedResult: \"heads\" | \"tails\";\n    21→  vrfFulfilled: boolean;\n    22→}\n    23→\n    24→interface MatchSettledEventData {\n    25→  creator: PublicKey;\n    26→  opponent: PublicKey;\n    27→  winner: PublicKey;\n    28→  randomness: number[];\n    29→  payoutAmount: { toNumber(): number };\n    30→  feeAmount: { toNumber(): number };\n    31→  vrfRequestKey: PublicKey;\n    32→}\n    33→\n    34→// ============ Verification ============\n    35→\n    36→/**\n    37→ * Verifies the fairness of a completed coinflip match by inspecting the\n    38→ * claim transaction's MatchSettled event and the Orao VRF randomness account.\n    39→ *\n    40→ * Steps:\n    41→ * 1. Fetch the parsed transaction by signature\n    42→ * 2. Extract MatchSettled event from program logs\n    43→ * 3. Read randomness bytes from the event\n    44→ * 4. Re-derive the coin flip result via from_randomness(randomness[0])\n    45→ * 5. Validate the event winner is one of creator/opponent\n    46→ * 6. Fetch the Orao randomness account to confirm VRF fulfillment\n    47→ */\n    48→export async function verifyMatch(\n    49→  connection: Connection,\n    50→  claimTxSignature: string\n    51→): Promise<VerificationResult> {\n    52→  // (1) Fetch transaction\n    53→  const tx = await connection.getTransaction(claimTxSignature, {\n    54→    commitment: \"confirmed\",\n    55→    maxSupportedTransactionVersion: 0,\n    56→  });\n    57→  if (!tx?.meta?.logMessages) {\n    58→    throw new Error(\"Transaction not found or has no logs\");\n    59→  }\n    60→\n    61→  // (2) Extract MatchSettled event from logs\n    62→  const coder = new BorshCoder(CoinflipIDL as Idl);\n    63→  const eventParser = new EventParser(COINFLIP_PROGRAM_ID, coder);\n    64→\n    65→  let settledEvent: MatchSettledEventData | null = null;\n    66→  for (const event of eventParser.parseLogs(tx.meta.logMessages)) {\n    67→    if (event.name === \"matchSettled\") {\n    68→      settledEvent = event.data as MatchSettledEventData;\n    69→      break;\n    70→    }\n    71→  }\n    72→\n    73→  if (!settledEvent) {\n    74→    throw new Error(\"MatchSettled event not found in transaction logs\");\n    75→  }\n    76→\n    77→  // (3) Read randomness bytes from event\n    78→  const randomnessBytes = Uint8Array.from(settledEvent.randomness);\n    79→  const randomnessHex = Array.from(randomnessBytes)\n    80→    .map((b) => b.toString(16).padStart(2, \"0\"))\n    81→    .join(\"\");\n    82→\n    83→  // (4) Re-derive result: from_randomness(randomness[0]) — matches on-chain logic\n    84→  const firstByte = randomnessBytes[0] ?? 0;\n    85→  const derivedResult: \"heads\" | \"tails\" =\n    86→    firstByte % 2 === 0 ? \"heads\" : \"tails\";\n    87→\n    88→  // (5) Validate winner is one of the two players\n    89→  const creator = settledEvent.creator.toBase58();\n    90→  const opponent = settledEvent.opponent.toBase58();\n    91→  const winner = settledEvent.winner.toBase58();\n    92→  const winnerIsValid = winner === creator || winner === opponent;\n    93→\n    94→  // (6) Fetch Orao randomness account by vrf_request_key to confirm VRF fulfillment\n    95→  let vrfFulfilled = false;\n    96→  try {\n    97→    const vrfAccount = await connection.getAccountInfo(\n    98→      settledEvent.vrfRequestKey\n    99→    );\n   100→    if (vrfAccount && vrfAccount.data.length > 8) {\n   101→      // Orao randomness account: 8-byte discriminator then randomness data.\n   102→      // Fulfilled means non-zero bytes in the randomness portion.\n   103→      const randomnessData = vrfAccount.data.subarray(8, 72);\n   104→      vrfFulfilled = randomnessData.some((b: number) => b !== 0);\n   105→    }\n   106→  } catch {\n   107→    vrfFulfilled = false;\n   108→  }\n   109→\n   110→  return {\n   111→    verified: winnerIsValid && vrfFulfilled,\n   112→    creator,\n   113→    opponent,\n   114→    winner,\n   115→    randomnessHex,\n   116→    derivedResult,\n   117→    vrfFulfilled,\n   118→  };\n   119→}\n   120→"}]},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"8df267cd-a452-4b5c-93c9-7fce4898f7c7","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/verification.ts","content":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport { BorshCoder, EventParser, type Idl } from \"@coral-xyz/anchor\";\nimport { CoinflipIDL } from \"@rng-utopia/anchor-client\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n);\n\n// ============ Types ============\n\nexport interface VerificationResult {\n  verified: boolean;\n  creator: string;\n  opponent: string;\n  winner: string;\n  randomnessHex: string;\n  derivedResult: \"heads\" | \"tails\";\n  vrfFulfilled: boolean;\n}\n\ninterface MatchSettledEventData {\n  creator: PublicKey;\n  opponent: PublicKey;\n  winner: PublicKey;\n  randomness: number[];\n  payoutAmount: { toNumber(): number };\n  feeAmount: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n}\n\n// ============ Verification ============\n\n/**\n * Verifies the fairness of a completed coinflip match by inspecting the\n * claim transaction's MatchSettled event and the Orao VRF randomness account.\n *\n * Steps:\n * 1. Fetch the parsed transaction by signature\n * 2. Extract MatchSettled event from program logs\n * 3. Read randomness bytes from the event\n * 4. Re-derive the coin flip result via from_randomness(randomness[0])\n * 5. Validate the event winner is one of creator/opponent\n * 6. Fetch the Orao randomness account to confirm VRF fulfillment\n */\nexport async function verifyMatch(\n  connection: Connection,\n  claimTxSignature: string\n): Promise<VerificationResult> {\n  // (1) Fetch transaction\n  const tx = await connection.getTransaction(claimTxSignature, {\n    commitment: \"confirmed\",\n    maxSupportedTransactionVersion: 0,\n  });\n  if (!tx?.meta?.logMessages) {\n    throw new Error(\"Transaction not found or has no logs\");\n  }\n\n  // (2) Extract MatchSettled event from logs\n  const coder = new BorshCoder(CoinflipIDL as Idl);\n  const eventParser = new EventParser(COINFLIP_PROGRAM_ID, coder);\n\n  let settledEvent: MatchSettledEventData | null = null;\n  for (const event of eventParser.parseLogs(tx.meta.logMessages)) {\n    if (event.name === \"matchSettled\") {\n      settledEvent = event.data as MatchSettledEventData;\n      break;\n    }\n  }\n\n  if (!settledEvent) {\n    throw new Error(\"MatchSettled event not found in transaction logs\");\n  }\n\n  // (3) Read randomness bytes from event\n  const randomnessBytes = Uint8Array.from(settledEvent.randomness);\n  const randomnessHex = Array.from(randomnessBytes)\n    .map((b) => b.toString(16).padStart(2, \"0\"))\n    .join(\"\");\n\n  // (4) Re-derive result: from_randomness(randomness[0]) — matches on-chain logic\n  const firstByte = randomnessBytes[0] ?? 0;\n  const derivedResult: \"heads\" | \"tails\" =\n    firstByte % 2 === 0 ? \"heads\" : \"tails\";\n\n  // (5) Validate winner is one of the two players\n  const creator = settledEvent.creator.toBase58();\n  const opponent = settledEvent.opponent.toBase58();\n  const winner = settledEvent.winner.toBase58();\n  const winnerIsValid = winner === creator || winner === opponent;\n\n  // (6) Fetch Orao randomness account by vrf_request_key to confirm VRF fulfillment\n  let vrfFulfilled = false;\n  try {\n    const vrfAccount = await connection.getAccountInfo(\n      settledEvent.vrfRequestKey\n    );\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      // Orao randomness account: 8-byte discriminator then randomness data.\n      // Fulfilled means non-zero bytes in the randomness portion.\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      vrfFulfilled = randomnessData.some((b: number) => b !== 0);\n    }\n  } catch {\n    vrfFulfilled = false;\n  }\n\n  return {\n    verified: winnerIsValid && vrfFulfilled,\n    creator,\n    opponent,\n    winner,\n    randomnessHex,\n    derivedResult,\n    vrfFulfilled,\n  };\n}\n","numLines":120,"startLine":1,"totalLines":120}}}
