{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YUX4YJx8qzj5Cj24yYLUsd","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey, type Transaction } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchClaimableMatches,\n    16→  fetchMatchByCreator,\n    17→  fetchMatch,\n    18→  getMatchPda,\n    19→  buildCreateMatchTx,\n    20→  buildJoinMatchTx,\n    21→  buildCancelMatchTx,\n    22→  buildTimeoutCancelTx,\n    23→  buildClaimPayoutTx,\n    24→} from \"../utils/chain\";\n    25→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    26→\n    27→/** Parse Solana/wallet errors into user-friendly messages */\n    28→function parseTransactionError(err: unknown): string {\n    29→  const msg = err instanceof Error ? err.message : String(err);\n    30→\n    31→  // Wallet not connected\n    32→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    33→    return \"Wallet not connected. Please connect your wallet first.\";\n    34→  }\n    35→\n    36→  // User rejected\n    37→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    38→    return \"Transaction cancelled by user.\";\n    39→  }\n    40→\n    41→  // Insufficient funds (Solana runtime error)\n    42→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    43→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    44→  }\n    45→\n    46→  // Account already in use (match already exists)\n    47→  if (msg.includes(\"already in use\")) {\n    48→    return \"You already have an active match. Cancel it before creating a new one.\";\n    49→  }\n    50→\n    51→  // Network / RPC errors\n    52→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    53→    return \"Network error. Please check your connection and try again.\";\n    54→  }\n    55→\n    56→  // Anchor program errors\n    57→  if (msg.includes(\"InvalidPhase\")) {\n    58→    return \"This match is no longer available.\";\n    59→  }\n    60→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    61→    return \"You cannot join your own match.\";\n    62→  }\n    63→\n    64→  // Simulation / preflight failures\n    65→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    66→    return \"Transaction simulation failed. The match may no longer be available.\";\n    67→  }\n    68→\n    69→  // Blockhash expiry\n    70→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    71→    return \"Transaction expired. Please try again.\";\n    72→  }\n    73→\n    74→  // Generic fallback — log full error for debugging\n    75→  console.error(\"[coinflip] unhandled transaction error:\", err);\n    76→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    77→}\n    78→\n    79→interface CoinflipContextValue {\n    80→  // State\n    81→  activeMatch: UIMatch | null;\n    82→  openMatches: UIMatch[];\n    83→  claimableMatches: UIMatch[];\n    84→  userHistory: UIMatch[];\n    85→  selectedTier: Tier | null;\n    86→  selectedSide: CoinSide | null;\n    87→\n    88→  // Loading states\n    89→  loading: boolean;\n    90→  creating: boolean;\n    91→  joining: boolean;\n    92→  claiming: boolean;\n    93→  joiningMatchId: string | null;\n    94→\n    95→  // Error state\n    96→  error: string | null;\n    97→  clearError: () => void;\n    98→\n    99→  // Actions\n   100→  setSelectedTier: (tier: Tier | null) => void;\n   101→  setSelectedSide: (side: CoinSide | null) => void;\n   102→  createMatch: () => Promise<void>;\n   103→  joinMatch: (matchId: string) => Promise<void>;\n   104→  cancelMatch: () => Promise<void>;\n   105→  timeoutCancel: () => Promise<void>;\n   106→  claimPayout: () => Promise<void>;\n   107→  clearActiveMatch: () => void;\n   108→  selectMatch: (match: UIMatch) => void;\n   109→  refreshMatches: () => void;\n   110→}\n   111→\n   112→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n   113→\n   114→export function CoinflipProvider({ children }: { children: ReactNode }) {\n   115→  const { connected, publicKey, sendTransaction } = useWallet();\n   116→  const { connection } = useConnection();\n   117→  const { refresh: refreshBalance } = useBalance();\n   118→\n   119→  // Selection state\n   120→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   121→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   122→\n   123→  // Match state\n   124→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   125→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   126→  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n   127→  const [userHistory] = useState<UIMatch[]>([]);\n   128→\n   129→  // Loading states\n   130→  const [loading, setLoading] = useState(true);\n   131→  const [creating, setCreating] = useState(false);\n   132→  const [joining, setJoining] = useState(false);\n   133→  const [claiming, setClaiming] = useState(false);\n   134→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   135→\n   136→  // Error state\n   137→  const [error, setError] = useState<string | null>(null);\n   138→  const clearError = useCallback(() => setError(null), []);\n   139→\n   140→  // Timer ref for flip animation delay (ready→flipping→complete)\n   141→  const flipTimerRef = useRef<number | null>(null);\n   142→\n   143→  // Ref to prevent polling races from restoring a dismissed match.\n   144→  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n   145→  // from the previous poll interval may resolve and call setActiveMatch,\n   146→  // putting them back on the match view. This ref blocks that.\n   147→  const dismissedMatchRef = useRef<string | null>(null);\n   148→\n   149→  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n   150→  const sendAndConfirm = useCallback(\n   151→    async (transaction: Transaction): Promise<string> => {\n   152→      const { blockhash, lastValidBlockHeight } =\n   153→        await connection.getLatestBlockhash(\"confirmed\");\n   154→      const signature = await sendTransaction(transaction);\n   155→      await connection.confirmTransaction(\n   156→        { signature, blockhash, lastValidBlockHeight },\n   157→        \"confirmed\",\n   158→      );\n   159→      await refreshBalance();\n   160→      return signature;\n   161→    },\n   162→    [connection, sendTransaction, refreshBalance],\n   163→  );\n   164→\n   165→  // Fetch open matches (and claimable matches when wallet connected) from on-chain\n   166→  const refreshMatches = useCallback(() => {\n   167→    fetchAllOpenMatches(connection)\n   168→      .then((matches) => {\n   169→        setOpenMatches(matches);\n   170→        setLoading(false);\n   171→      })\n   172→      .catch(() => {\n   173→        setLoading(false);\n   174→      });\n   175→\n   176→    if (publicKey) {\n   177→      fetchClaimableMatches(connection, publicKey)\n   178→        .then(setClaimableMatches)\n   179→        .catch(() => {});\n   180→    }\n   181→  }, [connection, publicKey]);\n   182→\n   183→  // Initial load\n   184→  useEffect(() => {\n   185→    setLoading(true);\n   186→    refreshMatches();\n   187→  }, [refreshMatches]);\n   188→\n   189→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   190→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   191→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   192→\n   193→  useEffect(() => {\n   194→    const interval = setInterval(() => {\n   195→      refreshMatches();\n   196→\n   197→      // If there's an active match, refresh it too (skip during flip animation)\n   198→      if (activeMatch && activeMatch.phase !== \"flipping\") {\n   199→        const matchPda = new PublicKey(activeMatch.id);\n   200→        fetchMatch(connection, matchPda)\n   201→          .then((updated) => {\n   202→            // If user dismissed this match while fetch was in flight, ignore\n   203→            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n   204→\n   205→            if (updated) {\n   206→              // Intercept ready→complete: insert 3s flip animation first\n   207→              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n   208→                setActiveMatch({ ...updated, phase: \"flipping\" });\n   209→                flipTimerRef.current = window.setTimeout(() => {\n   210→                  flipTimerRef.current = null;\n   211→                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n   212→                  setActiveMatch((current) =>\n   213→                    current?.phase === \"flipping\" ? updated : current\n   214→                  );\n   215→                }, 3000);\n   216→              } else {\n   217→                setActiveMatch(updated);\n   218→              }\n   219→            } else {\n   220→              // Match account closed (claimed or cancelled)\n   221→              setActiveMatch(null);\n   222→            }\n   223→          })\n   224→          .catch(() => {\n   225→            // Ignore polling errors\n   226→          });\n   227→      }\n   228→    }, pollInterval);\n   229→    return () => clearInterval(interval);\n   230→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   231→\n   232→  // Cleanup flip timer on unmount\n   233→  useEffect(() => {\n   234→    return () => {\n   235→      if (flipTimerRef.current !== null) {\n   236→        clearTimeout(flipTimerRef.current);\n   237→      }\n   238→    };\n   239→  }, []);\n   240→\n   241→  const createMatch = useCallback(async () => {\n   242→    if (!connected || !publicKey) {\n   243→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   244→      return;\n   245→    }\n   246→    if (!selectedTier || !selectedSide) {\n   247→      setError(\"Select tier and side first.\");\n   248→      return;\n   249→    }\n   250→\n   251→    setCreating(true);\n   252→    setError(null);\n   253→    try {\n   254→      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n   255→      const [matchPda] = getMatchPda(publicKey);\n   256→      const existing = await fetchMatch(connection, matchPda);\n   257→      if (existing) {\n   258→        if (existing.phase === \"complete\") {\n   259→          // Match is settled — show it so user can settle (winner claims, loser closes)\n   260→          setActiveMatch(existing);\n   261→          dismissedMatchRef.current = null;\n   262→          setError(\"Settle your previous match first.\");\n   263→        } else {\n   264→          // Match still in progress\n   265→          setActiveMatch(existing);\n   266→          dismissedMatchRef.current = null;\n   267→          setError(\"You already have an active match.\");\n   268→        }\n   269→        return;\n   270→      }\n   271→\n   272→      const { transaction } = await buildCreateMatchTx(\n   273→        connection,\n   274→        publicKey,\n   275→        selectedTier,\n   276→        selectedSide\n   277→      );\n   278→\n   279→      await sendAndConfirm(transaction);\n   280→\n   281→      // Clear dismissed ref — this is a new intentional match\n   282→      dismissedMatchRef.current = null;\n   283→\n   284→      // Fetch the created match from on-chain\n   285→      const match = await fetchMatch(connection, matchPda);\n   286→      if (match) {\n   287→        setActiveMatch(match);\n   288→      }\n   289→\n   290→      setSelectedSide(null);\n   291→      refreshMatches();\n   292→    } catch (err) {\n   293→      setError(parseTransactionError(err));\n   294→    } finally {\n   295→      setCreating(false);\n   296→    }\n   297→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n   298→\n   299→  const joinMatch = useCallback(\n   300→    async (matchId: string) => {\n   301→      if (!connected || !publicKey) {\n   302→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   303→        return;\n   304→      }\n   305→\n   306→      setJoining(true);\n   307→      setJoiningMatchId(matchId);\n   308→      setError(null);\n   309→      try {\n   310→        // matchId is the match PDA base58 — fetch to get the creator\n   311→        const matchPda = new PublicKey(matchId);\n   312→        const existingMatch = await fetchMatch(connection, matchPda);\n   313→        if (!existingMatch) {\n   314→          setError(\"Match not found. It may have been cancelled.\");\n   315→          return;\n   316→        }\n   317→\n   318→        const matchCreator = new PublicKey(existingMatch.player1);\n   319→        const transaction = await buildJoinMatchTx(\n   320→          connection,\n   321→          publicKey,\n   322→          matchCreator\n   323→        );\n   324→\n   325→        await sendAndConfirm(transaction);\n   326→\n   327→        // Clear dismissed ref — this is a new intentional match\n   328→        dismissedMatchRef.current = null;\n   329→\n   330→        // Fetch updated match\n   331→        const updated = await fetchMatch(connection, matchPda);\n   332→        if (updated) {\n   333→          setActiveMatch(updated);\n   334→        }\n   335→\n   336→        refreshMatches();\n   337→      } catch (err) {\n   338→        setError(parseTransactionError(err));\n   339→      } finally {\n   340→        setJoining(false);\n   341→        setJoiningMatchId(null);\n   342→      }\n   343→    },\n   344→    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n   345→  );\n   346→\n   347→  const cancelMatch = useCallback(async () => {\n   348→    if (!connected || !publicKey || !activeMatch) {\n   349→      setError(\"No active match to cancel.\");\n   350→      return;\n   351→    }\n   352→\n   353→    setError(null);\n   354→    try {\n   355→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   356→      await sendAndConfirm(transaction);\n   357→      setActiveMatch(null);\n   358→      refreshMatches();\n   359→    } catch (err) {\n   360→      setError(parseTransactionError(err));\n   361→    }\n   362→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   363→\n   364→  const timeoutCancel = useCallback(async () => {\n   365→    if (!connected || !publicKey || !activeMatch) {\n   366→      setError(\"No active match to cancel.\");\n   367→      return;\n   368→    }\n   369→    if (!activeMatch.player2) {\n   370→      setError(\"Match has no opponent.\");\n   371→      return;\n   372→    }\n   373→\n   374→    setError(null);\n   375→    try {\n   376→      const matchCreator = new PublicKey(activeMatch.player1);\n   377→      const opponent = new PublicKey(activeMatch.player2);\n   378→\n   379→      const transaction = await buildTimeoutCancelTx(\n   380→        connection,\n   381→        publicKey,\n   382→        matchCreator,\n   383→        opponent\n   384→      );\n   385→      await sendAndConfirm(transaction);\n   386→      setActiveMatch(null);\n   387→      refreshMatches();\n   388→    } catch (err) {\n   389→      setError(parseTransactionError(err));\n   390→    }\n   391→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   392→\n   393→  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   394→   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n   395→  const claimPayout = useCallback(async () => {\n   396→    if (!connected || !publicKey || !activeMatch) {\n   397→      setError(\"No active match to claim.\");\n   398→      return;\n   399→    }\n   400→    if (!activeMatch.player2) {\n   401→      setError(\"Match has no opponent yet.\");\n   402→      return;\n   403→    }\n   404→\n   405→    setClaiming(true);\n   406→    setError(null);\n   407→    try {\n   408→      const matchCreator = new PublicKey(activeMatch.player1);\n   409→      const opponent = new PublicKey(activeMatch.player2);\n   410→\n   411→      const transaction = await buildClaimPayoutTx(\n   412→        connection,\n   413→        publicKey,   // caller (either player — winner derived on-chain from VRF)\n   414→        matchCreator,\n   415→        opponent\n   416→      );\n   417→\n   418→      await sendAndConfirm(transaction);\n   419→\n   420→      // Match PDA is now closed — clear local state\n   421→      dismissedMatchRef.current = activeMatch.id;\n   422→      setActiveMatch(null);\n   423→      refreshMatches();\n   424→    } catch (err) {\n   425→      setError(parseTransactionError(err));\n   426→    } finally {\n   427→      setClaiming(false);\n   428→    }\n   429→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   430→\n   431→  // Track if user explicitly cleared the match\n   432→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   433→\n   434→  /** Open a match from the claimable list in ActiveMatchView. */\n   435→  const selectMatch = useCallback((match: UIMatch) => {\n   436→    dismissedMatchRef.current = null;\n   437→    setActiveMatch(match);\n   438→    setUserClearedMatch(false);\n   439→  }, []);\n   440→\n   441→  const clearActiveMatch = useCallback(() => {\n   442→    // Record the dismissed match ID so in-flight polls don't restore it\n   443→    dismissedMatchRef.current = activeMatch?.id ?? null;\n   444→    setActiveMatch(null);\n   445→    setUserClearedMatch(true);\n   446→    setError(null);\n   447→    refreshMatches();\n   448→  }, [activeMatch, refreshMatches]);\n   449→\n   450→  // Check for existing active match on wallet connect\n   451→  useEffect(() => {\n   452→    if (publicKey && !activeMatch && !userClearedMatch) {\n   453→      fetchMatchByCreator(connection, publicKey)\n   454→        .then((match) => {\n   455→          if (match) {\n   456→            // Don't restore a match the user explicitly dismissed\n   457→            if (dismissedMatchRef.current === match.id) return;\n   458→            setActiveMatch(match);\n   459→          }\n   460→        })\n   461→        .catch(() => {\n   462→          // No active match found\n   463→        });\n   464→    }\n   465→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   466→\n   467→  // Reset userClearedMatch when creating or joining a new match\n   468→  useEffect(() => {\n   469→    if (activeMatch) {\n   470→      setUserClearedMatch(false);\n   471→    }\n   472→  }, [activeMatch]);\n   473→\n   474→  const value: CoinflipContextValue = {\n   475→    activeMatch,\n   476→    openMatches,\n   477→    claimableMatches,\n   478→    userHistory,\n   479→    selectedTier,\n   480→    selectedSide,\n   481→    loading,\n   482→    creating,\n   483→    joining,\n   484→    claiming,\n   485→    joiningMatchId,\n   486→    error,\n   487→    clearError,\n   488→    setSelectedTier,\n   489→    setSelectedSide,\n   490→    createMatch,\n   491→    joinMatch,\n   492→    cancelMatch,\n   493→    timeoutCancel,\n   494→    claimPayout,\n   495→    clearActiveMatch,\n   496→    selectMatch,\n   497→    refreshMatches,\n   498→  };\n   499→\n   500→  return (\n   501→    <CoinflipContext.Provider value={value}>\n   502→      {children}\n   503→    </CoinflipContext.Provider>\n   504→  );\n   505→}\n   506→\n   507→export function useCoinflip(): CoinflipContextValue {\n   508→  const context = useContext(CoinflipContext);\n   509→  if (!context) {\n   510→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   511→  }\n   512→  return context;\n   513→}\n   514→"}]},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"b0b1dfdc-7cf9-43b6-80aa-3c381f9f0d1b","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { PublicKey, type Transaction } from \"@solana/web3.js\";\nimport type { Tier } from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch, CoinSide } from \"../types\";\nimport {\n  fetchAllOpenMatches,\n  fetchClaimableMatches,\n  fetchMatchByCreator,\n  fetchMatch,\n  getMatchPda,\n  buildCreateMatchTx,\n  buildJoinMatchTx,\n  buildCancelMatchTx,\n  buildTimeoutCancelTx,\n  buildClaimPayoutTx,\n} from \"../utils/chain\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n\n/** Parse Solana/wallet errors into user-friendly messages */\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  // Wallet not connected\n  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    return \"Wallet not connected. Please connect your wallet first.\";\n  }\n\n  // User rejected\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n\n  // Insufficient funds (Solana runtime error)\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n\n  // Account already in use (match already exists)\n  if (msg.includes(\"already in use\")) {\n    return \"You already have an active match. Cancel it before creating a new one.\";\n  }\n\n  // Network / RPC errors\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n\n  // Anchor program errors\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This match is no longer available.\";\n  }\n  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    return \"You cannot join your own match.\";\n  }\n\n  // Simulation / preflight failures\n  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    return \"Transaction simulation failed. The match may no longer be available.\";\n  }\n\n  // Blockhash expiry\n  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    return \"Transaction expired. Please try again.\";\n  }\n\n  // Generic fallback — log full error for debugging\n  console.error(\"[coinflip] unhandled transaction error:\", err);\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\ninterface CoinflipContextValue {\n  // State\n  activeMatch: UIMatch | null;\n  openMatches: UIMatch[];\n  claimableMatches: UIMatch[];\n  userHistory: UIMatch[];\n  selectedTier: Tier | null;\n  selectedSide: CoinSide | null;\n\n  // Loading states\n  loading: boolean;\n  creating: boolean;\n  joining: boolean;\n  claiming: boolean;\n  joiningMatchId: string | null;\n\n  // Error state\n  error: string | null;\n  clearError: () => void;\n\n  // Actions\n  setSelectedTier: (tier: Tier | null) => void;\n  setSelectedSide: (side: CoinSide | null) => void;\n  createMatch: () => Promise<void>;\n  joinMatch: (matchId: string) => Promise<void>;\n  cancelMatch: () => Promise<void>;\n  timeoutCancel: () => Promise<void>;\n  claimPayout: () => Promise<void>;\n  clearActiveMatch: () => void;\n  selectMatch: (match: UIMatch) => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n\n  // Selection state\n  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Timer ref for flip animation delay (ready→flipping→complete)\n  const flipTimerRef = useRef<number | null>(null);\n\n  // Ref to prevent polling races from restoring a dismissed match.\n  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n  // from the previous poll interval may resolve and call setActiveMatch,\n  // putting them back on the match view. This ref blocks that.\n  const dismissedMatchRef = useRef<string | null>(null);\n\n  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n      const signature = await sendTransaction(transaction);\n      await connection.confirmTransaction(\n        { signature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      await refreshBalance();\n      return signature;\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // Fetch open matches (and claimable matches when wallet connected) from on-chain\n  const refreshMatches = useCallback(() => {\n    fetchAllOpenMatches(connection)\n      .then((matches) => {\n        setOpenMatches(matches);\n        setLoading(false);\n      })\n      .catch(() => {\n        setLoading(false);\n      });\n\n    if (publicKey) {\n      fetchClaimableMatches(connection, publicKey)\n        .then(setClaimableMatches)\n        .catch(() => {});\n    }\n  }, [connection, publicKey]);\n\n  // Initial load\n  useEffect(() => {\n    setLoading(true);\n    refreshMatches();\n  }, [refreshMatches]);\n\n  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      refreshMatches();\n\n      // If there's an active match, refresh it too (skip during flip animation)\n      if (activeMatch && activeMatch.phase !== \"flipping\") {\n        const matchPda = new PublicKey(activeMatch.id);\n        fetchMatch(connection, matchPda)\n          .then((updated) => {\n            // If user dismissed this match while fetch was in flight, ignore\n            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n\n            if (updated) {\n              // Intercept ready→complete: insert 3s flip animation first\n              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n                setActiveMatch({ ...updated, phase: \"flipping\" });\n                flipTimerRef.current = window.setTimeout(() => {\n                  flipTimerRef.current = null;\n                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n                  setActiveMatch((current) =>\n                    current?.phase === \"flipping\" ? updated : current\n                  );\n                }, 3000);\n              } else {\n                setActiveMatch(updated);\n              }\n            } else {\n              // Match account closed (claimed or cancelled)\n              setActiveMatch(null);\n            }\n          })\n          .catch(() => {\n            // Ignore polling errors\n          });\n      }\n    }, pollInterval);\n    return () => clearInterval(interval);\n  }, [refreshMatches, activeMatch, connection, pollInterval]);\n\n  // Cleanup flip timer on unmount\n  useEffect(() => {\n    return () => {\n      if (flipTimerRef.current !== null) {\n        clearTimeout(flipTimerRef.current);\n      }\n    };\n  }, []);\n\n  const createMatch = useCallback(async () => {\n    if (!connected || !publicKey) {\n      setError(\"Wallet not connected. Please connect your wallet first.\");\n      return;\n    }\n    if (!selectedTier || !selectedSide) {\n      setError(\"Select tier and side first.\");\n      return;\n    }\n\n    setCreating(true);\n    setError(null);\n    try {\n      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n      const [matchPda] = getMatchPda(publicKey);\n      const existing = await fetchMatch(connection, matchPda);\n      if (existing) {\n        if (existing.phase === \"complete\") {\n          // Match is settled — show it so user can settle (winner claims, loser closes)\n          setActiveMatch(existing);\n          dismissedMatchRef.current = null;\n          setError(\"Settle your previous match first.\");\n        } else {\n          // Match still in progress\n          setActiveMatch(existing);\n          dismissedMatchRef.current = null;\n          setError(\"You already have an active match.\");\n        }\n        return;\n      }\n\n      const { transaction } = await buildCreateMatchTx(\n        connection,\n        publicKey,\n        selectedTier,\n        selectedSide\n      );\n\n      await sendAndConfirm(transaction);\n\n      // Clear dismissed ref — this is a new intentional match\n      dismissedMatchRef.current = null;\n\n      // Fetch the created match from on-chain\n      const match = await fetchMatch(connection, matchPda);\n      if (match) {\n        setActiveMatch(match);\n      }\n\n      setSelectedSide(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setCreating(false);\n    }\n  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n\n  const joinMatch = useCallback(\n    async (matchId: string) => {\n      if (!connected || !publicKey) {\n        setError(\"Wallet not connected. Please connect your wallet first.\");\n        return;\n      }\n\n      setJoining(true);\n      setJoiningMatchId(matchId);\n      setError(null);\n      try {\n        // matchId is the match PDA base58 — fetch to get the creator\n        const matchPda = new PublicKey(matchId);\n        const existingMatch = await fetchMatch(connection, matchPda);\n        if (!existingMatch) {\n          setError(\"Match not found. It may have been cancelled.\");\n          return;\n        }\n\n        const matchCreator = new PublicKey(existingMatch.player1);\n        const transaction = await buildJoinMatchTx(\n          connection,\n          publicKey,\n          matchCreator\n        );\n\n        await sendAndConfirm(transaction);\n\n        // Clear dismissed ref — this is a new intentional match\n        dismissedMatchRef.current = null;\n\n        // Fetch updated match\n        const updated = await fetchMatch(connection, matchPda);\n        if (updated) {\n          setActiveMatch(updated);\n        }\n\n        refreshMatches();\n      } catch (err) {\n        setError(parseTransactionError(err));\n      } finally {\n        setJoining(false);\n        setJoiningMatchId(null);\n      }\n    },\n    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n  );\n\n  const cancelMatch = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const transaction = await buildCancelMatchTx(connection, publicKey);\n      await sendAndConfirm(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  const timeoutCancel = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to cancel.\");\n      return;\n    }\n    if (!activeMatch.player2) {\n      setError(\"Match has no opponent.\");\n      return;\n    }\n\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = new PublicKey(activeMatch.player2);\n\n      const transaction = await buildTimeoutCancelTx(\n        connection,\n        publicKey,\n        matchCreator,\n        opponent\n      );\n      await sendAndConfirm(transaction);\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n  const claimPayout = useCallback(async () => {\n    if (!connected || !publicKey || !activeMatch) {\n      setError(\"No active match to claim.\");\n      return;\n    }\n    if (!activeMatch.player2) {\n      setError(\"Match has no opponent yet.\");\n      return;\n    }\n\n    setClaiming(true);\n    setError(null);\n    try {\n      const matchCreator = new PublicKey(activeMatch.player1);\n      const opponent = new PublicKey(activeMatch.player2);\n\n      const transaction = await buildClaimPayoutTx(\n        connection,\n        publicKey,   // caller (either player — winner derived on-chain from VRF)\n        matchCreator,\n        opponent\n      );\n\n      await sendAndConfirm(transaction);\n\n      // Match PDA is now closed — clear local state\n      dismissedMatchRef.current = activeMatch.id;\n      setActiveMatch(null);\n      refreshMatches();\n    } catch (err) {\n      setError(parseTransactionError(err));\n    } finally {\n      setClaiming(false);\n    }\n  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n\n  // Track if user explicitly cleared the match\n  const [userClearedMatch, setUserClearedMatch] = useState(false);\n\n  /** Open a match from the claimable list in ActiveMatchView. */\n  const selectMatch = useCallback((match: UIMatch) => {\n    dismissedMatchRef.current = null;\n    setActiveMatch(match);\n    setUserClearedMatch(false);\n  }, []);\n\n  const clearActiveMatch = useCallback(() => {\n    // Record the dismissed match ID so in-flight polls don't restore it\n    dismissedMatchRef.current = activeMatch?.id ?? null;\n    setActiveMatch(null);\n    setUserClearedMatch(true);\n    setError(null);\n    refreshMatches();\n  }, [activeMatch, refreshMatches]);\n\n  // Check for existing active match on wallet connect\n  useEffect(() => {\n    if (publicKey && !activeMatch && !userClearedMatch) {\n      fetchMatchByCreator(connection, publicKey)\n        .then((match) => {\n          if (match) {\n            // Don't restore a match the user explicitly dismissed\n            if (dismissedMatchRef.current === match.id) return;\n            setActiveMatch(match);\n          }\n        })\n        .catch(() => {\n          // No active match found\n        });\n    }\n  }, [publicKey, activeMatch, userClearedMatch, connection]);\n\n  // Reset userClearedMatch when creating or joining a new match\n  useEffect(() => {\n    if (activeMatch) {\n      setUserClearedMatch(false);\n    }\n  }, [activeMatch]);\n\n  const value: CoinflipContextValue = {\n    activeMatch,\n    openMatches,\n    claimableMatches,\n    userHistory,\n    selectedTier,\n    selectedSide,\n    loading,\n    creating,\n    joining,\n    claiming,\n    joiningMatchId,\n    error,\n    clearError,\n    setSelectedTier,\n    setSelectedSide,\n    createMatch,\n    joinMatch,\n    cancelMatch,\n    timeoutCancel,\n    claimPayout,\n    clearActiveMatch,\n    selectMatch,\n    refreshMatches,\n  };\n\n  return (\n    <CoinflipContext.Provider value={value}>\n      {children}\n    </CoinflipContext.Provider>\n  );\n}\n\nexport function useCoinflip(): CoinflipContextValue {\n  const context = useContext(CoinflipContext);\n  if (!context) {\n    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n  }\n  return context;\n}\n","numLines":514,"startLine":1,"totalLines":514}}}
