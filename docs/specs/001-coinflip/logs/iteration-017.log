{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UYSxV6QjoYiPUGqWXyKL5U","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/components/ActiveMatchView.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"8cef060a-5568-447a-a71b-c473ae13aa50","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/components/ActiveMatchView.tsx","oldString":"import { useState, useEffect } from \"react\";\nimport type { UIMatch } from \"../types\";\nimport { CoinAnimation } from \"./CoinAnimation\";\nimport { getOppositeSide } from \"../utils/helpers\";\nimport { PlayerAvatarCompact } from \"../../player-profile\";","newString":"import { useState, useEffect } from \"react\";\nimport type { UIMatch } from \"../types\";\nimport type { VerificationResult } from \"../utils/verification\";\nimport { CoinAnimation } from \"./CoinAnimation\";\nimport { getOppositeSide } from \"../utils/helpers\";\nimport { PlayerAvatarCompact } from \"../../player-profile\";","originalFile":"import { useState, useEffect } from \"react\";\nimport type { UIMatch } from \"../types\";\nimport { CoinAnimation } from \"./CoinAnimation\";\nimport { getOppositeSide } from \"../utils/helpers\";\nimport { PlayerAvatarCompact } from \"../../player-profile\";\n\nconst LOCK_TIMEOUT_MS = 120_000; // 2 minutes\n\ninterface ActiveMatchViewProps {\n  match: UIMatch;\n  currentUserAddress: string;\n  onCancel?: () => void;\n  onTimeoutCancel?: () => void;\n  onClaim?: () => void;\n  onClearMatch?: () => void;\n  cancelling?: boolean;\n  claiming?: boolean;\n}\n\nexport function ActiveMatchView({\n  match,\n  currentUserAddress,\n  onCancel,\n  onTimeoutCancel,\n  onClaim,\n  onClearMatch,\n  cancelling,\n  claiming,\n}: ActiveMatchViewProps) {\n  const isPlayer1 = match.player1 === currentUserAddress;\n  const isWinner = match.winner === currentUserAddress;\n\n  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n  const opponent = isPlayer1 ? match.player2 : match.player1;\n\n  // Track whether lock timeout has elapsed (for timeout cancel button)\n  const [lockTimedOut, setLockTimedOut] = useState(false);\n  const [cancellingTimeout, setCancellingTimeout] = useState(false);\n\n  useEffect(() => {\n    if (match.phase !== \"ready\" || !match.lockedAt) {\n      // For legacy matches with no lockedAt, show cancel immediately\n      setLockTimedOut(match.phase === \"ready\");\n      return;\n    }\n\n    const remaining = match.lockedAt + LOCK_TIMEOUT_MS - Date.now();\n    if (remaining <= 0) {\n      setLockTimedOut(true);\n      return;\n    }\n\n    setLockTimedOut(false);\n    const timer = setTimeout(() => setLockTimedOut(true), remaining);\n    return () => clearTimeout(timer);\n  }, [match.phase, match.lockedAt]);\n\n  // Countdown timer\n  const [countdown, setCountdown] = useState(3);\n\n  useEffect(() => {\n    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n      // Always start at 3\n      setCountdown(3);\n\n      const updateCountdown = () => {\n        const elapsed = Date.now() - match.countdownStartedAt!;\n        // Each number shows for exactly 1 second:\n        // 0-999ms: show 3\n        // 1000-1999ms: show 2\n        // 2000-2999ms: show 1\n        if (elapsed < 1000) {\n          setCountdown(3);\n        } else if (elapsed < 2000) {\n          setCountdown(2);\n        } else {\n          setCountdown(1);\n        }\n      };\n\n      const interval = setInterval(updateCountdown, 50);\n      return () => {\n        clearInterval(interval);\n        // Reset for next countdown\n        setCountdown(3);\n      };\n    }\n  }, [match.phase, match.countdownStartedAt]);\n\n  return (\n    <div className=\"coinflip-active-match\">\n      {/* Waiting for opponent */}\n      {match.phase === \"created\" && (\n        <div className=\"coinflip-active-match__waiting\">\n          <h3 className=\"coinflip-active-match__title\">Waiting for Opponent</h3>\n          <div className=\"coinflip-active-match__info\">\n            <p>\n              Your side: <strong className={`side-${match.player1Side}`}>\n                {match.player1Side.toUpperCase()}\n              </strong>\n            </p>\n            <p>Entry: <strong>{\"$\"}{match.entryAmount}</strong></p>\n          </div>\n          <div className=\"coinflip-waiting__spinner\" />\n          <p className=\"coinflip-active-match__hint\">\n            Someone will join soon...\n          </p>\n          {onCancel && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n              onClick={onCancel}\n              disabled={cancelling}\n            >\n              {cancelling ? \"Cancelling...\" : \"Cancel Match\"}\n            </button>\n          )}\n        </div>\n      )}\n\n      {/* Ready / Countdown */}\n      {(match.phase === \"ready\" || match.phase === \"countdown\") && (\n        <div className=\"coinflip-active-match__playing\">\n          <h3 className=\"coinflip-active-match__title\">\n            {match.phase === \"ready\" && \"Game Ready!\"}\n            {match.phase === \"countdown\" && (\n              <span className=\"coinflip-countdown-inline\">\n                Flipping in... <span className=\"coinflip-countdown-inline__number\">{countdown}</span>\n              </span>\n            )}\n          </h3>\n\n          <div className=\"coinflip-active-match__players\">\n            <div className=\"coinflip-player coinflip-player--you\">\n              <span className=\"coinflip-player__label\">\n                <PlayerAvatarCompact address={currentUserAddress} />\n              </span>\n              <span className={`coinflip-player__side side-${yourSide}`}>\n                {yourSide?.toUpperCase()}\n              </span>\n            </div>\n\n            <span className=\"coinflip-active-match__vs\">VS</span>\n\n            <div className=\"coinflip-player coinflip-player--opponent\">\n              <span className=\"coinflip-player__label\">\n                {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n              </span>\n              <span className={`coinflip-player__side side-${opponentSide}`}>\n                {opponentSide?.toUpperCase()}\n              </span>\n            </div>\n          </div>\n\n          {/* Static coin for ready/countdown phases */}\n          <CoinAnimation\n            isFlipping={false}\n            result={null}\n            initialSide={yourSide ?? \"heads\"}\n            size=\"lg\"\n          />\n\n          {/* Timeout cancel — shown when VRF hasn't resolved within 2 min */}\n          {match.phase === \"ready\" && lockTimedOut && onTimeoutCancel && (\n            <div className=\"coinflip-active-match__timeout\">\n              <p className=\"coinflip-active-match__hint\">\n                Resolution timed out.\n              </p>\n              <button\n                type=\"button\"\n                className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n                onClick={async () => {\n                  setCancellingTimeout(true);\n                  try { await onTimeoutCancel(); } finally { setCancellingTimeout(false); }\n                }}\n                disabled={cancellingTimeout}\n              >\n                {cancellingTimeout ? \"Cancelling...\" : \"Cancel & Refund\"}\n              </button>\n            </div>\n          )}\n\n        </div>\n      )}\n\n      {/* Flipping / Complete - same container so coin persists through transition */}\n      {(match.phase === \"flipping\" || match.phase === \"complete\") && (\n        <div className=\"coinflip-active-match__playing\">\n          <h3 className={`coinflip-active-match__title ${\n            match.phase === \"complete\" ? (isWinner ? \"coinflip-active-match__title--won\" : \"coinflip-active-match__title--lost\") : \"\"\n          }`}>\n            {match.phase === \"flipping\" && \"Flipping!\"}\n            {match.phase === \"complete\" && isWinner && \"You Won!\"}\n            {match.phase === \"complete\" && !isWinner && (\n              <span className=\"coinflip-lose-title\">\n                You Lost{\" \"}\n                <span className=\"coinflip-lose-title__heart\">💔</span>\n                <span className=\"coinflip-lose-title__shards\">\n                  {[...Array(5)].map((_, i) => (\n                    <span key={i} className=\"coinflip-lose-title__shard\" style={{ '--shard-index': i } as React.CSSProperties}>◆</span>\n                  ))}\n                </span>\n              </span>\n            )}\n          </h3>\n\n          {/* Players info during flipping */}\n          {match.phase === \"flipping\" && (\n            <div className=\"coinflip-active-match__players\">\n              <div className=\"coinflip-player coinflip-player--you\">\n                <span className=\"coinflip-player__label\">\n                  <PlayerAvatarCompact address={currentUserAddress} />\n                </span>\n                <span className={`coinflip-player__side side-${yourSide}`}>\n                  {yourSide?.toUpperCase()}\n                </span>\n              </div>\n\n              <span className=\"coinflip-active-match__vs\">VS</span>\n\n              <div className=\"coinflip-player coinflip-player--opponent\">\n                <span className=\"coinflip-player__label\">\n                  {opponent ? <PlayerAvatarCompact address={opponent} /> : \"...\"}\n                </span>\n                <span className={`coinflip-player__side side-${opponentSide}`}>\n                  {opponentSide?.toUpperCase()}\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Single coin that persists through flipping → complete */}\n          <CoinAnimation\n            isFlipping={match.phase === \"flipping\"}\n            result={match.result}\n            initialSide={yourSide ?? \"heads\"}\n            size=\"lg\"\n          />\n\n          {/* Result info during complete */}\n          {match.phase === \"complete\" && (\n            <>\n              {/* Win Animation - Arcade star burst */}\n              {isWinner && (\n                <div className=\"coinflip-win-animation\">\n                  <div className=\"coinflip-win-animation__stars\">\n                    {[...Array(8)].map((_, i) => (\n                      <span key={i} className=\"coinflip-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n                    ))}\n                  </div>\n                  <div className=\"coinflip-win-animation__coins\">\n                    {[...Array(6)].map((_, i) => (\n                      <span key={i} className=\"coinflip-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n                    ))}\n                  </div>\n                </div>\n              )}\n\n              <div\n                className={`coinflip-result ${\n                  isWinner ? \"coinflip-result--won\" : \"coinflip-result--lost\"\n                }`}\n              >\n                <p className=\"coinflip-result__outcome\">\n                  Result: <strong\n                    style={{\n                      color: match.result === \"heads\" ? \"#45b058\" : \"#e09030\",\n                      textShadow: `0 0 6px ${match.result === \"heads\" ? \"#45b058\" : \"#e09030\"}`\n                    }}\n                  >{match.result?.toUpperCase()}</strong>\n                </p>\n                {isWinner && (\n                  <p className=\"coinflip-result__payout\">\n                    Payout: <strong>{\"$\"}{match.payoutAmount.toFixed(4)}</strong>\n                  </p>\n                )}\n              </div>\n\n              {/* Action buttons */}\n              <div className=\"coinflip-active-match__actions\">\n                {!match.claimed && onClaim && (\n                  <button\n                    type=\"button\"\n                    className=\"coinflip-action-btn\"\n                    onClick={onClaim}\n                    disabled={claiming}\n                  >\n                    {claiming\n                      ? \"Settling...\"\n                      : isWinner\n                        ? \"Claim Payout\"\n                        : \"Settle & Return to Lobby\"}\n                  </button>\n                )}\n                {match.claimed && onClearMatch && (\n                  <button\n                    type=\"button\"\n                    className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n                    onClick={onClearMatch}\n                  >\n                    Back to Lobby\n                  </button>\n                )}\n              </div>\n\n            </>\n          )}\n        </div>\n      )}\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":6,"lines":[" import { useState, useEffect } from \"react\";"," import type { UIMatch } from \"../types\";","+import type { VerificationResult } from \"../utils/verification\";"," import { CoinAnimation } from \"./CoinAnimation\";"," import { getOppositeSide } from \"../utils/helpers\";"," import { PlayerAvatarCompact } from \"../../player-profile\";"]}],"userModified":false,"replaceAll":false}}
