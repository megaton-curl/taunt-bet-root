{verificationResult.winner.slice(0, 4)}...{verificationResult.winner.slice(-4)}","+                      </span>","+                    </div>","+                    <div className=\"coinflip-verification__row\">","+                      <span>VRF Fulfilled</span>","+                      <span className={verificationResult.vrfFulfilled ? \"coinflip-verification__check\" : \"coinflip-verification__cross\"}>","+                        {verificationResult.vrfFulfilled ? \"Yes\" : \"No\"}","+                      </span>","+                    </div>","+                  </div>","+                  <a href=\"/fairness\" className=\"coinflip-verification__link\">","+                    Full Verification Page","+                  </a>","+                </div>","+              )}","+","             </>","           )}","         </div>"]}],"userModified":false,"replaceAll":false}}
