Match,\n  cancelling,\n  claiming,\n}: ActiveMatchViewProps) {\n  const isPlayer1 = match.player1 === currentUserAddress;\n  const isWinner = match.winner === currentUserAddress;\n\n  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n  const opponent = isPlayer1 ? match.player2 : match.player1;\n\n  // Track whether lock timeout has elapsed (for timeout cancel button)\n  const [lockTimedOut, setLockTimedOut] = useState(false);\n  const [cancellingTimeout, setCancellingTimeout] = useState(false);\n\n  useEffect(() => {\n    if (match.phase !== \"ready\" || !match.lockedAt) {\n      // For legacy matches with no lockedAt, show cancel immediately\n      setLockTimedOut(match.phase === \"ready\");\n      return;\n    }\n\n    const remaining = match.lockedAt + LOCK_TIMEOUT_MS - Date.now();\n    if (remaining <= 0) {\n      setLockTimedOut(true);\n      return;\n    }\n\n    setLockTimedOut(false);\n    const timer = setTimeout(() => setLockTimedOut(true), remaining);\n    return () => clearTimeout(timer);\n  }, [match.phase, match.lockedAt]);\n\n  // Countdown timer\n  const [countdown, setCountdown] = useState(3);\n\n  useEffect(() => {\n    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n      // Always start at 3\n      setCountdown(3);\n\n      const updateCountdown = () => {\n        const elapsed = Date.now() - match.countdownStartedAt!;\n        // Each number shows for exactly 1 second:\n        // 0-999ms: show 3\n        // 1000-1999ms: show 2\n        // 2000-2999ms: show 1\n        if (elapsed < 1000) {\n          setCountdown(3);\n        } else if (elapsed < 2000) {\n          setCountdown(2);\n        } else {\n          setCountdown(1);\n        }\n      };\n\n      const interval = setInterval(updateCountdown, 50);\n      return () => {\n        clearInterval(interval);\n        // Reset for next countdown\n        setCountdown(3);\n      };\n    }\