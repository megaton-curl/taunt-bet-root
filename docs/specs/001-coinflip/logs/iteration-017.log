e ? `${claimTxSignature.slice(0, 8)}...${claimTxSignature.slice(-8)}` : \"—\"}\n                      </span>\n                    </div>\n                    <div className=\"coinflip-verification__row\">\n                      <span>Randomness</span>\n                      <span className=\"coinflip-verification__hash\" title={verificationResult.randomnessHex}>\n                        {verificationResult.randomnessHex.slice(0, 16)}...\n                      </span>\n                    </div>\n                    <div className=\"coinflip-verification__row\">\n                      <span>Derived Result</span>\n                      <span className={`side-${verificationResult.derivedResult}`}>\n                        {verificationResult.derivedResult.toUpperCase()}\n                      </span>\n                    </div>\n                    <div className=\"coinflip-verification__row\">\n                      <span>Winner</span>\n                      <span className=\"coinflip-verification__hash\" title={verificationResult.winner}>\n                        {verificationResult.winner.slice(0, 4)}...{verificationResult.winner.slice(-4)}\n                      </span>\n                    </div>\n                    <div className=\"coinflip-verification__row\">\n                      <span>VRF Fulfilled</span>\n                      <span className={verificationResult.vrfFulfilled ? \"coinflip-verification__check\" : \"coinflip-verification__cross\"}>\n                        {verificationResult.vrfFulfilled ? \"Yes\" : \"No\"}\n                      </span>\n                    </div>\n                  </div>\n                  <a href=\"/fairness\" className=\"coinflip-verification__link\">\n                    Full Verification Page\n                  </a>\n                </div>\n              )}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":321,"cache_read_input_tokens":10071