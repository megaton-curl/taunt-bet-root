{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018XH1iyraEKKmr265CR3i6D","type":"tool_result","content":"   988→    const hash = await hmacSha256(serverSeed, message);\n   989→    const crashPoint = hashToCrashPoint(hash);\n   990→\n   991→    setVerificationResult({\n   992→      valid: true,\n   993→      message: `Round outcome verified successfully.`,\n   994→      crashPoint: crashPoint.toFixed(2)\n   995→    });\n   996→  };\n   997→"}]},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"eec8c425-8b42-43b1-ac55-9fc78636f7d0","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/App.tsx","content":"    const hash = await hmacSha256(serverSeed, message);\n    const crashPoint = hashToCrashPoint(hash);\n\n    setVerificationResult({\n      valid: true,\n      message: `Round outcome verified successfully.`,\n      crashPoint: crashPoint.toFixed(2)\n    });\n  };\n","numLines":10,"startLine":988,"totalLines":1362}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LWmKHJZ5EFGtVn1QKR6Ud6","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016EAhR3Gm7ZytjmcZeJyedt","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/App.tsx","old_string":"    setVerificationResult({\n      valid: true,\n      message: `Round outcome verified successfully.`,\n      crashPoint: crashPoint.toFixed(2)\n    });\n  };\n\n  // Mock recent rounds data","new_string":"    setVerificationResult({\n      valid: true,\n      message: `Round outcome verified successfully.`,\n      crashPoint: crashPoint.toFixed(2)\n    });\n  };\n\n  // Coinflip VRF verification\n  const verifyCoinflipTx = async () => {\n    if (!coinflipTxSig.trim()) {\n      setCoinflipError('Please enter a claim transaction signature');\n      return;\n    }\n    setCoinflipVerifying(true);\n    setCoinflipError(null);\n    setCoinflipResult(null);\n    try {\n      const result = await verifyCoinflipMatch(connection, coinflipTxSig.trim());\n      setCoinflipResult(result);\n    } catch (err) {\n      setCoinflipError(err instanceof Error ? err.message : 'Verification failed');\n    } finally {\n      setCoinflipVerifying(false);\n    }\n  };\n\n  // Mock recent rounds data"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":258,"cache_read_input_tokens":105739,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":258},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"6e92ba44-fcf6-4902-bb95-4d79b873224d"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016EAhR3Gm7ZytjmcZeJyedt","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/App.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"59ba0125-0f76-4103-95f0-9eaafc029fda","uuid":"7ad6f969-5357-4921-a103-1c605b79428b","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/App.tsx","oldString":"    setVerificationResult({\n      valid: true,\n      message: `Round outcome verified successfully.`,\n      crashPoint: crashPoint.toFixed(2)\n    });\n  };\n\n  // Mock recent rounds data","newString":"    setVerificationResult({\n      valid: true,\n      message: `Round outcome verified successfully.`,\n      crashPoint: crashPoint.toFixed(2)\n    });\n  };\n\n  // Coinflip VRF verification\n  const verifyCoinflipTx = async () => {\n    if (!coinflipTxSig.trim()) {\n      setCoinflipError('Please enter a claim transaction signature');\n      return;\n    }\n    setCoinflipVerifying(true);\n    setCoinflipError(null);\n    setCoinflipResult(null);\n    try {\n      const result = await verifyCoinflipMatch(connection, coinflipTxSig.trim());\n      setCoinflipResult(result);\n    } catch (err) {\n      setCoinflipError(err instanceof Error ? err.message : 'Verification failed');\n    } finally {\n      setCoinflipVerifying(false);\n    }\n  };\n\n  // Mock recent rounds data","originalFile":"import { useState, useEffect, useRef } from \"react\";\nimport { BrowserRouter, Routes, Route, Link, NavLink, useLocation, useNavigate } from \"react-router-dom\";\nimport { CoinflipPage } from \"./pages/CoinflipPage\";\nimport { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\nimport { CloseCallPage } from \"./pages/CloseCallPage\";\nimport { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\nimport { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\nimport { BossRaidProvider, HeaderBossRaid, BossRaidModal, RNGBuffIndicator } from \"./features/boss-raid\";\nimport { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatar, PlayerAvatarCompact, getOrCreateProfile } from \"./features/player-profile\";\nimport { QuestsProvider, ChestDropNotification, useQuests } from \"./features/quests\";\nimport { QuestsPage } from \"./pages/QuestsPage\";\nimport { LootPage } from \"./pages/LootPage\";\nimport { useWallet, useBalance, useConnection } from \"@rng-utopia/wallet/hooks\";\nimport { verifyMatch as verifyCoinflipMatch, type VerificationResult as CoinflipVerificationResult } from \"./features/coinflip/utils/verification\";\n// WalletButton replaced by inline rpg-wallet-icon in scene area\n\nexport function App() {\n  return (\n    <BrowserRouter>\n      <PlayerProfileProvider>\n        <QuestsProvider>\n          <BossRaidProvider>\n            <AppContent />\n            <MiniProfileModal />\n            <ChestDropNotification />\n          </BossRaidProvider>\n        </QuestsProvider>\n      </PlayerProfileProvider>\n    </BrowserRouter>\n  );\n}\n\n\n// FAQ sections data\nconst faqSections = [\n    {\n      id: \"fees\",\n      title: \"Platform Fees\",\n      content: `RNG Wooftopia charges a 3% platform fee on all games. This means 97% of all wagered funds go directly to winners.\n\nFee breakdown:\n• 1% goes to player incentives (RNG Raid Boss reward pool, future promotions)\n• 2% goes to platform treasury (server costs, development, operations)\n\nWhat you get:\n• Winners receive: 97% of the pot\n• No hidden fees or withdrawal charges\n• Part of your wagers fund rewards you can win back through Raid Boss`\n    },\n    {\n      id: \"raid-boss\",\n      title: \"What is RNG Raid Boss?\",\n      content: `RNG Raid Boss is a community reward mechanic where players collectively battle a boss by playing games.\n\nHow it works:\n• A new boss spawns every hour with a 50-minute active phase\n• Every wager you make in any game deals \"damage\" to the boss\n• The boss HP drains over time - it's always defeated when the timer ends\n• When defeated, the reward pool is distributed to all participants\n\nRewards:\n• Your share is proportional to your damage contribution\n• The reward pool grows from 1% of all wagers during the raid\n• Higher total community damage = better loot tier = bigger multipliers\n• Bonus loot is occasionally added for extra rewards\n\nLoot Tiers (based on total damage):\n• Bronze: $0-$10 damage\n• Silver: $10-$50 damage\n• Gold: $50-$150 damage\n• Emerald: $150-$500 damage\n• Diamond: $500+ damage`\n    },\n    {\n      id: \"pvp\",\n      title: \"Why PvP Games?\",\n      content: `Unlike traditional house-edge gambling where you play against the casino, RNG Wooftopia is 100% player-vs-player. This creates a fundamentally fairer system:\n\n• No house edge exploiting players\n• Prize pools come entirely from player wagers\n• The platform only takes a small facilitation fee\n• Better odds than any traditional casino\n• Transparent, skill-independent wagering`\n    },\n    {\n      id: \"tiers\",\n      title: \"Wagering Tiers\",\n      content: `RNG Wooftopia uses wagering tiers to match players with similar risk appetites together. Each tier has a fixed $ amount - you play against others wagering the same amount.\n\nAvailable Tiers:\n• Iron: $0.50\n• Bronze: $1\n• Silver: $5\n• Gold: $10\n• Emerald: $25\n• Diamond: $100\n\nHow it works:\n• Each game has separate lobbies for each tier\n• Select your tier before joining a game\n• You're matched only with players in the same tier\n• Everyone in the round wagers the exact same amount\n\nBenefits:\n• Fair matchmaking - compete on equal footing\n• Choose the risk level you're comfortable with\n• No whales dominating smaller players`\n    },\n    {\n      id: \"leaderboard\",\n      title: \"Leaderboard System\",\n      content: `Leaderboard system details coming soon.\n\nWe're working on implementing competitive leaderboards to track and reward top players. Stay tuned for updates!`\n    },\n    {\n      id: \"fairness\",\n      title: \"On-Chain Fairness\",\n      content: `All game outcomes are provably fair using cryptographic verification:\n\nCommit-Reveal Pattern (Crash, Close Call):\n1. Server publishes a hash of its seed before betting\n2. Solana blockhash becomes the public seed\n3. After the round, server reveals its seed\n4. Anyone can verify the outcome matches\n\nOn-Chain VRF (Lord of RNGs, Coinflip):\n1. Game requests randomness from VRF provider\n2. VRF generates verifiable random bytes\n3. Result and proof stored on Solana blockchain\n4. Anyone can verify using blockchain explorer\n\nVisit the Fairness page in the header for verification tools.`\n    },\n    {\n      id: \"rng-buff\",\n      title: \"RNG Buff\",\n      content: `The RNG Buff is a powerful temporary bonus granted to players who help defeat the Raid Boss before the timer expires.\n\nHow to get the RNG Buff:\n1. Participate in the hourly Raid Boss by wagering in any game\n2. Your wagers deal \"damage\" to the boss\n3. If the boss is defeated before time runs out, ALL participants receive the buff\n4. The buff lasts for 1 hour (until the next raid starts)\n\nBuff Benefits:\n• Golden glowing border on your avatar (visible to all players)\n• Chance to drop treasure chests when wagering\n• Drop chance scales with wager amount (1% base + 5% per $1, max 25%)\n\nVisual Indicators:\n• Golden pulsing border around your avatar everywhere in the app\n• RNG Buff icon with countdown timer in your profile header\n• Star icon with timer in the main header\n\nThe buff expires when the next raid begins, so make the most of it!`\n    },\n    {\n      id: \"treasure-chests\",\n      title: \"Treasure Chests\",\n      content: `Treasure chests are mystery rewards that contain XP and $ prizes. Open them in the Loot page.\n\nHow to earn chests:\n• RNG Buff drops: Random chance when wagering with active RNG Buff\n• Complete ALL daily quests: 1 chest\n• Complete weekly quests: 1 chest per quest (3 total)\n• Complete ALL weekly quests: +2 bonus chests (5 total)\n\nRNG Buff chest drop rates:\n• Base chance: 1% per wager\n• Bonus: +5% per $1 wagered\n• Maximum: 25% chance per wager\n\nChest rarity (determined when opened):\n• Common (50%): 50-100 XP, $0.001-$0.005\n• Uncommon (30%): 100-250 XP, $0.005-$0.01\n• Rare (15%): 250-500 XP, $0.01-$0.025\n• Epic (4%): 500-1000 XP, $0.025-$0.05\n• Legendary (1%): 1000-2500 XP, $0.05-$0.1\n\n$ rewards are paid from the platform treasury. May the RNG gods smile upon you!`\n    },\n  ];\n\n// Terms Modal component\nfunction TermsModal({ onClose }: { onClose: () => void }) {\n  const ref = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    const handle = (e: MouseEvent) => {\n      if (ref.current && !ref.current.contains(e.target as Node)) onClose();\n    };\n    const esc = (e: KeyboardEvent) => { if (e.key === \"Escape\") onClose(); };\n    document.addEventListener(\"mousedown\", handle);\n    document.addEventListener(\"keydown\", esc);\n    return () => { document.removeEventListener(\"mousedown\", handle); document.removeEventListener(\"keydown\", esc); };\n  }, [onClose]);\n\n  return (\n    <div className=\"footer-terms-overlay\">\n      <div className=\"footer-terms-modal\" ref={ref}>\n        <button type=\"button\" className=\"footer-terms-close\" onClick={onClose}>×</button>\n        <h3 className=\"footer-terms-title\">Terms of Use</h3>\n        <div className=\"footer-terms-content\">\n          <p>By accessing and using RNG Wooftopia, you confirm that you are not a citizen, resident, or located within any jurisdiction where online gambling is prohibited or restricted by law, including but not limited to: the United States, United Kingdom, France, Germany, Spain, the Netherlands, or any other jurisdiction with similar regulations.</p>\n          <p>You are solely responsible for determining whether your use of this platform is lawful in your country or region of residence. RNG Wooftopia does not provide legal advice and assumes no liability for users who access the platform in violation of applicable laws.</p>\n          <p>By continuing to use this service, you acknowledge and accept these terms.</p>\n        </div>\n        <button type=\"button\" className=\"footer-terms-accept\" onClick={onClose}>I Understand</button>\n      </div>\n    </div>\n  );\n}\n\n// FAQ Modal component\nfunction FAQModal({ onClose }: { onClose: () => void }) {\n  const ref = useRef<HTMLDivElement>(null);\n  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n\n  useEffect(() => {\n    const handle = (e: MouseEvent) => {\n      if (ref.current && !ref.current.contains(e.target as Node)) onClose();\n    };\n    const esc = (e: KeyboardEvent) => { if (e.key === \"Escape\") onClose(); };\n    document.addEventListener(\"mousedown\", handle);\n    document.addEventListener(\"keydown\", esc);\n    return () => { document.removeEventListener(\"mousedown\", handle); document.removeEventListener(\"keydown\", esc); };\n  }, [onClose]);\n\n  return (\n    <div className=\"footer-faq-overlay\">\n      <div className=\"footer-faq-modal\" ref={ref}>\n        <button type=\"button\" className=\"footer-faq-close\" onClick={onClose}>×</button>\n        <h3 className=\"footer-faq-title\">Frequently Asked Questions</h3>\n        <div className=\"footer-faq-content\">\n          {faqSections.map((section) => (\n            <div key={section.id} className=\"faq-section\">\n              <button type=\"button\" className={`faq-section-header ${expandedFAQ === section.id ? \"expanded\" : \"\"}`} onClick={() => setExpandedFAQ(expandedFAQ === section.id ? null : section.id)}>\n                <span className=\"faq-section-title\">{section.title}</span>\n                <span className=\"faq-section-arrow\">{expandedFAQ === section.id ? \"−\" : \"+\"}</span>\n              </button>\n              {expandedFAQ === section.id && (\n                <div className=\"faq-section-content\">\n                  {section.content.split(\"\\n\\n\").map((paragraph, idx) => (\n                    <p key={idx}>{paragraph}</p>\n                  ))}\n                </div>\n              )}\n            </div>\n          ))}\n        </div>\n        <button type=\"button\" className=\"footer-faq-close-btn\" onClick={onClose}>Close</button>\n      </div>\n    </div>\n  );\n}\n\n// FooterModals - renders Terms and FAQ modals (triggered from Info popover)\nfunction FooterModals() {\n  // These modals are now triggered from the InfoPopover component\n  // This component is kept as a placeholder for any global footer-level modals\n  return null;\n}\n\n\nfunction AppContent() {\n  const [chatExpanded, setChatExpanded] = useState(false);\n  const [showInfoPopover, setShowInfoPopover] = useState(false);\n  const navigate = useNavigate();\n  const { connected, connecting, address, connect, disconnect } = useWallet();\n  const { formatted } = useBalance();\n  const infoRef = useRef<HTMLDivElement>(null);\n\n  // Close info popover on outside click\n  useEffect(() => {\n    if (!showInfoPopover) return;\n    const handle = (e: MouseEvent) => {\n      if (infoRef.current && !infoRef.current.contains(e.target as Node)) {\n        setShowInfoPopover(false);\n      }\n    };\n    document.addEventListener(\"mousedown\", handle);\n    return () => document.removeEventListener(\"mousedown\", handle);\n  }, [showInfoPopover]);\n\n  return (\n    <div className=\"app rpg-menu\">\n      {/* Background Scene (static composited image) */}\n      <div className=\"rpg-scene-bg\" />\n\n      {/* Shooting Stars */}\n      <div className=\"shooting-star shooting-star--1\" />\n      <div className=\"shooting-star shooting-star--2\" />\n      <div className=\"shooting-star shooting-star--3\" />\n      <div className=\"shooting-star shooting-star--4\" />\n      <div className=\"shooting-star shooting-star--5\" />\n\n      {/* HUD: Top-left - Raid Boss */}\n      <div className=\"rpg-hud rpg-hud--top-left\">\n        <HeaderBossRaid />\n      </div>\n      <BossRaidModal />\n\n      {/* HUD: Top-right - Chat (positioned below the moon) */}\n      <div className=\"rpg-hud rpg-hud--top-right\">\n        {/* Chat Panel (toggled by campfire) */}\n        <div className={`rpg-chat-panel ${chatExpanded ? \"expanded\" : \"\"}`}>\n          <div className=\"chat-panel-header\">\n            <h4>Global Chat</h4>\n            <button className=\"chat-close\" onClick={() => setChatExpanded(false)}>×</button>\n          </div>\n          <div className=\"chat-messages\">\n            <div className=\"chat-message\">\n              <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n              <span className=\"text\">gg nice flip!</span>\n            </div>\n            <div className=\"chat-message\">\n              <PlayerAvatarCompact address=\"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n              <span className=\"text\">who&apos;s ready for crash?</span>\n            </div>\n            <div className=\"chat-message\">\n              <PlayerAvatarCompact address=\"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n              <span className=\"text\">close call is rigged lol jk</span>\n            </div>\n            <div className=\"chat-message\">\n              <PlayerAvatarCompact address=\"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n              <span className=\"text\">just hit 5x on crash!</span>\n            </div>\n            <div className=\"chat-message\">\n              <PlayerAvatarCompact address=\"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n              <span className=\"text\">coinflip is where it&apos;s at</span>\n            </div>\n            <div className=\"chat-message\">\n              <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n              <span className=\"text\">how do I verify fairness?</span>\n            </div>\n          </div>\n          <div className=\"chat-input-container\">\n            <input type=\"text\" className=\"chat-input\" placeholder=\"Type a message...\" />\n            <button className=\"chat-send-btn\">Send</button>\n          </div>\n        </div>\n      </div>\n\n      {/* Title */}\n      <h1 className=\"rpg-title\">RNG Wooftopia</h1>\n\n      {/* Nav Bar */}\n      <RPGNavBar />\n\n      {/* Central Window */}\n      <div className=\"rpg-central-window\">\n        <div className=\"rpg-window-frame\">\n          <div className=\"rpg-window-bolt rpg-window-bolt--tl\" />\n          <div className=\"rpg-window-bolt rpg-window-bolt--tr\" />\n          <div className=\"rpg-window-bolt rpg-window-bolt--bl\" />\n          <div className=\"rpg-window-bolt rpg-window-bolt--br\" />\n\n          <div className=\"rpg-window-content\">\n            <Routes>\n              <Route path=\"/\" element={<HomePage />} />\n              <Route path=\"/coinflip\" element={<CoinflipPage />} />\n              <Route path=\"/lord-of-rngs\" element={<LordOfRngsPage />} />\n              <Route path=\"/close-call\" element={<CloseCallPage />} />\n              <Route path=\"/crash\" element={<CryptoCrashPage />} />\n              <Route path=\"/game-of-trades\" element={<GameOfTradesPage />} />\n              <Route path=\"/profile\" element={<ProfilePage />} />\n              <Route path=\"/loot\" element={<LootPage />} />\n              <Route path=\"/quests\" element={<QuestsPage />} />\n              <Route path=\"/fairness\" element={<FairnessPage />} />\n              <Route path=\"/leaderboard\" element={<LeaderboardPage />} />\n              <Route path=\"*\" element={<NotFoundPage />} />\n            </Routes>\n          </div>\n        </div>\n      </div>\n\n      {/* Scene: Quest Board + Treasure Chest (bottom-left) */}\n      <div className=\"rpg-scene-bottom-left\">\n        <div\n          className=\"rpg-scene-quest-board\"\n          onClick={() => navigate(\"/quests\")}\n          title=\"Quest Board\"\n        />\n        <SceneChest onClick={() => navigate(\"/loot\")} />\n      </div>\n\n      {/* Info Button (bottom-center) */}\n      <div className=\"rpg-info-btn-wrapper\" ref={infoRef}>\n        <button className=\"rpg-info-btn\" onClick={() => setShowInfoPopover(!showInfoPopover)}>\n          ?\n        </button>\n        {showInfoPopover && <InfoPopover onClose={() => setShowInfoPopover(false)} />}\n      </div>\n\n      {/* Scene: Campfire + Avatar (bottom-right, avatar at edge) */}\n      <div className=\"rpg-scene-campfire-area\">\n        <div\n          className={`rpg-scene-campfire ${chatExpanded ? \"rpg-scene-campfire--chat-active\" : \"\"}`}\n          onClick={() => setChatExpanded(!chatExpanded)}\n        >\n          <div className=\"rpg-scene-campfire__logs\" />\n          <div className=\"rpg-scene-campfire__flame\" />\n          <div className=\"rpg-scene-campfire__glow\" />\n        </div>\n        <div className=\"rpg-scene-avatar\" onClick={() => navigate(\"/profile\")}>\n          <RNGBuffIndicator />\n          <PlayerAvatar\n            address={address || \"DefaultPlayer\"}\n            size=\"lg\"\n            enableMiniProfile={false}\n          />\n        </div>\n        <div\n          className={`rpg-wallet-icon ${connected ? \"rpg-wallet-icon--connected\" : \"\"} ${connecting ? \"rpg-wallet-icon--connecting\" : \"\"}`}\n          onClick={() => connected ? disconnect() : connect()}\n          title={connected ? `$${formatted ?? \"0\"}` : \"Connect Wallet\"}\n        >\n          <span className=\"rpg-wallet-icon__amount\">\n            {connecting ? \"...\" : connected ? `$${formatted ?? \"0\"}` : \"—\"}\n          </span>\n          <div className=\"rpg-wallet-icon__bag\" />\n        </div>\n      </div>\n\n      {/* Footer modals (Terms/FAQ) - rendered globally */}\n      <FooterModals />\n    </div>\n  );\n}\n\n// RPG Nav Bar\nfunction RPGNavBar() {\n  const { claimableQuestCount, unopenedChestCount } = useQuests();\n\n  return (\n    <nav className=\"rpg-nav-bar\">\n      <NavLink to=\"/\" end className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n        Games\n      </NavLink>\n      <NavLink to=\"/quests\" className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n        Quests\n        {claimableQuestCount > 0 && <span className=\"rpg-nav-badge rpg-nav-badge--yellow\" />}\n      </NavLink>\n      <NavLink to=\"/loot\" className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n        Loot\n        {unopenedChestCount > 0 && <span className=\"rpg-nav-badge rpg-nav-badge--yellow\" />}\n      </NavLink>\n      <NavLink to=\"/profile\" className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n        Profile\n      </NavLink>\n      <NavLink to=\"/leaderboard\" className={({ isActive }) => `rpg-nav-btn ${isActive ? \"active\" : \"\"}`}>\n        Leaderboard\n      </NavLink>\n    </nav>\n  );\n}\n\n// Scene Treasure Chest (bottom-left)\nfunction SceneChest({ onClick }: { onClick: () => void }) {\n  const { unopenedChestCount } = useQuests();\n  const location = useLocation();\n  const hasLoot = unopenedChestCount > 0;\n  const isLootPage = location.pathname === \"/loot\";\n\n  return (\n    <div\n      className={`rpg-scene-chest ${hasLoot ? \"rpg-scene-chest--has-loot\" : \"\"} ${isLootPage ? \"rpg-scene-chest--open\" : \"\"}`}\n      onClick={onClick}\n      title={hasLoot ? \"You have loot!\" : \"Treasure chest\"}\n    />\n  );\n}\n\n// Info Popover (Terms, FAQ, Socials)\nfunction InfoPopover({ onClose }: { onClose: () => void }) {\n  const [showTerms, setShowTerms] = useState(false);\n  const [showFAQ, setShowFAQ] = useState(false);\n\n  if (showTerms) {\n    return <TermsModal onClose={() => { setShowTerms(false); onClose(); }} />;\n  }\n  if (showFAQ) {\n    return <FAQModal onClose={() => { setShowFAQ(false); onClose(); }} />;\n  }\n\n  return (\n    <div className=\"rpg-info-popover\">\n      <button className=\"rpg-info-popover__link\" onClick={() => setShowTerms(true)}>Terms</button>\n      <button className=\"rpg-info-popover__link\" onClick={() => setShowFAQ(true)}>FAQ</button>\n      <div className=\"rpg-info-popover__divider\" />\n      <a href=\"https://x.com/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"rpg-info-popover__link\">\n        X (Twitter)\n      </a>\n      <a href=\"https://t.me/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"rpg-info-popover__link\">\n        Telegram\n      </a>\n      <div className=\"rpg-info-popover__divider\" />\n      <span className=\"rpg-info-popover__link\" style={{ opacity: 0.5, cursor: \"default\", fontSize: \"0.4rem\" }}>\n        &copy; 2025 RNG Wooftopia\n      </span>\n    </div>\n  );\n}\n\n// Mock Leaderboard Data\nconst MOCK_LEADERBOARD_ADDRESSES = [\n  \"0xLB01aaa\", \"0xLB02bbb\", \"0xLB03ccc\", \"0xLB04ddd\", \"0xLB05eee\",\n  \"0xLB06fff\", \"0xLB07aab\", \"0xLB08bbc\", \"0xLB09ccd\", \"0xLB10dde\",\n  \"0xLB11eef\", \"0xLB12ffa\", \"0xLB13aac\", \"0xLB14bbd\", \"0xLB15cce\",\n  \"0xLB16ddf\", \"0xLB17eea\", \"0xLB18ffb\", \"0xLB19abc\", \"0xLB20def\",\n];\n\ninterface LeaderboardEntry {\n  address: string;\n  wagered: number;\n  points: number;\n}\n\nfunction generateLeaderboardData(): LeaderboardEntry[] {\n  return MOCK_LEADERBOARD_ADDRESSES.map((addr) => {\n    const profile = getOrCreateProfile(addr);\n    const lvl = profile.level;\n    // Wagered scales with level: lv1 ~$15, lv50 ~$1750, lv100 ~$6000\n    const baseWager = lvl * lvl * 0.5 + lvl * 10;\n    const wagered = Math.round(baseWager * (0.7 + Math.random() * 0.6) * 100) / 100;\n    const points = Math.round(wagered * (1 + lvl * 0.05) + profile.stats.wins * 10);\n    return { address: addr, wagered, points };\n  }).sort((a, b) => b.points - a.points);\n}\n\nfunction LeaderboardPage() {\n  const { address: myAddress } = useWallet();\n  const [entries] = useState<LeaderboardEntry[]>(() => generateLeaderboardData());\n\n  return (\n    <div className=\"leaderboard-page\">\n      <h2 className=\"leaderboard-page__title\">Leaderboard</h2>\n      <p className=\"leaderboard-page__subtitle\">Play wagered games, earn points, climb the leaderboard for seasonal rewards!</p>\n\n      <div className=\"leaderboard-page__table\">\n        <div className=\"leaderboard-page__row leaderboard-page__row--header\">\n          <span className=\"leaderboard-page__col leaderboard-page__col--rank\">#</span>\n          <span className=\"leaderboard-page__col leaderboard-page__col--player\">Player</span>\n          <span className=\"leaderboard-page__col leaderboard-page__col--wagered\">Wagered</span>\n          <span className=\"leaderboard-page__col leaderboard-page__col--points\">Points</span>\n        </div>\n\n        {entries.map((entry, i) => {\n          const isMe = entry.address === myAddress;\n          return (\n            <div\n              key={entry.address}\n              className={`leaderboard-page__row ${isMe ? \"leaderboard-page__row--me\" : \"\"}`}\n            >\n              <span className=\"leaderboard-page__col leaderboard-page__col--rank\">\n                {i + 1}\n              </span>\n              <span className=\"leaderboard-page__col leaderboard-page__col--player\">\n                <PlayerAvatarCompact address={entry.address} showLevel isCurrentUser={isMe} />\n              </span>\n              <span className=\"leaderboard-page__col leaderboard-page__col--wagered\">\n                {\"$\"}{entry.wagered.toFixed(2)}\n              </span>\n              <span className=\"leaderboard-page__col leaderboard-page__col--points\">\n                {entry.points.toLocaleString()}\n              </span>\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n\nfunction HomePage() {\n  return (\n    <div className=\"home\">\n      <div className=\"arcade-header\">\n        <h2>Select Your Game</h2>\n        <p className=\"subtitle\">Insert Conviction</p>\n      </div>\n\n      <div className=\"games-grid\">\n        <GameCard\n          name=\"Coinflip\"\n          description=\"Heads or Tails - 1v1 battles\"\n          path=\"/coinflip\"\n          visual=\"coinflip\"\n        />\n        <GameCard\n          name=\"Lord of the RNGs\"\n          description=\"Jackpot game - One RNG to win them all\"\n          path=\"/lord-of-rngs\"\n          visual=\"lotr\"\n        />\n        <GameCard\n          name=\"Close Call\"\n          description=\"Predict the outcome of the live 1 min candle close: Green or Red\"\n          path=\"/close-call\"\n          visual=\"close-call\"\n        />\n        <GameCard\n          name=\"Crypto Crash Simulator\"\n          description=\"Cash out before the crash - with multiplayer survival mode\"\n          path=\"/crash\"\n          visual=\"crash\"\n          hot\n        />\n        <GameCard\n          name=\"Game of Trades\"\n          description=\"Fast paced, 1 minute, multiplayer trading rounds. Best performance wins the pot\"\n          path=\"/game-of-trades\"\n          visual=\"trades\"\n        />\n        {/* TODO: Chart the Course, Tug of Earn, Slots Utopia — add back when implemented */}\n      </div>\n    </div>\n  );\n}\n\ninterface GameCardProps {\n  name: string;\n  description: string;\n  path: string;\n  visual: \"close-call\" | \"crash\" | \"lotr\" | \"coinflip\" | \"trades\" | \"slots\" | \"chart\" | \"tug\";\n  locked?: boolean;\n  hot?: boolean;\n}\n\nfunction GameCard({\n  name,\n  description,\n  path,\n  visual,\n  locked = false,\n  hot = false,\n}: GameCardProps) {\n  return (\n    <Link\n      to={locked ? \"#\" : path}\n      className={`game-card game-card--${visual} ${locked ? \"locked\" : \"\"}`}\n      onClick={(e) => locked && e.preventDefault()}\n    >\n      {hot && <span className=\"hot-badge\">HOT</span>}\n      {locked && <span className=\"lock-icon\">🔒</span>}\n\n      {/* Game Icon */}\n      <div className=\"game-card-icon\">\n        <GameCardIcon visual={visual} />\n      </div>\n\n      {/* Game Info */}\n      <div className=\"game-info\">\n        <h3>{name}</h3>\n        <p className=\"game-description\">{description}</p>\n      </div>\n\n      {/* Footer */}\n      <div className=\"game-footer\">\n        {locked ? (\n          <span className=\"lock-badge\">🔒</span>\n        ) : (\n          <span className=\"play-text\">PLAY</span>\n        )}\n      </div>\n    </Link>\n  );\n}\n\n// Game card icons — inline SVGs for each game type\nfunction GameCardIcon({ visual }: { visual: GameCardProps[\"visual\"] }) {\n  switch (visual) {\n    case \"coinflip\":\n      return <CoinflipIcon />;\n    case \"lotr\":\n      return <LordOfRngsIcon />;\n    case \"close-call\":\n      return <CloseCallIcon />;\n    case \"crash\":\n      return <CrashIcon />;\n    case \"trades\":\n      return <TradesIcon />;\n    default:\n      return null;\n  }\n}\n\n// Coinflip: Two shields (green + red) with crossed medieval swords behind\nfunction CoinflipIcon() {\n  return (\n    <div className=\"coinflip-icon\">\n      <svg className=\"coinflip-icon__swords\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        {/* Left sword (tip top-right) */}\n        <g transform=\"rotate(45 50 50)\">\n          <polygon points=\"48,8 50,2 52,8 52,52 48,52\" fill=\"url(#blade)\" stroke=\"#888\" strokeWidth=\"0.5\" />\n          <rect x=\"42\" y=\"52\" width=\"16\" height=\"4\" rx=\"1\" fill=\"url(#guard)\" />\n          <rect x=\"47\" y=\"56\" width=\"6\" height=\"14\" rx=\"1\" fill=\"#5a3a1a\" />\n          <rect x=\"48\" y=\"58\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n          <rect x=\"48\" y=\"62\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n          <rect x=\"48\" y=\"66\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n          <circle cx=\"50\" cy=\"72\" r=\"3.5\" fill=\"url(#guard)\" />\n        </g>\n        {/* Right sword (tip top-left) */}\n        <g transform=\"rotate(-45 50 50)\">\n          <polygon points=\"48,8 50,2 52,8 52,52 48,52\" fill=\"url(#blade)\" stroke=\"#888\" strokeWidth=\"0.5\" />\n          <rect x=\"42\" y=\"52\" width=\"16\" height=\"4\" rx=\"1\" fill=\"url(#guard)\" />\n          <rect x=\"47\" y=\"56\" width=\"6\" height=\"14\" rx=\"1\" fill=\"#5a3a1a\" />\n          <rect x=\"48\" y=\"58\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n          <rect x=\"48\" y=\"62\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n          <rect x=\"48\" y=\"66\" width=\"4\" height=\"2\" rx=\"0.5\" fill=\"#7a5a30\" />\n          <circle cx=\"50\" cy=\"72\" r=\"3.5\" fill=\"url(#guard)\" />\n        </g>\n        <defs>\n          <linearGradient id=\"blade\" x1=\"48\" y1=\"2\" x2=\"52\" y2=\"2\" gradientUnits=\"userSpaceOnUse\">\n            <stop offset=\"0%\" stopColor=\"#b8b8b8\" />\n            <stop offset=\"30%\" stopColor=\"#e8e8e8\" />\n            <stop offset=\"70%\" stopColor=\"#d0d0d0\" />\n            <stop offset=\"100%\" stopColor=\"#a0a0a0\" />\n          </linearGradient>\n          <linearGradient id=\"guard\" x1=\"42\" y1=\"52\" x2=\"42\" y2=\"56\" gradientUnits=\"userSpaceOnUse\">\n            <stop offset=\"0%\" stopColor=\"#d4a840\" />\n            <stop offset=\"100%\" stopColor=\"#8a6020\" />\n          </linearGradient>\n        </defs>\n      </svg>\n      <img src=\"/sprites/red-shield.png\" alt=\"\" className=\"coinflip-icon__shield coinflip-icon__shield--red\" />\n      <img src=\"/sprites/green-shield.png\" alt=\"\" className=\"coinflip-icon__shield coinflip-icon__shield--green\" />\n    </div>\n  );\n}\n\n// Lord of RNGs: Wide horizontal row of player silhouettes, center one is the winner\nfunction LordOfRngsIcon() {\n  return (\n    <svg viewBox=\"0 0 100 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" className=\"game-card-svg\">\n      {/* Container border */}\n      <rect x=\"2\" y=\"12\" width=\"96\" height=\"32\" rx=\"2\" fill=\"none\" stroke=\"#5a4830\" strokeWidth=\"2\" />\n      <rect x=\"2\" y=\"12\" width=\"96\" height=\"32\" rx=\"2\" fill=\"#2a1c10\" opacity=\"0.3\" />\n      {/* Player 1 (far left, dimmed) */}\n      <circle cx=\"14\" cy=\"28\" r=\"7\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"1.2\" opacity=\"0.35\" />\n      <circle cx=\"14\" cy=\"26\" r=\"2.5\" fill=\"#f0b820\" opacity=\"0.35\" />\n      <path d=\"M 9.5 34 Q 14 31 18.5 34\" stroke=\"#f0b820\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.35\" />\n      {/* Player 2 (left, dimmed) */}\n      <circle cx=\"32\" cy=\"28\" r=\"7\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"1.2\" opacity=\"0.4\" />\n      <circle cx=\"32\" cy=\"26\" r=\"2.5\" fill=\"#f0b820\" opacity=\"0.4\" />\n      <path d=\"M 27.5 34 Q 32 31 36.5 34\" stroke=\"#f0b820\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.4\" />\n      {/* Player 3 (CENTER — WINNER, highlighted) */}\n      <circle cx=\"50\" cy=\"28\" r=\"8\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"2\" opacity=\"1\" />\n      <circle cx=\"50\" cy=\"28\" r=\"8\" fill=\"rgba(240,184,32,0.08)\" />\n      <circle cx=\"50\" cy=\"26\" r=\"3\" fill=\"#f0b820\" opacity=\"0.9\" />\n      <path d=\"M 44.5 35 Q 50 31.5 55.5 35\" stroke=\"#f0b820\" strokeWidth=\"1.3\" fill=\"none\" opacity=\"0.9\" />\n      {/* Selection arrow pointing down toward winner */}\n      <polygon points=\"50,12 46,6 54,6\" fill=\"#f0b820\" stroke=\"#8a6010\" strokeWidth=\"0.6\" />\n      {/* Crown on winner */}\n      <polygon points=\"45,3 46.5,0 48,2.5 50,-1 52,2.5 53.5,0 55,3\" fill=\"#f0b820\" stroke=\"#8a6010\" strokeWidth=\"0.6\" />\n      <circle cx=\"50\" cy=\"-1\" r=\"0.8\" fill=\"#e070a0\" />\n      {/* Player 4 (right, dimmed) */}\n      <circle cx=\"68\" cy=\"28\" r=\"7\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"1.2\" opacity=\"0.4\" />\n      <circle cx=\"68\" cy=\"26\" r=\"2.5\" fill=\"#f0b820\" opacity=\"0.4\" />\n      <path d=\"M 63.5 34 Q 68 31 72.5 34\" stroke=\"#f0b820\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.4\" />\n      {/* Player 5 (far right, dimmed) */}\n      <circle cx=\"86\" cy=\"28\" r=\"7\" fill=\"none\" stroke=\"#f0b820\" strokeWidth=\"1.2\" opacity=\"0.3\" />\n      <circle cx=\"86\" cy=\"26\" r=\"2.5\" fill=\"#f0b820\" opacity=\"0.3\" />\n      <path d=\"M 81.5 34 Q 86 31 90.5 34\" stroke=\"#f0b820\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.3\" />\n    </svg>\n  );\n}\n\n// Close Call: Balance scale tilted toward green, bigger candles\nfunction CloseCallIcon() {\n  return (\n    <svg viewBox=\"0 0 64 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" className=\"game-card-svg\">\n      {/* Center pillar */}\n      <rect x=\"30\" y=\"10\" width=\"4\" height=\"32\" fill=\"#5a4830\" />\n      <rect x=\"27\" y=\"40\" width=\"10\" height=\"4\" rx=\"1\" fill=\"#6a5838\" />\n      {/* Fulcrum triangle */}\n      <polygon points=\"32,7 27,13 37,13\" fill=\"#8a7040\" stroke=\"#5a4830\" strokeWidth=\"0.8\" />\n      {/* Balance beam — tilted: left side (green) is heavier, dips down */}\n      <line x1=\"4\" y1=\"18\" x2=\"60\" y2=\"14\" stroke=\"#8a7040\" strokeWidth=\"2.5\" strokeLinecap=\"round\" />\n      {/* Left pan strings (lower — heavier side) */}\n      <line x1=\"4\" y1=\"18\" x2=\"9\" y2=\"28\" stroke=\"#6a5838\" strokeWidth=\"1\" />\n      <line x1=\"22\" y1=\"16.7\" x2=\"19\" y2=\"28\" stroke=\"#6a5838\" strokeWidth=\"1\" />\n      {/* Left pan */}\n      <ellipse cx=\"14\" cy=\"29\" rx=\"10\" ry=\"2.5\" fill=\"#5a4830\" stroke=\"#6a5838\" strokeWidth=\"0.8\" />\n      {/* BIG green candle on left pan */}\n      <rect x=\"12.5\" y=\"32\" width=\"1.5\" height=\"2\" fill=\"#45b058\" opacity=\"0.5\" />\n      <rect x=\"10\" y=\"14\" width=\"7\" height=\"18\" rx=\"0.5\" fill=\"#45b058\" />\n      <rect x=\"13\" y=\"10\" width=\"1.5\" height=\"4\" fill=\"#45b058\" opacity=\"0.7\" />\n      {/* Green candle inner highlight */}\n      <rect x=\"11\" y=\"15\" width=\"2\" height=\"16\" fill=\"#5cd070\" opacity=\"0.3\" />\n      {/* Right pan strings (higher — lighter side) */}\n      <line x1=\"42\" y1=\"15\" x2=\"46\" y2=\"24\" stroke=\"#6a5838\" strokeWidth=\"1\" />\n      <line x1=\"60\" y1=\"14\" x2=\"56\" y2=\"24\" stroke=\"#6a5838\" strokeWidth=\"1\" />\n      {/* Right pan */}\n      <ellipse cx=\"51\" cy=\"25\" rx=\"10\" ry=\"2.5\" fill=\"#5a4830\" stroke=\"#6a5838\" strokeWidth=\"0.8\" />\n      {/* Smaller red candle on right pan */}\n      <rect x=\"49\" y=\"14\" width=\"1.5\" height=\"2\" fill=\"#cc4444\" opacity=\"0.5\" />\n      <rect x=\"47\" y=\"16\" width=\"6\" height=\"12\" rx=\"0.5\" fill=\"#cc4444\" />\n      <rect x=\"49.5\" y=\"28\" width=\"1.5\" height=\"3\" fill=\"#cc4444\" opacity=\"0.5\" />\n      {/* Red candle inner highlight */}\n      <rect x=\"48\" y=\"17\" width=\"2\" height=\"10\" fill=\"#e05858\" opacity=\"0.3\" />\n      {/* Scale indicator dot */}\n      <circle cx=\"32\" cy=\"7\" r=\"2\" fill=\"#f0b820\" />\n    </svg>\n  );\n}\n\n// Crypto Crash: Green ascending candlesticks then one massive red crash candle\nfunction CrashIcon() {\n  return (\n    <svg viewBox=\"0 0 64 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" className=\"game-card-svg\">\n      {/* Baseline */}\n      <line x1=\"2\" y1=\"46\" x2=\"62\" y2=\"46\" stroke=\"#3a3020\" strokeWidth=\"0.5\" />\n      {/* Green candle 1 — opens 40, closes 36 (body), wick 34-42 */}\n      <line x1=\"7\" y1=\"34\" x2=\"7\" y2=\"42\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n      <rect x=\"5\" y=\"36\" width=\"4\" height=\"6\" rx=\"0.3\" fill=\"#45b058\" />\n      {/* Green candle 2 — opens 34, closes 28 */}\n      <line x1=\"14\" y1=\"26\" x2=\"14\" y2=\"36\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n      <rect x=\"12\" y=\"28\" width=\"4\" height=\"8\" rx=\"0.3\" fill=\"#45b058\" />\n      {/* Green candle 3 — opens 28, closes 20 */}\n      <line x1=\"21\" y1=\"18\" x2=\"21\" y2=\"30\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n      <rect x=\"19\" y=\"20\" width=\"4\" height=\"10\" rx=\"0.3\" fill=\"#45b058\" />\n      {/* Green candle 4 — opens 20, closes 10 */}\n      <line x1=\"28\" y1=\"8\" x2=\"28\" y2=\"22\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n      <rect x=\"26\" y=\"10\" width=\"4\" height=\"12\" rx=\"0.3\" fill=\"#45b058\" />\n      {/* Green candle 5 (peak) — opens 10, closes 4 */}\n      <line x1=\"35\" y1=\"2\" x2=\"35\" y2=\"12\" stroke=\"#45b058\" strokeWidth=\"0.8\" />\n      <rect x=\"33\" y=\"4\" width=\"4\" height=\"8\" rx=\"0.3\" fill=\"#45b058\" />\n      {/* BIG RED crash candle — opens at top (4), crashes all the way to bottom (45) */}\n      <line x1=\"46\" y1=\"2\" x2=\"46\" y2=\"46\" stroke=\"#cc4444\" strokeWidth=\"1\" />\n      <rect x=\"42\" y=\"3\" width=\"8\" height=\"42\" rx=\"0.3\" fill=\"#cc4444\" />\n      {/* Red candle inner shade */}\n      <rect x=\"43\" y=\"4\" width=\"3\" height=\"40\" fill=\"#e05858\" opacity=\"0.25\" />\n      {/* Crash lightning bolt accent */}\n      <path d=\"M 55 8 L 52 20 L 56 20 L 52 34\" stroke=\"#ff6666\" strokeWidth=\"1\" fill=\"none\" opacity=\"0.5\" />\n    </svg>\n  );\n}\n\n// Game of Trades: Chart line with podium (1st/2nd/3rd)\nfunction TradesIcon() {\n  return (\n    <svg viewBox=\"0 0 64 52\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" className=\"game-card-svg\">\n      {/* Chart area */}\n      {/* Axes */}\n      <line x1=\"4\" y1=\"2\" x2=\"4\" y2=\"28\" stroke=\"#5a4830\" strokeWidth=\"1\" />\n      <line x1=\"4\" y1=\"28\" x2=\"60\" y2=\"28\" stroke=\"#5a4830\" strokeWidth=\"1\" />\n      {/* Grid lines */}\n      <line x1=\"4\" y1=\"10\" x2=\"60\" y2=\"10\" stroke=\"#3a2810\" strokeWidth=\"0.3\" opacity=\"0.5\" />\n      <line x1=\"4\" y1=\"18\" x2=\"60\" y2=\"18\" stroke=\"#3a2810\" strokeWidth=\"0.3\" opacity=\"0.5\" />\n      {/* Chart line (zigzag trading) */}\n      <polyline\n        points=\"6,22 12,18 18,20 24,12 30,16 36,8 42,14 48,6 54,10 58,8\"\n        fill=\"none\"\n        stroke=\"#f0b820\"\n        strokeWidth=\"1.5\"\n        strokeLinecap=\"round\"\n        strokeLinejoin=\"round\"\n      />\n      {/* Glow under the chart line */}\n      <polygon\n        points=\"6,22 12,18 18,20 24,12 30,16 36,8 42,14 48,6 54,10 58,8 58,28 6,28\"\n        fill=\"url(#tradeGrad)\"\n        opacity=\"0.2\"\n      />\n      <defs>\n        <linearGradient id=\"tradeGrad\" x1=\"32\" y1=\"0\" x2=\"32\" y2=\"28\" gradientUnits=\"userSpaceOnUse\">\n          <stop offset=\"0%\" stopColor=\"#f0b820\" />\n          <stop offset=\"100%\" stopColor=\"#f0b820\" stopOpacity=\"0\" />\n        </linearGradient>\n      </defs>\n\n      {/* Podium */}\n      {/* 2nd place (left, shorter) */}\n      <rect x=\"12\" y=\"40\" width=\"12\" height=\"12\" fill=\"#a8b8c8\" stroke=\"#607080\" strokeWidth=\"0.8\" />\n      <text x=\"18\" y=\"48\" textAnchor=\"middle\" fill=\"#2a1c08\" fontSize=\"6\" fontWeight=\"bold\" fontFamily=\"monospace\">2</text>\n      {/* 1st place (center, tallest) */}\n      <rect x=\"26\" y=\"34\" width=\"12\" height=\"18\" fill=\"#f0b820\" stroke=\"#8a6010\" strokeWidth=\"0.8\" />\n      <text x=\"32\" y=\"45\" textAnchor=\"middle\" fill=\"#2a1c08\" fontSize=\"7\" fontWeight=\"bold\" fontFamily=\"monospace\">1</text>\n      {/* Crown on 1st */}\n      <polygon points=\"29,33 30,30 32,32 34,30 35,33\" fill=\"#f0b820\" stroke=\"#8a6010\" strokeWidth=\"0.5\" />\n      {/* 3rd place (right, shortest) */}\n      <rect x=\"40\" y=\"44\" width=\"12\" height=\"8\" fill=\"#cd7f32\" stroke=\"#8a5520\" strokeWidth=\"0.8\" />\n      <text x=\"46\" y=\"50\" textAnchor=\"middle\" fill=\"#2a1c08\" fontSize=\"5\" fontWeight=\"bold\" fontFamily=\"monospace\">3</text>\n    </svg>\n  );\n}\n\n// Fairness verification page\nfunction FairnessPage() {\n  const { connection } = useConnection();\n  const [activeTab, setActiveTab] = useState<'how' | 'verify' | 'seeds' | 'history'>('how');\n  const [serverSeed, setServerSeed] = useState('');\n  const [publicSeed, setPublicSeed] = useState('');\n  // Coinflip VRF verification state\n  const [coinflipTxSig, setCoinflipTxSig] = useState('');\n  const [coinflipResult, setCoinflipResult] = useState<CoinflipVerificationResult | null>(null);\n  const [coinflipVerifying, setCoinflipVerifying] = useState(false);\n  const [coinflipError, setCoinflipError] = useState<string | null>(null);\n  const [roundId, setRoundId] = useState('');\n  const [gameId, setGameId] = useState('crash');\n  const [commitmentHash, setCommitmentHash] = useState('');\n  const [verificationResult, setVerificationResult] = useState<{\n    valid: boolean;\n    message: string;\n    crashPoint?: string;\n  } | null>(null);\n\n  // SHA-256 hash function (using Web Crypto API)\n  const sha256 = async (message: string): Promise<string> => {\n    const encoder = new TextEncoder();\n    const data = encoder.encode(message);\n    const hashBuffer = await crypto.subtle.digest('SHA-256', data);\n    const hashArray = Array.from(new Uint8Array(hashBuffer));\n    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n  };\n\n  // HMAC-SHA256 function\n  const hmacSha256 = async (key: string, message: string): Promise<string> => {\n    const encoder = new TextEncoder();\n    const keyData = encoder.encode(key);\n    const messageData = encoder.encode(message);\n\n    const cryptoKey = await crypto.subtle.importKey(\n      'raw',\n      keyData,\n      { name: 'HMAC', hash: 'SHA-256' },\n      false,\n      ['sign']\n    );\n\n    const signature = await crypto.subtle.sign('HMAC', cryptoKey, messageData);\n    const hashArray = Array.from(new Uint8Array(signature));\n    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n  };\n\n  // Convert hash to crash point (standard algorithm)\n  const hashToCrashPoint = (hash: string): number => {\n    // Take first 13 hex characters (52 bits)\n    const h = parseInt(hash.substring(0, 13), 16);\n    // House edge: 1% (1 in 100 instant crash)\n    const e = Math.pow(2, 52);\n    const result = Math.floor((100 * e - h) / (e - h)) / 100;\n    return Math.max(1.00, result);\n  };\n\n  // Verify commitment\n  const verifyCommitment = async () => {\n    if (!serverSeed) {\n      setVerificationResult({\n        valid: false,\n        message: 'Please enter a server seed'\n      });\n      return;\n    }\n\n    const computedHash = await sha256(serverSeed);\n\n    if (commitmentHash) {\n      const isValid = computedHash.toLowerCase() === commitmentHash.toLowerCase();\n      setVerificationResult({\n        valid: isValid,\n        message: isValid\n          ? 'Commitment verified! The server seed matches the published hash.'\n          : 'Commitment FAILED! The server seed does not match the published hash.'\n      });\n    } else {\n      setVerificationResult({\n        valid: true,\n        message: `Computed commitment hash: ${computedHash}`\n      });\n    }\n  };\n\n  // Calculate crash point\n  const calculateCrashPoint = async () => {\n    if (!serverSeed || !publicSeed) {\n      setVerificationResult({\n        valid: false,\n        message: 'Please enter both server seed and public seed'\n      });\n      return;\n    }\n\n    // Combine seeds with round info\n    const message = `${publicSeed}:${roundId}:${gameId}`;\n    const hash = await hmacSha256(serverSeed, message);\n    const crashPoint = hashToCrashPoint(hash);\n\n    setVerificationResult({\n      valid: true,\n      message: `Round outcome verified successfully.`,\n      crashPoint: crashPoint.toFixed(2)\n    });\n  };\n\n  // Mock recent rounds data\n  const recentRounds = [\n    { id: '847291', game: 'Crash', result: '2.47x', commitment: 'a3f2...8e1c', verified: true },\n    { id: '847290', game: 'Crash', result: '1.23x', commitment: 'b7e1...2f9a', verified: true },\n    { id: '847289', game: 'Lord of the RNGs', result: 'Player_42', commitment: 'c9d3...7b4e', verified: true },\n    { id: '847288', game: 'Close Call', result: 'GREEN', commitment: 'd2a8...1c5f', verified: true },\n    { id: '847287', game: 'Coinflip', result: 'HEADS', commitment: 'e5f6...9d2b', verified: true },\n  ];\n\n  // Mock active seeds\n  const activeSeeds = [\n    { game: 'Crash', tier: 'All', commitment: 'f1e2d3c4b5a6978...', status: 'Active', expiresIn: '2:34' },\n    { game: 'Lord of the RNGs', tier: 'Gold', commitment: '9a8b7c6d5e4f321...', status: 'Betting', expiresIn: '0:45' },\n    { game: 'Close Call', tier: 'All', commitment: '1a2b3c4d5e6f789...', status: 'Active', expiresIn: '0:12' },\n  ];\n\n  return (\n    <div className=\"fairness-page\">\n      <div className=\"fairness-header\">\n        <h2>Provably Fair Verification</h2>\n        <p className=\"fairness-subtitle\">Every outcome is cryptographically verifiable</p>\n      </div>\n\n      {/* Tab Navigation */}\n      <div className=\"fairness-tabs\">\n        <button\n          className={`fairness-tab ${activeTab === 'how' ? 'active' : ''}`}\n          onClick={() => setActiveTab('how')}\n        >\n          How It Works\n        </button>\n        <button\n          className={`fairness-tab ${activeTab === 'verify' ? 'active' : ''}`}\n          onClick={() => setActiveTab('verify')}\n        >\n          Verify Round\n        </button>\n        <button\n          className={`fairness-tab ${activeTab === 'seeds' ? 'active' : ''}`}\n          onClick={() => setActiveTab('seeds')}\n        >\n          Active Seeds\n        </button>\n        <button\n          className={`fairness-tab ${activeTab === 'history' ? 'active' : ''}`}\n          onClick={() => setActiveTab('history')}\n        >\n          History\n        </button>\n      </div>\n\n      {/* Tab Content */}\n      <div className=\"fairness-content\">\n        {activeTab === 'how' && (\n          <div className=\"fairness-how\">\n            <div className=\"fairness-section\">\n              <h3>Why Provably Fair?</h3>\n              <p>\n                Traditional online games require you to trust that the house isn't cheating.\n                Provably fair systems eliminate this trust requirement by using cryptographic\n                commitments that can be independently verified by anyone.\n              </p>\n            </div>\n\n            <div className=\"fairness-section\">\n              <h3>Pattern 1: Commit-Reveal + Blockhash</h3>\n              <p className=\"pattern-label\">Used by: Crash, Close Call, Game of Trades</p>\n              <div className=\"fairness-steps\">\n                <div className=\"step\">\n                  <span className=\"step-num\">1</span>\n                  <div className=\"step-content\">\n                    <strong>Before Betting Opens</strong>\n                    <p>Server generates a random seed and publishes its SHA-256 hash (commitment)</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">2</span>\n                  <div className=\"step-content\">\n                    <strong>During Betting</strong>\n                    <p>Players place bets. The server cannot change its seed (hash is already public)</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">3</span>\n                  <div className=\"step-content\">\n                    <strong>At Round Start</strong>\n                    <p>A future Solana blockhash becomes the public seed (unpredictable by server)</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">4</span>\n                  <div className=\"step-content\">\n                    <strong>After Round</strong>\n                    <p>Server reveals its seed. Anyone can verify: SHA-256(seed) = commitment</p>\n                  </div>\n                </div>\n              </div>\n              <div className=\"formula-box\">\n                <code>outcome = HMAC-SHA256(serverSeed, publicSeed || roundId || gameId)</code>\n              </div>\n            </div>\n\n            <div className=\"fairness-section\">\n              <h3>Pattern 2: On-Chain VRF</h3>\n              <p className=\"pattern-label\">Used by: Lord of the RNGs, Coinflip, Tug of Earn</p>\n              <div className=\"fairness-steps\">\n                <div className=\"step\">\n                  <span className=\"step-num\">1</span>\n                  <div className=\"step-content\">\n                    <strong>Round Enters Resolution</strong>\n                    <p>The on-chain program requests randomness from a VRF provider</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">2</span>\n                  <div className=\"step-content\">\n                    <strong>VRF Fulfillment</strong>\n                    <p>Provider generates verifiable random bytes with a cryptographic proof</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">3</span>\n                  <div className=\"step-content\">\n                    <strong>On-Chain Verification</strong>\n                    <p>Program verifies the proof and uses the result for winner selection</p>\n                  </div>\n                </div>\n                <div className=\"step\">\n                  <span className=\"step-num\">4</span>\n                  <div className=\"step-content\">\n                    <strong>Permanent Record</strong>\n                    <p>Result and proof stored on-chain forever - viewable on Solana explorer</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"fairness-section\">\n              <h3>What Can't Be Manipulated</h3>\n              <div className=\"guarantees\">\n                <div className=\"guarantee\">\n                  <span className=\"check-icon\">✓</span>\n                  <span>Server cannot predict the blockhash used as public seed</span>\n                </div>\n                <div className=\"guarantee\">\n                  <span className=\"check-icon\">✓</span>\n                  <span>Server cannot change its seed after publishing the commitment</span>\n                </div>\n                <div className=\"guarantee\">\n                  <span className=\"check-icon\">✓</span>\n                  <span>VRF proofs are mathematically verifiable - forgery is impossible</span>\n                </div>\n                <div className=\"guarantee\">\n                  <span className=\"check-icon\">✓</span>\n                  <span>All settlement happens on-chain with public transaction history</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {activeTab === 'verify' && (\n          <div className=\"fairness-verify\">\n            <div className=\"verify-section\">\n              <h3>Verify a Round</h3>\n              <p>Enter the seeds from a completed round to independently verify the outcome.</p>\n\n              <div className=\"verify-form\">\n                <div className=\"form-group\">\n                  <label>Game</label>\n                  <select\n                    value={gameId}\n                    onChange={(e) => setGameId(e.target.value)}\n                    className=\"verify-select\"\n                  >\n                    <option value=\"crash\">Crypto Crash Simulator</option>\n                    <option value=\"close-call\">Close Call</option>\n                    <option value=\"lord-of-rngs\">Lord of the RNGs</option>\n                    <option value=\"coinflip\">Coinflip</option>\n                    <option value=\"game-of-trades\">Game of Trades</option>\n                  </select>\n                </div>\n\n                <div className=\"form-group\">\n                  <label>Server Seed (revealed after round)</label>\n                  <input\n                    type=\"text\"\n                    value={serverSeed}\n                    onChange={(e) => setServerSeed(e.target.value)}\n                    placeholder=\"e.g., a1b2c3d4e5f6...\"\n                    className=\"verify-input\"\n                  />\n                </div>\n\n                <div className=\"form-group\">\n                  <label>Public Seed (Solana blockhash)</label>\n                  <input\n                    type=\"text\"\n                    value={publicSeed}\n                    onChange={(e) => setPublicSeed(e.target.value)}\n                    placeholder=\"e.g., 5eykt4UsFv8P8NJdTREpY1vzqKqZKvdpKuc147dw2N9d\"\n                    className=\"verify-input\"\n                  />\n                </div>\n\n                <div className=\"form-row\">\n                  <div className=\"form-group\">\n                    <label>Round ID</label>\n                    <input\n                      type=\"text\"\n                      value={roundId}\n                      onChange={(e) => setRoundId(e.target.value)}\n                      placeholder=\"e.g., 847291\"\n                      className=\"verify-input\"\n                    />\n                  </div>\n\n                  <div className=\"form-group\">\n                    <label>Commitment Hash (optional)</label>\n                    <input\n                      type=\"text\"\n                      value={commitmentHash}\n                      onChange={(e) => setCommitmentHash(e.target.value)}\n                      placeholder=\"SHA-256 hash to verify against\"\n                      className=\"verify-input\"\n                    />\n                  </div>\n                </div>\n\n                <div className=\"verify-buttons\">\n                  <button onClick={verifyCommitment} className=\"verify-action-btn\">\n                    Verify Commitment\n                  </button>\n                  <button onClick={calculateCrashPoint} className=\"verify-action-btn primary\">\n                    Calculate Outcome\n                  </button>\n                </div>\n\n                {verificationResult && (\n                  <div className={`verification-result ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n                    <div className=\"result-status\">\n                      <span className={`status-icon ${verificationResult.valid ? 'valid' : 'invalid'}`}>\n                        {verificationResult.valid ? '✓' : '✗'}\n                      </span>\n                      <span className=\"status-text\">{verificationResult.message}</span>\n                    </div>\n                    {verificationResult.crashPoint && (\n                      <div className=\"result-value\">\n                        <span className=\"result-label\">Crash Point:</span>\n                        <span className=\"crash-point\">{verificationResult.crashPoint}x</span>\n                      </div>\n                    )}\n                  </div>\n                )}\n              </div>\n            </div>\n\n            <div className=\"verify-section\">\n              <h3>Quick Lookup</h3>\n              <p>Enter a round ID to fetch its verification data automatically.</p>\n              <div className=\"quick-lookup\">\n                <input\n                  type=\"text\"\n                  placeholder=\"Enter Round ID...\"\n                  className=\"verify-input\"\n                />\n                <button className=\"lookup-btn\">Lookup</button>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {activeTab === 'seeds' && (\n          <div className=\"fairness-seeds\">\n            <h3>Active Commitments</h3>\n            <p>These are the current seed commitments for ongoing rounds. The actual seeds will be revealed after each round completes.</p>\n\n            <div className=\"seeds-table\">\n              <div className=\"seeds-header\">\n                <span>Game</span>\n                <span>Tier</span>\n                <span>Commitment Hash</span>\n                <span>Status</span>\n                <span>Time</span>\n              </div>\n              {activeSeeds.map((seed, i) => (\n                <div className=\"seed-row\" key={i}>\n                  <span className=\"seed-game\">{seed.game}</span>\n                  <span className=\"seed-tier\">{seed.tier}</span>\n                  <span className=\"seed-hash\">{seed.commitment}</span>\n                  <span className={`seed-status ${seed.status.toLowerCase()}`}>{seed.status}</span>\n                  <span className=\"seed-time\">{seed.expiresIn}</span>\n                </div>\n              ))}\n            </div>\n\n            <div className=\"seeds-info\">\n              <h4>Understanding Commitments</h4>\n              <p>\n                A commitment is the SHA-256 hash of the server's secret seed. It's published before\n                betting opens, ensuring the server cannot change its seed after seeing player bets.\n                After the round, you can verify that SHA-256(revealed_seed) equals the commitment.\n              </p>\n            </div>\n          </div>\n        )}\n\n        {activeTab === 'history' && (\n          <div className=\"fairness-history\">\n            <h3>Recent Verified Rounds</h3>\n            <p>All completed rounds with their verification status.</p>\n\n            <div className=\"history-table\">\n              <div className=\"history-header\">\n                <span>Round</span>\n                <span>Game</span>\n                <span>Result</span>\n                <span>Commitment</span>\n                <span>Status</span>\n                <span>Action</span>\n              </div>\n              {recentRounds.map((round) => (\n                <div className=\"history-row\" key={round.id}>\n                  <span className=\"round-id\">#{round.id}</span>\n                  <span className=\"round-game\">{round.game}</span>\n                  <span className=\"round-result\">{round.result}</span>\n                  <span className=\"round-commitment\">{round.commitment}</span>\n                  <span className={`round-status ${round.verified ? 'verified' : 'pending'}`}>\n                    {round.verified ? 'Verified' : 'Pending'}\n                  </span>\n                  <button className=\"round-verify-btn\">Verify</button>\n                </div>\n              ))}\n            </div>\n\n            <div className=\"history-pagination\">\n              <button className=\"page-btn\" disabled>Previous</button>\n              <span className=\"page-info\">Page 1 of 1</span>\n              <button className=\"page-btn\" disabled>Next</button>\n            </div>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n\nfunction NotFoundPage() {\n  return (\n    <div className=\"not-found\">\n      <div className=\"error-code\">\n        <span className=\"digit\">4</span>\n        <span className=\"digit zero\">0</span>\n        <span className=\"digit\">4</span>\n      </div>\n      <h2>Game Over</h2>\n      <p>The level you're looking for doesn't exist.</p>\n      <p className=\"hint\">Maybe try a different warp pipe?</p>\n      <Link to=\"/\" className=\"continue-btn\">\n        Continue?\n      </Link>\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":995,"oldLines":6,"newStart":995,"newLines":25,"lines":["     });","   };"," ","+  // Coinflip VRF verification","+  const verifyCoinflipTx = async () => {","+    if (!coinflipTxSig.trim()) {","+      setCoinflipError('Please enter a claim transaction signature');","+      return;","+    }","+    setCoinflipVerifying(true);","+    setCoinflipError(null);","+    setCoinflipResult(null);","+    try {","+      const result = await verifyCoinflipMatch(connection, coinflipTxSig.trim());","+      setCoinflipResult(result);","+    } catch (err) {","+      setCoinflipError(err instanceof Error ? err.message : 'Verification failed');","+    } finally {","+      setCoinflipVerifying(false);","+    }","+  };","+","   // Mock recent rounds data","   const recentRounds = [","     { id: '847291', game: 'Crash', result: '2.47x', commitment: 'a3f2...8e1c', verified: true },"]}],"userModified":false,"replaceAll":false}}
