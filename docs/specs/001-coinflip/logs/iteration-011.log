 Record<Side, number> = {\n    65→  none: 0,\n    66→  green: 1,\n    67→  red: 2,\n    68→};\n    69→\n    70→export interface PlayerEntry {\n    71→  pool: PublicKey;\n    72→  player: PublicKey;\n    73→  amount: number;\n    74→  enteredAt: Date;\n    75→  sequence: number;\n    76→  side: Side;\n    77→  cashoutMultiplier: number | null;\n    78→  cashedOutAt: Date | null;\n    79→  claimed: boolean;\n    80→  payout: number;\n    81→  won: boolean;\n    82→  xpParticipation: number;\n    83→  xpWin: number;\n    84→}\n    85→\n    86→// ============ Game Config ============\n    87→\n    88→export interface GameConfig {\n    89→  gameId: string;\n    90→  paused: boolean;\n    91→  minBet: number;\n    92→  maxBet: number;\n    93→  feeBps: number;\n    94→  enabledTiers: Tier[];\n    95→  minPlayers: number;\n    96→  maxPlayers: number;\n    97→  roundDurationSecs: number;\n    98→  bettingWindowSecs: number;\n    99→  vrfQueue: PublicKey;\n   100→  authority: PublicKey;\n   101→  treasury: PublicKey;\n   102→  currentRound: number;\n   103→  totalRounds: number;\n   104→  totalVolume: number;\n   105→  totalFees: number;\n   106→  version: number;\n   107→  createdAt: Date;\n   108→  updatedAt: Date;\n   109→}\n   110→\n   111→// ============ Coinflip ============\n   112→\n   113→export type CoinSide = \"heads\" | \"tails\";\n   114→export type CoinflipPhase = \"created\" | \"ready\" | \"flipping\" | \"complete\";\n   115→\n   116→export const COIN_SIDE_VALUES: Record<CoinSide, number> = {\n   117→  heads: 0,\n   118→  tails: 1,\n   119→};\n   120→\n   121→export const COINFLIP_PHASE_VALUES: Record<CoinflipPhase, number> = {\n   122→  created: 0,\n   123→  ready: 1,\n   124→  flipping: 2,\n   125→  complete: 3,\n   126→};\n   127→\n   128→export interface CoinflipState {\n   129→  pool: PublicKey;\n   130→  player1: PublicKey;\n   131→  player2: PublicKey | null;\n   132→  player1Side: CoinSide;\n   133→  result: CoinSide | null;\n   134→  phase: CoinflipPhase;\n   135→  createdAt: Date;\n   136→  joinedAt: Date | null;\n   137→  flippedAt: Date | null;\n   138→  joinTimeoutSecs: number;\n   139→}\n   140→\n   141→export interface CoinflipMatch {\n   142→  pool: Pool;\n   143→  state: CoinflipState;\n   144→  player1Entry: PlayerEntry;\n   145→  player2Entry: PlayerEntry | null;\n   146→}\n   147→\n   148→// ============ Legacy Types (for backwards compatibility) ============\n   149→\n   150→/** @deprecated Use Pool instead */\n   151→export interface PoolState {\n   152→  roundId: string;\n   153→  gameId: string;\n   154→  tier: Tier;\n   155→  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n   156→  entries: LegacyPlayerEntry[];\n   157→  totalPool: number;\n   158→  createdAt: number;\n   159→  settledAt?: number;\n   160→  outcome?: unknown;\n   161→}\n   162→\n   163→/** @deprecated Use PlayerEntry instead */\n   164→export interface LegacyPlayerEntry {\n   165→  playerId: string;\n   166→  publicKey: string;\n   167→  tier: Tier;\n   168→  amount: number;\n   169→  timestamp: number;\n   170→  side?: \"green\" | \"red\";\n   171→  cashoutMultiplier?: number;\n   172→}\n   173→\n   174→// ============ Game IDs ============\n   175→\n   176→export const GAME_IDS = {\n   177→  COINFLIP: \"coinflip\",\n   178→  LORD_OF_RNGS: \"lord-of-rngs\",\n   179→  CRASH: \"crash\",\n   180→  CLOSE_CALL: \"close-call\",\n   181→  SLOTS: \"slots\",\n   182→  GAME_OF_TRADES: \"game-of-trades\",\n   183→  TUG_OF_EARN: \"tug-of-earn\",\n   184→  CHART_COURSE: \"chart-course\",\n   185→} as const;\n   186→\n   187→export type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n   188→\n   189→// ============ XP System ============\n   190→\n   191→export const XP_BY_TIER: Record<Tier, { participation: number; win: number }> = {\n   192→  iron: { participation: 1, win: 3 },\n   193→  bronze: { participation: 1, win: 3 },\n   194→  silver: { participation: 10, win: 30 },\n   195→  gold: { participation: 25, win: 75 },\n   196→  platinum: { participation: 50, win: 150 },\n   197→  diamond: { participation: 100, win: 300 },\n   198→};\n   199→\n   200→// ============ Fee Constants ============\n   201→\n   202→export const FEE_CONSTANTS = {\n   203→  TOTAL_BPS: 300, // 3%\n   204→  PLATFORM_REVENUE_BPS: 200, // 2.0%\n   205→  RAKEBACK_POOL_BPS: 70, // 0.7% — raid boss rewards\n   206→  CHEST_TREASURY_BPS: 30, // 0.3% — treasure chests\n   207→} as const;\n   208→"}]},"parent_tool_use_id":null,"session_id":"394db446-9d72-42e7-88ec-8467376c4aa2","uuid":"29da93a0-4efc-4e2e-b9b6-eb0674787f68","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/types.ts","content":"import { PublicKey } from \"@solana/web3.js\";\n\n// ============ Tier System ============\n\nexport type Tier = \"iron\" | \"bronze\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n\nexport const TIER_VALUES: Record<Tier, number> = {\n  iron: 0,\n  bronze: 1,\n  silver: 2,\n  gold: 3,\n  platinum: 4,\n  diamond: 5,\n};\n\nexport const TIER_AMOUNTS: Record<Tier, number> = {\n  iron: 0.005,\n  bronze: 0.01,\n  silver: 0.1,\n  gold: 0.25,\n  platinum: 0.5,\n  diamond: 1.0,\n};\n\n// ============ Pool State ============\n\nexport type PoolPhase = \"waiting\" | \"locked\" | \"resolving\" | \"settled\" | \"cancelled\";\n\nexport const POOL_PHASE_VALUES: Record<PoolPhase, number> = {\n  waiting: 0,\n  locked: 1,\n  resolving: 2,\n  settled: 3,\n  cancelled: 4,\n};\n\nexport interface Pool {\n  poolId: Uint8Array;\n  gameId: string;\n  roundId: number;\n  tier: Tier;\n  entryAmount: number;\n  phase: PoolPhase;\n  totalPool: number;\n  playerCount: number;\n  maxPlayers: number;\n  createdAt: Date;\n  lockedAt: Date | null;\n  settledAt: Date | null;\n  feeBps: number;\n  vrfRequest: PublicKey | null;\n  randomness: Uint8Array | null;\n  winner: PublicKey | null;\n  authority: PublicKey;\n  treasury: PublicKey;\n  carryoverAmount: number;\n  carryoverFromRound: number;\n}\n\n// ============ Player Entry ============\n\nexport type Side = \"none\" | \"green\" | \"red\";\n\nexport const SIDE_VALUES: Record<Side, number> = {\n  none: 0,\n  green: 1,\n  red: 2,\n};\n\nexport interface PlayerEntry {\n  pool: PublicKey;\n  player: PublicKey;\n  amount: number;\n  enteredAt: Date;\n  sequence: number;\n  side: Side;\n  cashoutMultiplier: number | null;\n  cashedOutAt: Date | null;\n  claimed: boolean;\n  payout: number;\n  won: boolean;\n  xpParticipation: number;\n  xpWin: number;\n}\n\n// ============ Game Config ============\n\nexport interface GameConfig {\n  gameId: string;\n  paused: boolean;\n  minBet: number;\n  maxBet: number;\n  feeBps: number;\n  enabledTiers: Tier[];\n  minPlayers: number;\n  maxPlayers: number;\n  roundDurationSecs: number;\n  bettingWindowSecs: number;\n  vrfQueue: PublicKey;\n  authority: PublicKey;\n  treasury: PublicKey;\n  currentRound: number;\n  totalRounds: number;\n  totalVolume: number;\n  totalFees: number;\n  version: number;\n  createdAt: Date;\n  updatedAt: Date;\n}\n\n// ============ Coinflip ============\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type CoinflipPhase = \"created\" | \"ready\" | \"flipping\" | \"complete\";\n\nexport const COIN_SIDE_VALUES: Record<CoinSide, number> = {\n  heads: 0,\n  tails: 1,\n};\n\nexport const COINFLIP_PHASE_VALUES: Record<CoinflipPhase, number> = {\n  created: 0,\n  ready: 1,\n  flipping: 2,\n  complete: 3,\n};\n\nexport interface CoinflipState {\n  pool: PublicKey;\n  player1: PublicKey;\n  player2: PublicKey | null;\n  player1Side: CoinSide;\n  result: CoinSide | null;\n  phase: CoinflipPhase;\n  createdAt: Date;\n  joinedAt: Date | null;\n  flippedAt: Date | null;\n  joinTimeoutSecs: number;\n}\n\nexport interface CoinflipMatch {\n  pool: Pool;\n  state: CoinflipState;\n  player1Entry: PlayerEntry;\n  player2Entry: PlayerEntry | null;\n}\n\n// ============ Legacy Types (for backwards compatibility) ============\n\n/** @deprecated Use Pool instead */\nexport interface PoolState {\n  roundId: string;\n  gameId: string;\n  tier: Tier;\n  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n  entries: LegacyPlayerEntry[];\n  totalPool: number;\n  createdAt: number;\n  settledAt?: number;\n  outcome?: unknown;\n}\n\n/** @deprecated Use PlayerEntry instead */\nexport interface LegacyPlayerEntry {\n  playerId: string;\n  publicKey: string;\n  tier: Tier;\n  amount: number;\n  timestamp: number;\n  side?: \"green\" | \"red\";\n  cashoutMultiplier?: number;\n}\n\n// ============ Game IDs ============\n\nexport const GAME_IDS = {\n  COINFLIP: \"coinflip\",\n  LORD_OF_RNGS: \"lord-of-rngs\",\n  CRASH: \"crash\",\n  CLOSE_CALL: \"close-call\",\n  SLOTS: \"slots\",\n  GAME_OF_TRADES: \"game-of-trades\",\n  TUG_OF_EARN: \"tug-of-earn\",\n  CHART_COURSE: \"chart-course\",\n} as const;\n\nexport type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n\n// ============ XP System ============\n\nexport const XP_BY_TIER: Record<Tier, { participation: number; win: number }> = {\n  iron: { participation: 1, win: 3 },\n  bronze: { participation: 1, win: 3 },\n  silver: { participation: 10, win: 30 },\n  gold: { participation: 25, win: 75 },\n  platinum: { participation: 50, win: 150 },\n  diamond: { participation: 100, win: 300 },\n};\n\n// ============ Fee Constants ============\n\nexport const FEE_CONSTANTS = {\n  TOTAL_BPS: 300, // 3%\n  PLATFORM_REVENUE_BPS: 200, // 2.0%\n  RAKEBACK_POOL_BPS: 70, // 0.7% — raid boss rewards\n  CHEST_TREASURY_BPS: 30, // 0.3% — treasure chests\n} as const;\n","numLines":208,"startLine":1,"totalLines":208}}}
