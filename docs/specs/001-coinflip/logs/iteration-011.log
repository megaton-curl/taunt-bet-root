{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XrYv6yr2KQyL7aD2v5CERv","type":"tool_result","content":"     1→import { HTMLAttributes } from \"react\";\n     2→\n     3→// Tier type matches game-engine\n     4→export type Tier = \"iron\" | \"bronze\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n     5→\n     6→// Tier amounts in SOL\n     7→export const TIER_AMOUNTS: Record<Tier, number> = {\n     8→  iron: 0.005,\n     9→  bronze: 0.01,\n    10→  silver: 0.1,\n    11→  gold: 0.25,\n    12→  platinum: 0.5,\n    13→  diamond: 1.0,\n    14→};\n    15→\n    16→// Tier display colors\n    17→export const TIER_COLORS: Record<Tier, string> = {\n    18→  iron: \"#8a6040\",\n    19→  bronze: \"#cd7f32\",\n    20→  silver: \"#a8b8c8\",\n    21→  gold: \"#f0b820\",\n    22→  platinum: \"#40c080\",\n    23→  diamond: \"#e070a0\",\n    24→};\n    25→\n    26→const ALL_TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n    27→\n    28→export interface TierSelectorProps extends Omit<HTMLAttributes<HTMLDivElement>, 'onSelect'> {\n    29→  selectedTier: Tier | null;\n    30→  onSelect: (tier: Tier | null) => void;\n    31→  enabledTiers?: Tier[];\n    32→  disabled?: boolean;\n    33→  showAllOption?: boolean;\n    34→}\n    35→\n    36→export function TierSelector({\n    37→  selectedTier,\n    38→  onSelect,\n    39→  enabledTiers = ALL_TIERS,\n    40→  disabled = false,\n    41→  showAllOption = false,\n    42→  className = \"\",\n    43→  ...props\n    44→}: TierSelectorProps) {\n    45→  return (\n    46→    <div className={`rng-tier-selector ${showAllOption ? \"rng-tier-selector--with-all\" : \"\"} ${className}`} {...props}>\n    47→      {showAllOption && (\n    48→        <button\n    49→          key=\"all\"\n    50→          type=\"button\"\n    51→          className={`rng-tier-btn rng-tier-btn--all ${selectedTier === null ? \"rng-tier-btn--selected\" : \"\"}`}\n    52→          style={{ \"--tier-color\": \"#ffffff\" } as React.CSSProperties}\n    53→          onClick={() => !disabled && onSelect(null)}\n    54→          disabled={disabled}\n    55→        >\n    56→          <span className=\"rng-tier-btn__name\">ALL</span>\n    57→          <span className=\"rng-tier-btn__amount\">Any tier</span>\n    58→        </button>\n    59→      )}\n    60→      {ALL_TIERS.map((tier) => {\n    61→        const isEnabled = enabledTiers.includes(tier);\n    62→        const isSelected = selectedTier === tier;\n    63→        const isDisabled = disabled || !isEnabled;\n    64→\n    65→        return (\n    66→          <button\n    67→            key={tier}\n    68→            type=\"button\"\n    69→            className={`rng-tier-btn ${isSelected ? \"rng-tier-btn--selected\" : \"\"} ${isDisabled ? \"rng-tier-btn--disabled\" : \"\"}`}\n    70→            style={\n    71→              {\n    72→                \"--tier-color\": TIER_COLORS[tier],\n    73→              } as React.CSSProperties\n    74→            }\n    75→            onClick={() => !isDisabled && onSelect(tier)}\n    76→            disabled={isDisabled}\n    77→          >\n    78→            <span className={`rng-tier-gem rng-tier-gem--${tier}`} />\n    79→            <span className=\"rng-tier-btn__name\">{tier.toUpperCase()}</span>\n    80→            <span className=\"rng-tier-btn__amount\">{TIER_AMOUNTS[tier]}</span>\n    81→          </button>\n    82→        );\n    83→      })}\n    84→    </div>\n    85→  );\n    86→}\n    87→"}]},"parent_tool_use_id":null,"session_id":"394db446-9d72-42e7-88ec-8467376c4aa2","uuid":"d26bc5de-98cf-4b75-a33e-1f8b02b7ab7d","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/ui/src/layouts/TierSelector.tsx","content":"import { HTMLAttributes } from \"react\";\n\n// Tier type matches game-engine\nexport type Tier = \"iron\" | \"bronze\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n\n// Tier amounts in SOL\nexport const TIER_AMOUNTS: Record<Tier, number> = {\n  iron: 0.005,\n  bronze: 0.01,\n  silver: 0.1,\n  gold: 0.25,\n  platinum: 0.5,\n  diamond: 1.0,\n};\n\n// Tier display colors\nexport const TIER_COLORS: Record<Tier, string> = {\n  iron: \"#8a6040\",\n  bronze: \"#cd7f32\",\n  silver: \"#a8b8c8\",\n  gold: \"#f0b820\",\n  platinum: \"#40c080\",\n  diamond: \"#e070a0\",\n};\n\nconst ALL_TIERS: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n\nexport interface TierSelectorProps extends Omit<HTMLAttributes<HTMLDivElement>, 'onSelect'> {\n  selectedTier: Tier | null;\n  onSelect: (tier: Tier | null) => void;\n  enabledTiers?: Tier[];\n  disabled?: boolean;\n  showAllOption?: boolean;\n}\n\nexport function TierSelector({\n  selectedTier,\n  onSelect,\n  enabledTiers = ALL_TIERS,\n  disabled = false,\n  showAllOption = false,\n  className = \"\",\n  ...props\n}: TierSelectorProps) {\n  return (\n    <div className={`rng-tier-selector ${showAllOption ? \"rng-tier-selector--with-all\" : \"\"} ${className}`} {...props}>\n      {showAllOption && (\n        <button\n          key=\"all\"\n          type=\"button\"\n          className={`rng-tier-btn rng-tier-btn--all ${selectedTier === null ? \"rng-tier-btn--selected\" : \"\"}`}\n          style={{ \"--tier-color\": \"#ffffff\" } as React.CSSProperties}\n          onClick={() => !disabled && onSelect(null)}\n          disabled={disabled}\n        >\n          <span className=\"rng-tier-btn__name\">ALL</span>\n          <span className=\"rng-tier-btn__amount\">Any tier</span>\n        </button>\n      )}\n      {ALL_TIERS.map((tier) => {\n        const isEnabled = enabledTiers.includes(tier);\n        const isSelected = selectedTier === tier;\n        const isDisabled = disabled || !isEnabled;\n\n        return (\n          <button\n            key={tier}\n            type=\"button\"\n            className={`rng-tier-btn ${isSelected ? \"rng-tier-btn--selected\" : \"\"} ${isDisabled ? \"rng-tier-btn--disabled\" : \"\"}`}\n            style={\n              {\n                \"--tier-color\": TIER_COLORS[tier],\n              } as React.CSSProperties\n            }\n            onClick={() => !isDisabled && onSelect(tier)}\n            disabled={isDisabled}\n          >\n            <span className={`rng-tier-gem rng-tier-gem--${tier}`} />\n            <span className=\"rng-tier-btn__name\">{tier.toUpperCase()}</span>\n            <span className=\"rng-tier-btn__amount\">{TIER_AMOUNTS[tier]}</span>\n          </button>\n        );\n      })}\n    </div>\n  );\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
