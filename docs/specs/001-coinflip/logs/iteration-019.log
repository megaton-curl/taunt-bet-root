{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ULcg3C9zv93HbKwXrSpbPp","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→use rng_shared::lifecycle::{self, RoundPhase};\n     4→use rng_shared::timeout::is_expired;\n     5→use rng_shared::vrf_orao::{is_fulfilled, read_orao_randomness};\n     6→\n     7→use crate::error::CoinflipError;\n     8→use crate::state::CoinflipMatch;\n     9→\n    10→#[derive(Accounts)]\n    11→pub struct TimeoutCancel<'info> {\n    12→    /// Any signer can trigger a timeout cancel (permissionless after deadline).\n    13→    #[account(mut)]\n    14→    pub caller: Signer<'info>,\n    15→\n    16→    /// The creator's account — receives entry refund + rent.\n    17→    /// CHECK: Validated against coinflip_match.creator.\n    18→    #[account(mut)]\n    19→    pub creator: AccountInfo<'info>,\n    20→\n    21→    /// The opponent's account — receives entry refund.\n    22→    /// CHECK: Validated against coinflip_match.opponent.\n    23→    #[account(mut)]\n    24→    pub opponent: AccountInfo<'info>,\n    25→\n    26→    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    27→    #[account(\n    28→        mut,\n    29→        close = creator,\n    30→        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    31→        bump = coinflip_match.bump,\n    32→    )]\n    33→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    34→\n    35→    /// The Orao randomness PDA — used to check VRF is NOT fulfilled.\n    36→    /// CHECK: Key validated against coinflip_match.vrf_request_key; data read by shared VRF helper.\n    37→    pub randomness_account: AccountInfo<'info>,\n    38→}\n    39→\n    40→pub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    41→    let coinflip_match = &ctx.accounts.coinflip_match;\n    42→\n    43→    // Must be in LOCKED phase\n    44→    require!(\n    45→        coinflip_match.phase == RoundPhase::Locked,\n    46→        CoinflipError::InvalidPhase\n    47→    );\n    48→\n    49→    // Validate passed accounts match stored keys\n    50→    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    51→    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n    52→    require_keys_eq!(\n    53→        ctx.accounts.randomness_account.key(),\n    54→        coinflip_match.vrf_request_key\n    55→    );\n    56→\n    57→    // Check timeout has elapsed using shared helper\n    58→    let now = Clock::get()?.unix_timestamp;\n    59→    require!(\n    60→        is_expired(coinflip_match.resolve_deadline, now),\n    61→        CoinflipError::LockTimeoutNotElapsed\n    62→    );\n    63→\n    64→    // Check that VRF randomness is NOT fulfilled — if it is, must use claim_payout instead.\n    65→    // read_orao_randomness returns Ok([u8;32]) if fulfilled, Err if not.\n    66→    // We try to read; if it succeeds and is fulfilled, reject the timeout cancel.\n    67→    let vrf_is_fulfilled = read_orao_randomness(&ctx.accounts.randomness_account)\n    68→        .map(|r| is_fulfilled(&r))\n    69→        .unwrap_or(false);\n    70→    require!(!vrf_is_fulfilled, CoinflipError::InvalidPhase);\n    71→\n    72→    let entry_amount = coinflip_match.entry_amount;\n    73→\n    74→    // Refund both players their entry amounts using shared escrow helper\n    75→    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    76→    transfer_lamports_from_pda(&match_info, &ctx.accounts.creator, entry_amount)?;\n    77→    transfer_lamports_from_pda(&match_info, &ctx.accounts.opponent, entry_amount)?;\n    78→\n    79→    // Transition to Refunded via shared lifecycle\n    80→    lifecycle::transition(coinflip_match.phase, RoundPhase::Refunded)?;\n    81→    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    82→    coinflip_match.phase = RoundPhase::Refunded;\n    83→\n    84→    // Account is closed by Anchor's `close = creator` constraint —\n    85→    // remaining lamports (rent) are returned to creator.\n    86→\n    87→    Ok(())\n    88→}\n    89→"}]},"parent_tool_use_id":"toolu_01CCVaEGWQjc688h4GWspKMi","session_id":"cccd267e-4b06-490e-a6ee-407a80f063f8","uuid":"a2f11071-83b2-42df-b611-aecbcde00db9"}
