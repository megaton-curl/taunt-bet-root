ame\": \"payoutAmount\",\n   893→            \"type\": \"u64\"\n   894→          },\n   895→          {\n   896→            \"name\": \"feeAmount\",\n   897→            \"type\": \"u64\"\n   898→          },\n   899→          {\n   900→            \"name\": \"vrfRequestKey\",\n   901→            \"type\": \"pubkey\"\n   902→          }\n   903→        ]\n   904→      }\n   905→    },\n   906→    {\n   907→      \"name\": \"roundPhase\",\n   908→      \"docs\": [\n   909→        \"Lifecycle phase for every round/match in any game.\"\n   910→      ],\n   911→      \"type\": {\n   912→        \"kind\": \"enum\",\n   913→        \"variants\": [\n   914→          {\n   915→            \"name\": \"waiting\"\n   916→          },\n   917→          {\n   918→            \"name\": \"active\"\n   919→          },\n   920→          {\n   921→            \"name\": \"locked\"\n   922→          },\n   923→          {\n   924→            \"name\": \"resolving\"\n   925→          },\n   926→          {\n   927→            \"name\": \"settled\"\n   928→          },\n   929→          {\n   930→            \"name\": \"refunded\"\n   931→          }\n   932→        ]\n   933→      }\n   934→    }\n   935→  ]\n   936→};\n   937→"}]},"parent_tool_use_id":"toolu_01BcRDdFAHtegqoVKFVRRjBv","session_id":"78853bc0-87e2-4084-ac9d-e40a4ee398e1","uuid":"8dc69cb4-f2d2-4d48-9abd-5d34c136d574"}
