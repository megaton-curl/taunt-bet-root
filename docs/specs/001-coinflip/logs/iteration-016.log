{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019avoxQ8GpSSgVt5zM7jcJs","type":"tool_result","content":"     1→/**\n     2→ * Program IDL in camelCase format in order to be used in JS/TS.\n     3→ *\n     4→ * Note that this is only a type helper and is not the actual IDL. The original\n     5→ * IDL can be found at `target/idl/coinflip.json`.\n     6→ */\n     7→export type Coinflip = {\n     8→  \"address\": \"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\",\n     9→  \"metadata\": {\n    10→    \"name\": \"coinflip\",\n    11→    \"version\": \"0.1.0\",\n    12→    \"spec\": \"0.1.0\"\n    13→  },\n    14→  \"instructions\": [\n    15→    {\n    16→      \"name\": \"cancelMatch\",\n    17→      \"discriminator\": [\n    18→        142,\n    19→        136,\n    20→        247,\n    21→        45,\n    22→        92,\n    23→        112,\n    24→        180,\n    25→        83\n    26→      ],\n    27→      \"accounts\": [\n    28→        {\n    29→          \"name\": \"creator\",\n    30→          \"docs\": [\n    31→            \"The creator cancelling their match.\"\n    32→          ],\n    33→          \"writable\": true,\n    34→          \"signer\": true\n    35→        },\n    36→        {\n    37→          \"name\": \"coinflipMatch\",\n    38→          \"docs\": [\n    39→            \"The match PDA (closed on cancel — escrow + rent refunded to creator).\"\n    40→          ],\n    41→          \"writable\": true,\n    42→          \"pda\": {\n    43→            \"seeds\": [\n    44→              {\n    45→                \"kind\": \"const\",\n    46→                \"value\": [\n    47→                  109,\n    48→                  97,\n    49→                  116,\n    50→                  99,\n    51→                  104\n    52→                ]\n    53→              },\n    54→              {\n    55→                \"kind\": \"account\",\n    56→                \"path\": \"creator\"\n    57→              }\n    58→     