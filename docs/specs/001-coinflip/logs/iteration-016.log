{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_016DfGcYRTpvPFdDEWvdysbp","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JCdzPjVnqntHKMvWzoF1nz","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/verification.ts","content":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport { BorshCoder, EventParser, type Idl } from \"@coral-xyz/anchor\";\nimport { CoinflipIDL } from \"@rng-utopia/anchor-client\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n);\n\n// ============ Types ============\n\nexport interface VerificationResult {\n  verified: boolean;\n  creator: string;\n  opponent: string;\n  winner: string;\n  randomnessHex: string;\n  derivedResult: \"heads\" | \"tails\";\n  vrfFulfilled: boolean;\n}\n\ninterface MatchSettledEventData {\n  creator: PublicKey;\n  opponent: PublicKey;\n  winner: PublicKey;\n  randomness: number[];\n  payoutAmount: { toNumber(): number };\n  feeAmount: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n}\n\n// ============ Verification ============\n\n/**\n * Verifies the fairness of a completed coinflip match by inspecting the\n * claim transaction's MatchSettled event and the Orao VRF randomness account.\n *\n * Steps:\n * 1. Fetch the parsed transaction by signature\n * 2. Extract MatchSettled event from program logs\n * 3. Read randomness bytes from the event\n * 4. Re-derive the coin flip result via from_randomness(randomness[0])\n * 5. Validate the event winner is one of creator/opponent\n * 6. Fetch the Orao randomness account to confirm VRF fulfillment\n */\nexport async function verifyMatch(\n  connection: Connection,\n  claimTxSignature: string\n): Promise<VerificationResult> {\n  // (1) Fetch transaction\n  const tx = await connection.getTransaction(claimTxSignature, {\n    commitment: \"confirmed\",\n    maxSupportedTransactionVersion: 0,\n  });\n  if (!tx?.meta?.logMessages) {\n    throw new Error(\"Transaction not found or has no logs\");\n  }\n\n  // (2) Extract MatchSettled event from logs\n  const coder = new BorshCoder(CoinflipIDL as Idl);\n  const eventParser = new EventParser(COINFLIP_PROGRAM_ID, coder);\n\n  let settledEvent: MatchSettledEventData | null = null;\n  for (const event of eventParser.parseLogs(tx.meta.logMessages)) {\n    if (event.name === \"matchSettled\") {\n      settledEvent = event.data as MatchSettledEventData;\n      break;\n    }\n  }\n\n  if (!settledEvent) {\n    throw new Error(\"MatchSettled event not found in transaction logs\");\n  }\n\n  // (3) Read randomness bytes from event\n  const randomnessBytes = Uint8Array.from(settledEvent.randomness);\n  const randomnessHex = Array.from(randomnessBytes)\n    .map((b) => b.toString(16).padStart(2, \"0\"))\n    .join(\"\");\n\n  // (4) Re-derive result: from_randomness(randomness[0]) — matches on-chain logic\n  const firstByte = randomnessBytes[0] ?? 0;\n  const derivedResult: \"heads\" | \"tails\" =\n    firstByte % 2 === 0 ? \"heads\" : \"tails\";\n\n  // (5) Validate winner is one of the two players\n  const creator = settledEvent.creator.toBase58();\n  const opponent = settledEvent.opponent.toBase58();\n  const winner = settledEvent.winner.toBase58();\n  const winnerIsValid = winner === creator || winner === opponent;\n\n  // (6) Fetch Orao randomness account by vrf_request_key to confirm VRF fulfillment\n  let vrfFulfilled = false;\n  try {\n    const vrfAccount = await connection.getAccountInfo(\n      settledEvent.vrfRequestKey\n    );\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      // Orao randomness account: 8-byte discriminator then randomness data.\n      // Fulfilled means non-zero bytes in the randomness portion.\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      vrfFulfilled = randomnessData.some((b: number) => b !== 0);\n    }\n  } catch {\n    vrfFulfilled = false;\n  }\n\n  return {\n    verified: winnerIsValid && vrfFulfilled,\n    creator,\n    opponent,\n    winner,\n    randomnessHex,\n    derivedResult,\n    vrfFulfilled,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5620,"cache_read_input_tokens":61456,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5620},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"78853bc0-87e2-4084-ac9d-e40a4ee398e1","uuid":"f242dfe7-ec6c-4f80-8cae-fcfa6779137b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JCdzPjVnqntHKMvWzoF1nz","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/verification.ts"}]},"parent_tool_use_id":null,"session_id":"78853bc0-87e2-4084-ac9d-e40a4ee398e1","uuid":"016514e3-e1d8-44ea-8f12-e02bba66c204","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/verification.ts","content":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport { BorshCoder, EventParser, type Idl } from \"@coral-xyz/anchor\";\nimport { CoinflipIDL } from \"@rng-utopia/anchor-client\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n);\n\n// ============ Types ============\n\nexport interface VerificationResult {\n  verified: boolean;\n  creator: string;\n  opponent: string;\n  winner: string;\n  randomnessHex: string;\n  derivedResult: \"heads\" | \"tails\";\n  vrfFulfilled: boolean;\n}\n\ninterface MatchSettledEventData {\n  creator: PublicKey;\n  opponent: PublicKey;\n  winner: PublicKey;\n  randomness: number[];\n  payoutAmount: { toNumber(): number };\n  feeAmount: { toNumber(): number };\n  vrfRequestKey: PublicKey;\n}\n\n// ============ Verification ============\n\n/**\n * Verifies the fairness of a completed coinflip match by inspecting the\n * claim transaction's MatchSettled event and the Orao VRF randomness account.\n *\n * Steps:\n * 1. Fetch the parsed transaction by signature\n * 2. Extract MatchSettled event from program logs\n * 3. Read randomness bytes from the event\n * 4. Re-derive the coin flip result via from_randomness(randomness[0])\n * 5. Validate the event winner is one of creator/opponent\n * 6. Fetch the Orao randomness account to confirm VRF fulfillment\n */\nexport async function verifyMatch(\n  connection: Connection,\n  claimTxSignature: string\n): Promise<VerificationResult> {\n  // (1) Fetch transaction\n  const tx = await connection.getTransaction(claimTxSignature, {\n    commitment: \"confirmed\",\n    maxSupportedTransactionVersion: 0,\n  });\n  if (!tx?.meta?.logMessages) {\n    throw new Error(\"Transaction not found or has no logs\");\n  }\n\n  // (2) Extract MatchSettled event from logs\n  const coder = new BorshCoder(CoinflipIDL as Idl);\n  const eventParser = new EventParser(COINFLIP_PROGRAM_ID, coder);\n\n  let settledEvent: MatchSettledEventData | null = null;\n  for (const event of eventParser.parseLogs(tx.meta.logMessages)) {\n    if (event.name === \"matchSettled\") {\n      settledEvent = event.data as MatchSettledEventData;\n      break;\n    }\n  }\n\n  if (!settledEvent) {\n    throw new Error(\"MatchSettled event not found in transaction logs\");\n  }\n\n  // (3) Read randomness bytes from event\n  const randomnessBytes = Uint8Array.from(settledEvent.randomness);\n  const randomnessHex = Array.from(randomnessBytes)\n    .map((b) => b.toString(16).padStart(2, \"0\"))\n    .join(\"\");\n\n  // (4) Re-derive result: from_randomness(randomness[0]) — matches on-chain logic\n  const firstByte = randomnessBytes[0] ?? 0;\n  const derivedResult: \"heads\" | \"tails\" =\n    firstByte % 2 === 0 ? \"heads\" : \"tails\";\n\n  // (5) Validate winner is one of the two players\n  const creator = settledEvent.creator.toBase58();\n  const opponent = settledEvent.opponent.toBase58();\n  const winner = settledEvent.winner.toBase58();\n  const winnerIsValid = winner === creator || winner === opponent;\n\n  // (6) Fetch Orao randomness account by vrf_request_key to confirm VRF fulfillment\n  let vrfFulfilled = false;\n  try {\n    const vrfAccount = await connection.getAccountInfo(\n      settledEvent.vrfRequestKey\n    );\n    if (vrfAccount && vrfAccount.data.length > 8) {\n      // Orao randomness account: 8-byte discriminator then randomness data.\n      // Fulfilled means non-zero bytes in the randomness portion.\n      const randomnessData = vrfAccount.data.subarray(8, 72);\n      vrfFulfilled = randomnessData.some((b: number) => b !== 0);\n    }\n  } catch {\n    vrfFulfilled = false;\n  }\n\n  return {\n    verified: winnerIsValid && vrfFulfilled,\n    creator,\n    opponent,\n    winner,\n    randomnessHex,\n    derivedResult,\n    vrfFulfilled,\n  };\n}\n","structuredPatch":[],"originalFile":null}}
