{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RHSJBfkzzGAAdbkv96nQxJ","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    23→import {\n    24→  decodeCoinflipMatch,\n    25→  decodeCoinflipConfig,\n    26→  decodeLordRound,\n    27→  decodeLordConfig,\n    28→  type DecodedJackpotRound,\n    29→} from \"./account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→function getInstructionDiscriminator(\n    36→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    37→  instructionName: string,\n    38→): Buffer {\n    39→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    40→  if (!instruction) {\n    41→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    42→  }\n    43→  return Buffer.from(instruction.discriminator);\n    44→}\n    45→\n    46→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    47→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    48→  lordIdl,\n    49→  \"claim_payout\",\n    50→);"}]},"parent_tool_use_id":null,"session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"a00b26bb-3a07-46f8-aff0-c2d8f63547d9","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settle-tx.ts","content":"/**\n * Settle transaction builder + submission.\n *\n * Retrieves the stored secret, reads on-chain match + config data to resolve\n * all accounts, builds the `settle` instruction, submits it, and updates the\n * DB on confirmation.\n */\n\nimport { createHash } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\nimport {\n  decodeCoinflipMatch,\n  decodeCoinflipConfig,\n  decodeLordRound,\n  decodeLordConfig,\n  type DecodedJackpotRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Instruction discriminators (from IDL — no hardcoded byte arrays)\n// ---------------------------------------------------------------------------\n\nfunction getInstructionDiscriminator(\n  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n  instructionName: string,\n): Buffer {\n  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n  if (!instruction) {\n    throw new Error(`Instruction ${instructionName} not found in IDL`);\n  }\n  return Buffer.from(instruction.discriminator);\n}\n\nconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\nconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n  lordIdl,\n  \"claim_payout\",\n);","numLines":50,"startLine":1,"totalLines":688}}}
