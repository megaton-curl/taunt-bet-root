lowHeaders: [\"Content-Type\", \"Authorization\"],\n    42→  }),\n    43→);\n    44→\n    45→// Request logging — correlate frontend fetch timing with server-side processing\n    46→app.use(\"*\", async (c, next) => {\n    47→  const start = Date.now();\n    48→  await next();\n    49→  const ms = Date.now() - start;\n    50→  const method = c.req.method;\n    51→  const path = c.req.path;\n    52→  // Skip noisy health checks and OPTIONS preflight\n    53→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    54→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    55→});\n    56→\n    57→// Auth routes — no JWT middleware (these are the login endpoints)\n    58→// Lighter rate limiting by IP for auth endpoints\n    59→app.use(\n    60→  \"/auth/*\",\n    61→  createRateLimitMiddleware({\n    62→    perWallet: 20,\n    63→    global: config.rateLimitGlobal,\n    64→    windowMs: 60_000,\n    65→  }),\n    66→);\n    67→\n    68→app.route(\n    69→  \"/auth\",\n    70→  createAuthRoutes({\n    71→    authDb,\n    72→    jwtSecret: config.jwtSecret,\n    73→    cluster: config.cluster,\n    74→    challengeTtlSeconds: config.challengeTtlSeconds,\n    75→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    76→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    77→  }),\n    78→);\n    79→\n    80→// JWT auth middleware for fairness endpoints\n    81→app.use(\n    82→  \"/fairness/*\",\n    83→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n    84→);\n    85→\n    86→// Rate limiting — per-wallet and global limits on POST requests\n    87→app.use(\n    88→  \"/fairness/*\",\n    89→  createRateLimitMiddleware({\n    90→    perWallet: config.rateLimitPerWallet,\n    91→    global: config.rateLimitGlobal,\n    92→    windowMs: 60_000,\n    93→  }),\n    94→);\n    95→\n    96→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n    97→const entropyAccount = new PublicKey(config.entropyAccount);\n    98→const retrySettler = createRetrySettler({\n    99→  db,\n   100→  connection,\n   101→  settleRound: (pda) =>\n   102→    settleRound(\n   103→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n   104→      pda,\n   105→    ),\n   106→});\n   107→\n   108→// PDA watcher — WebSocket-based instant join detection\n   109→const pdaWatcher = createPdaWatcher({\n   110→  connection,\n   111→  serverKey: config.serverKeypair.publicKey,\n   112→  onJoinDetected: async (pda, targetSlot) => {\n   113→    // Update DB phase if still in 'created'\n   114→    const round = await db.getRoundByPda(pda);\n   115→    if (round && round.phase === \"created\") {\n   116→      await db.updateRoundPhase(pda, \"locked\", {\n   117→        target_slot: targetSlot.toString(),\n   118→      });\n   119→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   120→        targetSlot: targetSlot.toString(),\n   121→        source: \"pda-watcher\",\n   122→        game: round.game,\n   123→      });\n   124→    }\n   125→\n   126→    // Check if target slot already passed — settle immediately if so\n   127→    const currentSlot = await connection.getSlot();\n   128→    if (BigInt(currentSlot) >= targetSlot) {\n   129→      await retrySettler.attemptSettle(pda);\n   130→      pdaWatcher.unwatch(pda);\n   131→    }\n   132→    // If target slot not reached yet, poll worker will pick it up next cycle\n   133→  },\n   134→});\n   135→\n   136→const worker = createSettlementWorker({\n   137→  db,\n   138→  connection,\n   139→  serverKey: config.serverKeypair.publicKey,\n   140→  pollIntervalMs: config.workerPollIntervalMs,\n   141→  onSettleReady: async (pda) => {\n   142→    await retrySettler.attemptSettle(pda);\n   143→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   144→  },\n   145→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   146→});\n   147→worker.start();\n   148→\n   149→// Coinflip fairness routes\n   150→app.route(\n   151→  \"/fairness/coinflip\",\n   152→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   153→);\n   154→app.route(\n   155→  \"/fairness/lord\",\n   156→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   157→);\n   158→\n   159→// Round verification routes\n   160→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   161→\n   162→// Health endpoint — wired after worker exists so we can query its status\n   163→app.route(\n   164→  \"/health\",\n   165→  createHealthRoutes({\n   166→    db,\n   167→    connection,\n   168→    serverKey: config.serverKeypair.publicKey,\n   169→    isWorkerRunning: () => worker.isRunning,\n   170→    minSolBalance: config.minSolBalance,\n   171→  }),\n   172→);\n   173→\n   174→const port = config.port;\n   175→logger.info(\"fairness-backend started\", { port });\n   176→\n   177→serve({\n   178→  fetch: app.fetch,\n   179→  port,\n   180→});\n   181→\n   182→export default {\n   183→  port,\n   184→  fetch: app.fetch,\n   185→};\n   186→"}]},"parent_tool_use_id":null,"session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"5472a082-148e-4ad5-b67d-807371c6b66b","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { cors } from \"hono/cors\";\nimport { serve } from \"@hono/node-server\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport postgres from \"postgres\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createAuthDb } from \"./auth-db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createLordRoutes } from \"./routes/lord-create.js\";\nimport { createRoundsRoutes } from \"./routes/rounds.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createAuthRoutes } from \"./routes/auth.js\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Shared postgres connection for both game DB and auth DB\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new Hono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\",\n    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// JWT auth middleware for fairness endpoints\napp.use(\n  \"/fairness/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/fairness/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/fairness/lord\",\n  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Round verification routes\napp.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    db,\n    connection,\n    serverKey: config.serverKeypair.publicKey,\n    isWorkerRunning: () => worker.isRunning,\n    minSolBalance: config.minSolBalance,\n  }),\n);\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", { port });\n\nserve({\n  fetch: app.fetch,\n  port,\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":186,"startLine":1,"totalLines":186}}}
