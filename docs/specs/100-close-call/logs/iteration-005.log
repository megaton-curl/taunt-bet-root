{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U7Cw1K85tMaUPedFAvoXop","type":"tool_result","content":"     1→/**\n     2→ * PDA watcher — subscribes to match/round PDAs via WebSocket to detect\n     3→ * phase changes (join, countdown start) instantly instead of waiting for\n     4→ * the next getProgramAccounts poll cycle.\n     5→ *\n     6→ * This dramatically reduces settlement latency: from ~13s (stale poll) to\n     7→ * ~1-3s (WebSocket delivery + settlement).\n     8→ *\n     9→ * The poll-based settlement worker remains as a fallback for server\n    10→ * restarts, missed subscriptions, and edge cases.\n    11→ */\n    12→\n    13→import { Connection, PublicKey } from \"@solana/web3.js\";\n    14→import { logger } from \"../logger.js\";\n    15→import {\n    16→  coinflipMatchSize,\n    17→  decodeCoinflipMatch,\n    18→  decodeLordRound,\n    19→} from \"./account-decoder.js\";\n    20→\n    21→// ---------------------------------------------------------------------------\n    22→// Types\n    23→// ---------------------------------------------------------------------------\n    24→\n    25→export interface PdaWatcherDeps {\n    26→  connection: Connection;\n    27→  serverKey: PublicKey;\n    28→  onJoinDetected: (pda: string, targetSlot: bigint) => Promise<void>;\n    29→}\n    30→\n    31→export interface PdaWatcher {\n    32→  /** Register a PDA for watching. Called after match/round creation. */\n    33→  watch(pda: string): void;\n    34→  /** Stop watching a PDA. Called after settlement or cleanup. */\n    35→  unwatch(pda: string): void;\n    36→  /** Stop all subscriptions. */\n    37→  stopAll(): void;\n    38→  /** Number of active subscriptions (for health/debugging). */\n    39→  readonly size: number;\n    40→}\n    41→\n    42→// ---------------------------------------------------------------------------\n    43→// Constants\n    44→// ---------------------------------------------------------------------------\n    45→\n    46→const COINFLIP_MATCH_SIZE = coinflipMatchSize();\n    47→const PHASE_LOCKED = 1;\n    48→const LORD_PHASE_ACTIVE = 1;\n    49→\n    50→// ---------------------------------------------------------------------------\n    51→// Factory\n    52→// ---------------------------------------------------------------------------\n    53→\n    54→export function createPdaWatcher(deps: PdaWatcherDeps): PdaWatcher {\n    55→  const { connection, serverKey, onJoinDetected } = deps;\n    56→\n    57→  /** Map from PDA base58 → WebSocket subscription ID. */\n    58→  const subscriptions = new Map<string, number>();\n    59→\n    60→  function watch(pda: string): void {\n    61→    if (subscriptions.has(pda)) return; // already watching\n    62→\n    63→    const pubkey = new PublicKey(pda);\n    64→\n    65→    const subId = connection.onAccountChange(\n    66→      pubkey,\n    67→      async (accountInfo) => {\n    68→        try {\n    69→          // Account closed (settled or cancelled) — just unwatch\n    70→          if (accountInfo.lamports === 0) {\n    71→            logger.debug(\"[pda-watcher] account closed, unwatching\", {\n    72→              pda: pda.slice(0, 12),\n    73→            });\n    74→            unwatch(pda);\n    75→            return;\n    76→          }\n    77→\n    78→          const data = Buffer.from(accountInfo.data);\n    79→\n    80→          // Determine game type by account size\n    81→          if (data.length === COINFLIP_MATCH_SIZE) {\n    82→            handleCoinflipChange(pda, data);\n    83→          } else {\n    84→            // Try lord decode — variable-size accounts\n    85→            handleLordChange(pda, data);\n    86→          }\n    87→        } catch (err) {\n    88→          logger.warn(\"[pda-watcher] callback error\", {\n    89→            pda: pda.slice(0, 12),\n    90→            error: err instanceof Error ? err.message : String(err),\n    91→          });\n    92→        }\n    93→      },\n    94→      \"confirmed\",\n    95→    );\n    96→\n    97→    subscriptions.set(pda, subId);\n    98→    logger.debug(\"[pda-watcher] watching\", { pda: pda.slice(0, 12) });\n    99→  }\n   100→\n   101→  function handleCoinflipChange(pda: string, data: Buffer): void {\n   102→    let match;\n   103→    try {\n   104→      match = decodeCoinflipMatch(data);\n   105→    } catch {\n   106→      return; // undecodeable — ignore, poll worker will log it\n   107→    }\n   108→\n   109→    // Only care about our server's matches that are now locked\n   110→    if (match.phase !== PHASE_LOCKED || !match.server.equals(serverKey)) return;\n   111→    if (match.targetSlot <= 0n) return;\n   112→\n   113→    logger.info(\"[pda-watcher] coinflip phase changed to locked\", {\n   114→      pda: pda.slice(0, 12),\n   115→      targetSlot: match.targetSlot.toString(),\n   116→    });\n   117→\n   118→    onJoinDetected(pda, match.targetSlot).catch((err) => {\n   119→      logger.error(\"[pda-watcher] onJoinDetected error\", {\n   120→        pda: pda.slice(0, 12),\n   121→        error: err instanceof Error ? err.message : String(err),\n   122→      });\n   123→    });\n   124→  }\n   125→\n   126→  function handleLordChange(pda: string, data: Buffer): void {\n   127→    let round;\n   128→    try {\n   129→      round = decodeLordRound(data);\n   130→    } catch {\n   131→      return; // undecodeable — ignore\n   132→    }\n   133→\n   134→    // Only care about our server's rounds that are active with a target slot\n   135→    if (round.phase !== LORD_PHASE_ACTIVE || !round.server.equals(serverKey)) return;\n   136→    if (round.targetEntropySlot <= 0n) return;\n   137→\n   138→    logger.info(\"[pda-watcher] lord round countdown started\", {\n   139→      pda: pda.slice(0, 12),\n   140→      targetEntropySlot: round.targetEntropySlot.toString(),\n   141→    });\n   142→\n   143→    onJoinDetected(pda, round.targetEntropySlot).catch((err) => {\n   144→      logger.error(\"[pda-watcher] onJoinDetected error\", {\n   145→        pda: pda.slice(0, 12),\n   146→        error: err instanceof Error ? err.message : String(err),\n   147→      });\n   148→    });\n   149→  }\n   150→\n   151→  function unwatch(pda: string): void {\n   152→    const subId = subscriptions.get(pda);\n   153→    if (subId === undefined) return;\n   154→\n   155→    connection.removeAccountChangeListener(subId).catch((err) => {\n   156→      logger.warn(\"[pda-watcher] removeAccountChangeListener error\", {\n   157→        pda: pda.slice(0, 12),\n   158→        error: err instanceof Error ? err.message : String(err),\n   159→      });\n   160→    });\n   161→\n   162→    subscriptions.delete(pda);\n   163→    logger.debug(\"[pda-watcher] unwatching\", { pda: pda.slice(0, 12) });\n   164→  }\n   165→\n   166→  function stopAll(): void {\n   167→    for (const pda of subscriptions.keys()) {\n   168→      unwatch(pda);\n   169→    }\n   170→    logger.info(\"[pda-watcher] stopped all subscriptions\");\n   171→  }\n   172→\n   173→  return {\n   174→    watch,\n   175→    unwatch,\n   176→    stopAll,\n   177→    get size() {\n   178→      return subscriptions.size;\n   179→    },\n   180→  };\n   181→}\n   182→"}]},"parent_tool_use_id":"toolu_01QNpujR2tmDF1bZgi2CBi4E","session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"4b416ab6-bc21-4311-ac94-dd0ad989d83c"}
{"type":"system","subtype":"task_progress","task_id":"a70c5b7f58684ff9a","tool_use_id":"toolu_01QNpujR2tmDF1bZgi2CBi4E","description":"Reading sources/rng-utopia/services/backend/src/worker/account-decoder.ts","usage":{"total_tokens":29894,"tool_uses":6,"duration_ms":8294},"last_tool_name":"Read","uuid":"b8da2025-9b59-4d35-80dc-b523b30a6fc1","session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01JUoeJofTaSQhQBSzcedHL3","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019vbneGb6YhuBRTXgCVwAZ1","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/account-decoder.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":180,"cache_read_input_tokens":29608,"cache_creation":{"ephemeral_5m_input_tokens":180,"ephemeral_1h_input_tokens":0},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01QNpujR2tmDF1bZgi2CBi4E","session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"02353734-7e8a-4b33-a647-e5c8daef6ed0"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019vbneGb6YhuBRTXgCVwAZ1","type":"tool_result","content":"     1→/**\n     2→ * IDL-driven account decoder — single source of truth for all Solana account\n     3→ * data access in the backend.\n     4→ *\n     5→ * Uses Anchor's BorshAccountsCoder to decode/encode accounts directly from\n     6→ * the generated IDL JSON files, eliminating all hardcoded byte offsets.\n     7→ */\n     8→\n     9→import anchor, { type Idl } from \"@coral-xyz/anchor\";\n    10→\n    11→const { BorshAccountsCoder, BN } = anchor;\n    12→import { PublicKey } from \"@solana/web3.js\";\n    13→import {\n    14→  CoinflipIDL as coinflipIdl,\n    15→  ClosecallIDL as closecallIdl,\n    16→  LordofrngsIDL as lordIdl,\n    17→} from \"@rng-utopia/anchor-client\";\n    18→\n    19→// ---------------------------------------------------------------------------\n    20→// Coders (instantiated once at module load)\n    21→// ---------------------------------------------------------------------------\n    22→\n    23→const coinflipCoder = new BorshAccountsCoder(coinflipIdl as Idl);\n    24→const closecallCoder = new BorshAccountsCoder(closecallIdl as Idl);\n    25→const lordCoder = new BorshAccountsCoder(lordIdl as Idl);\n    26→\n    27→// ---------------------------------------------------------------------------\n    28→// Type helpers\n    29→// ---------------------------------------------------------------------------\n    30→\n    31→function bnToBigInt(bn: InstanceType<typeof BN>): bigint {\n    32→  return BigInt(bn.toString());\n    33→}\n    34→\n    35→/**\n    36→ * Anchor decodes Rust enums as { VariantName: {} }. Convert RoundPhase to\n    37→ * the numeric value used throughout the backend.\n    38→ */\n    39→function roundPhaseToNumber(phase: Record<string, object>): number {\n    40→  if (\"Waiting\" in phase) return 0;\n    41→  if (\"Active\" in phase) return 1;\n    42→  if (\"Locked\" in phase) return 2;\n    43→  if (\"Resolving\" in phase) return 3;\n    44→  if (\"Settled\" in phase) return 4;\n    45→  if (\"Refunded\" in phase) return 5;\n    46→  throw new Error(`Unknown RoundPhase variant: ${JSON.stringify(phase)}`);\n    47→}\n    48→\n    49→/** CloseCallPhase enum: Open=0, Settled=1, Refunded=2 */\n    50→function closeCallPhaseToNumber(phase: Record<string, object>): number {\n    51→  if (\"Open\" in phase) return 0;\n    52→  if (\"Settled\" in phase) return 1;\n    53→  if (\"Refunded\" in phase) return 2;\n    54→  throw new Error(`Unknown CloseCallPhase variant: ${JSON.stringify(phase)}`);\n    55→}\n    56→\n    57→/** Outcome enum: Pending=0, Green=1, Red=2, Refund=3 */\n    58→function outcomeToNumber(outcome: Record<string, object>): number {\n    59→  if (\"Pending\" in outcome) return 0;\n    60→  if (\"Green\" in outcome) return 1;\n    61→  if (\"Red\" in outcome) return 2;\n    62→  if (\"Refund\" in outcome) return 3;\n    63→  throw new Error(`Unknown Outcome variant: ${JSON.stringify(outcome)}`);\n    64→}\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Exported interfaces (camelCase, BigInt instead of BN)\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export interface DecodedCoinflipMatch {\n    71→  creator: PublicKey;\n    72→  opponent: PublicKey;\n    73→  server: PublicKey;\n    74→  entryAmount: bigint;\n    75→  creatorSide: number;\n    76→  phase: number;\n    77→  commitment: number[];\n    78→  algorithmVer: number;\n    79→  targetSlot: bigint;\n    80→  resolveDeadline: bigint;\n    81→  resultHash: number[];\n    82→  result: number;\n    83→  winner: PublicKey;\n    84→  createdAt: bigint;\n    85→  matchId: number[];\n    86→  bump: number;\n    87→}\n    88→\n    89→export interface DecodedCoinflipConfig {\n    90→  authority: PublicKey;\n    91→  treasury: PublicKey;\n    92→  paused: boolean;\n    93→  bump: number;\n    94→}\n    95→\n    96→export interface DecodedJackpotRound {\n    97→  matchId: number[];\n    98→  server: PublicKey;\n    99→  phase: number;\n   100→  commitment: number[];\n   101→  algorithmVer: number;\n   102→  entries: Array<{ player: PublicKey; amountLamports: bigint }>;\n   103→  totalAmountLamports: bigint;\n   104→  distinctPlayers: number;\n   105→  createdAt: bigint;\n   106→  countdownStartedAt: bigint;\n   107→  countdownEndsAt: bigint;\n   108→  targetEntropySlot: bigint;\n   109→  resolveDeadline: bigint;\n   110→  resultHash: number[];\n   111→  winningOffset: bigint;\n   112→  winningEntryIndex: number;\n   113→  winner: PublicKey;\n   114→  creator: PublicKey;\n   115→  bump: number;\n   116→}\n   117→\n   118→export interface DecodedLordConfig {\n   119→  authority: PublicKey;\n   120→  treasury: PublicKey;\n   121→  paused: boolean;\n   122→  bump: number;\n   123→}\n   124→\n   125→export interface DecodedCloseCallRound {\n   126→  roundId: number[];\n   127→  server: PublicKey;\n   128→  phase: number;\n   129→  greenEntries: Array<{ player: PublicKey; amountLamports: bigint }>;\n   130→  redEntries: Array<{ player: PublicKey; amountLamports: bigint }>;\n   131→  greenPool: bigint;\n   132→  redPool: bigint;\n   133→  openPrice: bigint;\n   134→  openPriceExpo: number;\n   135→  closePrice: bigint;\n   136→  createdAt: bigint;\n   137→  bettingEndsAt: bigint;\n   138→  resolveDeadline: bigint;\n   139→  outcome: number;\n   140→  totalFee: bigint;\n   141→  bump: number;\n   142→}\n   143→\n   144→export interface DecodedCloseCallConfig {\n   145→  authority: PublicKey;\n   146→  treasury: PublicKey;\n   147→  pythFeedId: number[];\n   148→  bettingWindowSecs: number;\n   149→  maxEntriesPerSide: number;\n   150→  paused: boolean;\n   151→  bump: number;\n   152→}\n   153→\n   154→// ---------------------------------------------------------------------------\n   155→// Decode functions\n   156→// ---------------------------------------------------------------------------\n   157→\n   158→/* eslint-disable @typescript-eslint/no-explicit-any */\n   159→\n   160→export function decodeCoinflipMatch(data: Buffer): DecodedCoinflipMatch {\n   161→  const raw: any = coinflipCoder.decode(\"CoinflipMatch\", data);\n   162→  return {\n   163→    creator: raw.creator,\n   164→    opponent: raw.opponent,\n   165→    server: raw.server,\n   166→    entryAmount: bnToBigInt(raw.entry_amount),\n   167→    creatorSide: raw.creator_side,\n   168→    phase: raw.phase,\n   169→    commitment: raw.commitment,\n   170→    algorithmVer: raw.algorithm_ver,\n   171→    targetSlot: bnToBigInt(raw.target_slot),\n   172→    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n   173→    resultHash: raw.result_hash,\n   174→    result: raw.result,\n   175→    winner: raw.winner,\n   176→    createdAt: bnToBigInt(raw.created_at),\n   177→    matchId: raw.match_id,\n   178→    bump: raw.bump,\n   179→  };\n   180→}\n   181→\n   182→export function decodeCoinflipConfig(data: Buffer): DecodedCoinflipConfig {\n   183→  const raw: any = coinflipCoder.decode(\"CoinflipConfig\", data);\n   184→  return {\n   185→    authority: raw.authority,\n   186→    treasury: raw.treasury,\n   187→    paused: raw.paused,\n   188→    bump: raw.bump,\n   189→  };\n   190→}\n   191→\n   192→export function decodeLordRound(data: Buffer): DecodedJackpotRound {\n   193→  const raw: any = lordCoder.decode(\"JackpotRound\", data);\n   194→  return {\n   195→    matchId: raw.match_id,\n   196→    server: raw.server,\n   197→    phase: roundPhaseToNumber(raw.phase),\n   198→    commitment: raw.commitment,\n   199→    algorithmVer: raw.algorithm_ver,\n   200→    entries: raw.entries.map((e: any) => ({\n   201→      player: e.player,\n   202→      amountLamports: bnToBigInt(e.amount_lamports),\n   203→    })),\n   204→    totalAmountLamports: bnToBigInt(raw.total_amount_lamports),\n   205→    distinctPlayers: raw.distinct_players,\n   206→    createdAt: bnToBigInt(raw.created_at),\n   207→    countdownStartedAt: bnToBigInt(raw.countdown_started_at),\n   208→    countdownEndsAt: bnToBigInt(raw.countdown_ends_at),\n   209→    targetEntropySlot: bnToBigInt(raw.target_entropy_slot),\n   210→    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n   211→    resultHash: raw.result_hash,\n   212→    winningOffset: bnToBigInt(raw.winning_offset),\n   213→    winningEntryIndex: raw.winning_entry_index,\n   214→    winner: raw.winner,\n   215→    creator: raw.creator,\n   216→    bump: raw.bump,\n   217→  };\n   218→}\n   219→\n   220→export function decodeLordConfig(data: Buffer): DecodedLordConfig {\n   221→  const raw: any = lordCoder.decode(\"LordConfig\", data);\n   222→  return {\n   223→    authority: raw.authority,\n   224→    treasury: raw.treasury,\n   225→    paused: raw.paused,\n   226→    bump: raw.bump,\n   227→  };\n   228→}\n   229→\n   230→function decodeBetEntries(\n   231→  entries: any[],\n   232→): Array<{ player: PublicKey; amountLamports: bigint }> {\n   233→  return entries.map((e: any) => ({\n   234→    player: e.player,\n   235→    amountLamports: bnToBigInt(e.amount_lamports),\n   236→  }));\n   237→}\n   238→\n   239→export function decodeCloseCallRound(data: Buffer): DecodedCloseCallRound {\n   240→  const raw: any = closecallCoder.decode(\"CloseCallRound\", data);\n   241→  return {\n   242→    roundId: raw.round_id,\n   243→    server: raw.server,\n   244→    phase: closeCallPhaseToNumber(raw.phase),\n   245→    greenEntries: decodeBetEntries(raw.green_entries),\n   246→    redEntries: decodeBetEntries(raw.red_entries),\n   247→    greenPool: bnToBigInt(raw.green_pool),\n   248→    redPool: bnToBigInt(raw.red_pool),\n   249→    openPrice: bnToBigInt(raw.open_price),\n   250→    openPriceExpo: raw.open_price_expo,\n   251→    closePrice: bnToBigInt(raw.close_price),\n   252→    createdAt: bnToBigInt(raw.created_at),\n   253→    bettingEndsAt: bnToBigInt(raw.betting_ends_at),\n   254→    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n   255→    outcome: outcomeToNumber(raw.outcome),\n   256→    totalFee: bnToBigInt(raw.total_fee),\n   257→    bump: raw.bump,\n   258→  };\n   259→}\n   260→\n   261→export function decodeCloseCallConfig(data: Buffer): DecodedCloseCallConfig {\n   262→  const raw: any = closecallCoder.decode(\"CloseCallConfig\", data);\n   263→  return {\n   264→    authority: raw.authority,\n   265→    treasury: raw.treasury,\n   266→    pythFeedId: raw.pyth_feed_id,\n   267→    bettingWindowSecs: raw.betting_window_secs,\n   268→    maxEntriesPerSide: raw.max_entries_per_side,\n   269→    paused: raw.paused,\n   270→    bump: raw.bump,\n   271→  };\n   272→}\n   273→\n   274→/* eslint-enable @typescript-eslint/no-explicit-any */\n   275→\n   276→// ---------------------------------------------------------------------------\n   277→// Filter helpers for getProgramAccounts\n   278→// ---------------------------------------------------------------------------\n   279→\n   280→/** CoinflipMatch account size (includes 8-byte discriminator). */\n   281→export function coinflipMatchSize(): number {\n   282→  return coinflipCoder.size(\"CoinflipMatch\");\n   283→}\n   284→\n   285→/** Discriminator-based memcmp filter for JackpotRound accounts. */\n   286→export function lordRoundDiscriminatorFilter(): {\n   287→  memcmp: { offset: number; bytes: string };\n   288→} {\n   289→  return { memcmp: lordCoder.memcmp(\"JackpotRound\") };\n   290→}\n   291→\n   292→/** Discriminator-based memcmp filter for CloseCallRound accounts. */\n   293→export function closeCallRoundDiscriminatorFilter(): {\n   294→  memcmp: { offset: number; bytes: string };\n   295→} {\n   296→  return { memcmp: closecallCoder.memcmp(\"CloseCallRound\") };\n   297→}\n   298→\n   299→// ---------------------------------------------------------------------------\n   300→// Encode helpers (for integration tests)\n   301→// ---------------------------------------------------------------------------\n   302→\n   303→export async function encodeCoinflipMatch(\n   304→  fields: DecodedCoinflipMatch,\n   305→): Promise<Buffer> {\n   306→  return coinflipCoder.encode(\"CoinflipMatch\", {\n   307→    creator: fields.creator,\n   308→    opponent: fields.opponent,\n   309→    server: fields.server,\n   310→    entry_amount: new BN(fields.entryAmount.toString()),\n   311→    creator_side: fields.creatorSide,\n   312→    phase: fields.phase,\n   313→    commitment: fields.commitment,\n   314→    algorithm_ver: fields.algorithmVer,\n   315→    target_slot: new BN(fields.targetSlot.toString()),\n   316→    resolve_deadline: new BN(fields.resolveDeadline.toString()),\n   317→    result_hash: fields.resultHash,\n   318→    result: fields.result,\n   319→    winner: fields.winner,\n   320→    created_at: new BN(fields.createdAt.toString()),\n   321→    match_id: fields.matchId,\n   322→    bump: fields.bump,\n   323→  });\n   324→}\n   325→\n   326→export async function encodeCoinflipConfig(\n   327→  fields: DecodedCoinflipConfig,\n   328→): Promise<Buffer> {\n   329→  return coinflipCoder.encode(\"CoinflipConfig\", {\n   330→    authority: fields.authority,\n   331→    treasury: fields.treasury,\n   332→    paused: fields.paused,\n   333→    bump: fields.bump,\n   334→  });\n   335→}\n   336→"}]},"parent_tool_use_id":"toolu_01QNpujR2tmDF1bZgi2CBi4E","session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"734c1655-98c0-47cf-bafc-87a69ecebf1f"}
