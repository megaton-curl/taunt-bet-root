{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GXEAYBqPt2ZUEPGqdcbL6F","type":"tool_result","content":"     1→/**\n     2→ * Settlement retry logic — wraps settlement with exponential backoff\n     3→ * for transient failures and proper handling of permanent failures.\n     4→ *\n     5→ * Called by the settlement worker's onSettleReady callback on each poll\n     6→ * cycle for every locked match whose target_slot has been reached.\n     7→ */\n     8→\n     9→import { Connection, PublicKey } from \"@solana/web3.js\";\n    10→import type { Db } from \"../db.js\";\n    11→import type { SettleResult } from \"./settle-tx.js\";\n    12→import { PermanentSettleError } from \"./settle-tx.js\";\n    13→import { logger } from \"../logger.js\";\n    14→import { decodeCoinflipMatch, decodeLordRound } from \"./account-decoder.js\";\n    15→\n    16→// ---------------------------------------------------------------------------\n    17→// Constants\n    18→// ---------------------------------------------------------------------------\n    19→\n    20→const MAX_RETRIES = 5;\n    21→const BASE_DELAY_MS = 2_000;\n    22→const MAX_DELAY_MS = 30_000;\n    23→\n    24→// ---------------------------------------------------------------------------\n    25→// Types\n    26→// ---------------------------------------------------------------------------\n    27→\n    28→export interface RetrySettlerDeps {\n    29→  db: Db;\n    30→  connection: Connection;\n    31→  settleRound: (pda: string) => Promise<SettleResult>;\n    32→}\n    33→\n    34→interface RetryState {\n    35→  attempts: number;\n    36→  /** Timestamp (ms) at which next retry is allowed. */\n    37→  nextRetryAt: number;\n    38→}\n    39→\n    40→export interface RetrySettler {\n    41→  /**\n    42→   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n    43→   * failure tracking, and resolve_deadline timeout detection.\n    44→   *\n    45→   * Safe to call repeatedly — skips if a retry is scheduled but not yet due,\n    46→   * or if the PDA has already been marked as permanently failed / timed out.\n    47→   */\n    48→  attemptSettle(pda: string): Promise<void>;\n    49→  /** Returns true if this PDA is done (settled, failed, or timed out). */\n    50→  isFinalized(pda: string): boolean;\n    51→}\n    52→\n    53→// ---------------------------------------------------------------------------\n    54→// Factory\n    55→// ---------------------------------------------------------------------------\n    56→\n    57→export function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n    58→  const { db, connection, settleRound } = deps;\n    59→\n    60→  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n    61→  const retryStates = new Map<string, RetryState>();\n    62→\n    63→  /** PDAs that hit a permanent (non-retryable) error. */\n    64→  const failedPdas = new Set<string>();\n    65→\n    66→  /** PDAs whose resolve_deadline has passed. */\n    67→  const timeoutPdas = new Set<string>();\n    68→\n    69→  /** PDAs that settled successfully. */\n    70→  const settledPdas = new Set<string>();\n    71→\n    72→  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n    73→  function getDelay(attempt: number): number {\n    74→    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n    75→  }\n    76→\n    77→  /**\n    78→   * Check whether the on-chain resolve_deadline has passed for a round.\n    79→   * Returns true if the deadline is in the past (timeout refund eligible).\n    80→   */\n    81→  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    82→    try {\n    83→      const round = await db.getRoundByPda(pda);\n    84→      if (!round) return true;\n    85→      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n    86→      if (!accountInfo) return true; // account gone — treat as expired\n    87→      const data = Buffer.from(accountInfo.data);\n    88→      let resolveDeadline = 0;\n    89→      if (round.game === \"lord\") {\n    90→        const decoded = decodeLordRound(data);\n    91→        resolveDeadline = Number(decoded.resolveDeadline);\n    92→      } else {\n    93→        const decoded = decodeCoinflipMatch(data);\n    94→        resolveDeadline = Number(decoded.resolveDeadline);\n    95→      }\n    96→      if (resolveDeadline <= 0) return false; // not set yet\n    97→      const nowUnix = Math.floor(Date.now() / 1000);\n    98→      return nowUnix >= resolveDeadline;\n    99→    } catch {\n   100→      return false; // can't read — don't assume timeout\n   101→    }\n   102→  }\n   103→\n   104→  async function attemptSettle(pda: string): Promise<void> {\n   105→    // Skip finalized PDAs (settled, failed, or timed out)\n   106→    if (settledPdas.has(pda) || failedPdas.has(pda) || timeoutPdas.has(pda)) return;\n   107→\n   108→    const state = retryStates.get(pda);\n   109→\n   110→    // If a retry is scheduled but not yet due, skip\n   111→    if (state && Date.now() < state.nextRetryAt) return;\n   112→\n   113→    // If max retries exceeded, mark as failed\n   114→    if (state && state.attempts >= MAX_RETRIES) {\n   115→      failedPdas.add(pda);\n   116→      retryStates.delete(pda);\n   117→      await db.insertOperatorEvent(pda, \"settle_failed\", {\n   118→        reason: \"max retries exceeded\",\n   119→        attempts: state.attempts,\n   120→      });\n   121→      logger.error(\"settle failed — max retries exceeded\", {\n   122→        pda,\n   123→        attempts: state.attempts,\n   124→      });\n   125→      return;\n   126→    }\n   127→\n   128→    // Check resolve_deadline before attempting\n   129→    if (await isResolveDeadlinePassed(pda)) {\n   130→      timeoutPdas.add(pda);\n   131→      retryStates.delete(pda);\n   132→      await db.insertOperatorEvent(pda, \"timeout_detected\", {\n   133→        reason: \"resolve_deadline passed without successful settlement\",\n   134→        attempts: state?.attempts ?? 0,\n   135→      });\n   136→      logger.warn(\"resolve deadline passed, stopping settlement attempts\", {\n   137→        pda,\n   138→      });\n   139→      return;\n   140→    }\n   141→\n   142→    try {\n   143→      const result = await settleRound(pda);\n   144→\n   145→      // Success — mark finalized, clear retry state\n   146→      settledPdas.add(pda);\n   147→      retryStates.delete(pda);\n   148→      logger.info(\"round settled\", {\n   149→        pda,\n   150→        tx: result.txSignature,\n   151→        resultSide: result.resultSide,\n   152→        winningEntryIndex: result.winningEntryIndex,\n   153→        winner: result.winner,\n   154→      });\n   155→    } catch (err) {\n   156→      if (err instanceof PermanentSettleError) {\n   157→        // Permanent failure — do not retry\n   158→        failedPdas.add(pda);\n   159→        retryStates.delete(pda);\n   160→        await db.insertOperatorEvent(pda, \"settle_failed\", {\n   161→          reason: err.message,\n   162→          permanent: true,\n   163→        });\n   164→        logger.error(\"settle permanently failed\", {\n   165→          pda,\n   166→          error: err.message,\n   167→        });\n   168→      } else {\n   169→        // Transient failure — schedule retry with exponential backoff\n   170→        const attempts = (state?.attempts ?? 0) + 1;\n   171→        const delay = getDelay(attempts - 1);\n   172→\n   173→        retryStates.set(pda, {\n   174→          attempts,\n   175→          nextRetryAt: Date.now() + delay,\n   176→        });\n   177→\n   178→        await db.insertOperatorEvent(pda, \"settle_retried\", {\n   179→          attempt: attempts,\n   180→          nextRetryInMs: delay,\n   181→          error: err instanceof Error ? err.message : String(err),\n   182→        });\n   183→        logger.warn(\"settle transient failure, scheduling retry\", {\n   184→          pda,\n   185→          attempt: attempts,\n   186→          nextRetryInMs: delay,\n   187→          error: err instanceof Error ? err.message : String(err),\n   188→        });\n   189→      }\n   190→    }\n   191→  }\n   192→\n   193→  function isFinalized(pda: string): boolean {\n   194→    return settledPdas.has(pda) || failedPdas.has(pda) || timeoutPdas.has(pda);\n   195→  }\n   196→\n   197→  return { attemptSettle, isFinalized };\n   198→}\n   199→"}]},"parent_tool_use_id":"toolu_01QNpujR2tmDF1bZgi2CBi4E","session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"a9986317-4ecc-4729-ac0b-ec5e76b7ae61"}
