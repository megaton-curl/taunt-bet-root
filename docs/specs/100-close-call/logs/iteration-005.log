{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UsqaQ9iB8bjff7UGmHoDS8","type":"tool_result","content":"     1→/**\n     2→ * Settlement worker — polls the chain for server-owned rounds that are ready\n     3→ * for backend settlement across supported games.\n     4→ */\n     5→\n     6→import { performance } from \"node:perf_hooks\";\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\n     9→import type { Db } from \"../db.js\";\n    10→import { logger } from \"../logger.js\";\n    11→import {\n    12→  coinflipMatchSize,\n    13→  decodeCoinflipMatch,\n    14→  decodeLordRound,\n    15→  lordRoundDiscriminatorFilter,\n    16→} from \"./account-decoder.js\";\n    17→\n    18→const PHASE_LOCKED_VALUE = 1;\n    19→const LORD_PHASE_ACTIVE_VALUE = 1;\n    20→\n    21→export interface SettlementWorkerDeps {\n    22→  db: Db;\n    23→  connection: Connection;\n    24→  serverKey: PublicKey;\n    25→  pollIntervalMs: number;\n    26→  /** Called when a match is detected as ready for settlement (target_slot reached). */\n    27→  onSettleReady?: (pda: string) => Promise<void>;\n    28→  /** Called to check if a PDA is finalized (settled or permanently failed). */\n    29→  isFinalized?: (pda: string) => boolean;\n    30→}\n    31→\n    32→export interface SettlementWorker {\n    33→  start(): void;\n    34→  stop(): void;\n    35→  readonly isRunning: boolean;\n    36→  /** Run a single poll cycle (exposed for testing). */\n    37→  poll(): Promise<void>;\n    38→}\n    39→\n    40→export function createSettlementWorker(\n    41→  deps: SettlementWorkerDeps,\n    42→): SettlementWorker {\n    43→  const { db, connection, serverKey, pollIntervalMs } = deps;\n    44→  const discoveredPdas = new Set<string>();\n    45→  const readyPdas = new Set<string>();\n    46→  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n    47→  const undecodeablePdas = new Set<string>();\n    48→  let running = false;\n    49→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    50→\n    51→  async function handleDiscoveredRound(\n    52→    pda: string,\n    53→    targetSlot: bigint,\n    54→    currentSlot: number,\n    55→    slotTime: string | null,\n    56→  ): Promise<void> {\n    57→    const round = await db.getRoundByPda(pda);\n    58→    if (!round) {\n    59→      return;\n    60→    }\n    61→\n    62→    if (!discoveredPdas.has(pda)) {\n    63→      discoveredPdas.add(pda);\n    64→      if (round.phase === \"created\") {\n    65→        await db.updateRoundPhase(pda, \"locked\", {\n    66→          target_slot: targetSlot.toString(),\n    67→        });\n    68→        await db.insertOperatorEvent(pda, \"match_detected\", {\n    69→          targetSlot: targetSlot.toString(),\n    70→          currentSlot,\n    71→          game: round.game,\n    72→        });\n    73→        logger.info(\"settlement worker detected locked round\", {\n    74→          pda,\n    75→          creator: round.creator,\n    76→          targetSlot: targetSlot.toString(),\n    77→          currentSlot,\n    78→          slotTime,\n    79→          game: round.game,\n    80→        });\n    81→      }\n    82→    }\n    83→\n    84→    if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n    85→      if (deps.isFinalized?.(pda)) {\n    86→        // Clean up tracking sets for finalized PDAs to prevent unbounded growth\n    87→        discoveredPdas.delete(pda);\n    88→        readyPdas.delete(pda);\n    89→        return;\n    90→      }\n    91→\n    92→      const slotsAhead = currentSlot - Number(targetSlot);\n    93→      if (!readyPdas.has(pda)) {\n    94→        readyPdas.add(pda);\n    95→        logger.info(\"settlement worker found round ready\", {\n    96→          pda,\n    97→          targetSlot: targetSlot.toString(),\n    98→          currentSlot,\n    99→          slotsAhead,\n   100→          estimatedDelayMs: slotsAhead * 400,\n   101→          slotTime,\n   102→        });\n   103→      }\n   104→      const tSettle0 = performance.now();\n   105→      await deps.onSettleReady(pda);\n   106→      const tSettle1 = performance.now();\n   107→      logger.debug(\"settlement worker onSettleReady completed\", {\n   108→        pda: pda.slice(0, 12),\n   109→        settleMs: Math.round(tSettle1 - tSettle0),\n   110→      });\n   111→    }\n   112→  }\n   113→\n   114→  async function poll(): Promise<void> {\n   115→    const t0 = performance.now();\n   116→    const currentSlot = await connection.getSlot();\n   117→    const blockTime = await connection.getBlockTime(currentSlot).catch(() => null);\n   118→    const slotTime = blockTime ? new Date(blockTime * 1000).toISOString() : null;\n   119→    const tSlot = performance.now();\n   120→\n   121→    // Coinflip: fetch by dataSize (distinguishes Match from Config), decode + filter\n   122→    const coinflipAccounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n   123→      filters: [{ dataSize: coinflipMatchSize() }],\n   124→    });\n   125→    const tCoinflip = performance.now();\n   126→\n   127→    for (const { pubkey, account } of coinflipAccounts) {\n   128→      const key = pubkey.toBase58();\n   129→      if (undecodeablePdas.has(key)) continue;\n   130→      try {\n   131→        const match = decodeCoinflipMatch(Buffer.from(account.data));\n   132→        if (match.phase !== PHASE_LOCKED_VALUE || !match.server.equals(serverKey)) continue;\n   133→        await handleDiscoveredRound(key, match.targetSlot, currentSlot, slotTime);\n   134→      } catch {\n   135→        undecodeablePdas.add(key);\n   136→        logger.warn(\"skipping undecodeable coinflip account\", { pda: key });\n   137→      }\n   138→    }\n   139→\n   140→    // Lord: fetch by discriminator (variable-size accounts), decode + filter\n   141→    const lordAccounts = await connection.getProgramAccounts(LORDOFRNGS_PROGRAM_ID, {\n   142→      filters: [lordRoundDiscriminatorFilter()],\n   143→    });\n   144→    const tLord = performance.now();\n   145→\n   146→    for (const { pubkey, account } of lordAccounts) {\n   147→      const key = pubkey.toBase58();\n   148→      if (undecodeablePdas.has(key)) continue;\n   149→      try {\n   150→        const round = decodeLordRound(Buffer.from(account.data));\n   151→        if (round.phase !== LORD_PHASE_ACTIVE_VALUE || !round.server.equals(serverKey)) continue;\n   152→        if (round.targetEntropySlot <= 0n) continue;\n   153→        await handleDiscoveredRound(key, round.targetEntropySlot, currentSlot, slotTime);\n   154→      } catch {\n   155→        undecodeablePdas.add(key);\n   156→        logger.warn(\"skipping undecodeable lord account\", { pda: key });\n   157→      }\n   158→    }\n   159→    const tEnd = performance.now();\n   160→\n   161→    logger.debug(\"settlement poll cycle\", {\n   162→      slotMs: Math.round(tSlot - t0),\n   163→      coinflipFetchMs: Math.round(tCoinflip - tSlot),\n   164→      lordFetchMs: Math.round(tLord - tCoinflip),\n   165→      totalMs: Math.round(tEnd - t0),\n   166→      coinflipAccounts: coinflipAccounts.length,\n   167→      lordAccounts: lordAccounts.length,\n   168→      currentSlot,\n   169→      slotTime,\n   170→    });\n   171→  }\n   172→\n   173→  async function loop(): Promise<void> {\n   174→    if (!running) return;\n   175→    try {\n   176→      await poll();\n   177→    } catch (err) {\n   178→      // Log but don't crash — transient RPC errors are expected\n   179→      logger.error(\"settlement worker poll error\", {\n   180→        error: err instanceof Error ? err.message : String(err),\n   181→      });\n   182→    }\n   183→    if (running) {\n   184→      timeoutId = setTimeout(loop, pollIntervalMs);\n   185→    }\n   186→  }\n   187→\n   188→  return {\n   189→    start() {\n   190→      if (running) return;\n   191→      running = true;\n   192→      const rpcUrl = connection.rpcEndpoint;\n   193→      const trimmedRpc = (() => {\n   194→        try {\n   195→          const u = new URL(rpcUrl);\n   196→          return `${u.host}${u.pathname}`;\n   197→        } catch {\n   198→          return rpcUrl.slice(0, 40) + \"…\";\n   199→        }\n   200→      })();\n   201→      logger.info(\"settlement worker started\", {\n   202→        serverKey: serverKey.toBase58(),\n   203→        pollIntervalMs,\n   204→        rpc: trimmedRpc,\n   205→      });\n   206→      loop();\n   207→    },\n   208→    stop() {\n   209→      running = false;\n   210→      if (timeoutId) {\n   211→        clearTimeout(timeoutId);\n   212→        timeoutId = null;\n   213→      }\n   214→      logger.info(\"settlement worker stopped\", {\n   215→        serverKey: serverKey.toBase58(),\n   216→      });\n   217→    },\n   218→    get isRunning() {\n   219→      return running;\n   220→    },\n   221→    poll,\n   222→  };\n   223→}\n   224→"}]},"parent_tool_use_id":"toolu_01QNpujR2tmDF1bZgi2CBi4E","session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"7a1904de-d3af-4ed0-ba60-236cc6501de6"}
