ome: Outcome,\n   108→    pub open_price: i64,\n   109→    pub close_price: i64,\n   110→    pub green_pool: u64,\n   111→    pub red_pool: u64,\n   112→    pub total_fee: u64,\n   113→    pub num_winners: u8,\n   114→}\n   115→"}]},"parent_tool_use_id":null,"session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"ec52fcfd-b738-4586-bbe5-bbadad6f30cc","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/closecall/src/state.rs","content":"use anchor_lang::prelude::*;\n\n/// Betting side in Close Call.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\npub enum BetSide {\n    Green,\n    Red,\n}\n\n/// Round lifecycle phase.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\npub enum CloseCallPhase {\n    /// Round is open for bets (first 30s of candle).\n    Open,\n    /// Outcome determined, payouts distributed.\n    Settled,\n    /// All bets refunded (invalid round, timeout, or force close).\n    Refunded,\n}\n\n/// Settlement outcome.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\npub enum Outcome {\n    Pending,\n    Green,\n    Red,\n    Refund,\n}\n\n/// A single bet entry.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Debug, InitSpace)]\npub struct BetEntry {\n    pub player: Pubkey,\n    pub amount_lamports: u64,\n}\n\n/// Global configuration for the Close Call program.\n/// PDA seeds: [b\"closecall_config\"]\n#[account]\n#[derive(InitSpace)]\npub struct CloseCallConfig {\n    /// Admin authority (can update config, force close).\n    pub authority: Pubkey,\n    /// Fee destination wallet.\n    pub treasury: Pubkey,\n    /// Pyth price feed ID for BTC/USD (32 bytes).\n    pub pyth_feed_id: [u8; 32],\n    /// Betting window duration in seconds (default 30).\n    pub betting_window_secs: u32,\n    /// Maximum entries per side (default 32).\n    pub max_entries_per_side: u8,\n    /// Whether the game is paused.\n    pub paused: bool,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// A Close Call round.\n/// PDA seeds: [b\"cc_round\", &round_id]\n#[account]\n#[derive(InitSpace)]\npub struct CloseCallRound {\n    /// Backend-generated random round ID (used in PDA seeds).\n    pub round_id: [u8; 8],\n    /// Server wallet that paid rent and will settle.\n    pub server: Pubkey,\n    /// Current phase.\n    pub phase: CloseCallPhase,\n\n    /// Green (bull) entries.\n    #[max_len(32)]\n    pub green_entries: Vec<BetEntry>,\n    /// Red (bear) entries.\n    #[max_len(32)]\n    pub red_entries: Vec<BetEntry>,\n    /// Total lamports in green pool.\n    pub green_pool: u64,\n    /// Total lamports in red pool.\n    pub red_pool: u64,\n\n    /// Pyth open price at round creation (scaled integer).\n    pub open_price: i64,\n    /// Pyth price exponent at round creation.\n    pub open_price_expo: i32,\n    /// Pyth close price at settlement (0 until settled).\n    pub close_price: i64,\n\n    /// Unix timestamp when round was created.\n    pub created_at: i64,\n    /// Unix timestamp when betting window closes.\n    pub betting_ends_at: i64,\n    /// Unix timestamp after which timeout_refund is available.\n    pub resolve_deadline: i64,\n\n    /// Settlement outcome.\n    pub outcome: Outcome,\n    /// Fee collected (0 for refund rounds).\n    pub total_fee: u64,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// Event emitted when a round is settled.\n#[event]\npub struct RoundSettled {\n    pub round_id: [u8; 8],\n    pub outcome: Outcome,\n    pub open_price: i64,\n    pub close_price: i64,\n    pub green_pool: u64,\n    pub red_pool: u64,\n    pub total_fee: u64,\n    pub num_winners: u8,\n}\n","numLines":115,"startLine":1,"totalLines":115}}}
