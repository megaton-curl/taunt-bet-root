{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018vD7mP51Sr8rSLaBxCyE5B","type":"message","role":"assistant","content":[{"type":"text","text":"Now I have a complete understanding of the architecture. Let me write the clock worker."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3301,"cache_read_input_tokens":61830,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3301},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"a1777f7a-1636-4ba8-885e-43b87a1990b2"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018vD7mP51Sr8rSLaBxCyE5B","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TCRvnCmuAkRRLYv7kNTJQ1","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts","content":"/**\n * Close Call clock worker — creates and settles rounds on minute boundaries.\n *\n * Each tick (aligned to ~2s after each minute):\n *   1. Settle the previous round if it exists and the candle has closed.\n *   2. Create a new round (stores Pyth open price on-chain).\n *\n * On start, scans for an existing open round (recovery after restart).\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport { Connection, Keypair, PublicKey, type Transaction } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport {\n  buildCloseCallCreateRoundTx,\n  buildCloseCallSettleRoundTx,\n  type CloseCallTxDeps,\n} from \"./settle-tx.js\";\nimport {\n  closeCallRoundDiscriminatorFilter,\n  decodeCloseCallConfig,\n  decodeCloseCallRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Pyth PriceUpdateV2 raw offsets (same layout as pyth.rs)\n// discriminator(8) + write_authority(32) + verification_level(1) = 41\n// PriceFeedMessage: feed_id(32) + price(i64@73) + conf(u64@81) + exponent(i32@89)\n// ---------------------------------------------------------------------------\n\nconst PYTH_PRICE_OFFSET = 41 + 32; // 73\nconst PYTH_EXPO_OFFSET = PYTH_PRICE_OFFSET + 8 + 8; // 89\nconst PYTH_MIN_DATA_LEN = PYTH_EXPO_OFFSET + 4; // 93\n\n/** Close Call on-chain phase values */\nconst PHASE_OPEN = 0;\n\n/** Offset after minute boundary before first tick (ms). */\nconst TICK_OFFSET_MS = 2_000;\n\n/** Maximum retry attempts for a single tx submission. */\nconst MAX_TX_RETRIES = 3;\nconst TX_RETRY_DELAY_MS = 2_000;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface CloseCallClockDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n  /** Pyth BTC/USD push oracle price account on-chain. */\n  pythPriceAccount: PublicKey;\n}\n\nexport interface CloseCallClockWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single tick (exposed for testing). */\n  tick(): Promise<void>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createCloseCallClockWorker(\n  deps: CloseCallClockDeps,\n): CloseCallClockWorker {\n  const { connection, serverKeypair, pythPriceAccount } = deps;\n  const txDeps: CloseCallTxDeps = { connection, serverKeypair };\n\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  /** Active round tracking (in-memory, recovered on start). */\n  let activeRoundId: Buffer | null = null;\n  let activeRoundPda: PublicKey | null = null;\n\n  // -----------------------------------------------------------------------\n  // Helpers\n  // -----------------------------------------------------------------------\n\n  /** Milliseconds until the next minute boundary + offset. */\n  function msUntilNextMinute(): number {\n    const now = Date.now();\n    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    return nextMinute - now + TICK_OFFSET_MS;\n  }\n\n  /** Send a signed transaction and confirm with retry. */\n  async function sendAndConfirm(\n    tx: Transaction,\n    label: string,\n  ): Promise<string> {\n    let lastError: unknown;\n\n    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n      try {\n        const sig = await connection.sendRawTransaction(tx.serialize(), {\n          skipPreflight: false,\n        });\n        const { blockhash, lastValidBlockHeight } =\n          await connection.getLatestBlockhash();\n        const confirmation = await connection.confirmTransaction(\n          { signature: sig, blockhash, lastValidBlockHeight },\n          \"confirmed\",\n        );\n        if (confirmation.value.err) {\n          throw new Error(\n            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n          );\n        }\n        return sig;\n      } catch (err) {\n        lastError = err;\n        if (attempt < MAX_TX_RETRIES - 1) {\n          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n        }\n      }\n    }\n\n    throw lastError;\n  }\n\n  /** Read Pyth price from on-chain account for outcome pre-check. */\n  async function readPythPrice(): Promise<{ price: bigint; expo: number } | null> {\n    const info = await connection.getAccountInfo(pythPriceAccount);\n    if (!info || info.data.length < PYTH_MIN_DATA_LEN) return null;\n    const data = Buffer.from(info.data);\n    const price = data.readBigInt64LE(PYTH_PRICE_OFFSET);\n    const expo = data.readInt32LE(PYTH_EXPO_OFFSET);\n    return { price, expo };\n  }\n\n  /** Read CloseCallConfig for treasury address. */\n  async function readTreasury(): Promise<PublicKey | null> {\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"closecall_config\")],\n      CLOSECALL_PROGRAM_ID,\n    );\n    const info = await connection.getAccountInfo(configPda);\n    if (!info) return null;\n    const config = decodeCloseCallConfig(Buffer.from(info.data));\n    return config.treasury;\n  }\n\n  /**\n   * Discover an existing open round owned by this server (recovery after restart).\n   */\n  async function discoverActiveRound(): Promise<void> {\n    try {\n      const accounts = await connection.getProgramAccounts(\n        CLOSECALL_PROGRAM_ID,\n        { filters: [closeCallRoundDiscriminatorFilter()] },\n      );\n\n      for (const { pubkey, account } of accounts) {\n        try {\n          const round = decodeCloseCallRound(Buffer.from(account.data));\n          if (\n            round.phase === PHASE_OPEN &&\n            round.server.equals(serverKeypair.publicKey)\n          ) {\n            activeRoundPda = pubkey;\n            activeRoundId = Buffer.from(round.roundId);\n            logger.info(\"closecall clock: recovered active round\", {\n              pda: pubkey.toBase58(),\n              roundId: activeRoundId.toString(\"hex\"),\n            });\n            return;\n          }\n        } catch {\n          // Skip undecodeable accounts\n        }\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: discovery scan failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Settlement\n  // -----------------------------------------------------------------------\n\n  /**\n   * Settle the previous round if it exists.\n   * Returns true if settlement succeeded (or no round to settle).\n   */\n  async function settlePreviousRound(): Promise<boolean> {\n    if (!activeRoundPda || !activeRoundId) return true;\n\n    const roundPda = activeRoundPda;\n    const roundId = activeRoundId;\n\n    try {\n      // Read on-chain round\n      const info = await connection.getAccountInfo(roundPda);\n      if (!info) {\n        // Already closed (settled/refunded by someone else or timeout)\n        logger.info(\"closecall clock: round already closed\", {\n          pda: roundPda.toBase58(),\n        });\n        activeRoundPda = null;\n        activeRoundId = null;\n        return true;\n      }\n\n      const round = decodeCloseCallRound(Buffer.from(info.data));\n\n      // Only settle if still Open\n      if (round.phase !== PHASE_OPEN) {\n        logger.info(\"closecall clock: round not in Open phase, skipping\", {\n          pda: roundPda.toBase58(),\n          phase: round.phase,\n        });\n        activeRoundPda = null;\n        activeRoundId = null;\n        return true;\n      }\n\n      // Read Pyth close price + treasury in parallel\n      const [pythPrice, treasury] = await Promise.all([\n        readPythPrice(),\n        readTreasury(),\n      ]);\n\n      if (!pythPrice) {\n        logger.error(\"closecall clock: cannot read Pyth price for settlement\", {\n          pda: roundPda.toBase58(),\n        });\n        return false;\n      }\n      if (!treasury) {\n        logger.error(\"closecall clock: cannot read config treasury\");\n        return false;\n      }\n\n      // Pre-determine outcome to select correct remaining accounts\n      const greenCount = round.greenEntries.length;\n      const redCount = round.redEntries.length;\n      const totalCount = greenCount + redCount;\n      const hasBothSides = greenCount > 0 && redCount > 0;\n\n      const isRefund =\n        totalCount === 0 ||\n        !hasBothSides ||\n        totalCount === 1 ||\n        pythPrice.price === round.openPrice;\n\n      let remainingAccounts: PublicKey[];\n      if (isRefund) {\n        // All players: green entries then red entries (entry order)\n        remainingAccounts = [\n          ...round.greenEntries.map((e) => e.player),\n          ...round.redEntries.map((e) => e.player),\n        ];\n      } else if (pythPrice.price > round.openPrice) {\n        // Green wins — only green bettors\n        remainingAccounts = round.greenEntries.map((e) => e.player);\n      } else {\n        // Red wins — only red bettors\n        remainingAccounts = round.redEntries.map((e) => e.player);\n      }\n\n      const tx = await buildCloseCallSettleRoundTx(\n        txDeps,\n        roundId,\n        pythPriceAccount,\n        treasury,\n        remainingAccounts,\n      );\n\n      const sig = await sendAndConfirm(tx, \"settle\");\n\n      logger.info(\"closecall clock: round settled\", {\n        pda: roundPda.toBase58(),\n        tx: sig,\n        totalEntries: totalCount,\n        outcome: isRefund\n          ? \"refund\"\n          : pythPrice.price > round.openPrice\n            ? \"green\"\n            : \"red\",\n      });\n\n      activeRoundPda = null;\n      activeRoundId = null;\n      return true;\n    } catch (err) {\n      logger.error(\"closecall clock: settlement failed\", {\n        pda: roundPda.toBase58(),\n        error: err instanceof Error ? err.message : String(err),\n      });\n      // Clear active round — timeout_refund will handle it\n      activeRoundPda = null;\n      activeRoundId = null;\n      return false;\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Round creation\n  // -----------------------------------------------------------------------\n\n  async function createNewRound(): Promise<void> {\n    const roundId = randomBytes(8);\n\n    try {\n      const { tx, roundPda } = await buildCloseCallCreateRoundTx(\n        txDeps,\n        roundId,\n        pythPriceAccount,\n      );\n\n      const sig = await sendAndConfirm(tx, \"create_round\");\n\n      activeRoundId = roundId;\n      activeRoundPda = roundPda;\n\n      logger.info(\"closecall clock: new round created\", {\n        pda: roundPda.toBase58(),\n        roundId: roundId.toString(\"hex\"),\n        tx: sig,\n      });\n    } catch (err) {\n      logger.error(\"closecall clock: round creation failed\", {\n        roundId: roundId.toString(\"hex\"),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Tick loop\n  // -----------------------------------------------------------------------\n\n  async function tick(): Promise<void> {\n    const t0 = performance.now();\n\n    // Step 1: Settle previous round (log + continue on failure)\n    await settlePreviousRound();\n\n    // Step 2: Create new round\n    await createNewRound();\n\n    const elapsed = Math.round(performance.now() - t0);\n    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed });\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await tick();\n    } catch (err) {\n      logger.error(\"closecall clock loop error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      const delay = msUntilNextMinute();\n      timeoutId = setTimeout(loop, delay);\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Public interface\n  // -----------------------------------------------------------------------\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n\n      logger.info(\"closecall clock started\", {\n        serverKey: serverKeypair.publicKey.toBase58(),\n        pythPriceAccount: pythPriceAccount.toBase58(),\n      });\n\n      // Discover any existing round, then schedule first tick\n      discoverActiveRound()\n        .then(() => {\n          if (!running) return;\n          const delay = msUntilNextMinute();\n          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n          timeoutId = setTimeout(loop, delay);\n        })\n        .catch((err) => {\n          logger.error(\"closecall clock: discovery failed\", {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          if (running) {\n            const delay = msUntilNextMinute();\n            timeoutId = setTimeout(loop, delay);\n          }\n        });\n    },\n\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"closecall clock stopped\");\n    },\n\n    get isRunning() {\n      return running;\n    },\n\n    tick,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3301,"cache_read_input_tokens":61830,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3301},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"8633b3b0-5fdf-4016-91d6-cc0febc832c3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TCRvnCmuAkRRLYv7kNTJQ1","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts"}]},"parent_tool_use_id":null,"session_id":"a54ffa4d-9499-4219-a63b-2e98c595bc33","uuid":"16be99bd-7bb2-47e5-982a-d824627a98c9","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts","content":"/**\n * Close Call clock worker — creates and settles rounds on minute boundaries.\n *\n * Each tick (aligned to ~2s after each minute):\n *   1. Settle the previous round if it exists and the candle has closed.\n *   2. Create a new round (stores Pyth open price on-chain).\n *\n * On start, scans for an existing open round (recovery after restart).\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport { Connection, Keypair, PublicKey, type Transaction } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport {\n  buildCloseCallCreateRoundTx,\n  buildCloseCallSettleRoundTx,\n  type CloseCallTxDeps,\n} from \"./settle-tx.js\";\nimport {\n  closeCallRoundDiscriminatorFilter,\n  decodeCloseCallConfig,\n  decodeCloseCallRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Pyth PriceUpdateV2 raw offsets (same layout as pyth.rs)\n// discriminator(8) + write_authority(32) + verification_level(1) = 41\n// PriceFeedMessage: feed_id(32) + price(i64@73) + conf(u64@81) + exponent(i32@89)\n// ---------------------------------------------------------------------------\n\nconst PYTH_PRICE_OFFSET = 41 + 32; // 73\nconst PYTH_EXPO_OFFSET = PYTH_PRICE_OFFSET + 8 + 8; // 89\nconst PYTH_MIN_DATA_LEN = PYTH_EXPO_OFFSET + 4; // 93\n\n/** Close Call on-chain phase values */\nconst PHASE_OPEN = 0;\n\n/** Offset after minute boundary before first tick (ms). */\nconst TICK_OFFSET_MS = 2_000;\n\n/** Maximum retry attempts for a single tx submission. */\nconst MAX_TX_RETRIES = 3;\nconst TX_RETRY_DELAY_MS = 2_000;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface CloseCallClockDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n  /** Pyth BTC/USD push oracle price account on-chain. */\n  pythPriceAccount: PublicKey;\n}\n\nexport interface CloseCallClockWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single tick (exposed for testing). */\n  tick(): Promise<void>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createCloseCallClockWorker(\n  deps: CloseCallClockDeps,\n): CloseCallClockWorker {\n  const { connection, serverKeypair, pythPriceAccount } = deps;\n  const txDeps: CloseCallTxDeps = { connection, serverKeypair };\n\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  /** Active round tracking (in-memory, recovered on start). */\n  let activeRoundId: Buffer | null = null;\n  let activeRoundPda: PublicKey | null = null;\n\n  // -----------------------------------------------------------------------\n  // Helpers\n  // -----------------------------------------------------------------------\n\n  /** Milliseconds until the next minute boundary + offset. */\n  function msUntilNextMinute(): number {\n    const now = Date.now();\n    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    return nextMinute - now + TICK_OFFSET_MS;\n  }\n\n  /** Send a signed transaction and confirm with retry. */\n  async function sendAndConfirm(\n    tx: Transaction,\n    label: string,\n  ): Promise<string> {\n    let lastError: unknown;\n\n    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n      try {\n        const sig = await connection.sendRawTransaction(tx.serialize(), {\n          skipPreflight: false,\n        });\n        const { blockhash, lastValidBlockHeight } =\n          await connection.getLatestBlockhash();\n        const confirmation = await connection.confirmTransaction(\n          { signature: sig, blockhash, lastValidBlockHeight },\n          \"confirmed\",\n        );\n        if (confirmation.value.err) {\n          throw new Error(\n            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n          );\n        }\n        return sig;\n      } catch (err) {\n        lastError = err;\n        if (attempt < MAX_TX_RETRIES - 1) {\n          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n        }\n      }\n    }\n\n    throw lastError;\n  }\n\n  /** Read Pyth price from on-chain account for outcome pre-check. */\n  async function readPythPrice(): Promise<{ price: bigint; expo: number } | null> {\n    const info = await connection.getAccountInfo(pythPriceAccount);\n    if (!info || info.data.length < PYTH_MIN_DATA_LEN) return null;\n    const data = Buffer.from(info.data);\n    const price = data.readBigInt64LE(PYTH_PRICE_OFFSET);\n    const expo = data.readInt32LE(PYTH_EXPO_OFFSET);\n    return { price, expo };\n  }\n\n  /** Read CloseCallConfig for treasury address. */\n  async function readTreasury(): Promise<PublicKey | null> {\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"closecall_config\")],\n      CLOSECALL_PROGRAM_ID,\n    );\n    const info = await connection.getAccountInfo(configPda);\n    if (!info) return null;\n    const config = decodeCloseCallConfig(Buffer.from(info.data));\n    return config.treasury;\n  }\n\n  /**\n   * Discover an existing open round owned by this server (recovery after restart).\n   */\n  async function discoverActiveRound(): Promise<void> {\n    try {\n      const accounts = await connection.getProgramAccounts(\n        CLOSECALL_PROGRAM_ID,\n        { filters: [closeCallRoundDiscriminatorFilter()] },\n      );\n\n      for (const { pubkey, account } of accounts) {\n        try {\n          const round = decodeCloseCallRound(Buffer.from(account.data));\n          if (\n            round.phase === PHASE_OPEN &&\n            round.server.equals(serverKeypair.publicKey)\n          ) {\n            activeRoundPda = pubkey;\n            activeRoundId = Buffer.from(round.roundId);\n            logger.info(\"closecall clock: recovered active round\", {\n              pda: pubkey.toBase58(),\n              roundId: activeRoundId.toString(\"hex\"),\n            });\n            return;\n          }\n        } catch {\n          // Skip undecodeable accounts\n        }\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: discovery scan failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Settlement\n  // -----------------------------------------------------------------------\n\n  /**\n   * Settle the previous round if it exists.\n   * Returns true if settlement succeeded (or no round to settle).\n   */\n  async function settlePreviousRound(): Promise<boolean> {\n    if (!activeRoundPda || !activeRoundId) return true;\n\n    const roundPda = activeRoundPda;\n    const roundId = activeRoundId;\n\n    try {\n      // Read on-chain round\n      const info = await connection.getAccountInfo(roundPda);\n      if (!info) {\n        // Already closed (settled/refunded by someone else or timeout)\n        logger.info(\"closecall clock: round already closed\", {\n          pda: roundPda.toBase58(),\n        });\n        activeRoundPda = null;\n        activeRoundId = null;\n        return true;\n      }\n\n      const round = decodeCloseCallRound(Buffer.from(info.data));\n\n      // Only settle if still Open\n      if (round.phase !== PHASE_OPEN) {\n        logger.info(\"closecall clock: round not in Open phase, skipping\", {\n          pda: roundPda.toBase58(),\n          phase: round.phase,\n        });\n        activeRoundPda = null;\n        activeRoundId = null;\n        return true;\n      }\n\n      // Read Pyth close price + treasury in parallel\n      const [pythPrice, treasury] = await Promise.all([\n        readPythPrice(),\n        readTreasury(),\n      ]);\n\n      if (!pythPrice) {\n        logger.error(\"closecall clock: cannot read Pyth price for settlement\", {\n          pda: roundPda.toBase58(),\n        });\n        return false;\n      }\n      if (!treasury) {\n        logger.error(\"closecall clock: cannot read config treasury\");\n        return false;\n      }\n\n      // Pre-determine outcome to select correct remaining accounts\n      const greenCount = round.greenEntries.length;\n      const redCount = round.redEntries.length;\n      const totalCount = greenCount + redCount;\n      const hasBothSides = greenCount > 0 && redCount > 0;\n\n      const isRefund =\n        totalCount === 0 ||\n        !hasBothSides ||\n        totalCount === 1 ||\n        pythPrice.price === round.openPrice;\n\n      let remainingAccounts: PublicKey[];\n      if (isRefund) {\n        // All players: green entries then red entries (entry order)\n        remainingAccounts = [\n          ...round.greenEntries.map((e) => e.player),\n          ...round.redEntries.map((e) => e.player),\n        ];\n      } else if (pythPrice.price > round.openPrice) {\n        // Green wins — only green bettors\n        remainingAccounts = round.greenEntries.map((e) => e.player);\n      } else {\n        // Red wins — only red bettors\n        remainingAccounts = round.redEntries.map((e) => e.player);\n      }\n\n      const tx = await buildCloseCallSettleRoundTx(\n        txDeps,\n        roundId,\n        pythPriceAccount,\n        treasury,\n        remainingAccounts,\n      );\n\n      const sig = await sendAndConfirm(tx, \"settle\");\n\n      logger.info(\"closecall clock: round settled\", {\n        pda: roundPda.toBase58(),\n        tx: sig,\n        totalEntries: totalCount,\n        outcome: isRefund\n          ? \"refund\"\n          : pythPrice.price > round.openPrice\n            ? \"green\"\n            : \"red\",\n      });\n\n      activeRoundPda = null;\n      activeRoundId = null;\n      return true;\n    } catch (err) {\n      logger.error(\"closecall clock: settlement failed\", {\n        pda: roundPda.toBase58(),\n        error: err instanceof Error ? err.message : String(err),\n      });\n      // Clear active round — timeout_refund will handle it\n      activeRoundPda = null;\n      activeRoundId = null;\n      return false;\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Round creation\n  // -----------------------------------------------------------------------\n\n  async function createNewRound(): Promise<void> {\n    const roundId = randomBytes(8);\n\n    try {\n      const { tx, roundPda } = await buildCloseCallCreateRoundTx(\n        txDeps,\n        roundId,\n        pythPriceAccount,\n      );\n\n      const sig = await sendAndConfirm(tx, \"create_round\");\n\n      activeRoundId = roundId;\n      activeRoundPda = roundPda;\n\n      logger.info(\"closecall clock: new round created\", {\n        pda: roundPda.toBase58(),\n        roundId: roundId.toString(\"hex\"),\n        tx: sig,\n      });\n    } catch (err) {\n      logger.error(\"closecall clock: round creation failed\", {\n        roundId: roundId.toString(\"hex\"),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Tick loop\n  // -----------------------------------------------------------------------\n\n  async function tick(): Promise<void> {\n    const t0 = performance.now();\n\n    // Step 1: Settle previous round (log + continue on failure)\n    await settlePreviousRound();\n\n    // Step 2: Create new round\n    await createNewRound();\n\n    const elapsed = Math.round(performance.now() - t0);\n    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed });\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await tick();\n    } catch (err) {\n      logger.error(\"closecall clock loop error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      const delay = msUntilNextMinute();\n      timeoutId = setTimeout(loop, delay);\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Public interface\n  // -----------------------------------------------------------------------\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n\n      logger.info(\"closecall clock started\", {\n        serverKey: serverKeypair.publicKey.toBase58(),\n        pythPriceAccount: pythPriceAccount.toBase58(),\n      });\n\n      // Discover any existing round, then schedule first tick\n      discoverActiveRound()\n        .then(() => {\n          if (!running) return;\n          const delay = msUntilNextMinute();\n          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n          timeoutId = setTimeout(loop, delay);\n        })\n        .catch((err) => {\n          logger.error(\"closecall clock: discovery failed\", {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          if (running) {\n            const delay = msUntilNextMinute();\n            timeoutId = setTimeout(loop, delay);\n          }\n        });\n    },\n\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"closecall clock stopped\");\n    },\n\n    get isRunning() {\n      return running;\n    },\n\n    tick,\n  };\n}\n","structuredPatch":[],"originalFile":null}}
