{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017FEEUhzPL8LkkQRLHNx6Px","type":"tool_result","content":"     1→/**\n     2→ * Close Call clock worker — creates and settles rounds on minute boundaries.\n     3→ *\n     4→ * Each tick (aligned to ~2s after each minute):\n     5→ *   1. Settle the previous round if it exists and the candle has closed.\n     6→ *   2. Create a new round (stores Pyth open price on-chain).\n     7→ *\n     8→ * On start, scans for an existing open round (recovery after restart).\n     9→ */\n    10→\n    11→import { randomBytes } from \"node:crypto\";\n    12→import { performance } from \"node:perf_hooks\";\n    13→import { Connection, Keypair, PublicKey, type Transaction } from \"@solana/web3.js\";\n    14→import { logger } from \"../logger.js\";\n    15→import { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    16→import {\n    17→  buildCloseCallCreateRoundTx,\n    18→  buildCloseCallSettleRoundTx,\n    19→  type CloseCallTxDeps,\n    20→} from \"./settle-tx.js\";\n    21→import {\n    22→  closeCallRoundDiscriminatorFilter,\n    23→  decodeCloseCallConfig,\n    24→  decodeCloseCallRound,\n    25→} from \"./account-decoder.js\";\n    26→\n    27→// ---------------------------------------------------------------------------\n    28→// Pyth PriceUpdateV2 raw offsets (same layout as pyth.rs)\n    29→// discriminator(8) + write_authority(32) + verification_level(1) = 41\n    30→// PriceFeedMessage: feed_id(32) + price(i64@73) + conf(u64@81) + exponent(i32@89)\n    31→// ---------------------------------------------------------------------------\n    32→\n    33→const PYTH_PRICE_OFFSET = 41 + 32; // 73\n    34→const PYTH_EXPO_OFFSET = PYTH_PRICE_OFFSET + 8 + 8; // 89\n    35→const PYTH_MIN_DATA_LEN = PYTH_EXPO_OFFSET + 4; // 93\n    36→\n    37→/** Close Call on-chain phase values */\n    38→const PHASE_OPEN = 0;\n    39→\n    40→/** Offset after minute boundary before first tick (ms). */\n    41→const TICK_OFFSET_MS = 2_000;\n    42→\n    43→/** Maximum retry attempts for a single tx submission. */\n    44→const MAX_TX_RETRIES = 3;\n    45→const TX_RETRY_DELAY_MS = 2_000;\n    46→\n    47→// ---------------------------------------------------------------------------\n    48→// Types\n    49→// ---------------------------------------------------------------------------\n    50→\n    51→export interface CloseCallClockDeps {\n    52→  connection: Connection;\n    53→  serverKeypair: Keypair;\n    54→  /** Pyth BTC/USD push oracle price account on-chain. */\n    55→  pythPriceAccount: PublicKey;\n    56→}\n    57→\n    58→export interface CloseCallClockWorker {\n    59→  start(): void;\n    60→  stop(): void;\n    61→  readonly isRunning: boolean;\n    62→  /** Run a single tick (exposed for testing). */\n    63→  tick(): Promise<void>;\n    64→}\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Factory\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export function createCloseCallClockWorker(\n    71→  deps: CloseCallClockDeps,\n    72→): CloseCallClockWorker {\n    73→  const { connection, serverKeypair, pythPriceAccount } = deps;\n    74→  const txDeps: CloseCallTxDeps = { connection, serverKeypair };\n    75→\n    76→  let running = false;\n    77→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    78→\n    79→  /** Active round tracking (in-memory, recovered on start). */\n    80→  let activeRoundId: Buffer | null = null;\n    81→  let activeRoundPda: PublicKey | null = null;\n    82→\n    83→  // -----------------------------------------------------------------------\n    84→  // Helpers\n    85→  // -----------------------------------------------------------------------\n    86→\n    87→  /** Milliseconds until the next minute boundary + offset. */\n    88→  function msUntilNextMinute(): number {\n    89→    const now = Date.now();\n    90→    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    91→    return nextMinute - now + TICK_OFFSET_MS;\n    92→  }\n    93→\n    94→  /** Send a signed transaction and confirm with retry. */\n    95→  async function sendAndConfirm(\n    96→    tx: Transaction,\n    97→    label: string,\n    98→  ): Promise<string> {\n    99→    let lastError: unknown;\n   100→"}]},"parent_tool_use_id":"toolu_01TVrhQDzjNAbznhSJSQdJTY","session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"bc470419-30d5-4be7-8453-ad42dfaf6148"}
