{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0178LHF44XCp9g6nW1Uc5dBn","type":"tool_result","content":"     1→import { randomBytes, createHash } from \"node:crypto\";\n     2→import { PublicKey } from \"@solana/web3.js\";\n     3→import { CoinflipIDL as coinflipIdl } from \"@rng-utopia/anchor-client\";\n     4→\n     5→export const COINFLIP_PROGRAM_ID = new PublicKey(\n     6→  coinflipIdl.address,\n     7→);\n     8→\n     9→/** Generate a 32-byte cryptographically secure random secret. */\n    10→export function generateSecret(): Buffer {\n    11→  return randomBytes(32);\n    12→}\n    13→\n    14→/** Generate an 8-byte random match ID. */\n    15→export function generateMatchId(): Buffer {\n    16→  return randomBytes(8);\n    17→}\n    18→\n    19→/**\n    20→ * Compute commitment = sha256(secret).\n    21→ * Matches the algorithm in packages/fairness/src/commitment.ts.\n    22→ */\n    23→export function computeCommitment(secret: Buffer): Buffer {\n    24→  return createHash(\"sha256\").update(secret).digest();\n    25→}\n    26→\n    27→/**\n    28→ * Derive match PDA using seeds [\"match\", creator, matchId].\n    29→ * Matches the on-chain program's PDA derivation.\n    30→ */\n    31→export function deriveMatchPda(\n    32→  creator: PublicKey,\n    33→  matchId: Buffer,\n    34→): [PublicKey, number] {\n    35→  return PublicKey.findProgramAddressSync(\n    36→    [Buffer.from(\"match\"), creator.toBuffer(), matchId],\n    37→    COINFLIP_PROGRAM_ID,\n    38→  );\n    39→}\n    40→"}]},"parent_tool_use_id":"toolu_01TVrhQDzjNAbznhSJSQdJTY","session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"1471c77c-e68d-41f4-9b84-8b9490b62360"}
