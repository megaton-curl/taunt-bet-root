{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S7KD1tzJzmHGtk1MYCejpA","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n     3→import { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\n     4→import { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\n     5→import type { Db } from \"../db.js\";\n     6→import { logger } from \"../logger.js\";\n     7→import type { AppEnv } from \"../hono-env.js\";\n     8→import type { PdaWatcher } from \"../worker/pda-watcher.js\";\n     9→\n    10→export interface LordCreateRoutesDeps {\n    11→  db: Db;\n    12→  connection: Connection;\n    13→  serverKeypair: Keypair;\n    14→  pdaWatcher?: PdaWatcher;\n    15→}\n    16→\n    17→const MIN_WAGER_LAMPORTS = 1_000_000;\n    18→\n    19→interface CreateLordRequestBody {\n    20→  wallet: string;\n    21→  amountLamports: number;\n    22→}\n    23→\n    24→function isValidBase58(s: string): boolean {\n    25→  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n    26→}\n    27→\n    28→function validateBody(body: unknown): CreateLordRequestBody {\n    29→  if (!body || typeof body !== \"object\") {\n    30→    throw new Error(\"Request body must be a JSON object\");\n    31→  }\n    32→\n    33→  const b = body as Record<string, unknown>;\n    34→\n    35→  if (typeof b.wallet !== \"string\" || !isValidBase58(b.wallet)) {\n    36→    throw new Error(\"wallet must be a valid base58 public key\");\n    37→  }\n    38→\n    39→  if (\n    40→    typeof b.amountLamports !== \"number\" ||\n    41→    !Number.isInteger(b.amountLamports) ||\n    42→    b.amountLamports < MIN_WAGER_LAMPORTS\n    43→  ) {\n    44→    throw new Error(`amountLamports must be an integer >= ${MIN_WAGER_LAMPORTS}`);\n    45→  }\n    46→\n    47→  return {\n    48→    wallet: b.wallet,\n    49→    amountLamports: b.amountLamports,\n    50→  };\n    51→}\n    52→\n    53→export function createLordRoutes(deps: LordCreateRoutesDeps) {\n    54→  const { db, connection, serverKeypair, pdaWatcher } = deps;\n    55→  const app = new Hono<AppEnv>();\n    56→\n    57→  app.post(\"/create\", async (c) => {\n    58→    let body: CreateLordRequestBody;\n    59→    try {\n    60→      body = validateBody(await c.req.json());\n    61→    } catch (err) {\n    62→      return c.json(\n    63→        { error: err instanceof Error ? err.message : \"Invalid request body\" },\n    64→        400,\n    65→      );\n    66→    }\n    67→\n    68→    const jwtWallet = c.get(\"wallet\") as string | undefined;\n    69→    if (jwtWallet && body.wallet !== jwtWallet) {\n    70→      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n    71→    }\n    72→\n    73→    let creatorPubkey: PublicKey;\n    74→    try {\n    75→      creatorPubkey = new PublicKey(body.wallet);\n    76→    } catch {\n    77→      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n    78→    }\n    79→\n    80→    const secret = generateSecret();\n    81→    const commitment = computeCommitment(secret);\n    82→    const matchId = generateMatchId();\n    83→    const matchIdHex = matchId.toString(\"hex\");\n    84→    const [roundPda] = deriveLordRoundPda(matchId);\n    85→    const roundPdaStr = roundPda.toBase58();\n    86→\n    87→    const existing = await db.getRoundByPda(roundPdaStr);\n    88→    if (existing) {\n    89→      return c.json({ error: \"Round ID collision — please retry\" }, 409);\n    90→    }\n    91→\n    92→    let transaction: string;\n    93→    let lastValidBlockHeight: number;\n    94→    try {\n    95→      const result = await buildCreateLordRoundTx({\n    96→        connection,\n    97→        creator: creatorPubkey,\n    98→        serverKeypair,\n    99→        commitment,\n   100→        amountLamports: body.amountLamports,\n   101→        matchId,\n   102→      });\n   103→      transaction = result.transaction;\n   104→      lastValidBlockHeight = result.lastValidBlockHeight;\n   105→    } catch (err) {\n   106→      logger.error(\"lord create failed: transaction build error\", {\n   107→        wallet: body.wallet,\n   108→        roundPda: roundPdaStr,\n   109→        error: err instanceof Error ? err.message : \"Failed to build transaction\",\n   110→      });\n   111→      return c.json({ error: \"Failed to build transaction\" }, 500);\n   112→    }\n   113→\n   114→    try {\n   115→      await db.insertRound({\n   116→        pda: roundPdaStr,\n   117→        game: \"lord\",\n   118→        creator: body.wallet,\n   119→        serverKey: serverKeypair.publicKey.toBase58(),\n   120→        secret,\n   121→        commitment,\n   122→        amountLamports: body.amountLamports,\n   123→        side: 0,\n   124→        matchId: matchIdHex,\n   125→        phase: \"created\",\n   126→      });\n   127→    } catch (err) {\n   128→      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n   129→        return c.json({ error: \"Round ID collision — please retry\" }, 409);\n   130→      }\n   131→      throw err;\n   132→    }\n   133→\n   134→    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n   135→      creator: body.wallet,\n   136→      amountLamports: body.amountLamports,\n   137→      matchId: matchIdHex,\n   138→      game: \"lord\",\n   139→    });\n   140→\n   141→    // Subscribe to PDA for instant join/countdown detection via WebSocket\n   142→    pdaWatcher?.watch(roundPdaStr);\n   143→\n   144→    return c.json({\n   145→      transaction,\n   146→      roundPda: roundPdaStr,\n   147→      matchId: matchIdHex,\n   148→      commitment: commitment.toString(\"hex\"),\n   149→      lastValidBlockHeight,\n   150→    });\n   151→  });\n   152→\n   153→  return app;\n   154→}\n   155→"}]},"parent_tool_use_id":null,"session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"9c756fd3-10b3-4557-a7de-f1872f601e24","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/lord-create.ts","content":"import { Hono } from \"hono\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\nimport { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\n\nexport interface LordCreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\nconst MIN_WAGER_LAMPORTS = 1_000_000;\n\ninterface CreateLordRequestBody {\n  wallet: string;\n  amountLamports: number;\n}\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\nfunction validateBody(body: unknown): CreateLordRequestBody {\n  if (!body || typeof body !== \"object\") {\n    throw new Error(\"Request body must be a JSON object\");\n  }\n\n  const b = body as Record<string, unknown>;\n\n  if (typeof b.wallet !== \"string\" || !isValidBase58(b.wallet)) {\n    throw new Error(\"wallet must be a valid base58 public key\");\n  }\n\n  if (\n    typeof b.amountLamports !== \"number\" ||\n    !Number.isInteger(b.amountLamports) ||\n    b.amountLamports < MIN_WAGER_LAMPORTS\n  ) {\n    throw new Error(`amountLamports must be an integer >= ${MIN_WAGER_LAMPORTS}`);\n  }\n\n  return {\n    wallet: b.wallet,\n    amountLamports: b.amountLamports,\n  };\n}\n\nexport function createLordRoutes(deps: LordCreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n  const app = new Hono<AppEnv>();\n\n  app.post(\"/create\", async (c) => {\n    let body: CreateLordRequestBody;\n    try {\n      body = validateBody(await c.req.json());\n    } catch (err) {\n      return c.json(\n        { error: err instanceof Error ? err.message : \"Invalid request body\" },\n        400,\n      );\n    }\n\n    const jwtWallet = c.get(\"wallet\") as string | undefined;\n    if (jwtWallet && body.wallet !== jwtWallet) {\n      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n    }\n\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n    }\n\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n    const matchIdHex = matchId.toString(\"hex\");\n    const [roundPda] = deriveLordRoundPda(matchId);\n    const roundPdaStr = roundPda.toBase58();\n\n    const existing = await db.getRoundByPda(roundPdaStr);\n    if (existing) {\n      return c.json({ error: \"Round ID collision — please retry\" }, 409);\n    }\n\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateLordRoundTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (err) {\n      logger.error(\"lord create failed: transaction build error\", {\n        wallet: body.wallet,\n        roundPda: roundPdaStr,\n        error: err instanceof Error ? err.message : \"Failed to build transaction\",\n      });\n      return c.json({ error: \"Failed to build transaction\" }, 500);\n    }\n\n    try {\n      await db.insertRound({\n        pda: roundPdaStr,\n        game: \"lord\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: 0,\n        matchId: matchIdHex,\n        phase: \"created\",\n      });\n    } catch (err) {\n      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n        return c.json({ error: \"Round ID collision — please retry\" }, 409);\n      }\n      throw err;\n    }\n\n    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      matchId: matchIdHex,\n      game: \"lord\",\n    });\n\n    // Subscribe to PDA for instant join/countdown detection via WebSocket\n    pdaWatcher?.watch(roundPdaStr);\n\n    return c.json({\n      transaction,\n      roundPda: roundPdaStr,\n      matchId: matchIdHex,\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    });\n  });\n\n  return app;\n}\n","numLines":155,"startLine":1,"totalLines":155}}}
