{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0112uJBAZpybGzujAM7jT9oW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XZ43N3C2D2nNN1ukD2My82","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/closecall.ts","content":"/**\n * Close Call API routes.\n *\n * GET /closecall/current-round — active round + pool state\n * GET /closecall/history       — last N settled/refunded rounds\n */\n\nimport { Hono } from \"hono\";\nimport type { CloseCallRound, Db } from \"../db.js\";\n\nexport interface CloseCallRoutesDeps {\n  db: Db;\n}\n\nfunction formatCloseCallRound(round: CloseCallRound) {\n  const totalPool = round.green_pool + round.red_pool;\n  return {\n    roundId: round.round_id,\n    pda: round.pda,\n    phase: round.phase,\n    openPrice: round.open_price,\n    openPriceExpo: round.open_price_expo,\n    closePrice: round.close_price,\n    outcome: round.outcome,\n    greenPool: round.green_pool,\n    redPool: round.red_pool,\n    totalPool,\n    totalFee: round.total_fee,\n    greenEntries: round.green_entries,\n    redEntries: round.red_entries,\n    greenCount: round.green_entries.length,\n    redCount: round.red_entries.length,\n    settleTx: round.settle_tx,\n    createdAt: round.created_at.toISOString(),\n    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n  };\n}\n\nexport function createCloseCallRoutes(deps: CloseCallRoutesDeps): Hono {\n  const { db } = deps;\n  const app = new Hono();\n\n  app.get(\"/current-round\", async (c) => {\n    const round = await db.getCloseCallCurrentRound();\n    if (!round) {\n      return c.json({ round: null });\n    }\n    return c.json({ round: formatCloseCallRound(round) });\n  });\n\n  app.get(\"/history\", async (c) => {\n    const limitParam = c.req.query(\"limit\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n    const rounds = await db.getCloseCallHistory(limit);\n    return c.json({ rounds: rounds.map(formatCloseCallRound) });\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":970,"cache_read_input_tokens":66035,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":970},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"f5111558-5398-4ed1-abf5-106a19448cb2"}
