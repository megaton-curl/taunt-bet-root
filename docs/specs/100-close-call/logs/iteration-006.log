{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017XBV7cD7RnYSTQvR9ZWJma","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    23→import {\n    24→  decodeCoinflipMatch,\n    25→  decodeCoinflipConfig,\n    26→  decodeLordRound,\n    27→  decodeLordConfig,\n    28→  type DecodedJackpotRound,\n    29→} from \"./account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→function getInstructionDiscriminator(\n    36→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    37→  instructionName: string,\n    38→): Buffer {\n    39→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    40→  if (!instruction) {\n    41→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    42→  }\n    43→  return Buffer.from(instruction.discriminator);\n    44→}\n    45→\n    46→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    47→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    48→  lordIdl,\n    49→  \"claim_payout\",\n    50→);\n    51→const CC_CREATE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"create_round\");\n    52→const CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    53→const CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    54→\n    55→// ---------------------------------------------------------------------------\n    56→// Types\n    57→// ---------------------------------------------------------------------------\n    58→\n    59→export interface SettleTxDeps {\n    60→  db: Db;\n    61→  connection: Connection;\n    62→  serverKeypair: Keypair;\n    63→  entropyAccount: PublicKey;\n    64→}\n    65→\n    66→export interface SettleResult {\n    67→  txSignature: string;\n    68→  resultHash: Buffer;\n    69→  resultSide?: number;\n    70→  winningEntryIndex?: number;\n    71→  winner: string;\n    72→}\n    73→\n    74→// ---------------------------------------------------------------------------\n    75→// PDA helpers\n    76→// ---------------------------------------------------------------------------\n    77→\n    78→function deriveConfigPda(): [PublicKey, number] {\n    79→  return PublicKey.findProgramAddressSync(\n    80→    [Buffer.from(\"coinflip_config\")],\n    81→    COINFLIP_PROGRAM_ID,\n    82→  );\n    83→}\n    84→\n    85→function deriveLordConfigPda(): [PublicKey, number] {\n    86→  return PublicKey.findProgramAddressSync(\n    87→    [Buffer.from(\"lord_config\")],\n    88→    LORDOFRNGS_PROGRAM_ID,\n    89→  );\n    90→}\n    91→\n    92→// ---------------------------------------------------------------------------\n    93→// Instruction encoding\n    94→// ---------------------------------------------------------------------------\n    95→\n    96→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    97→function encodeSettleData(secret: Buffer): Buffer {\n    98→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    99→}\n   100→\n   101→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n   102→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n   103→}\n   104→\n   105→// ---------------------------------------------------------------------------\n   106→// Result derivation (mirrors on-chain derive_result)\n   107→// ---------------------------------------------------------------------------\n   108→\n   109→/**\n   110→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n   111→ * Must match shared/src/fairness.rs `derive_result()`.\n   112→ */\n   113→function deriveResult(\n   114→  secret: Buffer,\n   115→  entropy: Buffer,\n   116→  matchPdaBytes: Buffer,\n   117→  algoVer: number,\n   118→): Buffer {\n   119→  return createHash(\"sha256\")\n   120→    .update(secret)\n   121→    .update(entropy)\n   122→    .update(matchPdaBytes)\n   123→    .update(Buffer.from([algoVer]))\n   124→    .digest();\n   125→}\n   126→\n   127→// ---------------------------------------------------------------------------\n   128→// Core settle function\n   129→// ---------------------------------------------------------------------------\n   130→\n   131→/**\n   132→ * Build, submit, and confirm a settle transaction for a locked match.\n   133→ *\n   134→ * Steps:\n   135→ * 1. Retrieve secret from DB\n   136→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   137→ * 3. Fetch config account data (treasury)\n   138→ * 4. Read entropy from the entropy account\n   139→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   140→ * 6. Build + submit settle tx\n   141→ * 7. Update DB on confirmation\n   142→ */\n   143→export async function settleMatch(\n   144→  deps: SettleTxDeps,\n   145→  pda: string,\n   146→): Promise<SettleResult> {\n   147→  const t0 = performance.now();\n   148→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   149→  const matchPubkey = new PublicKey(pda);\n   150→\n   151→  // 1. Retrieve secret from DB\n   152→  const round = await db.getRoundByPda(pda);\n   153→  const tDb = performance.now();\n   154→  if (!round) {\n   155→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   156→  }\n   157→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   158→    throw new PermanentSettleError(\n   159→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   160→    );\n   161→  }\n   162→\n   163→  const secret = Buffer.from(round.secret);\n   164→\n   165→  // Transition to settling (locked → settling)\n   166→  if (round.phase === \"locked\") {\n   167→    await db.updateRoundPhase(pda, \"settling\");\n   168→  }\n   169→\n   170→  // Log settle_submitted\n   171→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   172→    attempt: round.settle_attempts + 1,\n   173→  });\n   174→\n   175→  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n   176→  const [configPda] = deriveConfigPda();\n   177→  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   178→    await Promise.all([\n   179→      connection.getAccountInfo(matchPubkey),\n   180→      connection.getAccountInfo(configPda),\n   181→      connection.getAccountInfo(entropyAccount),\n   182→      connection.getLatestBlockhash(),\n   183→    ]);\n   184→  const tFetch = performance.now();\n   185→\n   186→  if (!matchAccountInfo) {\n   187→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   188→  }\n   189→  if (!configAccountInfo) {\n   190→    throw new PermanentSettleError(\"Coinflip config account not found\");\n   191→  }\n   192→  if (!entropyInfo) {\n   193→    throw new TransientSettleError(\"Entropy account not available yet\");\n   194→  }\n   195→\n   196→  // IDL-driven decode — no manual byte offsets\n   197→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   198→  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n   199→\n   200→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   201→  const { treasury } = config;\n   202→\n   203→  const pool = entryAmount * 2n;\n   204→  const feeAmount = Number((pool * 300n) / 10_000n);\n   205→  const payoutAmount = Number(pool) - feeAmount;\n   206→\n   207→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   208→\n   209→  // 5. Pre-compute result\n   210→  const matchPdaBytes = matchPubkey.toBuffer();\n   211→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   212→  const resultSide = resultHash[0]! % 2;\n   213→  const winner = resultSide === creatorSide ? creator : opponent;\n   214→\n   215→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   216→  const data = encodeSettleData(secret);\n   217→\n   218→  const instruction = new TransactionInstruction({\n   219→    keys: [\n   220→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   221→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   222→      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n   223→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   224→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   225→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   226→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   227→      {\n   228→        pubkey: SystemProgram.programId,\n   229→        isSigner: false,\n   230→        isWritable: false,\n   231→      }, // system_program\n   232→    ],\n   233→    programId: COINFLIP_PROGRAM_ID,\n   234→    data,\n   235→  });\n   236→\n   237→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   238→\n   239→  const tx = new Transaction({\n   240→    feePayer: serverKeypair.publicKey,\n   241→    blockhash,\n   242→    lastValidBlockHeight,\n   243→  });\n   244→  tx.add(instruction);\n   245→  tx.sign(serverKeypair);\n   246→\n   247→  // 7. Submit and confirm\n   248→  const rawTx = tx.serialize();\n   249→  const tBuild = performance.now();\n   250→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   251→    skipPreflight: false,\n   252→  });\n   253→  const tSend = performance.now();\n   254→\n   255→  logger.info(\"settlement transaction submitted\", {\n   256→    pda,\n   257→    txSignature,\n   258→    attempt: round.settle_attempts + 1,\n   259→    dbMs: Math.round(tDb - t0),\n   260→    fetchMs: Math.round(tFetch - tDb),\n   261→    buildMs: Math.round(tBuild - tFetch),\n   262→    sendMs: Math.round(tSend - tBuild),\n   263→  });\n   264→\n   265→  const confirmation = await connection.confirmTransaction(\n   266→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   267→    \"confirmed\",\n   268→  );\n   269→  const tConfirm = performance.now();\n   270→  if (confirmation.value.err) {\n   271→    throw new TransientSettleError(\n   272→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   273→    );\n   274→  }\n   275→\n   276→  // 8. Update DB — phase settling → settled\n   277→  await db.updateRoundPhase(pda, \"settled\", {\n   278→    settle_tx: txSignature,\n   279→    result_hash: resultHash,\n   280→    result_side: resultSide,\n   281→    winner: winner.toBase58(),\n   282→    settle_attempts: round.settle_attempts + 1,\n   283→  });\n   284→\n   285→  // Log settle_confirmed\n   286→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   287→    txSignature,\n   288→    resultSide,\n   289→    winner: winner.toBase58(),\n   290→    entropy: entropy.toString(\"hex\"),\n   291→    payoutAmount,\n   292→    feeAmount,\n   293→  });\n   294→\n   295→  const tDone = performance.now();\n   296→  logger.info(\"settlement transaction confirmed\", {\n   297→    pda,\n   298→    txSignature,\n   299→    resultSide,\n   300→    winner: winner.toBase58(),\n   301→    timing: {\n   302→      dbMs: Math.round(tDb - t0),\n   303→      fetchMs: Math.round(tFetch - tDb),\n   304→      buildMs: Math.round(tBuild - tFetch),\n   305→      sendMs: Math.round(tSend - tBuild),\n   306→      confirmMs: Math.round(tConfirm - tSend),\n   307→      dbWriteMs: Math.round(tDone - tConfirm),\n   308→      totalMs: Math.round(tDone - t0),\n   309→    },\n   310→  });\n   311→\n   312→  return {\n   313→    txSignature,\n   314→    resultHash,\n   315→    resultSide,\n   316→    winner: winner.toBase58(),\n   317→  };\n   318→}\n   319→\n   320→export async function settleLordRound(\n   321→  deps: SettleTxDeps,\n   322→  pda: string,\n   323→): Promise<SettleResult> {\n   324→  const t0 = performance.now();\n   325→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   326→  const roundPubkey = new PublicKey(pda);\n   327→\n   328→  const round = await db.getRoundByPda(pda);\n   329→  const tDb = performance.now();\n   330→  if (!round) {\n   331→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   332→  }\n   333→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   334→    throw new PermanentSettleError(\n   335→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   336→    );\n   337→  }\n   338→\n   339→  const secret = Buffer.from(round.secret);\n   340→\n   341→  if (round.phase === \"locked\") {\n   342→    await db.updateRoundPhase(pda, \"settling\");\n   343→  }\n   344→\n   345→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   346→    attempt: round.settle_attempts + 1,\n   347→    game: \"lord\",\n   348→  });\n   349→\n   350→  const [configPda] = deriveLordConfigPda();\n   351→  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   352→    await Promise.all([\n   353→      connection.getAccountInfo(roundPubkey),\n   354→      connection.getAccountInfo(configPda),\n   355→      connection.getAccountInfo(entropyAccount),\n   356→      connection.getLatestBlockhash(),\n   357→    ]);\n   358→\n   359→  const tFetch = performance.now();\n   360→\n   361→  if (!roundAccountInfo) {\n   362→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   363→  }\n   364→  if (!configAccountInfo) {\n   365→    throw new PermanentSettleError(\"Lord config account not found\");\n   366→  }\n   367→  if (!entropyInfo) {\n   368→    throw new TransientSettleError(\"Entropy account not available yet\");\n   369→  }\n   370→\n   371→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   372→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   373→  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n   374→  const { treasury } = lordConfig;\n   375→\n   376→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   377→  const resultHash = deriveResult(\n   378→    secret,\n   379→    entropy,\n   380→    roundPubkey.toBuffer(),\n   381→    roundData.algorithmVer,\n   382→  );\n   383→  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n   384→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   385→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   386→\n   387→  const raw = resultHash.readBigUInt64LE(0);\n   388→  const winningOffset = raw % roundData.totalAmountLamports;\n   389→\n   390→  let cumulative = 0n;\n   391→  let winnerEntryIndex = -1;\n   392→  let winner = roundData.entries[0]?.player;\n   393→  for (const [index, entry] of roundData.entries.entries()) {\n   394→    cumulative += entry.amountLamports;\n   395→    if (winningOffset < cumulative) {\n   396→      winnerEntryIndex = index;\n   397→      winner = entry.player;\n   398→      break;\n   399→    }\n   400→  }\n   401→\n   402→  if (!winner || winnerEntryIndex < 0) {\n   403→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   404→  }\n   405→\n   406→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   407→  const instruction = new TransactionInstruction({\n   408→    keys: [\n   409→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   410→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   411→      { pubkey: configPda, isSigner: false, isWritable: false },\n   412→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   413→      { pubkey: treasury, isSigner: false, isWritable: true },\n   414→      { pubkey: winner, isSigner: false, isWritable: true },\n   415→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   416→    ],\n   417→    programId: LORDOFRNGS_PROGRAM_ID,\n   418→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   419→  });\n   420→\n   421→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   422→  const tx = new Transaction({\n   423→    feePayer: serverKeypair.publicKey,\n   424→    blockhash,\n   425→    lastValidBlockHeight,\n   426→  });\n   427→  tx.add(instruction);\n   428→  tx.sign(serverKeypair);\n   429→\n   430→  const tBuild = performance.now();\n   431→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   432→    skipPreflight: false,\n   433→  });\n   434→  const tSend = performance.now();\n   435→\n   436→  logger.info(\"lord settlement transaction submitted\", {\n   437→    pda,\n   438→    txSignature,\n   439→    attempt: round.settle_attempts + 1,\n   440→    winningEntryIndex: winnerEntryIndex,\n   441→    dbMs: Math.round(tDb - t0),\n   442→    fetchMs: Math.round(tFetch - tDb),\n   443→    buildMs: Math.round(tBuild - tFetch),\n   444→    sendMs: Math.round(tSend - tBuild),\n   445→  });\n   446→\n   447→  const confirmation = await connection.confirmTransaction(\n   448→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   449→    \"confirmed\",\n   450→  );\n   451→  const tConfirm = performance.now();\n   452→  if (confirmation.value.err) {\n   453→    throw new TransientSettleError(\n   454→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   455→    );\n   456→  }\n   457→\n   458→  await db.updateRoundPhase(pda, \"settled\", {\n   459→    settle_tx: txSignature,\n   460→    result_hash: resultHash,\n   461→    result_side: winnerEntryIndex,\n   462→    winner: winner.toBase58(),\n   463→    settle_attempts: round.settle_attempts + 1,\n   464→  });\n   465→\n   466→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   467→    txSignature,\n   468→    winner: winner.toBase58(),\n   469→    winningEntryIndex: winnerEntryIndex,\n   470→    game: \"lord\",\n   471→    entropy: entropy.toString(\"hex\"),\n   472→    winningOffset: winningOffset.toString(),\n   473→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   474→    payoutAmount,\n   475→    feeAmount,\n   476→    rentRefund,\n   477→  });\n   478→\n   479→  const tDone = performance.now();\n   480→  logger.info(\"lord settlement transaction confirmed\", {\n   481→    pda,\n   482→    txSignature,\n   483→    winner: winner.toBase58(),\n   484→    winningEntryIndex: winnerEntryIndex,\n   485→    timing: {\n   486→      dbMs: Math.round(tDb - t0),\n   487→      fetchMs: Math.round(tFetch - tDb),\n   488→      buildMs: Math.round(tBuild - tFetch),\n   489→      sendMs: Math.round(tSend - tBuild),\n   490→      confirmMs: Math.round(tConfirm - tSend),\n   491→      dbWriteMs: Math.round(tDone - tConfirm),\n   492→      totalMs: Math.round(tDone - t0),\n   493→    },\n   494→  });\n   495→\n   496→  return {\n   497→    txSignature,\n   498→    resultHash,\n   499→    winningEntryIndex: winnerEntryIndex,\n   500→    winner: winner.toBase58(),\n   501→  };\n   502→}\n   503→\n   504→export async function settleRound(\n   505→  deps: SettleTxDeps,\n   506→  pda: string,\n   507→): Promise<SettleResult> {\n   508→  const round = await deps.db.getRoundByPda(pda);\n   509→  if (!round) {\n   510→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   511→  }\n   512→\n   513→  if (round.game === \"lord\") {\n   514→    return settleLordRound(deps, pda);\n   515→  }\n   516→\n   517→  return settleMatch(deps, pda);\n   518→}\n   519→\n   520→// ---------------------------------------------------------------------------\n   521→// Close Call — transaction builders\n   522→// ---------------------------------------------------------------------------\n   523→\n   524→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   525→  return PublicKey.findProgramAddressSync(\n   526→    [Buffer.from(\"closecall_config\")],\n   527→    CLOSECALL_PROGRAM_ID,\n   528→  );\n   529→}\n   530→\n   531→function deriveCloseCallRoundPda(roundId: Buffer): [PublicKey, number] {\n   532→  return PublicKey.findProgramAddressSync(\n   533→    [Buffer.from(\"cc_round\"), roundId],\n   534→    CLOSECALL_PROGRAM_ID,\n   535→  );\n   536→}\n   537→\n   538→/** Encode closecall instruction data: discriminator(8) + round_id(8) = 16 bytes */\n   539→function encodeCcRoundIdData(discriminator: Buffer, roundId: Buffer): Buffer {\n   540→  return Buffer.concat([discriminator, roundId]);\n   541→}\n   542→\n   543→export interface CloseCallTxDeps {\n   544→  connection: Connection;\n   545→  serverKeypair: Keypair;\n   546→}\n   547→\n   548→/**\n   549→ * Build a signed `create_round` transaction for the Close Call program.\n   550→ *\n   551→ * The server pays rent and is the sole signer. The Pyth price account is read\n   552→ * on-chain to store the candle open price.\n   553→ */\n   554→export async function buildCloseCallCreateRoundTx(\n   555→  deps: CloseCallTxDeps,\n   556→  roundId: Buffer,\n   557→  pythPriceAccount: PublicKey,\n   558→): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   559→  const { connection, serverKeypair } = deps;\n   560→\n   561→  const [roundPda] = deriveCloseCallRoundPda(roundId);\n   562→  const [configPda] = deriveCloseCallConfigPda();\n   563→  const data = encodeCcRoundIdData(CC_CREATE_ROUND_DISCRIMINATOR, roundId);\n   564→\n   565→  const instruction = new TransactionInstruction({\n   566→    keys: [\n   567→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // server (pays rent)\n   568→      { pubkey: configPda, isSigner: false, isWritable: false },               // config\n   569→      { pubkey: roundPda, isSigner: false, isWritable: true },                 // round (init)\n   570→      { pubkey: pythPriceAccount, isSigner: false, isWritable: false },        // price_update\n   571→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false }, // system_program\n   572→    ],\n   573→    programId: CLOSECALL_PROGRAM_ID,\n   574→    data,\n   575→  });\n   576→\n   577→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   578→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   579→  tx.add(instruction);\n   580→  tx.sign(serverKeypair);\n   581→\n   582→  return { tx, roundPda };\n   583→}\n   584→\n   585→/**\n   586→ * Build a signed `settle_round` transaction for the Close Call program.\n   587→ *\n   588→ * Reads Pyth close price on-chain to determine outcome. Winners (or all\n   589→ * players for refund) are passed as remaining accounts for auto-payout.\n   590→ */\n   591→export async function buildCloseCallSettleRoundTx(\n   592→  deps: CloseCallTxDeps,\n   593→  roundId: Buffer,\n   594→  pythPriceAccount: PublicKey,\n   595→  treasury: PublicKey,\n   596→  winnerAccounts: PublicKey[],\n   597→): Promise<Transaction> {\n   598→  const { connection, serverKeypair } = deps;\n   599→\n   600→  const [roundPda] = deriveCloseCallRoundPda(roundId);\n   601→  const [configPda] = deriveCloseCallConfigPda();\n   602→  const data = encodeCcRoundIdData(CC_SETTLE_ROUND_DISCRIMINATOR, roundId);\n   603→\n   604→  const keys = [\n   605→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   606→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   607→    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n   608→    { pubkey: pythPriceAccount, isSigner: false, isWritable: false },        // price_update\n   609→    { pubkey: treasury, isSigner: false, isWritable: true },                 // treasury\n   610→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   611→    ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   612→  ];\n   613→\n   614→  const instruction = new TransactionInstruction({\n   615→    keys,\n   616→    programId: CLOSECALL_PROGRAM_ID,\n   617→    data,\n   618→  });\n   619→\n   620→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   621→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   622→  tx.add(instruction);\n   623→  tx.sign(serverKeypair);\n   624→\n   625→  return tx;\n   626→}\n   627→\n   628→/**\n   629→ * Build a signed `timeout_refund` transaction for the Close Call program.\n   630→ *\n   631→ * Permissionless after the resolve deadline. Refunds all players their exact\n   632→ * deposit via remaining accounts.\n   633→ */\n   634→export async function buildCloseCallTimeoutRefundTx(\n   635→  deps: CloseCallTxDeps,\n   636→  roundId: Buffer,\n   637→  playerAccounts: PublicKey[],\n   638→): Promise<Transaction> {\n   639→  const { connection, serverKeypair } = deps;\n   640→\n   641→  const [roundPda] = deriveCloseCallRoundPda(roundId);\n   642→  const [configPda] = deriveCloseCallConfigPda();\n   643→  const data = encodeCcRoundIdData(CC_TIMEOUT_REFUND_DISCRIMINATOR, roundId);\n   644→\n   645→  const keys = [\n   646→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   647→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   648→    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n   649→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   650→    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   651→  ];\n   652→\n   653→  const instruction = new TransactionInstruction({\n   654→    keys,\n   655→    programId: CLOSECALL_PROGRAM_ID,\n   656→    data,\n   657→  });\n   658→\n   659→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   660→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   661→  tx.add(instruction);\n   662→  tx.sign(serverKeypair);\n   663→\n   664→  return tx;\n   665→}\n   666→\n   667→// ---------------------------------------------------------------------------\n   668→// Error types\n   669→// ---------------------------------------------------------------------------\n   670→\n   671→/** Permanent failure — should not be retried. */\n   672→export class PermanentSettleError extends Error {\n   673→  readonly permanent = true;\n   674→  constructor(message: string) {\n   675→    super(message);\n   676→    this.name = \"PermanentSettleError\";\n   677→  }\n   678→}\n   679→\n   680→/** Transient failure — safe to retry. */\n   681→export class TransientSettleError extends Error {\n   682→  readonly permanent = false;\n   683→  constructor(message: string) {\n   684→    super(message);\n   685→    this.name = \"TransientSettleError\";\n   686→  }\n   687→}\n   688→"}]},"parent_tool_use_id":"toolu_017TgsJaBmRzsi276rv1fSSw","session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"b68f2e68-891c-4336-846b-ba4a2dbbac7f"}
