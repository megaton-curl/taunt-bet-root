{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C3eRUtHAqiQbKxFKdYhDwc","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3→\n     4→export interface Config {\n     5→  port: number;\n     6→  databaseUrl: string;\n     7→  dbSchema: string;\n     8→  rpcUrl: string;\n     9→  wsRpcUrl: string | undefined;\n    10→  serverKeypair: Keypair;\n    11→  jwtSecret: Uint8Array;\n    12→  cluster: string;\n    13→  challengeTtlSeconds: number;\n    14→  accessTokenTtlSeconds: number;\n    15→  refreshTokenTtlDays: number;\n    16→  rateLimitPerWallet: number;\n    17→  rateLimitGlobal: number;\n    18→  workerPollIntervalMs: number;\n    19→  entropyAccount: string;\n    20→  minSolBalance: number;\n    21→}\n    22→\n    23→function requireEnv(name: string): string {\n    24→  const value = process.env[name];\n    25→  if (!value) {\n    26→    throw new Error(`Missing required environment variable: ${name}`);\n    27→  }\n    28→  return value;\n    29→}\n    30→\n    31→function parseKeypair(raw: string): Keypair {\n    32→  try {\n    33→    const bytes = JSON.parse(raw) as number[];\n    34→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    35→  } catch {\n    36→    throw new Error(\n    37→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    38→    );\n    39→  }\n    40→}\n    41→\n    42→export function loadConfig(): Config {\n    43→  const dbSchema = loadDbSchemaFromEnv();\n    44→\n    45→  return {\n    46→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    47→    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    48→    dbSchema,\n    49→    rpcUrl: requireEnv(\"RPC_URL\"),\n    50→    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    51→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    52→    jwtSecret: (() => {\n    53→      const explicit = process.env.JWT_SECRET;\n    54→      if (explicit) return new TextEncoder().encode(explicit);\n    55→      // Derive from first 32 bytes of server keypair secret key\n    56→      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    57→      return kp.secretKey.slice(0, 32);\n    58→    })(),\n    59→    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    60→    challengeTtlSeconds: parseInt(\n    61→      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    62→      10,\n    63→    ),\n    64→    accessTokenTtlSeconds: parseInt(\n    65→      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    66→      10,\n    67→    ),\n    68→    refreshTokenTtlDays: parseInt(\n    69→      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    70→      10,\n    71→    ),\n    72→    rateLimitPerWallet: parseInt(\n    73→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    74→      10,\n    75→    ),\n    76→    rateLimitGlobal: parseInt(\n    77→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    78→      10,\n    79→    ),\n    80→    workerPollIntervalMs: parseInt(\n    81→      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    82→      10,\n    83→    ),\n    84→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    85→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    86→  };\n    87→}\n    88→"}]},"parent_tool_use_id":null,"session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"dc3b8cbd-6b29-448a-821d-573626ecd41e","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/config.ts","content":"import { Keypair } from \"@solana/web3.js\";\nimport { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n\nexport interface Config {\n  port: number;\n  databaseUrl: string;\n  dbSchema: string;\n  rpcUrl: string;\n  wsRpcUrl: string | undefined;\n  serverKeypair: Keypair;\n  jwtSecret: Uint8Array;\n  cluster: string;\n  challengeTtlSeconds: number;\n  accessTokenTtlSeconds: number;\n  refreshTokenTtlDays: number;\n  rateLimitPerWallet: number;\n  rateLimitGlobal: number;\n  workerPollIntervalMs: number;\n  entropyAccount: string;\n  minSolBalance: number;\n}\n\nfunction requireEnv(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction parseKeypair(raw: string): Keypair {\n  try {\n    const bytes = JSON.parse(raw) as number[];\n    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n  } catch {\n    throw new Error(\n      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    );\n  }\n}\n\nexport function loadConfig(): Config {\n  const dbSchema = loadDbSchemaFromEnv();\n\n  return {\n    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    dbSchema,\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    jwtSecret: (() => {\n      const explicit = process.env.JWT_SECRET;\n      if (explicit) return new TextEncoder().encode(explicit);\n      // Derive from first 32 bytes of server keypair secret key\n      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n      return kp.secretKey.slice(0, 32);\n    })(),\n    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    challengeTtlSeconds: parseInt(\n      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n      10,\n    ),\n    accessTokenTtlSeconds: parseInt(\n      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n      10,\n    ),\n    refreshTokenTtlDays: parseInt(\n      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n      10,\n    ),\n    rateLimitPerWallet: parseInt(\n      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n      10,\n    ),\n    rateLimitGlobal: parseInt(\n      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n      10,\n    ),\n    workerPollIntervalMs: parseInt(\n      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n      10,\n    ),\n    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n  };\n}\n","numLines":88,"startLine":1,"totalLines":88}}}
