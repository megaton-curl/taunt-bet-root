{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DpxTvnzNQyCmaX3uBEUKHG","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type OperatorEventType =\n    17→  | \"secret_generated\"\n    18→  | \"tx_built\"\n    19→  | \"match_detected\"\n    20→  | \"settle_submitted\"\n    21→  | \"settle_confirmed\"\n    22→  | \"settle_failed\"\n    23→  | \"settle_retried\"\n    24→  | \"timeout_detected\";\n    25→\n    26→export interface Round {\n    27→  pda: string;\n    28→  game: string;\n    29→  creator: string;\n    30→  server_key: string;\n    31→  secret: Buffer;\n    32→  commitment: Buffer;\n    33→  amount_lamports: number;\n    34→  side: number;\n    35→  match_id: string;\n    36→  phase: RoundPhase;\n    37→  target_slot: string | null;\n    38→  settle_tx: string | null;\n    39→  settle_attempts: number;\n    40→  result_hash: Buffer | null;\n    41→  result_side: number | null;\n    42→  winner: string | null;\n    43→  created_at: Date;\n    44→  updated_at: Date;\n    45→}\n    46→\n    47→export interface InsertRoundParams {\n    48→  pda: string;\n    49→  game: string;\n    50→  creator: string;\n    51→  serverKey: string;\n    52→  secret: Buffer;\n    53→  commitment: Buffer;\n    54→  amountLamports: number;\n    55→  side: number;\n    56→  matchId: string;\n    57→  phase: RoundPhase;\n    58→}\n    59→\n    60→export interface OperatorEvent {\n    61→  id: string;\n    62→  pda: string | null;\n    63→  event_type: OperatorEventType;\n    64→  payload: unknown;\n    65→  created_at: Date;\n    66→}\n    67→\n    68→// ---------------------------------------------------------------------------\n    69→// Phase transition guard\n    70→// ---------------------------------------------------------------------------\n    71→\n    72→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n    73→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n    74→  created: [\"locked\", \"expired\"],\n    75→  locked: [\"settling\"],\n    76→  settling: [\"settled\"],\n    77→  settled: [],\n    78→  expired: [],\n    79→};\n    80→\n    81→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n    82→  const allowed = VALID_TRANSITIONS[from];\n    83→  if (!allowed.includes(to)) {\n    84→    throw new Error(\n    85→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    86→    );\n    87→  }\n    88→}\n    89→\n    90→// ---------------------------------------------------------------------------\n    91→// DB client\n    92→// ---------------------------------------------------------------------------\n    93→\n    94→export interface Db {\n    95→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n    96→  insertRound(params: InsertRoundParams): Promise<Round>;\n    97→\n    98→  /** Delete a round by PDA. Returns true if a row was removed. */\n    99→  deleteRoundByPda(pda: string): Promise<boolean>;\n   100→\n   101→  /** Transition a round's phase. Enforces unidirectional state machine.\n   102→   *  Optional `updates` can set additional columns alongside the phase change. */\n   103→  updateRoundPhase(\n   104→    pda: string,\n   105→    newPhase: RoundPhase,\n   106→    updates?: Partial<\n   107→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   108→    >,\n   109→  ): Promise<Round>;\n   110→\n   111→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   112→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   113→\n   114→  /** Get all rounds matching a given phase. */\n   115→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   116→\n   117→  /** Append an operator event to the audit log. */\n   118→  insertOperatorEvent(\n   119→    pda: string | null,\n   120→    eventType: OperatorEventType,\n   121→    payload?: unknown,\n   122→  ): Promise<OperatorEvent>;\n   123→\n   124→  /** Get the latest operator event for a PDA + type. */\n   125→  getLatestOperatorEvent(\n   126→    pda: string,\n   127→    eventType: OperatorEventType,\n   128→  ): Promise<OperatorEvent | undefined>;\n   129→\n   130→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   131→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   132→\n   133→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   134→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   135→\n   136→  /** Gracefully close the connection pool. */\n   137→  close(): Promise<void>;\n   138→}\n   139→\n   140→function normalizeRound(row: Round): Round {\n   141→  return {\n   142→    ...row,\n   143→    amount_lamports: Number(row.amount_lamports),\n   144→    side: Number(row.side),\n   145→    settle_attempts: Number(row.settle_attempts),\n   146→    result_side: row.result_side === null ? null : Number(row.result_side),\n   147→  };\n   148→}\n   149→\n   150→export function createDb(databaseUrl: string): Db {\n   151→  const sql = postgres(databaseUrl);\n   152→\n   153→  return {\n   154→    async insertRound(params) {\n   155→      const rows = await sql<Round[]>`\n   156→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)\n   157→        VALUES (\n   158→          ${params.pda},\n   159→          ${params.game},\n   160→          ${params.creator},\n   161→          ${params.serverKey},\n   162→          ${params.secret},\n   163→          ${params.commitment},\n   164→          ${params.amountLamports},\n   165→          ${params.side},\n   166→          ${params.matchId},\n   167→          ${params.phase}\n   168→        )\n   169→        RETURNING *\n   170→      `;\n   171→      return normalizeRound(rows[0]!);\n   172→    },\n   173→\n   174→    async deleteRoundByPda(pda) {\n   175→      const rows = await sql<{ pda: string }[]>`\n   176→        DELETE FROM rounds WHERE pda = ${pda}\n   177→        RETURNING pda\n   178→      `;\n   179→      return rows.length > 0;\n   180→    },\n   181→\n   182→    async updateRoundPhase(pda, newPhase, updates) {\n   183→      // Fetch current phase to validate transition\n   184→      const current = await sql<Pick<Round, \"phase\">[]>`\n   185→        SELECT phase FROM rounds WHERE pda = ${pda}\n   186→      `;\n   187→\n   188→      if (current.length === 0) {\n   189→        throw new Error(`Round not found: ${pda}`);\n   190→      }\n   191→\n   192→      const currentPhase = current[0]!.phase as RoundPhase;\n   193→      assertPhaseTransition(currentPhase, newPhase);\n   194→\n   195→      // Build the update — always set phase + updated_at\n   196→      const rows = await sql<Round[]>`\n   197→        UPDATE rounds SET\n   198→          phase = ${newPhase},\n   199→          updated_at = now(),\n   200→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   201→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   202→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   203→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   204→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   205→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   206→        WHERE pda = ${pda}\n   207→        RETURNING *\n   208→      `;\n   209→\n   210→      return normalizeRound(rows[0]!);\n   211→    },\n   212→\n   213→    async getRoundByPda(pda) {\n   214→      const rows = await sql<Round[]>`\n   215→        SELECT * FROM rounds WHERE pda = ${pda}\n   216→      `;\n   217→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   218→    },\n   219→\n   220→    async getRoundByMatchId(matchId) {\n   221→      const rows = await sql<Round[]>`\n   222→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   223→      `;\n   224→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   225→    },\n   226→\n   227→    async getRoundsByPhase(phase) {\n   228→      const rows = await sql<Round[]>`\n   229→        SELECT * FROM rounds WHERE phase = ${phase}\n   230→      `;\n   231→      return rows.map(normalizeRound);\n   232→    },\n   233→\n   234→    async insertOperatorEvent(pda, eventType, payload) {\n   235→      const rows = await sql<OperatorEvent[]>`\n   236→        INSERT INTO operator_events (pda, event_type, payload)\n   237→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   238→        RETURNING *\n   239→      `;\n   240→      return rows[0]!;\n   241→    },\n   242→\n   243→    async getLatestOperatorEvent(pda, eventType) {\n   244→      const rows = await sql<OperatorEvent[]>`\n   245→        SELECT * FROM operator_events\n   246→        WHERE pda = ${pda} AND event_type = ${eventType}\n   247→        ORDER BY id DESC\n   248→        LIMIT 1\n   249→      `;\n   250→      return rows[0];\n   251→    },\n   252→\n   253→    async getUnsettledStats() {\n   254→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   255→        SELECT\n   256→          COUNT(*)::text AS count,\n   257→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   258→        FROM rounds\n   259→        WHERE phase NOT IN ('settled', 'expired')\n   260→      `;\n   261→      const row = rows[0]!;\n   262→      return {\n   263→        count: parseInt(row.count, 10),\n   264→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   265→      };\n   266→    },\n   267→\n   268→    async close() {\n   269→      await sql.end();\n   270→    },\n   271→  };\n   272→}\n   273→"}]},"parent_tool_use_id":null,"session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"ed7f37a4-ea02-4b3b-9b68-09dae9520db7","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/db.ts","content":"/**\n * Database client module — typed query functions for `rounds` and `operator_events`.\n *\n * Phase transitions are unidirectional: created → locked → settling → settled,\n * or created → expired. The application layer rejects backward transitions.\n */\n\nimport postgres from \"postgres\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n\nexport type OperatorEventType =\n  | \"secret_generated\"\n  | \"tx_built\"\n  | \"match_detected\"\n  | \"settle_submitted\"\n  | \"settle_confirmed\"\n  | \"settle_failed\"\n  | \"settle_retried\"\n  | \"timeout_detected\";\n\nexport interface Round {\n  pda: string;\n  game: string;\n  creator: string;\n  server_key: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amount_lamports: number;\n  side: number;\n  match_id: string;\n  phase: RoundPhase;\n  target_slot: string | null;\n  settle_tx: string | null;\n  settle_attempts: number;\n  result_hash: Buffer | null;\n  result_side: number | null;\n  winner: string | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface InsertRoundParams {\n  pda: string;\n  game: string;\n  creator: string;\n  serverKey: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amountLamports: number;\n  side: number;\n  matchId: string;\n  phase: RoundPhase;\n}\n\nexport interface OperatorEvent {\n  id: string;\n  pda: string | null;\n  event_type: OperatorEventType;\n  payload: unknown;\n  created_at: Date;\n}\n\n// ---------------------------------------------------------------------------\n// Phase transition guard\n// ---------------------------------------------------------------------------\n\n/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\nconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n  created: [\"locked\", \"expired\"],\n  locked: [\"settling\"],\n  settling: [\"settled\"],\n  settled: [],\n  expired: [],\n};\n\nfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n  const allowed = VALID_TRANSITIONS[from];\n  if (!allowed.includes(to)) {\n    throw new Error(\n      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    );\n  }\n}\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db {\n  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n  insertRound(params: InsertRoundParams): Promise<Round>;\n\n  /** Delete a round by PDA. Returns true if a row was removed. */\n  deleteRoundByPda(pda: string): Promise<boolean>;\n\n  /** Transition a round's phase. Enforces unidirectional state machine.\n   *  Optional `updates` can set additional columns alongside the phase change. */\n  updateRoundPhase(\n    pda: string,\n    newPhase: RoundPhase,\n    updates?: Partial<\n      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n    >,\n  ): Promise<Round>;\n\n  /** Get a single round by its PDA. Returns `undefined` if not found. */\n  getRoundByPda(pda: string): Promise<Round | undefined>;\n\n  /** Get all rounds matching a given phase. */\n  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n\n  /** Append an operator event to the audit log. */\n  insertOperatorEvent(\n    pda: string | null,\n    eventType: OperatorEventType,\n    payload?: unknown,\n  ): Promise<OperatorEvent>;\n\n  /** Get the latest operator event for a PDA + type. */\n  getLatestOperatorEvent(\n    pda: string,\n    eventType: OperatorEventType,\n  ): Promise<OperatorEvent | undefined>;\n\n  /** Get a single round by its match_id. Returns `undefined` if not found. */\n  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n\n  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n\n  /** Gracefully close the connection pool. */\n  close(): Promise<void>;\n}\n\nfunction normalizeRound(row: Round): Round {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n    side: Number(row.side),\n    settle_attempts: Number(row.settle_attempts),\n    result_side: row.result_side === null ? null : Number(row.result_side),\n  };\n}\n\nexport function createDb(databaseUrl: string): Db {\n  const sql = postgres(databaseUrl);\n\n  return {\n    async insertRound(params) {\n      const rows = await sql<Round[]>`\n        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)\n        VALUES (\n          ${params.pda},\n          ${params.game},\n          ${params.creator},\n          ${params.serverKey},\n          ${params.secret},\n          ${params.commitment},\n          ${params.amountLamports},\n          ${params.side},\n          ${params.matchId},\n          ${params.phase}\n        )\n        RETURNING *\n      `;\n      return normalizeRound(rows[0]!);\n    },\n\n    async deleteRoundByPda(pda) {\n      const rows = await sql<{ pda: string }[]>`\n        DELETE FROM rounds WHERE pda = ${pda}\n        RETURNING pda\n      `;\n      return rows.length > 0;\n    },\n\n    async updateRoundPhase(pda, newPhase, updates) {\n      // Fetch current phase to validate transition\n      const current = await sql<Pick<Round, \"phase\">[]>`\n        SELECT phase FROM rounds WHERE pda = ${pda}\n      `;\n\n      if (current.length === 0) {\n        throw new Error(`Round not found: ${pda}`);\n      }\n\n      const currentPhase = current[0]!.phase as RoundPhase;\n      assertPhaseTransition(currentPhase, newPhase);\n\n      // Build the update — always set phase + updated_at\n      const rows = await sql<Round[]>`\n        UPDATE rounds SET\n          phase = ${newPhase},\n          updated_at = now(),\n          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n          winner = COALESCE(${updates?.winner ?? null}, winner)\n        WHERE pda = ${pda}\n        RETURNING *\n      `;\n\n      return normalizeRound(rows[0]!);\n    },\n\n    async getRoundByPda(pda) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE pda = ${pda}\n      `;\n      return rows[0] ? normalizeRound(rows[0]) : undefined;\n    },\n\n    async getRoundByMatchId(matchId) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE match_id = ${matchId}\n      `;\n      return rows[0] ? normalizeRound(rows[0]) : undefined;\n    },\n\n    async getRoundsByPhase(phase) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE phase = ${phase}\n      `;\n      return rows.map(normalizeRound);\n    },\n\n    async insertOperatorEvent(pda, eventType, payload) {\n      const rows = await sql<OperatorEvent[]>`\n        INSERT INTO operator_events (pda, event_type, payload)\n        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getLatestOperatorEvent(pda, eventType) {\n      const rows = await sql<OperatorEvent[]>`\n        SELECT * FROM operator_events\n        WHERE pda = ${pda} AND event_type = ${eventType}\n        ORDER BY id DESC\n        LIMIT 1\n      `;\n      return rows[0];\n    },\n\n    async getUnsettledStats() {\n      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n        SELECT\n          COUNT(*)::text AS count,\n          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n        FROM rounds\n        WHERE phase NOT IN ('settled', 'expired')\n      `;\n      const row = rows[0]!;\n      return {\n        count: parseInt(row.count, 10),\n        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n      };\n    },\n\n    async close() {\n      await sql.end();\n    },\n  };\n}\n","numLines":273,"startLine":1,"totalLines":273}}}
