{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XLVUiNzbxZ8qELnWSGA3yF","type":"tool_result","content":"     1→/**\n     2→ * GET /fairness/rounds/:pda — round verification endpoint.\n     3→ *\n     4→ * Returns round lifecycle data and post-settlement verification payloads.\n     5→ * Secret is only exposed for settled rounds.\n     6→ */\n     7→\n     8→import { Hono } from \"hono\";\n     9→import type { Db, Round, OperatorEvent } from \"../db.js\";\n    10→\n    11→export interface RoundsRoutesDeps {\n    12→  db: Db;\n    13→}\n    14→\n    15→function getEventPayload(\n    16→  event: OperatorEvent | undefined,\n    17→): Record<string, unknown> | null {\n    18→  if (!event || typeof event.payload !== \"object\" || event.payload === null) {\n    19→    return null;\n    20→  }\n    21→  return event.payload as Record<string, unknown>;\n    22→}\n    23→\n    24→/** Map a DB round row to a camelCase JSON response, redacting secret if unsettled. */\n    25→async function formatRoundResponse(db: Db, round: Round) {\n    26→  const isSettled = round.phase === \"settled\";\n    27→  let settlePayload: Record<string, unknown> | null = null;\n    28→  if (isSettled) {\n    29→    try {\n    30→      const settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    31→      settlePayload = getEventPayload(settleEvent);\n    32→    } catch {\n    33→      // Gracefully degrade — return round data without settle enrichment\n    34→    }\n    35→  }\n    36→\n    37→  const response: Record<string, unknown> = {\n    38→    pda: round.pda,\n    39→    game: round.game,\n    40→    phase: round.phase,\n    41→    creator: round.creator,\n    42→    commitment: round.commitment.toString(\"hex\"),\n    43→    amountLamports: round.amount_lamports,\n    44→    side: round.side,\n    45→    matchId: round.match_id,\n    46→    createdAt: round.created_at.toISOString(),\n    47→    updatedAt: round.updated_at.toISOString(),\n    48→  };\n    49→\n    50→  if (round.target_slot !== null) {\n    51→    response.targetSlot = Number(round.target_slot);\n    52→  }\n    53→\n    54→  if (isSettled) {\n    55→    response.secret = round.secret.toString(\"hex\");\n    56→    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    57→    if (round.game === \"lord\") {\n    58→      response.winningEntryIndex = round.result_side;\n    59→    } else {\n    60→      response.resultSide = round.result_side;\n    61→    }\n    62→    response.winner = round.winner;\n    63→    response.settleTx = round.settle_tx;\n    64→    response.verification = {\n    65→      commitmentCheck: \"sha256(secret) == commitment\",\n    66→      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n    67→      entropySource: \"SlotHashes sysvar at target_slot\",\n    68→    };\n    69→    if (settlePayload) {\n    70→      response.entropy = settlePayload.entropy ?? null;\n    71→      response.payoutAmount = settlePayload.payoutAmount ?? null;\n    72→      response.feeAmount = settlePayload.feeAmount ?? null;\n    73→      if (round.game === \"lord\") {\n    74→        response.winningOffset = settlePayload.winningOffset ?? null;\n    75→        response.totalAmountLamports = settlePayload.totalAmountLamports ?? round.amount_lamports;\n    76→        response.rentRefund = settlePayload.rentRefund ?? null;\n    77→      }\n    78→    }\n    79→  }\n    80→\n    81→  return response;\n    82→}\n    83→\n    84→export function createRoundsRoutes(deps: RoundsRoutesDeps): Hono {\n    85→  const { db } = deps;\n    86→\n    87→  const app = new Hono();\n    88→\n    89→  app.get(\"/by-id/:matchId\", async (c) => {\n    90→    const matchId = c.req.param(\"matchId\");\n    91→    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n    92→      return c.json({ error: \"matchId must be a 16-char hex string\" }, 400);\n    93→    }\n    94→\n    95→    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    96→    if (!round) {\n    97→      return c.json({ error: \"Round not found\" }, 404);\n    98→    }\n    99→\n   100→    return c.json(await formatRoundResponse(db, round));\n   101→  });\n   102→\n   103→  app.get(\"/:pda\", async (c) => {\n   104→    const pda = c.req.param(\"pda\");\n   105→\n   106→    const round = await db.getRoundByPda(pda);\n   107→    if (!round) {\n   108→      return c.json({ error: \"Round not found\" }, 404);\n   109→    }\n   110→\n   111→    return c.json(await formatRoundResponse(db, round));\n   112→  });\n   113→\n   114→  return app;\n   115→}\n   116→"}]},"parent_tool_use_id":null,"session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"db42da2f-e114-4463-bcfa-2738559312c2","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/rounds.ts","content":"/**\n * GET /fairness/rounds/:pda — round verification endpoint.\n *\n * Returns round lifecycle data and post-settlement verification payloads.\n * Secret is only exposed for settled rounds.\n */\n\nimport { Hono } from \"hono\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\n\nexport interface RoundsRoutesDeps {\n  db: Db;\n}\n\nfunction getEventPayload(\n  event: OperatorEvent | undefined,\n): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) {\n    return null;\n  }\n  return event.payload as Record<string, unknown>;\n}\n\n/** Map a DB round row to a camelCase JSON response, redacting secret if unsettled. */\nasync function formatRoundResponse(db: Db, round: Round) {\n  const isSettled = round.phase === \"settled\";\n  let settlePayload: Record<string, unknown> | null = null;\n  if (isSettled) {\n    try {\n      const settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n      settlePayload = getEventPayload(settleEvent);\n    } catch {\n      // Gracefully degrade — return round data without settle enrichment\n    }\n  }\n\n  const response: Record<string, unknown> = {\n    pda: round.pda,\n    game: round.game,\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.game === \"lord\") {\n      response.winningEntryIndex = round.result_side;\n    } else {\n      response.resultSide = round.result_side;\n    }\n    response.winner = round.winner;\n    response.settleTx = round.settle_tx;\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n    if (settlePayload) {\n      response.entropy = settlePayload.entropy ?? null;\n      response.payoutAmount = settlePayload.payoutAmount ?? null;\n      response.feeAmount = settlePayload.feeAmount ?? null;\n      if (round.game === \"lord\") {\n        response.winningOffset = settlePayload.winningOffset ?? null;\n        response.totalAmountLamports = settlePayload.totalAmountLamports ?? round.amount_lamports;\n        response.rentRefund = settlePayload.rentRefund ?? null;\n      }\n    }\n  }\n\n  return response;\n}\n\nexport function createRoundsRoutes(deps: RoundsRoutesDeps): Hono {\n  const { db } = deps;\n\n  const app = new Hono();\n\n  app.get(\"/by-id/:matchId\", async (c) => {\n    const matchId = c.req.param(\"matchId\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return c.json({ error: \"matchId must be a 16-char hex string\" }, 400);\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round) {\n      return c.json({ error: \"Round not found\" }, 404);\n    }\n\n    return c.json(await formatRoundResponse(db, round));\n  });\n\n  app.get(\"/:pda\", async (c) => {\n    const pda = c.req.param(\"pda\");\n\n    const round = await db.getRoundByPda(pda);\n    if (!round) {\n      return c.json({ error: \"Round not found\" }, 404);\n    }\n\n    return c.json(await formatRoundResponse(db, round));\n  });\n\n  return app;\n}\n","numLines":116,"startLine":1,"totalLines":116}}}
