ESTAMPTZ DEFAULT now(),\n  settled_at     TIMESTAMPTZ             -- NULL until settled/refunded\n);\n\nCREATE INDEX IF NOT EXISTS idx_closecall_rounds_phase ON closecall_rounds(phase);\nCREATE INDEX IF NOT EXISTS idx_closecall_rounds_settled_at ON closecall_rounds(settled_at DESC);\n","structuredPatch":[],"originalFile":null}}
