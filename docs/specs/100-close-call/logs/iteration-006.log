es(deps: RoundsRoutesDeps): Hono {\n  const { db } = deps;\n\n  const app = new Hono();\n\n  app.get(\"/by-id/:matchId\", async (c) => {\n    const matchId = c.req.param(\"matchId\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return c.json({ error: \"matchId must be a 16-char hex string\" }, 400);\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round) {\n      return c.json({ error: \"Round not found\" }, 404);\n    }\n\n    return c.json(await formatRoundResponse(db, round));\n  });\n\n  app.get(\"/:pda\", async (c) => {\n    const pda = c.req.param(\"pda\");\n\n    const round = await db.getRoundByPda(pda);\n    if (!round) {\n      return c.json({ error: \"Round not found\" }, 404);\n    }\n\n    return c.json(await formatRoundResponse(db, round));\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":134,"oldLines":12,"newStart":134,"newLines":21,"lines":["       return c.json({ error: \"matchId must be a 16-char hex string\" }, 400);","     }"," ","-    const round = await db.getRoundByMatchId(matchId.toLowerCase());","-    if (!round) {","-      return c.json({ error: \"Round not found\" }, 404);","+    const normalizedId = matchId.toLowerCase();","+","+    // Check commit-reveal rounds table first","+    const round = await db.getRoundByMatchId(normalizedId);","+    if (round) {","+      return c.json(await formatRoundResponse(db, round));","     }"," ","-    return c.json(await formatRoundResponse(db, round));","+    // Fall back to closecall_rounds table","+    const ccRound = await db.getCloseCallRound(normalizedId);","+    if (ccRound) {","+      return c.json(formatCloseCallResponse(ccRound));","+    }","+","+    return c.json({ error: \"Round not found\" }, 404);","   });"," ","   app.get(\"/:pda\", async (c) => {"]}],"userModified":false,"replaceAll":false}}
