{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011D3DNsz3A543e9VjoVFMBo","type":"tool_result","content":"     1→/**\n     2→ * Close Call clock worker — creates and settles rounds on minute boundaries.\n     3→ *\n     4→ * Each tick (aligned to ~2s after each minute):\n     5→ *   1. Settle the previous round if it exists and the candle has closed.\n     6→ *   2. Create a new round (stores Pyth open price on-chain).\n     7→ *\n     8→ * On start, scans for an existing open round (recovery after restart).\n     9→ */\n    10→\n    11→import { randomBytes } from \"node:crypto\";\n    12→import { performance } from \"node:perf_hooks\";\n    13→import { Connection, Keypair, PublicKey, type Transaction } from \"@solana/web3.js\";\n    14→import { logger } from \"../logger.js\";\n    15→import { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    16→import {\n    17→  buildCloseCallCreateRoundTx,\n    18→  buildCloseCallSettleRoundTx,\n    19→  type CloseCallTxDeps,\n    20→} from \"./settle-tx.js\";\n    21→import {\n    22→  closeCallRoundDiscriminatorFilter,\n    23→  decodeCloseCallConfig,\n    24→  decodeCloseCallRound,\n    25→} from \"./account-decoder.js\";\n    26→\n    27→// ---------------------------------------------------------------------------\n    28→// Pyth PriceUpdateV2 raw offsets (same layout as pyth.rs)\n    29→// discriminator(8) + write_authority(32) + verification_level(1) = 41\n    30→// PriceFeedMessage: feed_id(32) + price(i64@73) + conf(u64@81) + exponent(i32@89)\n    31→// ---------------------------------------------------------------------------\n    32→\n    33→const PYTH_PRICE_OFFSET = 41 + 32; // 73\n    34→const PYTH_EXPO_OFFSET = PYTH_PRICE_OFFSET + 8 + 8; // 89\n    35→const PYTH_MIN_DATA_LEN = PYTH_EXPO_OFFSET + 4; // 93\n    36→\n    37→/** Close Call on-chain phase values */\n    38→const PHASE_OPEN = 0;\n    39→\n    40→/** Offset after minute boundary before first tick (ms). */\n    41→const TICK_OFFSET_MS = 2_000;\n    42→\n    43→/** Maximum retry attempts for a single tx submission. */\n    44→const MAX_TX_RETRIES = 3;\n    45→const TX_RETRY_DELAY_MS = 2_000;\n    46→\n    47→// ---------------------------------------------------------------------------\n    48→// Types\n    49→// ---------------------------------------------------------------------------\n    50→\n    51→export interface CloseCallClockDeps {\n    52→  connection: Connection;\n    53→  serverKeypair: Keypair;\n    54→  /** Pyth BTC/USD push oracle price account on-chain. */\n    55→  pythPriceAccount: PublicKey;\n    56→}\n    57→\n    58→export interface CloseCallClockWorker {\n    59→  start(): void;\n    60→  stop(): void;\n    61→  readonly isRunning: boolean;\n    62→  /** Run a single tick (exposed for testing). */\n    63→  tick(): Promise<void>;\n    64→}\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Factory\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export function createCloseCallClockWorker(\n    71→  deps: CloseCallClockDeps,\n    72→): CloseCallClockWorker {\n    73→  const { connection, serverKeypair, pythPriceAccount } = deps;\n    74→  const txDeps: CloseCallTxDeps = { connection, serverKeypair };\n    75→\n    76→  let running = false;\n    77→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    78→\n    79→  /** Active round tracking (in-memory, recovered on start). */\n    80→  let activeRoundId: Buffer | null = null;\n    81→  let activeRoundPda: PublicKey | null = null;\n    82→\n    83→  // -----------------------------------------------------------------------\n    84→  // Helpers\n    85→  // -----------------------------------------------------------------------\n    86→\n    87→  /** Milliseconds until the next minute boundary + offset. */\n    88→  function msUntilNextMinute(): number {\n    89→    const now = Date.now();\n    90→    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    91→    return nextMinute - now + TICK_OFFSET_MS;\n    92→  }\n    93→\n    94→  /** Send a signed transaction and confirm with retry. */\n    95→  async function sendAndConfirm(\n    96→    tx: Transaction,\n    97→    label: string,\n    98→  ): Promise<string> {\n    99→    let lastError: unknown;\n   100→\n   101→    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n   102→      try {\n   103→        const sig = await connection.sendRawTransaction(tx.serialize(), {\n   104→          skipPreflight: false,\n   105→        });\n   106→        const { blockhash, lastValidBlockHeight } =\n   107→          await connection.getLatestBlockhash();\n   108→        const confirmation = await connection.confirmTransaction(\n   109→          { signature: sig, blockhash, lastValidBlockHeight },\n   110→          \"confirmed\",\n   111→        );\n   112→        if (confirmation.value.err) {\n   113→          throw new Error(\n   114→            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   115→          );\n   116→        }\n   117→        return sig;\n   118→      } catch (err) {\n   119→        lastError = err;\n   120→        if (attempt < MAX_TX_RETRIES - 1) {\n   121→          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n   122→            error: err instanceof Error ? err.message : String(err),\n   123→          });\n   124→          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n   125→        }\n   126→      }\n   127→    }\n   128→\n   129→    throw lastError;\n   130→  }\n   131→\n   132→  /** Read Pyth price from on-chain account for outcome pre-check. */\n   133→  async function readPythPrice(): Promise<{ price: bigint; expo: number } | null> {\n   134→    const info = await connection.getAccountInfo(pythPriceAccount);\n   135→    if (!info || info.data.length < PYTH_MIN_DATA_LEN) return null;\n   136→    const data = Buffer.from(info.data);\n   137→    const price = data.readBigInt64LE(PYTH_PRICE_OFFSET);\n   138→    const expo = data.readInt32LE(PYTH_EXPO_OFFSET);\n   139→    return { price, expo };\n   140→  }\n   141→\n   142→  /** Read CloseCallConfig for treasury address. */\n   143→  async function readTreasury(): Promise<PublicKey | null> {\n   144→    const [configPda] = PublicKey.findProgramAddressSync(\n   145→      [Buffer.from(\"closecall_config\")],\n   146→      CLOSECALL_PROGRAM_ID,\n   147→    );\n   148→    const info = await connection.getAccountInfo(configPda);\n   149→    if (!info) return null;\n   150→    const config = decodeCloseCallConfig(Buffer.from(info.data));\n   151→    return config.treasury;\n   152→  }\n   153→\n   154→  /**\n   155→   * Discover an existing open round owned by this server (recovery after restart).\n   156→   */\n   157→  async function discoverActiveRound(): Promise<void> {\n   158→    try {\n   159→      const accounts = await connection.getProgramAccounts(\n   160→        CLOSECALL_PROGRAM_ID,\n   161→        { filters: [closeCallRoundDiscriminatorFilter()] },\n   162→      );\n   163→\n   164→      for (const { pubkey, account } of accounts) {\n   165→        try {\n   166→          const round = decodeCloseCallRound(Buffer.from(account.data));\n   167→          if (\n   168→            round.phase === PHASE_OPEN &&\n   169→            round.server.equals(serverKeypair.publicKey)\n   170→          ) {\n   171→            activeRoundPda = pubkey;\n   172→            activeRoundId = Buffer.from(round.roundId);\n   173→            logger.info(\"closecall clock: recovered active round\", {\n   174→              pda: pubkey.toBase58(),\n   175→              roundId: activeRoundId.toString(\"hex\"),\n   176→            });\n   177→            return;\n   178→          }\n   179→        } catch {\n   180→          // Skip undecodeable accounts\n   181→        }\n   182→      }\n   183→    } catch (err) {\n   184→      logger.warn(\"closecall clock: discovery scan failed\", {\n   185→        error: err instanceof Error ? err.message : String(err),\n   186→      });\n   187→    }\n   188→  }\n   189→\n   190→  // -----------------------------------------------------------------------\n   191→  // Settlement\n   192→  // -----------------------------------------------------------------------\n   193→\n   194→  /**\n   195→   * Settle the previous round if it exists.\n   196→   * Returns true if settlement succeeded (or no round to settle).\n   197→   */\n   198→  async function settlePreviousRound(): Promise<boolean> {\n   199→    if (!activeRoundPda || !activeRoundId) return true;\n   200→\n   201→    const roundPda = activeRoundPda;\n   202→    const roundId = activeRoundId;\n   203→\n   204→    try {\n   205→      // Read on-chain round\n   206→      const info = await connection.getAccountInfo(roundPda);\n   207→      if (!info) {\n   208→        // Already closed (settled/refunded by someone else or timeout)\n   209→        logger.info(\"closecall clock: round already closed\", {\n   210→          pda: roundPda.toBase58(),\n   211→        });\n   212→        activeRoundPda = null;\n   213→        activeRoundId = null;\n   214→        return true;\n   215→      }\n   216→\n   217→      const round = decodeCloseCallRound(Buffer.from(info.data));\n   218→\n   219→      // Only settle if still Open\n   220→      if (round.phase !== PHASE_OPEN) {\n   221→        logger.info(\"closecall clock: round not in Open phase, skipping\", {\n   222→          pda: roundPda.toBase58(),\n   223→          phase: round.phase,\n   224→        });\n   225→        activeRoundPda = null;\n   226→        activeRoundId = null;\n   227→        return true;\n   228→      }\n   229→\n   230→      // Read Pyth close price + treasury in parallel\n   231→      const [pythPrice, treasury] = await Promise.all([\n   232→        readPythPrice(),\n   233→        readTreasury(),\n   234→      ]);\n   235→\n   236→      if (!pythPrice) {\n   237→        logger.error(\"closecall clock: cannot read Pyth price for settlement\", {\n   238→          pda: roundPda.toBase58(),\n   239→        });\n   240→        return false;\n   241→      }\n   242→      if (!treasury) {\n   243→        logger.error(\"closecall clock: cannot read config treasury\");\n   244→        return false;\n   245→      }\n   246→\n   247→      // Pre-determine outcome to select correct remaining accounts\n   248→      const greenCount = round.greenEntries.length;\n   249→      const redCount = round.redEntries.length;\n   250→      const totalCount = greenCount + redCount;\n   251→      const hasBothSides = greenCount > 0 && redCount > 0;\n   252→\n   253→      const isRefund =\n   254→        totalCount === 0 ||\n   255→        !hasBothSides ||\n   256→        totalCount === 1 ||\n   257→        pythPrice.price === round.openPrice;\n   258→\n   259→      let remainingAccounts: PublicKey[];\n   260→      if (isRefund) {\n   261→        // All players: green entries then red entries (entry order)\n   262→        remainingAccounts = [\n   263→          ...round.greenEntries.map((e) => e.player),\n   264→          ...round.redEntries.map((e) => e.player),\n   265→        ];\n   266→      } else if (pythPrice.price > round.openPrice) {\n   267→        // Green wins — only green bettors\n   268→        remainingAccounts = round.greenEntries.map((e) => e.player);\n   269→      } else {\n   270→        // Red wins — only red bettors\n   271→        remainingAccounts = round.redEntries.map((e) => e.player);\n   272→      }\n   273→\n   274→      const tx = await buildCloseCallSettleRoundTx(\n   275→        txDeps,\n   276→        roundId,\n   277→        pythPriceAccount,\n   278→        treasury,\n   279→        remainingAccounts,\n   280→      );\n   281→\n   282→      const sig = await sendAndConfirm(tx, \"settle\");\n   283→\n   284→      logger.info(\"closecall clock: round settled\", {\n   285→        pda: roundPda.toBase58(),\n   286→        tx: sig,\n   287→        totalEntries: totalCount,\n   288→        outcome: isRefund\n   289→          ? \"refund\"\n   290→          : pythPrice.price > round.openPrice\n   291→            ? \"green\"\n   292→            : \"red\",\n   293→      });\n   294→\n   295→      activeRoundPda = null;\n   296→      activeRoundId = null;\n   297→      return true;\n   298→    } catch (err) {\n   299→      logger.error(\"closecall clock: settlement failed\", {\n   300→        pda: roundPda.toBase58(),\n   301→        error: err instanceof Error ? err.message : String(err),\n   302→      });\n   303→      // Clear active round — timeout_refund will handle it\n   304→      activeRoundPda = null;\n   305→      activeRoundId = null;\n   306→      return false;\n   307→    }\n   308→  }\n   309→\n   310→  // -----------------------------------------------------------------------\n   311→  // Round creation\n   312→  // -----------------------------------------------------------------------\n   313→\n   314→  async function createNewRound(): Promise<void> {\n   315→    const roundId = randomBytes(8);\n   316→\n   317→    try {\n   318→      const { tx, roundPda } = await buildCloseCallCreateRoundTx(\n   319→        txDeps,\n   320→        roundId,\n   321→        pythPriceAccount,\n   322→      );\n   323→\n   324→      const sig = await sendAndConfirm(tx, \"create_round\");\n   325→\n   326→      activeRoundId = roundId;\n   327→      activeRoundPda = roundPda;\n   328→\n   329→      logger.info(\"closecall clock: new round created\", {\n   330→        pda: roundPda.toBase58(),\n   331→        roundId: roundId.toString(\"hex\"),\n   332→        tx: sig,\n   333→      });\n   334→    } catch (err) {\n   335→      logger.error(\"closecall clock: round creation failed\", {\n   336→        roundId: roundId.toString(\"hex\"),\n   337→        error: err instanceof Error ? err.message : String(err),\n   338→      });\n   339→    }\n   340→  }\n   341→\n   342→  // -----------------------------------------------------------------------\n   343→  // Tick loop\n   344→  // -----------------------------------------------------------------------\n   345→\n   346→  async function tick(): Promise<void> {\n   347→    const t0 = performance.now();\n   348→\n   349→    // Step 1: Settle previous round (log + continue on failure)\n   350→    await settlePreviousRound();\n   351→\n   352→    // Step 2: Create new round\n   353→    await createNewRound();\n   354→\n   355→    const elapsed = Math.round(performance.now() - t0);\n   356→    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed });\n   357→  }\n   358→\n   359→  async function loop(): Promise<void> {\n   360→    if (!running) return;\n   361→    try {\n   362→      await tick();\n   363→    } catch (err) {\n   364→      logger.error(\"closecall clock loop error\", {\n   365→        error: err instanceof Error ? err.message : String(err),\n   366→      });\n   367→    }\n   368→    if (running) {\n   369→      const delay = msUntilNextMinute();\n   370→      timeoutId = setTimeout(loop, delay);\n   371→    }\n   372→  }\n   373→\n   374→  // -----------------------------------------------------------------------\n   375→  // Public interface\n   376→  // -----------------------------------------------------------------------\n   377→\n   378→  return {\n   379→    start() {\n   380→      if (running) return;\n   381→      running = true;\n   382→\n   383→      logger.info(\"closecall clock started\", {\n   384→        serverKey: serverKeypair.publicKey.toBase58(),\n   385→        pythPriceAccount: pythPriceAccount.toBase58(),\n   386→      });\n   387→\n   388→      // Discover any existing round, then schedule first tick\n   389→      discoverActiveRound()\n   390→        .then(() => {\n   391→          if (!running) return;\n   392→          const delay = msUntilNextMinute();\n   393→          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n   394→          timeoutId = setTimeout(loop, delay);\n   395→        })\n   396→        .catch((err) => {\n   397→          logger.error(\"closecall clock: discovery failed\", {\n   398→            error: err instanceof Error ? err.message : String(err),\n   399→          });\n   400→          if (running) {\n   401→            const delay = msUntilNextMinute();\n   402→            timeoutId = setTimeout(loop, delay);\n   403→          }\n   404→        });\n   405→    },\n   406→\n   407→    stop() {\n   408→      running = false;\n   409→      if (timeoutId) {\n   410→        clearTimeout(timeoutId);\n   411→        timeoutId = null;\n   412→      }\n   413→      logger.info(\"closecall clock stopped\");\n   414→    },\n   415→\n   416→    get isRunning() {\n   417→      return running;\n   418→    },\n   419→\n   420→    tick,\n   421→  };\n   422→}\n   423→"}]},"parent_tool_use_id":null,"session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"2c63b5b3-114b-48ba-be07-b33c983e2810","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/closecall-clock.ts","content":"/**\n * Close Call clock worker — creates and settles rounds on minute boundaries.\n *\n * Each tick (aligned to ~2s after each minute):\n *   1. Settle the previous round if it exists and the candle has closed.\n *   2. Create a new round (stores Pyth open price on-chain).\n *\n * On start, scans for an existing open round (recovery after restart).\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport { Connection, Keypair, PublicKey, type Transaction } from \"@solana/web3.js\";\nimport { logger } from \"../logger.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport {\n  buildCloseCallCreateRoundTx,\n  buildCloseCallSettleRoundTx,\n  type CloseCallTxDeps,\n} from \"./settle-tx.js\";\nimport {\n  closeCallRoundDiscriminatorFilter,\n  decodeCloseCallConfig,\n  decodeCloseCallRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Pyth PriceUpdateV2 raw offsets (same layout as pyth.rs)\n// discriminator(8) + write_authority(32) + verification_level(1) = 41\n// PriceFeedMessage: feed_id(32) + price(i64@73) + conf(u64@81) + exponent(i32@89)\n// ---------------------------------------------------------------------------\n\nconst PYTH_PRICE_OFFSET = 41 + 32; // 73\nconst PYTH_EXPO_OFFSET = PYTH_PRICE_OFFSET + 8 + 8; // 89\nconst PYTH_MIN_DATA_LEN = PYTH_EXPO_OFFSET + 4; // 93\n\n/** Close Call on-chain phase values */\nconst PHASE_OPEN = 0;\n\n/** Offset after minute boundary before first tick (ms). */\nconst TICK_OFFSET_MS = 2_000;\n\n/** Maximum retry attempts for a single tx submission. */\nconst MAX_TX_RETRIES = 3;\nconst TX_RETRY_DELAY_MS = 2_000;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface CloseCallClockDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n  /** Pyth BTC/USD push oracle price account on-chain. */\n  pythPriceAccount: PublicKey;\n}\n\nexport interface CloseCallClockWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single tick (exposed for testing). */\n  tick(): Promise<void>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createCloseCallClockWorker(\n  deps: CloseCallClockDeps,\n): CloseCallClockWorker {\n  const { connection, serverKeypair, pythPriceAccount } = deps;\n  const txDeps: CloseCallTxDeps = { connection, serverKeypair };\n\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  /** Active round tracking (in-memory, recovered on start). */\n  let activeRoundId: Buffer | null = null;\n  let activeRoundPda: PublicKey | null = null;\n\n  // -----------------------------------------------------------------------\n  // Helpers\n  // -----------------------------------------------------------------------\n\n  /** Milliseconds until the next minute boundary + offset. */\n  function msUntilNextMinute(): number {\n    const now = Date.now();\n    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    return nextMinute - now + TICK_OFFSET_MS;\n  }\n\n  /** Send a signed transaction and confirm with retry. */\n  async function sendAndConfirm(\n    tx: Transaction,\n    label: string,\n  ): Promise<string> {\n    let lastError: unknown;\n\n    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n      try {\n        const sig = await connection.sendRawTransaction(tx.serialize(), {\n          skipPreflight: false,\n        });\n        const { blockhash, lastValidBlockHeight } =\n          await connection.getLatestBlockhash();\n        const confirmation = await connection.confirmTransaction(\n          { signature: sig, blockhash, lastValidBlockHeight },\n          \"confirmed\",\n        );\n        if (confirmation.value.err) {\n          throw new Error(\n            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n          );\n        }\n        return sig;\n      } catch (err) {\n        lastError = err;\n        if (attempt < MAX_TX_RETRIES - 1) {\n          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n        }\n      }\n    }\n\n    throw lastError;\n  }\n\n  /** Read Pyth price from on-chain account for outcome pre-check. */\n  async function readPythPrice(): Promise<{ price: bigint; expo: number } | null> {\n    const info = await connection.getAccountInfo(pythPriceAccount);\n    if (!info || info.data.length < PYTH_MIN_DATA_LEN) return null;\n    const data = Buffer.from(info.data);\n    const price = data.readBigInt64LE(PYTH_PRICE_OFFSET);\n    const expo = data.readInt32LE(PYTH_EXPO_OFFSET);\n    return { price, expo };\n  }\n\n  /** Read CloseCallConfig for treasury address. */\n  async function readTreasury(): Promise<PublicKey | null> {\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"closecall_config\")],\n      CLOSECALL_PROGRAM_ID,\n    );\n    const info = await connection.getAccountInfo(configPda);\n    if (!info) return null;\n    const config = decodeCloseCallConfig(Buffer.from(info.data));\n    return config.treasury;\n  }\n\n  /**\n   * Discover an existing open round owned by this server (recovery after restart).\n   */\n  async function discoverActiveRound(): Promise<void> {\n    try {\n      const accounts = await connection.getProgramAccounts(\n        CLOSECALL_PROGRAM_ID,\n        { filters: [closeCallRoundDiscriminatorFilter()] },\n      );\n\n      for (const { pubkey, account } of accounts) {\n        try {\n          const round = decodeCloseCallRound(Buffer.from(account.data));\n          if (\n            round.phase === PHASE_OPEN &&\n            round.server.equals(serverKeypair.publicKey)\n          ) {\n            activeRoundPda = pubkey;\n            activeRoundId = Buffer.from(round.roundId);\n            logger.info(\"closecall clock: recovered active round\", {\n              pda: pubkey.toBase58(),\n              roundId: activeRoundId.toString(\"hex\"),\n            });\n            return;\n          }\n        } catch {\n          // Skip undecodeable accounts\n        }\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: discovery scan failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Settlement\n  // -----------------------------------------------------------------------\n\n  /**\n   * Settle the previous round if it exists.\n   * Returns true if settlement succeeded (or no round to settle).\n   */\n  async function settlePreviousRound(): Promise<boolean> {\n    if (!activeRoundPda || !activeRoundId) return true;\n\n    const roundPda = activeRoundPda;\n    const roundId = activeRoundId;\n\n    try {\n      // Read on-chain round\n      const info = await connection.getAccountInfo(roundPda);\n      if (!info) {\n        // Already closed (settled/refunded by someone else or timeout)\n        logger.info(\"closecall clock: round already closed\", {\n          pda: roundPda.toBase58(),\n        });\n        activeRoundPda = null;\n        activeRoundId = null;\n        return true;\n      }\n\n      const round = decodeCloseCallRound(Buffer.from(info.data));\n\n      // Only settle if still Open\n      if (round.phase !== PHASE_OPEN) {\n        logger.info(\"closecall clock: round not in Open phase, skipping\", {\n          pda: roundPda.toBase58(),\n          phase: round.phase,\n        });\n        activeRoundPda = null;\n        activeRoundId = null;\n        return true;\n      }\n\n      // Read Pyth close price + treasury in parallel\n      const [pythPrice, treasury] = await Promise.all([\n        readPythPrice(),\n        readTreasury(),\n      ]);\n\n      if (!pythPrice) {\n        logger.error(\"closecall clock: cannot read Pyth price for settlement\", {\n          pda: roundPda.toBase58(),\n        });\n        return false;\n      }\n      if (!treasury) {\n        logger.error(\"closecall clock: cannot read config treasury\");\n        return false;\n      }\n\n      // Pre-determine outcome to select correct remaining accounts\n      const greenCount = round.greenEntries.length;\n      const redCount = round.redEntries.length;\n      const totalCount = greenCount + redCount;\n      const hasBothSides = greenCount > 0 && redCount > 0;\n\n      const isRefund =\n        totalCount === 0 ||\n        !hasBothSides ||\n        totalCount === 1 ||\n        pythPrice.price === round.openPrice;\n\n      let remainingAccounts: PublicKey[];\n      if (isRefund) {\n        // All players: green entries then red entries (entry order)\n        remainingAccounts = [\n          ...round.greenEntries.map((e) => e.player),\n          ...round.redEntries.map((e) => e.player),\n        ];\n      } else if (pythPrice.price > round.openPrice) {\n        // Green wins — only green bettors\n        remainingAccounts = round.greenEntries.map((e) => e.player);\n      } else {\n        // Red wins — only red bettors\n        remainingAccounts = round.redEntries.map((e) => e.player);\n      }\n\n      const tx = await buildCloseCallSettleRoundTx(\n        txDeps,\n        roundId,\n        pythPriceAccount,\n        treasury,\n        remainingAccounts,\n      );\n\n      const sig = await sendAndConfirm(tx, \"settle\");\n\n      logger.info(\"closecall clock: round settled\", {\n        pda: roundPda.toBase58(),\n        tx: sig,\n        totalEntries: totalCount,\n        outcome: isRefund\n          ? \"refund\"\n          : pythPrice.price > round.openPrice\n            ? \"green\"\n            : \"red\",\n      });\n\n      activeRoundPda = null;\n      activeRoundId = null;\n      return true;\n    } catch (err) {\n      logger.error(\"closecall clock: settlement failed\", {\n        pda: roundPda.toBase58(),\n        error: err instanceof Error ? err.message : String(err),\n      });\n      // Clear active round — timeout_refund will handle it\n      activeRoundPda = null;\n      activeRoundId = null;\n      return false;\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Round creation\n  // -----------------------------------------------------------------------\n\n  async function createNewRound(): Promise<void> {\n    const roundId = randomBytes(8);\n\n    try {\n      const { tx, roundPda } = await buildCloseCallCreateRoundTx(\n        txDeps,\n        roundId,\n        pythPriceAccount,\n      );\n\n      const sig = await sendAndConfirm(tx, \"create_round\");\n\n      activeRoundId = roundId;\n      activeRoundPda = roundPda;\n\n      logger.info(\"closecall clock: new round created\", {\n        pda: roundPda.toBase58(),\n        roundId: roundId.toString(\"hex\"),\n        tx: sig,\n      });\n    } catch (err) {\n      logger.error(\"closecall clock: round creation failed\", {\n        roundId: roundId.toString(\"hex\"),\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Tick loop\n  // -----------------------------------------------------------------------\n\n  async function tick(): Promise<void> {\n    const t0 = performance.now();\n\n    // Step 1: Settle previous round (log + continue on failure)\n    await settlePreviousRound();\n\n    // Step 2: Create new round\n    await createNewRound();\n\n    const elapsed = Math.round(performance.now() - t0);\n    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed });\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await tick();\n    } catch (err) {\n      logger.error(\"closecall clock loop error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      const delay = msUntilNextMinute();\n      timeoutId = setTimeout(loop, delay);\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Public interface\n  // -----------------------------------------------------------------------\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n\n      logger.info(\"closecall clock started\", {\n        serverKey: serverKeypair.publicKey.toBase58(),\n        pythPriceAccount: pythPriceAccount.toBase58(),\n      });\n\n      // Discover any existing round, then schedule first tick\n      discoverActiveRound()\n        .then(() => {\n          if (!running) return;\n          const delay = msUntilNextMinute();\n          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n          timeoutId = setTimeout(loop, delay);\n        })\n        .catch((err) => {\n          logger.error(\"closecall clock: discovery failed\", {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          if (running) {\n            const delay = msUntilNextMinute();\n            timeoutId = setTimeout(loop, delay);\n          }\n        });\n    },\n\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"closecall clock stopped\");\n    },\n\n    get isRunning() {\n      return running;\n    },\n\n    tick,\n  };\n}\n","numLines":423,"startLine":1,"totalLines":423}}}
