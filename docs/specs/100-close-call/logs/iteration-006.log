nexport function createRoundsRoutes(deps: RoundsRoutesDeps): Hono {","originalFile":"/**\n * GET /fairness/rounds/:pda — round verification endpoint.\n *\n * Returns round lifecycle data and post-settlement verification payloads.\n * Secret is only exposed for settled rounds.\n */\n\nimport { Hono } from \"hono\";\nimport type { CloseCallRound, Db, Round, OperatorEvent } from \"../db.js\";\n\nexport interface RoundsRoutesDeps {\n  db: Db;\n}\n\nfunction getEventPayload(\n  event: OperatorEvent | undefined,\n): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) {\n    return null;\n  }\n  return event.payload as Record<string, unknown>;\n}\n\n/** Map a DB round row to a camelCase JSON response, redacting secret if unsettled. */\nasync function formatRoundResponse(db: Db, round: Round) {\n  const isSettled = round.phase === \"settled\";\n  let settlePayload: Record<string, unknown> | null = null;\n  if (isSettled) {\n    try {\n      const settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n      settlePayload = getEventPayload(settleEvent);\n    } catch {\n      // Gracefully degrade — return round data without settle enrichment\n    }\n  }\n\n  const response: Record<string, unknown> = {\n    pda: round.pda,\n    game: round.game,\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.game === \"lord\") {\n      response.winningEntryIndex = round.result_side;\n    } else {\n      response.resultSide = round.result_side;\n    }\n    response.winner = round.winner;\n    response.settleTx = round.settle_tx;\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n    if (settlePayload) {\n      response.entropy = settlePayload.entropy ?? null;\n      response.payoutAmount = settlePayload.payoutAmount ?? null;\n      response.feeAmount = settlePayload.feeAmount ?? null;\n      if (round.game === \"lord\") {\n        response.winningOffset = settlePayload.winningOffset ?? null;\n        response.totalAmountLamports = settlePayload.totalAmountLamports ?? round.amount_lamports;\n        response.rentRefund = settlePayload.rentRefund ?? null;\n      }\n    }\n  }\n\n  return response;\n}\n\nexport function createRoundsRoutes(deps: RoundsRoutesDeps): Hono {\n  const { db } = deps;\n\n  const app = new Hono();\n\n  app.get(\"/by-id/:matchId\", async (c) => {\n    const matchId = c.req.param(\"matchId\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return c.json({ error: \"matchId must be a 16-char hex string\" }, 400);\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round) {\n      return c.json({ error: \"Round not found\" }, 404);\n    }\n\n    return c.json(await formatRoundResponse(db, round));\n  });\n\n  app.get(\"/:pda\", async (c) => {\n    const pda = c.req.param(\"pda\");\n\n    const round = await db.getRoundByPda(pda);\n    if (!round) {\n      return c.json({ error: \"Round not found\" }, 404);\n    }\n\n    return c.json(await formatRoundResponse(db, round));\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":81,"oldLines":6,"newStart":81,"newLines":48,"lines":["   return response;"," }"," ","+/** Format a Close Call round for the /by-id endpoint (unified shape). */","+function formatCloseCallResponse(round: CloseCallRound) {","+  const totalPool = round.green_pool + round.red_pool;","+  const isSettled = round.phase === \"settled\" || round.phase === \"refunded\";","+","+  const response: Record<string, unknown> = {","+    pda: round.pda,","+    game: \"closecall\",","+    phase: round.phase,","+    matchId: round.round_id,","+    openPrice: round.open_price,","+    openPriceExpo: round.open_price_expo,","+    greenPool: round.green_pool,","+    redPool: round.red_pool,","+    totalPool,","+    greenEntries: round.green_entries,","+    redEntries: round.red_entries,","+    greenCount: round.green_entries.length,","+    redCount: round.red_entries.length,","+    createdAt: round.created_at.toISOString(),","+  };","+","+  if (isSettled) {","+    response.closePrice = round.close_price;","+    response.outcome = round.outcome;","+    response.totalFee = round.total_fee;","+    response.settleTx = round.settle_tx;","+    response.settledAt = round.settled_at ? round.settled_at.toISOString() : null;","+    response.verification = {","+      priceSource: \"Pyth Network push oracle\",","+      outcome:","+        round.outcome === \"green\"","+          ? \"close > open\"","+          : round.outcome === \"red\"","+            ? \"close < open\"","+            : \"refund (equal price, one-sided, or single player)\",","+    };","+  }","+","+  return response;","+}","+"," export function createRoundsRoutes(deps: RoundsRoutesDeps): Hono {","   const { db } = deps;"," "]}],"userModified":false,"replaceAll":false}}
