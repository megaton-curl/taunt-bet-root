{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HLaaL5xbnXnwc4RN6M1F1M","type":"tool_result","content":"     1→-- 002_auth_sessions.sql — Auth challenge + refresh token tables for JWT sessions\n     2→\n     3→CREATE TABLE IF NOT EXISTS auth_challenges (\n     4→  nonce       TEXT PRIMARY KEY,\n     5→  wallet      TEXT NOT NULL,\n     6→  cluster     TEXT NOT NULL DEFAULT 'devnet',\n     7→  message     TEXT NOT NULL,\n     8→  expires_at  TIMESTAMPTZ NOT NULL,\n     9→  used        BOOLEAN DEFAULT FALSE,\n    10→  created_at  TIMESTAMPTZ DEFAULT now()\n    11→);\n    12→\n    13→CREATE TABLE IF NOT EXISTS refresh_tokens (\n    14→  id          BIGSERIAL PRIMARY KEY,\n    15→  wallet      TEXT NOT NULL,\n    16→  token_hash  BYTEA NOT NULL UNIQUE,\n    17→  family_id   TEXT NOT NULL,\n    18→  expires_at  TIMESTAMPTZ NOT NULL,\n    19→  revoked     BOOLEAN DEFAULT FALSE,\n    20→  created_at  TIMESTAMPTZ DEFAULT now()\n    21→);\n    22→\n    23→CREATE INDEX IF NOT EXISTS idx_refresh_tokens_wallet ON refresh_tokens(wallet);\n    24→CREATE INDEX IF NOT EXISTS idx_refresh_tokens_family ON refresh_tokens(family_id);\n    25→"}]},"parent_tool_use_id":"toolu_01TVrhQDzjNAbznhSJSQdJTY","session_id":"8567a258-d736-4e38-97a8-6f64b6a42fd3","uuid":"24993c9e-d870-4ff2-aa93-bce5b01dacf7"}
