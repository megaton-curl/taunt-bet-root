         {\n   998→            \"name\": \"round_id\",\n   999→            \"type\": {\n  1000→              \"array\": [\n  1001→                \"u8\",\n  1002→                8\n  1003→              ]\n  1004→            }\n  1005→          },\n  1006→          {\n  1007→            \"name\": \"outcome\",\n  1008→            \"type\": {\n  1009→              \"defined\": {\n  1010→                \"name\": \"Outcome\"\n  1011→              }\n  1012→            }\n  1013→          },\n  1014→          {\n  1015→            \"name\": \"open_price\",\n  1016→            \"type\": \"i64\"\n  1017→          },\n  1018→          {\n  1019→            \"name\": \"close_price\",\n  1020→            \"type\": \"i64\"\n  1021→          },\n  1022→          {\n  1023→            \"name\": \"green_pool\",\n  1024→            \"type\": \"u64\"\n  1025→          },\n  1026→          {\n  1027→            \"name\": \"red_pool\",\n  1028→            \"type\": \"u64\"\n  1029→          },\n  1030→          {\n  1031→            \"name\": \"total_fee\",\n  1032→            \"type\": \"u64\"\n  1033→          },\n  1034→          {\n  1035→            \"name\": \"num_winners\",\n  1036→            \"type\": \"u8\"\n  1037→          }\n  1038→        ]\n  1039→      }\n  1040→    }\n  1041→  ]\n  1042→}"}]},"parent_tool_use_id":"toolu_015UHQzRirKrwxJTp9g2HKLM","session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e","uuid":"516ae242-0146-47ea-8ee1-144a8c5fabea"}
