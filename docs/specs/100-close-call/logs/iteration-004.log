{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LiRTdDTHwFqRYQaexREq9p","type":"tool_result","content":"     1→/**\n     2→ * Settlement worker — polls the chain for server-owned rounds that are ready\n     3→ * for backend settlement across supported games.\n     4→ */\n     5→\n     6→import { performance } from \"node:perf_hooks\";\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\n     9→import type { Db } from \"../db.js\";\n    10→import { logger } from \"../logger.js\";\n    11→import {\n    12→  coinflipMatchSize,\n    13→  decodeCoinflipMatch,\n    14→  decodeLordRound,\n    15→  lordRoundDiscriminatorFilter,\n    16→} from \"./account-decoder.js\";\n    17→\n    18→const PHASE_LOCKED_VALUE = 1;\n    19→const LORD_PHASE_ACTIVE_VALUE = 1;\n    20→\n    21→export interface SettlementWorkerDeps {\n    22→  db: Db;\n    23→  connection: Connection;\n    24→  serverKey: PublicKey;\n    25→  pollIntervalMs: number;\n    26→  /** Called when a match is detected as ready for settlement (target_slot reached). */\n    27→  onSettleReady?: (pda: string) => Promise<void>;\n    28→  /** Called to check if a PDA is finalized (settled or permanently failed). */\n    29→  isFinalized?: (pda: string) => boolean;\n    30→}\n    31→\n    32→export interface SettlementWorker {\n    33→  start(): void;\n    34→  stop(): void;\n    35→  readonly isRunning: boolean;\n    36→  /** Run a single poll cycle (exposed for testing). */\n    37→  poll(): Promise<void>;\n    38→}\n    39→\n    40→export function createSettlementWorker(\n    41→  deps: SettlementWorkerDeps,\n    42→): SettlementWorker {\n    43→  const { db, connection, serverKey, pollIntervalMs } = deps;\n    44→  const discoveredPdas = new Set<string>();\n    45→  const readyPdas = new Set<string>();\n    46→  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n    47→  const undecodeablePdas = new Set<string>();\n    48→  let running = false;\n    49→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    50→\n    51→  async function handleDiscoveredRound(\n    52→    pda: string,\n    53→    targetSlot: bigint,\n    54→    currentSlot: number,\n    55→    slotTime: string | null,\n    56→  ): Promise<void> {\n    57→    const round = await db.getRoundByPda(pda);\n    58→    if (!round) {\n    59→      return;\n    60→    }\n    61→\n    62→    if (!discoveredPdas.has(pda)) {\n    63→      discoveredPdas.add(pda);\n    64→      if (round.phase === \"created\") {\n    65→        await db.updateRoundPhase(pda, \"locked\", {\n    66→          target_slot: targetSlot.toString(),\n    67→        });\n    68→        await db.insertOperatorEvent(pda, \"match_detected\", {\n    69→          targetSlot: targetSlot.toString(),\n    70→          currentSlot,\n    71→          game: round.game,\n    72→        });\n    73→        logger.info(\"settlement worker detected locked round\", {\n    74→          pda,\n    75→          creator: round.creator,\n    76→          targetSlot: targetSlot.toString(),\n    77→          currentSlot,\n    78→          slotTime,\n    79→          game: round.game,\n    80→        });\n    81→      }\n    82→    }\n    83→\n    84→    if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n    85→      if (deps.isFinalized?.(pda)) {\n    86→        // Clean up tracking sets for finalized PDAs to prevent unbounded growth\n    87→        discoveredPdas.delete(pda);\n    88→        readyPdas.delete(pda);\n    89→        return;\n    90→      }\n    91→\n    92→      const slotsAhead = currentSlot - Number(targetSlot);\n    93→      if (!readyPdas.has(pda)) {\n    94→        readyPdas.add(pda);\n    95→        logger.info(\"settlement worker found round ready\", {\n    96→          pda,\n    97→          targetSlot: targetSlot.toString(),\n    98→          currentSlot,\n    99→          slotsAhead,\n   100→          estimatedDelayMs: slotsAhead * 400,\n   101→          slotTime,\n   102→        });\n   103→      }\n   104→      const tSettle0 = performance.now();\n   105→      await deps.onSettleReady(pda);\n   106→      const tSettle1 = performance.now();\n   107→      logger.debug(\"settlement worker onSettleReady completed\", {\n   108→        pda: pda.slice(0, 12),\n   109→        settleMs: Math.round(tSettle1 - tSettle0),\n   110→      });\n   111→    }\n   112→  }\n   113→\n   114→  async function poll(): Promise<void> {\n   115→    const t0 = performance.now();\n   116→    const currentSlot = await connection.getSlot();\n   117→    const blockTime = await connection.getBlockTime(currentSlot).catch(() => null);\n   118→    const slotTime = blockTime ? new Date(blockTime * 1000).toISOString() : null;\n   119→    const tSlot = performance.now();\n   120→\n   121→    // Coinflip: fetch by dataSize (distinguishes Match from Config), decode + filter\n   122→    const coinflipAccounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n   123→      filters: [{ dataSize: coinflipMatchSize() }],\n   124→    });\n   125→    const tCoinflip = performance.now();\n   126→\n   127→    for (const { pubkey, account } of coinflipAccounts) {\n   128→      const key = pubkey.toBase58();\n   129→      if (undecodeablePdas.has(key)) continue;\n   130→      try {\n   131→        const match = decodeCoinflipMatch(Buffer.from(account.data));\n   132→        if (match.phase !== PHASE_LOCKED_VALUE || !match.server.equals(serverKey)) continue;\n   133→        await handleDiscoveredRound(key, match.targetSlot, currentSlot, slotTime);\n   134→      } catch {\n   135→        undecodeablePdas.add(key);\n   136→        logger.warn(\"skipping undecodeable coinflip account\", { pda: key });\n   137→      }\n   138→    }\n   139→\n   140→    // Lord: fetch by discriminator (variable-size accounts), decode + filter\n   141→    const lordAccounts = await connection.getProgramAccounts(LORDOFRNGS_PROGRAM_ID, {\n   142→      filters: [lordRoundDiscriminatorFilter()],\n   143→    });\n   144→    const tLord = performance.now();\n   145→\n   146→    for (const { pubkey, account } of lordAccounts) {\n   147→      const key = pubkey.toBase58();\n   148→      if (undecodeablePdas.has(key)) continue;\n   149→      try {\n   150→        const round = decodeLordRound(Buffer.from(account.data));\n   151→        if (round.phase !== LORD_PHASE_ACTIVE_VALUE || !round.server.equals(serverKey)) continue;\n   152→        if (round.targetEntropySlot <= 0n) continue;\n   153→        await handleDiscoveredRound(key, round.targetEntropySlot, currentSlot, slotTime);\n   154→      } catch {\n   155→        undecodeablePdas.add(key);\n   156→        logger.warn(\"skipping undecodeable lord account\", { pda: key });\n   157→      }\n   158→    }\n   159→    const tEnd = performance.now();\n   160→\n   161→    logger.debug(\"settlement poll cycle\", {\n   162→      slotMs: Math.round(tSlot - t0),\n   163→      coinflipFetchMs: Math.round(tCoinflip - tSlot),\n   164→      lordFetchMs: Math.round(tLord - tCoinflip),\n   165→      totalMs: Math.round(tEnd - t0),\n   166→      coinflipAccounts: coinflipAccounts.length,\n   167→      lordAccounts: lordAccounts.length,\n   168→      currentSlot,\n   169→      slotTime,\n   170→    });\n   171→  }\n   172→\n   173→  async function loop(): Promise<void> {\n   174→    if (!running) return;\n   175→    try {\n   176→      await poll();\n   177→    } catch (err) {\n   178→      // Log but don't crash — transient RPC errors are expected\n   179→      logger.error(\"settlement worker poll error\", {\n   180→        error: err instanceof Error ? err.message : String(err),\n   181→      });\n   182→    }\n   183→    if (running) {\n   184→      timeoutId = setTimeout(loop, pollIntervalMs);\n   185→    }\n   186→  }\n   187→\n   188→  return {\n   189→    start() {\n   190→      if (running) return;\n   191→      running = true;\n   192→      const rpcUrl = connection.rpcEndpoint;\n   193→      const trimmedRpc = (() => {\n   194→        try {\n   195→          const u = new URL(rpcUrl);\n   196→          return `${u.host}${u.pathname}`;\n   197→        } catch {\n   198→          return rpcUrl.slice(0, 40) + \"…\";\n   199→        }\n   200→      })();\n   201→      logger.info(\"settlement worker started\", {\n   202→        serverKey: serverKey.toBase58(),\n   203→        pollIntervalMs,\n   204→        rpc: trimmedRpc,\n   205→      });\n   206→      loop();\n   207→    },\n   208→    stop() {\n   209→      running = false;\n   210→      if (timeoutId) {\n   211→        clearTimeout(timeoutId);\n   212→        timeoutId = null;\n   213→      }\n   214→      logger.info(\"settlement worker stopped\", {\n   215→        serverKey: serverKey.toBase58(),\n   216→      });\n   217→    },\n   218→    get isRunning() {\n   219→      return running;\n   220→    },\n   221→    poll,\n   222→  };\n   223→}\n   224→"}]},"parent_tool_use_id":"toolu_01R9oEoy9wKwjzHJjaGks4p8","session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e","uuid":"f2399719-5468-41dc-90a2-64f180ebe96a"}
{"type":"system","subtype":"task_progress","task_id":"af2de18b4cf37ab9a","tool_use_id":"toolu_01R9oEoy9wKwjzHJjaGks4p8","description":"Reading sources/rng-utopia/services/backend/src/worker/account-decoder.ts","usage":{"total_tokens":38490,"tool_uses":4,"duration_ms":17002},"last_tool_name":"Read","uuid":"644f6324-5181-497d-9de2-c8048ea22039","session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_019kxJ4wtJxKX7c2Ze3qBMjS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RRBpSebZCnopYKMECcftXu","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/account-decoder.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":9216,"cache_read_input_tokens":29258,"cache_creation":{"ephemeral_5m_input_tokens":9216,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01R9oEoy9wKwjzHJjaGks4p8","session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e","uuid":"053775d7-5211-4b90-8f76-65144ffcedf3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RRBpSebZCnopYKMECcftXu","type":"tool_result","content":"     1→/**\n     2→ * IDL-driven account decoder — single source of truth for all Solana account\n     3→ * data access in the backend.\n     4→ *\n     5→ * Uses Anchor's BorshAccountsCoder to decode/encode accounts directly from\n     6→ * the generated IDL JSON files, eliminating all hardcoded byte offsets.\n     7→ */\n     8→\n     9→import anchor, { type Idl } from \"@coral-xyz/anchor\";\n    10→\n    11→const { BorshAccountsCoder, BN } = anchor;\n    12→import { PublicKey } from \"@solana/web3.js\";\n    13→import {\n    14→  CoinflipIDL as coinflipIdl,\n    15→  ClosecallIDL as closecallIdl,\n    16→  LordofrngsIDL as lordIdl,\n    17→} from \"@rng-utopia/anchor-client\";\n    18→\n    19→// ---------------------------------------------------------------------------\n    20→// Coders (instantiated once at module load)\n    21→// ---------------------------------------------------------------------------\n    22→\n    23→const coinflipCoder = new BorshAccountsCoder(coinflipIdl as Idl);\n    24→const closecallCoder = new BorshAccountsCoder(closecallIdl as Idl);\n    25→const lordCoder = new BorshAccountsCoder(lordIdl as Idl);\n    26→\n    27→// ---------------------------------------------------------------------------\n    28→// Type helpers\n    29→// ---------------------------------------------------------------------------\n    30→\n    31→function bnToBigInt(bn: InstanceType<typeof BN>): bigint {\n    32→  return BigInt(bn.toString());\n    33→}\n    34→\n    35→/**\n    36→ * Anchor decodes Rust enums as { VariantName: {} }. Convert RoundPhase to\n    37→ * the numeric value used throughout the backend.\n    38→ */\n    39→function roundPhaseToNumber(phase: Record<string, object>): number {\n    40→  if (\"Waiting\" in phase) return 0;\n    41→  if (\"Active\" in phase) return 1;\n    42→  if (\"Locked\" in phase) return 2;\n    43→  if (\"Resolving\" in phase) return 3;\n    44→  if (\"Settled\" in phase) return 4;\n    45→  if (\"Refunded\" in phase) return 5;\n    46→  throw new Error(`Unknown RoundPhase variant: ${JSON.stringify(phase)}`);\n    47→}\n    48→\n    49→/** CloseCallPhase enum: Open=0, Settled=1, Refunded=2 */\n    50→function closeCallPhaseToNumber(phase: Record<string, object>): number {\n    51→  if (\"Open\" in phase) return 0;\n    52→  if (\"Settled\" in phase) return 1;\n    53→  if (\"Refunded\" in phase) return 2;\n    54→  throw new Error(`Unknown CloseCallPhase variant: ${JSON.stringify(phase)}`);\n    55→}\n    56→\n    57→/** Outcome enum: Pending=0, Green=1, Red=2, Refund=3 */\n    58→function outcomeToNumber(outcome: Record<string, object>): number {\n    59→  if (\"Pending\" in outcome) return 0;\n    60→  if (\"Green\" in outcome) return 1;\n    61→  if (\"Red\" in outcome) return 2;\n    62→  if (\"Refund\" in outcome) return 3;\n    63→  throw new Error(`Unknown Outcome variant: ${JSON.stringify(outcome)}`);\n    64→}\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Exported interfaces (camelCase, BigInt instead of BN)\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export interface DecodedCoinflipMatch {\n    71→  creator: PublicKey;\n    72→  opponent: PublicKey;\n    73→  server: PublicKey;\n    74→  entryAmount: bigint;\n    75→  creatorSide: number;\n    76→  phase: number;\n    77→  commitment: number[];\n    78→  algorithmVer: number;\n    79→  targetSlot: bigint;\n    80→  resolveDeadline: bigint;\n    81→  resultHash: number[];\n    82→  result: number;\n    83→  winner: PublicKey;\n    84→  createdAt: bigint;\n    85→  matchId: number[];\n    86→  bump: number;\n    87→}\n    88→\n    89→export interface DecodedCoinflipConfig {\n    90→  authority: PublicKey;\n    91→  treasury: PublicKey;\n    92→  paused: boolean;\n    93→  bump: number;\n    94→}\n    95→\n    96→export interface DecodedJackpotRound {\n    97→  matchId: number[];\n    98→  server: PublicKey;\n    99→  phase: number;\n   100→  commitment: number[];\n   101→  algorithmVer: number;\n   102→  entries: Array<{ player: PublicKey; amountLamports: bigint }>;\n   103→  totalAmountLamports: bigint;\n   104→  distinctPlayers: number;\n   105→  createdAt: bigint;\n   106→  countdownStartedAt: bigint;\n   107→  countdownEndsAt: bigint;\n   108→  targetEntropySlot: bigint;\n   109→  resolveDeadline: bigint;\n   110→  resultHash: number[];\n   111→  winningOffset: bigint;\n   112→  winningEntryIndex: number;\n   113→  winner: PublicKey;\n   114→  creator: PublicKey;\n   115→  bump: number;\n   116→}\n   117→\n   118→export interface DecodedLordConfig {\n   119→  authority: PublicKey;\n   120→  treasury: PublicKey;\n   121→  paused: boolean;\n   122→  bump: number;\n   123→}\n   124→\n   125→export interface DecodedCloseCallRound {\n   126→  roundId: number[];\n   127→  server: PublicKey;\n   128→  phase: number;\n   129→  greenEntries: Array<{ player: PublicKey; amountLamports: bigint }>;\n   130→  redEntries: Array<{ player: PublicKey; amountLamports: bigint }>;\n   131→  greenPool: bigint;\n   132→  redPool: bigint;\n   133→  openPrice: bigint;\n   134→  openPriceExpo: number;\n   135→  closePrice: bigint;\n   136→  createdAt: bigint;\n   137→  bettingEndsAt: bigint;\n   138→  resolveDeadline: bigint;\n   139→  outcome: number;\n   140→  totalFee: bigint;\n   141→  bump: number;\n   142→}\n   143→\n   144→export interface DecodedCloseCallConfig {\n   145→  authority: PublicKey;\n   146→  treasury: PublicKey;\n   147→  pythFeedId: number[];\n   148→  bettingWindowSecs: number;\n   149→  maxEntriesPerSide: number;\n   150→  paused: boolean;\n   151→  bump: number;\n   152→}\n   153→\n   154→// ---------------------------------------------------------------------------\n   155→// Decode functions\n   156→// ---------------------------------------------------------------------------\n   157→\n   158→/* eslint-disable @typescript-eslint/no-explicit-any */\n   159→\n   160→export function decodeCoinflipMatch(data: Buffer): DecodedCoinflipMatch {\n   161→  const raw: any = coinflipCoder.decode(\"CoinflipMatch\", data);\n   162→  return {\n   163→    creator: raw.creator,\n   164→    opponent: raw.opponent,\n   165→    server: raw.server,\n   166→    entryAmount: bnToBigInt(raw.entry_amount),\n   167→    creatorSide: raw.creator_side,\n   168→    phase: raw.phase,\n   169→    commitment: raw.commitment,\n   170→    algorithmVer: raw.algorithm_ver,\n   171→    targetSlot: bnToBigInt(raw.target_slot),\n   172→    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n   173→    resultHash: raw.result_hash,\n   174→    result: raw.result,\n   175→    winner: raw.winner,\n   176→    createdAt: bnToBigInt(raw.created_at),\n   177→    matchId: raw.match_id,\n   178→    bump: raw.bump,\n   179→  };\n   180→}\n   181→\n   182→export function decodeCoinflipConfig(data: Buffer): DecodedCoinflipConfig {\n   183→  const raw: any = coinflipCoder.decode(\"CoinflipConfig\", data);\n   184→  return {\n   185→    authority: raw.authority,\n   186→    treasury: raw.treasury,\n   187→    paused: raw.paused,\n   188→    bump: raw.bump,\n   189→  };\n   190→}\n   191→\n   192→export function decodeLordRound(data: Buffer): DecodedJackpotRound {\n   193→  const raw: any = lordCoder.decode(\"JackpotRound\", data);\n   194→  return {\n   195→    matchId: raw.match_id,\n   196→    server: raw.server,\n   197→    phase: roundPhaseToNumber(raw.phase),\n   198→    commitment: raw.commitment,\n   199→    algorithmVer: raw.algorithm_ver,\n   200→    entries: raw.entries.map((e: any) => ({\n   201→      player: e.player,\n   202→      amountLamports: bnToBigInt(e.amount_lamports),\n   203→    })),\n   204→    totalAmountLamports: bnToBigInt(raw.total_amount_lamports),\n   205→    distinctPlayers: raw.distinct_players,\n   206→    createdAt: bnToBigInt(raw.created_at),\n   207→    countdownStartedAt: bnToBigInt(raw.countdown_started_at),\n   208→    countdownEndsAt: bnToBigInt(raw.countdown_ends_at),\n   209→    targetEntropySlot: bnToBigInt(raw.target_entropy_slot),\n   210→    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n   211→    resultHash: raw.result_hash,\n   212→    winningOffset: bnToBigInt(raw.winning_offset),\n   213→    winningEntryIndex: raw.winning_entry_index,\n   214→    winner: raw.winner,\n   215→    creator: raw.creator,\n   216→    bump: raw.bump,\n   217→  };\n   218→}\n   219→\n   220→export function decodeLordConfig(data: Buffer): DecodedLordConfig {\n   221→  const raw: any = lordCoder.decode(\"LordConfig\", data);\n   222→  return {\n   223→    authority: raw.authority,\n   224→    treasury: raw.treasury,\n   225→    paused: raw.paused,\n   226→    bump: raw.bump,\n   227→  };\n   228→}\n   229→\n   230→function decodeBetEntries(\n   231→  entries: any[],\n   232→): Array<{ player: PublicKey; amountLamports: bigint }> {\n   233→  return entries.map((e: any) => ({\n   234→    player: e.player,\n   235→    amountLamports: bnToBigInt(e.amount_lamports),\n   236→  }));\n   237→}\n   238→\n   239→export function decodeCloseCallRound(data: Buffer): DecodedCloseCallRound {\n   240→  const raw: any = closecallCoder.decode(\"CloseCallRound\", data);\n   241→  return {\n   242→    roundId: raw.round_id,\n   243→    server: raw.server,\n   244→    phase: closeCallPhaseToNumber(raw.phase),\n   245→    greenEntries: decodeBetEntries(raw.green_entries),\n   246→    redEntries: decodeBetEntries(raw.red_entries),\n   247→    greenPool: bnToBigInt(raw.green_pool),\n   248→    redPool: bnToBigInt(raw.red_pool),\n   249→    openPrice: bnToBigInt(raw.open_price),\n   250→    openPriceExpo: raw.open_price_expo,\n   251→    closePrice: bnToBigInt(raw.close_price),\n   252→    createdAt: bnToBigInt(raw.created_at),\n   253→    bettingEndsAt: bnToBigInt(raw.betting_ends_at),\n   254→    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n   255→    outcome: outcomeToNumber(raw.outcome),\n   256→    totalFee: bnToBigInt(raw.total_fee),\n   257→    bump: raw.bump,\n   258→  };\n   259→}\n   260→\n   261→export function decodeCloseCallConfig(data: Buffer): DecodedCloseCallConfig {\n   262→  const raw: any = closecallCoder.decode(\"CloseCallConfig\", data);\n   263→  return {\n   264→    authority: raw.authority,\n   265→    treasury: raw.treasury,\n   266→    pythFeedId: raw.pyth_feed_id,\n   267→    bettingWindowSecs: raw.betting_window_secs,\n   268→    maxEntriesPerSide: raw.max_entries_per_side,\n   269→    paused: raw.paused,\n   270→    bump: raw.bump,\n   271→  };\n   272→}\n   273→\n   274→/* eslint-enable @typescript-eslint/no-explicit-any */\n   275→\n   276→// ---------------------------------------------------------------------------\n   277→// Filter helpers for getProgramAccounts\n   278→// ---------------------------------------------------------------------------\n   279→\n   280→/** CoinflipMatch account size (includes 8-byte discriminator). */\n   281→export function coinflipMatchSize(): number {\n   282→  return coinflipCoder.size(\"CoinflipMatch\");\n   283→}\n   284→\n   285→/** Discriminator-based memcmp filter for JackpotRound accounts. */\n   286→export function lordRoundDiscriminatorFilter(): {\n   287→  memcmp: { offset: number; bytes: string };\n   288→} {\n   289→  return { memcmp: lordCoder.memcmp(\"JackpotRound\") };\n   290→}\n   291→\n   292→/** Discriminator-based memcmp filter for CloseCallRound accounts. */\n   293→export function closeCallRoundDiscriminatorFilter(): {\n   294→  memcmp: { offset: number; bytes: string };\n   295→} {\n   296→  return { memcmp: closecallCoder.memcmp(\"CloseCallRound\") };\n   297→}\n   298→\n   299→// ---------------------------------------------------------------------------\n   300→// Encode helpers (for integration tests)\n   301→// ---------------------------------------------------------------------------\n   302→\n   303→export async function encodeCoinflipMatch(\n   304→  fields: DecodedCoinflipMatch,\n   305→): Promise<Buffer> {\n   306→  return coinflipCoder.encode(\"CoinflipMatch\", {\n   307→    creator: fields.creator,\n   308→    opponent: fields.opponent,\n   309→    server: fields.server,\n   310→    entry_amount: new BN(fields.entryAmount.toString()),\n   311→    creator_side: fields.creatorSide,\n   312→    phase: fields.phase,\n   313→    commitment: fields.commitment,\n   314→    algorithm_ver: fields.algorithmVer,\n   315→    target_slot: new BN(fields.targetSlot.toString()),\n   316→    resolve_deadline: new BN(fields.resolveDeadline.toString()),\n   317→    result_hash: fields.resultHash,\n   318→    result: fields.result,\n   319→    winner: fields.winner,\n   320→    created_at: new BN(fields.createdAt.toString()),\n   321→    match_id: fields.matchId,\n   322→    bump: fields.bump,\n   323→  });\n   324→}\n   325→\n   326→export async function encodeCoinflipConfig(\n   327→  fields: DecodedCoinflipConfig,\n   328→): Promise<Buffer> {\n   329→  return coinflipCoder.encode(\"CoinflipConfig\", {\n   330→    authority: fields.authority,\n   331→    treasury: fields.treasury,\n   332→    paused: fields.paused,\n   333→    bump: fields.bump,\n   334→  });\n   335→}\n   336→"}]},"parent_tool_use_id":"toolu_01R9oEoy9wKwjzHJjaGks4p8","session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e","uuid":"50c0a785-9244-4cc7-b91e-a389848a63f3"}
