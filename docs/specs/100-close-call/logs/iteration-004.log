{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019GvY3ybUBDVsQ8RHDLNnqt","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::state::CloseCallConfig;\n     4→\n     5→#[derive(Accounts)]\n     6→pub struct InitializeConfig<'info> {\n     7→    #[account(mut)]\n     8→    pub authority: Signer<'info>,\n     9→\n    10→    #[account(\n    11→        init,\n    12→        payer = authority,\n    13→        space = 8 + CloseCallConfig::INIT_SPACE,\n    14→        seeds = [b\"closecall_config\"],\n    15→        bump,\n    16→    )]\n    17→    pub config: Account<'info, CloseCallConfig>,\n    18→\n    19→    pub system_program: Program<'info, System>,\n    20→}\n    21→\n    22→pub fn handler(\n    23→    ctx: Context<InitializeConfig>,\n    24→    treasury: Pubkey,\n    25→    pyth_feed_id: [u8; 32],\n    26→    betting_window_secs: u32,\n    27→    max_entries_per_side: u8,\n    28→) -> Result<()> {\n    29→    let config = &mut ctx.accounts.config;\n    30→    config.authority = ctx.accounts.authority.key();\n    31→    config.treasury = treasury;\n    32→    config.pyth_feed_id = pyth_feed_id;\n    33→    config.betting_window_secs = betting_window_secs;\n    34→    config.max_entries_per_side = max_entries_per_side;\n    35→    config.paused = false;\n    36→    config.bump = ctx.bumps.config;\n    37→    Ok(())\n    38→}\n    39→"}]},"parent_tool_use_id":"toolu_01YDRWH2KbC8qVxxFeq6cQ73","session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e","uuid":"79174297-f713-4d99-bc95-1e4c15a9716a"}
