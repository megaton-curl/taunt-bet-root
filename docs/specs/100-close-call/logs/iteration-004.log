{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QVXo2X1aEXg291xDmbLSLQ","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl } from \"@rng-utopia/anchor-client\";\n    23→import {\n    24→  decodeCoinflipMatch,\n    25→  decodeCoinflipConfig,\n    26→  decodeLordRound,\n    27→  decodeLordConfig,\n    28→  type DecodedJackpotRound,\n    29→} from \"./account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→function getInstructionDiscriminator(\n    36→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    37→  instructionName: string,\n    38→): Buffer {\n    39→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    40→  if (!instruction) {\n    41→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    42→  }\n    43→  return Buffer.from(instruction.discriminator);\n    44→}\n    45→\n    46→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    47→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    48→  lordIdl,\n    49→  \"claim_payout\",\n    50→);\n    51→\n    52→// ---------------------------------------------------------------------------\n    53→// Types\n    54→// ---------------------------------------------------------------------------\n    55→\n    56→export interface SettleTxDeps {\n    57→  db: Db;\n    58→  connection: Connection;\n    59→  serverKeypair: Keypair;\n    60→  entropyAccount: PublicKey;\n    61→}\n    62→\n    63→export interface SettleResult {\n    64→  txSignature: string;\n    65→  resultHash: Buffer;\n    66→  resultSide?: number;\n    67→  winningEntryIndex?: number;\n    68→  winner: string;\n    69→}\n    70→\n    71→// ---------------------------------------------------------------------------\n    72→// PDA helpers\n    73→// ---------------------------------------------------------------------------\n    74→\n    75→function deriveConfigPda(): [PublicKey, number] {\n    76→  return PublicKey.findProgramAddressSync(\n    77→    [Buffer.from(\"coinflip_config\")],\n    78→    COINFLIP_PROGRAM_ID,\n    79→  );\n    80→}\n    81→\n    82→function deriveLordConfigPda(): [PublicKey, number] {\n    83→  return PublicKey.findProgramAddressSync(\n    84→    [Buffer.from(\"lord_config\")],\n    85→    LORDOFRNGS_PROGRAM_ID,\n    86→  );\n    87→}\n    88→\n    89→// ---------------------------------------------------------------------------\n    90→// Instruction encoding\n    91→// ---------------------------------------------------------------------------\n    92→\n    93→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    94→function encodeSettleData(secret: Buffer): Buffer {\n    95→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    96→}\n    97→\n    98→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n    99→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n   100→}\n   101→\n   102→// ---------------------------------------------------------------------------\n   103→// Result derivation (mirrors on-chain derive_result)\n   104→// ---------------------------------------------------------------------------\n   105→\n   106→/**\n   107→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n   108→ * Must match shared/src/fairness.rs `derive_result()`.\n   109→ */\n   110→function deriveResult(\n   111→  secret: Buffer,\n   112→  entropy: Buffer,\n   113→  matchPdaBytes: Buffer,\n   114→  algoVer: number,\n   115→): Buffer {\n   116→  return createHash(\"sha256\")\n   117→    .update(secret)\n   118→    .update(entropy)\n   119→    .update(matchPdaBytes)\n   120→    .update(Buffer.from([algoVer]))\n   121→    .digest();\n   122→}\n   123→\n   124→// ---------------------------------------------------------------------------\n   125→// Core settle function\n   126→// ---------------------------------------------------------------------------\n   127→\n   128→/**\n   129→ * Build, submit, and confirm a settle transaction for a locked match.\n   130→ *\n   131→ * Steps:\n   132→ * 1. Retrieve secret from DB\n   133→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   134→ * 3. Fetch config account data (treasury)\n   135→ * 4. Read entropy from the entropy account\n   136→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   137→ * 6. Build + submit settle tx\n   138→ * 7. Update DB on confirmation\n   139→ */\n   140→export async function settleMatch(\n   141→  deps: SettleTxDeps,\n   142→  pda: string,\n   143→): Promise<SettleResult> {\n   144→  const t0 = performance.now();\n   145→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   146→  const matchPubkey = new PublicKey(pda);\n   147→\n   148→  // 1. Retrieve secret from DB\n   149→  const round = await db.getRoundByPda(pda);\n   150→  const tDb = performance.now();\n   151→  if (!round) {\n   152→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   153→  }\n   154→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   155→    throw new PermanentSettleError(\n   156→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   157→    );\n   158→  }\n   159→\n   160→  const secret = Buffer.from(round.secret);\n   161→\n   162→  // Transition to settling (locked → settling)\n   163→  if (round.phase === \"locked\") {\n   164→    await db.updateRoundPhase(pda, \"settling\");\n   165→  }\n   166→\n   167→  // Log settle_submitted\n   168→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   169→    attempt: round.settle_attempts + 1,\n   170→  });\n   171→\n   172→  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n   173→  const [configPda] = deriveConfigPda();\n   174→  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   175→    await Promise.all([\n   176→      connection.getAccountInfo(matchPubkey),\n   177→      connection.getAccountInfo(configPda),\n   178→      connection.getAccountInfo(entropyAccount),\n   179→      connection.getLatestBlockhash(),\n   180→    ]);\n   181→  const tFetch = performance.now();\n   182→\n   183→  if (!matchAccountInfo) {\n   184→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   185→  }\n   186→  if (!configAccountInfo) {\n   187→    throw new PermanentSettleError(\"Coinflip config account not found\");\n   188→  }\n   189→  if (!entropyInfo) {\n   190→    throw new TransientSettleError(\"Entropy account not available yet\");\n   191→  }\n   192→\n   193→  // IDL-driven decode — no manual byte offsets\n   194→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   195→  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n   196→\n   197→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   198→  const { treasury } = config;\n   199→\n   200→  const pool = entryAmount * 2n;\n   201→  const feeAmount = Number((pool * 300n) / 10_000n);\n   202→  const payoutAmount = Number(pool) - feeAmount;\n   203→\n   204→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   205→\n   206→  // 5. Pre-compute result\n   207→  const matchPdaBytes = matchPubkey.toBuffer();\n   208→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   209→  const resultSide = resultHash[0]! % 2;\n   210→  const winner = resultSide === creatorSide ? creator : opponent;\n   211→\n   212→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   213→  const data = encodeSettleData(secret);\n   214→\n   215→  const instruction = new TransactionInstruction({\n   216→    keys: [\n   217→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   218→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   219→      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n   220→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   221→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   222→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   223→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   224→      {\n   225→        pubkey: SystemProgram.programId,\n   226→        isSigner: false,\n   227→        isWritable: false,\n   228→      }, // system_program\n   229→    ],\n   230→    programId: COINFLIP_PROGRAM_ID,\n   231→    data,\n   232→  });\n   233→\n   234→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   235→\n   236→  const tx = new Transaction({\n   237→    feePayer: serverKeypair.publicKey,\n   238→    blockhash,\n   239→    lastValidBlockHeight,\n   240→  });\n   241→  tx.add(instruction);\n   242→  tx.sign(serverKeypair);\n   243→\n   244→  // 7. Submit and confirm\n   245→  const rawTx = tx.serialize();\n   246→  const tBuild = performance.now();\n   247→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   248→    skipPreflight: false,\n   249→  });\n   250→  const tSend = performance.now();\n   251→\n   252→  logger.info(\"settlement transaction submitted\", {\n   253→    pda,\n   254→    txSignature,\n   255→    attempt: round.settle_attempts + 1,\n   256→    dbMs: Math.round(tDb - t0),\n   257→    fetchMs: Math.round(tFetch - tDb),\n   258→    buildMs: Math.round(tBuild - tFetch),\n   259→    sendMs: Math.round(tSend - tBuild),\n   260→  });\n   261→\n   262→  const confirmation = await connection.confirmTransaction(\n   263→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   264→    \"confirmed\",\n   265→  );\n   266→  const tConfirm = performance.now();\n   267→  if (confirmation.value.err) {\n   268→    throw new TransientSettleError(\n   269→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   270→    );\n   271→  }\n   272→\n   273→  // 8. Update DB — phase settling → settled\n   274→  await db.updateRoundPhase(pda, \"settled\", {\n   275→    settle_tx: txSignature,\n   276→    result_hash: resultHash,\n   277→    result_side: resultSide,\n   278→    winner: winner.toBase58(),\n   279→    settle_attempts: round.settle_attempts + 1,\n   280→  });\n   281→\n   282→  // Log settle_confirmed\n   283→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   284→    txSignature,\n   285→    resultSide,\n   286→    winner: winner.toBase58(),\n   287→    entropy: entropy.toString(\"hex\"),\n   288→    payoutAmount,\n   289→    feeAmount,\n   290→  });\n   291→\n   292→  const tDone = performance.now();\n   293→  logger.info(\"settlement transaction confirmed\", {\n   294→    pda,\n   295→    txSignature,\n   296→    resultSide,\n   297→    winner: winner.toBase58(),\n   298→    timing: {\n   299→      dbMs: Math.round(tDb - t0),\n   300→      fetchMs: Math.round(tFetch - tDb),\n   301→      buildMs: Math.round(tBuild - tFetch),\n   302→      sendMs: Math.round(tSend - tBuild),\n   303→      confirmMs: Math.round(tConfirm - tSend),\n   304→      dbWriteMs: Math.round(tDone - tConfirm),\n   305→      totalMs: Math.round(tDone - t0),\n   306→    },\n   307→  });\n   308→\n   309→  return {\n   310→    txSignature,\n   311→    resultHash,\n   312→    resultSide,\n   313→    winner: winner.toBase58(),\n   314→  };\n   315→}\n   316→\n   317→export async function settleLordRound(\n   318→  deps: SettleTxDeps,\n   319→  pda: string,\n   320→): Promise<SettleResult> {\n   321→  const t0 = performance.now();\n   322→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   323→  const roundPubkey = new PublicKey(pda);\n   324→\n   325→  const round = await db.getRoundByPda(pda);\n   326→  const tDb = performance.now();\n   327→  if (!round) {\n   328→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   329→  }\n   330→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   331→    throw new PermanentSettleError(\n   332→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   333→    );\n   334→  }\n   335→\n   336→  const secret = Buffer.from(round.secret);\n   337→\n   338→  if (round.phase === \"locked\") {\n   339→    await db.updateRoundPhase(pda, \"settling\");\n   340→  }\n   341→\n   342→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   343→    attempt: round.settle_attempts + 1,\n   344→    game: \"lord\",\n   345→  });\n   346→\n   347→  const [configPda] = deriveLordConfigPda();\n   348→  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   349→    await Promise.all([\n   350→      connection.getAccountInfo(roundPubkey),\n   351→      connection.getAccountInfo(configPda),\n   352→      connection.getAccountInfo(entropyAccount),\n   353→      connection.getLatestBlockhash(),\n   354→    ]);\n   355→\n   356→  const tFetch = performance.now();\n   357→\n   358→  if (!roundAccountInfo) {\n   359→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   360→  }\n   361→  if (!configAccountInfo) {\n   362→    throw new PermanentSettleError(\"Lord config account not found\");\n   363→  }\n   364→  if (!entropyInfo) {\n   365→    throw new TransientSettleError(\"Entropy account not available yet\");\n   366→  }\n   367→\n   368→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   369→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   370→  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n   371→  const { treasury } = lordConfig;\n   372→\n   373→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   374→  const resultHash = deriveResult(\n   375→    secret,\n   376→    entropy,\n   377→    roundPubkey.toBuffer(),\n   378→    roundData.algorithmVer,\n   379→  );\n   380→  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n   381→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   382→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   383→\n   384→  const raw = resultHash.readBigUInt64LE(0);\n   385→  const winningOffset = raw % roundData.totalAmountLamports;\n   386→\n   387→  let cumulative = 0n;\n   388→  let winnerEntryIndex = -1;\n   389→  let winner = roundData.entries[0]?.player;\n   390→  for (const [index, entry] of roundData.entries.entries()) {\n   391→    cumulative += entry.amountLamports;\n   392→    if (winningOffset < cumulative) {\n   393→      winnerEntryIndex = index;\n   394→      winner = entry.player;\n   395→      break;\n   396→    }\n   397→  }\n   398→\n   399→  if (!winner || winnerEntryIndex < 0) {\n   400→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   401→  }\n   402→\n   403→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   404→  const instruction = new TransactionInstruction({\n   405→    keys: [\n   406→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   407→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   408→      { pubkey: configPda, isSigner: false, isWritable: false },\n   409→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   410→      { pubkey: treasury, isSigner: false, isWritable: true },\n   411→      { pubkey: winner, isSigner: false, isWritable: true },\n   412→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   413→    ],\n   414→    programId: LORDOFRNGS_PROGRAM_ID,\n   415→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   416→  });\n   417→\n   418→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   419→  const tx = new Transaction({\n   420→    feePayer: serverKeypair.publicKey,\n   421→    blockhash,\n   422→    lastValidBlockHeight,\n   423→  });\n   424→  tx.add(instruction);\n   425→  tx.sign(serverKeypair);\n   426→\n   427→  const tBuild = performance.now();\n   428→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   429→    skipPreflight: false,\n   430→  });\n   431→  const tSend = performance.now();\n   432→\n   433→  logger.info(\"lord settlement transaction submitted\", {\n   434→    pda,\n   435→    txSignature,\n   436→    attempt: round.settle_attempts + 1,\n   437→    winningEntryIndex: winnerEntryIndex,\n   438→    dbMs: Math.round(tDb - t0),\n   439→    fetchMs: Math.round(tFetch - tDb),\n   440→    buildMs: Math.round(tBuild - tFetch),\n   441→    sendMs: Math.round(tSend - tBuild),\n   442→  });\n   443→\n   444→  const confirmation = await connection.confirmTransaction(\n   445→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   446→    \"confirmed\",\n   447→  );\n   448→  const tConfirm = performance.now();\n   449→  if (confirmation.value.err) {\n   450→    throw new TransientSettleError(\n   451→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   452→    );\n   453→  }\n   454→\n   455→  await db.updateRoundPhase(pda, \"settled\", {\n   456→    settle_tx: txSignature,\n   457→    result_hash: resultHash,\n   458→    result_side: winnerEntryIndex,\n   459→    winner: winner.toBase58(),\n   460→    settle_attempts: round.settle_attempts + 1,\n   461→  });\n   462→\n   463→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   464→    txSignature,\n   465→    winner: winner.toBase58(),\n   466→    winningEntryIndex: winnerEntryIndex,\n   467→    game: \"lord\",\n   468→    entropy: entropy.toString(\"hex\"),\n   469→    winningOffset: winningOffset.toString(),\n   470→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   471→    payoutAmount,\n   472→    feeAmount,\n   473→    rentRefund,\n   474→  });\n   475→\n   476→  const tDone = performance.now();\n   477→  logger.info(\"lord settlement transaction confirmed\", {\n   478→    pda,\n   479→    txSignature,\n   480→    winner: winner.toBase58(),\n   481→    winningEntryIndex: winnerEntryIndex,\n   482→    timing: {\n   483→      dbMs: Math.round(tDb - t0),\n   484→      fetchMs: Math.round(tFetch - tDb),\n   485→      buildMs: Math.round(tBuild - tFetch),\n   486→      sendMs: Math.round(tSend - tBuild),\n   487→      confirmMs: Math.round(tConfirm - tSend),\n   488→      dbWriteMs: Math.round(tDone - tConfirm),\n   489→      totalMs: Math.round(tDone - t0),\n   490→    },\n   491→  });\n   492→\n   493→  return {\n   494→    txSignature,\n   495→    resultHash,\n   496→    winningEntryIndex: winnerEntryIndex,\n   497→    winner: winner.toBase58(),\n   498→  };\n   499→}\n   500→\n   501→export async function settleRound(\n   502→  deps: SettleTxDeps,\n   503→  pda: string,\n   504→): Promise<SettleResult> {\n   505→  const round = await deps.db.getRoundByPda(pda);\n   506→  if (!round) {\n   507→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   508→  }\n   509→\n   510→  if (round.game === \"lord\") {\n   511→    return settleLordRound(deps, pda);\n   512→  }\n   513→\n   514→  return settleMatch(deps, pda);\n   515→}\n   516→\n   517→// ---------------------------------------------------------------------------\n   518→// Error types\n   519→// ---------------------------------------------------------------------------\n   520→\n   521→/** Permanent failure — should not be retried. */\n   522→export class PermanentSettleError extends Error {\n   523→  readonly permanent = true;\n   524→  constructor(message: string) {\n   525→    super(message);\n   526→    this.name = \"PermanentSettleError\";\n   527→  }\n   528→}\n   529→\n   530→/** Transient failure — safe to retry. */\n   531→export class TransientSettleError extends Error {\n   532→  readonly permanent = false;\n   533→  constructor(message: string) {\n   534→    super(message);\n   535→    this.name = \"TransientSettleError\";\n   536→  }\n   537→}\n   538→"}]},"parent_tool_use_id":null,"session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e","uuid":"14e2af0f-885a-4107-bb01-b17f43d0855f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settle-tx.ts","content":"/**\n * Settle transaction builder + submission.\n *\n * Retrieves the stored secret, reads on-chain match + config data to resolve\n * all accounts, builds the `settle` instruction, submits it, and updates the\n * DB on confirmation.\n */\n\nimport { createHash } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\nimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl } from \"@rng-utopia/anchor-client\";\nimport {\n  decodeCoinflipMatch,\n  decodeCoinflipConfig,\n  decodeLordRound,\n  decodeLordConfig,\n  type DecodedJackpotRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Instruction discriminators (from IDL — no hardcoded byte arrays)\n// ---------------------------------------------------------------------------\n\nfunction getInstructionDiscriminator(\n  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n  instructionName: string,\n): Buffer {\n  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n  if (!instruction) {\n    throw new Error(`Instruction ${instructionName} not found in IDL`);\n  }\n  return Buffer.from(instruction.discriminator);\n}\n\nconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\nconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n  lordIdl,\n  \"claim_payout\",\n);\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface SettleTxDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  entropyAccount: PublicKey;\n}\n\nexport interface SettleResult {\n  txSignature: string;\n  resultHash: Buffer;\n  resultSide?: number;\n  winningEntryIndex?: number;\n  winner: string;\n}\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\n\nfunction deriveConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n\nfunction deriveLordConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID,\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Instruction encoding\n// ---------------------------------------------------------------------------\n\n/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\nfunction encodeSettleData(secret: Buffer): Buffer {\n  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n}\n\nfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n}\n\n// ---------------------------------------------------------------------------\n// Result derivation (mirrors on-chain derive_result)\n// ---------------------------------------------------------------------------\n\n/**\n * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n * Must match shared/src/fairness.rs `derive_result()`.\n */\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")\n    .update(secret)\n    .update(entropy)\n    .update(matchPdaBytes)\n    .update(Buffer.from([algoVer]))\n    .digest();\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on confirmation\n */\nexport async function settleMatch(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const matchPubkey = new PublicKey(pda);\n\n  // 1. Retrieve secret from DB\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  // Transition to settling (locked → settling)\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  // Log settle_submitted\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n  });\n\n  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n  const [configPda] = deriveConfigPda();\n  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(matchPubkey),\n      connection.getAccountInfo(configPda),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n  const tFetch = performance.now();\n\n  if (!matchAccountInfo) {\n    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n  }\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Coinflip config account not found\");\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets\n  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n\n  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n  const { treasury } = config;\n\n  const pool = entryAmount * 2n;\n  const feeAmount = Number((pool * 300n) / 10_000n);\n  const payoutAmount = Number(pool) - feeAmount;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n\n  // 5. Pre-compute result\n  const matchPdaBytes = matchPubkey.toBuffer();\n  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n  const resultSide = resultHash[0]! % 2;\n  const winner = resultSide === creatorSide ? creator : opponent;\n\n  // 6. Build settle instruction (8 accounts, no profile CPI)\n  const data = encodeSettleData(secret);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      }, // system_program\n    ],\n    programId: COINFLIP_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  // 7. Submit and confirm\n  const rawTx = tx.serialize();\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(rawTx, {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  // 8. Update DB — phase settling → settled\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: resultSide,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  // Log settle_confirmed\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    entropy: entropy.toString(\"hex\"),\n    payoutAmount,\n    feeAmount,\n  });\n\n  const tDone = performance.now();\n  logger.info(\"settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    resultSide,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleLordRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const roundPubkey = new PublicKey(pda);\n\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n    game: \"lord\",\n  });\n\n  const [configPda] = deriveLordConfigPda();\n  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(roundPubkey),\n      connection.getAccountInfo(configPda),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n\n  const tFetch = performance.now();\n\n  if (!roundAccountInfo) {\n    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n  }\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Lord config account not found\");\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets or parseLordRound()\n  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n  const { treasury } = lordConfig;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n  const resultHash = deriveResult(\n    secret,\n    entropy,\n    roundPubkey.toBuffer(),\n    roundData.algorithmVer,\n  );\n  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n\n  const raw = resultHash.readBigUInt64LE(0);\n  const winningOffset = raw % roundData.totalAmountLamports;\n\n  let cumulative = 0n;\n  let winnerEntryIndex = -1;\n  let winner = roundData.entries[0]?.player;\n  for (const [index, entry] of roundData.entries.entries()) {\n    cumulative += entry.amountLamports;\n    if (winningOffset < cumulative) {\n      winnerEntryIndex = index;\n      winner = entry.player;\n      break;\n    }\n  }\n\n  if (!winner || winnerEntryIndex < 0) {\n    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n  }\n\n  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n      { pubkey: configPda, isSigner: false, isWritable: false },\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: winner, isSigner: false, isWritable: true },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: LORDOFRNGS_PROGRAM_ID,\n    data: encodeClaimPayoutData(matchIdBuf, secret),\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"lord settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    winningEntryIndex: winnerEntryIndex,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: winnerEntryIndex,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    game: \"lord\",\n    entropy: entropy.toString(\"hex\"),\n    winningOffset: winningOffset.toString(),\n    totalAmountLamports: Number(roundData.totalAmountLamports),\n    payoutAmount,\n    feeAmount,\n    rentRefund,\n  });\n\n  const tDone = performance.now();\n  logger.info(\"lord settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    winningEntryIndex: winnerEntryIndex,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const round = await deps.db.getRoundByPda(pda);\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n\n  if (round.game === \"lord\") {\n    return settleLordRound(deps, pda);\n  }\n\n  return settleMatch(deps, pda);\n}\n\n// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------\n\n/** Permanent failure — should not be retried. */\nexport class PermanentSettleError extends Error {\n  readonly permanent = true;\n  constructor(message: string) {\n    super(message);\n    this.name = \"PermanentSettleError\";\n  }\n}\n\n/** Transient failure — safe to retry. */\nexport class TransientSettleError extends Error {\n  readonly permanent = false;\n  constructor(message: string) {\n    super(message);\n    this.name = \"TransientSettleError\";\n  }\n}\n","numLines":538,"startLine":1,"totalLines":538}}}
