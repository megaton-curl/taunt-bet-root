{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0171Z2t5h4eqFrr2P4D3N9Fk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HvAtNEfAw1njhcdjpb7CtU","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settle-tx.ts","old_string":"// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------","new_string":"// ---------------------------------------------------------------------------\n// Close Call — transaction builders\n// ---------------------------------------------------------------------------\n\nfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"closecall_config\")],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\nfunction deriveCloseCallRoundPda(roundId: Buffer): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), roundId],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\n/** Encode closecall instruction data: discriminator(8) + round_id(8) = 16 bytes */\nfunction encodeCcRoundIdData(discriminator: Buffer, roundId: Buffer): Buffer {\n  return Buffer.concat([discriminator, roundId]);\n}\n\nexport interface CloseCallTxDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\n/**\n * Build a signed `create_round` transaction for the Close Call program.\n *\n * The server pays rent and is the sole signer. The Pyth price account is read\n * on-chain to store the candle open price.\n */\nexport async function buildCloseCallCreateRoundTx(\n  deps: CloseCallTxDeps,\n  roundId: Buffer,\n  pythPriceAccount: PublicKey,\n): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(roundId);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcRoundIdData(CC_CREATE_ROUND_DISCRIMINATOR, roundId);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // server (pays rent)\n      { pubkey: configPda, isSigner: false, isWritable: false },               // config\n      { pubkey: roundPda, isSigner: false, isWritable: true },                 // round (init)\n      { pubkey: pythPriceAccount, isSigner: false, isWritable: false },        // price_update\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false }, // system_program\n    ],\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return { tx, roundPda };\n}\n\n/**\n * Build a signed `settle_round` transaction for the Close Call program.\n *\n * Reads Pyth close price on-chain to determine outcome. Winners (or all\n * players for refund) are passed as remaining accounts for auto-payout.\n */\nexport async function buildCloseCallSettleRoundTx(\n  deps: CloseCallTxDeps,\n  roundId: Buffer,\n  pythPriceAccount: PublicKey,\n  treasury: PublicKey,\n  winnerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(roundId);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcRoundIdData(CC_SETTLE_ROUND_DISCRIMINATOR, roundId);\n\n  const keys = [\n    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n    { pubkey: pythPriceAccount, isSigner: false, isWritable: false },        // price_update\n    { pubkey: treasury, isSigner: false, isWritable: true },                 // treasury\n    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n    ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n  ];\n\n  const instruction = new TransactionInstruction({\n    keys,\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n/**\n * Build a signed `timeout_refund` transaction for the Close Call program.\n *\n * Permissionless after the resolve deadline. Refunds all players their exact\n * deposit via remaining accounts.\n */\nexport async function buildCloseCallTimeoutRefundTx(\n  deps: CloseCallTxDeps,\n  roundId: Buffer,\n  playerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(roundId);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcRoundIdData(CC_TIMEOUT_REFUND_DISCRIMINATOR, roundId);\n\n  const keys = [\n    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n  ];\n\n  const instruction = new TransactionInstruction({\n    keys,\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":413,"cache_read_input_tokens":65934,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":413},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e","uuid":"215b78ec-0b3e-499a-a16c-7d14e4e4284f"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HvAtNEfAw1njhcdjpb7CtU","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settle-tx.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"3173b348-180a-4cf2-ac38-47c17bdb617e","uuid":"063b073c-c1a3-4fae-b029-122de5de79d8","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settle-tx.ts","oldString":"// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------","newString":"// ---------------------------------------------------------------------------\n// Close Call — transaction builders\n// ---------------------------------------------------------------------------\n\nfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"closecall_config\")],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\nfunction deriveCloseCallRoundPda(roundId: Buffer): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), roundId],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\n/** Encode closecall instruction data: discriminator(8) + round_id(8) = 16 bytes */\nfunction encodeCcRoundIdData(discriminator: Buffer, roundId: Buffer): Buffer {\n  return Buffer.concat([discriminator, roundId]);\n}\n\nexport interface CloseCallTxDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\n/**\n * Build a signed `create_round` transaction for the Close Call program.\n *\n * The server pays rent and is the sole signer. The Pyth price account is read\n * on-chain to store the candle open price.\n */\nexport async function buildCloseCallCreateRoundTx(\n  deps: CloseCallTxDeps,\n  roundId: Buffer,\n  pythPriceAccount: PublicKey,\n): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(roundId);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcRoundIdData(CC_CREATE_ROUND_DISCRIMINATOR, roundId);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // server (pays rent)\n      { pubkey: configPda, isSigner: false, isWritable: false },               // config\n      { pubkey: roundPda, isSigner: false, isWritable: true },                 // round (init)\n      { pubkey: pythPriceAccount, isSigner: false, isWritable: false },        // price_update\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false }, // system_program\n    ],\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return { tx, roundPda };\n}\n\n/**\n * Build a signed `settle_round` transaction for the Close Call program.\n *\n * Reads Pyth close price on-chain to determine outcome. Winners (or all\n * players for refund) are passed as remaining accounts for auto-payout.\n */\nexport async function buildCloseCallSettleRoundTx(\n  deps: CloseCallTxDeps,\n  roundId: Buffer,\n  pythPriceAccount: PublicKey,\n  treasury: PublicKey,\n  winnerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(roundId);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcRoundIdData(CC_SETTLE_ROUND_DISCRIMINATOR, roundId);\n\n  const keys = [\n    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n    { pubkey: pythPriceAccount, isSigner: false, isWritable: false },        // price_update\n    { pubkey: treasury, isSigner: false, isWritable: true },                 // treasury\n    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n    ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n  ];\n\n  const instruction = new TransactionInstruction({\n    keys,\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n/**\n * Build a signed `timeout_refund` transaction for the Close Call program.\n *\n * Permissionless after the resolve deadline. Refunds all players their exact\n * deposit via remaining accounts.\n */\nexport async function buildCloseCallTimeoutRefundTx(\n  deps: CloseCallTxDeps,\n  roundId: Buffer,\n  playerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(roundId);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcRoundIdData(CC_TIMEOUT_REFUND_DISCRIMINATOR, roundId);\n\n  const keys = [\n    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n    { pubkey: configPda, isSigner: false, isWritable: false },               // config\n    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n  ];\n\n  const instruction = new TransactionInstruction({\n    keys,\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------","originalFile":"/**\n * Settle transaction builder + submission.\n *\n * Retrieves the stored secret, reads on-chain match + config data to resolve\n * all accounts, builds the `settle` instruction, submits it, and updates the\n * DB on confirmation.\n */\n\nimport { createHash } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\nimport {\n  decodeCoinflipMatch,\n  decodeCoinflipConfig,\n  decodeLordRound,\n  decodeLordConfig,\n  type DecodedJackpotRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Instruction discriminators (from IDL — no hardcoded byte arrays)\n// ---------------------------------------------------------------------------\n\nfunction getInstructionDiscriminator(\n  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n  instructionName: string,\n): Buffer {\n  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n  if (!instruction) {\n    throw new Error(`Instruction ${instructionName} not found in IDL`);\n  }\n  return Buffer.from(instruction.discriminator);\n}\n\nconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\nconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n  lordIdl,\n  \"claim_payout\",\n);\nconst CC_CREATE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"create_round\");\nconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\nconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface SettleTxDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  entropyAccount: PublicKey;\n}\n\nexport interface SettleResult {\n  txSignature: string;\n  resultHash: Buffer;\n  resultSide?: number;\n  winningEntryIndex?: number;\n  winner: string;\n}\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\n\nfunction deriveConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n\nfunction deriveLordConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID,\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Instruction encoding\n// ---------------------------------------------------------------------------\n\n/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\nfunction encodeSettleData(secret: Buffer): Buffer {\n  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n}\n\nfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n}\n\n// ---------------------------------------------------------------------------\n// Result derivation (mirrors on-chain derive_result)\n// ---------------------------------------------------------------------------\n\n/**\n * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n * Must match shared/src/fairness.rs `derive_result()`.\n */\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")\n    .update(secret)\n    .update(entropy)\n    .update(matchPdaBytes)\n    .update(Buffer.from([algoVer]))\n    .digest();\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on confirmation\n */\nexport async function settleMatch(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const matchPubkey = new PublicKey(pda);\n\n  // 1. Retrieve secret from DB\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  // Transition to settling (locked → settling)\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  // Log settle_submitted\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n  });\n\n  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n  const [configPda] = deriveConfigPda();\n  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(matchPubkey),\n      connection.getAccountInfo(configPda),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n  const tFetch = performance.now();\n\n  if (!matchAccountInfo) {\n    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n  }\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Coinflip config account not found\");\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets\n  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n\n  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n  const { treasury } = config;\n\n  const pool = entryAmount * 2n;\n  const feeAmount = Number((pool * 300n) / 10_000n);\n  const payoutAmount = Number(pool) - feeAmount;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n\n  // 5. Pre-compute result\n  const matchPdaBytes = matchPubkey.toBuffer();\n  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n  const resultSide = resultHash[0]! % 2;\n  const winner = resultSide === creatorSide ? creator : opponent;\n\n  // 6. Build settle instruction (8 accounts, no profile CPI)\n  const data = encodeSettleData(secret);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      }, // system_program\n    ],\n    programId: COINFLIP_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  // 7. Submit and confirm\n  const rawTx = tx.serialize();\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(rawTx, {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  // 8. Update DB — phase settling → settled\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: resultSide,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  // Log settle_confirmed\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    entropy: entropy.toString(\"hex\"),\n    payoutAmount,\n    feeAmount,\n  });\n\n  const tDone = performance.now();\n  logger.info(\"settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    resultSide,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleLordRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const roundPubkey = new PublicKey(pda);\n\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n    game: \"lord\",\n  });\n\n  const [configPda] = deriveLordConfigPda();\n  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(roundPubkey),\n      connection.getAccountInfo(configPda),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n\n  const tFetch = performance.now();\n\n  if (!roundAccountInfo) {\n    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n  }\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Lord config account not found\");\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets or parseLordRound()\n  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n  const { treasury } = lordConfig;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n  const resultHash = deriveResult(\n    secret,\n    entropy,\n    roundPubkey.toBuffer(),\n    roundData.algorithmVer,\n  );\n  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n\n  const raw = resultHash.readBigUInt64LE(0);\n  const winningOffset = raw % roundData.totalAmountLamports;\n\n  let cumulative = 0n;\n  let winnerEntryIndex = -1;\n  let winner = roundData.entries[0]?.player;\n  for (const [index, entry] of roundData.entries.entries()) {\n    cumulative += entry.amountLamports;\n    if (winningOffset < cumulative) {\n      winnerEntryIndex = index;\n      winner = entry.player;\n      break;\n    }\n  }\n\n  if (!winner || winnerEntryIndex < 0) {\n    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n  }\n\n  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n      { pubkey: configPda, isSigner: false, isWritable: false },\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: winner, isSigner: false, isWritable: true },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: LORDOFRNGS_PROGRAM_ID,\n    data: encodeClaimPayoutData(matchIdBuf, secret),\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"lord settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    winningEntryIndex: winnerEntryIndex,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: winnerEntryIndex,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    game: \"lord\",\n    entropy: entropy.toString(\"hex\"),\n    winningOffset: winningOffset.toString(),\n    totalAmountLamports: Number(roundData.totalAmountLamports),\n    payoutAmount,\n    feeAmount,\n    rentRefund,\n  });\n\n  const tDone = performance.now();\n  logger.info(\"lord settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    winningEntryIndex: winnerEntryIndex,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const round = await deps.db.getRoundByPda(pda);\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n\n  if (round.game === \"lord\") {\n    return settleLordRound(deps, pda);\n  }\n\n  return settleMatch(deps, pda);\n}\n\n// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------\n\n/** Permanent failure — should not be retried. */\nexport class PermanentSettleError extends Error {\n  readonly permanent = true;\n  constructor(message: string) {\n    super(message);\n    this.name = \"PermanentSettleError\";\n  }\n}\n\n/** Transient failure — safe to retry. */\nexport class TransientSettleError extends Error {\n  readonly permanent = false;\n  constructor(message: string) {\n    super(message);\n    this.name = \"TransientSettleError\";\n  }\n}\n","structuredPatch":[{"oldStart":518,"oldLines":6,"newStart":518,"newLines":153,"lines":[" }"," "," // ---------------------------------------------------------------------------","+// Close Call — transaction builders","+// ---------------------------------------------------------------------------","+","+function deriveCloseCallConfigPda(): [PublicKey, number] {","+  return PublicKey.findProgramAddressSync(","+    [Buffer.from(\"closecall_config\")],","+    CLOSECALL_PROGRAM_ID,","+  );","+}","+","+function deriveCloseCallRoundPda(roundId: Buffer): [PublicKey, number] {","+  return PublicKey.findProgramAddressSync(","+    [Buffer.from(\"cc_round\"), roundId],","+    CLOSECALL_PROGRAM_ID,","+  );","+}","+","+/** Encode closecall instruction data: discriminator(8) + round_id(8) = 16 bytes */","+function encodeCcRoundIdData(discriminator: Buffer, roundId: Buffer): Buffer {","+  return Buffer.concat([discriminator, roundId]);","+}","+","+export interface CloseCallTxDeps {","+  connection: Connection;","+  serverKeypair: Keypair;","+}","+","+/**","+ * Build a signed `create_round` transaction for the Close Call program.","+ *","+ * The server pays rent and is the sole signer. The Pyth price account is read","+ * on-chain to store the candle open price.","+ */","+export async function buildCloseCallCreateRoundTx(","+  deps: CloseCallTxDeps,","+  roundId: Buffer,","+  pythPriceAccount: PublicKey,","+): Promise<{ tx: Transaction; roundPda: PublicKey }> {","+  const { connection, serverKeypair } = deps;","+","+  const [roundPda] = deriveCloseCallRoundPda(roundId);","+  const [configPda] = deriveCloseCallConfigPda();","+  const data = encodeCcRoundIdData(CC_CREATE_ROUND_DISCRIMINATOR, roundId);","+","+  const instruction = new TransactionInstruction({","+    keys: [","+      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // server (pays rent)","+      { pubkey: configPda, isSigner: false, isWritable: false },               // config","+      { pubkey: roundPda, isSigner: false, isWritable: true },                 // round (init)","+      { pubkey: pythPriceAccount, isSigner: false, isWritable: false },        // price_update","+      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false }, // system_program","+    ],","+    programId: CLOSECALL_PROGRAM_ID,","+    data,","+  });","+","+  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();","+  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });","+  tx.add(instruction);","+  tx.sign(serverKeypair);","+","+  return { tx, roundPda };","+}","+","+/**","+ * Build a signed `settle_round` transaction for the Close Call program.","+ *","+ * Reads Pyth close price on-chain to determine outcome. Winners (or all","+ * players for refund) are passed as remaining accounts for auto-payout.","+ */","+export async function buildCloseCallSettleRoundTx(","+  deps: CloseCallTxDeps,","+  roundId: Buffer,","+  pythPriceAccount: PublicKey,","+  treasury: PublicKey,","+  winnerAccounts: PublicKey[],","+): Promise<Transaction> {","+  const { connection, serverKeypair } = deps;","+","+  const [roundPda] = deriveCloseCallRoundPda(roundId);","+  const [configPda] = deriveCloseCallConfigPda();","+  const data = encodeCcRoundIdData(CC_SETTLE_ROUND_DISCRIMINATOR, roundId);","+","+  const keys = [","+    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller","+    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round","+    { pubkey: configPda, isSigner: false, isWritable: false },               // config","+    { pubkey: pythPriceAccount, isSigner: false, isWritable: false },        // price_update","+    { pubkey: treasury, isSigner: false, isWritable: true },                 // treasury","+    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)","+    ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),","+  ];","+","+  const instruction = new TransactionInstruction({","+    keys,","+    programId: CLOSECALL_PROGRAM_ID,","+    data,","+  });","+","+  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();","+  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });","+  tx.add(instruction);","+  tx.sign(serverKeypair);","+","+  return tx;","+}","+","+/**","+ * Build a signed `timeout_refund` transaction for the Close Call program.","+ *","+ * Permissionless after the resolve deadline. Refunds all players their exact","+ * deposit via remaining accounts.","+ */","+export async function buildCloseCallTimeoutRefundTx(","+  deps: CloseCallTxDeps,","+  roundId: Buffer,","+  playerAccounts: PublicKey[],","+): Promise<Transaction> {","+  const { connection, serverKeypair } = deps;","+","+  const [roundPda] = deriveCloseCallRoundPda(roundId);","+  const [configPda] = deriveCloseCallConfigPda();","+  const data = encodeCcRoundIdData(CC_TIMEOUT_REFUND_DISCRIMINATOR, roundId);","+","+  const keys = [","+    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller","+    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round","+    { pubkey: configPda, isSigner: false, isWritable: false },               // config","+    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)","+    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),","+  ];","+","+  const instruction = new TransactionInstruction({","+    keys,","+    programId: CLOSECALL_PROGRAM_ID,","+    data,","+  });","+","+  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();","+  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });","+  tx.add(instruction);","+  tx.sign(serverKeypair);","+","+  return tx;","+}","+","+// ---------------------------------------------------------------------------"," // Error types"," // ---------------------------------------------------------------------------"," "]}],"userModified":false,"replaceAll":false}}
