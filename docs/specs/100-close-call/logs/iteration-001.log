2);\n    43→PYTH_BTC_USD_FEED_ID.write(\"e62df6c8b4a85fe1a67db44dc12de5db\", 0, 16, \"hex\");\n    44→PYTH_BTC_USD_FEED_ID.write(\"330f7ac66b72dc658afedf0f4a415b43\", 16, 16, \"hex\");\n    45→\n    46→// ---------------------------------------------------------------------------\n    47→// Mock Pyth PriceUpdateV2 account builder\n    48→// ---------------------------------------------------------------------------\n    49→function buildMockPythAccount(\n    50→  price: bigint,\n    51→  exponent: number,\n    52→  feedId: Buffer,\n    53→  publishTime: bigint\n    54→): Buffer {\n    55→  // Layout: [8 disc][32 write_auth][1 verif_level][32 feed_id][8 price][8 conf]\n    56→  //         [4 expo][8 publish_time][8 prev_publish_time][8 ema_price][8 ema_conf][8 posted_slot]\n    57→  const buf = Buffer.alloc(133);\n    58→  let offset = 0;\n    59→\n    60→  // Discriminator (8 bytes — arbitrary, program skips these)\n    61→  buf.fill(0xde, offset, offset + 8);\n    62→  offset += 8;\n    63→\n    64→  // write_authority (32 bytes — zeros)\n    65→  offset += 32;\n    66→\n    67→  // verification_level: Full = variant index 1\n    68→  buf.writeUInt8(1, offset);\n    69→  offset += 1;\n    70→\n    71→  // feed_id (32 bytes)\n    72→  feedId.copy(buf, offset);\n    73→  offset += 32;\n    74→\n    75→  // price (i64 LE)\n    76→  buf.writeBigInt64LE(price, offset);\n    77→  offset += 8;\n    78→\n    79→  // conf (u64 LE)\n    80→  buf.writeBigUInt64LE(100n, offset);\n    81→  offset += 8;\n    82→\n    83→  // exponent (i32 LE)\n    84→  buf.writeInt32LE(exponent, offset);\n    85→  offset += 4;\n    86→\n    87→  // publish_time (i64 LE)\n    88→  buf.writeBigInt64LE(publishTime, offset);\n    89→  offset += 8;\n    90→\n    91→  // prev_publish_time (i64 LE)\n    92→  buf.writeBigInt64LE(publishTime - 1n, offset);\n    93→  offset += 8;\n    94→\n    95→  // ema_price (i64 LE)\n    96→  buf.writeBigInt64LE(price, offset);\n    97→  offset += 8;\n    98→\n    99→  // ema_conf (u64 LE)\n   100→  buf.writeBigUInt64LE(100n, offset);"}]},"parent_tool_use_id":"toolu_011rr1yfgNLixmd4MBJw5da9","session_id":"846c05db-31a6-42c7-8cfa-8e6a53a70110","uuid":"e2708e71-3e7a-47c9-9a12-b2928ebba5fb"}
