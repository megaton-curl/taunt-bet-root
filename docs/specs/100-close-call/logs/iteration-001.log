{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011AbJ5AbdszAPuxE9v1s5tN","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→\n     4→use crate::error::CloseCallError;\n     5→use crate::state::{CloseCallConfig, CloseCallPhase, CloseCallRound, Outcome};\n     6→\n     7→#[derive(Accounts)]\n     8→#[instruction(round_id: [u8; 8])]\n     9→pub struct ForceClose<'info> {\n    10→    /// Config authority (admin only).\n    11→    pub authority: Signer<'info>,\n    12→\n    13→    /// The round PDA (closed after refunds — rent goes to server).\n    14→    #[account(\n    15→        mut,\n    16→        close = rent_receiver,\n    17→        seeds = [b\"cc_round\", &round_id],\n    18→        bump = round.bump,\n    19→    )]\n    20→    pub round: Account<'info, CloseCallRound>,\n    21→\n    22→    /// Config PDA — validates authority via `has_one`.\n    23→    #[account(\n    24→        seeds = [b\"closecall_config\"],\n    25→        bump = config.bump,\n    26→        has_one = authority,\n    27→    )]\n    28→    pub config: Account<'info, CloseCallConfig>,\n    29→\n    30→    /// Server wallet that paid rent (receives rent on close).\n    31→    /// CHECK: Validated against round.server in handler.\n    32→    #[account(mut)]\n    33→    pub rent_receiver: AccountInfo<'info>,\n    34→\n    35→    // Remaining accounts: all player wallets [green_0..green_n, red_0..red_m].\n    36→}\n    37→\n    38→pub fn handler<'info>(\n    39→    ctx: Context<'_, '_, 'info, 'info, ForceClose<'info>>,\n    40→    _round_id: [u8; 8],\n    41→) -> Result<()> {\n    42→    let round = &ctx.accounts.round;\n    43→    require!(\n    44→        round.phase == CloseCallPhase::Open,\n    45→        CloseCallError::InvalidPhase\n    46→    );\n    47→\n    48→    require_keys_eq!(\n    49→        ctx.accounts.rent_receiver.key(),\n    50→        round.server,\n    51→        CloseCallError::AccountMismatch\n    52→    );\n    53→\n    54→    let green_count = round.green_entries.len();\n    55→    let red_count = round.red_entries.len();\n    56→    let total_count = green_count + red_count;\n    57→    let remaining = ctx.remaining_accounts;\n    58→\n    59→    if total_count > 0 {\n    60→        require!(\n    61→            remaining.len() == total_count,\n    62→            CloseCallError::RemainingAccountsMismatch\n    63→        );\n    64→\n    65→        let round_info = ctx.accounts.round.to_account_info();\n    66→\n    67→        for (i, entry) in round.green_entries.iter().enumerate() {\n    68→            let player_account = &remaining[i];\n    69→            require_keys_eq!(\n    70→                player_account.key(),\n    71→                entry.player,\n    72→                CloseCallError::AccountMismatch\n    73→            );\n    74→            transfer_lamports_from_pda(&round_info, player_account, entry.amount_lamports)?;\n    75→        }\n    76→\n    77→        for (i, entry) in round.red_entries.iter().enumerate() {\n    78→            let player_account = &remaining[green_count + i];\n    79→            require_keys_eq!(\n    80→                player_account.key(),\n    81→                entry.player,\n    82→                CloseCallError::AccountMismatch\n    83→            );\n    84→            transfer_lamports_from_pda(&round_info, player_account, entry.amount_lamports)?;\n    85→        }\n    86→    }\n    87→\n    88→    let round = &mut ctx.accounts.round;\n    89→    round.phase = CloseCallPhase::Refunded;\n    90→    round.outcome = Outcome::Refund;\n    91→\n    92→    Ok(())\n    93→}\n    94→"}]},"parent_tool_use_id":"toolu_01LhUCdQ4XVVfKqy9b4uuRkN","session_id":"846c05db-31a6-42c7-8cfa-8e6a53a70110","uuid":"84e53489-14b2-45bf-9154-391b7d37f159"}
