{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FVr34PgqmYufmYTPRUqtp1","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Betting side in Close Call.\n     4→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\n     5→pub enum BetSide {\n     6→    Green,\n     7→    Red,\n     8→}\n     9→\n    10→/// Round lifecycle phase.\n    11→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\n    12→pub enum CloseCallPhase {\n    13→    /// Round is open for bets (first 30s of candle).\n    14→    Open,\n    15→    /// Outcome determined, payouts distributed.\n    16→    Settled,\n    17→    /// All bets refunded (invalid round, timeout, or force close).\n    18→    Refunded,\n    19→}\n    20→\n    21→/// Settlement outcome.\n    22→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\n    23→pub enum Outcome {\n    24→    Pending,\n    25→    Green,\n    26→    Red,\n    27→    Refund,\n    28→}\n    29→\n    30→/// A single bet entry.\n    31→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Debug, InitSpace)]\n    32→pub struct BetEntry {\n    33→    pub player: Pubkey,\n    34→    pub amount_lamports: u64,\n    35→}\n    36→\n    37→/// Global configuration for the Close Call program.\n    38→/// PDA seeds: [b\"closecall_config\"]\n    39→#[account]\n    40→#[derive(InitSpace)]\n    41→pub struct CloseCallConfig {\n    42→    /// Admin authority (can update config, force close).\n    43→    pub authority: Pubkey,\n    44→    /// Fee destination wallet.\n    45→    pub treasury: Pubkey,\n    46→    /// Pyth price feed ID for BTC/USD (32 bytes).\n    47→    pub pyth_feed_id: [u8; 32],\n    48→    /// Betting window duration in seconds (default 30).\n    49→    pub betting_window_secs: u32,\n    50→    /// Maximum entries per side (default 32).\n    51→    pub max_entries_per_side: u8,\n    52→    /// Whether the game is paused.\n    53→    pub paused: bool,\n    54→    /// Bump seed for PDA derivation.\n    55→    pub bump: u8,\n    56→}\n    57→\n    58→/// A Close Call round.\n    59→/// PDA seeds: [b\"cc_round\", &round_id]\n    60→#[account]\n    61→#[derive(InitSpace)]\n    62→pub struct CloseCallRound {\n    63→    /// Backend-generated random round ID (used in PDA seeds).\n    64→    pub round_id: [u8; 8],\n    65→    /// Server wallet that paid rent and will settle.\n    66→    pub server: Pubkey,\n    67→    /// Current phase.\n    68→    pub phase: CloseCallPhase,\n    69→\n    70→    /// Green (bull) entries.\n    71→    #[max_len(32)]\n    72→    pub green_entries: Vec<BetEntry>,\n    73→    /// Red (bear) entries.\n    74→    #[max_len(32)]\n    75→    pub red_entries: Vec<BetEntry>,\n    76→    /// Total lamports in green pool.\n    77→    pub green_pool: u64,\n    78→    /// Total lamports in red pool.\n    79→    pub red_pool: u64,\n    80→\n    81→    /// Pyth open price at round creation (scaled integer).\n    82→    pub open_price: i64,\n    83→    /// Pyth price exponent at round creation.\n    84→    pub open_price_expo: i32,\n    85→    /// Pyth close price at settlement (0 until settled).\n    86→    pub close_price: i64,\n    87→\n    88→    /// Unix timestamp when round was created.\n    89→    pub created_at: i64,\n    90→    /// Unix timestamp when betting window closes.\n    91→    pub betting_ends_at: i64,\n    92→    /// Unix timestamp after which timeout_refund is available.\n    93→    pub resolve_deadline: i64,\n    94→\n    95→    /// Settlement outcome.\n    96→    pub outcome: Outcome,\n    97→    /// Fee collected (0 for refund rounds).\n    98→    pub total_fee: u64,\n    99→    /// Bump seed for PDA derivation.\n   100→    pub bump: u8,\n   101→}\n   102→\n   103→/// Event emitted when a round is settled.\n   104→#[event]\n   105→pub struct RoundSettled {\n   106→    pub round_id: [u8; 8],\n   107→    pub outcome: Outcome,\n   108→    pub open_price: i64,\n   109→    pub close_price: i64,\n   110→    pub green_pool: u64,\n   111→    pub red_pool: u64,\n   112→    pub total_fee: u64,\n   113→    pub num_winners: u8,\n   114→}\n   115→"}]},"parent_tool_use_id":"toolu_011rr1yfgNLixmd4MBJw5da9","session_id":"846c05db-31a6-42c7-8cfa-8e6a53a70110","uuid":"c70bd4b1-6dfe-4519-aaf3-f8672f9c207f"}
