{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FiX7bsC9tpzYYksHMLeGRt","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::error::CloseCallError;\n     4→\n     5→/// Parsed Pyth price data from a PriceUpdateV2 account.\n     6→#[derive(Debug)]\n     7→pub struct PythPrice {\n     8→    pub price: i64,\n     9→    pub conf: u64,\n    10→    pub exponent: i32,\n    11→    pub publish_time: i64,\n    12→}\n    13→\n    14→// ---------------------------------------------------------------------------\n    15→// Internal deserialization types matching Pyth PriceUpdateV2 account layout.\n    16→// We define these locally to avoid depending on pyth-solana-receiver-sdk\n    17→// (which may have anchor-lang version conflicts).\n    18→// ---------------------------------------------------------------------------\n    19→\n    20→#[derive(AnchorSerialize, AnchorDeserialize)]\n    21→struct PriceFeedMessage {\n    22→    feed_id: [u8; 32],\n    23→    price: i64,\n    24→    conf: u64,\n    25→    exponent: i32,\n    26→    publish_time: i64,\n    27→    prev_publish_time: i64,\n    28→    ema_price: i64,\n    29→    ema_conf: u64,\n    30→}\n    31→\n    32→#[derive(AnchorSerialize, AnchorDeserialize)]\n    33→enum VerificationLevel {\n    34→    Partial { num_signatures: u8 },\n    35→    Full,\n    36→}\n    37→\n    38→#[derive(AnchorSerialize, AnchorDeserialize)]\n    39→struct PriceUpdateV2Inner {\n    40→    write_authority: Pubkey,\n    41→    verification_level: VerificationLevel,\n    42→    price_message: PriceFeedMessage,\n    43→    posted_slot: u64,\n    44→}\n    45→\n    46→/// Parse a Pyth PriceUpdateV2 account's raw data to extract the price.\n    47→///\n    48→/// Verifies:\n    49→/// - Account data is valid PriceUpdateV2 (Borsh-deserializable after 8-byte discriminator)\n    50→/// - Feed ID matches the expected value\n    51→/// - Price is not older than `max_age_secs`\n    52→///\n    53→/// The caller is responsible for verifying the account owner if needed.\n    54→pub fn parse_price_update(\n    55→    account_data: &[u8],\n    56→    expected_feed_id: &[u8; 32],\n    57→    max_age_secs: i64,\n    58→    current_time: i64,\n    59→) -> Result<PythPrice> {\n    60→    require!(account_data.len() > 8, CloseCallError::InvalidPriceAccount);\n    61→\n    62→    // Skip 8-byte Anchor account discriminator\n    63→    let mut data = &account_data[8..];\n    64→    let update = PriceUpdateV2Inner::deserialize(&mut data)\n    65→        .map_err(|_| error!(CloseCallError::InvalidPriceAccount))?;\n    66→\n    67→    require!(\n    68→        update.price_message.feed_id == *expected_feed_id,\n    69→        CloseCallError::PriceFeedMismatch\n    70→    );\n    71→\n    72→    // Verify price freshness\n    73→    let age = current_time.saturating_sub(update.price_message.publish_time);\n    74→    require!(age <= max_age_secs, CloseCallError::PriceTooStale);\n    75→\n    76→    Ok(PythPrice {\n    77→        price: update.price_message.price,\n    78→        conf: update.price_message.conf,\n    79→        exponent: update.price_message.exponent,\n    80→        publish_time: update.price_message.publish_time,\n    81→    })\n    82→}\n    83→"}]},"parent_tool_use_id":"toolu_01LhUCdQ4XVVfKqy9b4uuRkN","session_id":"846c05db-31a6-42c7-8cfa-8e6a53a70110","uuid":"b74d2c32-1874-4fad-9fa1-c7453e672c44"}
