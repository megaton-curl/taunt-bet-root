{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WnHmUattYwdc748pChEiSu","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_to_pda;\n     3→use rng_shared::pause::check_not_paused;\n     4→use rng_shared::wager::validate_wager;\n     5→\n     6→use crate::error::CloseCallError;\n     7→use crate::state::{BetEntry, BetSide, CloseCallConfig, CloseCallPhase, CloseCallRound};\n     8→\n     9→#[derive(Accounts)]\n    10→#[instruction(round_id: [u8; 8])]\n    11→pub struct PlaceBet<'info> {\n    12→    #[account(mut)]\n    13→    pub player: Signer<'info>,\n    14→\n    15→    #[account(\n    16→        seeds = [b\"closecall_config\"],\n    17→        bump = config.bump,\n    18→    )]\n    19→    pub config: Account<'info, CloseCallConfig>,\n    20→\n    21→    #[account(\n    22→        mut,\n    23→        seeds = [b\"cc_round\", round_id.as_ref()],\n    24→        bump = round.bump,\n    25→    )]\n    26→    pub round: Account<'info, CloseCallRound>,\n    27→\n    28→    pub system_program: Program<'info, System>,\n    29→}\n    30→\n    31→pub fn handler(\n    32→    ctx: Context<PlaceBet>,\n    33→    _round_id: [u8; 8],\n    34→    side: u8,\n    35→    amount: u64,\n    36→) -> Result<()> {\n    37→    check_not_paused(false, ctx.accounts.config.paused)?;\n    38→\n    39→    let round = &ctx.accounts.round;\n    40→    require!(round.phase == CloseCallPhase::Open, CloseCallError::InvalidPhase);\n    41→\n    42→    let now = Clock::get()?.unix_timestamp;\n    43→    require!(now < round.betting_ends_at, CloseCallError::BettingClosed);\n    44→\n    45→    validate_wager(amount).map_err(|_| CloseCallError::WagerBelowMinimum)?;\n    46→\n    47→    let bet_side = match side {\n    48→        0 => BetSide::Green,\n    49→        1 => BetSide::Red,\n    50→        _ => return Err(CloseCallError::InvalidSide.into()),\n    51→    };\n    52→\n    53→    let player_key = ctx.accounts.player.key();\n    54→    let max_per_side = ctx.accounts.config.max_entries_per_side as usize;\n    55→\n    56→    // One bet per player per round (either side).\n    57→    let already_bet = ctx\n    58→        .accounts\n    59→        .round\n    60→        .green_entries\n    61→        .iter()\n    62→        .chain(ctx.accounts.round.red_entries.iter())\n    63→        .any(|e| e.player == player_key);\n    64→    require!(!already_bet, CloseCallError::PlayerAlreadyBet);\n    65→\n    66→    // Check max entries per side.\n    67→    match bet_side {\n    68→        BetSide::Green => {\n    69→            require!(\n    70→                ctx.accounts.round.green_entries.len() < max_per_side,\n    71→                CloseCallError::MaxEntriesReached\n    72→            );\n    73→        }\n    74→        BetSide::Red => {\n    75→            require!(\n    76→                ctx.accounts.round.red_entries.len() < max_per_side,\n    77→                CloseCallError::MaxEntriesReached\n    78→            );\n    79→        }\n    80→    }\n    81→\n    82→    // Transfer wager to round PDA.\n    83→    transfer_lamports_to_pda(\n    84→        &ctx.accounts.player.to_account_info(),\n    85→        &ctx.accounts.round.to_account_info(),\n    86→        amount,\n    87→        &ctx.accounts.system_program.to_account_info(),\n    88→    )?;\n    89→\n    90→    let entry = BetEntry {\n    91→        player: player_key,\n    92→        amount_lamports: amount,\n    93→    };\n    94→\n    95→    let round = &mut ctx.accounts.round;\n    96→    match bet_side {\n    97→        BetSide::Green => {\n    98→            round.green_pool = round\n    99→                .green_pool\n   100→                .checked_add(amount)\n   101→                .ok_or(CloseCallError::ArithmeticOverflow)?;\n   102→            round.green_entries.push(entry);\n   103→        }\n   104→        BetSide::Red => {\n   105→            round.red_pool = round\n   106→                .red_pool\n   107→                .checked_add(amount)\n   108→                .ok_or(CloseCallError::ArithmeticOverflow)?;\n   109→            round.red_entries.push(entry);\n   110→        }\n   111→    }\n   112→\n   113→    Ok(())\n   114→}\n   115→"}]},"parent_tool_use_id":"toolu_01LhUCdQ4XVVfKqy9b4uuRkN","session_id":"846c05db-31a6-42c7-8cfa-8e6a53a70110","uuid":"522276f1-725d-4d7a-a6ae-67534696690a"}
