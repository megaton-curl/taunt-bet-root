{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_018HrcswbmAFEnMVNSeUSy5P","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01341MMpRFE98VEVgo6E9qp4","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/closecall/src/instructions/settle_round.rs"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":6184,"cache_read_input_tokens":29933,"cache_creation":{"ephemeral_5m_input_tokens":6184,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01LhUCdQ4XVVfKqy9b4uuRkN","session_id":"846c05db-31a6-42c7-8cfa-8e6a53a70110","uuid":"5dadeb3c-90ce-4744-838e-0ceb4f2aeb24"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01341MMpRFE98VEVgo6E9qp4","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→use rng_shared::fees::calculate_net_payout;\n     4→\n     5→use crate::error::CloseCallError;\n     6→use crate::pyth::parse_price_update;\n     7→use crate::state::{CloseCallConfig, CloseCallPhase, CloseCallRound, Outcome, RoundSettled};\n     8→\n     9→use super::create_round::CANDLE_DURATION_SECS;\n    10→\n    11→/// Maximum age of Pyth price data for close price (seconds).\n    12→/// Allows some staleness since the price is from the candle close moment.\n    13→const MAX_CLOSE_PRICE_AGE_SECS: i64 = 120;\n    14→\n    15→#[derive(Accounts)]\n    16→#[instruction(round_id: [u8; 8])]\n    17→pub struct SettleRound<'info> {\n    18→    /// Backend settlement caller.\n    19→    #[account(mut)]\n    20→    pub caller: Signer<'info>,\n    21→\n    22→    /// The round PDA (closed after settlement — rent refunded to server).\n    23→    #[account(\n    24→        mut,\n    25→        close = rent_receiver,\n    26→        seeds = [b\"cc_round\", &round_id],\n    27→        bump = round.bump,\n    28→    )]\n    29→    pub round: Account<'info, CloseCallRound>,\n    30→\n    31→    #[account(\n    32→        seeds = [b\"closecall_config\"],\n    33→        bump = config.bump,\n    34→    )]\n    35→    pub config: Account<'info, CloseCallConfig>,\n    36→\n    37→    /// Pyth PriceUpdateV2 account for the close price.\n    38→    /// CHECK: Parsed and validated in handler (feed_id, freshness).\n    39→    pub price_update: AccountInfo<'info>,\n    40→\n    41→    /// Treasury to receive fees.\n    42→    /// CHECK: Validated against config.treasury in handler.\n    43→    #[account(mut)]\n    44→    pub treasury: AccountInfo<'info>,\n    45→\n    46→    /// Server wallet that paid rent (receives rent on close).\n    47→    /// CHECK: Validated against round.server in handler.\n    48→    #[account(mut)]\n    49→    pub rent_receiver: AccountInfo<'info>,\n    50→\n    51→    // Remaining accounts:\n    52→    // - Decisive (green/red wins): one mutable AccountInfo per winning bettor, in entry order.\n    53→    // - Refund: all player wallets [green_0..green_n, red_0..red_m], in entry order.\n    54→}\n    55→\n    56→pub fn handler<'info>(\n    57→    ctx: Context<'_, '_, 'info, 'info, SettleRound<'info>>,\n    58→    _round_id: [u8; 8],\n    59→) -> Result<()> {\n    60→    let round = &ctx.accounts.round;\n    61→    require!(\n    62→        round.phase == CloseCallPhase::Open,\n    63→        CloseCallError::InvalidPhase\n    64→    );\n    65→\n    66→    // Verify treasury and rent_receiver.\n    67→    require_keys_eq!(\n    68→        ctx.accounts.treasury.key(),\n    69→        ctx.accounts.config.treasury,\n    70→        CloseCallError::AccountMismatch\n    71→    );\n    72→    require_keys_eq!(\n    73→        ctx.accounts.rent_receiver.key(),\n    74→        round.server,\n    75→        CloseCallError::AccountMismatch\n    76→    );\n    77→\n    78→    let now = Clock::get()?.unix_timestamp;\n    79→    let candle_close_time = round\n    80→        .created_at\n    81→        .checked_add(CANDLE_DURATION_SECS)\n    82→        .ok_or(CloseCallError::ArithmeticOverflow)?;\n    83→    require!(now >= candle_close_time, CloseCallError::CandleNotClosed);\n    84→\n    85→    // Parse close price from Pyth.\n    86→    let price_data = ctx.accounts.price_update.try_borrow_data()?;\n    87→    let close_price_info = parse_price_update(\n    88→        &price_data,\n    89→        &ctx.accounts.config.pyth_feed_id,\n    90→        MAX_CLOSE_PRICE_AGE_SECS,\n    91→        now,\n    92→    )?;\n    93→\n    94→    // Verify exponents match for accurate comparison.\n    95→    require!(\n    96→        close_price_info.exponent == round.open_price_expo,\n    97→        CloseCallError::ExponentMismatch\n    98→    );\n    99→\n   100→    let green_count = round.green_entries.len();\n   101→    let red_count = round.red_entries.len();\n   102→    let total_count = green_count + red_count;\n   103→    let remaining = ctx.remaining_accounts;\n   104→    let open_price = round.open_price;\n   105→    let close_price = close_price_info.price;\n   106→\n   107→    // Determine outcome.\n   108→    let has_both_sides = green_count > 0 && red_count > 0;\n   109→    let outcome = if total_count == 0 {\n   110→        Outcome::Refund\n   111→    } else if !has_both_sides || total_count == 1 || close_price == open_price {\n   112→        Outcome::Refund\n   113→    } else if close_price > open_price {\n   114→        Outcome::Green\n   115→    } else {\n   116→        Outcome::Red\n   117→    };\n   118→\n   119→    let round_info = ctx.accounts.round.to_account_info();\n   120→    let mut total_fee = 0u64;\n   121→\n   122→    match outcome {\n   123→        Outcome::Green | Outcome::Red => {\n   124→            // Decisive round — pay winners, collect fee.\n   125→            let total_pool = round\n   126→                .green_pool\n   127→                .checked_add(round.red_pool)\n   128→                .ok_or(CloseCallError::ArithmeticOverflow)?;\n   129→            let (fee, net_pool) = calculate_net_payout(total_pool);\n   130→            total_fee = fee;\n   131→\n   132→            let (winning_entries, winning_pool) = if outcome == Outcome::Green {\n   133→                (&round.green_entries, round.green_pool)\n   134→            } else {\n   135→                (&round.red_entries, round.red_pool)\n   136→            };\n   137→\n   138→            // remaining_accounts = one per winning bettor, in entry order.\n   139→            require!(\n   140→                remaining.len() == winning_entries.len(),\n   141→                CloseCallError::RemainingAccountsMismatch\n   142→            );\n   143→\n   144→            let mut paid_out = 0u64;\n   145→            for (i, entry) in winning_entries.iter().enumerate() {\n   146→                let player_account = &remaining[i];\n   147→                require_keys_eq!(\n   148→                    player_account.key(),\n   149→                    entry.player,\n   150→                    CloseCallError::AccountMismatch\n   151→                );\n   152→\n   153→                let payout = if i == winning_entries.len() - 1 {\n   154→                    // Last winner gets remainder to avoid dust.\n   155→                    net_pool\n   156→                        .checked_sub(paid_out)\n   157→                        .ok_or(CloseCallError::ArithmeticOverflow)?\n   158→                } else {\n   159→                    (entry.amount_lamports as u128)\n   160→                        .checked_mul(net_pool as u128)\n   161→                        .ok_or(CloseCallError::ArithmeticOverflow)?\n   162→                        .checked_div(winning_pool as u128)\n   163→                        .ok_or(CloseCallError::ArithmeticOverflow)?\n   164→                        as u64\n   165→                };\n   166→\n   167→                transfer_lamports_from_pda(&round_info, player_account, payout)?;\n   168→                paid_out = paid_out\n   169→                    .checked_add(payout)\n   170→                    .ok_or(CloseCallError::ArithmeticOverflow)?;\n   171→            }\n   172→\n   173→            // Transfer fee to treasury.\n   174→            transfer_lamports_from_pda(&round_info, &ctx.accounts.treasury, fee)?;\n   175→        }\n   176→        Outcome::Refund => {\n   177→            if total_count > 0 {\n   178→                // Refund all bets — remaining_accounts = [green bettors, red bettors].\n   179→                require!(\n   180→                    remaining.len() == total_count,\n   181→                    CloseCallError::RemainingAccountsMismatch\n   182→                );\n   183→\n   184→                for (i, entry) in round.green_entries.iter().enumerate() {\n   185→                    let player_account = &remaining[i];\n   186→                    require_keys_eq!(\n   187→                        player_account.key(),\n   188→                        entry.player,\n   189→                        CloseCallError::AccountMismatch\n   190→                    );\n   191→                    transfer_lamports_from_pda(\n   192→                        &round_info,\n   193→                        player_account,\n   194→                        entry.amount_lamports,\n   195→                    )?;\n   196→                }\n   197→\n   198→                for (i, entry) in round.red_entries.iter().enumerate() {\n   199→                    let player_account = &remaining[green_count + i];\n   200→                    require_keys_eq!(\n   201→                        player_account.key(),\n   202→                        entry.player,\n   203→                        CloseCallError::AccountMismatch\n   204→                    );\n   205→                    transfer_lamports_from_pda(\n   206→                        &round_info,\n   207→                        player_account,\n   208→                        entry.amount_lamports,\n   209→                    )?;\n   210→                }\n   211→            }\n   212→        }\n   213→        Outcome::Pending => unreachable!(),\n   214→    }\n   215→\n   216→    // Emit event before close zeroes the account.\n   217→    emit!(RoundSettled {\n   218→        round_id: round.round_id,\n   219→        outcome,\n   220→        open_price,\n   221→        close_price,\n   222→        green_pool: round.green_pool,\n   223→        red_pool: round.red_pool,\n   224→        total_fee,\n   225→        num_winners: if outcome == Outcome::Green {\n   226→            green_count as u8\n   227→        } else if outcome == Outcome::Red {\n   228→            red_count as u8\n   229→        } else {\n   230→            0\n   231→        },\n   232→    });\n   233→\n   234→    // Update round state (written before Anchor's close runs).\n   235→    let round = &mut ctx.accounts.round;\n   236→    round.phase = if outcome == Outcome::Refund {\n   237→        CloseCallPhase::Refunded\n   238→    } else {\n   239→        CloseCallPhase::Settled\n   240→    };\n   241→    round.close_price = close_price;\n   242→    round.outcome = outcome;\n   243→    round.total_fee = total_fee;\n   244→\n   245→    Ok(())\n   246→}\n   247→"}]},"parent_tool_use_id":"toolu_01LhUCdQ4XVVfKqy9b4uuRkN","session_id":"846c05db-31a6-42c7-8cfa-8e6a53a70110","uuid":"034b8767-2e54-473a-b416-efea5e6c6141"}
