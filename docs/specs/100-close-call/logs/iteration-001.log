{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012uwvH73hcLXZZzcX4PSz5J","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→#[error_code]\n     4→pub enum CloseCallError {\n     5→    /// 6100 (Anchor adds 6000 base offset)\n     6→    #[msg(\"Wager amount below minimum\")]\n     7→    WagerBelowMinimum = 100,\n     8→\n     9→    /// 6101\n    10→    #[msg(\"Round is not in the expected phase\")]\n    11→    InvalidPhase,\n    12→\n    13→    /// 6102\n    14→    #[msg(\"Betting window has closed\")]\n    15→    BettingClosed,\n    16→\n    17→    /// 6103\n    18→    #[msg(\"Player already has a bet in this round\")]\n    19→    PlayerAlreadyBet,\n    20→\n    21→    /// 6104\n    22→    #[msg(\"Maximum entries per side reached\")]\n    23→    MaxEntriesReached,\n    24→\n    25→    /// 6105\n    26→    #[msg(\"Invalid bet side: must be 0 (Green) or 1 (Red)\")]\n    27→    InvalidSide,\n    28→\n    29→    /// 6106\n    30→    #[msg(\"Candle has not closed yet\")]\n    31→    CandleNotClosed,\n    32→\n    33→    /// 6107\n    34→    #[msg(\"Invalid Pyth price account data\")]\n    35→    InvalidPriceAccount,\n    36→\n    37→    /// 6108\n    38→    #[msg(\"Pyth feed ID does not match expected feed\")]\n    39→    PriceFeedMismatch,\n    40→\n    41→    /// 6109\n    42→    #[msg(\"Price data is too stale\")]\n    43→    PriceTooStale,\n    44→\n    45→    /// 6110\n    46→    #[msg(\"Resolve deadline has not elapsed yet\")]\n    47→    DeadlineNotReached,\n    48→\n    49→    /// 6111\n    50→    #[msg(\"Account key does not match expected value\")]\n    51→    AccountMismatch,\n    52→\n    53→    /// 6112\n    54→    #[msg(\"Arithmetic overflow\")]\n    55→    ArithmeticOverflow,\n    56→\n    57→    /// 6113\n    58→    #[msg(\"Remaining accounts count does not match expected\")]\n    59→    RemainingAccountsMismatch,\n    60→\n    61→    /// 6114\n    62→    #[msg(\"Price exponent mismatch between open and close\")]\n    63→    ExponentMismatch,\n    64→}\n    65→"}]},"parent_tool_use_id":"toolu_01LhUCdQ4XVVfKqy9b4uuRkN","session_id":"846c05db-31a6-42c7-8cfa-8e6a53a70110","uuid":"8368463d-a354-480e-92d7-2cb9741f6082"}
