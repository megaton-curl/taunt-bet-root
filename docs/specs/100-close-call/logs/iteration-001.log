n  \n  const price = data.readBigInt64LE(offset);\n  console.log(\"price (\" + offset + \"-\" + (offset + 7) + \"):\", price.toString());\n  offset += 8;\n  \n  const conf = data.readBigUInt64LE(offset);\n  console.log(\"conf (\" + offset + \"-\" + (offset + 7) + \"):\", conf.toString());\n  offset += 8;\n  \n  const exponent = data.readInt32LE(offset);\n  console.log(\"exponent (\" + offset + \"-\" + (offset + 3) + \"):\", exponent);\n  offset += 4;\n  \n  const publishTime = data.readBigInt64LE(offset);\n  console.log(\"publish_time (\" + offset + \"-\" + (offset + 7) + \"):\", publishTime.toString(), \"=\", new Date(Number(publishTime) * 1000).toISOString());\n  offset += 8;\n  \n  const prevPublishTime = data.readBigInt64LE(offset);\n  console.log(\"prev_publish_time (\" + offset + \"-\" + (offset + 7) + \"):\", prevPublishTime.toString());\n  offset += 8;\n  \n  const emaPrice = data.readBigInt64LE(offset);\n  console.log(\"ema_price (\" + offset + \"-\" + (offset + 7) + \"):\", emaPrice.toString());\n  offset += 8;\n  \n  const emaConf = data.readBigUInt64LE(offset);\n  console.log(\"ema_conf (\" + offset + \"-\" + (offset + 7) + \"):\", emaConf.toString());\n  offset += 8;\n  \n  const postedSlot = data.readBigUInt64LE(offset);\n  console.log(\"posted_slot (\" + offset + \"-\" + (offset + 7) + \"):\", postedSlot.toString());\n  offset += 8;\n  \n  console.log(\"\\nTotal bytes parsed:\", offset);\n  console.log(\"Remaining bytes:\", data.length - offset);\n  \n  const priceFloat = Number(price) * Math.pow(10, exponent);\n  console.log(\"\\n=== HUMAN-READABLE PRICE ===\");\n  console.log(\"BTC/USD price:\", priceFloat.toFixed(2));\n  console.log(\"Confidence:\", (Number(conf) * Math.pow(10, exponent)).toFixed(2));\n  console.log(\"EMA price:\", (Number(emaPrice) * Math.pow(10, exponent)).toFixed(2));\n}\nmain().catch(e => console.error(e));\n'\n","description":"Fetch BTC/USD push oracle account via dRPC devnet endpoint","timeout":30000},"caller":{"type":"direct