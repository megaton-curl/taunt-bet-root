{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Emy63uMbRDRu2dMv9j3j2J","type":"tool_result","content":"   200→ * @param expectedEntryAmount - Expected entry amount in lamports\n   201→ */\n   202→export async function assertMatchCreated(\n   203→  connection: Connection,\n   204→  creator: PublicKey,\n   205→  expectedSide: number,\n   206→  expectedEntryAmount?: number,\n   207→): Promise<{ matchPda: PublicKey; match: MatchAccount }> {\n   208→  // Use memcmp to find any active match by this creator (works for any nonce).\n   209→  const program = getCoinflipProgram(connection);\n   210→  const matches = await program.account.coinflipMatch.all([\n   211→    { memcmp: { offset: 8, bytes: creator.toBase58() } },\n   212→    { dataSize: program.account.coinflipMatch.size },\n   213→  ]);\n   214→  const activeMatches = matches.filter((m) => {\n   215→    const match = m.account as unknown as MatchAccount;\n   216→    return (\n   217→      match.phase !== COINFLIP_PHASE_SETTLED &&\n   218→      match.phase !== COINFLIP_PHASE_REFUNDED\n   219→    );\n   220→  });\n   221→  if (activeMatches.length === 0) {\n   222→    throw new Error(`No active match PDA found for creator ${creator}`);\n   223→  }\n   224→  const matchPda = activeMatches[0].publicKey;\n   225→  const match = activeMatches[0].account as unknown as MatchAccount;\n   226→\n   227→  const phase = coinflipPhaseName(match.phase);\n   228→  if (phase !== \"waiting\") {\n   229→    throw new Error(`Expected phase 'waiting', got '${phase}'`);\n   230→  }\n   231→  if (match.creator.toBase58() !== creator.toBase58()) {\n   232→    throw new Error(\"Match creator does not match expected creator\");\n   233→  }\n   234→  if (match.creatorSide !== expectedSide) {\n   235→    throw new Error(`Expected side ${expectedSide}, got ${match.creatorSide}`);\n   236→  }\n   237→  if (match.opponent.toBase58() !== PublicKey.default.toBase58()) {\n   238→    throw new Error(\"Expected no opponent in waiting phase\");\n   239→  }\n   240→  if (expectedEntryAmount !== undefined && match.entryAmount.toNumber() !== expectedEntryAmount) {\n   241→    throw new Error(\n   242→      `Expected entryAmount ${expectedEntryAmount}, got ${match.entryAmount.toNumber()}`,\n   243→    );\n   244→  }\n   245→\n   246→  return { matchPda, match };\n   247→}\n   248→\n   249→/**\n   250→ * Assert match PDA is closed (account no longer exists).\n   251→ *\n   252→ * @param connection - Solana RPC connection\n   253→ * @param matchPda - The match PDA address to check\n   254→ */\n   255→export async function assertMatchClosed(\n   256→  connection: Connection,\n   257→  matchPda: PublicKey,\n   258→): Promise<void> {\n   259→  const match = await fetchMatch(connection, matchPda);\n   260→  if (match !== null) {\n   261→    const phase = coinflipPhaseName(match.phase);\n   262→    throw new Error(\n   263→      `Expected match PDA to be closed, but it still exists (phase: ${phase})`,\n   264→    );\n   265→  }\n   266→}\n   267→\n   268→/**\n   269→ * Assert that the treasury received the expected fee.\n   270→ * Call snapshotBalance before the payout, then call this after.\n   271→ *\n   272→ * @param connection - Solana RPC connection\n   273→ * @param treasury - Treasury public key\n   274→ * @param balanceBefore - Treasury balance in lamports before claim\n   275→ * @param entryAmount - Single player's entry in lamports\n   276→ */\n   277→export async function assertTreasuryFee(\n   278→  connection: Connection,\n   279→  treasury: PublicKey,\n   280→  balanceBefore: number,\n   281→  entryAmount: number,\n   282→): Promise<void> {\n   283→  const balanceAfter = await getBalanceLamports(connection, treasury);\n   284→  const { fee } = calculateExpectedFee(entryAmount);\n   285→  const actualDelta = balanceAfter - balanceBefore;\n   286→\n   287→  // When treasury == server wallet (devnet), the delta includes rent refund\n   288→  // and is reduced by gas costs, so allow approximate match.\n   289→  // Exact match for dedicated treasury, ±10% tolerance otherwise.\n   290→  const tolerance = Math.max(fee * 0.1, 10_000);\n   291→  if (Math.abs(actualDelta - fee) > tolerance) {\n   292→    throw new Error(\n   293→      `Treasury fee mismatch: expected ~${fee} lamports (±${tolerance}), got delta ${actualDelta}`,\n   294→    );\n   295→  }\n   296→}\n   297→\n   298→// ============ Lord of RNGs Helpers ============\n   299→\n   300→/** Derive a Lord of RNGs round PDA. Seeds: [\"jackpot_round\", matchId]. */\n   301→export function getLordRoundPda(matchId: string | Buffer): [PublicKey, number] {\n   302→  const matchIdBuf = typeof matchId === \"string\" ? Buffer.from(matchId, \"hex\") : matchId;\n   303→  return PublicKey.findProgramAddressSync(\n   304→    [Buffer.from(\"jackpot_round\"), matchIdBuf],\n   305→    LORDOFRNGS_PROGRAM_ID,\n   306→  );\n   307→}\n   308→\n   309→/** Derive the Lord of RNGs config PDA. Seeds: [\"lord_config\"]. */\n   310→export function getLordConfigPda(): [PublicKey, number] {\n   311→  return PublicKey.findProgramAddressSync(\n   312→    [Buffer.from(\"lord_config\")],\n   313→    LORDOFRNGS_PROGRAM_ID,\n   314→  );\n   315→}\n   316→\n   317→/** Create a read-only Lord of RNGs program instance. */\n   318→export function getLordProgram(connection: Connection): Program<Lordofrngs> {\n   319→  const provider = new AnchorProvider(\n   320→    connection,\n   321→    {} as AnchorProvider[\"wallet\"],\n   322→    { commitment: \"confirmed\" },\n   323→  );\n   324→  return new Program(LordofrngsIDL as Idl as Lordofrngs, provider);\n   325→}\n   326→\n   327→/** Deserialized jackpot round account shape. */\n   328→export interface JackpotRoundAccount {\n   329→  matchId: number[];\n   330→  server: PublicKey;\n   331→  phase: Record<string, object>;\n   332→  commitment: number[];\n   333→  algorithmVer: number;\n   334→  entries: { player: PublicKey; amountLamports: { toNumber(): number } }[];\n   335→  totalAmountLamports: { toNumber(): number };\n   336→  distinctPlayers: number;\n   337→  creator: PublicKey;\n   338→  createdAt: { toNumber(): number };\n   339→  countdownStartedAt: { toNumber(): number };\n   340→  countdownEndsAt: { toNumber(): number };\n   341→  targetEntropySlot: { toNumber(): number };\n   342→  resolveDeadline: { toNumber(): number };\n   343→  resultHash: number[];\n   344→  winningOffset: { toNumber(): number };\n   345→  winningEntryIndex: number;\n   346→  winner: PublicKey;\n   347→  bump: number;\n   348→}\n   349→\n   350→/** Fetch a Lord of RNGs round PDA. Returns null if closed/missing. */\n   351→export async function fetchLordRound(\n   352→  connection: Connection,\n   353→  roundPda: PublicKey,\n   354→): Promise<JackpotRoundAccount | null> {\n   355→  const program = getLordProgram(connection);\n   356→  try {\n   357→    return (await program.account.jackpotRound.fetch(\n   358→      roundPda,\n   359→    )) as unknown as JackpotRoundAccount;\n   360→  } catch {\n   361→    return null;\n   362→  }\n   363→}\n   364→\n   365→/** Assert a Lord of RNGs round PDA is closed. */\n   366→export async function assertLordRoundClosed(\n   367→  connection: Connection,\n   368→  roundPda: PublicKey,\n   369→): Promise<void> {\n   370→  const round = await fetchLordRound(connection, roundPda);\n   371→  if (round !== null) {\n   372→    const phase = Object.keys(round.phase)[0];\n   373→    throw new Error(\n   374→      `Expected round PDA to be closed, but it still exists (phase: ${phase})`,\n   375→    );\n   376→  }\n   377→}\n   378→\n   379→/**\n   380→ * Calculate the expected fee and net payout for a Lord of RNGs jackpot round.\n   381→ * pool = totalAmountLamports; fee = floor(pool * 300 / 10_000).\n   382→ */\n   383→export function calculateLordExpectedFee(\n   384→  totalAmountLamports: number,\n   385→): { pool: number; fee: number; payout: number } {\n   386→  const pool = totalAmountLamports;\n   387→  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n   388→  const payout = pool - fee;\n   389→  return { pool, fee, payout };\n   390→}\n   391→\n   392→/**\n   393→ * Assert that the treasury received the expected Lord of RNGs fee.\n   394→ * On devnet, treasury == server wallet, so the delta includes both the 3% fee\n   395→ * AND the rent refund (server subsidizes rent and gets it back on close).\n   396→ * We check that the delta is at least the fee amount.\n   397→ */\n   398→export async function assertLordTreasuryFee(\n   399→  connection: Connection,\n   400→  treasury: PublicKey,\n   401→  balanceBefore: number,\n   402→  totalAmountLamports: number,\n   403→): Promise<void> {\n   404→  const balanceAfter = await getBalanceLamports(connection, treasury);\n   405→  const { fee } = calculateLordExpectedFee(totalAmountLamports);\n   406→  const actualDelta = balanceAfter - balanceBefore;\n   407→\n   408→  // When treasury == server wallet (devnet), the delta includes rent refund.\n   409→  // Just verify the fee portion is present (delta >= fee).\n   410→  if (actualDelta < fee - 10_000) {\n   411→    throw new Error(\n   412→      `Lord treasury fee mismatch: expected at least ~${fee} lamports, got delta ${actualDelta}`,\n   413→    );\n   414→  }\n   415→}\n   416→"}]},"parent_tool_use_id":"toolu_01EWoNASPT6R2cYfWgZ31awF","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"266ccba8-f438-4c8a-addb-10540e37bb65"}
