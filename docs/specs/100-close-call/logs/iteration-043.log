{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PVPCoK6uT8xc3Qm7Bcik9u","type":"tool_result","content":"     1→/**\n     2→ * Local cancel-flow E2E test: create → cancel → refund → lobby clears → recreate.\n     3→ *\n     4→ * Uses a single browser context (Player A) with a deterministic keypair.\n     5→ * Verifies that cancellation refunds the creator, clears the lobby, and\n     6→ * allows immediate re-creation of a new match.\n     7→ *\n     8→ * Prerequisites (handled by localnet-bootstrap.sh):\n     9→ * - solana-test-validator running with coinflip + platform programs\n    10→ */\n    11→import { test, expect } from \"./fixtures\";\n    12→import * as po from \"./helpers/page-objects\";\n    13→import { fundTestWallets, PLAYER_A } from \"./helpers/wallets\";\n    14→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    15→import {\n    16→  assertMatchCreated,\n    17→  assertMatchClosed,\n    18→  getBalanceLamports,\n    19→} from \"./helpers/on-chain\";\n    20→\n    21→// ── Suite setup ────────────────────────────────────────────────────────\n    22→\n    23→test.beforeAll(async () => {\n    24→  await fundTestWallets();\n    25→  await initializeLocalnet();\n    26→});\n    27→\n    28→// ── Cancel flow test ───────────────────────────────────────────────────\n    29→\n    30→test(\"coinflip cancel flow: create → cancel → refund → lobby clears → recreate\", async ({\n    31→  playerAPage,\n    32→  connection,\n    33→}) => {\n    34→  const consoleA = po.trackConsoleErrors(playerAPage);\n    35→\n    36→  // Navigate to coinflip\n    37→  await po.navigateToCoinflip(playerAPage);\n    38→\n    39→  // Snapshot balance before creating match\n    40→  const balanceBefore = await getBalanceLamports(\n    41→    connection,\n    42→    PLAYER_A.publicKey,\n    43→  );\n    44→\n    45→  // 1. Create a match (iron tier, heads)\n    46→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n    47→\n    48→  // Verify active match is in waiting state\n    49→  await expect(\n    50→    playerAPage.locator(po.sel.activeMatchWaiting),\n    51→  ).toBeVisible({ timeout: 10_000 });\n    52→\n    53→  // On-chain: verify match PDA exists in waiting phase\n    54→  const { matchPda } = await assertMatchCreated(\n    55→    connection,\n    56→    PLAYER_A.publicKey,\n    57→    0, // heads\n    58→  );\n    59→\n    60→  // Balance after create should be lower (entry + rent + tx fee)\n    61→  const balanceAfterCreate = await getBalanceLamports(\n    62→    connection,\n    63→    PLAYER_A.publicKey,\n    64→  );\n    65→  expect(balanceAfterCreate).toBeLessThan(balanceBefore);\n    66→\n    67→  // 2. Cancel the match\n    68→  await po.cancelMatch(playerAPage);\n    69→\n    70→  // 3. Verify lobby is visible again and the match is gone\n    71→  await po.waitForLobby(playerAPage);\n    72→  await po.assertLobbyEmpty(playerAPage);\n    73→\n    74→  // On-chain: verify match PDA is closed\n    75→  await assertMatchClosed(connection, matchPda);\n    76→\n    77→  // 4. Verify refund: balance after cancel should recover entry (rent goes to server)\n    78→  const balanceAfterCancel = await getBalanceLamports(\n    79→    connection,\n    80→    PLAYER_A.publicKey,\n    81→  );\n    82→  // Balance should be higher than after create (got entry refund)\n    83→  expect(balanceAfterCancel).toBeGreaterThan(balanceAfterCreate);\n    84→  // Net cost = rent (goes to server) + tx fees for create + cancel\n    85→  // Rent is ~2.4M lamports, tx fees ~10k each — well under 0.01 SOL = 10M lamports\n    86→  const netCost = balanceBefore - balanceAfterCancel;\n    87→  expect(netCost).toBeLessThan(10_000_000);\n    88→\n    89→  // 5. Recreate: creator can immediately create a new match after cancellation\n    90→  await po.createMatch(playerAPage, \"iron\", \"tails\");\n    91→  await expect(\n    92→    playerAPage.locator(po.sel.activeMatchWaiting),\n    93→  ).toBeVisible({ timeout: 10_000 });\n    94→\n    95→  // On-chain: verify new match PDA exists (same PDA address, new side)\n    96→  await assertMatchCreated(\n    97→    connection,\n    98→    PLAYER_A.publicKey,\n    99→    1, // tails (different from first match)\n   100→  );\n   101→\n   102→  // Clean up: cancel the second match to leave a clean state\n   103→  await po.cancelMatch(playerAPage);\n   104→  await po.waitForLobby(playerAPage);\n   105→\n   106→  // No unhandled console errors\n   107→  consoleA.assertClean();\n   108→});\n   109→"}]},"parent_tool_use_id":"toolu_01EWoNASPT6R2cYfWgZ31awF","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"51dc0c15-f68f-41a1-a899-6f259b60a858"}
