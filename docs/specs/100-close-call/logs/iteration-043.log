{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MoHnnutVF15yRUMyHY5iHs","type":"tool_result","content":"     1→/**\n     2→ * Local lifecycle E2E test: create → join → resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. The local validator has mock-VRF enabled,\n     6→ * and the randomness account is pre-loaded with fulfilled data\n     7→ * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n     8→ *\n     9→ * Prerequisites (handled by localnet-bootstrap.sh):\n    10→ * - solana-test-validator running with coinflip + platform programs\n    11→ * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n    12→ */\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import { fundTestWallets, PLAYER_A } from \"./helpers/wallets\";\n    16→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    17→import {\n    18→  assertMatchCreated,\n    19→  assertMatchClosed,\n    20→  assertTreasuryFee,\n    21→  snapshotBalance,\n    22→  getTreasuryAddress,\n    23→} from \"./helpers/on-chain\";\n    24→\n    25→// ── Suite setup ────────────────────────────────────────────────────────\n    26→\n    27→test.beforeAll(async () => {\n    28→  // Fund test wallets and initialize program configs\n    29→  await fundTestWallets();\n    30→  await initializeLocalnet();\n    31→});\n    32→\n    33→// ── Full lifecycle test ────────────────────────────────────────────────\n    34→\n    35→test(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n    36→  playerAPage,\n    37→  playerBPage,\n    38→  connection,\n    39→}) => {\n    40→  const SIDE_HEADS = 0;\n    41→  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n    42→\n    43→  // Track console errors in both contexts\n    44→  const consoleA = po.trackConsoleErrors(playerAPage);\n    45→  const consoleB = po.trackConsoleErrors(playerBPage);\n    46→\n    47→  // 1. Player A navigates and creates a match (iron tier, heads)\n    48→  await po.navigateToCoinflip(playerAPage);\n    49→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n    50→\n    51→  // Player A should see the active match in \"waiting\" state\n    52→  await expect(\n    53→    playerAPage.locator(po.sel.activeMatchWaiting),\n    54→  ).toBeVisible({ timeout: 10_000 });\n    55→\n    56→  // ── On-chain: verify match PDA after creation ──\n    57→  const { matchPda } = await assertMatchCreated(\n    58→    connection,\n    59→    PLAYER_A.publicKey,\n    60→    SIDE_HEADS,\n    61→  );\n    62→\n    63→  // 2. Player B navigates (after match is created) and sees it in the lobby\n    64→  await po.navigateToCoinflip(playerBPage);\n    65→  await po.waitForLobbyMatch(playerBPage, 15_000);\n    66→\n    67→  // 3. Player B joins the match\n    68→  await po.joinMatch(playerBPage);\n    69→\n    70→  // ── On-chain: snapshot treasury before resolution/claim ──\n    71→  const treasury = await getTreasuryAddress(connection);\n    72→  const treasuryBefore = await snapshotBalance(connection, treasury);\n    73→\n    74→  // 4. Both players wait for the backend-settled result.\n    75→  const [resultA, resultB] = await Promise.all([\n    76→    po.waitForResult(playerAPage, 30_000),\n    77→    po.waitForResult(playerBPage, 30_000),\n    78→  ]);\n    79→\n    80→  // 5. Verify results are complementary.\n    81→  expect(resultA).not.toBe(resultB);\n    82→\n    83→  // 6. Settlement is backend-driven, so the match PDA should already be closed.\n    84→  await assertMatchClosed(connection, matchPda);\n    85→\n    86→  // ── On-chain: verify treasury received the 3% fee ──\n    87→  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n    88→\n    89→  // 7. Winner can return to the lobby after settlement.\n    90→  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n    91→  await expect(\n    92→    winnerPage.locator(po.sel.sidebar).locator(\"button\", { hasText: \"Back to Lobby\" }),\n    93→  ).toBeVisible();\n    94→  await po.backToLobby(winnerPage);\n    95→  await po.assertLobbyEmpty(winnerPage);\n    96→\n    97→  // No unhandled console errors in either context\n    98→  consoleA.assertClean();\n    99→  consoleB.assertClean();\n   100→});\n   101→"}]},"parent_tool_use_id":"toolu_01EWoNASPT6R2cYfWgZ31awF","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"44124553-1d61-4be8-9b5f-46e98e42cccc"}
