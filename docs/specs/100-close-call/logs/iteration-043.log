{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Po4idizqDfnybyLymFzAUg","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useEffect,\n     6→  useCallback,\n     7→  useMemo,\n     8→  useRef,\n     9→  type ReactNode,\n    10→} from \"react\";\n    11→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    12→import { usePriceSubscription } from \"@rng-utopia/price-feeds\";\n    13→import { Program, AnchorProvider, BN, type Idl } from \"@coral-xyz/anchor\";\n    14→import {\n    15→  PublicKey,\n    16→  SystemProgram,\n    17→  Transaction,\n    18→  type Connection,\n    19→} from \"@solana/web3.js\";\n    20→import { ClosecallIDL, type Closecall } from \"@rng-utopia/anchor-client\";\n    21→import type {\n    22→  Round,\n    23→  BetSide,\n    24→  Candle,\n    25→  PlayerBet,\n    26→  UserRoundHistory,\n    27→  RoundPhase,\n    28→  CandleOutcome,\n    29→  CloseCallContextValue,\n    30→} from \"../types\";\n    31→import {\n    32→  DEFAULT_BET_AMOUNT,\n    33→  MIN_BET_AMOUNT,\n    34→  MAX_BET_AMOUNT,\n    35→  BETTING_WINDOW_MS,\n    36→} from \"../types\";\n    37→import { calculatePotentialPayout } from \"../utils/payout-calculator\";\n    38→\n    39→// ---------------------------------------------------------------------------\n    40→// Backend API\n    41→// ---------------------------------------------------------------------------\n    42→\n    43→const FAIRNESS_BACKEND_URL = (\n    44→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    45→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    46→).replace(/\\/$/, \"\");\n    47→\n    48→const ROUND_POLL_MS = 2000;\n    49→const LAMPORTS_PER_SOL = 1_000_000_000;\n    50→\n    51→interface BackendRoundResponse {\n    52→  roundId: string;\n    53→  pda: string;\n    54→  phase: string;\n    55→  openPrice: number;\n    56→  openPriceExpo: number;\n    57→  closePrice: number | null;\n    58→  outcome: string;\n    59→  greenPool: number;\n    60→  redPool: number;\n    61→  totalPool: number;\n    62→  totalFee: number;\n    63→  greenEntries: Array<{ player: string; amountLamports: number }>;\n    64→  redEntries: Array<{ player: string; amountLamports: number }>;\n    65→  greenCount: number;\n    66→  redCount: number;\n    67→  settleTx: string | null;\n    68→  createdAt: string;\n    69→  settledAt: string | null;\n    70→}\n    71→\n    72→function backendToRound(br: BackendRoundResponse): Round {\n    73→  const greenBets: PlayerBet[] = br.greenEntries.map((e) => ({\n    74→    address: e.player,\n    75→    side: \"green\" as const,\n    76→    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    77→    timestamp: new Date(br.createdAt).getTime(),\n    78→  }));\n    79→  const redBets: PlayerBet[] = br.redEntries.map((e) => ({\n    80→    address: e.player,\n    81→    side: \"red\" as const,\n    82→    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    83→    timestamp: new Date(br.createdAt).getTime(),\n    84→  }));\n    85→  const greenPool = greenBets.reduce((s, b) => s + b.amount, 0);\n    86→  const redPool = redBets.reduce((s, b) => s + b.amount, 0);\n    87→\n    88→  return {\n    89→    id: br.roundId,\n    90→    phase: br.phase as RoundPhase,\n    91→    pool: {\n    92→      greenPool,\n    93→      redPool,\n    94→      totalPool: greenPool + redPool,\n    95→      playerCount: greenBets.length + redBets.length,\n    96→      greenBets,\n    97→      redBets,\n    98→    },\n    99→    createdAt: new Date(br.createdAt).getTime(),\n   100→    bettingEndsAt: new Date(br.createdAt).getTime() + BETTING_WINDOW_MS,\n   101→    resolvedAt: br.settledAt ? new Date(br.settledAt).getTime() : undefined,\n   102→    targetCandleTime: new Date(br.createdAt).getTime(),\n   103→    outcome: br.outcome === \"pending\" ? undefined : (br.outcome as CandleOutcome),\n   104→    openPrice: br.openPrice,\n   105→    openPriceExpo: br.openPriceExpo,\n   106→    closePrice: br.closePrice ?? undefined,\n   107→    settleTx: br.settleTx ?? undefined,\n   108→  };\n   109→}\n   110→\n   111→async function fetchCurrentRound(): Promise<Round | null> {\n   112→  try {\n   113→    const res = await fetch(`${FAIRNESS_BACKEND_URL}/closecall/current-round`);\n   114→    if (!res.ok) return null;\n   115→    const data = (await res.json()) as { round: BackendRoundResponse | null };\n   116→    if (!data.round) return null;\n   117→    return backendToRound(data.round);\n   118→  } catch {\n   119→    return null;\n   120→  }\n   121→}\n   122→\n   123→async function fetchRoundHistory(limit = 20): Promise<Round[]> {\n   124→  try {\n   125→    const res = await fetch(\n   126→      `${FAIRNESS_BACKEND_URL}/closecall/history?limit=${limit}`,\n   127→    );\n   128→    if (!res.ok) return [];\n   129→    const data = (await res.json()) as { rounds: BackendRoundResponse[] };\n   130→    return data.rounds.map(backendToRound);\n   131→  } catch {\n   132→    return [];\n   133→  }\n   134→}\n   135→\n   136→// ---------------------------------------------------------------------------\n   137→// PDA derivation (local — game-engine uses Buffer which breaks browser build)\n   138→// ---------------------------------------------------------------------------\n   139→\n   140→const CLOSECALL_PROGRAM_ID = new PublicKey(ClosecallIDL.address);\n   141→\n   142→function getCloseCallConfigPda(): [PublicKey, number] {\n   143→  return PublicKey.findProgramAddressSync(\n   144→    [Buffer.from(\"closecall_config\")],\n   145→    CLOSECALL_PROGRAM_ID,\n   146→  );\n   147→}\n   148→\n   149→function getCloseCallRoundPda(roundIdBytes: Uint8Array): [PublicKey, number] {\n   150→  return PublicKey.findProgramAddressSync(\n   151→    [Buffer.from(\"cc_round\"), Buffer.from(roundIdBytes)],\n   152→    CLOSECALL_PROGRAM_ID,\n   153→  );\n   154→}\n   155→\n   156→// ---------------------------------------------------------------------------\n   157→// Anchor program + transaction builder\n   158→// ---------------------------------------------------------------------------\n   159→\n   160→function getClosecallProgram(connection: Connection): Program<Closecall> {\n   161→  const provider = new AnchorProvider(\n   162→    connection,\n   163→    {} as AnchorProvider[\"wallet\"],\n   164→    { commitment: \"confirmed\" },\n   165→  );\n   166→  return new Program(ClosecallIDL as Idl as Closecall, provider);\n   167→}\n   168→\n   169→async function buildPlaceBetTx(\n   170→  connection: Connection,\n   171→  player: PublicKey,\n   172→  roundId: string,\n   173→  side: BetSide,\n   174→  amountSol: number,\n   175→): Promise<Transaction> {\n   176→  const program = getClosecallProgram(connection);\n   177→  const [configPda] = getCloseCallConfigPda();\n   178→\n   179→  // Round ID is a hex string (16 chars = 8 bytes)\n   180→  const roundIdBytes = Array.from(Buffer.from(roundId, \"hex\"));\n   181→  const [roundPda] = getCloseCallRoundPda(new Uint8Array(roundIdBytes));\n   182→\n   183→  const sideValue = side === \"green\" ? 0 : 1;\n   184→  const amountLamports = new BN(Math.round(amountSol * LAMPORTS_PER_SOL));\n   185→\n   186→  const ix = await program.methods\n   187→    .placeBet(roundIdBytes as unknown as number[], sideValue, amountLamports)\n   188→    .accountsStrict({\n   189→      player,\n   190→      config: configPda,\n   191→      round: roundPda,\n   192→      systemProgram: SystemProgram.programId,\n   193→    })\n   194→    .instruction();\n   195→\n   196→  const tx = new Transaction().add(ix);\n   197→  tx.feePayer = player;\n   198→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   199→\n   200→  return tx;\n   201→}\n   202→\n   203→// ---------------------------------------------------------------------------\n   204→// Error parsing (user-friendly messages)\n   205→// ---------------------------------------------------------------------------\n   206→\n   207→function parseTransactionError(err: unknown): string {\n   208→  const msg = err instanceof Error ? err.message : String(err);\n   209→\n   210→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n   211→    return \"Transaction cancelled by user.\";\n   212→  }\n   213→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n   214→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n   215→  }\n   216→  if (msg.includes(\"BettingClosed\") || msg.includes(\"BettingWindowClosed\")) {\n   217→    return \"Betting window has closed for this round. Wait for the next round.\";\n   218→  }\n   219→  if (msg.includes(\"AlreadyBet\") || msg.includes(\"already\")) {\n   220→    return \"You already placed a bet on this round.\";\n   221→  }\n   222→  if (msg.includes(\"MaxEntriesReached\")) {\n   223→    return \"This round is full. Wait for the next round.\";\n   224→  }\n   225→  if (msg.includes(\"Paused\") || msg.includes(\"GamePaused\")) {\n   226→    return \"Game is currently paused.\";\n   227→  }\n   228→  if (msg.includes(\"InvalidPhase\")) {\n   229→    return \"This round is no longer accepting bets.\";\n   230→  }\n   231→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n   232→    return \"Network error. Please check your connection and try again.\";\n   233→  }\n   234→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n   235→    return \"Transaction simulation failed. The round may no longer be open for bets.\";\n   236→  }\n   237→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n   238→    return \"Transaction expired. Please try again.\";\n   239→  }\n   240→\n   241→  console.error(\"[closecall] unhandled transaction error:\", err);\n   242→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n   243→}\n   244→\n   245→// ---------------------------------------------------------------------------\n   246→// Local candle builder — accumulates 1-min OHLC from live Pyth price ticks\n   247→// ---------------------------------------------------------------------------\n   248→\n   249→function getMinuteBoundary(ts: number): number {\n   250→  return Math.floor(ts / 60_000) * 60_000;\n   251→}\n   252→\n   253→// ---------------------------------------------------------------------------\n   254→// Context\n   255→// ---------------------------------------------------------------------------\n   256→\n   257→const defaultContextValue: CloseCallContextValue = {\n   258→  currentRound: null,\n   259→  completedRound: null,\n   260→  recentCandles: [],\n   261→  currentPrice: 0,\n   262→  candleProgress: 0,\n   263→  userHistory: [],\n   264→  pendingAmount: DEFAULT_BET_AMOUNT,\n   265→  pendingSide: null,\n   266→  userBet: null,\n   267→  loading: true,\n   268→  placingBet: false,\n   269→  setPendingAmount: () => {},\n   270→  setPendingSide: () => {},\n   271→  placeBet: async () => {},\n   272→  adjustBetAmount: () => {},\n   273→  clearCompletedRound: () => {},\n   274→  potentialPayout: 0,\n   275→  userOdds: 0,\n   276→  refreshRound: () => {},\n   277→};\n   278→\n   279→const CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n   280→\n   281→export function CloseCallProvider({ children }: { children: ReactNode }) {\n   282→  const { address, publicKey, sendTransaction, getBalance } = useWallet();\n   283→  const { connection } = useConnection();\n   284→  const { refresh: refreshBalance } = useBalance();\n   285→\n   286→  // Live BTC price from Pyth via price-feeds package\n   287→  const btcPrice = usePriceSubscription(\"BTC\");\n   288→\n   289→  // Round state\n   290→  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n   291→  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n   292→  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n   293→  const [currentPrice, setCurrentPrice] = useState(0);\n   294→  const [candleProgress, setCandleProgress] = useState(0);\n   295→\n   296→  // User state\n   297→  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n   298→  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n   299→  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n   300→\n   301→  // Loading states\n   302→  const [loading, setLoading] = useState(true);\n   303→  const [placingBet, setPlacingBet] = useState(false);\n   304→\n   305→  // Candle builder refs\n   306→  const candlesRef = useRef<Candle[]>([]);\n   307→  const currentCandleRef = useRef<Candle | null>(null);\n   308→\n   309→  // Track previous round id to detect round transitions\n   310→  const prevRoundIdRef = useRef<string | null>(null);\n   311→\n   312→  // -----------------------------------------------------------------------\n   313→  // Update currentPrice from Pyth subscription\n   314→  // -----------------------------------------------------------------------\n   315→  useEffect(() => {\n   316→    if (btcPrice && btcPrice.price > 0) {\n   317→      setCurrentPrice(btcPrice.price);\n   318→    }\n   319→  }, [btcPrice]);\n   320→\n   321→  // -----------------------------------------------------------------------\n   322→  // Build local candles from live price ticks\n   323→  // -----------------------------------------------------------------------\n   324→  useEffect(() => {\n   325→    if (!btcPrice || btcPrice.price <= 0) return;\n   326→\n   327→    const price = btcPrice.price;\n   328→    const now = Date.now();\n   329→    const minuteStart = getMinuteBoundary(now);\n   330→\n   331→    const current = currentCandleRef.current;\n   332→    if (!current || current.openTime !== minuteStart) {\n   333→      // New minute boundary — close previous candle\n   334→      if (current) {\n   335→        candlesRef.current = [...candlesRef.current.slice(-14), current];\n   336→      }\n   337→      currentCandleRef.current = {\n   338→        open: price,\n   339→        high: price,\n   340→        low: price,\n   341→        close: price,\n   342→        openTime: minuteStart,\n   343→        closeTime: minuteStart + 60_000,\n   344→      };\n   345→    } else {\n   346→      // Update current candle tick\n   347→      currentCandleRef.current = {\n   348→        ...current,\n   349→        high: Math.max(current.high, price),\n   350→        low: Math.min(current.low, price),\n   351→        close: price,\n   352→      };\n   353→    }\n   354→\n   355→    // Push to state so chart re-renders\n   356→    const forming = currentCandleRef.current;\n   357→    setRecentCandles(forming ? [...candlesRef.current, forming] : candlesRef.current);\n   358→  }, [btcPrice]);\n   359→\n   360→  // -----------------------------------------------------------------------\n   361→  // Candle progress timer (100ms tick)\n   362→  // -----------------------------------------------------------------------\n   363→  useEffect(() => {\n   364→    const timer = setInterval(() => {\n   365→      const now = Date.now();\n   366→      const minuteStart = getMinuteBoundary(now);\n   367→      const progress = (now - minuteStart) / 60_000;\n   368→      setCandleProgress(Math.min(progress, 1));\n   369→    }, 100);\n   370→    return () => clearInterval(timer);\n   371→  }, []);\n   372→\n   373→  // -----------------------------------------------------------------------\n   374→  // Poll backend for current round (every 2s)\n   375→  // -----------------------------------------------------------------------\n   376→  useEffect(() => {\n   377→    let cancelled = false;\n   378→\n   379→    async function poll() {\n   380→      const round = await fetchCurrentRound();\n   381→      if (cancelled) return;\n   382→\n   383→      if (round) {\n   384→        // Detect round transition: previous round settled/refunded\n   385→        if (prevRoundIdRef.current && prevRoundIdRef.current !== round.id) {\n   386→          // Fetch the completed round from history for result overlay\n   387→          const history = await fetchRoundHistory(1);\n   388→          const prev = history[0];\n   389→          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n   390→            setCompletedRound(prev);\n   391→          }\n   392→        }\n   393→        prevRoundIdRef.current = round.id;\n   394→        setCurrentRound(round);\n   395→      } else {\n   396→        // No active round — check if previous round just settled\n   397→        if (prevRoundIdRef.current) {\n   398→          const history = await fetchRoundHistory(1);\n   399→          const prev = history[0];\n   400→          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n   401→            setCompletedRound(prev);\n   402→          }\n   403→          prevRoundIdRef.current = null;\n   404→        }\n   405→        setCurrentRound(null);\n   406→      }\n   407→      setLoading(false);\n   408→    }\n   409→\n   410→    // Initial fetch\n   411→    poll();\n   412→\n   413→    const interval = setInterval(poll, ROUND_POLL_MS);\n   414→    return () => {\n   415→      cancelled = true;\n   416→      clearInterval(interval);\n   417→    };\n   418→  }, []);\n   419→\n   420→  // -----------------------------------------------------------------------\n   421→  // Derive user bet from current round\n   422→  // -----------------------------------------------------------------------\n   423→  const userBet = useMemo(() => {\n   424→    if (!currentRound || !address) return null;\n   425→    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n   426→    return allBets.find((b) => b.address === address) ?? null;\n   427→  }, [currentRound, address]);\n   428→\n   429→  // -----------------------------------------------------------------------\n   430→  // Build user history from settled rounds\n   431→  // -----------------------------------------------------------------------\n   432→  useEffect(() => {\n   433→    if (!address) {\n   434→      setUserHistory([]);\n   435→      return;\n   436→    }\n   437→\n   438→    let cancelled = false;\n   439→\n   440→    async function loadHistory() {\n   441→      const rounds = await fetchRoundHistory(20);\n   442→      if (cancelled) return;\n   443→\n   444→      const history: UserRoundHistory[] = [];\n   445→      for (const round of rounds) {\n   446→        const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n   447→        const bet = allBets.find((b) => b.address === address);\n   448→        if (bet) {\n   449→          const won = round.outcome === bet.side;\n   450→          history.push({\n   451→            round,\n   452→            userBet: bet,\n   453→            payout: won ? calculatePotentialPayout(bet.amount, bet.side, round.pool) : 0,\n   454→            won,\n   455→          });\n   456→        }\n   457→      }\n   458→      setUserHistory(history);\n   459→    }\n   460→\n   461→    loadHistory();\n   462→\n   463→    return () => { cancelled = true; };\n   464→  }, [address, currentRound?.phase]);\n   465→\n   466→  // -----------------------------------------------------------------------\n   467→  // Potential payout\n   468→  // -----------------------------------------------------------------------\n   469→  const potentialPayout = useMemo(() => {\n   470→    if (!currentRound) return 0;\n   471→\n   472→    if (userBet) {\n   473→      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n   474→    }\n   475→\n   476→    if (!pendingSide || pendingAmount <= 0) return 0;\n   477→\n   478→    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n   479→  }, [pendingAmount, pendingSide, currentRound, userBet]);\n   480→\n   481→  // User odds (share of winning pool)\n   482→  const userOdds = useMemo(() => {\n   483→    if (!userBet || !currentRound) return 0;\n   484→    const winningPool =\n   485→      userBet.side === \"green\"\n   486→        ? currentRound.pool.greenPool\n   487→        : currentRound.pool.redPool;\n   488→    if (winningPool === 0) return 0;\n   489→    return (userBet.amount / winningPool) * 100;\n   490→  }, [userBet, currentRound]);\n   491→\n   492→  // -----------------------------------------------------------------------\n   493→  // Refresh round data on demand\n   494→  // -----------------------------------------------------------------------\n   495→  const refreshRound = useCallback(() => {\n   496→    fetchCurrentRound().then((round) => {\n   497→      if (round) setCurrentRound(round);\n   498→    });\n   499→  }, []);\n   500→\n   501→  // Clear completed round (after user dismisses result overlay)\n   502→  const clearCompletedRound = useCallback(() => {\n   503→    setCompletedRound(null);\n   504→  }, []);\n   505→\n   506→  // -----------------------------------------------------------------------\n   507→  // Send + confirm helper (retries on blockhash expiry)\n   508→  // -----------------------------------------------------------------------\n   509→  const sendAndConfirm = useCallback(\n   510→    async (transaction: Transaction): Promise<string> => {\n   511→      const MAX_SEND_ATTEMPTS = 3;\n   512→      let cachedBlockhash: string | undefined;\n   513→      let cachedHeight: number | undefined;\n   514→\n   515→      // Pre-flight simulation\n   516→      try {\n   517→        const { blockhash, lastValidBlockHeight } =\n   518→          await connection.getLatestBlockhash(\"confirmed\");\n   519→        cachedBlockhash = blockhash;\n   520→        cachedHeight = lastValidBlockHeight;\n   521→        transaction.recentBlockhash = blockhash;\n   522→\n   523→        const simResult = await connection.simulateTransaction(transaction);\n   524→        if (simResult.value.err) {\n   525→          console.error(\"[closecall] simulation failed:\", JSON.stringify(simResult.value.err));\n   526→          if (simResult.value.logs) {\n   527→            console.error(\"[closecall] simulation logs:\\n\" + simResult.value.logs.join(\"\\n\"));\n   528→          }\n   529→          const err = simResult.value.err;\n   530→          if (typeof err === \"object\" && err !== null && \"InstructionError\" in err) {\n   531→            throw new Error(`Transaction will fail: ${JSON.stringify(err)}`);\n   532→          }\n   533→        }\n   534→      } catch (simErr) {\n   535→        if (simErr instanceof Error && simErr.message.startsWith(\"Transaction will fail:\")) {\n   536→          throw simErr;\n   537→        }\n   538→        console.error(\"[closecall] simulation RPC error:\", simErr);\n   539→      }\n   540→\n   541→      for (let attempt = 1; attempt <= MAX_SEND_ATTEMPTS; attempt++) {\n   542→        let blockhash: string;\n   543→        let lastValidBlockHeight: number;\n   544→\n   545→        if (attempt === 1 && cachedBlockhash && cachedHeight) {\n   546→          blockhash = cachedBlockhash;\n   547→          lastValidBlockHeight = cachedHeight;\n   548→        } else {\n   549→          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n   550→          blockhash = fresh.blockhash;\n   551→          lastValidBlockHeight = fresh.lastValidBlockHeight;\n   552→        }\n   553→        transaction.recentBlockhash = blockhash;\n   554→\n   555→        const signature = await sendTransaction(transaction);\n   556→        console.log(`[closecall] tx sent (attempt ${attempt}/${MAX_SEND_ATTEMPTS}): ${signature}`);\n   557→\n   558→        const controller = new AbortController();\n   559→        const timeout = setTimeout(() => controller.abort(), 30_000);\n   560→        try {\n   561→          await connection.confirmTransaction(\n   562→            { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n   563→            \"confirmed\",\n   564→          );\n   565→          await refreshBalance();\n   566→          return signature;\n   567→        } catch (confirmErr) {\n   568→          const confirmMsg = confirmErr instanceof Error ? confirmErr.message : String(confirmErr);\n   569→          const isExpired = confirmMsg.includes(\"expired\") || confirmMsg.includes(\"block height exceeded\");\n   570→          const isAborted = confirmMsg.includes(\"aborted\");\n   571→\n   572→          if ((isExpired || isAborted) && attempt < MAX_SEND_ATTEMPTS) {\n   573→            try {\n   574→              const status = await connection.getSignatureStatus(signature);\n   575→              if (\n   576→                status.value?.confirmationStatus === \"confirmed\" ||\n   577→                status.value?.confirmationStatus === \"finalized\"\n   578→              ) {\n   579→                console.log(`[closecall] tx ${signature} confirmed via fallback status check`);\n   580→                await refreshBalance();\n   581→                return signature;\n   582→              }\n   583→            } catch {\n   584→              // Status check failed — fall through to retry\n   585→            }\n   586→            console.warn(`[closecall] tx dropped/expired on attempt ${attempt}, retrying...`);\n   587→            continue;\n   588→          }\n   589→          throw confirmErr;\n   590→        } finally {\n   591→          clearTimeout(timeout);\n   592→        }\n   593→      }\n   594→\n   595→      throw new Error(\"Transaction failed after max retry attempts\");\n   596→    },\n   597→    [connection, sendTransaction, refreshBalance],\n   598→  );\n   599→\n   600→  // -----------------------------------------------------------------------\n   601→  // Place bet — builds and sends on-chain place_bet transaction\n   602→  // -----------------------------------------------------------------------\n   603→  const placeBet = useCallback(\n   604→    async (sideOverride?: BetSide) => {\n   605→      if (!address || !publicKey) throw new Error(\"Wallet not connected\");\n   606→\n   607→      const side = sideOverride ?? pendingSide;\n   608→      if (!side) throw new Error(\"Select GREEN or RED\");\n   609→\n   610→      if (pendingAmount < MIN_BET_AMOUNT) {\n   611→        throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n   612→      }\n   613→      if (pendingAmount > MAX_BET_AMOUNT) {\n   614→        throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n   615→      }\n   616→\n   617→      const currentBalance = getBalance?.();\n   618→      if (currentBalance !== undefined && pendingAmount > currentBalance) {\n   619→        throw new Error(\"Insufficient balance\");\n   620→      }\n   621→\n   622→      if (!currentRound || currentRound.phase !== \"open\") {\n   623→        throw new Error(\"No active round to bet on\");\n   624→      }\n   625→\n   626→      if (Date.now() > currentRound.bettingEndsAt) {\n   627→        throw new Error(\"Betting window has closed. Wait for the next round.\");\n   628→      }\n   629→\n   630→      setPlacingBet(true);\n   631→      try {\n   632→        const transaction = await buildPlaceBetTx(\n   633→          connection,\n   634→          publicKey,\n   635→          currentRound.id,\n   636→          side,\n   637→          pendingAmount,\n   638→        );\n   639→\n   640→        await sendAndConfirm(transaction);\n   641→\n   642→        // Clear pending side on success\n   643→        setPendingSide(null);\n   644→\n   645→        // Refresh round data to reflect the new bet\n   646→        refreshRound();\n   647→      } catch (err) {\n   648→        const userMsg = parseTransactionError(err);\n   649→\n   650→        // If betting closed race condition, refresh round state\n   651→        if (userMsg.includes(\"closed\") || userMsg.includes(\"no longer\")) {\n   652→          refreshRound();\n   653→        }\n   654→\n   655→        throw new Error(userMsg);\n   656→      } finally {\n   657→        setPlacingBet(false);\n   658→      }\n   659→    },\n   660→    [address, publicKey, pendingSide, pendingAmount, getBalance, currentRound, connection, sendAndConfirm, refreshRound],\n   661→  );\n   662→\n   663→  // -----------------------------------------------------------------------\n   664→  // Adjust bet amount\n   665→  // -----------------------------------------------------------------------\n   666→  const adjustBetAmount = useCallback(\n   667→    (adjustment: \"half\" | \"double\" | \"max\") => {\n   668→      let newAmount: number;\n   669→      const currentBalance = getBalance?.();\n   670→\n   671→      switch (adjustment) {\n   672→        case \"half\":\n   673→          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n   674→          break;\n   675→        case \"double\":\n   676→          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n   677→          break;\n   678→        case \"max\":\n   679→          newAmount =\n   680→            currentBalance !== undefined\n   681→              ? Math.min(currentBalance, MAX_BET_AMOUNT)\n   682→              : MAX_BET_AMOUNT;\n   683→          break;\n   684→      }\n   685→\n   686→      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n   687→    },\n   688→    [pendingAmount, getBalance],\n   689→  );\n   690→\n   691→  const contextValue: CloseCallContextValue = {\n   692→    currentRound,\n   693→    completedRound,\n   694→    recentCandles,\n   695→    currentPrice,\n   696→    candleProgress,\n   697→    userHistory,\n   698→    pendingAmount,\n   699→    pendingSide,\n   700→    userBet,\n   701→    loading,\n   702→    placingBet,\n   703→    setPendingAmount,\n   704→    setPendingSide,\n   705→    placeBet,\n   706→    adjustBetAmount,\n   707→    clearCompletedRound,\n   708→    potentialPayout,\n   709→    userOdds,\n   710→    refreshRound,\n   711→  };\n   712→\n   713→  return (\n   714→    <CloseCallContext.Provider value={contextValue}>\n   715→      {children}\n   716→    </CloseCallContext.Provider>\n   717→  );\n   718→}\n   719→\n   720→export function useCloseCall(): CloseCallContextValue {\n   721→  const context = useContext(CloseCallContext);\n   722→  if (!context) {\n   723→    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n   724→  }\n   725→  return context;\n   726→}\n   727→"}]},"parent_tool_use_id":"toolu_019g1fz37RyReuh9CSNW9zfa","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"75cd084d-596b-4521-9e1e-42feae1e2380"}
