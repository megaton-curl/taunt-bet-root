{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01LnoGP47nccbZfS7ggR5yyg","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01D74bGGiTgh3Ws2RJ7C3jwf","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/on-chain.ts","limit":200},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":5,"cache_creation_input_tokens":6123,"cache_read_input_tokens":36921,"cache_creation":{"ephemeral_5m_input_tokens":6123,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01EWoNASPT6R2cYfWgZ31awF","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"19bfc393-7aa6-4f00-bf38-b790ba3f85f3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D74bGGiTgh3Ws2RJ7C3jwf","type":"tool_result","content":"     1→/**\n     2→ * On-chain assertion helpers for local E2E tests.\n     3→ *\n     4→ * Provides RPC-based helpers to query and assert match PDA state,\n     5→ * treasury fee deltas, and player profile stat updates.\n     6→ */\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     9→import {\n    10→  CoinflipIDL,\n    11→  LordofrngsIDL,\n    12→  type Coinflip,\n    13→  type Lordofrngs,\n    14→} from \"@rng-utopia/anchor-client\";\n    15→\n    16→// ============ Program IDs ============\n    17→\n    18→/** Coinflip program address (from IDL). */\n    19→export const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    20→\n    21→/** Lord of RNGs program address (from IDL). */\n    22→export const LORDOFRNGS_PROGRAM_ID = new PublicKey(LordofrngsIDL.address);\n    23→\n    24→/** Platform fee: 300 basis points = 3%. */\n    25→export const FEE_BPS = 300;\n    26→\n    27→/** Coinflip phase constants matching the on-chain program. */\n    28→export const COINFLIP_PHASE_WAITING = 0;\n    29→export const COINFLIP_PHASE_LOCKED = 1;\n    30→export const COINFLIP_PHASE_SETTLED = 2;\n    31→export const COINFLIP_PHASE_REFUNDED = 3;\n    32→\n    33→// ============ PDA Derivation ============\n    34→\n    35→/** Derive the match PDA for a creator + matchId. Seeds: [\"match\", creator, matchId]. */\n    36→export function getMatchPda(creator: PublicKey, matchId: Buffer | Uint8Array): [PublicKey, number] {\n    37→  return PublicKey.findProgramAddressSync(\n    38→    [Buffer.from(\"match\"), creator.toBuffer(), Buffer.from(matchId)],\n    39→    COINFLIP_PROGRAM_ID,\n    40→  );\n    41→}\n    42→\n    43→/** Derive the coinflip config PDA. Seeds: [\"coinflip_config\"]. */\n    44→export function getConfigPda(): [PublicKey, number] {\n    45→  return PublicKey.findProgramAddressSync(\n    46→    [Buffer.from(\"coinflip_config\")],\n    47→    COINFLIP_PROGRAM_ID,\n    48→  );\n    49→}\n    50→\n    51→// ============ Program Instances ============\n    52→\n    53→/**\n    54→ * Create a read-only Coinflip program instance.\n    55→ *\n    56→ * @param connection - Solana RPC connection\n    57→ */\n    58→export function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    59→  const provider = new AnchorProvider(\n    60→    connection,\n    61→    {} as AnchorProvider[\"wallet\"],\n    62→    { commitment: \"confirmed\" },\n    63→  );\n    64→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    65→}\n    66→\n    67→// ============ Account Types ============\n    68→\n    69→/** Deserialized match account shape. */\n    70→export interface MatchAccount {\n    71→  creator: PublicKey;\n    72→  opponent: PublicKey;\n    73→  server: PublicKey;\n    74→  entryAmount: { toNumber(): number };\n    75→  creatorSide: number;\n    76→  phase: number;\n    77→  commitment: Uint8Array;\n    78→  algorithmVer: number;\n    79→  targetSlot: { toNumber(): number };\n    80→  resolveDeadline: { toNumber(): number };\n    81→  resultHash: Uint8Array;\n    82→  result: number;\n    83→  winner: PublicKey;\n    84→  createdAt: { toNumber(): number };\n    85→  matchId: number[];\n    86→  bump: number;\n    87→}\n    88→\n    89→function coinflipPhaseName(phase: number): \"waiting\" | \"locked\" | \"settled\" | \"refunded\" | \"unknown\" {\n    90→  switch (phase) {\n    91→    case COINFLIP_PHASE_WAITING:\n    92→      return \"waiting\";\n    93→    case COINFLIP_PHASE_LOCKED:\n    94→      return \"locked\";\n    95→    case COINFLIP_PHASE_SETTLED:\n    96→      return \"settled\";\n    97→    case COINFLIP_PHASE_REFUNDED:\n    98→      return \"refunded\";\n    99→    default:\n   100→      return \"unknown\";\n   101→  }\n   102→}\n   103→\n   104→// ============ Fetch Helpers ============\n   105→\n   106→/**\n   107→ * Fetch a match PDA account. Returns null if the account is closed.\n   108→ *\n   109→ * @param connection - Solana RPC connection\n   110→ * @param matchPda - The match PDA address\n   111→ */\n   112→export async function fetchMatch(\n   113→  connection: Connection,\n   114→  matchPda: PublicKey,\n   115→): Promise<MatchAccount | null> {\n   116→  const program = getCoinflipProgram(connection);\n   117→  try {\n   118→    return (await program.account.coinflipMatch.fetch(\n   119→      matchPda,\n   120→    )) as unknown as MatchAccount;\n   121→  } catch {\n   122→    // Account not found (closed or never created)\n   123→    return null;\n   124→  }\n   125→}\n   126→\n   127→/**\n   128→ * Get the treasury wallet address from the coinflip config PDA.\n   129→ *\n   130→ * @param connection - Solana RPC connection\n   131→ */\n   132→export async function getTreasuryAddress(\n   133→  connection: Connection,\n   134→): Promise<PublicKey> {\n   135→  const program = getCoinflipProgram(connection);\n   136→  const [configPda] = getConfigPda();\n   137→  const config = await program.account.coinflipConfig.fetch(configPda);\n   138→  return (config as unknown as { treasury: PublicKey }).treasury;\n   139→}\n   140→\n   141→// ============ Balance Helpers ============\n   142→\n   143→/**\n   144→ * Get the SOL balance of an address in lamports.\n   145→ *\n   146→ * @param connection - Solana RPC connection\n   147→ * @param address - Public key to check\n   148→ */\n   149→export async function getBalanceLamports(\n   150→  connection: Connection,\n   151→  address: PublicKey,\n   152→): Promise<number> {\n   153→  return connection.getBalance(address);\n   154→}\n   155→\n   156→/**\n   157→ * Capture a balance snapshot for later delta comparison.\n   158→ *\n   159→ * @param connection - Solana RPC connection\n   160→ * @param address - Public key to snapshot\n   161→ */\n   162→export async function snapshotBalance(\n   163→  connection: Connection,\n   164→  address: PublicKey,\n   165→): Promise<number> {\n   166→  return connection.getBalance(address);\n   167→}\n   168→\n   169→// ============ Fee Calculation ============\n   170→\n   171→/**\n   172→ * Calculate the expected fee and net payout for a coinflip match.\n   173→ * Mirrors on-chain logic: fee = floor(pool * FEE_BPS / 10_000).\n   174→ *\n   175→ * @param entryAmount - Single player's entry in lamports\n   176→ * @returns Object with pool, fee, and payout amounts in lamports\n   177→ */\n   178→export function calculateExpectedFee(entryAmount: number): {\n   179→  pool: number;\n   180→  fee: number;\n   181→  payout: number;\n   182→} {\n   183→  const pool = entryAmount * 2;\n   184→  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n   185→  const payout = pool - fee;\n   186→  return { pool, fee, payout };\n   187→}\n   188→\n   189→// ============ Assertion Helpers ============\n   190→\n   191→/**\n   192→ * Assert match PDA state after creation (Waiting phase).\n   193→ *\n   194→ * Uses memcmp-based search to find the creator's active match,\n   195→ * so it works regardless of which nonce was used for PDA derivation.\n   196→ *\n   197→ * @param connection - Solana RPC connection\n   198→ * @param creator - Creator's public key\n   199→ * @param expectedSide - Expected creator side (0 = heads, 1 = tails)\n   200→ * @param expectedEntryAmount - Expected entry amount in lamports"}]},"parent_tool_use_id":"toolu_01EWoNASPT6R2cYfWgZ31awF","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"32e65351-9814-477e-816c-a1db59c32c9a"}
