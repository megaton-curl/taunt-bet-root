{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XtQ9KimPdFN6wTUkHZ5AhW","type":"tool_result","content":"     1→import type { Round, PlayerBet } from \"../types\";\n     2→import { SIDE_COLORS, PLATFORM_FEE, BETTING_WINDOW_MS } from \"../types\";\n     3→\n     4→interface ActiveBetViewProps {\n     5→  round: Round;\n     6→  userBet: PlayerBet;\n     7→}\n     8→\n     9→export function ActiveBetView({ round, userBet }: ActiveBetViewProps) {\n    10→  // Calculate potential payout\n    11→  const winningPool = userBet.side === \"green\" ? round.pool.greenPool : round.pool.redPool;\n    12→  const totalPool = round.pool.totalPool;\n    13→  const netPool = totalPool * (1 - PLATFORM_FEE);\n    14→\n    15→  const potentialPayout = winningPool > 0 ? (userBet.amount / winningPool) * netPool : 0;\n    16→  const potentialProfit = potentialPayout - userBet.amount;\n    17→  const multiplier = userBet.amount > 0 ? potentialPayout / userBet.amount : 0;\n    18→\n    19→  // Get side color\n    20→  const sideColor = SIDE_COLORS[userBet.side];\n    21→\n    22→  // Determine if still in betting window (round is open and betting time hasn't elapsed)\n    23→  const isBettingOpen = round.phase === \"open\" && Date.now() < round.bettingEndsAt;\n    24→  const isLocked = round.phase === \"open\" && Date.now() >= round.bettingEndsAt;\n    25→\n    26→  // Phase display text\n    27→  const getPhaseText = () => {\n    28→    if (round.phase === \"settled\") return \"Round complete\";\n    29→    if (round.phase === \"refunded\") return \"Round refunded\";\n    30→    if (isBettingOpen) return \"Waiting for candle...\";\n    31→    if (isLocked) return \"Bets locked - watching candle...\";\n    32→    return \"\";\n    33→  };\n    34→\n    35→  // Time remaining in betting window\n    36→  const bettingTimeLeft = Math.max(0, round.bettingEndsAt - Date.now());\n    37→  const bettingProgress = 1 - bettingTimeLeft / BETTING_WINDOW_MS;\n    38→\n    39→  return (\n    40→    <div className=\"close-call-active-bet\">\n    41→      <div className=\"close-call-active-bet__header\">\n    42→        <h3 className=\"close-call-active-bet__title\">Your Active Bet</h3>\n    43→        <span\n    44→          className=\"close-call-active-bet__phase\"\n    45→          data-phase={round.phase}\n    46→          data-betting={isBettingOpen ? \"true\" : undefined}\n    47→          data-locked={isLocked ? \"true\" : undefined}\n    48→        >\n    49→          {getPhaseText()}\n    50→        </span>\n    51→      </div>\n    52→\n    53→      <div className=\"close-call-active-bet__card\">\n    54→        <div className=\"close-call-active-bet__side\" style={{ color: sideColor }}>\n    55→          <span className=\"close-call-active-bet__side-icon\">\n    56→            {userBet.side === \"green\" ? \"▲\" : \"▼\"}\n    57→          </span>\n    58→          <span className=\"close-call-active-bet__side-label\">\n    59→            {userBet.side.toUpperCase()}\n    60→          </span>\n    61→        </div>\n    62→\n    63→        <div className=\"close-call-active-bet__details\">\n    64→          <div className=\"close-call-active-bet__row\">\n    65→            <span>Your Stake</span>\n    66→            <span>{userBet.amount.toFixed(4)} SOL</span>\n    67→          </div>\n    68→          <div className=\"close-call-active-bet__row\">\n    69→            <span>Your Share</span>\n    70→            <span>\n    71→              {winningPool > 0\n    72→                ? ((userBet.amount / winningPool) * 100).toFixed(1)\n    73→                : 0}%\n    74→            </span>\n    75→          </div>\n    76→          <div className=\"close-call-active-bet__row close-call-active-bet__row--highlight\">\n    77→            <span>Potential Win</span>\n    78→            <span className=\"close-call-active-bet__payout\">\n    79→              {potentialPayout.toFixed(4)} SOL\n    80→              <span className=\"close-call-active-bet__profit\">\n    81→                (+{potentialProfit.toFixed(4)})\n    82→              </span>\n    83→            </span>\n    84→          </div>\n    85→          <div className=\"close-call-active-bet__row\">\n    86→            <span>Multiplier</span>\n    87→            <span style={{ color: sideColor }}>{multiplier.toFixed(2)}x</span>\n    88→          </div>\n    89→        </div>\n    90→      </div>\n    91→\n    92→      {isBettingOpen && (\n    93→        <div className=\"close-call-active-bet__note\">\n    94→          Your odds may change as more bets come in ({Math.ceil(bettingTimeLeft / 1000)}s left)\n    95→          <div className=\"close-call-active-bet__progress\" style={{ width: `${bettingProgress * 100}%` }} />\n    96→        </div>\n    97→      )}\n    98→\n    99→      {isLocked && (\n   100→        <div className=\"close-call-active-bet__note close-call-active-bet__note--locked\">\n   101→          Odds are now locked. Good luck!\n   102→        </div>\n   103→      )}\n   104→    </div>\n   105→  );\n   106→}\n   107→"}]},"parent_tool_use_id":"toolu_019g1fz37RyReuh9CSNW9zfa","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"175d551e-c66f-4b4e-997e-73e10699f9d4"}
