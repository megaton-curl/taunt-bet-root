{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DiczdDhHPLGFaU6xPb1dyc","type":"tool_result","content":"     1→/**\n     2→ * Pari-Mutuel Payout Calculator for Close Call\n     3→ *\n     4→ * Formula:\n     5→ *   totalPool = greenPool + redPool\n     6→ *   netPool = totalPool × 0.97 (3% fee)\n     7→ *   playerPayout = (playerBet / winningPool) × netPool\n     8→ */\n     9→\n    10→import type { BetSide, CandleOutcome, Candle, PoolState } from \"../types\";\n    11→import { PLATFORM_FEE } from \"../types\";\n    12→\n    13→export interface PayoutResult {\n    14→  winner: BetSide | null;\n    15→  payouts: Record<string, number>;\n    16→  totalPayout: number;\n    17→  platformFee: number;\n    18→}\n    19→\n    20→/**\n    21→ * Determine the outcome of a candle (strict comparison, no threshold)\n    22→ */\n    23→export function determineOutcome(candle: Candle): CandleOutcome {\n    24→  const diff = candle.close - candle.open;\n    25→\n    26→  if (diff === 0) {\n    27→    return \"refund\";\n    28→  }\n    29→\n    30→  return diff > 0 ? \"green\" : \"red\";\n    31→}\n    32→\n    33→/**\n    34→ * Calculate payouts for all winners\n    35→ */\n    36→export function calculatePayouts(\n    37→  pool: PoolState,\n    38→  outcome: CandleOutcome\n    39→): PayoutResult {\n    40→  const totalPool = pool.totalPool;\n    41→\n    42→  // Handle refund - no winners, full refund, no fee\n    43→  if (outcome === \"refund\") {\n    44→    return {\n    45→      winner: null,\n    46→      payouts: {},\n    47→      totalPayout: 0,\n    48→      platformFee: 0,\n    49→    };\n    50→  }\n    51→\n    52→  // Determine winning side\n    53→  const winner: BetSide = outcome;\n    54→  const winningBets = outcome === \"green\" ? pool.greenBets : pool.redBets;\n    55→  const winningPool = outcome === \"green\" ? pool.greenPool : pool.redPool;\n    56→  const losingPool = outcome === \"green\" ? pool.redPool : pool.greenPool;\n    57→\n    58→  // Handle one-sided pool: no losers means refund, no fee\n    59→  if (losingPool === 0 || winningPool === 0 || winningBets.length === 0) {\n    60→    return {\n    61→      winner,\n    62→      payouts: {},\n    63→      totalPayout: 0,\n    64→      platformFee: 0,\n    65→    };\n    66→  }\n    67→\n    68→  // Calculate platform fee (3% of total pool on decisive rounds only)\n    69→  const platformFee = totalPool * PLATFORM_FEE;\n    70→  const netPool = totalPool - platformFee;\n    71→\n    72→  // Calculate individual payouts\n    73→  const payouts: Record<string, number> = {};\n    74→  let totalPayout = 0;\n    75→\n    76→  for (const bet of winningBets) {\n    77→    const share = bet.amount / winningPool;\n    78→    const payout = netPool * share;\n    79→    payouts[bet.address] = payout;\n    80→    totalPayout += payout;\n    81→  }\n    82→\n    83→  return {\n    84→    winner,\n    85→    payouts,\n    86→    totalPayout,\n    87→    platformFee,\n    88→  };\n    89→}\n    90→\n    91→/**\n    92→ * Calculate potential payout for a hypothetical bet\n    93→ */\n    94→export function calculatePotentialPayout(\n    95→  betAmount: number,\n    96→  betSide: BetSide,\n    97→  pool: PoolState\n    98→): number {\n    99→  // Calculate what the pool would look like with this bet\n   100→  const newWinningPool =\n   101→    betSide === \"green\" ? pool.greenPool + betAmount : pool.redPool + betAmount;\n   102→  const newTotalPool = pool.totalPool + betAmount;\n   103→  const netPool = newTotalPool * (1 - PLATFORM_FEE);\n   104→\n   105→  // Player's share of winning pool\n   106→  const share = betAmount / newWinningPool;\n   107→\n   108→  return netPool * share;\n   109→}\n   110→\n   111→/**\n   112→ * Calculate odds multiplier for a side\n   113→ * Returns how much $1 would win (e.g., 2.0 means double your money)\n   114→ */\n   115→export function calculateOddsMultiplier(\n   116→  side: BetSide,\n   117→  pool: PoolState\n   118→): number {\n   119→  const winningPool = side === \"green\" ? pool.greenPool : pool.redPool;\n   120→  const totalPool = pool.totalPool;\n   121→\n   122→  if (winningPool === 0 || totalPool === 0) {\n   123→    return 0;\n   124→  }\n   125→\n   126→  const netPool = totalPool * (1 - PLATFORM_FEE);\n   127→  return netPool / winningPool;\n   128→}\n   129→\n   130→/**\n   131→ * Calculate percentage of pool on each side\n   132→ */\n   133→export function calculatePoolDistribution(pool: PoolState): {\n   134→  greenPercent: number;\n   135→  redPercent: number;\n   136→} {\n   137→  if (pool.totalPool === 0) {\n   138→    return { greenPercent: 50, redPercent: 50 };\n   139→  }\n   140→\n   141→  return {\n   142→    greenPercent: (pool.greenPool / pool.totalPool) * 100,\n   143→    redPercent: (pool.redPool / pool.totalPool) * 100,\n   144→  };\n   145→}\n   146→\n   147→/**\n   148→ * Format amount for display\n   149→ */\n   150→export function formatAmount(amount: number, decimals: number = 4): string {\n   151→  return amount.toFixed(decimals);\n   152→}\n   153→\n   154→/**\n   155→ * Format USD amount for display\n   156→ */\n   157→export function formatUsd(amount: number): string {\n   158→  return amount.toLocaleString(\"en-US\", {\n   159→    style: \"currency\",\n   160→    currency: \"USD\",\n   161→    minimumFractionDigits: 2,\n   162→    maximumFractionDigits: 2,\n   163→  });\n   164→}\n   165→"}]},"parent_tool_use_id":"toolu_019g1fz37RyReuh9CSNW9zfa","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"5cca7e08-cc8b-4b75-8740-8d1d5f90c839"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RksHagrGHht46GVRQuQKoo","type":"tool_result","content":"     1→/**\n     2→ * Shared E2E page-object helpers for coinflip tests.\n     3→ *\n     4→ * CSS-class-based selectors matching the actual component markup.\n     5→ * Provides create, join, claim, cancel actions and reusable wait/assert primitives.\n     6→ */\n     7→import { type Page, type Locator, expect } from \"@playwright/test\";\n     8→\n     9→// ---------------------------------------------------------------------------\n    10→// Selectors (CSS classes from CoinflipPage, ActiveMatchView, OpenMatchesList)\n    11→// ---------------------------------------------------------------------------\n    12→\n    13→export const sel = {\n    14→  // Page structure\n    15→  lobby: \".coinflip-lobby\",\n    16→  sidebar: \".coinflip-sidebar\",\n    17→  main: \".coinflip-main\",\n    18→\n    19→  // Sidebar — create flow\n    20→  sidebarTitle: \".coinflip-sidebar__title\",\n    21→  tierSelector: \".rng-tier-selector\",\n    22→  tierButton: (tier: string) => `.rng-tier-btn:has(.rng-tier-gem--${tier})`,\n    23→  tierButtonSelected: \".rng-tier-btn--selected\",\n    24→  sideSelector: \".coinflip-side-selector\",\n    25→  sideButtonHeads: \".coinflip-side-btn--heads\",\n    26→  sideButtonTails: \".coinflip-side-btn--tails\",\n    27→  sideButtonSelected: \".coinflip-side-btn--selected\",\n    28→  summary: \".coinflip-sidebar__summary\",\n    29→  actionButton: \".coinflip-action-btn\",\n    30→  actionButtonSecondary: \".coinflip-action-btn--secondary\",\n    31→\n    32→  // Lobby — open matches\n    33→  matchesList: \".coinflip-matches__list\",\n    34→  matchesCount: \".coinflip-matches__count\",\n    35→  matchCard: \".coinflip-match-card\",\n    36→  matchCardOwn: \".coinflip-match-card--own\",\n    37→  matchCardClaimable: \".coinflip-match-card--claimable\",\n    38→  matchCardJoinBtn: \".coinflip-match-card__join-btn\",\n    39→  matchCardAmount: \".coinflip-match-card__amount\",\n    40→  matchCardAddress: \".coinflip-match-card__address\",\n    41→\n    42→  // Active match view\n    43→  activeMatch: \".coinflip-active-match\",\n    44→  activeMatchTitle: \".coinflip-active-match__title\",\n    45→  activeMatchTitleWon: \".coinflip-active-match__title--won\",\n    46→  activeMatchTitleLost: \".coinflip-active-match__title--lost\",\n    47→  activeMatchWaiting: \".coinflip-active-match__waiting\",\n    48→  activeMatchPlaying: \".coinflip-active-match__playing\",\n    49→\n    50→  // Result\n    51→  resultOutcome: \".coinflip-result__outcome\",\n    52→  resultPayout: \".coinflip-result__payout\",\n    53→\n    54→  // Post-claim\n    55→  postClaim: \".coinflip-active-match__post-claim\",\n    56→\n    57→  // Error\n    58→  errorToast: \".rng-toast--error\",\n    59→  toastMessage: \".rng-toast__message\",\n    60→\n    61→  // Sidebar — active match info\n    62→  sidebarStatus: \".coinflip-sidebar__status\",\n    63→  sidebarPot: \".coinflip-sidebar__pot\",\n    64→} as const;\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Types\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export type CoinSide = \"heads\" | \"tails\";\n    71→\n    72→// ---------------------------------------------------------------------------\n    73→// Page-object actions\n    74→// ---------------------------------------------------------------------------\n    75→\n    76→/**\n    77→ * Navigate to the coinflip page and wait for the lobby to render.\n    78→ */\n    79→export async function navigateToCoinflip(page: Page): Promise<void> {\n    80→  await page.goto(\"/coinflip\", { waitUntil: \"domcontentloaded\" });\n    81→  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 15_000 });\n    82→}\n    83→\n    84→/**\n    85→ * Enter a wager amount in SOL into the WagerInput.\n    86→ */\n    87→export async function enterWager(page: Page, amountSol: number): Promise<void> {\n    88→  const input = page.locator(\".rng-wager-input__input\").first();\n    89→  await expect(input).toBeVisible({ timeout: 15_000 });\n    90→  await input.fill(amountSol.toString());\n    91→}\n    92→\n    93→/**\n    94→ * @deprecated Use enterWager instead.\n    95→ * Legacy tier selection — clicks a preset amount button that matches the old tier amount.\n    96→ */\n    97→export async function selectTier(page: Page, _tier: string): Promise<void> {\n    98→  // After tier→amount migration, select the 0.005 SOL preset (matches old \"iron\" tier)\n    99→  await enterWager(page, 0.005);\n   100→}\n   101→\n   102→/**\n   103→ * Select a coin side (heads or tails) in the sidebar.\n   104→ */\n   105→export async function selectSide(page: Page, side: CoinSide): Promise<void> {\n   106→  const selector =\n   107→    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n   108→  await page.click(selector);\n   109→  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n   110→}\n   111→\n   112→/**\n   113→ * Create a match: enter wager amount, select side, click \"Create Game\".\n   114→ * Returns when the active match view (waiting state) is visible.\n   115→ */\n   116→export async function createMatch(\n   117→  page: Page,\n   118→  amountOrTier: number | string,\n   119→  side: CoinSide,\n   120→  options?: { timeout?: number },\n   121→): Promise<void> {\n   122→  // Support both new amount (number) and legacy tier name (string)\n   123→  const amount = typeof amountOrTier === \"number\" ? amountOrTier : 0.005;\n   124→  await enterWager(page, amount);\n   125→  await selectSide(page, side);\n   126→\n   127→  // Click create — button text is \"Create Game\"\n   128→  const createBtn = page.locator(sel.actionButton, {\n   129→    hasText: \"Create Game\",\n   130→  });\n   131→  await expect(createBtn).toBeEnabled();\n   132→  await createBtn.click();\n   133→\n   134→  // Wait for transition to active match (waiting for opponent).\n   135→  // Default 15s is fine for local; devnet callers should pass a longer timeout.\n   136→  await page.waitForSelector(sel.activeMatch, {\n   137→    state: \"visible\",\n   138→    timeout: options?.timeout ?? 15_000,\n   139→  });\n   140→}\n   141→\n   142→/**\n   143→ * Join a match visible in the lobby. If `matchIndex` is provided, join that\n   144→ * specific card (0-based). Otherwise joins the first joinable match.\n   145→ */\n   146→export async function joinMatch(\n   147→  page: Page,\n   148→  matchIndex = 0,\n   149→): Promise<void> {\n   150→  const cards = page.locator(\n   151→    `${sel.matchCard}:not(${sel.matchCardOwn}):not(${sel.matchCardClaimable})`,\n   152→  );\n   153→  const joinBtn = cards.nth(matchIndex).locator(sel.matchCardJoinBtn);\n   154→  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n   155→  await joinBtn.click();\n   156→\n   157→  // Wait for active match view to appear\n   158→  await page.waitForSelector(sel.activeMatch, {\n   159→    state: \"visible\",\n   160→    timeout: 15_000,\n   161→  });\n   162→}\n   163→\n   164→/**\n   165→ * Join a specific match by exact match PDA id.\n   166→ */\n   167→export async function joinMatchById(\n   168→  page: Page,\n   169→  matchId: string,\n   170→): Promise<void> {\n   171→  const card = page.locator(`[data-match-id=\"${matchId}\"]`).first();\n   172→  await expect(card).toBeVisible({ timeout: 15_000 });\n   173→  const joinBtn = card.locator(sel.matchCardJoinBtn);\n   174→  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n   175→  await joinBtn.click();\n   176→\n   177→  await page.waitForSelector(sel.activeMatch, {\n   178→    state: \"visible\",\n   179→    timeout: 15_000,\n   180→  });\n   181→}\n   182→\n   183→/**\n   184→ * Cancel the currently active match (phase = \"created\", waiting for opponent).\n   185→ * Clicks \"Cancel Match\" button in the ActiveMatchView.\n   186→ */\n   187→export async function cancelMatch(page: Page): Promise<void> {\n   188→  const cancelBtn = page.locator(\"button\", { hasText: \"Cancel Match\" });\n   189→  await expect(cancelBtn).toBeVisible({ timeout: 5_000 });\n   190→  await cancelBtn.click();\n   191→\n   192→  // Wait for lobby to reappear\n   193→  await page.waitForSelector(sel.lobby, {\n   194→    state: \"visible\",\n   195→    timeout: 15_000,\n   196→  });\n   197→}\n   198→\n   199→/**\n   200→ * Claim payout for the winner, or settle for the loser.\n   201→ * Clicks the \"Claim Payout\" or \"Settle & Return\" button in the sidebar.\n   202→ */\n   203→export async function claimOrSettle(page: Page): Promise<void> {\n   204→  // The claim/settle button is inside ActiveMatchView (not the sidebar)\n   205→  const claimBtn = page.locator(sel.activeMatch).locator(sel.actionButton).first();\n   206→  await expect(claimBtn).toBeEnabled({ timeout: 15_000 });\n   207→  await claimBtn.click();\n   208→\n   209→  // Wait for post-claim section to confirm claim completed\n   210→  await expect(\n   211→    page.locator(sel.postClaim),\n   212→  ).toBeVisible({ timeout: 15_000 });\n   213→}\n   214→\n   215→/**\n   216→ * Click \"Back to Lobby\" to return after claiming.\n   217→ */\n   218→export async function backToLobby(page: Page): Promise<void> {\n   219→  // \"Back to Lobby\" may appear in sidebar or post-claim area\n   220→  const btn = page.locator(\"button\", { hasText: \"Back to Lobby\" }).first();\n   221→  await expect(btn).toBeVisible();\n   222→  await btn.click();\n   223→  await page.waitForSelector(sel.lobby, {\n   224→    state: \"visible\",\n   225→    timeout: 10_000,\n   226→  });\n   227→}\n   228→\n   229→// ---------------------------------------------------------------------------\n   230→// Wait / assert primitives\n   231→// ---------------------------------------------------------------------------\n   232→\n   233→/**\n   234→ * Wait until the sidebar status text matches the expected phase label.\n   235→ * Phase labels: \"Waiting...\", \"Ready!\", \"Countdown...\", \"Flipping...\", \"Complete\"\n   236→ */\n   237→export async function waitForPhaseLabel(\n   238→  page: Page,\n   239→  label: string,\n   240→  timeout = 30_000,\n   241→): Promise<void> {\n   242→  await expect(page.locator(sel.sidebarStatus)).toHaveText(label, {\n   243→    timeout,\n   244→  });\n   245→}\n   246→\n   247→/**\n   248→ * Wait for the active match title to indicate a win or loss.\n   249→ */\n   250→export async function waitForResult(\n   251→  page: Page,\n   252→  timeout = 30_000,\n   253→): Promise<\"won\" | \"lost\"> {\n   254→  // Wait for either won or lost title class to appear\n   255→  const wonLocator = page.locator(sel.activeMatchTitleWon);\n   256→  const lostLocator = page.locator(sel.activeMatchTitleLost);\n   257→\n   258→  await expect(wonLocator.or(lostLocator)).toBeVisible({ timeout });\n   259→\n   260→  if (await wonLocator.isVisible()) return \"won\";\n   261→  return \"lost\";\n   262→}\n   263→\n   264→/**\n   265→ * Wait until the match either shows a visible result title or has already\n   266→ * returned the player to the lobby after settlement.\n   267→ */\n   268→export async function waitForResultOrLobby(\n   269→  page: Page,\n   270→  timeout = 30_000,\n   271→): Promise<\"won\" | \"lost\" | null> {\n   272→  const wonLocator = page.locator(sel.activeMatchTitleWon);\n   273→  const lostLocator = page.locator(sel.activeMatchTitleLost);\n   274→  const lobbyLocator = page.locator(sel.lobby);\n   275→  const backToLobbyBtn = page.locator(\"button\", { hasText: \"Back to Lobby\" });\n   276→\n   277→  await expect\n   278→    .poll(\n   279→      async () => {\n   280→        const checks = await Promise.all([\n   281→          wonLocator.count(),\n   282→          lostLocator.count(),\n   283→          lobbyLocator.count(),\n   284→          backToLobbyBtn.count(),\n   285→        ]);\n   286→        return checks.some((count) => count > 0);\n   287→      },\n   288→      { timeout },\n   289→    )\n   290→    .toBe(true);\n   291→\n   292→  if (await wonLocator.isVisible()) return \"won\";\n   293→  if (await lostLocator.isVisible()) return \"lost\";\n   294→  return null;\n   295→}\n   296→\n   297→/**\n   298→ * Wait for a match to appear in the lobby's open match list.\n   299→ */\n   300→export async function waitForLobbyMatch(\n   301→  page: Page,\n   302→  timeout = 15_000,\n   303→): Promise<Locator> {\n   304→  const card = page.locator(\n   305→    `${sel.matchCard}:not(${sel.matchCardClaimable})`,\n   306→  ).first();\n   307→  await expect(card).toBeVisible({ timeout });\n   308→  return card;\n   309→}\n   310→\n   311→/**\n   312→ * Assert the lobby is empty (no open matches).\n   313→ */\n   314→export async function assertLobbyEmpty(\n   315→  page: Page,\n   316→  timeout = 10_000,\n   317→): Promise<void> {\n   318→  // Either the empty state text or zero non-claimable match cards\n   319→  await expect(\n   320→    page.locator(`${sel.matchCard}:not(${sel.matchCardClaimable})`),\n   321→  ).toHaveCount(0, { timeout });\n   322→}\n   323→\n   324→/**\n   325→ * Assert that an error toast is visible with the given message substring.\n   326→ */\n   327→export async function assertErrorToast(\n   328→  page: Page,\n   329→  messageSubstring: string,\n   330→  timeout = 5_000,\n   331→): Promise<void> {\n   332→  const toast = page.locator(sel.errorToast);\n   333→  await expect(toast).toBeVisible({ timeout });\n   334→  await expect(toast).toContainText(messageSubstring);\n   335→}\n   336→\n   337→/**\n   338→ * Assert that no error toasts are visible.\n   339→ */\n   340→export async function assertNoErrorToast(page: Page): Promise<void> {\n   341→  await expect(page.locator(sel.errorToast)).toHaveCount(0);\n   342→}\n   343→\n   344→/**\n   345→ * Get the current balance displayed or fetched from connection for a wallet.\n   346→ * This is a convenience wrapper for reading SOL balance via RPC, not UI-based.\n   347→ */\n   348→export async function getSolBalance(\n   349→  page: Page,\n   350→  walletAddress: string,\n   351→  rpcUrl = \"http://127.0.0.1:8899\",\n   352→): Promise<number> {\n   353→  return page.evaluate(\n   354→    async ({ address, rpc }) => {\n   355→      const res = await fetch(rpc, {\n   356→        method: \"POST\",\n   357→        headers: { \"Content-Type\": \"application/json\" },\n   358→        body: JSON.stringify({\n   359→          jsonrpc: \"2.0\",\n   360→          id: 1,\n   361→          method: \"getBalance\",\n   362→          params: [address, { commitment: \"confirmed\" }],\n   363→        }),\n   364→      });\n   365→      const json = await res.json();\n   366→      return (json.result?.value ?? 0) / 1_000_000_000;\n   367→    },\n   368→    { address: walletAddress, rpc: rpcUrl },\n   369→  );\n   370→}\n   371→\n   372→/**\n   373→ * Collect console errors from a page. Returns a cleanup function\n   374→ * and an array that accumulates errors.\n   375→ */\n   376→export function trackConsoleErrors(page: Page): {\n   377→  errors: string[];\n   378→  assertClean: () => void;\n   379→} {\n   380→  const errors: string[] = [];\n   381→  page.on(\"console\", (msg) => {\n   382→    if (msg.type() === \"error\") errors.push(msg.text());\n   383→  });\n   384→  return {\n   385→    errors,\n   386→    assertClean: () => {\n   387→      // Filter out known non-critical browser noise\n   388→      const real = errors.filter(\n   389→        (e) =>\n   390→          !e.includes(\"favicon.ico\") &&\n   391→          !e.includes(\"downloadable font\") &&\n   392→          !e.includes(\"third-party cookie\"),\n   393→      );\n   394→      expect(real).toEqual([]);\n   395→    },\n   396→  };\n   397→}\n   398→\n   399→/**\n   400→ * Wait for a specific text to appear anywhere on the page.\n   401→ */\n   402→export async function waitForText(\n   403→  page: Page,\n   404→  text: string,\n   405→  timeout = 10_000,\n   406→): Promise<void> {\n   407→  await expect(page.getByText(text).first()).toBeVisible({ timeout });\n   408→}\n   409→\n   410→/**\n   411→ * Wait for the lobby to be visible (no active match).\n   412→ */\n   413→export async function waitForLobby(\n   414→  page: Page,\n   415→  timeout = 15_000,\n   416→): Promise<void> {\n   417→  await page.waitForSelector(sel.lobby, {\n   418→    state: \"visible\",\n   419→    timeout,\n   420→  });\n   421→}\n   422→"}]},"parent_tool_use_id":"toolu_01EWoNASPT6R2cYfWgZ31awF","session_id":"4d69f4c8-14e7-4d13-b2b6-b269933f82f3","uuid":"9ff82a2c-021b-45cc-b654-dd0156ce8acc"}
