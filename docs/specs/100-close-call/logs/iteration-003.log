---------------------------------------------\n   200→\n   201→export async function encodeCoinflipMatch(\n   202→  fields: DecodedCoinflipMatch,\n   203→): Promise<Buffer> {\n   204→  return coinflipCoder.encode(\"CoinflipMatch\", {\n   205→    creator: fields.creator,\n   206→    opponent: fields.opponent,\n   207→    server: fields.server,\n   208→    entry_amount: new BN(fields.entryAmount.toString()),\n   209→    creator_side: fields.creatorSide,\n   210→    phase: fields.phase,\n   211→    commitment: fields.commitment,\n   212→    algorithm_ver: fields.algorithmVer,\n   213→    target_slot: new BN(fields.targetSlot.toString()),\n   214→    resolve_deadline: new BN(fields.resolveDeadline.toString()),\n   215→    result_hash: fields.resultHash,\n   216→    result: fields.result,\n   217→    winner: fields.winner,\n   218→    created_at: new BN(fields.createdAt.toString()),\n   219→    match_id: fields.matchId,\n   220→    bump: fields.bump,\n   221→  });\n   222→}\n   223→\n   224→export async function encodeCoinflipConfig(\n   225→  fields: DecodedCoinflipConfig,\n   226→): Promise<Buffer> {\n   227→  return coinflipCoder.encode(\"CoinflipConfig\", {\n   228→    authority: fields.authority,\n   229→    treasury: fields.treasury,\n   230→    paused: fields.paused,\n   231→    bump: fields.bump,\n   232→  });\n   233→}\n   234→"}]},"parent_tool_use_id":null,"session_id":"c7e08aab-e81c-466a-b6c2-35d333150199","uuid":"cecd13bb-1c2b-4202-94c2-938a40008a8f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/account-decoder.ts","content":"/**\n * IDL-driven account decoder — single source of truth for all Solana account\n * data access in the backend.\n *\n * Uses Anchor's BorshAccountsCoder to decode/encode accounts directly from\n * the generated IDL JSON files, eliminating all hardcoded byte offsets.\n */\n\nimport anchor, { type Idl } from \"@coral-xyz/anchor\";\n\nconst { BorshAccountsCoder, BN } = anchor;\nimport { PublicKey } from \"@solana/web3.js\";\nimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl } from \"@rng-utopia/anchor-client\";\n\n// ---------------------------------------------------------------------------\n// Coders (instantiated once at module load)\n// ---------------------------------------------------------------------------\n\nconst coinflipCoder = new BorshAccountsCoder(coinflipIdl as Idl);\nconst lordCoder = new BorshAccountsCoder(lordIdl as Idl);\n\n// ---------------------------------------------------------------------------\n// Type helpers\n// ---------------------------------------------------------------------------\n\nfunction bnToBigInt(bn: InstanceType<typeof BN>): bigint {\n  return BigInt(bn.toString());\n}\n\n/**\n * Anchor decodes Rust enums as { VariantName: {} }. Convert RoundPhase to\n * the numeric value used throughout the backend.\n */\nfunction roundPhaseToNumber(phase: Record<string, object>): number {\n  if (\"Waiting\" in phase) return 0;\n  if (\"Active\" in phase) return 1;\n  if (\"Locked\" in phase) return 2;\n  if (\"Resolving\" in phase) return 3;\n  if (\"Settled\" in phase) return 4;\n  if (\"Refunded\" in phase) return 5;\n  throw new Error(`Unknown RoundPhase variant: ${JSON.stringify(phase)}`);\n}\n\n// ---------------------------------------------------------------------------\n// Exported interfaces (camelCase, BigInt instead of BN)\n// ---------------------------------------------------------------------------\n\nexport interface DecodedCoinflipMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: number[];\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  resultHash: number[];\n  result: number;\n  winner: PublicKey;\n  createdAt: bigint;\n  matchId: number[];\n  bump: number;\n}\n\nexport interface DecodedCoinflipConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  paused: boolean;\n  bump: number;\n}\n\nexport interface DecodedJackpotRound {\n  matchId: number[];\n  server: PublicKey;\n  phase: number;\n  commitment: number[];\n  algorithmVer: number;\n  entries: Array<{ player: PublicKey; amountLamports: bigint }>;\n  totalAmountLamports: bigint;\n  distinctPlayers: number;\n  createdAt: bigint;\n  countdownStartedAt: bigint;\n  countdownEndsAt: bigint;\n  targetEntropySlot: bigint;\n  resolveDeadline: bigint;\n  resultHash: number[];\n  winningOffset: bigint;\n  winningEntryIndex: number;\n  winner: PublicKey;\n  creator: PublicKey;\n  bump: number;\n}\n\nexport interface DecodedLordConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  paused: boolean;\n  bump: number;\n}\n\n// ---------------------------------------------------------------------------\n// Decode functions\n// ---------------------------------------------------------------------------\n\n/* eslint-disable @typescript-eslint/no-explicit-any */\n\nexport function decodeCoinflipMatch(data: Buffer): DecodedCoinflipMatch {\n  const raw: any = coinflipCoder.decode(\"CoinflipMatch\", data);\n  return {\n    creator: raw.creator,\n    opponent: raw.opponent,\n    server: raw.server,\n    entryAmount: bnToBigInt(raw.entry_amount),\n    creatorSide: raw.creator_side,\n    phase: raw.phase,\n    commitment: raw.commitment,\n    algorithmVer: raw.algorithm_ver,\n    targetSlot: bnToBigInt(raw.target_slot),\n    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n    resultHash: raw.result_hash,\n    result: raw.result,\n    winner: raw.winner,\n    createdAt: bnToBigInt(raw.created_at),\n    matchId: raw.match_id,\n    bump: raw.bump,\n  };\n}\n\nexport function decodeCoinflipConfig(data: Buffer): DecodedCoinflipConfig {\n  const raw: any = coinflipCoder.decode(\"CoinflipConfig\", data);\n  return {\n    authority: raw.authority,\n    treasury: raw.treasury,\n    paused: raw.paused,\n    bump: raw.bump,\n  };\n}\n\nexport function decodeLordRound(data: Buffer): DecodedJackpotRound {\n  const raw: any = lordCoder.decode(\"JackpotRound\", data);\n  return {\n    matchId: raw.match_id,\n    server: raw.server,\n    phase: roundPhaseToNumber(raw.phase),\n    commitment: raw.commitment,\n    algorithmVer: raw.algorithm_ver,\n    entries: raw.entries.map((e: any) => ({\n      player: e.player,\n      amountLamports: bnToBigInt(e.amount_lamports),\n    })),\n    totalAmountLamports: bnToBigInt(raw.total_amount_lamports),\n    distinctPlayers: raw.distinct_players,\n    createdAt: bnToBigInt(raw.created_at),\n    countdownStartedAt: bnToBigInt(raw.countdown_started_at),\n    countdownEndsAt: bnToBigInt(raw.countdown_ends_at),\n    targetEntropySlot: bnToBigInt(raw.target_entropy_slot),\n    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n    resultHash: raw.result_hash,\n    winningOffset: bnToBigInt(raw.winning_offset),\n    winningEntryIndex: raw.winning_entry_index,\n    winner: raw.winner,\n    creator: raw.creator,\n    bump: raw.bump,\n  };\n}\n\nexport function decodeLordConfig(data: Buffer): DecodedLordConfig {\n  const raw: any = lordCoder.decode(\"LordConfig\", data);\n  return {\n    authority: raw.authority,\n    treasury: raw.treasury,\n    paused: raw.paused,\n    bump: raw.bump,\n  };\n}\n\n/* eslint-enable @typescript-eslint/no-explicit-any */\n\n// ---------------------------------------------------------------------------\n// Filter helpers for getProgramAccounts\n// ---------------------------------------------------------------------------\n\n/** CoinflipMatch account size (includes 8-byte discriminator). */\nexport function coinflipMatchSize(): number {\n  return coinflipCoder.size(\"CoinflipMatch\");\n}\n\n/** Discriminator-based memcmp filter for JackpotRound accounts. */\nexport function lordRoundDiscriminatorFilter(): {\n  memcmp: { offset: number; bytes: string };\n} {\n  return { memcmp: lordCoder.memcmp(\"JackpotRound\") };\n}\n\n// ---------------------------------------------------------------------------\n// Encode helpers (for integration tests)\n// ---------------------------------------------------------------------------\n\nexport async function encodeCoinflipMatch(\n  fields: DecodedCoinflipMatch,\n): Promise<Buffer> {\n  return coinflipCoder.encode(\"CoinflipMatch\", {\n    creator: fields.creator,\n    opponent: fields.opponent,\n    server: fields.server,\n    entry_amount: new BN(fields.entryAmount.toString()),\n    creator_side: fields.creatorSide,\n    phase: fields.phase,\n    commitment: fields.commitment,\n    algorithm_ver: fields.algorithmVer,\n    target_slot: new BN(fields.targetSlot.toString()),\n    resolve_deadline: new BN(fields.resolveDeadline.toString()),\n    result_hash: fields.resultHash,\n    result: fields.result,\n    winner: fields.winner,\n    created_at: new BN(fields.createdAt.toString()),\n    match_id: fields.matchId,\n    bump: fields.bump,\n  });\n}\n\nexport async function encodeCoinflipConfig(\n  fields: DecodedCoinflipConfig,\n): Promise<Buffer> {\n  return coinflipCoder.encode(\"CoinflipConfig\", {\n    authority: fields.authority,\n    treasury: fields.treasury,\n    paused: fields.paused,\n    bump: fields.bump,\n  });\n}\n","numLines":234,"startLine":1,"totalLines":234}}}
