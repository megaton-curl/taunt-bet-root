{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TFKMo9cSFw6hpyr24J6fPc","type":"tool_result","content":"     1→import {\n     2→  Connection,\n     3→  Keypair,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→  TransactionInstruction,\n     8→} from \"@solana/web3.js\";\n     9→import { deriveMatchPda } from \"./fairness.js\";\n    10→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl } from \"@rng-utopia/anchor-client\";\n    11→\n    12→export const COINFLIP_PROGRAM_ID = new PublicKey(coinflipIdl.address);\n    13→export const LORDOFRNGS_PROGRAM_ID = new PublicKey(lordIdl.address);\n    14→\n    15→function getInstructionDiscriminator(\n    16→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    17→  instructionName: string,\n    18→): Buffer {\n    19→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    20→  if (!instruction) {\n    21→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    22→  }\n    23→  return Buffer.from(instruction.discriminator);\n    24→}\n    25→\n    26→const CREATE_MATCH_DISCRIMINATOR = getInstructionDiscriminator(\n    27→  coinflipIdl,\n    28→  \"create_match\",\n    29→);\n    30→const CREATE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(\n    31→  lordIdl,\n    32→  \"create_round\",\n    33→);\n    34→\n    35→/** Derive the coinflip config PDA (seeds: [\"coinflip_config\"]). */\n    36→function deriveConfigPda(): [PublicKey, number] {\n    37→  return PublicKey.findProgramAddressSync(\n    38→    [Buffer.from(\"coinflip_config\")],\n    39→    COINFLIP_PROGRAM_ID,\n    40→  );\n    41→}\n    42→\n    43→function deriveLordConfigPda(): [PublicKey, number] {\n    44→  return PublicKey.findProgramAddressSync(\n    45→    [Buffer.from(\"lord_config\")],\n    46→    LORDOFRNGS_PROGRAM_ID,\n    47→  );\n    48→}\n    49→\n    50→export function deriveLordRoundPda(matchId: Buffer): [PublicKey, number] {\n    51→  return PublicKey.findProgramAddressSync(\n    52→    [Buffer.from(\"jackpot_round\"), matchId],\n    53→    LORDOFRNGS_PROGRAM_ID,\n    54→  );\n    55→}\n    56→\n    57→/**\n    58→ * Borsh-encode the create_match instruction data.\n    59→ * Layout: discriminator(8) + commitment(32) + amount(8, u64 LE) + side(1) + matchId(8) = 57 bytes\n    60→ */\n    61→function encodeCreateMatchData(\n    62→  commitment: Buffer,\n    63→  amountLamports: number,\n    64→  side: number,\n    65→  matchId: Buffer,\n    66→): Buffer {\n    67→  const amount = Buffer.alloc(8);\n    68→  amount.writeBigUInt64LE(BigInt(amountLamports));\n    69→  return Buffer.concat([\n    70→    CREATE_MATCH_DISCRIMINATOR,\n    71→    commitment,\n    72→    amount,\n    73→    Buffer.from([side]),\n    74→    matchId,\n    75→  ]);\n    76→}\n    77→\n    78→function encodeCreateRoundData(\n    79→  commitment: Buffer,\n    80→  amountLamports: number,\n    81→  matchId: Buffer,\n    82→): Buffer {\n    83→  const amount = Buffer.alloc(8);\n    84→  amount.writeBigUInt64LE(BigInt(amountLamports));\n    85→  return Buffer.concat([CREATE_ROUND_DISCRIMINATOR, commitment, amount, matchId]);\n    86→}\n    87→\n    88→export interface BuildCreateMatchTxParams {\n    89→  connection: Connection;\n    90→  creator: PublicKey;\n    91→  serverKeypair: Keypair;\n    92→  commitment: Buffer;\n    93→  amountLamports: number;\n    94→  side: number;\n    95→  matchId: Buffer;\n    96→}\n    97→\n    98→export interface BuildCreateMatchTxResult {\n    99→  /** Base64-serialized partially-signed transaction. */\n   100→  transaction: string;"}]},"parent_tool_use_id":"toolu_01D26TE5AfCUSgvbLk5tA4pE","session_id":"c7e08aab-e81c-466a-b6c2-35d333150199","uuid":"1cd32b9a-91bb-4188-9d9a-01483507f5b0"}
