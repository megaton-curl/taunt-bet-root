{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SzCtbL5AwLQXrXUEYgYaGA","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/account-decoder.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"c7e08aab-e81c-466a-b6c2-35d333150199","uuid":"08684521-f0b9-4d31-aac4-b2ba2323de1d","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/account-decoder.ts","oldString":"/** Discriminator-based memcmp filter for JackpotRound accounts. */\nexport function lordRoundDiscriminatorFilter(): {\n  memcmp: { offset: number; bytes: string };\n} {\n  return { memcmp: lordCoder.memcmp(\"JackpotRound\") };\n}","newString":"/** Discriminator-based memcmp filter for JackpotRound accounts. */\nexport function lordRoundDiscriminatorFilter(): {\n  memcmp: { offset: number; bytes: string };\n} {\n  return { memcmp: lordCoder.memcmp(\"JackpotRound\") };\n}\n\n/** Discriminator-based memcmp filter for CloseCallRound accounts. */\nexport function closeCallRoundDiscriminatorFilter(): {\n  memcmp: { offset: number; bytes: string };\n} {\n  return { memcmp: closecallCoder.memcmp(\"CloseCallRound\") };\n}","originalFile":"/**\n * IDL-driven account decoder — single source of truth for all Solana account\n * data access in the backend.\n *\n * Uses Anchor's BorshAccountsCoder to decode/encode accounts directly from\n * the generated IDL JSON files, eliminating all hardcoded byte offsets.\n */\n\nimport anchor, { type Idl } from \"@coral-xyz/anchor\";\n\nconst { BorshAccountsCoder, BN } = anchor;\nimport { PublicKey } from \"@solana/web3.js\";\nimport {\n  CoinflipIDL as coinflipIdl,\n  ClosecallIDL as closecallIdl,\n  LordofrngsIDL as lordIdl,\n} from \"@rng-utopia/anchor-client\";\n\n// ---------------------------------------------------------------------------\n// Coders (instantiated once at module load)\n// ---------------------------------------------------------------------------\n\nconst coinflipCoder = new BorshAccountsCoder(coinflipIdl as Idl);\nconst closecallCoder = new BorshAccountsCoder(closecallIdl as Idl);\nconst lordCoder = new BorshAccountsCoder(lordIdl as Idl);\n\n// ---------------------------------------------------------------------------\n// Type helpers\n// ---------------------------------------------------------------------------\n\nfunction bnToBigInt(bn: InstanceType<typeof BN>): bigint {\n  return BigInt(bn.toString());\n}\n\n/**\n * Anchor decodes Rust enums as { VariantName: {} }. Convert RoundPhase to\n * the numeric value used throughout the backend.\n */\nfunction roundPhaseToNumber(phase: Record<string, object>): number {\n  if (\"Waiting\" in phase) return 0;\n  if (\"Active\" in phase) return 1;\n  if (\"Locked\" in phase) return 2;\n  if (\"Resolving\" in phase) return 3;\n  if (\"Settled\" in phase) return 4;\n  if (\"Refunded\" in phase) return 5;\n  throw new Error(`Unknown RoundPhase variant: ${JSON.stringify(phase)}`);\n}\n\n/** CloseCallPhase enum: Open=0, Settled=1, Refunded=2 */\nfunction closeCallPhaseToNumber(phase: Record<string, object>): number {\n  if (\"Open\" in phase) return 0;\n  if (\"Settled\" in phase) return 1;\n  if (\"Refunded\" in phase) return 2;\n  throw new Error(`Unknown CloseCallPhase variant: ${JSON.stringify(phase)}`);\n}\n\n/** Outcome enum: Pending=0, Green=1, Red=2, Refund=3 */\nfunction outcomeToNumber(outcome: Record<string, object>): number {\n  if (\"Pending\" in outcome) return 0;\n  if (\"Green\" in outcome) return 1;\n  if (\"Red\" in outcome) return 2;\n  if (\"Refund\" in outcome) return 3;\n  throw new Error(`Unknown Outcome variant: ${JSON.stringify(outcome)}`);\n}\n\n// ---------------------------------------------------------------------------\n// Exported interfaces (camelCase, BigInt instead of BN)\n// ---------------------------------------------------------------------------\n\nexport interface DecodedCoinflipMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: number[];\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  resultHash: number[];\n  result: number;\n  winner: PublicKey;\n  createdAt: bigint;\n  matchId: number[];\n  bump: number;\n}\n\nexport interface DecodedCoinflipConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  paused: boolean;\n  bump: number;\n}\n\nexport interface DecodedJackpotRound {\n  matchId: number[];\n  server: PublicKey;\n  phase: number;\n  commitment: number[];\n  algorithmVer: number;\n  entries: Array<{ player: PublicKey; amountLamports: bigint }>;\n  totalAmountLamports: bigint;\n  distinctPlayers: number;\n  createdAt: bigint;\n  countdownStartedAt: bigint;\n  countdownEndsAt: bigint;\n  targetEntropySlot: bigint;\n  resolveDeadline: bigint;\n  resultHash: number[];\n  winningOffset: bigint;\n  winningEntryIndex: number;\n  winner: PublicKey;\n  creator: PublicKey;\n  bump: number;\n}\n\nexport interface DecodedLordConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  paused: boolean;\n  bump: number;\n}\n\nexport interface DecodedCloseCallRound {\n  roundId: number[];\n  server: PublicKey;\n  phase: number;\n  greenEntries: Array<{ player: PublicKey; amountLamports: bigint }>;\n  redEntries: Array<{ player: PublicKey; amountLamports: bigint }>;\n  greenPool: bigint;\n  redPool: bigint;\n  openPrice: bigint;\n  openPriceExpo: number;\n  closePrice: bigint;\n  createdAt: bigint;\n  bettingEndsAt: bigint;\n  resolveDeadline: bigint;\n  outcome: number;\n  totalFee: bigint;\n  bump: number;\n}\n\nexport interface DecodedCloseCallConfig {\n  authority: PublicKey;\n  treasury: PublicKey;\n  pythFeedId: number[];\n  bettingWindowSecs: number;\n  maxEntriesPerSide: number;\n  paused: boolean;\n  bump: number;\n}\n\n// ---------------------------------------------------------------------------\n// Decode functions\n// ---------------------------------------------------------------------------\n\n/* eslint-disable @typescript-eslint/no-explicit-any */\n\nexport function decodeCoinflipMatch(data: Buffer): DecodedCoinflipMatch {\n  const raw: any = coinflipCoder.decode(\"CoinflipMatch\", data);\n  return {\n    creator: raw.creator,\n    opponent: raw.opponent,\n    server: raw.server,\n    entryAmount: bnToBigInt(raw.entry_amount),\n    creatorSide: raw.creator_side,\n    phase: raw.phase,\n    commitment: raw.commitment,\n    algorithmVer: raw.algorithm_ver,\n    targetSlot: bnToBigInt(raw.target_slot),\n    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n    resultHash: raw.result_hash,\n    result: raw.result,\n    winner: raw.winner,\n    createdAt: bnToBigInt(raw.created_at),\n    matchId: raw.match_id,\n    bump: raw.bump,\n  };\n}\n\nexport function decodeCoinflipConfig(data: Buffer): DecodedCoinflipConfig {\n  const raw: any = coinflipCoder.decode(\"CoinflipConfig\", data);\n  return {\n    authority: raw.authority,\n    treasury: raw.treasury,\n    paused: raw.paused,\n    bump: raw.bump,\n  };\n}\n\nexport function decodeLordRound(data: Buffer): DecodedJackpotRound {\n  const raw: any = lordCoder.decode(\"JackpotRound\", data);\n  return {\n    matchId: raw.match_id,\n    server: raw.server,\n    phase: roundPhaseToNumber(raw.phase),\n    commitment: raw.commitment,\n    algorithmVer: raw.algorithm_ver,\n    entries: raw.entries.map((e: any) => ({\n      player: e.player,\n      amountLamports: bnToBigInt(e.amount_lamports),\n    })),\n    totalAmountLamports: bnToBigInt(raw.total_amount_lamports),\n    distinctPlayers: raw.distinct_players,\n    createdAt: bnToBigInt(raw.created_at),\n    countdownStartedAt: bnToBigInt(raw.countdown_started_at),\n    countdownEndsAt: bnToBigInt(raw.countdown_ends_at),\n    targetEntropySlot: bnToBigInt(raw.target_entropy_slot),\n    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n    resultHash: raw.result_hash,\n    winningOffset: bnToBigInt(raw.winning_offset),\n    winningEntryIndex: raw.winning_entry_index,\n    winner: raw.winner,\n    creator: raw.creator,\n    bump: raw.bump,\n  };\n}\n\nexport function decodeLordConfig(data: Buffer): DecodedLordConfig {\n  const raw: any = lordCoder.decode(\"LordConfig\", data);\n  return {\n    authority: raw.authority,\n    treasury: raw.treasury,\n    paused: raw.paused,\n    bump: raw.bump,\n  };\n}\n\nfunction decodeBetEntries(\n  entries: any[],\n): Array<{ player: PublicKey; amountLamports: bigint }> {\n  return entries.map((e: any) => ({\n    player: e.player,\n    amountLamports: bnToBigInt(e.amount_lamports),\n  }));\n}\n\nexport function decodeCloseCallRound(data: Buffer): DecodedCloseCallRound {\n  const raw: any = closecallCoder.decode(\"CloseCallRound\", data);\n  return {\n    roundId: raw.round_id,\n    server: raw.server,\n    phase: closeCallPhaseToNumber(raw.phase),\n    greenEntries: decodeBetEntries(raw.green_entries),\n    redEntries: decodeBetEntries(raw.red_entries),\n    greenPool: bnToBigInt(raw.green_pool),\n    redPool: bnToBigInt(raw.red_pool),\n    openPrice: bnToBigInt(raw.open_price),\n    openPriceExpo: raw.open_price_expo,\n    closePrice: bnToBigInt(raw.close_price),\n    createdAt: bnToBigInt(raw.created_at),\n    bettingEndsAt: bnToBigInt(raw.betting_ends_at),\n    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n    outcome: outcomeToNumber(raw.outcome),\n    totalFee: bnToBigInt(raw.total_fee),\n    bump: raw.bump,\n  };\n}\n\nexport function decodeCloseCallConfig(data: Buffer): DecodedCloseCallConfig {\n  const raw: any = closecallCoder.decode(\"CloseCallConfig\", data);\n  return {\n    authority: raw.authority,\n    treasury: raw.treasury,\n    pythFeedId: raw.pyth_feed_id,\n    bettingWindowSecs: raw.betting_window_secs,\n    maxEntriesPerSide: raw.max_entries_per_side,\n    paused: raw.paused,\n    bump: raw.bump,\n  };\n}\n\n/* eslint-enable @typescript-eslint/no-explicit-any */\n\n// ---------------------------------------------------------------------------\n// Filter helpers for getProgramAccounts\n// ---------------------------------------------------------------------------\n\n/** CoinflipMatch account size (includes 8-byte discriminator). */\nexport function coinflipMatchSize(): number {\n  return coinflipCoder.size(\"CoinflipMatch\");\n}\n\n/** Discriminator-based memcmp filter for JackpotRound accounts. */\nexport function lordRoundDiscriminatorFilter(): {\n  memcmp: { offset: number; bytes: string };\n} {\n  return { memcmp: lordCoder.memcmp(\"JackpotRound\") };\n}\n\n// ---------------------------------------------------------------------------\n// Encode helpers (for integration tests)\n// ---------------------------------------------------------------------------\n\nexport async function encodeCoinflipMatch(\n  fields: DecodedCoinflipMatch,\n): Promise<Buffer> {\n  return coinflipCoder.encode(\"CoinflipMatch\", {\n    creator: fields.creator,\n    opponent: fields.opponent,\n    server: fields.server,\n    entry_amount: new BN(fields.entryAmount.toString()),\n    creator_side: fields.creatorSide,\n    phase: fields.phase,\n    commitment: fields.commitment,\n    algorithm_ver: fields.algorithmVer,\n    target_slot: new BN(fields.targetSlot.toString()),\n    resolve_deadline: new BN(fields.resolveDeadline.toString()),\n    result_hash: fields.resultHash,\n    result: fields.result,\n    winner: fields.winner,\n    created_at: new BN(fields.createdAt.toString()),\n    match_id: fields.matchId,\n    bump: fields.bump,\n  });\n}\n\nexport async function encodeCoinflipConfig(\n  fields: DecodedCoinflipConfig,\n): Promise<Buffer> {\n  return coinflipCoder.encode(\"CoinflipConfig\", {\n    authority: fields.authority,\n    treasury: fields.treasury,\n    paused: fields.paused,\n    bump: fields.bump,\n  });\n}\n","structuredPatch":[{"oldStart":289,"oldLines":6,"newStart":289,"newLines":13,"lines":["   return { memcmp: lordCoder.memcmp(\"JackpotRound\") };"," }"," ","+/** Discriminator-based memcmp filter for CloseCallRound accounts. */","+export function closeCallRoundDiscriminatorFilter(): {","+  memcmp: { offset: number; bytes: string };","+} {","+  return { memcmp: closecallCoder.memcmp(\"CloseCallRound\") };","+}","+"," // ---------------------------------------------------------------------------"," // Encode helpers (for integration tests)"," // ---------------------------------------------------------------------------"]}],"userModified":false,"replaceAll":false}}
