{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UGS9C1mFERCwY84vWfcrua","type":"tool_result","content":"     1→/**\n     2→ * IDL-driven account decoder — single source of truth for all Solana account\n     3→ * data access in the backend.\n     4→ *\n     5→ * Uses Anchor's BorshAccountsCoder to decode/encode accounts directly from\n     6→ * the generated IDL JSON files, eliminating all hardcoded byte offsets.\n     7→ */\n     8→\n     9→import anchor, { type Idl } from \"@coral-xyz/anchor\";\n    10→\n    11→const { BorshAccountsCoder, BN } = anchor;\n    12→import { PublicKey } from \"@solana/web3.js\";\n    13→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl } from \"@rng-utopia/anchor-client\";\n    14→\n    15→// ---------------------------------------------------------------------------\n    16→// Coders (instantiated once at module load)\n    17→// ---------------------------------------------------------------------------\n    18→\n    19→const coinflipCoder = new BorshAccountsCoder(coinflipIdl as Idl);\n    20→const lordCoder = new BorshAccountsCoder(lordIdl as Idl);\n    21→\n    22→// ---------------------------------------------------------------------------\n    23→// Type helpers\n    24→// ---------------------------------------------------------------------------\n    25→\n    26→function bnToBigInt(bn: InstanceType<typeof BN>): bigint {\n    27→  return BigInt(bn.toString());\n    28→}\n    29→\n    30→/**\n    31→ * Anchor decodes Rust enums as { VariantName: {} }. Convert RoundPhase to\n    32→ * the numeric value used throughout the backend.\n    33→ */\n    34→function roundPhaseToNumber(phase: Record<string, object>): number {\n    35→  if (\"Waiting\" in phase) return 0;\n    36→  if (\"Active\" in phase) return 1;\n    37→  if (\"Locked\" in phase) return 2;\n    38→  if (\"Resolving\" in phase) return 3;\n    39→  if (\"Settled\" in phase) return 4;\n    40→  if (\"Refunded\" in phase) return 5;\n    41→  throw new Error(`Unknown RoundPhase variant: ${JSON.stringify(phase)}`);\n    42→}\n    43→\n    44→// ---------------------------------------------------------------------------\n    45→// Exported interfaces (camelCase, BigInt instead of BN)\n    46→// ---------------------------------------------------------------------------\n    47→\n    48→export interface DecodedCoinflipMatch {\n    49→  creator: PublicKey;\n    50→  opponent: PublicKey;\n    51→  server: PublicKey;\n    52→  entryAmount: bigint;\n    53→  creatorSide: number;\n    54→  phase: number;\n    55→  commitment: number[];\n    56→  algorithmVer: number;\n    57→  targetSlot: bigint;\n    58→  resolveDeadline: bigint;\n    59→  resultHash: number[];\n    60→  result: number;\n    61→  winner: PublicKey;\n    62→  createdAt: bigint;\n    63→  matchId: number[];\n    64→  bump: number;\n    65→}\n    66→\n    67→export interface DecodedCoinflipConfig {\n    68→  authority: PublicKey;\n    69→  treasury: PublicKey;\n    70→  paused: boolean;\n    71→  bump: number;\n    72→}\n    73→\n    74→export interface DecodedJackpotRound {\n    75→  matchId: number[];\n    76→  server: PublicKey;\n    77→  phase: number;\n    78→  commitment: number[];\n    79→  algorithmVer: number;\n    80→  entries: Array<{ player: PublicKey; amountLamports: bigint }>;\n    81→  totalAmountLamports: bigint;\n    82→  distinctPlayers: number;\n    83→  createdAt: bigint;\n    84→  countdownStartedAt: bigint;\n    85→  countdownEndsAt: bigint;\n    86→  targetEntropySlot: bigint;\n    87→  resolveDeadline: bigint;\n    88→  resultHash: number[];\n    89→  winningOffset: bigint;\n    90→  winningEntryIndex: number;\n    91→  winner: PublicKey;\n    92→  creator: PublicKey;\n    93→  bump: number;\n    94→}\n    95→\n    96→export interface DecodedLordConfig {\n    97→  authority: PublicKey;\n    98→  treasury: PublicKey;\n    99→  paused: boolean;\n   100→  bump: number;\n   101→}\n   102→\n   103→// ---------------------------------------------------------------------------\n   104→// Decode functions\n   105→// ---------------------------------------------------------------------------\n   106→\n   107→/* eslint-disable @typescript-eslint/no-explicit-any */\n   108→\n   109→export function decodeCoinflipMatch(data: Buffer): DecodedCoinflipMatch {\n   110→  const raw: any = coinflipCoder.decode(\"CoinflipMatch\", data);\n   111→  return {\n   112→    creator: raw.creator,\n   113→    opponent: raw.opponent,\n   114→    server: raw.server,\n   115→    entryAmount: bnToBigInt(raw.entry_amount),\n   116→    creatorSide: raw.creator_side,\n   117→    phase: raw.phase,\n   118→    commitment: raw.commitment,\n   119→    algorithmVer: raw.algorithm_ver,\n   120→    targetSlot: bnToBigInt(raw.target_slot),\n   121→    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n   122→    resultHash: raw.result_hash,\n   123→    result: raw.result,\n   124→    winner: raw.winner,\n   125→    createdAt: bnToBigInt(raw.created_at),\n   126→    matchId: raw.match_id,\n   127→    bump: raw.bump,\n   128→  };\n   129→}\n   130→\n   131→export function decodeCoinflipConfig(data: Buffer): DecodedCoinflipConfig {\n   132→  const raw: any = coinflipCoder.decode(\"CoinflipConfig\", data);\n   133→  return {\n   134→    authority: raw.authority,\n   135→    treasury: raw.treasury,\n   136→    paused: raw.paused,\n   137→    bump: raw.bump,\n   138→  };\n   139→}\n   140→\n   141→export function decodeLordRound(data: Buffer): DecodedJackpotRound {\n   142→  const raw: any = lordCoder.decode(\"JackpotRound\", data);\n   143→  return {\n   144→    matchId: raw.match_id,\n   145→    server: raw.server,\n   146→    phase: roundPhaseToNumber(raw.phase),\n   147→    commitment: raw.commitment,\n   148→    algorithmVer: raw.algorithm_ver,\n   149→    entries: raw.entries.map((e: any) => ({\n   150→      player: e.player,\n   151→      amountLamports: bnToBigInt(e.amount_lamports),\n   152→    })),\n   153→    totalAmountLamports: bnToBigInt(raw.total_amount_lamports),\n   154→    distinctPlayers: raw.distinct_players,\n   155→    createdAt: bnToBigInt(raw.created_at),\n   156→    countdownStartedAt: bnToBigInt(raw.countdown_started_at),\n   157→    countdownEndsAt: bnToBigInt(raw.countdown_ends_at),\n   158→    targetEntropySlot: bnToBigInt(raw.target_entropy_slot),\n   159→    resolveDeadline: bnToBigInt(raw.resolve_deadline),\n   160→    resultHash: raw.result_hash,\n   161→    winningOffset: bnToBigInt(raw.winning_offset),\n   162→    winningEntryIndex: raw.winning_entry_index,\n   163→    winner: raw.winner,\n   164→    creator: raw.creator,\n   165→    bump: raw.bump,\n   166→  };\n   167→}\n   168→\n   169→export function decodeLordConfig(data: Buffer): DecodedLordConfig {\n   170→  const raw: any = lordCoder.decode(\"LordConfig\", data);\n   171→  return {\n   172→    authority: raw.authority,\n   173→    treasury: raw.treasury,\n   174→    paused: raw.paused,\n   175→    bump: raw.bump,\n   176→  };\n   177→}\n   178→\n   179→/* eslint-enable @typescript-eslint/no-explicit-any */\n   180→\n   181→// ---------------------------------------------------------------------------\n   182→// Filter helpers for getProgramAccounts\n   183→// ---------------------------------------------------------------------------\n   184→\n   185→/** CoinflipMatch account size (includes 8-byte discriminator). */\n   186→export function coinflipMatchSize(): number {\n   187→  return coinflipCoder.size(\"CoinflipMatch\");\n   188→}\n   189→\n   190→/** Discriminator-based memcmp filter for JackpotRound accounts. */\n   191→export function lordRoundDiscriminatorFilter(): {\n   192→  memcmp: { offset: number; bytes: string };\n   193→} {\n   194→  return { memcmp: lordCoder.memcmp(\"JackpotRound\") };\n   195→}\n   196→\n   197→// ---------------------------------------------------------------------------\n   198→// Encode helpers (for integration tests)\n   199→// ---------------------------------------------------------------------------\n   200→\n   201→export async function encodeCoinflipMatch(\n   202→  fields: DecodedCoinflipMatch,\n   203→): Promise<Buffer> {\n   204→  return coinflipCoder.encode(\"CoinflipMatch\", {\n   205→    creator: fields.creator,\n   206→    opponent: fields.opponent,\n   207→    server: fields.server,\n   208→    entry_amount: new BN(fields.entryAmount.toString()),\n   209→    creator_side: fields.creatorSide,\n   210→    phase: fields.phase,\n   211→    commitment: fields.commitment,\n   212→    algorithm_ver: fields.algorithmVer,\n   213→    target_slot: new BN(fields.targetSlot.toString()),\n   214→    resolve_deadline: new BN(fields.resolveDeadline.toString()),\n   215→    result_hash: fields.resultHash,\n   216→    result: fields.result,\n   217→    winner: fields.winner,\n   218→    created_at: new BN(fields.createdAt.toString()),\n   219→    match_id: fields.matchId,\n   220→    bump: fields.bump,\n   221→  });\n   222→}\n   223→\n   224→export async function encodeCoinflipConfig(\n   225→  fields: DecodedCoinflipConfig,\n   226→): Promise<Buffer> {\n   227→  return coinflipCoder.encode(\"CoinflipConfig\", {\n   228→    authority: fields.authority,\n   229→    treasury: fields.treasury,\n   230→    paused: fields.paused,\n   231→    bump: fields.bump,\n   232→  });\n   233→}\n   234→"}]},"parent_tool_use_id":"toolu_01D26TE5AfCUSgvbLk5tA4pE","session_id":"c7e08aab-e81c-466a-b6c2-35d333150199","uuid":"101874cb-3705-4e38-9a38-cc89ef31de68"}
