{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xo5a61VXcYVgJnVxwaoirQ","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl } from \"@rng-utopia/anchor-client\";\n    23→import {\n    24→  decodeCoinflipMatch,\n    25→  decodeCoinflipConfig,\n    26→  decodeLordRound,\n    27→  decodeLordConfig,\n    28→  type DecodedJackpotRound,\n    29→} from \"./account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→function getInstructionDiscriminator(\n    36→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    37→  instructionName: string,\n    38→): Buffer {\n    39→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    40→  if (!instruction) {\n    41→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    42→  }\n    43→  return Buffer.from(instruction.discriminator);\n    44→}\n    45→\n    46→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    47→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    48→  lordIdl,\n    49→  \"claim_payout\",\n    50→);\n    51→\n    52→// ---------------------------------------------------------------------------\n    53→// Types\n    54→// ---------------------------------------------------------------------------\n    55→\n    56→export interface SettleTxDeps {\n    57→  db: Db;\n    58→  connection: Connection;\n    59→  serverKeypair: Keypair;\n    60→  entropyAccount: PublicKey;\n    61→}\n    62→\n    63→export interface SettleResult {\n    64→  txSignature: string;\n    65→  resultHash: Buffer;\n    66→  resultSide?: number;\n    67→  winningEntryIndex?: number;\n    68→  winner: string;\n    69→}\n    70→\n    71→// ---------------------------------------------------------------------------\n    72→// PDA helpers\n    73→// ---------------------------------------------------------------------------\n    74→\n    75→function deriveConfigPda(): [PublicKey, number] {\n    76→  return PublicKey.findProgramAddressSync(\n    77→    [Buffer.from(\"coinflip_config\")],\n    78→    COINFLIP_PROGRAM_ID,\n    79→  );\n    80→}\n    81→\n    82→function deriveLordConfigPda(): [PublicKey, number] {\n    83→  return PublicKey.findProgramAddressSync(\n    84→    [Buffer.from(\"lord_config\")],\n    85→    LORDOFRNGS_PROGRAM_ID,\n    86→  );\n    87→}\n    88→\n    89→// ---------------------------------------------------------------------------\n    90→// Instruction encoding\n    91→// ---------------------------------------------------------------------------\n    92→\n    93→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    94→function encodeSettleData(secret: Buffer): Buffer {\n    95→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    96→}\n    97→\n    98→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n    99→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n   100→}\n   101→\n   102→// ---------------------------------------------------------------------------\n   103→// Result derivation (mirrors on-chain derive_result)\n   104→// ---------------------------------------------------------------------------\n   105→\n   106→/**\n   107→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n   108→ * Must match shared/src/fairness.rs `derive_result()`.\n   109→ */\n   110→function deriveResult(\n   111→  secret: Buffer,\n   112→  entropy: Buffer,\n   113→  matchPdaBytes: Buffer,\n   114→  algoVer: number,\n   115→): Buffer {\n   116→  return createHash(\"sha256\")\n   117→    .update(secret)\n   118→    .update(entropy)\n   119→    .update(matchPdaBytes)\n   120→    .update(Buffer.from([algoVer]))\n   121→    .digest();\n   122→}\n   123→\n   124→// ---------------------------------------------------------------------------\n   125→// Core settle function\n   126→// ---------------------------------------------------------------------------\n   127→\n   128→/**\n   129→ * Build, submit, and confirm a settle transaction for a locked match.\n   130→ *\n   131→ * Steps:\n   132→ * 1. Retrieve secret from DB\n   133→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   134→ * 3. Fetch config account data (treasury)\n   135→ * 4. Read entropy from the entropy account\n   136→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   137→ * 6. Build + submit settle tx\n   138→ * 7. Update DB on confirmation\n   139→ */\n   140→export async function settleMatch(\n   141→  deps: SettleTxDeps,\n   142→  pda: string,\n   143→): Promise<SettleResult> {\n   144→  const t0 = performance.now();\n   145→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   146→  const matchPubkey = new PublicKey(pda);\n   147→\n   148→  // 1. Retrieve secret from DB\n   149→  const round = await db.getRoundByPda(pda);\n   150→  const tDb = performance.now();\n   151→  if (!round) {\n   152→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   153→  }\n   154→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   155→    throw new PermanentSettleError(\n   156→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   157→    );\n   158→  }\n   159→\n   160→  const secret = Buffer.from(round.secret);\n   161→\n   162→  // Transition to settling (locked → settling)\n   163→  if (round.phase === \"locked\") {\n   164→    await db.updateRoundPhase(pda, \"settling\");\n   165→  }\n   166→\n   167→  // Log settle_submitted\n   168→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   169→    attempt: round.settle_attempts + 1,\n   170→  });\n   171→\n   172→  // 2-4. Fetch match, config, entropy, and blockhash in parallel\n   173→  const [configPda] = deriveConfigPda();\n   174→  const [matchAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   175→    await Promise.all([\n   176→      connection.getAccountInfo(matchPubkey),\n   177→      connection.getAccountInfo(configPda),\n   178→      connection.getAccountInfo(entropyAccount),\n   179→      connection.getLatestBlockhash(),\n   180→    ]);\n   181→  const tFetch = performance.now();\n   182→\n   183→  if (!matchAccountInfo) {\n   184→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   185→  }\n   186→  if (!configAccountInfo) {\n   187→    throw new PermanentSettleError(\"Coinflip config account not found\");\n   188→  }\n   189→  if (!entropyInfo) {\n   190→    throw new TransientSettleError(\"Entropy account not available yet\");\n   191→  }\n   192→\n   193→  // IDL-driven decode — no manual byte offsets\n   194→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   195→  const config = decodeCoinflipConfig(Buffer.from(configAccountInfo.data));\n   196→\n   197→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   198→  const { treasury } = config;\n   199→\n   200→  const pool = entryAmount * 2n;\n   201→  const feeAmount = Number((pool * 300n) / 10_000n);\n   202→  const payoutAmount = Number(pool) - feeAmount;\n   203→\n   204→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   205→\n   206→  // 5. Pre-compute result\n   207→  const matchPdaBytes = matchPubkey.toBuffer();\n   208→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   209→  const resultSide = resultHash[0]! % 2;\n   210→  const winner = resultSide === creatorSide ? creator : opponent;\n   211→\n   212→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   213→  const data = encodeSettleData(secret);\n   214→\n   215→  const instruction = new TransactionInstruction({\n   216→    keys: [\n   217→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   218→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   219→      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n   220→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   221→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   222→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   223→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   224→      {\n   225→        pubkey: SystemProgram.programId,\n   226→        isSigner: false,\n   227→        isWritable: false,\n   228→      }, // system_program\n   229→    ],\n   230→    programId: COINFLIP_PROGRAM_ID,\n   231→    data,\n   232→  });\n   233→\n   234→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   235→\n   236→  const tx = new Transaction({\n   237→    feePayer: serverKeypair.publicKey,\n   238→    blockhash,\n   239→    lastValidBlockHeight,\n   240→  });\n   241→  tx.add(instruction);\n   242→  tx.sign(serverKeypair);\n   243→\n   244→  // 7. Submit and confirm\n   245→  const rawTx = tx.serialize();\n   246→  const tBuild = performance.now();\n   247→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   248→    skipPreflight: false,\n   249→  });\n   250→  const tSend = performance.now();\n   251→\n   252→  logger.info(\"settlement transaction submitted\", {\n   253→    pda,\n   254→    txSignature,\n   255→    attempt: round.settle_attempts + 1,\n   256→    dbMs: Math.round(tDb - t0),\n   257→    fetchMs: Math.round(tFetch - tDb),\n   258→    buildMs: Math.round(tBuild - tFetch),\n   259→    sendMs: Math.round(tSend - tBuild),\n   260→  });\n   261→\n   262→  const confirmation = await connection.confirmTransaction(\n   263→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   264→    \"confirmed\",\n   265→  );\n   266→  const tConfirm = performance.now();\n   267→  if (confirmation.value.err) {\n   268→    throw new TransientSettleError(\n   269→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   270→    );\n   271→  }\n   272→\n   273→  // 8. Update DB — phase settling → settled\n   274→  await db.updateRoundPhase(pda, \"settled\", {\n   275→    settle_tx: txSignature,\n   276→    result_hash: resultHash,\n   277→    result_side: resultSide,\n   278→    winner: winner.toBase58(),\n   279→    settle_attempts: round.settle_attempts + 1,\n   280→  });\n   281→\n   282→  // Log settle_confirmed\n   283→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   284→    txSignature,\n   285→    resultSide,\n   286→    winner: winner.toBase58(),\n   287→    entropy: entropy.toString(\"hex\"),\n   288→    payoutAmount,\n   289→    feeAmount,\n   290→  });\n   291→\n   292→  const tDone = performance.now();\n   293→  logger.info(\"settlement transaction confirmed\", {\n   294→    pda,\n   295→    txSignature,\n   296→    resultSide,\n   297→    winner: winner.toBase58(),\n   298→    timing: {\n   299→      dbMs: Math.round(tDb - t0),\n   300→      fetchMs: Math.round(tFetch - tDb),\n   301→      buildMs: Math.round(tBuild - tFetch),\n   302→      sendMs: Math.round(tSend - tBuild),\n   303→      confirmMs: Math.round(tConfirm - tSend),\n   304→      dbWriteMs: Math.round(tDone - tConfirm),\n   305→      totalMs: Math.round(tDone - t0),\n   306→    },\n   307→  });\n   308→\n   309→  return {\n   310→    txSignature,\n   311→    resultHash,\n   312→    resultSide,\n   313→    winner: winner.toBase58(),\n   314→  };\n   315→}\n   316→\n   317→export async function settleLordRound(\n   318→  deps: SettleTxDeps,\n   319→  pda: string,\n   320→): Promise<SettleResult> {\n   321→  const t0 = performance.now();\n   322→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   323→  const roundPubkey = new PublicKey(pda);\n   324→\n   325→  const round = await db.getRoundByPda(pda);\n   326→  const tDb = performance.now();\n   327→  if (!round) {\n   328→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   329→  }\n   330→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   331→    throw new PermanentSettleError(\n   332→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   333→    );\n   334→  }\n   335→\n   336→  const secret = Buffer.from(round.secret);\n   337→\n   338→  if (round.phase === \"locked\") {\n   339→    await db.updateRoundPhase(pda, \"settling\");\n   340→  }\n   341→\n   342→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   343→    attempt: round.settle_attempts + 1,\n   344→    game: \"lord\",\n   345→  });\n   346→\n   347→  const [configPda] = deriveLordConfigPda();\n   348→  const [roundAccountInfo, configAccountInfo, entropyInfo, latestBlockhash] =\n   349→    await Promise.all([\n   350→      connection.getAccountInfo(roundPubkey),\n   351→      connection.getAccountInfo(configPda),\n   352→      connection.getAccountInfo(entropyAccount),\n   353→      connection.getLatestBlockhash(),\n   354→    ]);\n   355→\n   356→  const tFetch = performance.now();\n   357→\n   358→  if (!roundAccountInfo) {\n   359→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   360→  }\n   361→  if (!configAccountInfo) {\n   362→    throw new PermanentSettleError(\"Lord config account not found\");\n   363→  }\n   364→  if (!entropyInfo) {\n   365→    throw new TransientSettleError(\"Entropy account not available yet\");\n   366→  }\n   367→\n   368→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   369→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   370→  const lordConfig = decodeLordConfig(Buffer.from(configAccountInfo.data));\n   371→  const { treasury } = lordConfig;\n   372→\n   373→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   374→  const resultHash = deriveResult(\n   375→    secret,\n   376→    entropy,\n   377→    roundPubkey.toBuffer(),\n   378→    roundData.algorithmVer,\n   379→  );\n   380→  const feeAmount = Number((roundData.totalAmountLamports * 300n) / 10_000n);\n   381→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   382→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   383→\n   384→  const raw = resultHash.readBigUInt64LE(0);\n   385→  const winningOffset = raw % roundData.totalAmountLamports;\n   386→\n   387→  let cumulative = 0n;\n   388→  let winnerEntryIndex = -1;\n   389→  let winner = roundData.entries[0]?.player;\n   390→  for (const [index, entry] of roundData.entries.entries()) {\n   391→    cumulative += entry.amountLamports;\n   392→    if (winningOffset < cumulative) {\n   393→      winnerEntryIndex = index;\n   394→      winner = entry.player;\n   395→      break;\n   396→    }\n   397→  }\n   398→\n   399→  if (!winner || winnerEntryIndex < 0) {\n   400→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   401→  }\n   402→\n   403→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   404→  const instruction = new TransactionInstruction({\n   405→    keys: [\n   406→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   407→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   408→      { pubkey: configPda, isSigner: false, isWritable: false },\n   409→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   410→      { pubkey: treasury, isSigner: false, isWritable: true },\n   411→      { pubkey: winner, isSigner: false, isWritable: true },\n   412→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   413→    ],\n   414→    programId: LORDOFRNGS_PROGRAM_ID,\n   415→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   416→  });\n   417→\n   418→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   419→  const tx = new Transaction({\n   420→    feePayer: serverKeypair.publicKey,\n   421→    blockhash,\n   422→    lastValidBlockHeight,\n   423→  });\n   424→  tx.add(instruction);\n   425→  tx.sign(serverKeypair);\n   426→\n   427→  const tBuild = performance.now();\n   428→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   429→    skipPreflight: false,\n   430→  });\n   431→  const tSend = performance.now();\n   432→\n   433→  logger.info(\"lord settlement transaction submitted\", {\n   434→    pda,\n   435→    txSignature,\n   436→    attempt: round.settle_attempts + 1,\n   437→    winningEntryIndex: winnerEntryIndex,\n   438→    dbMs: Math.round(tDb - t0),\n   439→    fetchMs: Math.round(tFetch - tDb),\n   440→    buildMs: Math.round(tBuild - tFetch),\n   441→    sendMs: Math.round(tSend - tBuild),\n   442→  });\n   443→\n   444→  const confirmation = await connection.confirmTransaction(\n   445→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   446→    \"confirmed\",\n   447→  );\n   448→  const tConfirm = performance.now();\n   449→  if (confirmation.value.err) {\n   450→    throw new TransientSettleError(\n   451→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   452→    );\n   453→  }\n   454→\n   455→  await db.updateRoundPhase(pda, \"settled\", {\n   456→    settle_tx: txSignature,\n   457→    result_hash: resultHash,\n   458→    result_side: winnerEntryIndex,\n   459→    winner: winner.toBase58(),\n   460→    settle_attempts: round.settle_attempts + 1,\n   461→  });\n   462→\n   463→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   464→    txSignature,\n   465→    winner: winner.toBase58(),\n   466→    winningEntryIndex: winnerEntryIndex,\n   467→    game: \"lord\",\n   468→    entropy: entropy.toString(\"hex\"),\n   469→    winningOffset: winningOffset.toString(),\n   470→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   471→    payoutAmount,\n   472→    feeAmount,\n   473→    rentRefund,\n   474→  });\n   475→\n   476→  const tDone = performance.now();\n   477→  logger.info(\"lord settlement transaction confirmed\", {\n   478→    pda,\n   479→    txSignature,\n   480→    winner: winner.toBase58(),\n   481→    winningEntryIndex: winnerEntryIndex,\n   482→    timing: {\n   483→      dbMs: Math.round(tDb - t0),\n   484→      fetchMs: Math.round(tFetch - tDb),\n   485→      buildMs: Math.round(tBuild - tFetch),\n   486→      sendMs: Math.round(tSend - tBuild),\n   487→      confirmMs: Math.round(tConfirm - tSend),\n   488→      dbWriteMs: Math.round(tDone - tConfirm),\n   489→      totalMs: Math.round(tDone - t0),\n   490→    },\n   491→  });\n   492→\n   493→  return {\n   494→    txSignature,\n   495→    resultHash,\n   496→    winningEntryIndex: winnerEntryIndex,\n   497→    winner: winner.toBase58(),\n   498→  };\n   499→}\n   500→\n   501→export async function settleRound(\n   502→  deps: SettleTxDeps,\n   503→  pda: string,\n   504→): Promise<SettleResult> {\n   505→  const round = await deps.db.getRoundByPda(pda);\n   506→  if (!round) {\n   507→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   508→  }\n   509→\n   510→  if (round.game === \"lord\") {\n   511→    return settleLordRound(deps, pda);\n   512→  }\n   513→\n   514→  return settleMatch(deps, pda);\n   515→}\n   516→\n   517→// ---------------------------------------------------------------------------\n   518→// Error types\n   519→// ---------------------------------------------------------------------------\n   520→\n   521→/** Permanent failure — should not be retried. */\n   522→export class PermanentSettleError extends Error {\n   523→  readonly permanent = true;\n   524→  constructor(message: string) {\n   525→    super(message);\n   526→    this.name = \"PermanentSettleError\";\n   527→  }\n   528→}\n   529→\n   530→/** Transient failure — safe to retry. */\n   531→export class TransientSettleError extends Error {\n   532→  readonly permanent = false;\n   533→  constructor(message: string) {\n   534→    super(message);\n   535→    this.name = \"TransientSettleError\";\n   536→  }\n   537→}\n   538→"}]},"parent_tool_use_id":"toolu_01D26TE5AfCUSgvbLk5tA4pE","session_id":"c7e08aab-e81c-466a-b6c2-35d333150199","uuid":"78ca6a82-570b-40fd-a7e4-5e64f6915842"}
