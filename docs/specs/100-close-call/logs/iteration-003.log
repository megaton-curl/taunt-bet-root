{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012hBCxwzXUeG1E36FFCdQH4","type":"tool_result","content":"     1→/**\n     2→ * PDA watcher — subscribes to match/round PDAs via WebSocket to detect\n     3→ * phase changes (join, countdown start) instantly instead of waiting for\n     4→ * the next getProgramAccounts poll cycle.\n     5→ *\n     6→ * This dramatically reduces settlement latency: from ~13s (stale poll) to\n     7→ * ~1-3s (WebSocket delivery + settlement).\n     8→ *\n     9→ * The poll-based settlement worker remains as a fallback for server\n    10→ * restarts, missed subscriptions, and edge cases.\n    11→ */\n    12→\n    13→import { Connection, PublicKey } from \"@solana/web3.js\";\n    14→import { logger } from \"../logger.js\";\n    15→import {\n    16→  coinflipMatchSize,\n    17→  decodeCoinflipMatch,\n    18→  decodeLordRound,\n    19→} from \"./account-decoder.js\";\n    20→\n    21→// ---------------------------------------------------------------------------\n    22→// Types\n    23→// ---------------------------------------------------------------------------\n    24→\n    25→export interface PdaWatcherDeps {\n    26→  connection: Connection;\n    27→  serverKey: PublicKey;\n    28→  onJoinDetected: (pda: string, targetSlot: bigint) => Promise<void>;\n    29→}\n    30→\n    31→export interface PdaWatcher {\n    32→  /** Register a PDA for watching. Called after match/round creation. */\n    33→  watch(pda: string): void;\n    34→  /** Stop watching a PDA. Called after settlement or cleanup. */\n    35→  unwatch(pda: string): void;\n    36→  /** Stop all subscriptions. */\n    37→  stopAll(): void;\n    38→  /** Number of active subscriptions (for health/debugging). */\n    39→  readonly size: number;\n    40→}\n    41→\n    42→// ---------------------------------------------------------------------------\n    43→// Constants\n    44→// ---------------------------------------------------------------------------\n    45→\n    46→const COINFLIP_MATCH_SIZE = coinflipMatchSize();\n    47→const PHASE_LOCKED = 1;\n    48→const LORD_PHASE_ACTIVE = 1;\n    49→\n    50→// ---------------------------------------------------------------------------\n    51→// Factory\n    52→// ---------------------------------------------------------------------------\n    53→\n    54→export function createPdaWatcher(deps: PdaWatcherDeps): PdaWatcher {\n    55→  const { connection, serverKey, onJoinDetected } = deps;\n    56→\n    57→  /** Map from PDA base58 → WebSocket subscription ID. */\n    58→  const subscriptions = new Map<string, number>();\n    59→\n    60→  function watch(pda: string): void {\n    61→    if (subscriptions.has(pda)) return; // already watching\n    62→\n    63→    const pubkey = new PublicKey(pda);\n    64→\n    65→    const subId = connection.onAccountChange(\n    66→      pubkey,\n    67→      async (accountInfo) => {\n    68→        try {\n    69→          // Account closed (settled or cancelled) — just unwatch\n    70→          if (accountInfo.lamports === 0) {\n    71→            logger.debug(\"[pda-watcher] account closed, unwatching\", {\n    72→              pda: pda.slice(0, 12),\n    73→            });\n    74→            unwatch(pda);\n    75→            return;\n    76→          }\n    77→\n    78→          const data = Buffer.from(accountInfo.data);\n    79→\n    80→          // Determine game type by account size\n    81→          if (data.length === COINFLIP_MATCH_SIZE) {\n    82→            handleCoinflipChange(pda, data);\n    83→          } else {\n    84→            // Try lord decode — variable-size accounts\n    85→            handleLordChange(pda, data);\n    86→          }\n    87→        } catch (err) {\n    88→          logger.warn(\"[pda-watcher] callback error\", {\n    89→            pda: pda.slice(0, 12),\n    90→            error: err instanceof Error ? err.message : String(err),\n    91→          });\n    92→        }\n    93→      },\n    94→      \"confirmed\",\n    95→    );\n    96→\n    97→    subscriptions.set(pda, subId);\n    98→    logger.debug(\"[pda-watcher] watching\", { pda: pda.slice(0, 12) });\n    99→  }\n   100→\n   101→  function handleCoinflipChange(pda: string, data: Buffer): void {\n   102→    let match;\n   103→    try {\n   104→      match = decodeCoinflipMatch(data);\n   105→    } catch {\n   106→      return; // undecodeable — ignore, poll worker will log it\n   107→    }\n   108→\n   109→    // Only care about our server's matches that are now locked\n   110→    if (match.phase !== PHASE_LOCKED || !match.server.equals(serverKey)) return;\n   111→    if (match.targetSlot <= 0n) return;\n   112→\n   113→    logger.info(\"[pda-watcher] coinflip phase changed to locked\", {\n   114→      pda: pda.slice(0, 12),\n   115→      targetSlot: match.targetSlot.toString(),\n   116→    });\n   117→\n   118→    onJoinDetected(pda, match.targetSlot).catch((err) => {\n   119→      logger.error(\"[pda-watcher] onJoinDetected error\", {\n   120→        pda: pda.slice(0, 12),\n   121→        error: err instanceof Error ? err.message : String(err),\n   122→      });\n   123→    });\n   124→  }\n   125→\n   126→  function handleLordChange(pda: string, data: Buffer): void {\n   127→    let round;\n   128→    try {\n   129→      round = decodeLordRound(data);\n   130→    } catch {\n   131→      return; // undecodeable — ignore\n   132→    }\n   133→\n   134→    // Only care about our server's rounds that are active with a target slot\n   135→    if (round.phase !== LORD_PHASE_ACTIVE || !round.server.equals(serverKey)) return;\n   136→    if (round.targetEntropySlot <= 0n) return;\n   137→\n   138→    logger.info(\"[pda-watcher] lord round countdown started\", {\n   139→      pda: pda.slice(0, 12),\n   140→      targetEntropySlot: round.targetEntropySlot.toString(),\n   141→    });\n   142→\n   143→    onJoinDetected(pda, round.targetEntropySlot).catch((err) => {\n   144→      logger.error(\"[pda-watcher] onJoinDetected error\", {\n   145→        pda: pda.slice(0, 12),\n   146→        error: err instanceof Error ? err.message : String(err),\n   147→      });\n   148→    });\n   149→  }\n   150→\n   151→  function unwatch(pda: string): void {\n   152→    const subId = subscriptions.get(pda);\n   153→    if (subId === undefined) return;\n   154→\n   155→    connection.removeAccountChangeListener(subId).catch((err) => {\n   156→      logger.warn(\"[pda-watcher] removeAccountChangeListener error\", {\n   157→        pda: pda.slice(0, 12),\n   158→        error: err instanceof Error ? err.message : String(err),\n   159→      });\n   160→    });\n   161→\n   162→    subscriptions.delete(pda);\n   163→    logger.debug(\"[pda-watcher] unwatching\", { pda: pda.slice(0, 12) });\n   164→  }\n   165→\n   166→  function stopAll(): void {\n   167→    for (const pda of subscriptions.keys()) {\n   168→      unwatch(pda);\n   169→    }\n   170→    logger.info(\"[pda-watcher] stopped all subscriptions\");\n   171→  }\n   172→\n   173→  return {\n   174→    watch,\n   175→    unwatch,\n   176→    stopAll,\n   177→    get size() {\n   178→      return subscriptions.size;\n   179→    },\n   180→  };\n   181→}\n   182→"}]},"parent_tool_use_id":"toolu_01D26TE5AfCUSgvbLk5tA4pE","session_id":"c7e08aab-e81c-466a-b6c2-35d333150199","uuid":"4573acca-e088-4607-b260-025bcec95b21"}
