      \"The player who created the match.\"\n   615→            ],\n   616→            \"type\": \"pubkey\"\n   617→          },\n   618→          {\n   619→            \"name\": \"opponent\",\n   620→            \"docs\": [\n   621→              \"The player who joined (Pubkey::default() if empty).\"\n   622→            ],\n   623→            \"type\": \"pubkey\"\n   624→          },\n   625→          {\n   626→            \"name\": \"server\",\n   627→            \"docs\": [\n   628→              \"Server key that co-signed create and will settle.\"\n   629→            ],\n   630→            \"type\": \"pubkey\"\n   631→          },\n   632→          {\n   633→            \"name\": \"entry_amount\",\n   634→            \"docs\": [\n   635→              \"Entry amount in lamports (custom wager, min 0.0026 SOL).\"\n   636→            ],\n   637→            \"type\": \"u64\"\n   638→          },\n   639→          {\n   640→            \"name\": \"creator_side\",\n   641→            \"docs\": [\n   642→              \"Side chosen by creator (0 = Heads, 1 = Tails).\"\n   643→            ],\n   644→            \"type\": \"u8\"\n   645→          },\n   646→          {\n   647→            \"name\": \"phase\",\n   648→            \"docs\": [\n   649→              \"Current phase (0=Waiting, 1=Locked, 2=Settled, 3=Refunded).\"\n   650→            ],\n   651→            \"type\": \"u8\"\n   652→          },\n   653→          {\n   654→            \"name\": \"commitment\",\n   655→            \"docs\": [\n   656→              \"SHA256(server_secret) — committed at create time.\"\n   657→            ],\n   658→            \"type\": {\n   659→              \"array\": [\n   660→                \"u8\",\n   661→                32\n   662→              ]\n   663→            }\n   664→          },\n   665→          {\n   666→            \"name\": \"algorithm_ver\",\n   667→            \"docs\": [\n   668→              \"Algorithm version used for result derivation.\"\n   669→            ],\n   670→            \"type\": \"u8\"\n   671→          },\n   672→          {\n   673→            \"name\": \"target_slot\",\n   674→            \"docs\": [\n   675→              \"Slot at which entropy should be read (set on join).\"\n   676→            ],\n   677→            \"type\": \"u64\"\n   678→          },\n   679→          {\n   680→            \"name\": \"resolve_deadline\",\n   681→            \"docs\": [\n   682→              \"Unix timestamp deadline for server to settle; after this, timeout refund is available.\"\n   683→            ],\n   684→            \"type\": \"i64\"\n   685→          },\n   686→          {\n   687→            \"name\": \"result_hash\",\n   688→            \"docs\": [\n   689→              \"Derived result hash (set on settle).\"\n   690→            ],\n   691→            \"type\": {\n   692→              \"array\": [\n   693→                \"u8\",\n   694→                32\n   695→              ]\n   696→            }\n   697→          },\n   698→          {\n   699→            \"name\": \"result\","}]},"parent_tool_use_id":"toolu_01D26TE5AfCUSgvbLk5tA4pE","session_id":"c7e08aab-e81c-466a-b6c2-35d333150199","uuid":"9be0fc16-ac08-4851-b186-b595b681fd9f"}
