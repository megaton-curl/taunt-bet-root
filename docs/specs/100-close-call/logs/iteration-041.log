 </PriceFeedProvider>\n    36→    </BrowserRouter>\n    37→  );\n    38→}\n    39→\n    40→\n    41→// Chat icon SVG\n    42→const ChatIcon = () => (\n    43→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    44→    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    45→    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    46→    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    47→    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n    48→  </svg>\n    49→);\n    50→\n    51→// Footer component with terms and FAQ modals\n    52→function Footer() {\n    53→  const [showTerms, setShowTerms] = useState(false);\n    54→  const [showFAQ, setShowFAQ] = useState(false);\n    55→  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n    56→  const termsModalRef = useRef<HTMLDivElement>(null);\n    57→  const faqModalRef = useRef<HTMLDivElement>(null);\n    58→\n    59→  // Close modal on outside click\n    60→  useEffect(() => {\n    61→    if (!showTerms && !showFAQ) return;\n    62→\n    63→    const handleClickOutside = (e: MouseEvent) => {\n    64→      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n    65→        setShowTerms(false);\n    66→      }\n    67→      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n    68→        setShowFAQ(false);\n    69→      }\n    70→    };\n    71→\n    72→    document.addEventListener(\"mousedown\", handleClickOutside);\n    73→    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n    74→  }, [showTerms, showFAQ]);\n    75→\n    76→  // Close on escape\n    77→  useEffect(() => {\n    78→    if (!showTerms && !showFAQ) return;\n    79→\n    80→    const handleEscape = (e: KeyboardEvent) => {\n    81→      if (e.key === \"Escape\") {\n    82→        setShowTerms(false);\n    83→        setShowFAQ(false);\n    84→      }\n    85→    };\n    86→\n    87→    document.addEventListener(\"keydown\", handleEscape);\n    88→    return () => document.removeEventListener(\"keydown\", handleEscape);\n    89→  }, [showTerms, showFAQ]);\n    90→\n    91→  const toggleFAQSection = (section: string) => {\n    92→    setExpandedFAQ(expandedFAQ === section ? null : section);\n    93→  };\n    94→\n    95→  const faqSections = [\n    96→    {\n    97→      id: \"fees\",\n    98→      title: \"Platform Fees\",\n    99→      content: `TAUNT charges a 3% platform fee on all games. This means 97% of all wagered funds go directly to winners.\n   100→\n   101→Fee breakdown:\n   102→• 1% goes to player incentives (Dogpile Raid reward pool, future promotions)\n   103→• 2% goes to platform treasury (server costs, development, operations)\n   104→\n   105→What you get:\n   106→• Winners receive: 97% of the pot\n   107→• No hidden fees or withdrawal charges\n   108→• Part of your wagers fund rewards you can win back through Dogpile Raid`\n   109→    },\n   110→    {\n   111→      id: \"raid-boss\",\n   112→      title: \"What is Dogpile Raid?\",\n   113→      content: `Dogpile Raid is a community reward mechanic where players collectively take down a Mark by playing games.\n   114→\n   115→How it works:\n   116→• A new Mark spawns every hour with a 50-minute active phase\n   117→• Every wager you make in any game lands \"hits\" on the Mark\n   118→• The Mark's Armor drains over time - it's always dropped when the timer ends\n   119→• When dropped, the reward pool is distributed to all participants\n   120→\n   121→Rewards:\n   122→• Your share is proportional to your hit contribution\n   123→• The reward pool grows from 1% of all wagers during the raid\n   124→• Higher total community hits = better loot tier = bigger multipliers\n   125→• Bonus loot is occasionally added for extra rewards\n   126→\n   127→Loot Tiers (based on total hits):\n   128→• Bronze: 0-10 SOL in hits\n   129→• Silver: 10-50 SOL in hits\n   130→• Gold: 50-150 SOL in hits\n   131→• Platinum: 150-500 SOL in hits\n   132→• Diamond: 500+ SOL in hits`\n   133→    },\n   134→    {\n   135→      id: \"pvp\",\n   136→      title: \"Why PvP Games?\",\n   137→      content: `Unlike traditional house-edge gambling where you play against the casino, TAUNT is 100% player-vs-player. This creates a fundamentally fairer system:\n   138→\n   139→• No house edge exploiting players\n   140→• Prize pools come entirely from player wagers\n   141→• The platform only takes a small facilitation fee\n   142→• Better odds than any traditional casino\n   143→• Transparent, skill-independent wagering`\n   144→    },\n   145→    {\n   146→      id: \"tiers\",\n   147→      title: \"Wagering Tiers\",\n   148→      content: `TAUNT uses wagering tiers to match players with similar risk appetites together. Each tier has a fixed SOL amount - you play against others wagering the same amount.\n   149→\n   150→Available Tiers:\n   151→• Iron: 0.005 SOL\n   152→• Bronze: 0.01 SOL\n   153→• Silver: 0.1 SOL\n   154→• Gold: 0.25 SOL\n   155→• Platinum: 0.5 SOL\n   156→• Diamond: 1 SOL\n   157→\n   158→How it works:\n   159→• Each game has separate lobbies for each tier\n   160→• Select your tier before joining a game\n   161→• You're matched only with players in the same tier\n   162→• Everyone in the round wagers the exact same amount\n   163→\n   164→Benefits:\n   165→• Fair matchmaking - compete on equal footing\n   166→• Choose the risk level you're comfortable with\n   167→• No whales dominating smaller players`\n   168→    },\n   169→    {\n   170→      id: \"leaderboard\",\n   171→      title: \"Leaderboard System\",\n   172→      content: `Leaderboard system details coming soon.\n   173→\n   174→We're working on implementing competitive leaderboards to track and reward top players. Stay tuned for updates!`\n   175→    },\n   176→    {\n   177→      id: \"fairness\",\n   178→      title: \"On-Chain Fairness\",\n   179→      content: `All game outcomes are provably fair using cryptographic verification:\n   180→\n   181→Commit-Reveal Pattern (Crash, Close Call):\n   182→1. Server publishes a hash of its seed before betting\n   183→2. Solana blockhash becomes the public seed\n   184→3. After the round, server reveals its seed\n   185→4. Anyone can verify the outcome matches\n   186→\n   187→On-Chain VRF (Jackpot, Flip You):\n   188→1. Game requests randomness from VRF provider\n   189→2. VRF generates verifiable random bytes\n   190→3. Result and proof stored on Solana blockchain\n   191→4. Anyone can verify using blockchain explorer\n   192→\n   193→Visit the Fairness page in the header for verification tools.`\n   194→    },\n   195→    {\n   196→      id: \"rng-buff\",\n   197→      title: \"Heater\",\n   198→      content: `The Heater is a powerful temporary bonus granted to players who help drop the Mark before the timer expires.\n   199→\n   200→How to get the Heater:\n   201→1. Participate in the hourly Dogpile Raid by wagering in any game\n   202→2. Your wagers land \"hits\" on the Mark\n   203→3. If the Mark is dropped before time runs out, ALL participants receive the Heater\n   204→4. The Heater lasts for 1 hour (until the next raid starts)\n   205→\n   206→Heater Benefits:\n   207→• Golden glowing border on your avatar (visible to all players)\n   208→• Chance to drop crates when wagering\n   209→• Drop chance scales with wager amount (1% base + 5% per SOL, max 25%)\n   210→\n   211→Visual Indicators:\n   212→• Golden pulsing border around your avatar everywhere in the app\n   213→• Heater icon with countdown timer in your profile header\n   214→• Star icon with timer in the main header\n   215→\n   216→The Heater expires when the next raid begins, so make the most of it!`\n   217→    },\n   218→    {\n   219→      id: \"treasure-chests\",\n   220→      title: \"Crates\",\n   221→      content: `Crates are mystery rewards that contain XP and SOL prizes. Open them in the Loot page.\n   222→\n   223→How to earn crates:\n   224→• Heater drops: Random chance when wagering with active Heater\n   225→• Complete ALL daily quests: 1 crate\n   226→• Complete weekly quests: 1 crate per quest (3 total)\n   227→• Complete ALL weekly quests: +2 bonus crates (5 total)\n   228→\n   229→Heater crate drop rates:\n   230→• Base chance: 1% per wager\n   231→• Bonus: +5% per 1 SOL wagered\n   232→• Maximum: 25% chance per wager\n   233→\n   234→Crate rarity (determined when opened):\n   235→• Common (50%): 50-100 XP, 0.001-0.005 SOL\n   236→• Uncommon (30%): 100-250 XP, 0.005-0.01 SOL\n   237→• Rare (15%): 250-500 XP, 0.01-0.025 SOL\n   238→• Epic (4%): 500-1000 XP, 0.025-0.05 SOL\n   239→• Legendary (1%): 1000-2500 XP, 0.05-0.1 SOL\n   240→\n   241→SOL rewards are paid from the platform treasury. May the RNG gods smile upon you!`\n   242→    },\n   243→  ];\n   244→\n   245→  return (\n   246→    <>\n   247→      <footer className=\"footer-v2\">\n   248→        <div className=\"ft-logo\">TAUNT<em>.</em></div>\n   249→        <div className=\"ft-links\">\n   250→          <button type=\"button\" className=\"ft-lnk\" onClick={() => setShowFAQ(true)}>FAQ</button>\n   251→          <button type=\"button\" className=\"ft-lnk\" onClick={() => setShowTerms(true)}>Terms</button>\n   252→          <a href=\"https://x.com/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"ft-lnk\">Twitter</a>\n   253→          <a href=\"https://t.me/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"ft-lnk\">Telegram</a>\n   254→        </div>\n   255→        <div className=\"ft-tag\">taunt.bet &middot; Provably Fair &middot; Solana</div>\n   256→      </footer>\n   257→\n   258→      {/* Terms Modal */}\n   259→      {showTerms && (\n   260→        <div className=\"footer-terms-overlay\">\n   261→          <div className=\"footer-terms-modal\" ref={termsModalRef}>\n   262→            <button\n   263→              type=\"button\"\n   264→              className=\"footer-terms-close\"\n   265→              onClick={() => setShowTerms(false)}\n   266→            >\n   267→              ×\n   268→            </button>\n   269→            <h3 className=\"footer-terms-title\">Terms of Use</h3>\n   270→            <div className=\"footer-terms-content\">\n   271→              <p>\n   272→                By accessing and using TAUNT, you confirm that you are not a citizen,\n   273→                resident, or located within any jurisdiction where online gambling is prohibited\n   274→                or restricted by law, including but not limited to: the United States,\n   275→                United Kingdom, France, Germany, Spain, the Netherlands, or any other\n   276→                jurisdiction with similar regulations.\n   277→              </p>\n   278→              <p>\n   279→                You are solely responsible for determining whether your use of this platform\n   280→                is lawful in your country or region of residence. TAUNT does not provide\n   281→                legal advice and assumes no liability for users who access the platform in\n   282→                violation of applicable laws.\n   283→              </p>\n   284→              <p>\n   285→                By continuing to use this service, you acknowledge and accept these terms.\n   286→              </p>\n   287→            </div>\n   288→            <button\n   289→              type=\"button\"\n   290→              className=\"footer-terms-accept\"\n   291→              onClick={() => setShowTerms(false)}\n   292→            >\n   293→              I Understand\n   294→            </button>\n   295→          </div>\n   296→        </div>\n   297→      )}\n   298→\n   299→      {/* FAQ Modal */}\n   300→      {showFAQ && (\n   301→        <div className=\"footer-faq-overlay\">\n   302→          <div className=\"footer-faq-modal\" ref={faqModalRef}>\n   303→            <button\n   304→              type=\"button\"\n   305→              className=\"footer-faq-close\"\n   306→              onClick={() => setShowFAQ(false)}\n   307→            >\n   308→              ×\n   309→            </button>\n   310→            <h3 className=\"footer-faq-title\">Frequently Asked Questions</h3>\n   311→            <div className=\"footer-faq-content\">\n   312→              {faqSections.map((section) => (\n   313→                <div key={section.id} className=\"faq-section\">\n   314→                  <button\n   315→                    type=\"button\"\n   316→                    className={`faq-section-header ${expandedFAQ === section.id ? \"expanded\" : \"\"}`}\n   317→                    onClick={() => toggleFAQSection(section.id)}\n   318→                  >\n   319→                    <span className=\"faq-section-title\">{section.title}</span>\n   320→                    <span className=\"faq-section-arrow\">{expandedFAQ === section.id ? \"−\" : \"+\"}</span>\n   321→                  </button>\n   322→                  {expandedFAQ === section.id && (\n   323→                    <div className=\"faq-section-content\">\n   324→                      {section.content.split(\"\\n\\n\").map((paragraph, idx) => (\n   325→                        <p key={idx}>{paragraph}</p>\n   326→                      ))}\n   327→                    </div>\n   328→                  )}\n   329→                </div>\n   330→              ))}\n   331→            </div>\n   332→            <button\n   333→              type=\"button\"\n   334→              className=\"footer-faq-close-btn\"\n   335→              onClick={() => setShowFAQ(false)}\n   336→            >\n   337→              Close\n   338→            </button>\n   339→          </div>\n   340→        </div>\n   341→      )}\n   342→    </>\n   343→  );\n   344→}\n   345→\n   346→function AppContent() {\n   347→  const [chatExpanded, setChatExpanded] = useState(false);\n   348→  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);\n   349→\n   350→  const toggleSidebar = () => {\n   351→    setSidebarCollapsed(!sidebarCollapsed);\n   352→    document.body.classList.toggle(\"nc\", !sidebarCollapsed);\n   353→  };\n   354→\n   355→  return (\n   356→    <div className=\"app\">\n   357→      <BackgroundEffects />\n   358→\n   359→      {/* Fixed top bar */}\n   360→      <div className=\"top-bar\">\n   361→        <Header />\n   362→        <Ticker />\n   363→      </div>\n   364→\n   365→      {/* Fixed sidebar */}\n   366→      <Sidebar collapsed={sidebarCollapsed} onToggle={toggleSidebar} />\n   367→\n   368→      <main className=\"main\">\n   369→        <Routes>\n   370→          <Route path=\"/\" element={<HomePage />} />\n   371→          <Route path=\"/coinflip\" element={<CoinflipPage />} />\n   372→          <Route path=\"/coinflip/:matchId\" element={<CoinflipPage />} />\n   373→          <Route path=\"/lord-of-rngs\" element={<LordOfRngsPage />} />\n   374→          <Route path=\"/lord-of-rngs/:matchId\" element={<LordOfRngsPage />} />\n   375→          <Route path=\"/close-call\" element={<CloseCallPage />} />\n   376→          <Route path=\"/crash\" element={<CryptoCrashPage />} />\n   377→          <Route path=\"/game-of-trades\" element={<GameOfTradesPage />} />\n   378→          <Route path=\"/profile\" element={<ProfilePage />} />\n   379→          <Route path=\"/loot\" element={<LootPage />} />\n   380→          <Route path=\"/quests\" element={<QuestsPage />} />\n   381→          <Route path=\"/fairness\" element={<FairnessPage />} />\n   382→          <Route path=\"/coinflip/:matchId/proof\" element={<CoinflipRoundPage />} />\n   383→          <Route path=\"/lord-of-rngs/:matchId/proof\" element={<LordRoundPage />} />\n   384→          <Route path=\"*\" element={<NotFoundPage />} />\n   385→        </Routes>\n   386→        <Footer />\n   387→      </main>\n   388→\n   389→      <BuildBadge />\n   390→\n   391→      {/* Floating chat button */}\n   392→      <div className=\"chat-float\">\n   393→        <button type=\"button\" className=\"chat-float__btn\" onClick={() => setChatExpanded(!chatExpanded)}>\n   394→          <ChatIcon />\n   395→          <span className=\"chat-float__dot\" />\n   396→        </button>\n   397→        {chatExpanded && (\n   398→          <div className=\"chat-float__panel\">\n   399→            <div className=\"chat-panel-header\">\n   400→              <h4>Global Chat</h4>\n   401→              <button className=\"chat-close\" onClick={() => setChatExpanded(false)}>×</button>\n   402→            </div>\n   403→            <div className=\"chat-messages\">\n   404→              <div className=\"chat-message\">\n   405→                <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   406→                <span className=\"text\">gg nice flip!</span>\n   407→              </div>\n   408→              <div className=\"chat-message\">\n   409→                <PlayerAvatarCompact address=\"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   410→                <span className=\"text\">who's ready for crash?</span>\n   411→              </div>\n   412→              <div className=\"chat-message\">\n   413→                <PlayerAvatarCompact address=\"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   414→                <span className=\"text\">close call is rigged lol jk</span>\n   415→              </div>\n   416→              <div className=\"chat-message\">\n   417→                <PlayerAvatarCompact address=\"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   418→                <span className=\"text\">just hit 5x on crash!</span>\n   419→              </div>\n   420→              <div className=\"chat-message\">\n   421→                <PlayerAvatarCompact address=\"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   422→                <span className=\"text\">coinflip is where it's at</span>\n   423→              </div>\n   424→            </div>\n   425→            <div className=\"chat-input-container\">\n   426→              <input type=\"text\" className=\"chat-input\" placeholder=\"Type a message...\" />\n   427→              <button className=\"chat-send-btn\">Send</button>\n   428→            </div>\n   429→          </div>\n   430→        )}\n   431→      </div>\n   432→\n   433→      <MiniProfileModal />\n   434→      <ChestDropNotification />\n   435→    </div>\n   436→  );\n   437→}\n   438→\n   439→// Mock recent winners data\n   440→const RECENT_WINNERS = [\n   441→  { player: \"CryptoSavage.eth\", game: \"FLIP YOU\", amount: \"+$194.00\", positive: true, taunt: \"later, bitch\", color: \"#FFB800\" },\n   442→  { player: \"degen_whale_99\", game: \"MOON OR REKT\", amount: \"+$407.40\", positive: true, taunt: \"gg ez lmao\", color: \"#FF2D55\" },\n   443→  { player: \"0x9f…22b1\", game: \"JACKPOT\", amount: \"+$38.80\", positive: true, taunt: null, color: \"#FF1F8E\" },\n   444→  { player: \"paper_hands_pete\", game: \"FLIP YOU\", amount: \"-$10.00\", positive: false, taunt: \"skill issue ngl\", color: \"#FFB800\" },\n   445→  { player: \"sol_degen_88\", game: \"GAME OF TRADES\", amount: \"+$30.00\", positive: true, taunt: null, color: \"#3D7FFF\" },\n   446→  { player: \"anon_8821\", game: \"JACKPOT\", amount: \"+$146.55\", positive: true, taunt: \"the RNG chose me\", color: \"#FF1F8E\" },\n   447→  { player: \"0x3b…81a2\", game: \"CLOSE CALL\", amount: \"+$18.40\", positive: true, taunt: null, color: \"#00E676\" },\n   448→  { player: \"moon_maxi_99\", game: \"CRYPTO CRASH\", amount: \"+$82.10\", positive: true, taunt: \"rekt. bye.\", color: \"#FF2D55\" },\n   449→];\n   450→\n   451→function HomePage() {\n   452→  return (\n   453→    <>\n   454→      {/* Page header */}\n   455→      <div className=\"page-hd\">\n   456→        <div>\n   457→          <div className=\"pg-title\">The <span className=\"pk\">Pit.</span></div>\n   458→          <div className=\"pg-sub\">Five ways to ruin someone's day</div>\n   459→        </div>\n   460→        <div className=\"pg-tags\">\n   461→          <div className=\"ptag on\">Floor Open · 24/7</div>\n   462→          <div className=\"ptag\">3% Flat Fee · Zero House Edge</div>\n   463→          <div className=\"ptag\">Provably Fair · Solana</div>\n   464→        </div>\n   465→      </div>\n   466→\n   467→      {/* Game grid */}\n   468→      <div className=\"game-grid\">\n   469→        <GameCardV2\n   470→          name=\"Flip You\"\n   471→          subtitle=\"$0.50 — $100 · P2P · 1v1\"\n   472→          description=\"Pure 50/50. One winner takes the pot. Your opponent sees your taunt the moment they lose.\"\n   473→          path=\"/coinflip\"\n   474→          visual=\"coinflip\"\n   475→          mode=\"VRF · On-chain\"\n   476→          colorClass=\"y\"\n   477→          stats={[\n   478→            { value: \"18\", label: \"Open Games\" },\n   479→            { value: \"6\", label: \"Tiers\" },\n   480→            { value: \"97%\", label: \"Payout\" },\n   481→          ]}\n   482→        />\n   483→        <GameCardV2\n   484→          name=\"Jackpot\"\n   485→          subtitle=\"$0.50 — $100 · P2P · Lottery\"\n   486→          description=\"Buy tickets, buy odds. One spin decides everything. The wheel doesn't care how many you own.\"\n   487→          path=\"/lord-of-rngs\"\n   488→          visual=\"lotr\"\n   489→          mode=\"VRF · On-chain\"\n   490→          colorClass=\"pk\"\n   491→          stats={[\n   492→            { value: \"$146\", label: \"Top Jackpot\" },\n   493→            { value: \"6\", label: \"Active\" },\n   494→            { value: \"VRF\", label: \"Randomness\" },\n   495→          ]}\n   496→        />\n   497→        <GameCardV2\n   498→          name=\"Close Call\"\n   499→          subtitle=\"$0.50 — $100 · P2P · Binary\"\n   500→          description=\"Green or red. Lock in before the round closes. Winners split the losers' side pro-rata.\"\n   501→          path=\"/close-call\"\n   502→          visual=\"close-c