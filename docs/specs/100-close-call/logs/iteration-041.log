{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PoMJLHdsYKArku8fmyUt8D","type":"tool_result","content":"     1→import { useState } from \"react\";\n     2→import { SolanaLogo } from \"../components/SolanaLogo\";\n     3→import {\n     4→  GameLayout,\n     5→  WagerInput,\n     6→  Modal,\n     7→  type HistoryEntry,\n     8→} from \"@rng-utopia/ui\";\n     9→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    10→import {\n    11→  CoinflipProvider,\n    12→  useCoinflip,\n    13→  CoinSideSelector,\n    14→  OpenMatchesList,\n    15→  ActiveMatchView,\n    16→  type UIMatch,\n    17→} from \"../features/coinflip\";\n    18→\n    19→function CoinflipPageContent() {\n    20→  const { connected, address, connect } = useWallet();\n    21→  const {\n    22→    activeMatch,\n    23→    openMatches,\n    24→    userHistory,\n    25→    wagerAmount,\n    26→    selectedSide,\n    27→    loading,\n    28→    creating,\n    29→    joiningMatchId,\n    30→    setWagerAmount,\n    31→    setSelectedSide,\n    32→    createMatch,\n    33→    joinMatch,\n    34→    cancelMatch,\n    35→    timeoutRefund,\n    36→    clearActiveMatch,\n    37→    lastSettleSignature,\n    38→  } = useCoinflip();\n    39→\n    40→  // State for history detail modal\n    41→  const [selectedHistoryMatch, setSelectedHistoryMatch] = useState<UIMatch | null>(null);\n    42→\n    43→  // Side colors (match the CSS .side-heads / .side-tails)\n    44→  const SIDE_COLORS = {\n    45→    heads: \"#00cc88\",\n    46→    tails: \"#ff6644\",\n    47→  };\n    48→\n    49→  // Convert user history to HistoryEntry format\n    50→  const historyEntries: HistoryEntry[] = userHistory.map((match) => {\n    51→    const isWinner = match.winner === address;\n    52→    const isPlayer1 = match.player1 === address;\n    53→    const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    54→    const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n    55→    const outcomeColor = isWinner ? \"#39ff14\" : \"#d45d5d\";\n    56→\n    57→    return {\n    58→      roundId: match.id.slice(-6),\n    59→      result: (\n    60→        <span className=\"coinflip-history-result\">\n    61→          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n    62→            {yourSide?.toUpperCase() ?? \"?\"}\n    63→          </span>\n    64→          <span className=\"coinflip-history-result__separator\">|</span>\n    65→          <span style={{ color: \"#ccc\" }}>\n    66→            {match.entryAmount} SOL\n    67→          </span>\n    68→          <span className=\"coinflip-history-result__separator\">|</span>\n    69→          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n    70→            {isWinner ? \"WON\" : \"LOST\"}\n    71→          </span>\n    72→        </span>\n    73→      ),\n    74→      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n    75→      timestamp: new Date(match.completedAt ?? match.createdAt),\n    76→      verified: true,\n    77→      won: isWinner,\n    78→      onClick: () => setSelectedHistoryMatch(match),\n    79→    };\n    80→  });\n    81→\n    82→  // Calculate potential payout\n    83→  const potentialPayout = wagerAmount\n    84→    ? wagerAmount * 2 * 0.97\n    85→    : 0;\n    86→\n    87→  const handleCreateMatch = async () => {\n    88→    try {\n    89→      await createMatch();\n    90→    } catch (error) {\n    91→      console.error(\"Failed to create match:\", error);\n    92→    }\n    93→  };\n    94→\n    95→  const handleJoinMatch = async (matchId: string) => {\n    96→    try {\n    97→      await joinMatch(matchId);\n    98→    } catch (error) {\n    99→      console.error(\"Failed to join match:\", error);\n   100→    }"}]},"parent_tool_use_id":"toolu_01K3BwDBXXg1hHyopzaHRMMb","session_id":"89d4f6ce-bf36-4167-ba30-a196c35784b5","uuid":"54cba975-baf8-4ef7-91e5-3ad19cc736fd"}
