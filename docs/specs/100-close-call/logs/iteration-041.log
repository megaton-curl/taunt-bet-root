{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018vGtLJSS1CZuFr16p1mthi","type":"tool_result","content":"     1→/**\n     2→ * Close Call - Pari-mutuel BTC candle prediction game\n     3→ */\n     4→\n     5→// Bet side selection\n     6→export type BetSide = \"green\" | \"red\";\n     7→\n     8→// Round phase state machine (aligned with on-chain CloseCallPhase)\n     9→export type RoundPhase = \"open\" | \"settled\" | \"refunded\";\n    10→\n    11→// Candle outcome (aligned with on-chain Outcome enum)\n    12→export type CandleOutcome = \"green\" | \"red\" | \"refund\";\n    13→\n    14→// OHLC candle data\n    15→export interface Candle {\n    16→  open: number;\n    17→  high: number;\n    18→  low: number;\n    19→  close: number;\n    20→  openTime: number;  // Unix timestamp ms\n    21→  closeTime: number; // Unix timestamp ms\n    22→}\n    23→\n    24→// Individual player bet\n    25→export interface PlayerBet {\n    26→  address: string;\n    27→  side: BetSide;\n    28→  amount: number;     // in SOL\n    29→  timestamp: number;\n    30→  displayName?: string;\n    31→}\n    32→\n    33→// Pool state tracking\n    34→export interface PoolState {\n    35→  greenPool: number;\n    36→  redPool: number;\n    37→  totalPool: number;\n    38→  playerCount: number;\n    39→  greenBets: PlayerBet[];\n    40→  redBets: PlayerBet[];\n    41→}\n    42→\n    43→// Complete round data\n    44→export interface Round {\n    45→  id: string;\n    46→  phase: RoundPhase;\n    47→\n    48→  // Pool state\n    49→  pool: PoolState;\n    50→\n    51→  // Timing\n    52→  createdAt: number;\n    53→  bettingEndsAt: number;\n    54→  resolvedAt?: number;\n    55→\n    56→  // Target candle (the one being bet on)\n    57→  targetCandleTime: number;\n    58→\n    59→  // Result\n    60→  outcome?: CandleOutcome;\n    61→  resultCandle?: Candle;\n    62→\n    63→  // Oracle prices (Pyth)\n    64→  openPrice?: number;\n    65→  openPriceExpo?: number;\n    66→  closePrice?: number;\n    67→\n    68→  // Settlement\n    69→  winners?: string[];\n    70→  payouts?: Record<string, number>;\n    71→  payoutAmount?: number;\n    72→  settleTx?: string;\n    73→}\n    74→\n    75→// User's history entry\n    76→export interface UserRoundHistory {\n    77→  round: Round;\n    78→  userBet: PlayerBet;\n    79→  payout: number;\n    80→  won: boolean;\n    81→}\n    82→\n    83→// Context value type\n    84→export interface CloseCallContextValue {\n    85→  // Round state\n    86→  currentRound: Round | null;\n    87→  completedRound: Round | null; // Most recently completed round (for result display)\n    88→  recentCandles: Candle[];\n    89→  currentPrice: number;\n    90→  candleProgress: number;\n    91→  userHistory: UserRoundHistory[];\n    92→\n    93→  // User bet state\n    94→  pendingAmount: number;\n    95→  pendingSide: BetSide | null;\n    96→  userBet: PlayerBet | null;\n    97→\n    98→  // Loading states\n    99→  loading: boolean;\n   100→  placingBet: boolean;\n   101→\n   102→  // Actions\n   103→  setPendingAmount: (amount: number) => void;\n   104→  setPendingSide: (side: BetSide | null) => void;\n   105→  placeBet: (side?: BetSide) => Promise<void>;\n   106→  adjustBetAmount: (adjustment: \"half\" | \"double\" | \"max\") => void;\n   107→  clearCompletedRound: () => void;\n   108→\n   109→  // Computed\n   110→  potentialPayout: number;\n   111→  userOdds: number;\n   112→\n   113→  // Utils\n   114→  refreshRound: () => void;\n   115→}\n   116→\n   117→// Constants\n   118→export const DEFAULT_BET_AMOUNT = 0.5;\n   119→export const MIN_BET_AMOUNT = 0.001; // 0.001 SOL platform minimum\n   120→export const MAX_BET_AMOUNT = 100;   // 100 SOL platform maximum\n   121→export const PLATFORM_FEE_BPS = 300; // 3%\n   122→export const PLATFORM_FEE = 0.03;\n   123→\n   124→// Candle timing (1-minute candles)\n   125→export const CANDLE_SPEED_MULTIPLIER = 1;\n   126→export const CANDLE_DURATION_MS = 60000 / CANDLE_SPEED_MULTIPLIER; // 60 seconds\n   127→\n   128→// Betting window (first 30 seconds of each candle)\n   129→export const BETTING_WINDOW_MS = 30000;\n   130→\n   131→// Side colors\n   132→export const SIDE_COLORS = {\n   133→  green: \"#45b058\",\n   134→  red: \"#dc3545\",\n   135→  refund: \"#f0b820\",\n   136→};\n   137→"}]},"parent_tool_use_id":null,"session_id":"89d4f6ce-bf36-4167-ba30-a196c35784b5","uuid":"f2eee538-d402-441f-a59d-dc4bfc661263","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/types.ts","content":"/**\n * Close Call - Pari-mutuel BTC candle prediction game\n */\n\n// Bet side selection\nexport type BetSide = \"green\" | \"red\";\n\n// Round phase state machine (aligned with on-chain CloseCallPhase)\nexport type RoundPhase = \"open\" | \"settled\" | \"refunded\";\n\n// Candle outcome (aligned with on-chain Outcome enum)\nexport type CandleOutcome = \"green\" | \"red\" | \"refund\";\n\n// OHLC candle data\nexport interface Candle {\n  open: number;\n  high: number;\n  low: number;\n  close: number;\n  openTime: number;  // Unix timestamp ms\n  closeTime: number; // Unix timestamp ms\n}\n\n// Individual player bet\nexport interface PlayerBet {\n  address: string;\n  side: BetSide;\n  amount: number;     // in SOL\n  timestamp: number;\n  displayName?: string;\n}\n\n// Pool state tracking\nexport interface PoolState {\n  greenPool: number;\n  redPool: number;\n  totalPool: number;\n  playerCount: number;\n  greenBets: PlayerBet[];\n  redBets: PlayerBet[];\n}\n\n// Complete round data\nexport interface Round {\n  id: string;\n  phase: RoundPhase;\n\n  // Pool state\n  pool: PoolState;\n\n  // Timing\n  createdAt: number;\n  bettingEndsAt: number;\n  resolvedAt?: number;\n\n  // Target candle (the one being bet on)\n  targetCandleTime: number;\n\n  // Result\n  outcome?: CandleOutcome;\n  resultCandle?: Candle;\n\n  // Oracle prices (Pyth)\n  openPrice?: number;\n  openPriceExpo?: number;\n  closePrice?: number;\n\n  // Settlement\n  winners?: string[];\n  payouts?: Record<string, number>;\n  payoutAmount?: number;\n  settleTx?: string;\n}\n\n// User's history entry\nexport interface UserRoundHistory {\n  round: Round;\n  userBet: PlayerBet;\n  payout: number;\n  won: boolean;\n}\n\n// Context value type\nexport interface CloseCallContextValue {\n  // Round state\n  currentRound: Round | null;\n  completedRound: Round | null; // Most recently completed round (for result display)\n  recentCandles: Candle[];\n  currentPrice: number;\n  candleProgress: number;\n  userHistory: UserRoundHistory[];\n\n  // User bet state\n  pendingAmount: number;\n  pendingSide: BetSide | null;\n  userBet: PlayerBet | null;\n\n  // Loading states\n  loading: boolean;\n  placingBet: boolean;\n\n  // Actions\n  setPendingAmount: (amount: number) => void;\n  setPendingSide: (side: BetSide | null) => void;\n  placeBet: (side?: BetSide) => Promise<void>;\n  adjustBetAmount: (adjustment: \"half\" | \"double\" | \"max\") => void;\n  clearCompletedRound: () => void;\n\n  // Computed\n  potentialPayout: number;\n  userOdds: number;\n\n  // Utils\n  refreshRound: () => void;\n}\n\n// Constants\nexport const DEFAULT_BET_AMOUNT = 0.5;\nexport const MIN_BET_AMOUNT = 0.001; // 0.001 SOL platform minimum\nexport const MAX_BET_AMOUNT = 100;   // 100 SOL platform maximum\nexport const PLATFORM_FEE_BPS = 300; // 3%\nexport const PLATFORM_FEE = 0.03;\n\n// Candle timing (1-minute candles)\nexport const CANDLE_SPEED_MULTIPLIER = 1;\nexport const CANDLE_DURATION_MS = 60000 / CANDLE_SPEED_MULTIPLIER; // 60 seconds\n\n// Betting window (first 30 seconds of each candle)\nexport const BETTING_WINDOW_MS = 30000;\n\n// Side colors\nexport const SIDE_COLORS = {\n  green: \"#45b058\",\n  red: \"#dc3545\",\n  refund: \"#f0b820\",\n};\n","numLines":137,"startLine":1,"totalLines":137}}}
