{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tzu5WXBB8PhLWfz8NRuyc7","type":"tool_result","content":"     1→import { useState } from \"react\";\n     2→import { GameLayout, Modal, RoundResultBanner, type HistoryEntry } from \"@rng-utopia/ui\";\n     3→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     4→import {\n     5→  CloseCallProvider,\n     6→  useCloseCall,\n     7→  CandlestickChart,\n     8→  BetAmountInput,\n     9→  SideSelector,\n    10→  PoolDistribution,\n    11→  SIDE_COLORS,\n    12→  type UserRoundHistory,\n    13→  type BetSide,\n    14→} from \"../features/close-call\";\n    15→\n    16→function CloseCallPageContent() {\n    17→  const { connected, connect, getBalance, address } = useWallet();\n    18→  const {\n    19→    currentRound,\n    20→    completedRound,\n    21→    recentCandles,\n    22→    currentPrice,\n    23→    candleProgress,\n    24→    userHistory,\n    25→    pendingAmount,\n    26→    pendingSide,\n    27→    userBet,\n    28→    loading,\n    29→    placingBet,\n    30→    setPendingAmount,\n    31→    setPendingSide,\n    32→    placeBet,\n    33→    adjustBetAmount,\n    34→    potentialPayout,\n    35→    clearCompletedRound,\n    36→  } = useCloseCall();\n    37→\n    38→  // State for history modal\n    39→  const [selectedHistory, setSelectedHistory] = useState<UserRoundHistory | null>(null);\n    40→\n    41→  // Get user's bet in the completed round (if any)\n    42→  const completedRoundUserBet = completedRound && address\n    43→    ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n    44→        (b) => b.address === address\n    45→      ) ?? null\n    46→    : null;\n    47→\n    48→  // Convert user history to HistoryEntry format\n    49→  const historyEntries: HistoryEntry[] = userHistory.map((entry) => {\n    50→    const sideColor = SIDE_COLORS[entry.userBet.side];\n    51→    const outcomeColor = entry.won ? SIDE_COLORS.green : \"#d45d5d\";\n    52→\n    53→    return {\n    54→      roundId: entry.round.id.slice(-8),\n    55→      result: (\n    56→        <span className=\"close-call-history-result\">\n    57→          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n    58→            {entry.userBet.side.toUpperCase()}\n    59→          </span>\n    60→          <span className=\"close-call-history-result__separator\">|</span>\n    61→          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n    62→            {entry.won ? \"WON\" : \"LOST\"}\n    63→          </span>\n    64→        </span>\n    65→      ),\n    66→      payout: entry.won ? entry.payout : -entry.userBet.amount,\n    67→      timestamp: new Date(entry.round.resolvedAt ?? entry.round.createdAt),\n    68→      verified: true,\n    69→      won: entry.won,\n    70→      onClick: () => setSelectedHistory(entry),\n    71→    };\n    72→  });\n    73→\n    74→  // Handle placing bet with side selection\n    75→  const handlePlaceBetWithSide = async (side: BetSide) => {\n    76→    setPendingSide(side);\n    77→    try {\n    78→      await placeBet(side);\n    79→    } catch (error) {\n    80→      console.error(\"Failed to place bet:\", error);\n    81→    }\n    82→  };\n    83→\n    84→  // Determine if betting window is open (round is open and within betting time)\n    85→  const isBettingOpen = currentRound?.phase === \"open\" && Date.now() < (currentRound?.bettingEndsAt ?? 0);\n    86→\n    87→  // Sidebar content\n    88→  const sidebar = (\n    89→    <div className=\"close-call-sidebar\">\n    90→      {/* Bet amount input */}\n    91→      <div className=\"close-call-sidebar__section\">\n    92→        <BetAmountInput\n    93→          value={pendingAmount}\n    94→          onChange={setPendingAmount}\n    95→          onAdjust={adjustBetAmount}\n    96→          disabled={placingBet || !!userBet}\n    97→          maxAmount={getBalance?.() ?? 10}\n    98→        />\n    99→      </div>\n   100→\n   101→      {/* Side selector - buttons place bets directly */}\n   102→      <div className=\"close-call-sidebar__section\">\n   103→        {!connected ? (\n   104→          <button\n   105→            type=\"button\"\n   106→            className=\"close-call-action-btn\"\n   107→            onClick={connect}\n   108→          >\n   109→            Connect Wallet\n   110→          </button>\n   111→        ) : (\n   112→          <SideSelector\n   113→            selectedSide={userBet?.side ?? pendingSide}\n   114→            onSelect={handlePlaceBetWithSide}\n   115→            disabled={!isBettingOpen || placingBet || pendingAmount <= 0 || !!userBet}\n   116→            placingBet={placingBet}\n   117→          />\n   118→        )}\n   119→      </div>\n   120→\n   121→      {/* Pool distribution - under the buttons */}\n   122→      {currentRound && (\n   123→        <div className=\"close-call-sidebar__section\">\n   124→          <PoolDistribution\n   125→            pool={currentRound.pool}\n   126→            userBet={userBet}\n   127→            potentialPayout={potentialPayout}\n   128→            roundOutcome={currentRound.outcome}\n   129→            isRoundComplete={currentRound.phase === \"settled\" || currentRound.phase === \"refunded\"}\n   130→          />\n   131→        </div>\n   132→      )}\n   133→\n   134→      {/* Auto-payout message for winners - shown under prize pool */}\n   135→      {completedRound && (() => {\n   136→        const completedUserBet = address\n   137→          ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n   138→              (b) => b.address === address\n   139→            ) ?? null\n   140→          : null;\n   141→        const isWinner = completedUserBet && completedRound.winners?.includes(completedUserBet.address);\n   142→        const payout = completedUserBet && completedRound.payouts?.[completedUserBet.address];\n   143→\n   144→        if (isWinner && payout) {\n   145→          return (\n   146→            <div className=\"close-call-payout-received\">\n   147→              <span className=\"close-call-payout-received__label\">Payout Received!</span>\n   148→              <span className=\"close-call-payout-received__amount\">{`+${payout.toFixed(4)} SOL`}</span>\n   149→            </div>\n   150→          );\n   151→        }\n   152→        return null;\n   153→      })()}\n   154→\n   155→      {/* Round info */}\n   156→      {currentRound && (\n   157→        <div className=\"close-call-sidebar__fairness\">\n   158→          <h4 className=\"close-call-sidebar__fairness-title\">Round Info</h4>\n   159→          <div className=\"close-call-sidebar__fairness-row\">\n   160→            <span>Round ID</span>\n   161→            <span className=\"close-call-sidebar__hash\" title={currentRound.id}>\n   162→              {currentRound.id.slice(-12)}\n   163→            </span>\n   164→          </div>\n   165→          <div className=\"close-call-sidebar__fairness-row\">\n   166→            <span>Oracle</span>\n   167→            <span className=\"close-call-sidebar__hash\">Pyth BTC/USD</span>\n   168→          </div>\n   169→        </div>\n   170→      )}\n   171→    </div>\n   172→  );\n   173→\n   174→  return (\n   175→    <>\n   176→      <GameLayout\n   177→        gameName=\"Close Call\"\n   178→        gameDescription=\"A pari-mutuel prediction market game\"\n   179→        sidebar={sidebar}\n   180→        historyEntries={historyEntries}\n   181→        showHistory={true}\n   182→      >\n   183→        <div className=\"close-call-main\">\n   184→          {/* Result banner - positioned above the chart */}\n   185→          {completedRound && (() => {\n   186→            const outcome = completedRound.outcome;\n   187→            const isUserWinner = completedRoundUserBet && completedRound.winners?.includes(completedRoundUserBet.address);\n   188→            const userPayout = completedRoundUserBet && completedRound.payouts?.[completedRoundUserBet.address];\n   189→            const outcomeColor = outcome === \"green\"\n   190→              ? SIDE_COLORS.green\n   191→              : outcome === \"red\"\n   192→              ? SIDE_COLORS.red\n   193→              : SIDE_COLORS.refund;\n   194→\n   195→            return (\n   196→              <RoundResultBanner\n   197→                outcomeText={outcome === \"refund\" ? \"REFUND\" : `${outcome?.toUpperCase()} WINS`}\n   198→                outcomeColor={outcomeColor}\n   199→                userWon={!!isUserWinner}\n   200→                userLost={!!completedRoundUserBet && !isUserWinner && outcome !== \"refund\"}\n   201→                statusText={\n   202→                  !completedRoundUserBet\n   203→                    ? undefined\n   204→                    : isUserWinner\n   205→                    ? \"You Won!\"\n   206→                    : outcome === \"refund\"\n   207→                    ? \"Bet refunded\"\n   208→                    : \"You Lost\"\n   209→                }\n   210→                payoutAmount={\n   211→                  completedRoundUserBet\n   212→                    ? isUserWinner\n   213→                      ? userPayout ?? undefined\n   214→                      : outcome === \"refund\"\n   215→                      ? undefined\n   216→                      : -completedRoundUserBet.amount\n   217→                    : undefined\n   218→                }\n   219→                onDismiss={clearCompletedRound}\n   220→              />\n   221→            );\n   222→          })()}\n   223→\n   224→          {/* Banner: betting on current candle */}\n   225→          <div className=\"close-call-main__banner\">\n   226→            <span>\n   227→              Will the current candle close{\" \"}\n   228→              <span style={{ color: SIDE_COLORS.green }}>GREEN</span> or{\" \"}\n   229→              <span style={{ color: SIDE_COLORS.red }}>RED</span>?\n   230→            </span>\n   231→          </div>\n   232→\n   233→          {/* Candlestick chart */}\n   234→          {!loading && recentCandles.length > 0 ? (\n   235→            <CandlestickChart\n   236→              candles={recentCandles}\n   237→              currentPrice={currentPrice}\n   238→              progress={candleProgress}\n   239→            />\n   240→          ) : (\n   241→            <div className=\"close-call-main__loading\">\n   242→              <div className=\"close-call-main__spinner\" />\n   243→              <span>Loading chart...</span>\n   244→            </div>\n   245→          )}\n   246→        </div>\n   247→      </GameLayout>\n   248→\n   249→      {/* History detail modal */}\n   250→      <Modal\n   251→        isOpen={selectedHistory !== null}\n   252→        onClose={() => setSelectedHistory(null)}\n   253→        title=\"Round Details\"\n   254→      >\n   255→        {selectedHistory && (() => {\n   256→          const { round, userBet: bet, payout, won } = selectedHistory;\n   257→          const sideColor = SIDE_COLORS[bet.side];\n   258→\n   259→          return (\n   260→            <div className=\"close-call-history-modal\">\n   261→              {/* Round stats */}\n   262→              <div className=\"close-call-history-modal__section\">\n   263→                <h4 className=\"close-call-history-modal__section-title\">Round Stats</h4>\n   264→                <div className=\"close-call-history-modal__row\">\n   265→                  <span>Your Side</span>\n   266→                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n   267→                    {bet.side.toUpperCase()}\n   268→                  </span>\n   269→                </div>\n   270→                <div className=\"close-call-history-modal__row\">\n   271→                  <span>Your Stake</span>\n   272→                  <span>{`${bet.amount.toFixed(4)} SOL`}</span>\n   273→                </div>\n   274→                <div className=\"close-call-history-modal__row\">\n   275→                  <span>Outcome</span>\n   276→                  <span\n   277→                    style={{\n   278→                      color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   279→                      textShadow: round.outcome ? `0 0 4px ${SIDE_COLORS[round.outcome]}` : undefined,\n   280→                    }}\n   281→                  >\n   282→                    {round.outcome?.toUpperCase() ?? \"?\"}\n   283→                  </span>\n   284→                </div>\n   285→                <div className=\"close-call-history-modal__row\">\n   286→                  <span>Result</span>\n   287→                  <span style={{ color: won ? SIDE_COLORS.green : \"#d45d5d\" }}>\n   288→                    {won ? \"WON!\" : \"LOST\"}\n   289→                  </span>\n   290→                </div>\n   291→                <div className=\"close-call-history-modal__row close-call-history-modal__row--highlight\">\n   292→                  <span>Payout</span>\n   293→                  <span className={won ? \"close-call-history-modal__highlight\" : \"\"}>\n   294→                    {won ? `+${payout.toFixed(4)} SOL` : `-${bet.amount.toFixed(4)} SOL`}\n   295→                  </span>\n   296→                </div>\n   297→              </div>\n   298→\n   299→              {/* Candle data */}\n   300→              {round.resultCandle && (\n   301→                <div className=\"close-call-history-modal__section\">\n   302→                  <h4 className=\"close-call-history-modal__section-title\">Candle Data</h4>\n   303→                  <div className=\"close-call-history-modal__row\">\n   304→                    <span>Open</span>\n   305→                    <span>${round.resultCandle.open.toFixed(2)}</span>\n   306→                  </div>\n   307→                  <div className=\"close-call-history-modal__row\">\n   308→                    <span>Close</span>\n   309→                    <span>${round.resultCandle.close.toFixed(2)}</span>\n   310→                  </div>\n   311→                  <div className=\"close-call-history-modal__row\">\n   312→                    <span>Change</span>\n   313→                    <span\n   314→                      style={{\n   315→                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   316→                      }}\n   317→                    >\n   318→                      {round.outcome === \"green\" ? \"+\" : \"\"}\n   319→                      {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n   320→                    </span>\n   321→                  </div>\n   322→                </div>\n   323→              )}\n   324→\n   325→              {/* Round info (oracle-resolved, no commit-reveal) */}\n   326→              <div className=\"close-call-history-modal__section\">\n   327→                <h4 className=\"close-call-history-modal__section-title\">\n   328→                  <span className=\"close-call-history-modal__lock\">🔒</span>\n   329→                  Oracle Verification\n   330→                </h4>\n   331→                <div className=\"close-call-history-modal__row\">\n   332→                  <span>Round ID</span>\n   333→                  <span className=\"close-call-history-modal__hash\" title={round.id}>\n   334→                    {round.id}\n   335→                  </span>\n   336→                </div>\n   337→                <div className=\"close-call-history-modal__row\">\n   338→                  <span>Oracle</span>\n   339→                  <span className=\"close-call-history-modal__hash\">Pyth BTC/USD</span>\n   340→                </div>\n   341→                {round.settleTx && (\n   342→                  <div className=\"close-call-history-modal__row\">\n   343→                    <span>Settlement Tx</span>\n   344→                    <span className=\"close-call-history-modal__hash close-call-history-modal__hash--revealed\" title={round.settleTx}>\n   345→                      {round.settleTx}\n   346→                    </span>\n   347→                  </div>\n   348→                )}\n   349→              </div>\n   350→\n   351→              {/* Verify link */}\n   352→              <a href=\"/fairness\" className=\"close-call-history-modal__verify-link\">\n   353→                Verify on Fairness Page →\n   354→              </a>\n   355→            </div>\n   356→          );\n   357→        })()}\n   358→      </Modal>\n   359→    </>\n   360→  );\n   361→}\n   362→\n   363→export function CloseCallPage() {\n   364→  return (\n   365→    <CloseCallProvider>\n   366→      <CloseCallPageContent />\n   367→    </CloseCallProvider>\n   368→  );\n   369→}\n   370→"}]},"parent_tool_use_id":null,"session_id":"89d4f6ce-bf36-4167-ba30-a196c35784b5","uuid":"32bb0426-8f28-43c7-8d2d-749a6bce10fb","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/pages/CloseCallPage.tsx","content":"import { useState } from \"react\";\nimport { GameLayout, Modal, RoundResultBanner, type HistoryEntry } from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport {\n  CloseCallProvider,\n  useCloseCall,\n  CandlestickChart,\n  BetAmountInput,\n  SideSelector,\n  PoolDistribution,\n  SIDE_COLORS,\n  type UserRoundHistory,\n  type BetSide,\n} from \"../features/close-call\";\n\nfunction CloseCallPageContent() {\n  const { connected, connect, getBalance, address } = useWallet();\n  const {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    potentialPayout,\n    clearCompletedRound,\n  } = useCloseCall();\n\n  // State for history modal\n  const [selectedHistory, setSelectedHistory] = useState<UserRoundHistory | null>(null);\n\n  // Get user's bet in the completed round (if any)\n  const completedRoundUserBet = completedRound && address\n    ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n        (b) => b.address === address\n      ) ?? null\n    : null;\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((entry) => {\n    const sideColor = SIDE_COLORS[entry.userBet.side];\n    const outcomeColor = entry.won ? SIDE_COLORS.green : \"#d45d5d\";\n\n    return {\n      roundId: entry.round.id.slice(-8),\n      result: (\n        <span className=\"close-call-history-result\">\n          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n            {entry.userBet.side.toUpperCase()}\n          </span>\n          <span className=\"close-call-history-result__separator\">|</span>\n          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {entry.won ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: entry.won ? entry.payout : -entry.userBet.amount,\n      timestamp: new Date(entry.round.resolvedAt ?? entry.round.createdAt),\n      verified: true,\n      won: entry.won,\n      onClick: () => setSelectedHistory(entry),\n    };\n  });\n\n  // Handle placing bet with side selection\n  const handlePlaceBetWithSide = async (side: BetSide) => {\n    setPendingSide(side);\n    try {\n      await placeBet(side);\n    } catch (error) {\n      console.error(\"Failed to place bet:\", error);\n    }\n  };\n\n  // Determine if betting window is open (round is open and within betting time)\n  const isBettingOpen = currentRound?.phase === \"open\" && Date.now() < (currentRound?.bettingEndsAt ?? 0);\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"close-call-sidebar\">\n      {/* Bet amount input */}\n      <div className=\"close-call-sidebar__section\">\n        <BetAmountInput\n          value={pendingAmount}\n          onChange={setPendingAmount}\n          onAdjust={adjustBetAmount}\n          disabled={placingBet || !!userBet}\n          maxAmount={getBalance?.() ?? 10}\n        />\n      </div>\n\n      {/* Side selector - buttons place bets directly */}\n      <div className=\"close-call-sidebar__section\">\n        {!connected ? (\n          <button\n            type=\"button\"\n            className=\"close-call-action-btn\"\n            onClick={connect}\n          >\n            Connect Wallet\n          </button>\n        ) : (\n          <SideSelector\n            selectedSide={userBet?.side ?? pendingSide}\n            onSelect={handlePlaceBetWithSide}\n            disabled={!isBettingOpen || placingBet || pendingAmount <= 0 || !!userBet}\n            placingBet={placingBet}\n          />\n        )}\n      </div>\n\n      {/* Pool distribution - under the buttons */}\n      {currentRound && (\n        <div className=\"close-call-sidebar__section\">\n          <PoolDistribution\n            pool={currentRound.pool}\n            userBet={userBet}\n            potentialPayout={potentialPayout}\n            roundOutcome={currentRound.outcome}\n            isRoundComplete={currentRound.phase === \"settled\" || currentRound.phase === \"refunded\"}\n          />\n        </div>\n      )}\n\n      {/* Auto-payout message for winners - shown under prize pool */}\n      {completedRound && (() => {\n        const completedUserBet = address\n          ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n              (b) => b.address === address\n            ) ?? null\n          : null;\n        const isWinner = completedUserBet && completedRound.winners?.includes(completedUserBet.address);\n        const payout = completedUserBet && completedRound.payouts?.[completedUserBet.address];\n\n        if (isWinner && payout) {\n          return (\n            <div className=\"close-call-payout-received\">\n              <span className=\"close-call-payout-received__label\">Payout Received!</span>\n              <span className=\"close-call-payout-received__amount\">{`+${payout.toFixed(4)} SOL`}</span>\n            </div>\n          );\n        }\n        return null;\n      })()}\n\n      {/* Round info */}\n      {currentRound && (\n        <div className=\"close-call-sidebar__fairness\">\n          <h4 className=\"close-call-sidebar__fairness-title\">Round Info</h4>\n          <div className=\"close-call-sidebar__fairness-row\">\n            <span>Round ID</span>\n            <span className=\"close-call-sidebar__hash\" title={currentRound.id}>\n              {currentRound.id.slice(-12)}\n            </span>\n          </div>\n          <div className=\"close-call-sidebar__fairness-row\">\n            <span>Oracle</span>\n            <span className=\"close-call-sidebar__hash\">Pyth BTC/USD</span>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Close Call\"\n        gameDescription=\"A pari-mutuel prediction market game\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"close-call-main\">\n          {/* Result banner - positioned above the chart */}\n          {completedRound && (() => {\n            const outcome = completedRound.outcome;\n            const isUserWinner = completedRoundUserBet && completedRound.winners?.includes(completedRoundUserBet.address);\n            const userPayout = completedRoundUserBet && completedRound.payouts?.[completedRoundUserBet.address];\n            const outcomeColor = outcome === \"green\"\n              ? SIDE_COLORS.green\n              : outcome === \"red\"\n              ? SIDE_COLORS.red\n              : SIDE_COLORS.refund;\n\n            return (\n              <RoundResultBanner\n                outcomeText={outcome === \"refund\" ? \"REFUND\" : `${outcome?.toUpperCase()} WINS`}\n                outcomeColor={outcomeColor}\n                userWon={!!isUserWinner}\n                userLost={!!completedRoundUserBet && !isUserWinner && outcome !== \"refund\"}\n                statusText={\n                  !completedRoundUserBet\n                    ? undefined\n                    : isUserWinner\n                    ? \"You Won!\"\n                    : outcome === \"refund\"\n                    ? \"Bet refunded\"\n                    : \"You Lost\"\n                }\n                payoutAmount={\n                  completedRoundUserBet\n                    ? isUserWinner\n                      ? userPayout ?? undefined\n                      : outcome === \"refund\"\n                      ? undefined\n                      : -completedRoundUserBet.amount\n                    : undefined\n                }\n                onDismiss={clearCompletedRound}\n              />\n            );\n          })()}\n\n          {/* Banner: betting on current candle */}\n          <div className=\"close-call-main__banner\">\n            <span>\n              Will the current candle close{\" \"}\n              <span style={{ color: SIDE_COLORS.green }}>GREEN</span> or{\" \"}\n              <span style={{ color: SIDE_COLORS.red }}>RED</span>?\n            </span>\n          </div>\n\n          {/* Candlestick chart */}\n          {!loading && recentCandles.length > 0 ? (\n            <CandlestickChart\n              candles={recentCandles}\n              currentPrice={currentPrice}\n              progress={candleProgress}\n            />\n          ) : (\n            <div className=\"close-call-main__loading\">\n              <div className=\"close-call-main__spinner\" />\n              <span>Loading chart...</span>\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* History detail modal */}\n      <Modal\n        isOpen={selectedHistory !== null}\n        onClose={() => setSelectedHistory(null)}\n        title=\"Round Details\"\n      >\n        {selectedHistory && (() => {\n          const { round, userBet: bet, payout, won } = selectedHistory;\n          const sideColor = SIDE_COLORS[bet.side];\n\n          return (\n            <div className=\"close-call-history-modal\">\n              {/* Round stats */}\n              <div className=\"close-call-history-modal__section\">\n                <h4 className=\"close-call-history-modal__section-title\">Round Stats</h4>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {bet.side.toUpperCase()}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Your Stake</span>\n                  <span>{`${bet.amount.toFixed(4)} SOL`}</span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    style={{\n                      color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n                      textShadow: round.outcome ? `0 0 4px ${SIDE_COLORS[round.outcome]}` : undefined,\n                    }}\n                  >\n                    {round.outcome?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Result</span>\n                  <span style={{ color: won ? SIDE_COLORS.green : \"#d45d5d\" }}>\n                    {won ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row close-call-history-modal__row--highlight\">\n                  <span>Payout</span>\n                  <span className={won ? \"close-call-history-modal__highlight\" : \"\"}>\n                    {won ? `+${payout.toFixed(4)} SOL` : `-${bet.amount.toFixed(4)} SOL`}\n                  </span>\n                </div>\n              </div>\n\n              {/* Candle data */}\n              {round.resultCandle && (\n                <div className=\"close-call-history-modal__section\">\n                  <h4 className=\"close-call-history-modal__section-title\">Candle Data</h4>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Open</span>\n                    <span>${round.resultCandle.open.toFixed(2)}</span>\n                  </div>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Close</span>\n                    <span>${round.resultCandle.close.toFixed(2)}</span>\n                  </div>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Change</span>\n                    <span\n                      style={{\n                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n                      }}\n                    >\n                      {round.outcome === \"green\" ? \"+\" : \"\"}\n                      {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n                    </span>\n                  </div>\n                </div>\n              )}\n\n              {/* Round info (oracle-resolved, no commit-reveal) */}\n              <div className=\"close-call-history-modal__section\">\n                <h4 className=\"close-call-history-modal__section-title\">\n                  <span className=\"close-call-history-modal__lock\">🔒</span>\n                  Oracle Verification\n                </h4>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Round ID</span>\n                  <span className=\"close-call-history-modal__hash\" title={round.id}>\n                    {round.id}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Oracle</span>\n                  <span className=\"close-call-history-modal__hash\">Pyth BTC/USD</span>\n                </div>\n                {round.settleTx && (\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Settlement Tx</span>\n                    <span className=\"close-call-history-modal__hash close-call-history-modal__hash--revealed\" title={round.settleTx}>\n                      {round.settleTx}\n                    </span>\n                  </div>\n                )}\n              </div>\n\n              {/* Verify link */}\n              <a href=\"/fairness\" className=\"close-call-history-modal__verify-link\">\n                Verify on Fairness Page →\n              </a>\n            </div>\n          );\n        })()}\n      </Modal>\n    </>\n  );\n}\n\nexport function CloseCallPage() {\n  return (\n    <CloseCallProvider>\n      <CloseCallPageContent />\n    </CloseCallProvider>\n  );\n}\n","numLines":370,"startLine":1,"totalLines":370}}}
