{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JMRnC8G5MZiBKUshUA9Pe7","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createAuthRoutes } from \"./routes/auth.js\";\n    15→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    16→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    17→import { createSettlementWorker } from \"./worker/settlement.js\";\n    18→import { settleRound } from \"./worker/settle-tx.js\";\n    19→import { createRetrySettler } from \"./worker/retry.js\";\n    20→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    21→import { logger } from \"./logger.js\";\n    22→\n    23→const config = loadConfig();\n    24→\n    25→// Shared postgres connection for both game DB and auth DB\n    26→const sql = postgres(config.databaseUrl);\n    27→const db = createDb(config.databaseUrl);\n    28→const authDb = createAuthDb(sql);\n    29→\n    30→const connection = new Connection(config.rpcUrl, {\n    31→  commitment: \"confirmed\",\n    32→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    33→});\n    34→\n    35→const app = new Hono();\n    36→\n    37→app.use(\n    38→  \"*\",\n    39→  cors({\n    40→    origin: \"*\",\n    41→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    42→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    43→  }),\n    44→);\n    45→\n    46→// Request logging — correlate frontend fetch timing with server-side processing\n    47→app.use(\"*\", async (c, next) => {\n    48→  const start = Date.now();\n    49→  await next();\n    50→  const ms = Date.now() - start;\n    51→  const method = c.req.method;\n    52→  const path = c.req.path;\n    53→  // Skip noisy health checks and OPTIONS preflight\n    54→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    55→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    56→});\n    57→\n    58→// Auth routes — no JWT middleware (these are the login endpoints)\n    59→// Lighter rate limiting by IP for auth endpoints\n    60→app.use(\n    61→  \"/auth/*\",\n    62→  createRateLimitMiddleware({\n    63→    perWallet: 20,\n    64→    global: config.rateLimitGlobal,\n    65→    windowMs: 60_000,\n    66→  }),\n    67→);\n    68→\n    69→app.route(\n    70→  \"/auth\",\n    71→  createAuthRoutes({\n    72→    authDb,\n    73→    jwtSecret: config.jwtSecret,\n    74→    cluster: config.cluster,\n    75→    challengeTtlSeconds: config.challengeTtlSeconds,\n    76→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    77→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    78→  }),\n    79→);\n    80→\n    81→// JWT auth middleware for fairness endpoints\n    82→app.use(\n    83→  \"/fairness/*\",\n    84→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n    85→);\n    86→\n    87→// Rate limiting — per-wallet and global limits on POST requests\n    88→app.use(\n    89→  \"/fairness/*\",\n    90→  createRateLimitMiddleware({\n    91→    perWallet: config.rateLimitPerWallet,\n    92→    global: config.rateLimitGlobal,\n    93→    windowMs: 60_000,\n    94→  }),\n    95→);\n    96→\n    97→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n    98→const entropyAccount = new PublicKey(config.entropyAccount);\n    99→const retrySettler = createRetrySettler({\n   100→  db,\n   101→  connection,\n   102→  settleRound: (pda) =>\n   103→    settleRound(\n   104→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n   105→      pda,\n   106→    ),\n   107→});\n   108→\n   109→// PDA watcher — WebSocket-based instant join detection\n   110→const pdaWatcher = createPdaWatcher({\n   111→  connection,\n   112→  serverKey: config.serverKeypair.publicKey,\n   113→  onJoinDetected: async (pda, targetSlot) => {\n   114→    // Update DB phase if still in 'created'\n   115→    const round = await db.getRoundByPda(pda);\n   116→    if (round && round.phase === \"created\") {\n   117→      await db.updateRoundPhase(pda, \"locked\", {\n   118→        target_slot: targetSlot.toString(),\n   119→      });\n   120→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   121→        targetSlot: targetSlot.toString(),\n   122→        source: \"pda-watcher\",\n   123→        game: round.game,\n   124→      });\n   125→    }\n   126→\n   127→    // Check if target slot already passed — settle immediately if so\n   128→    const currentSlot = await connection.getSlot();\n   129→    if (BigInt(currentSlot) >= targetSlot) {\n   130→      await retrySettler.attemptSettle(pda);\n   131→      pdaWatcher.unwatch(pda);\n   132→    }\n   133→    // If target slot not reached yet, poll worker will pick it up next cycle\n   134→  },\n   135→});\n   136→\n   137→const worker = createSettlementWorker({\n   138→  db,\n   139→  connection,\n   140→  serverKey: config.serverKeypair.publicKey,\n   141→  pollIntervalMs: config.workerPollIntervalMs,\n   142→  onSettleReady: async (pda) => {\n   143→    await retrySettler.attemptSettle(pda);\n   144→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   145→  },\n   146→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   147→});\n   148→worker.start();\n   149→\n   150→// Coinflip fairness routes\n   151→app.route(\n   152→  \"/fairness/coinflip\",\n   153→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   154→);\n   155→app.route(\n   156→  \"/fairness/lord\",\n   157→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   158→);\n   159→\n   160→// Close Call routes (read-only — clock worker handles round lifecycle)\n   161→app.route(\"/closecall\", createCloseCallRoutes({ db }));\n   162→\n   163→// Round verification routes\n   164→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   165→\n   166→// Health endpoint — wired after worker exists so we can query its status\n   167→app.route(\n   168→  \"/health\",\n   169→  createHealthRoutes({\n   170→    db,\n   171→    connection,\n   172→    serverKey: config.serverKeypair.publicKey,\n   173→    isWorkerRunning: () => worker.isRunning,\n   174→    minSolBalance: config.minSolBalance,\n   175→  }),\n   176→);\n   177→\n   178→const port = config.port;\n   179→logger.info(\"fairness-backend started\", { port });\n   180→\n   181→serve({\n   182→  fetch: app.fetch,\n   183→  port,\n   184→});\n   185→\n   186→export default {\n   187→  port,\n   188→  fetch: app.fetch,\n   189→};\n   190→"}]},"parent_tool_use_id":null,"session_id":"2e376739-eb09-46f7-a274-ef7ba5202edd","uuid":"870f0bb2-c8bd-409f-8b23-aa5ebe947b1c","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { cors } from \"hono/cors\";\nimport { serve } from \"@hono/node-server\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport postgres from \"postgres\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createAuthDb } from \"./auth-db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createLordRoutes } from \"./routes/lord-create.js\";\nimport { createRoundsRoutes } from \"./routes/rounds.js\";\nimport { createCloseCallRoutes } from \"./routes/closecall.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createAuthRoutes } from \"./routes/auth.js\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Shared postgres connection for both game DB and auth DB\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new Hono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\",\n    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// JWT auth middleware for fairness endpoints\napp.use(\n  \"/fairness/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/fairness/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/fairness/lord\",\n  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Close Call routes (read-only — clock worker handles round lifecycle)\napp.route(\"/closecall\", createCloseCallRoutes({ db }));\n\n// Round verification routes\napp.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    db,\n    connection,\n    serverKey: config.serverKeypair.publicKey,\n    isWorkerRunning: () => worker.isRunning,\n    minSolBalance: config.minSolBalance,\n  }),\n);\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", { port });\n\nserve({\n  fetch: app.fetch,\n  port,\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":190,"startLine":1,"totalLines":190}}}
