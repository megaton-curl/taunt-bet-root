{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C5ftiCQ86EPjF6hh92655r","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3→\n     4→export interface Config {\n     5→  port: number;\n     6→  databaseUrl: string;\n     7→  dbSchema: string;\n     8→  rpcUrl: string;\n     9→  wsRpcUrl: string | undefined;\n    10→  serverKeypair: Keypair;\n    11→  jwtSecret: Uint8Array;\n    12→  cluster: string;\n    13→  challengeTtlSeconds: number;\n    14→  accessTokenTtlSeconds: number;\n    15→  refreshTokenTtlDays: number;\n    16→  rateLimitPerWallet: number;\n    17→  rateLimitGlobal: number;\n    18→  workerPollIntervalMs: number;\n    19→  entropyAccount: string;\n    20→  minSolBalance: number;\n    21→}\n    22→\n    23→function requireEnv(name: string): string {\n    24→  const value = process.env[name];\n    25→  if (!value) {\n    26→    throw new Error(`Missing required environment variable: ${name}`);\n    27→  }\n    28→  return value;\n    29→}\n    30→\n    31→function parseKeypair(raw: string): Keypair {\n    32→  try {\n    33→    const bytes = JSON.parse(raw) as number[];\n    34→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    35→  } catch {\n    36→    throw new Error(\n    37→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    38→    );\n    39→  }\n    40→}\n    41→\n    42→export function loadConfig(): Config {\n    43→  const dbSchema = loadDbSchemaFromEnv();\n    44→\n    45→  return {\n    46→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    47→    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    48→    dbSchema,\n    49→    rpcUrl: requireEnv(\"RPC_URL\"),\n    50→    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    51→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    52→    jwtSecret: (() => {\n    53→      const explicit = process.env.JWT_SECRET;\n    54→      if (explicit) return new TextEncoder().encode(explicit);\n    55→      // Derive from first 32 bytes of server keypair secret key\n    56→      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    57→      return kp.secretKey.slice(0, 32);\n    58→    })(),\n    59→    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    60→    challengeTtlSeconds: parseInt(\n    61→      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    62→      10,\n    63→    ),\n    64→    accessTokenTtlSeconds: parseInt(\n    65→      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    66→      10,\n    67→    ),\n    68→    refreshTokenTtlDays: parseInt(\n    69→      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    70→      10,\n    71→    ),\n    72→    rateLimitPerWallet: parseInt(\n    73→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    74→      10,\n    75→    ),\n    76→    rateLimitGlobal: parseInt(\n    77→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    78→      10,\n    79→    ),\n    80→    workerPollIntervalMs: parseInt(\n    81→      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    82→      10,\n    83→    ),\n    84→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    85→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    86→  };\n    87→}\n    88→"}]},"parent_tool_use_id":"toolu_01FthPhFvpT6rVHourJSW1Lf","session_id":"2e376739-eb09-46f7-a274-ef7ba5202edd","uuid":"df4ee11c-3d38-40e3-87fd-f4998e7a1662"}
