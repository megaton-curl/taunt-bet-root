{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014ceLLbzUCH2x5SKdZMgPiH","type":"tool_result","content":"     1→export const DEFAULT_DB_SCHEMA = \"public\";\n     2→\n     3→function normalizeSchema(schema: string): string {\n     4→  return schema.trim() || DEFAULT_DB_SCHEMA;\n     5→}\n     6→\n     7→export function loadDbSchemaFromEnv(\n     8→  env: Record<string, string | undefined> = process.env,\n     9→): string {\n    10→  return normalizeSchema(env.DB_SCHEMA ?? DEFAULT_DB_SCHEMA);\n    11→}\n    12→\n    13→export function applyDbSchemaToUrl(databaseUrl: string, schema: string): string {\n    14→  const normalizedSchema = normalizeSchema(schema);\n    15→  if (normalizedSchema === DEFAULT_DB_SCHEMA) {\n    16→    return databaseUrl;\n    17→  }\n    18→\n    19→  const url = new URL(databaseUrl);\n    20→  const existingOptions = url.searchParams.get(\"options\");\n    21→  const searchPathOption = `-csearch_path=${normalizedSchema}`;\n    22→\n    23→  if (existingOptions) {\n    24→    const hasSearchPath = existingOptions.includes(\"search_path=\");\n    25→    url.searchParams.set(\n    26→      \"options\",\n    27→      hasSearchPath\n    28→        ? existingOptions.replace(/-csearch_path=[^\\s]+/, searchPathOption)\n    29→        : `${existingOptions} ${searchPathOption}`,\n    30→    );\n    31→  } else {\n    32→    url.searchParams.set(\"options\", searchPathOption);\n    33→  }\n    34→\n    35→  return url.toString();\n    36→}\n    37→"}]},"parent_tool_use_id":"toolu_01FthPhFvpT6rVHourJSW1Lf","session_id":"2e376739-eb09-46f7-a274-ef7ba5202edd","uuid":"1f57a8b6-b02e-4573-b6ca-ad1a56333bff"}
