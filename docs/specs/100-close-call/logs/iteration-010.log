{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RxCwsivepZTWcPyhFRojv5","type":"tool_result","content":"     1→/**\n     2→ * Pari-Mutuel Payout Calculator for Close Call\n     3→ *\n     4→ * Formula:\n     5→ *   totalPool = greenPool + redPool + carryoverPool\n     6→ *   netPool = totalPool × 0.97 (3% fee)\n     7→ *   playerPayout = (playerBet / winningPool) × netPool\n     8→ */\n     9→\n    10→import type { BetSide, CandleOutcome, Candle, PoolState } from \"../types\";\n    11→import { PLATFORM_FEE, DOJI_THRESHOLD_BPS } from \"../types\";\n    12→\n    13→export interface PayoutResult {\n    14→  winner: BetSide | null;\n    15→  payouts: Record<string, number>;\n    16→  totalPayout: number;\n    17→  platformFee: number;\n    18→  carryoverToNext: number;\n    19→}\n    20→\n    21→/**\n    22→ * Determine the outcome of a candle\n    23→ */\n    24→export function determineOutcome(candle: Candle): CandleOutcome {\n    25→  const diff = candle.close - candle.open;\n    26→  const threshold = candle.open * (DOJI_THRESHOLD_BPS / 10000);\n    27→\n    28→  if (Math.abs(diff) <= threshold) {\n    29→    return \"doji\";\n    30→  }\n    31→\n    32→  return diff > 0 ? \"green\" : \"red\";\n    33→}\n    34→\n    35→/**\n    36→ * Calculate payouts for all winners\n    37→ */\n    38→export function calculatePayouts(\n    39→  pool: PoolState,\n    40→  outcome: CandleOutcome,\n    41→  carryoverAmount: number = 0\n    42→): PayoutResult {\n    43→  const totalPool = pool.totalPool + carryoverAmount;\n    44→\n    45→  // Handle DOJI - no winners, pool carries over\n    46→  if (outcome === \"doji\") {\n    47→    const fee = pool.totalPool * PLATFORM_FEE;\n    48→    return {\n    49→      winner: null,\n    50→      payouts: {},\n    51→      totalPayout: 0,\n    52→      platformFee: fee,\n    53→      carryoverToNext: totalPool - fee,\n    54→    };\n    55→  }\n    56→\n    57→  // Determine winning side\n    58→  const winner: BetSide = outcome;\n    59→  const winningBets = outcome === \"green\" ? pool.greenBets : pool.redBets;\n    60→  const winningPool = outcome === \"green\" ? pool.greenPool : pool.redPool;\n    61→\n    62→  // Handle edge case: no bets on winning side\n    63→  if (winningPool === 0 || winningBets.length === 0) {\n    64→    // All funds carry over (minus fee on current round bets)\n    65→    const fee = pool.totalPool * PLATFORM_FEE;\n    66→    return {\n    67→      winner,\n    68→      payouts: {},\n    69→      totalPayout: 0,\n    70→      platformFee: fee,\n    71→      carryoverToNext: totalPool - fee,\n    72→    };\n    73→  }\n    74→\n    75→  // Calculate platform fee (only on current round's bets, not carryover)\n    76→  const platformFee = pool.totalPool * PLATFORM_FEE;\n    77→  const netPool = totalPool - platformFee;\n    78→\n    79→  // Calculate individual payouts\n    80→  const payouts: Record<string, number> = {};\n    81→  let totalPayout = 0;\n    82→\n    83→  for (const bet of winningBets) {\n    84→    const share = bet.amount / winningPool;\n    85→    const payout = netPool * share;\n    86→    payouts[bet.address] = payout;\n    87→    totalPayout += payout;\n    88→  }\n    89→\n    90→  return {\n    91→    winner,\n    92→    payouts,\n    93→    totalPayout,\n    94→    platformFee,\n    95→    carryoverToNext: 0,\n    96→  };\n    97→}\n    98→\n    99→/**\n   100→ * Calculate potential payout for a hypothetical bet\n   101→ */\n   102→export function calculatePotentialPayout(\n   103→  betAmount: number,\n   104→  betSide: BetSide,\n   105→  pool: PoolState,\n   106→  carryoverAmount: number = 0\n   107→): number {\n   108→  // Calculate what the pool would look like with this bet\n   109→  const newWinningPool =\n   110→    betSide === \"green\" ? pool.greenPool + betAmount : pool.redPool + betAmount;\n   111→  const newTotalPool = pool.totalPool + betAmount + carryoverAmount;\n   112→  const netPool = newTotalPool * (1 - PLATFORM_FEE);\n   113→\n   114→  // Player's share of winning pool\n   115→  const share = betAmount / newWinningPool;\n   116→\n   117→  return netPool * share;\n   118→}\n   119→\n   120→/**\n   121→ * Calculate odds multiplier for a side\n   122→ * Returns how much $1 would win (e.g., 2.0 means double your money)\n   123→ */\n   124→export function calculateOddsMultiplier(\n   125→  side: BetSide,\n   126→  pool: PoolState,\n   127→  carryoverAmount: number = 0\n   128→): number {\n   129→  const winningPool = side === \"green\" ? pool.greenPool : pool.redPool;\n   130→  const totalPool = pool.totalPool + carryoverAmount;\n   131→\n   132→  if (winningPool === 0 || totalPool === 0) {\n   133→    return 0;\n   134→  }\n   135→\n   136→  const netPool = totalPool * (1 - PLATFORM_FEE);\n   137→  return netPool / winningPool;\n   138→}\n   139→\n   140→/**\n   141→ * Calculate percentage of pool on each side\n   142→ */\n   143→export function calculatePoolDistribution(pool: PoolState): {\n   144→  greenPercent: number;\n   145→  redPercent: number;\n   146→} {\n   147→  if (pool.totalPool === 0) {\n   148→    return { greenPercent: 50, redPercent: 50 };\n   149→  }\n   150→\n   151→  return {\n   152→    greenPercent: (pool.greenPool / pool.totalPool) * 100,\n   153→    redPercent: (pool.redPool / pool.totalPool) * 100,\n   154→  };\n   155→}\n   156→\n   157→/**\n   158→ * Format amount for display\n   159→ */\n   160→export function formatAmount(amount: number, decimals: number = 4): string {\n   161→  return amount.toFixed(decimals);\n   162→}\n   163→\n   164→/**\n   165→ * Format USD amount for display\n   166→ */\n   167→export function formatUsd(amount: number): string {\n   168→  return amount.toLocaleString(\"en-US\", {\n   169→    style: \"currency\",\n   170→    currency: \"USD\",\n   171→    minimumFractionDigits: 2,\n   172→    maximumFractionDigits: 2,\n   173→  });\n   174→}\n   175→"}]},"parent_tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b","uuid":"c54e81df-9855-41bf-af62-b69d0efc5a76"}
