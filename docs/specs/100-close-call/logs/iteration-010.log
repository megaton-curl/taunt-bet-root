{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Uj1fXSpuydrJxt1w5KMc5i","type":"tool_result","content":"     1→import type { PoolState, PlayerBet, CandleOutcome } from \"../types\";\n     2→import { SIDE_COLORS, PLATFORM_FEE } from \"../types\";\n     3→\n     4→interface PoolDistributionProps {\n     5→  pool: PoolState;\n     6→  carryoverAmount?: number;\n     7→  userBet?: PlayerBet | null;\n     8→  potentialPayout?: number;\n     9→  roundOutcome?: CandleOutcome | null;\n    10→  isRoundComplete?: boolean;\n    11→}\n    12→\n    13→export function PoolDistribution({\n    14→  pool,\n    15→  carryoverAmount = 0,\n    16→  userBet,\n    17→  potentialPayout = 0,\n    18→  roundOutcome,\n    19→  isRoundComplete = false,\n    20→}: PoolDistributionProps) {\n    21→  // Determine if user won or lost\n    22→  const userWon = isRoundComplete && userBet && roundOutcome && userBet.side === roundOutcome;\n    23→  const userLost = isRoundComplete && userBet && roundOutcome && roundOutcome !== \"doji\" && userBet.side !== roundOutcome;\n    24→  const totalPool = pool.totalPool + carryoverAmount;\n    25→\n    26→  // Calculate percentages\n    27→  const greenPercent = pool.totalPool > 0 ? (pool.greenPool / pool.totalPool) * 100 : 50;\n    28→  const redPercent = pool.totalPool > 0 ? (pool.redPool / pool.totalPool) * 100 : 50;\n    29→\n    30→  // Calculate odds multiplier for each side\n    31→  const netPool = totalPool * (1 - PLATFORM_FEE);\n    32→  const greenOdds = pool.greenPool > 0 ? netPool / pool.greenPool : 0;\n    33→  const redOdds = pool.redPool > 0 ? netPool / pool.redPool : 0;\n    34→\n    35→  // Format odds display\n    36→  const formatOdds = (odds: number): string => {\n    37→    if (odds === 0) return \"∞\";\n    38→    return `${odds.toFixed(2)}x`;\n    39→  };\n    40→\n    41→  return (\n    42→    <div className=\"close-call-pool-bar\">\n    43→      {/* Percentages only - no GREEN/RED labels */}\n    44→      <div className=\"close-call-pool-bar__labels\">\n    45→        <span\n    46→          className=\"close-call-pool-bar__label close-call-pool-bar__label--green\"\n    47→          style={{ color: SIDE_COLORS.green }}\n    48→        >\n    49→          {greenPercent.toFixed(0)}%\n    50→        </span>\n    51→        <span\n    52→          className=\"close-call-pool-bar__label close-call-pool-bar__label--red\"\n    53→          style={{ color: SIDE_COLORS.red }}\n    54→        >\n    55→          {redPercent.toFixed(0)}%\n    56→        </span>\n    57→      </div>\n    58→\n    59→      {/* Progress bar */}\n    60→      <div className=\"close-call-pool-bar__track\">\n    61→        <div\n    62→          className=\"close-call-pool-bar__fill close-call-pool-bar__fill--green\"\n    63→          style={{\n    64→            width: `${greenPercent}%`,\n    65→            backgroundColor: SIDE_COLORS.green,\n    66→          }}\n    67→        />\n    68→        <div\n    69→          className=\"close-call-pool-bar__fill close-call-pool-bar__fill--red\"\n    70→          style={{\n    71→            width: `${redPercent}%`,\n    72→            backgroundColor: SIDE_COLORS.red,\n    73→          }}\n    74→        />\n    75→      </div>\n    76→\n    77→      {/* Pool amounts and multipliers */}\n    78→      <div className=\"close-call-pool-bar__stats\">\n    79→        <div className=\"close-call-pool-bar__stat close-call-pool-bar__stat--green\">\n    80→          <span className=\"close-call-pool-bar__pool-amount\" style={{ color: SIDE_COLORS.green }}>\n    81→            {\"$\" + pool.greenPool.toFixed(2)}\n    82→          </span>\n    83→          <span className=\"close-call-pool-bar__odds\" style={{ color: SIDE_COLORS.green }}>\n    84→            ~{formatOdds(greenOdds)}\n    85→          </span>\n    86→        </div>\n    87→        <div className=\"close-call-pool-bar__stat close-call-pool-bar__stat--red\">\n    88→          <span className=\"close-call-pool-bar__pool-amount\" style={{ color: SIDE_COLORS.red }}>\n    89→            {\"$\" + pool.redPool.toFixed(2)}\n    90→          </span>\n    91→          <span className=\"close-call-pool-bar__odds\" style={{ color: SIDE_COLORS.red }}>\n    92→            ~{formatOdds(redOdds)}\n    93→          </span>\n    94→        </div>\n    95→      </div>\n    96→\n    97→      {/* Prize Pool - striking display */}\n    98→      <div className=\"close-call-pool-bar__prize\">\n    99→        <div className=\"close-call-pool-bar__prize-label\">PRIZE POOL</div>\n   100→        <div className=\"close-call-pool-bar__prize-amount\">\n   101→          <span className=\"close-call-pool-bar__prize-sol\">{\"$\" + totalPool.toFixed(2)}</span>\n   102→        </div>\n   103→        {carryoverAmount > 0 && (\n   104→          <div className=\"close-call-pool-bar__prize-jackpot\">\n   105→            {\"+$\" + carryoverAmount.toFixed(2)} jackpot\n   106→          </div>\n   107→        )}\n   108→\n   109→        {/* User's bet stats when they have an active bet */}\n   110→        {userBet && (\n   111→          <div className={`close-call-pool-bar__user-bet ${userWon ? \"close-call-pool-bar__user-bet--won\" : \"\"} ${userLost ? \"close-call-pool-bar__user-bet--lost\" : \"\"}`}>\n   112→            {/* Win animation */}\n   113→            {userWon && (\n   114→              <div className=\"close-call-pool-bar__win-animation\">\n   115→                <div className=\"close-call-pool-bar__stars\">\n   116→                  {[...Array(6)].map((_, i) => (\n   117→                    <span key={i} className=\"close-call-pool-bar__star\" style={{ \"--star-index\": i } as React.CSSProperties}>★</span>\n   118→                  ))}\n   119→                </div>\n   120→                <div className=\"close-call-pool-bar__coins\">\n   121→                  {[...Array(4)].map((_, i) => (\n   122→                    <span key={i} className=\"close-call-pool-bar__coin\" style={{ \"--coin-index\": i } as React.CSSProperties}>●</span>\n   123→                  ))}\n   124→                </div>\n   125→              </div>\n   126→            )}\n   127→\n   128→            {/* Loss animation */}\n   129→            {userLost && (\n   130→              <div className=\"close-call-pool-bar__loss-animation\">\n   131→                <span className=\"close-call-pool-bar__heartbreak\">💔</span>\n   132→              </div>\n   133→            )}\n   134→\n   135→            {/* Header: Joined GREEN/RED */}\n   136→            <div\n   137→              className=\"close-call-pool-bar__user-bet-header\"\n   138→              style={{ color: SIDE_COLORS[userBet.side] }}\n   139→            >\n   140→              Joined {userBet.side.toUpperCase()}\n   141→            </div>\n   142→\n   143→            {/* Amount row */}\n   144→            <div className=\"close-call-pool-bar__user-bet-row\">\n   145→              <span className=\"close-call-pool-bar__user-bet-label\">Amount</span>\n   146→              <span className=\"close-call-pool-bar__user-bet-value\">\n   147→                {\"$\" + userBet.amount.toFixed(2)}\n   148→              </span>\n   149→            </div>\n   150→\n   151→            {/* Potential Payout row */}\n   152→            {potentialPayout > 0 && (\n   153→              <div className=\"close-call-pool-bar__user-bet-row close-call-pool-bar__user-bet-row--payout\">\n   154→                <span className=\"close-call-pool-bar__user-bet-label\">\n   155→                  {userWon ? \"Payout\" : \"Potential Payout\"}\n   156→                </span>\n   157→                <span className={`close-call-pool-bar__user-bet-value ${userWon ? \"close-call-pool-bar__user-bet-value--won\" : \"\"}`}>\n   158→                  {\"$\" + potentialPayout.toFixed(2)}\n   159→                </span>\n   160→              </div>\n   161→            )}\n   162→          </div>\n   163→        )}\n   164→      </div>\n   165→    </div>\n   166→  );\n   167→}\n   168→"}]},"parent_tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b","uuid":"b164d337-2c40-4600-b4fa-f36525a3441d"}
