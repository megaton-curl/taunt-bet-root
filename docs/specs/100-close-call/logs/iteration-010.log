{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L7GhxJx3gdeWQ37GufPxqy","type":"tool_result","content":"     1→import { useEffect, useState } from \"react\";\n     2→import type { Round, PlayerBet } from \"../types\";\n     3→import { SIDE_COLORS } from \"../types\";\n     4→\n     5→interface RoundResultOverlayProps {\n     6→  round: Round;\n     7→  userBet: PlayerBet | null;\n     8→  onClose: () => void;\n     9→}\n    10→\n    11→export function RoundResultOverlay({\n    12→  round,\n    13→  userBet,\n    14→  onClose,\n    15→}: RoundResultOverlayProps) {\n    16→  const [isVisible, setIsVisible] = useState(false);\n    17→\n    18→  // Animate in\n    19→  useEffect(() => {\n    20→    const timer = setTimeout(() => setIsVisible(true), 50);\n    21→    return () => clearTimeout(timer);\n    22→  }, []);\n    23→\n    24→  // Auto-close after delay\n    25→  useEffect(() => {\n    26→    const timer = setTimeout(() => {\n    27→      setIsVisible(false);\n    28→      setTimeout(onClose, 300);\n    29→    }, 5000);\n    30→\n    31→    return () => clearTimeout(timer);\n    32→  }, [onClose]);\n    33→\n    34→  // Determine result\n    35→  const outcome = round.outcome;\n    36→  const isUserWinner = userBet && round.winners?.includes(userBet.address);\n    37→  const userPayout = userBet && round.payouts?.[userBet.address];\n    38→\n    39→  // Get outcome color\n    40→  const outcomeColor = outcome === \"green\"\n    41→    ? SIDE_COLORS.green\n    42→    : outcome === \"red\"\n    43→    ? SIDE_COLORS.red\n    44→    : SIDE_COLORS.doji;\n    45→\n    46→  // Get result text\n    47→  const getResultText = () => {\n    48→    if (!userBet) {\n    49→      if (outcome === \"doji\") return \"DOJI - Pool Carries Over!\";\n    50→      return `${outcome?.toUpperCase()} WINS!`;\n    51→    }\n    52→\n    53→    if (outcome === \"doji\") {\n    54→      return \"DOJI - No Winner!\";\n    55→    }\n    56→\n    57→    if (isUserWinner) {\n    58→      return \"YOU WON!\";\n    59→    }\n    60→\n    61→    return \"YOU LOST\";\n    62→  };\n    63→\n    64→  // Get payout text\n    65→  const getPayoutText = () => {\n    66→    if (!userBet) return null;\n    67→\n    68→    if (outcome === \"doji\") {\n    69→      return \"Pool carries over to next round\";\n    70→    }\n    71→\n    72→    if (isUserWinner && userPayout != null) {\n    73→      const profit = userPayout - userBet.amount;\n    74→      return `+$${userPayout.toFixed(4)} (+$${profit.toFixed(4)} profit)`;\n    75→    }\n    76→\n    77→    return `-$${userBet.amount.toFixed(4)}`;\n    78→  };\n    79→\n    80→  return (\n    81→    <div\n    82→      className={`close-call-result-overlay ${isVisible ? \"close-call-result-overlay--visible\" : \"\"}`}\n    83→      onClick={onClose}\n    84→    >\n    85→      <div\n    86→        className={`close-call-result-overlay__content ${\n    87→          outcome === \"doji\"\n    88→            ? \"close-call-result-overlay__content--doji\"\n    89→            : isUserWinner\n    90→            ? \"close-call-result-overlay__content--win\"\n    91→            : \"close-call-result-overlay__content--loss\"\n    92→        }`}\n    93→        onClick={(e) => e.stopPropagation()}\n    94→      >\n    95→        {/* Win Animation - Coin fountain */}\n    96→        {isUserWinner && (\n    97→          <div className=\"close-call-win-animation\">\n    98→            <div className=\"close-call-win-animation__stars\">\n    99→              {[...Array(8)].map((_, i) => (\n   100→                <span key={i} className=\"close-call-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n   101→              ))}\n   102→            </div>\n   103→            <div className=\"close-call-win-animation__coins\">\n   104→              {[...Array(6)].map((_, i) => (\n   105→                <span key={i} className=\"close-call-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n   106→              ))}\n   107→            </div>\n   108→          </div>\n   109→        )}\n   110→\n   111→        {/* Candle result visualization */}\n   112→        <div className=\"close-call-result-overlay__candle\">\n   113→          <div\n   114→            className={`close-call-result-overlay__candle-body close-call-result-overlay__candle-body--${outcome}`}\n   115→            style={{ backgroundColor: outcomeColor }}\n   116→          />\n   117→        </div>\n   118→\n   119→        {/* Result text */}\n   120→        <div\n   121→          className=\"close-call-result-overlay__result\"\n   122→          style={{ color: outcomeColor }}\n   123→        >\n   124→          {getResultText()}\n   125→        </div>\n   126→\n   127→        {/* Payout */}\n   128→        {userBet && (\n   129→          <div\n   130→            className={`close-call-result-overlay__payout ${\n   131→              isUserWinner ? \"close-call-result-overlay__payout--win\" : \"\"\n   132→            }`}\n   133→          >\n   134→            {getPayoutText()}\n   135→          </div>\n   136→        )}\n   137→\n   138→        {/* Candle details */}\n   139→        {round.resultCandle && (\n   140→          <div className=\"close-call-result-overlay__details\">\n   141→            <div className=\"close-call-result-overlay__price\">\n   142→              Open: ${round.resultCandle.open.toFixed(2)}\n   143→            </div>\n   144→            <div className=\"close-call-result-overlay__price\">\n   145→              Close: ${round.resultCandle.close.toFixed(2)}\n   146→            </div>\n   147→            <div\n   148→              className=\"close-call-result-overlay__change\"\n   149→              style={{ color: outcomeColor }}\n   150→            >\n   151→              {outcome === \"green\" ? \"+\" : outcome === \"red\" ? \"\" : \"~\"}\n   152→              {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n   153→            </div>\n   154→          </div>\n   155→        )}\n   156→\n   157→        {/* Fairness data */}\n   158→        <div className=\"close-call-result-overlay__fairness\">\n   159→          <div className=\"close-call-result-overlay__fairness-row\">\n   160→            <span>Round ID</span>\n   161→            <span className=\"close-call-result-overlay__hash\">\n   162→              {round.id.slice(-12)}\n   163→            </span>\n   164→          </div>\n   165→          {round.serverSeed && (\n   166→            <div className=\"close-call-result-overlay__fairness-row\">\n   167→              <span>Server Seed</span>\n   168→              <span className=\"close-call-result-overlay__hash close-call-result-overlay__hash--revealed\">\n   169→                {round.serverSeed.slice(0, 8)}...{round.serverSeed.slice(-4)}\n   170→              </span>\n   171→            </div>\n   172→          )}\n   173→        </div>\n   174→\n   175→        {/* Close button */}\n   176→        <button\n   177→          type=\"button\"\n   178→          className=\"close-call-result-overlay__close\"\n   179→          onClick={onClose}\n   180→        >\n   181→          Continue\n   182→        </button>\n   183→      </div>\n   184→    </div>\n   185→  );\n   186→}\n   187→"}]},"parent_tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b","uuid":"6e3ce1bd-a53b-411b-9f83-978e0badf642"}
{"type":"system","subtype":"task_progress","task_id":"a96054d48851d6fb2","tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","description":"Reading sources/rng-utopia/apps/platform/src/features/close-call/utils/mock-simulation.ts","usage":{"total_tokens":50412,"tool_uses":13,"duration_ms":12833},"last_tool_name":"Read","uuid":"77ee7006-5c2b-474e-8a65-0aec3b707644","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_016kNnxHagHnNeEwuKXSJ4CA","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RDfQYAUpLBqEe8sHGEa9He","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/utils/mock-simulation.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":11122,"cache_read_input_tokens":39229,"cache_creation":{"ephemeral_5m_input_tokens":11122,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b","uuid":"8256ec84-c5f9-4e67-a526-31665867cad6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RDfQYAUpLBqEe8sHGEa9He","type":"tool_result","content":"     1→/**\n     2→ * Mock Simulation for Close Call\n     3→ *\n     4→ * Manages round lifecycle, betting, and settlement in mock mode.\n     5→ */\n     6→\n     7→import type {\n     8→  Round,\n     9→  BetSide,\n    10→  Candle,\n    11→  PlayerBet,\n    12→  PoolState,\n    13→  UserRoundHistory,\n    14→} from \"../types\";\n    15→import { BETTING_WINDOW_MS, MIN_BET_AMOUNT, MAX_BET_AMOUNT } from \"../types\";\n    16→import { getReplayEngine, type CandleReplayEngine } from \"./candle-replay\";\n    17→import { calculatePayouts, determineOutcome } from \"./payout-calculator\";\n    18→import { emitCloseCallComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\n    19→import { emitCloseCallResults } from \"../../player-profile/utils/profile-event-bus\";\n    20→\n    21→// ============ Store ============\n    22→\n    23→interface MockStore {\n    24→  currentRound: Round | null;\n    25→  completedRound: Round | null; // Most recently completed round (for result display)\n    26→  roundHistory: Round[];\n    27→  userHistory: Map<string, UserRoundHistory[]>;\n    28→  listeners: Set<(round: Round) => void>;\n    29→  completedListeners: Set<(round: Round) => void>;\n    30→  carryoverAmount: number;\n    31→  replayEngine: CandleReplayEngine | null;\n    32→  serverSeeds: Map<string, { serverSeed: string; blockHash: string }>;\n    33→  mockBetTimers: ReturnType<typeof setTimeout>[];\n    34→  isInitialized: boolean;\n    35→}\n    36→\n    37→const store: MockStore = {\n    38→  currentRound: null,\n    39→  completedRound: null,\n    40→  roundHistory: [],\n    41→  userHistory: new Map(),\n    42→  listeners: new Set(),\n    43→  completedListeners: new Set(),\n    44→  carryoverAmount: 0,\n    45→  replayEngine: null,\n    46→  serverSeeds: new Map(),\n    47→  mockBetTimers: [],\n    48→  isInitialized: false,\n    49→};\n    50→\n    51→// ============ Fairness Data ============\n    52→\n    53→// Generate a mock hex string (simulates SHA-256 hash or seed)\n    54→function generateMockHexString(length: number = 64): string {\n    55→  const chars = \"0123456789abcdef\";\n    56→  let result = \"\";\n    57→  for (let i = 0; i < length; i++) {\n    58→    result += chars[Math.floor(Math.random() * chars.length)];\n    59→  }\n    60→  return result;\n    61→}\n    62→\n    63→function generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string } {\n    64→  const serverSeed = generateMockHexString(64); // 256-bit seed\n    65→  const seedHash = generateMockHexString(64);   // SHA-256 hash of server seed\n    66→  const blockHash = generateMockHexString(64);  // Block hash\n    67→\n    68→  return { seedHash, serverSeed, blockHash };\n    69→}\n    70→\n    71→function generateRoundId(): string {\n    72→  return `cc-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n    73→}\n    74→\n    75→// ============ Mock Address Generation ============\n    76→\n    77→const MOCK_ADDRESSES = [\n    78→  \"7xKQ...nM4p\", \"3vBr...8sYq\", \"9aZm...kL2x\", \"5hTn...jR7w\",\n    79→  \"2cVp...9fGd\", \"8kLm...4nHs\", \"1qWe...6bYt\", \"4rTy...0mXz\",\n    80→  \"6uIo...2pAw\", \"0oKj...5nBv\", \"Ax7K...mN3p\", \"Bv8L...nO4q\",\n    81→  \"Cw9M...oP5r\", \"Dx0N...pQ6s\", \"Ey1O...qR7t\", \"Fz2P...rS8u\",\n    82→];\n    83→\n    84→function generateMockAddress(): string {\n    85→  const index = Math.floor(Math.random() * MOCK_ADDRESSES.length);\n    86→  return MOCK_ADDRESSES[index]!;\n    87→}\n    88→\n    89→// ============ Round Management ============\n    90→\n    91→function createEmptyPool(): PoolState {\n    92→  return {\n    93→    greenPool: 0,\n    94→    redPool: 0,\n    95→    totalPool: 0,\n    96→    playerCount: 0,\n    97→    greenBets: [],\n    98→    redBets: [],\n    99→  };\n   100→}\n   101→\n   102→function createNewRound(targetCandleTime: number): Round {\n   103→  const fairnessData = generateFairnessData();\n   104→  const roundId = generateRoundId();\n   105→\n   106→  store.serverSeeds.set(roundId, {\n   107→    serverSeed: fairnessData.serverSeed,\n   108→    blockHash: fairnessData.blockHash,\n   109→  });\n   110→\n   111→  const round: Round = {\n   112→    id: roundId,\n   113→    phase: \"betting\",\n   114→    pool: createEmptyPool(),\n   115→    createdAt: Date.now(),\n   116→    bettingEndsAt: Date.now() + BETTING_WINDOW_MS, // Betting window is first 10 seconds\n   117→    targetCandleTime,\n   118→    carryoverAmount: store.carryoverAmount,\n   119→    seedHash: fairnessData.seedHash,\n   120→  };\n   121→\n   122→  store.currentRound = round;\n   123→  notifyListeners(round);\n   124→\n   125→  // Schedule mock bets\n   126→  scheduleMockBets(round.id);\n   127→\n   128→  return round;\n   129→}\n   130→\n   131→function lockRound(): void {\n   132→  if (!store.currentRound) return;\n   133→  if (store.currentRound.phase !== \"betting\") return;\n   134→\n   135→  store.currentRound.phase = \"locked\";\n   136→  notifyListeners(store.currentRound);\n   137→\n   138→  // Clear any pending mock bet timers\n   139→  clearMockBetTimers();\n   140→}\n   141→\n   142→function resolveRound(resultCandle: Candle): void {\n   143→  if (!store.currentRound) return;\n   144→  if (store.currentRound.phase !== \"locked\") return;\n   145→\n   146→  const round = store.currentRound;\n   147→  round.phase = \"resolving\";\n   148→  round.resultCandle = resultCandle;\n   149→  notifyListeners(round);\n   150→\n   151→  // Determine outcome\n   152→  const outcome = determineOutcome(resultCandle);\n   153→  round.outcome = outcome;\n   154→\n   155→  // Reveal server seed\n   156→  const secrets = store.serverSeeds.get(round.id);\n   157→  if (secrets) {\n   158→    round.serverSeed = secrets.serverSeed;\n   159→    round.blockHash = secrets.blockHash;\n   160→  }\n   161→\n   162→  // Calculate payouts\n   163→  const payoutResult = calculatePayouts(round.pool, outcome, round.carryoverAmount);\n   164→  round.winners = Object.keys(payoutResult.payouts);\n   165→  round.payouts = payoutResult.payouts;\n   166→  round.payoutAmount = payoutResult.totalPayout;\n   167→\n   168→  // Update carryover for next round\n   169→  store.carryoverAmount = payoutResult.carryoverToNext;\n   170→\n   171→  // Complete the round immediately (don't wait - new round may have started)\n   172→  round.phase = \"complete\";\n   173→  round.resolvedAt = Date.now();\n   174→\n   175→  // Store as completed round for result display\n   176→  store.completedRound = { ...round, pool: { ...round.pool } };\n   177→\n   178→  // Archive round\n   179→  store.roundHistory.unshift(round);\n   180→\n   181→  // Update user histories\n   182→  updateUserHistories(round);\n   183→\n   184→  // Clean up server seed\n   185→  store.serverSeeds.delete(round.id);\n   186→\n   187→  // Notify completed round listeners\n   188→  notifyCompletedListeners(store.completedRound);\n   189→\n   190→  // Emit event for Boss Raid\n   191→  const allBets = [...round.pool.greenBets, ...round.pool.redBets].map((b) => ({\n   192→    address: b.address,\n   193→    amount: b.amount,\n   194→  }));\n   195→  if (allBets.length > 0) {\n   196→    emitCloseCallComplete(round.id, allBets);\n   197→  }\n   198→\n   199→  // Emit event for Player Profile (XP and stats tracking)\n   200→  const profileResults = [...round.pool.greenBets, ...round.pool.redBets].map((bet) => {\n   201→    const payout = round.payouts?.[bet.address] ?? 0;\n   202→    const won = payout > 0;\n   203→    return {\n   204→      address: bet.address,\n   205→      wager: bet.amount,\n   206→      outcome: (won ? \"win\" : \"loss\") as \"win\" | \"loss\",\n   207→      payout,\n   208→    };\n   209→  });\n   210→  if (profileResults.length > 0) {\n   211→    emitCloseCallResults(round.id, profileResults);\n   212→  }\n   213→}\n   214→\n   215→function updateUserHistories(round: Round): void {\n   216→  const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n   217→\n   218→  for (const bet of allBets) {\n   219→    const payout = round.payouts?.[bet.address] ?? 0;\n   220→    const won = payout > 0;\n   221→\n   222→    const historyEntry: UserRoundHistory = {\n   223→      round,\n   224→      userBet: bet,\n   225→      payout,\n   226→      won,\n   227→    };\n   228→\n   229→    const userHistory = store.userHistory.get(bet.address) ?? [];\n   230→    userHistory.unshift(historyEntry);\n   231→    store.userHistory.set(bet.address, userHistory);\n   232→  }\n   233→}\n   234→\n   235→// ============ Betting ============\n   236→\n   237→export function placeBet(playerAddress: string, side: BetSide, amount: number): Round {\n   238→  const round = store.currentRound;\n   239→\n   240→  if (!round) {\n   241→    throw new Error(\"No active round\");\n   242→  }\n   243→\n   244→  if (round.phase !== \"betting\") {\n   245→    throw new Error(\"Betting is closed for this round\");\n   246→  }\n   247→\n   248→  if (amount < MIN_BET_AMOUNT) {\n   249→    throw new Error(`Minimum bet is $${MIN_BET_AMOUNT}`);\n   250→  }\n   251→\n   252→  if (amount > MAX_BET_AMOUNT) {\n   253→    throw new Error(`Maximum bet is $${MAX_BET_AMOUNT}`);\n   254→  }\n   255→\n   256→  // Check for existing bet\n   257→  const existingBet = [...round.pool.greenBets, ...round.pool.redBets].find(\n   258→    (b) => b.address === playerAddress\n   259→  );\n   260→\n   261→  if (existingBet) {\n   262→    throw new Error(\"You have already bet on this round\");\n   263→  }\n   264→\n   265→  // Create bet\n   266→  const bet: PlayerBet = {\n   267→    address: playerAddress,\n   268→    side,\n   269→    amount,\n   270→    timestamp: Date.now(),\n   271→  };\n   272→\n   273→  // Add to pool\n   274→  if (side === \"green\") {\n   275→    round.pool.greenBets.push(bet);\n   276→    round.pool.greenPool += amount;\n   277→  } else {\n   278→    round.pool.redBets.push(bet);\n   279→    round.pool.redPool += amount;\n   280→  }\n   281→\n   282→  round.pool.totalPool += amount;\n   283→  round.pool.playerCount++;\n   284→\n   285→  // Emit wager placed event (triggers RNG buff chest drop check)\n   286→  emitWagerPlaced(\"close-call\", round.id, playerAddress, amount);\n   287→\n   288→  notifyListeners(round);\n   289→  return round;\n   290→}\n   291→\n   292→// ============ Mock Bets ============\n   293→\n   294→function scheduleMockBets(roundId: string): void {\n   295→  clearMockBetTimers();\n   296→\n   297→  // Schedule 3-7 mock bets within the 10 second betting window\n   298→  const betCount = 3 + Math.floor(Math.random() * 5);\n   299→  const bettingDuration = BETTING_WINDOW_MS - 1000; // Leave 1s buffer before lock\n   300→\n   301→  for (let i = 0; i < betCount; i++) {\n   302→    const delay = Math.random() * bettingDuration;\n   303→    const timer = setTimeout(() => {\n   304→      if (store.currentRound?.id !== roundId) return;\n   305→      if (store.currentRound?.phase !== \"betting\") return;\n   306→\n   307→      addMockBet();\n   308→    }, delay);\n   309→\n   310→    store.mockBetTimers.push(timer);\n   311→  }\n   312→}\n   313→\n   314→function addMockBet(): void {\n   315→  if (!store.currentRound || store.currentRound.phase !== \"betting\") return;\n   316→\n   317→  const address = generateMockAddress();\n   318→\n   319→  // Check if this mock address already bet\n   320→  const existingBet = [\n   321→    ...store.currentRound.pool.greenBets,\n   322→    ...store.currentRound.pool.redBets,\n   323→  ].find((b) => b.address === address);\n   324→\n   325→  if (existingBet) return;\n   326→\n   327→  // Random side (slightly biased toward current minority for balance)\n   328→  const greenRatio =\n   329→    store.currentRound.pool.totalPool > 0\n   330→      ? store.currentRound.pool.greenPool / store.currentRound.pool.totalPool\n   331→      : 0.5;\n   332→\n   333→  // Bias toward minority side for more balanced pools\n   334→  const greenProbability = greenRatio < 0.5 ? 0.6 : 0.4;\n   335→  const side: BetSide = Math.random() < greenProbability ? \"green\" : \"red\";\n   336→\n   337→  // Random amount (weighted toward smaller bets)\n   338→  const amount = Math.round((0.05 + Math.random() * Math.random() * 2) * 1000) / 1000;\n   339→\n   340→  try {\n   341→    placeBet(address, side, Math.max(MIN_BET_AMOUNT, amount));\n   342→  } catch {\n   343→    // Ignore bet errors for mock bets\n   344→  }\n   345→}\n   346→\n   347→function clearMockBetTimers(): void {\n   348→  for (const timer of store.mockBetTimers) {\n   349→    clearTimeout(timer);\n   350→  }\n   351→  store.mockBetTimers = [];\n   352→}\n   353→\n   354→// ============ Subscription ============\n   355→\n   356→function notifyListeners(round: Round): void {\n   357→  const roundCopy = { ...round, pool: { ...round.pool } };\n   358→  for (const listener of store.listeners) {\n   359→    try {\n   360→      listener(roundCopy);\n   361→    } catch (error) {\n   362→      console.error(\"Listener error:\", error);\n   363→    }\n   364→  }\n   365→}\n   366→\n   367→function notifyCompletedListeners(round: Round): void {\n   368→  const roundCopy = { ...round, pool: { ...round.pool } };\n   369→  for (const listener of store.completedListeners) {\n   370→    try {\n   371→      listener(roundCopy);\n   372→    } catch (error) {\n   373→      console.error(\"Completed listener error:\", error);\n   374→    }\n   375→  }\n   376→}\n   377→\n   378→export function subscribeToRound(callback: (round: Round) => void): () => void {\n   379→  store.listeners.add(callback);\n   380→\n   381→  // Immediately emit current round if exists\n   382→  if (store.currentRound) {\n   383→    callback({ ...store.currentRound, pool: { ...store.currentRound.pool } });\n   384→  }\n   385→\n   386→  return () => {\n   387→    store.listeners.delete(callback);\n   388→  };\n   389→}\n   390→\n   391→export function subscribeToCompletedRound(callback: (round: Round) => void): () => void {\n   392→  store.completedListeners.add(callback);\n   393→\n   394→  return () => {\n   395→    store.completedListeners.delete(callback);\n   396→  };\n   397→}\n   398→\n   399→// ============ Game Initialization ============\n   400→\n   401→export function initializeGame(): void {\n   402→  if (store.isInitialized) return;\n   403→\n   404→  store.replayEngine = getReplayEngine();\n   405→\n   406→  store.replayEngine.start({\n   407→    onCandleStart: (candle) => {\n   408→      // Resolve any pending round from previous candle\n   409→      if (store.currentRound?.phase === \"locked\" && store.currentRound.resultCandle) {\n   410→        // Already resolved via onCandleComplete\n   411→      }\n   412→\n   413→      // Create new round - users bet on THIS candle's outcome\n   414→      createNewRound(candle.openTime);\n   415→    },\n   416→\n   417→    onCandleComplete: (candle) => {\n   418→      // Resolve current round when candle closes\n   419→      if (store.currentRound?.phase === \"locked\") {\n   420→        resolveRound(candle);\n   421→      } else if (store.currentRound?.phase === \"betting\") {\n   422→        // If still in betting (shouldn't happen), lock first then resolve\n   423→        lockRound();\n   424→        resolveRound(candle);\n   425→      }\n   426→    },\n   427→\n   428→    onPriceTick: () => {\n   429→      // Auto-lock after 10 second betting window\n   430→      if (store.currentRound?.phase === \"betting\") {\n   431→        if (Date.now() >= store.currentRound.bettingEndsAt) {\n   432→          lockRound();\n   433→        }\n   434→      }\n   435→    },\n   436→  });\n   437→\n   438→  store.isInitialized = true;\n   439→}\n   440→\n   441→export function stopGame(): void {\n   442→  if (store.replayEngine) {\n   443→    store.replayEngine.stop();\n   444→  }\n   445→  clearMockBetTimers();\n   446→  store.isInitialized = false;\n   447→}\n   448→\n   449→// ============ Getters ============\n   450→\n   451→export function getCurrentRound(): Round | null {\n   452→  return store.currentRound;\n   453→}\n   454→\n   455→export function getCompletedRound(): Round | null {\n   456→  return store.completedRound;\n   457→}\n   458→\n   459→export function clearCompletedRound(): void {\n   460→  store.completedRound = null;\n   461→}\n   462→\n   463→export function getRoundHistory(): Round[] {\n   464→  return store.roundHistory;\n   465→}\n   466→\n   467→export function getUserHistory(address: string): UserRoundHistory[] {\n   468→  return store.userHistory.get(address) ?? [];\n   469→}\n   470→\n   471→export function getCarryoverAmount(): number {\n   472→  return store.carryoverAmount;\n   473→}\n   474→\n   475→export function getRecentCandles(count: number = 15): Candle[] {\n   476→  if (!store.replayEngine) return [];\n   477→  return store.replayEngine.getCandlesUpToCurrent(count);\n   478→}\n   479→\n   480→export function getCurrentCandle(): Candle | null {\n   481→  if (!store.replayEngine) return null;\n   482→  return store.replayEngine.getCurrentCandle();\n   483→}\n   484→\n   485→export function getCandleProgress(): number {\n   486→  if (!store.replayEngine) return 0;\n   487→  return store.replayEngine.getProgress();\n   488→}\n   489→\n   490→export function getTimeRemaining(): number {\n   491→  if (!store.replayEngine) return 0;\n   492→  return store.replayEngine.getTimeRemaining();\n   493→}\n   494→\n   495→export function isGameInitialized(): boolean {\n   496→  return store.isInitialized;\n   497→}\n   498→\n   499→// ============ Utility ============\n   500→\n   501→export function truncateAddress(address: string): string {\n   502→  if (address.length <= 10) return address;\n   503→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n   504→}\n   505→"}]},"parent_tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b","uuid":"f2397470-0c7e-48bd-adaa-3ad37e34eff2"}
