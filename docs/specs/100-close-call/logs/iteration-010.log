{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T3ourqRTUm35haQEK3Dsst","type":"tool_result","content":"     1→import type { Round, PlayerBet } from \"../types\";\n     2→import { SIDE_COLORS, PLATFORM_FEE } from \"../types\";\n     3→\n     4→interface ActiveBetViewProps {\n     5→  round: Round;\n     6→  userBet: PlayerBet;\n     7→}\n     8→\n     9→export function ActiveBetView({ round, userBet }: ActiveBetViewProps) {\n    10→  // Calculate potential payout\n    11→  const winningPool = userBet.side === \"green\" ? round.pool.greenPool : round.pool.redPool;\n    12→  const totalPool = round.pool.totalPool + round.carryoverAmount;\n    13→  const netPool = totalPool * (1 - PLATFORM_FEE);\n    14→\n    15→  const potentialPayout = winningPool > 0 ? (userBet.amount / winningPool) * netPool : 0;\n    16→  const potentialProfit = potentialPayout - userBet.amount;\n    17→  const multiplier = userBet.amount > 0 ? potentialPayout / userBet.amount : 0;\n    18→\n    19→  // Get side color\n    20→  const sideColor = SIDE_COLORS[userBet.side];\n    21→\n    22→  // Phase display text\n    23→  const getPhaseText = () => {\n    24→    switch (round.phase) {\n    25→      case \"betting\":\n    26→        return \"Waiting for candle...\";\n    27→      case \"locked\":\n    28→        return \"Bets locked - watching candle...\";\n    29→      case \"resolving\":\n    30→        return \"Determining outcome...\";\n    31→      case \"complete\":\n    32→        return \"Round complete\";\n    33→      default:\n    34→        return \"\";\n    35→    }\n    36→  };\n    37→\n    38→  return (\n    39→    <div className=\"close-call-active-bet\">\n    40→      <div className=\"close-call-active-bet__header\">\n    41→        <h3 className=\"close-call-active-bet__title\">Your Active Bet</h3>\n    42→        <span\n    43→          className=\"close-call-active-bet__phase\"\n    44→          data-phase={round.phase}\n    45→        >\n    46→          {getPhaseText()}\n    47→        </span>\n    48→      </div>\n    49→\n    50→      <div className=\"close-call-active-bet__card\">\n    51→        <div className=\"close-call-active-bet__side\" style={{ color: sideColor }}>\n    52→          <span className=\"close-call-active-bet__side-icon\">\n    53→            {userBet.side === \"green\" ? \"▲\" : \"▼\"}\n    54→          </span>\n    55→          <span className=\"close-call-active-bet__side-label\">\n    56→            {userBet.side.toUpperCase()}\n    57→          </span>\n    58→        </div>\n    59→\n    60→        <div className=\"close-call-active-bet__details\">\n    61→          <div className=\"close-call-active-bet__row\">\n    62→            <span>Your Stake</span>\n    63→            <span>{\"$\" + userBet.amount.toFixed(2)}</span>\n    64→          </div>\n    65→          <div className=\"close-call-active-bet__row\">\n    66→            <span>Your Share</span>\n    67→            <span>\n    68→              {winningPool > 0\n    69→                ? ((userBet.amount / winningPool) * 100).toFixed(1)\n    70→                : 0}%\n    71→            </span>\n    72→          </div>\n    73→          <div className=\"close-call-active-bet__row close-call-active-bet__row--highlight\">\n    74→            <span>Potential Win</span>\n    75→            <span className=\"close-call-active-bet__payout\">\n    76→              {\"$\" + potentialPayout.toFixed(2)}\n    77→              <span className=\"close-call-active-bet__profit\">\n    78→                (+{\"$\" + potentialProfit.toFixed(2)})\n    79→              </span>\n    80→            </span>\n    81→          </div>\n    82→          <div className=\"close-call-active-bet__row\">\n    83→            <span>Multiplier</span>\n    84→            <span style={{ color: sideColor }}>{multiplier.toFixed(2)}x</span>\n    85→          </div>\n    86→        </div>\n    87→      </div>\n    88→\n    89→      {round.phase === \"betting\" && (\n    90→        <div className=\"close-call-active-bet__note\">\n    91→          Your odds may change as more bets come in\n    92→        </div>\n    93→      )}\n    94→\n    95→      {round.phase === \"locked\" && (\n    96→        <div className=\"close-call-active-bet__note close-call-active-bet__note--locked\">\n    97→          Odds are now locked. Good luck!\n    98→        </div>\n    99→      )}\n   100→    </div>\n   101→  );\n   102→}\n   103→"}]},"parent_tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b","uuid":"42bbfd80-bc0c-435b-9775-cdc49bf5fa2a"}
