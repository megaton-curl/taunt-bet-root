y-modal__section-title\">Candle Data</h4>\n   314→                  <div className=\"close-call-history-modal__row\">\n   315→                    <span>Open</span>\n   316→                    <span>${round.resultCandle.open.toFixed(2)}</span>\n   317→                  </div>\n   318→                  <div className=\"close-call-history-modal__row\">\n   319→                    <span>Close</span>\n   320→                    <span>${round.resultCandle.close.toFixed(2)}</span>\n   321→                  </div>\n   322→                  <div className=\"close-call-history-modal__row\">\n   323→                    <span>Change</span>\n   324→                    <span\n   325→                      style={{\n   326→                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   327→                      }}\n   328→                    >\n   329→                      {round.outcome === \"green\" ? \"+\" : \"\"}\n   330→                      {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n   331→                    </span>\n   332→                  </div>\n   333→                </div>\n   334→              )}\n   335→\n   336→              {/* Round fairness */}\n   337→              <div className=\"close-call-history-modal__section\">\n   338→                <h4 className=\"close-call-history-modal__section-title\">\n   339→                  <span className=\"close-call-history-modal__lock\">🔒</span>\n   340→                  Round Fairness\n   341→                </h4>\n   342→                <div className=\"close-call-history-modal__row\">\n   343→                  <span>Round ID</span>\n   344→                  <span className=\"close-call-history-modal__hash\" title={round.id}>\n   345→                    {round.id}\n   346→                  </span>\n   347→                </div>\n   348→                <div className=\"close-call-history-modal__row\">\n   349→                  <span>Seed Hash</span>\n   350→                  <span className=\"close-call-history-modal__hash\" title={round.seedHash}>\n   351→                    {round.seedHash}\n   352→                  </span>\n   353→                </div>\n   354→                {round.serverSeed && (\n   355→                  <div className=\"close-call-history-modal__row\">\n   356→                    <span>Server Seed</span>\n   357→                    <span\n   358→                      className=\"close-call-history-modal__hash close-call-history-modal__hash--revealed\"\n   359→                      title={round.serverSeed}\n   360→                    >\n   361→                      {round.serverSeed}\n   362→                    </span>\n   363→                  </div>\n   364→                )}\n   365→              </div>\n   366→\n   367→              {/* Verify link */}\n   368→              <a href=\"/fairness\" className=\"close-call-history-modal__verify-link\">\n   369→                Verify on Fairness Page →\n   370→              </a>\n   371→            </div>\n   372→          );\n   373→        })()}\n   374→      </Modal>\n   375→    </>\n   376→  );\n   377→}\n   378→\n   379→export function CloseCallPage() {\n   380→  return (\n   381→    <CloseCallProvider>\n   382→      <CloseCallPageContent />\n   383→    </CloseCallProvider>\n   384→  );\n   385→}\n   386→"}]},"parent_tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b","uuid":"901e8ebb-27e3-43c5-b844-53ff6273bac0"}
