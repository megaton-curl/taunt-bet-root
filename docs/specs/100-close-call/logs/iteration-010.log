{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011qr19FMJWm9cLUzgZThCZM","type":"tool_result","content":"     1→import type { BetSide } from \"../types\";\n     2→import { SIDE_COLORS } from \"../types\";\n     3→\n     4→interface SideSelectorProps {\n     5→  selectedSide: BetSide | null;\n     6→  onSelect: (side: BetSide) => void;\n     7→  disabled?: boolean;\n     8→  placingBet?: boolean;\n     9→}\n    10→\n    11→export function SideSelector({\n    12→  selectedSide,\n    13→  onSelect,\n    14→  disabled = false,\n    15→  placingBet = false,\n    16→}: SideSelectorProps) {\n    17→  const isGreenPlacing = placingBet && selectedSide === \"green\";\n    18→  const isRedPlacing = placingBet && selectedSide === \"red\";\n    19→\n    20→  return (\n    21→    <div className={`close-call-side-selector ${disabled ? \"close-call-side-selector--disabled\" : \"\"}`}>\n    22→      <button\n    23→        type=\"button\"\n    24→        className={`close-call-side-btn close-call-side-btn--green ${\n    25→          selectedSide === \"green\" ? \"close-call-side-btn--selected\" : \"\"\n    26→        }`}\n    27→        onClick={() => onSelect(\"green\")}\n    28→        disabled={disabled || isRedPlacing}\n    29→        style={{\n    30→          \"--side-color\": SIDE_COLORS.green,\n    31→        } as React.CSSProperties}\n    32→      >\n    33→        <div className=\"close-call-side-btn__label\">\n    34→          {isGreenPlacing ? \"Joining...\" : \"GREEN\"}\n    35→        </div>\n    36→      </button>\n    37→\n    38→      <button\n    39→        type=\"button\"\n    40→        className={`close-call-side-btn close-call-side-btn--red ${\n    41→          selectedSide === \"red\" ? \"close-call-side-btn--selected\" : \"\"\n    42→        }`}\n    43→        onClick={() => onSelect(\"red\")}\n    44→        disabled={disabled || isGreenPlacing}\n    45→        style={{\n    46→          \"--side-color\": SIDE_COLORS.red,\n    47→        } as React.CSSProperties}\n    48→      >\n    49→        <div className=\"close-call-side-btn__label\">\n    50→          {isRedPlacing ? \"Joining...\" : \"RED\"}\n    51→        </div>\n    52→      </button>\n    53→    </div>\n    54→  );\n    55→}\n    56→"}]},"parent_tool_use_id":"toolu_018VZUpFWDfsBM5qJv9yZcZu","session_id":"d5daa2fb-13cd-4249-820b-ad6ea49cbd9b","uuid":"3b4b4050-11e4-4614-95e7-2633c511bd12"}
