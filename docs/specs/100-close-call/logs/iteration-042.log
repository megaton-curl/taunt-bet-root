{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LwZ1uCPEBzzXebnrjSf1SY","type":"tool_result","content":"     1→import { useState } from \"react\";\n     2→import { Link } from \"react-router-dom\";\n     3→import { GameLayout, Modal, RoundResultBanner, type HistoryEntry } from \"@rng-utopia/ui\";\n     4→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     5→import {\n     6→  CloseCallProvider,\n     7→  useCloseCall,\n     8→  CandlestickChart,\n     9→  BetAmountInput,\n    10→  SideSelector,\n    11→  PoolDistribution,\n    12→  SIDE_COLORS,\n    13→  type UserRoundHistory,\n    14→  type BetSide,\n    15→} from \"../features/close-call\";\n    16→\n    17→function CloseCallPageContent() {\n    18→  const { connected, connect, getBalance, address } = useWallet();\n    19→  const {\n    20→    currentRound,\n    21→    completedRound,\n    22→    recentCandles,\n    23→    currentPrice,\n    24→    candleProgress,\n    25→    userHistory,\n    26→    pendingAmount,\n    27→    pendingSide,\n    28→    userBet,\n    29→    loading,\n    30→    placingBet,\n    31→    setPendingAmount,\n    32→    setPendingSide,\n    33→    placeBet,\n    34→    adjustBetAmount,\n    35→    potentialPayout,\n    36→    clearCompletedRound,\n    37→  } = useCloseCall();\n    38→\n    39→  // State for history modal\n    40→  const [selectedHistory, setSelectedHistory] = useState<UserRoundHistory | null>(null);\n    41→\n    42→  // Get user's bet in the completed round (if any)\n    43→  const completedRoundUserBet = completedRound && address\n    44→    ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n    45→        (b) => b.address === address\n    46→      ) ?? null\n    47→    : null;\n    48→\n    49→  // Convert user history to HistoryEntry format\n    50→  const historyEntries: HistoryEntry[] = userHistory.map((entry) => {\n    51→    const sideColor = SIDE_COLORS[entry.userBet.side];\n    52→    const outcomeColor = entry.won ? SIDE_COLORS.green : \"#d45d5d\";\n    53→\n    54→    return {\n    55→      roundId: entry.round.id.slice(-8),\n    56→      result: (\n    57→        <span className=\"close-call-history-result\">\n    58→          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n    59→            {entry.userBet.side.toUpperCase()}\n    60→          </span>\n    61→          <span className=\"close-call-history-result__separator\">|</span>\n    62→          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n    63→            {entry.won ? \"WON\" : \"LOST\"}\n    64→          </span>\n    65→        </span>\n    66→      ),\n    67→      payout: entry.won ? entry.payout : -entry.userBet.amount,\n    68→      timestamp: new Date(entry.round.resolvedAt ?? entry.round.createdAt),\n    69→      verified: true,\n    70→      won: entry.won,\n    71→      onClick: () => setSelectedHistory(entry),\n    72→    };\n    73→  });\n    74→\n    75→  // Handle placing bet with side selection\n    76→  const handlePlaceBetWithSide = async (side: BetSide) => {\n    77→    setPendingSide(side);\n    78→    try {\n    79→      await placeBet(side);\n    80→    } catch (error) {\n    81→      console.error(\"Failed to place bet:\", error);\n    82→    }\n    83→  };\n    84→\n    85→  // Determine if betting window is open (round is open and within betting time)\n    86→  const isBettingOpen = currentRound?.phase === \"open\" && Date.now() < (currentRound?.bettingEndsAt ?? 0);\n    87→\n    88→  // Sidebar content\n    89→  const sidebar = (\n    90→    <div className=\"close-call-sidebar\">\n    91→      {/* Bet amount input */}\n    92→      <div className=\"close-call-sidebar__section\">\n    93→        <BetAmountInput\n    94→          value={pendingAmount}\n    95→          onChange={setPendingAmount}\n    96→          onAdjust={adjustBetAmount}\n    97→          disabled={placingBet || !!userBet}\n    98→          maxAmount={getBalance?.() ?? 10}\n    99→        />\n   100→      </div>\n   101→\n   102→      {/* Side selector - buttons place bets directly */}\n   103→      <div className=\"close-call-sidebar__section\">\n   104→        {!connected ? (\n   105→          <button\n   106→            type=\"button\"\n   107→            className=\"close-call-action-btn\"\n   108→            onClick={connect}\n   109→          >\n   110→            Connect Wallet\n   111→          </button>\n   112→        ) : (\n   113→          <SideSelector\n   114→            selectedSide={userBet?.side ?? pendingSide}\n   115→            onSelect={handlePlaceBetWithSide}\n   116→            disabled={!isBettingOpen || placingBet || pendingAmount <= 0 || !!userBet}\n   117→            placingBet={placingBet}\n   118→          />\n   119→        )}\n   120→      </div>\n   121→\n   122→      {/* Pool distribution - under the buttons */}\n   123→      {currentRound && (\n   124→        <div className=\"close-call-sidebar__section\">\n   125→          <PoolDistribution\n   126→            pool={currentRound.pool}\n   127→            userBet={userBet}\n   128→            potentialPayout={potentialPayout}\n   129→            roundOutcome={currentRound.outcome}\n   130→            isRoundComplete={currentRound.phase === \"settled\" || currentRound.phase === \"refunded\"}\n   131→          />\n   132→        </div>\n   133→      )}\n   134→\n   135→      {/* Auto-payout message for winners - shown under prize pool */}\n   136→      {completedRound && (() => {\n   137→        const completedUserBet = address\n   138→          ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n   139→              (b) => b.address === address\n   140→            ) ?? null\n   141→          : null;\n   142→        const isWinner = completedUserBet && completedRound.winners?.includes(completedUserBet.address);\n   143→        const payout = completedUserBet && completedRound.payouts?.[completedUserBet.address];\n   144→\n   145→        if (isWinner && payout) {\n   146→          return (\n   147→            <div className=\"close-call-payout-received\">\n   148→              <span className=\"close-call-payout-received__label\">Payout Received!</span>\n   149→              <span className=\"close-call-payout-received__amount\">{`+${payout.toFixed(4)} SOL`}</span>\n   150→            </div>\n   151→          );\n   152→        }\n   153→        return null;\n   154→      })()}\n   155→\n   156→      {/* Round info */}\n   157→      {currentRound && (\n   158→        <div className=\"close-call-sidebar__fairness\">\n   159→          <h4 className=\"close-call-sidebar__fairness-title\">Round Info</h4>\n   160→          <div className=\"close-call-sidebar__fairness-row\">\n   161→            <span>Round ID</span>\n   162→            <span className=\"close-call-sidebar__hash\" title={currentRound.id}>\n   163→              {currentRound.id.slice(-12)}\n   164→            </span>\n   165→          </div>\n   166→          <div className=\"close-call-sidebar__fairness-row\">\n   167→            <span>Oracle</span>\n   168→            <span className=\"close-call-sidebar__hash\">Pyth BTC/USD</span>\n   169→          </div>\n   170→        </div>\n   171→      )}\n   172→    </div>\n   173→  );\n   174→\n   175→  return (\n   176→    <>\n   177→      <GameLayout\n   178→        gameName=\"Close Call\"\n   179→        gameDescription=\"A pari-mutuel prediction market game\"\n   180→        sidebar={sidebar}\n   181→        historyEntries={historyEntries}\n   182→        showHistory={true}\n   183→      >\n   184→        <div className=\"close-call-main\">\n   185→          {/* Result banner - positioned above the chart */}\n   186→          {completedRound && (() => {\n   187→            const outcome = completedRound.outcome;\n   188→            const isUserWinner = completedRoundUserBet && completedRound.winners?.includes(completedRoundUserBet.address);\n   189→            const userPayout = completedRoundUserBet && completedRound.payouts?.[completedRoundUserBet.address];\n   190→            const outcomeColor = outcome === \"green\"\n   191→              ? SIDE_COLORS.green\n   192→              : outcome === \"red\"\n   193→              ? SIDE_COLORS.red\n   194→              : SIDE_COLORS.refund;\n   195→\n   196→            return (\n   197→              <RoundResultBanner\n   198→                outcomeText={outcome === \"refund\" ? \"REFUND\" : `${outcome?.toUpperCase()} WINS`}\n   199→                outcomeColor={outcomeColor}\n   200→                userWon={!!isUserWinner}\n   201→                userLost={!!completedRoundUserBet && !isUserWinner && outcome !== \"refund\"}\n   202→                statusText={\n   203→                  !completedRoundUserBet\n   204→                    ? undefined\n   205→                    : isUserWinner\n   206→                    ? \"You Won!\"\n   207→                    : outcome === \"refund\"\n   208→                    ? \"Bet refunded\"\n   209→                    : \"You Lost\"\n   210→                }\n   211→                payoutAmount={\n   212→                  completedRoundUserBet\n   213→                    ? isUserWinner\n   214→                      ? userPayout ?? undefined\n   215→                      : outcome === \"refund\"\n   216→                      ? undefined\n   217→                      : -completedRoundUserBet.amount\n   218→                    : undefined\n   219→                }\n   220→                onDismiss={clearCompletedRound}\n   221→              />\n   222→            );\n   223→          })()}\n   224→\n   225→          {/* Banner: betting on current candle */}\n   226→          <div className=\"close-call-main__banner\">\n   227→            <span>\n   228→              Will the current candle close{\" \"}\n   229→              <span style={{ color: SIDE_COLORS.green }}>GREEN</span> or{\" \"}\n   230→              <span style={{ color: SIDE_COLORS.red }}>RED</span>?\n   231→            </span>\n   232→          </div>\n   233→\n   234→          {/* Candlestick chart */}\n   235→          {!loading && recentCandles.length > 0 ? (\n   236→            <CandlestickChart\n   237→              candles={recentCandles}\n   238→              currentPrice={currentPrice}\n   239→              progress={candleProgress}\n   240→            />\n   241→          ) : (\n   242→            <div className=\"close-call-main__loading\">\n   243→              <div className=\"close-call-main__spinner\" />\n   244→              <span>Loading chart...</span>\n   245→            </div>\n   246→          )}\n   247→        </div>\n   248→      </GameLayout>\n   249→\n   250→      {/* History detail modal */}\n   251→      <Modal\n   252→        isOpen={selectedHistory !== null}\n   253→        onClose={() => setSelectedHistory(null)}\n   254→        title=\"Round Details\"\n   255→      >\n   256→        {selectedHistory && (() => {\n   257→          const { round, userBet: bet, payout, won } = selectedHistory;\n   258→          const sideColor = SIDE_COLORS[bet.side];\n   259→\n   260→          return (\n   261→            <div className=\"close-call-history-modal\">\n   262→              {/* Round stats */}\n   263→              <div className=\"close-call-history-modal__section\">\n   264→                <h4 className=\"close-call-history-modal__section-title\">Round Stats</h4>\n   265→                <div className=\"close-call-history-modal__row\">\n   266→                  <span>Your Side</span>\n   267→                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n   268→                    {bet.side.toUpperCase()}\n   269→                  </span>\n   270→                </div>\n   271→                <div className=\"close-call-history-modal__row\">\n   272→                  <span>Your Stake</span>\n   273→                  <span>{`${bet.amount.toFixed(4)} SOL`}</span>\n   274→                </div>\n   275→                <div className=\"close-call-history-modal__row\">\n   276→                  <span>Outcome</span>\n   277→                  <span\n   278→                    style={{\n   279→                      color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   280→                      textShadow: round.outcome ? `0 0 4px ${SIDE_COLORS[round.outcome]}` : undefined,\n   281→                    }}\n   282→                  >\n   283→                    {round.outcome?.toUpperCase() ?? \"?\"}\n   284→                  </span>\n   285→                </div>\n   286→                <div className=\"close-call-history-modal__row\">\n   287→                  <span>Result</span>\n   288→                  <span style={{ color: won ? SIDE_COLORS.green : \"#d45d5d\" }}>\n   289→                    {won ? \"WON!\" : \"LOST\"}\n   290→                  </span>\n   291→                </div>\n   292→                <div className=\"close-call-history-modal__row close-call-history-modal__row--highlight\">\n   293→                  <span>Payout</span>\n   294→                  <span className={won ? \"close-call-history-modal__highlight\" : \"\"}>\n   295→                    {won ? `+${payout.toFixed(4)} SOL` : `-${bet.amount.toFixed(4)} SOL`}\n   296→                  </span>\n   297→                </div>\n   298→              </div>\n   299→\n   300→              {/* Candle data */}\n   301→              {round.resultCandle && (\n   302→                <div className=\"close-call-history-modal__section\">\n   303→                  <h4 className=\"close-call-history-modal__section-title\">Candle Data</h4>\n   304→                  <div className=\"close-call-history-modal__row\">\n   305→                    <span>Open</span>\n   306→                    <span>${round.resultCandle.open.toFixed(2)}</span>\n   307→                  </div>\n   308→                  <div className=\"close-call-history-modal__row\">\n   309→                    <span>Close</span>\n   310→                    <span>${round.resultCandle.close.toFixed(2)}</span>\n   311→                  </div>\n   312→                  <div className=\"close-call-history-modal__row\">\n   313→                    <span>Change</span>\n   314→                    <span\n   315→                      style={{\n   316→                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   317→                      }}\n   318→                    >\n   319→                      {round.outcome === \"green\" ? \"+\" : \"\"}\n   320→                      {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n   321→                    </span>\n   322→                  </div>\n   323→                </div>\n   324→              )}\n   325→\n   326→              {/* Round info (oracle-resolved, no commit-reveal) */}\n   327→              <div className=\"close-call-history-modal__section\">\n   328→                <h4 className=\"close-call-history-modal__section-title\">\n   329→                  <span className=\"close-call-history-modal__lock\">🔒</span>\n   330→                  Oracle Verification\n   331→                </h4>\n   332→                <div className=\"close-call-history-modal__row\">\n   333→                  <span>Round ID</span>\n   334→                  <span className=\"close-call-history-modal__hash\" title={round.id}>\n   335→                    {round.id}\n   336→                  </span>\n   337→                </div>\n   338→                <div className=\"close-call-history-modal__row\">\n   339→                  <span>Oracle</span>\n   340→                  <span className=\"close-call-history-modal__hash\">Pyth BTC/USD</span>\n   341→                </div>\n   342→                {round.settleTx && (\n   343→                  <div className=\"close-call-history-modal__row\">\n   344→                    <span>Settlement Tx</span>\n   345→                    <span className=\"close-call-history-modal__hash close-call-history-modal__hash--revealed\" title={round.settleTx}>\n   346→                      {round.settleTx}\n   347→                    </span>\n   348→                  </div>\n   349→                )}\n   350→              </div>\n   351→\n   352→              {/* Verify link */}\n   353→              <Link to={`/close-call/${round.id}`} className=\"close-call-history-modal__verify-link\">\n   354→                View Round Details →\n   355→              </Link>\n   356→            </div>\n   357→          );\n   358→        })()}\n   359→      </Modal>\n   360→    </>\n   361→  );\n   362→}\n   363→\n   364→export function CloseCallPage() {\n   365→  return (\n   366→    <CloseCallProvider>\n   367→      <CloseCallPageContent />\n   368→    </CloseCallProvider>\n   369→  );\n   370→}\n   371→"}]},"parent_tool_use_id":"toolu_01W1oVvLDGY6k672bAvcK4Hb","session_id":"3203ecf8-5327-4c6a-a3f1-03636bd6e7bf","uuid":"afb1e35b-70e1-4142-a66c-2a93f5e3fe7f"}
