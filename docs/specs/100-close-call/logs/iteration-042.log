{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CmViJrboxhmL4FspvfkgPK","type":"tool_result","content":"     1→import { ReactNode, lazy, Suspense } from \"react\";\n     2→import { ConnectionProvider } from \"@solana/wallet-adapter-react\";\n     3→import type { ConnectionConfig } from \"@solana/web3.js\";\n     4→import { MockWalletProvider } from \"./mock\";\n     5→\n     6→// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     7→const RealWalletProvider = lazy(() =>\n     8→  import(\"./real/RealWalletProvider\").then((m) => ({\n     9→    default: m.RealWalletProvider,\n    10→  })),\n    11→);\n    12→\n    13→// Lazy-load TestWalletWrapper for E2E tests (reads keypair seed from window)\n    14→const TestWalletWrapper = lazy(() =>\n    15→  import(\"./test/TestWalletWrapper\").then((m) => ({\n    16→    default: m.TestWalletWrapper,\n    17→  })),\n    18→);\n    19→\n    20→// Re-export WalletContext from the shared context file\n    21→export { WalletContext } from \"./context\";\n    22→\n    23→const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    24→const RPC_MAX_RETRIES = 3;\n    25→const RPC_INITIAL_RETRY_DELAY_MS = 1000;\n    26→\n    27→function getRpcUrl(): string {\n    28→  const envUrl =\n    29→    typeof import.meta !== \"undefined\"\n    30→      ? import.meta.env?.VITE_RPC_URL\n    31→      : undefined;\n    32→  return envUrl || DEFAULT_RPC_URL;\n    33→}\n    34→\n    35→function getWsRpcUrl(): string | undefined {\n    36→  const envUrl =\n    37→    typeof import.meta !== \"undefined\"\n    38→      ? import.meta.env?.VITE_WS_RPC_URL\n    39→      : undefined;\n    40→  return envUrl || undefined;\n    41→}\n    42→\n    43→interface WalletProviderProps {\n    44→  children: ReactNode;\n    45→}\n    46→\n    47→function delay(ms: number): Promise<void> {\n    48→  return new Promise((resolve) => setTimeout(resolve, ms));\n    49→}\n    50→\n    51→const baseFetch = globalThis.fetch?.bind(globalThis);\n    52→\n    53→const rpcFetch: typeof fetch = async (input, init) => {\n    54→  if (!baseFetch) {\n    55→    throw new Error(\"Global fetch is not available in this environment.\");\n    56→  }\n    57→\n    58→  let attempt = 0;\n    59→  let retryDelayMs = RPC_INITIAL_RETRY_DELAY_MS;\n    60→  let response = await baseFetch(input, init);\n    61→\n    62→  while (response.status === 429 && attempt < RPC_MAX_RETRIES) {\n    63→    await delay(retryDelayMs);\n    64→    attempt += 1;\n    65→    retryDelayMs *= 2;\n    66→    response = await baseFetch(input, init);\n    67→  }\n    68→\n    69→  return response;\n    70→};\n    71→\n    72→function buildConnectionConfig(): ConnectionConfig {\n    73→  const wsEndpoint = getWsRpcUrl();\n    74→  return {\n    75→    commitment: \"confirmed\",\n    76→    // Disable web3.js internal 429 retries so we can control retry timing.\n    77→    disableRetryOnRateLimit: true,\n    78→    fetch: rpcFetch,\n    79→    // Use a separate WSS endpoint for subscriptions if configured.\n    80→    // Load-balanced HTTP RPC providers (dRPC, etc.) often don't relay\n    81→    // WebSocket subscription notifications, so a dedicated WSS endpoint\n    82→    // (e.g. Helius, public Solana) is needed for onLogs/onAccountChange.\n    83→    ...(wsEndpoint ? { wsEndpoint } : {}),\n    84→  };\n    85→}\n    86→\n    87→function isMockMode(): boolean {\n    88→  const flag =\n    89→    typeof import.meta !== \"undefined\"\n    90→      ? import.meta.env?.VITE_MOCK_MODE\n    91→      : undefined;\n    92→  // Default to real mode — only mock when explicitly set to \"true\"\n    93→  return flag === \"true\";\n    94→}\n    95→\n    96→function isTestWalletMode(): boolean {\n    97→  const flag =\n    98→    typeof import.meta !== \"undefined\"\n    99→      ? import.meta.env?.VITE_TEST_WALLET\n   100→      : undefined;\n   101→  return flag === \"true\";\n   102→}\n   103→\n   104→/**\n   105→ * Unified WalletProvider.\n   106→ * Wraps both Mock and Real providers with a shared ConnectionProvider.\n   107→ */\n   108→export function WalletProvider({ children }: WalletProviderProps) {\n   109→  const endpoint = getRpcUrl();\n   110→\n   111→  const inner = isMockMode() ? (\n   112→    <MockWalletProvider>{children}</MockWalletProvider>\n   113→  ) : isTestWalletMode() ? (\n   114→    <Suspense fallback={null}>\n   115→      <TestWalletWrapper>{children}</TestWalletWrapper>\n   116→    </Suspense>\n   117→  ) : (\n   118→    <Suspense fallback={null}>\n   119→      <RealWalletProvider>{children}</RealWalletProvider>\n   120→    </Suspense>\n   121→  );\n   122→\n   123→  return (\n   124→    <ConnectionProvider endpoint={endpoint} config={buildConnectionConfig()}>\n   125→      {inner}\n   126→    </ConnectionProvider>\n   127→  );\n   128→}\n   129→"}]},"parent_tool_use_id":"toolu_01W1oVvLDGY6k672bAvcK4Hb","session_id":"3203ecf8-5327-4c6a-a3f1-03636bd6e7bf","uuid":"e358e32d-28c1-49d2-a2c3-d806ac4a216e"}
