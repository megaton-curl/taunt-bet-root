{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X6q49r3D8p1otUdhcr5sHe","type":"tool_result","content":"     1→import { useEffect, useRef, useState } from \"react\";\n     2→import {\n     3→  createChart,\n     4→  CandlestickSeries,\n     5→  type IChartApi,\n     6→  type ISeriesApi,\n     7→  type CandlestickData,\n     8→  type Time,\n     9→} from \"lightweight-charts\";\n    10→import type { Candle } from \"../types\";\n    11→import { SIDE_COLORS, CANDLE_DURATION_MS, BETTING_WINDOW_MS } from \"../types\";\n    12→\n    13→// Muted colors for history candles\n    14→const HISTORY_COLORS = {\n    15→  up: \"rgba(69, 176, 88, 0.35)\",\n    16→  down: \"rgba(220, 53, 69, 0.35)\",\n    17→};\n    18→\n    19→interface CandlestickChartProps {\n    20→  candles: Candle[];\n    21→  currentPrice: number;\n    22→  progress: number;\n    23→}\n    24→\n    25→export function CandlestickChart({\n    26→  candles,\n    27→  currentPrice,\n    28→  progress,\n    29→}: CandlestickChartProps) {\n    30→  const chartContainerRef = useRef<HTMLDivElement>(null);\n    31→  const chartRef = useRef<IChartApi | null>(null);\n    32→  const historySeriesRef = useRef<ISeriesApi<\"Candlestick\"> | null>(null);\n    33→  const currentSeriesRef = useRef<ISeriesApi<\"Candlestick\"> | null>(null);\n    34→\n    35→  // Track the forming candle using a ref to avoid stale closures\n    36→  const formingCandleRef = useRef<{\n    37→    openTime: number;\n    38→    open: number;\n    39→    high: number;\n    40→    low: number;\n    41→  } | null>(null);\n    42→\n    43→  // Force re-render when forming candle changes\n    44→  const [, forceUpdate] = useState(0);\n    45→\n    46→  // Get the current forming candle (last in array)\n    47→  const currentCandle = candles.length > 0 ? candles[candles.length - 1]! : null;\n    48→\n    49→  // Get history candles (5 before the current one)\n    50→  const historyCandles = candles.length > 1 ? candles.slice(-6, -1) : [];\n    51→\n    52→  // Reset forming candle when a new candle starts (openTime changes)\n    53→  // For mock mode, use actual candle OHLC for realistic initial display\n    54→  if (currentCandle) {\n    55→    const forming = formingCandleRef.current;\n    56→    if (!forming || forming.openTime !== currentCandle.openTime) {\n    57→      formingCandleRef.current = {\n    58→        openTime: currentCandle.openTime,\n    59→        open: currentCandle.open,\n    60→        high: currentCandle.high,\n    61→        low: currentCandle.low,\n    62→      };\n    63→    }\n    64→  }\n    65→\n    66→  // Update high/low as price changes\n    67→  useEffect(() => {\n    68→    const forming = formingCandleRef.current;\n    69→    if (!forming || currentPrice <= 0) return;\n    70→\n    71→    const newHigh = Math.max(forming.high, currentPrice);\n    72→    const newLow = Math.min(forming.low, currentPrice);\n    73→\n    74→    if (newHigh !== forming.high || newLow !== forming.low) {\n    75→      forming.high = newHigh;\n    76→      forming.low = newLow;\n    77→      forceUpdate(n => n + 1);\n    78→    }\n    79→  }, [currentPrice]);\n    80→\n    81→  // Calculate display values for current candle\n    82→  // Only use currentPrice if it's a valid positive number (avoids 0 on initial load)\n    83→  const forming = formingCandleRef.current;\n    84→  const validPrice = currentPrice > 0 ? currentPrice : null;\n    85→  const displayOpen = forming?.open ?? currentCandle?.open ?? 0;\n    86→  const displayHigh = forming\n    87→    ? Math.max(forming.high, validPrice ?? forming.high)\n    88→    : validPrice ?? currentCandle?.high ?? displayOpen;\n    89→  const displayLow = forming\n    90→    ? Math.min(forming.low, validPrice ?? forming.low)\n    91→    : validPrice ?? currentCandle?.low ?? displayOpen;\n    92→  const displayClose = validPrice ?? displayOpen;\n    93→\n    94→  const isUp = displayClose >= displayOpen;\n    95→\n    96→  // Format price for display\n    97→  const formatPrice = (price: number): string => {\n    98→    return price.toLocaleString(\"en-US\", {\n    99→      minimumFractionDigits: 2,\n   100→      maximumFractionDigits: 2,\n   101→    });\n   102→  };\n   103→\n   104→  // Initialize chart with TWO series: history (muted) and current (vibrant)\n   105→  useEffect(() => {\n   106→    if (!chartContainerRef.current) return;\n   107→\n   108→    const chart = createChart(chartContainerRef.current, {\n   109→      layout: {\n   110→        background: { color: \"transparent\" },\n   111→        textColor: \"#888\",\n   112→      },\n   113→      grid: {\n   114→        vertLines: { visible: false },\n   115→        horzLines: { visible: false },\n   116→      },\n   117→      width: chartContainerRef.current.clientWidth,\n   118→      height: 280,\n   119→      rightPriceScale: {\n   120→        visible: false,\n   121→      },\n   122→      timeScale: {\n   123→        visible: false,\n   124→        barSpacing: 50,\n   125→        rightOffset: 1,\n   126→      },\n   127→      crosshair: {\n   128→        vertLine: { visible: false },\n   129→        horzLine: { visible: false },\n   130→      },\n   131→      handleScale: false,\n   132→      handleScroll: false,\n   133→    });\n   134→\n   135→    // History series - muted/dimmed colors\n   136→    const historySeries = chart.addSeries(CandlestickSeries, {\n   137→      upColor: HISTORY_COLORS.up,\n   138→      downColor: HISTORY_COLORS.down,\n   139→      wickUpColor: HISTORY_COLORS.up,\n   140→      wickDownColor: HISTORY_COLORS.down,\n   141→      borderUpColor: HISTORY_COLORS.up,\n   142→      borderDownColor: HISTORY_COLORS.down,\n   143→      priceLineVisible: false,\n   144→      lastValueVisible: false,\n   145→    });\n   146→\n   147→    // Current series - vibrant colors\n   148→    const currentSeries = chart.addSeries(CandlestickSeries, {\n   149→      upColor: SIDE_COLORS.green,\n   150→      downColor: SIDE_COLORS.red,\n   151→      wickUpColor: SIDE_COLORS.green,\n   152→      wickDownColor: SIDE_COLORS.red,\n   153→      borderUpColor: SIDE_COLORS.green,\n   154→      borderDownColor: SIDE_COLORS.red,\n   155→      priceLineVisible: false,\n   156→      lastValueVisible: false,\n   157→    });\n   158→\n   159→    chartRef.current = chart;\n   160→    historySeriesRef.current = historySeries;\n   161→    currentSeriesRef.current = currentSeries;\n   162→\n   163→    const handleResize = () => {\n   164→      if (chartContainerRef.current) {\n   165→        chart.applyOptions({ width: chartContainerRef.current.clientWidth });\n   166→      }\n   167→    };\n   168→    window.addEventListener(\"resize\", handleResize);\n   169→\n   170→    return () => {\n   171→      window.removeEventListener(\"resize\", handleResize);\n   172→      chart.remove();\n   173→      chartRef.current = null;\n   174→      historySeriesRef.current = null;\n   175→      currentSeriesRef.current = null;\n   176→    };\n   177→  }, []);\n   178→\n   179→  // Update chart data when candles or price changes\n   180→  useEffect(() => {\n   181→    if (!historySeriesRef.current || !currentSeriesRef.current || !currentCandle) return;\n   182→\n   183→    // History candles data (muted)\n   184→    const historyData: CandlestickData<Time>[] = historyCandles.map((candle, index) => ({\n   185→      time: index as Time,\n   186→      open: candle.open,\n   187→      high: candle.high,\n   188→      low: candle.low,\n   189→      close: candle.close,\n   190→    }));\n   191→\n   192→    // Current candle data (vibrant) - with gap for visual separation\n   193→    const currentCandleIndex = historyCandles.length + 2;\n   194→    const currentData: CandlestickData<Time>[] = [{\n   195→      time: currentCandleIndex as Time,\n   196→      open: displayOpen,\n   197→      high: displayHigh,\n   198→      low: displayLow,\n   199→      close: displayClose,\n   200→    }];\n   201→\n   202→    historySeriesRef.current.setData(historyData);\n   203→    currentSeriesRef.current.setData(currentData);\n   204→\n   205→    // Adjust visible range based on number of history candles\n   206→    const totalRange = currentCandleIndex + 2;\n   207→    chartRef.current?.timeScale().setVisibleLogicalRange({ from: -0.5, to: totalRange });\n   208→  }, [historyCandles, currentCandle, displayOpen, displayHigh, displayLow, displayClose]);\n   209→\n   210→  // Calculate betting status\n   211→  const elapsedMs = progress * CANDLE_DURATION_MS;\n   212→  const remainingMs = CANDLE_DURATION_MS - elapsedMs;\n   213→  const remainingSec = Math.ceil(remainingMs / 1000);\n   214→  const isBettingOpen = elapsedMs < BETTING_WINDOW_MS;\n   215→  const bettingRemainingMs = Math.max(0, BETTING_WINDOW_MS - elapsedMs);\n   216→  const bettingRemainingSec = Math.ceil(bettingRemainingMs / 1000);\n   217→\n   218→  const bettingProgress = Math.min(elapsedMs / BETTING_WINDOW_MS, 1);\n   219→  const lockedProgress = Math.max(0, (elapsedMs - BETTING_WINDOW_MS) / (CANDLE_DURATION_MS - BETTING_WINDOW_MS));\n   220→\n   221→  const candleColor = isUp ? SIDE_COLORS.green : SIDE_COLORS.red;\n   222→\n   223→  return (\n   224→    <div className=\"close-call-chart\">\n   225→      {/* Header: Asset name only */}\n   226→      <div className=\"close-call-chart__header\">\n   227→        <div className=\"close-call-chart__asset-name\">BTC/USD 1 min</div>\n   228→      </div>\n   229→\n   230→      {/* Lightweight Charts container */}\n   231→      <div className=\"close-call-chart__container close-call-chart__container--lw\">\n   232→        <div ref={chartContainerRef} className=\"close-call-chart__lw-chart\" />\n   233→        {/* Price info panel - centered in right half */}\n   234→        <div className=\"close-call-chart__price-panel\">\n   235→          <div className=\"close-call-chart__current-label\">Current Round</div>\n   236→          {/* Current price - prominent */}\n   237→          <div className=\"close-call-chart__current-price\" style={{ color: candleColor }}>\n   238→            ${formatPrice(displayClose)}\n   239→          </div>\n   240→          {/* OHL prices - smaller */}\n   241→          <div className=\"close-call-chart__ohl\">\n   242→            <span className=\"close-call-chart__ohl-item\">\n   243→              <span className=\"close-call-chart__ohl-label\">O</span>\n   244→              <span className=\"close-call-chart__ohl-value\">${formatPrice(displayOpen)}</span>\n   245→            </span>\n   246→            <span className=\"close-call-chart__ohl-item\">\n   247→              <span className=\"close-call-chart__ohl-label\">H</span>\n   248→              <span className=\"close-call-chart__ohl-value\">${formatPrice(displayHigh)}</span>\n   249→            </span>\n   250→            <span className=\"close-call-chart__ohl-item\">\n   251→              <span className=\"close-call-chart__ohl-label\">L</span>\n   252→              <span className=\"close-call-chart__ohl-value\">${formatPrice(displayLow)}</span>\n   253→            </span>\n   254→          </div>\n   255→        </div>\n   256→      </div>\n   257→\n   258→      {/* Footer: Progress bar and status */}\n   259→      <div className=\"close-call-chart__footer\">\n   260→        {/* Progress bar: white for betting, gray for locked */}\n   261→        <div className=\"close-call-chart__progress\">\n   262→          <div className=\"close-call-chart__progress-track\">\n   263→            {/* Betting phase (first 10s) - white */}\n   264→            <div\n   265→              className=\"close-call-chart__progress-betting\"\n   266→              style={{ width: `${(BETTING_WINDOW_MS / CANDLE_DURATION_MS) * 100}%` }}\n   267→            >\n   268→              <div\n   269→                className=\"close-call-chart__progress-fill close-call-chart__progress-fill--betting\"\n   270→                style={{ width: `${bettingProgress * 100}%` }}\n   271→              />\n   272→            </div>\n   273→            {/* Locked phase (remaining 50s) - gray */}\n   274→            <div\n   275→              className=\"close-call-chart__progress-locked\"\n   276→              style={{ width: `${((CANDLE_DURATION_MS - BETTING_WINDOW_MS) / CANDLE_DURATION_MS) * 100}%` }}\n   277→            >\n   278→              <div\n   279→                className=\"close-call-chart__progress-fill close-call-chart__progress-fill--locked\"\n   280→                style={{ width: `${lockedProgress * 100}%` }}\n   281→              />\n   282→            </div>\n   283→          </div>\n   284→        </div>\n   285→\n   286→        {/* Countdown label */}\n   287→        <div className=\"close-call-chart__label\">\n   288→          {isBettingOpen ? (\n   289→            <span className=\"close-call-chart__label--betting\">\n   290→              BETTING OPEN • {bettingRemainingSec}s to bet\n   291→            </span>\n   292→          ) : (\n   293→            <span className=\"close-call-chart__label--locked\">\n   294→              BETTING LOCKED • Candle Close in {remainingSec}s\n   295→            </span>\n   296→          )}\n   297→        </div>\n   298→      </div>\n   299→    </div>\n   300→  );\n   301→}\n   302→"}]},"parent_tool_use_id":"toolu_01W1oVvLDGY6k672bAvcK4Hb","session_id":"3203ecf8-5327-4c6a-a3f1-03636bd6e7bf","uuid":"a8a9983a-8a97-4928-b2bc-16dccfa7a313"}
