{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014rndVxwgtcpNGce39CWmp9","type":"tool_result","content":"     1→import { defineConfig } from \"vite\";\n     2→import react from \"@vitejs/plugin-react\";\n     3→import { nodePolyfills } from \"vite-plugin-node-polyfills\";\n     4→import { resolve } from \"path\";\n     5→import { execSync } from \"child_process\";\n     6→\n     7→const gitHash = (() => {\n     8→  try {\n     9→    return execSync(\"git rev-parse --short HEAD\").toString().trim();\n    10→  } catch {\n    11→    return \"unknown\";\n    12→  }\n    13→})();\n    14→\n    15→const buildTime = new Date().toISOString();\n    16→\n    17→export default defineConfig({\n    18→  define: {\n    19→    __BUILD_HASH__: JSON.stringify(gitHash),\n    20→    __BUILD_TIME__: JSON.stringify(buildTime),\n    21→  },\n    22→  plugins: [\n    23→    react(),\n    24→    nodePolyfills({\n    25→      include: [\"buffer\", \"crypto\", \"stream\", \"util\"],\n    26→      globals: { Buffer: true },\n    27→    }),\n    28→  ],\n    29→  resolve: {\n    30→    alias: {\n    31→      \"@\": resolve(__dirname, \"./src\"),\n    32→    },\n    33→  },\n    34→  server: {\n    35→    port: 3000,\n    36→    host: true,\n    37→    watch: {\n    38→      // Exclude validator ledger directory — its snapshot symlinks crash chokidar\n    39→      ignored: [\"**/.localnet-ledger/**\"],\n    40→    },\n    41→  },\n    42→  build: {\n    43→    // Disable sourcemaps for production (saves memory during build)\n    44→    sourcemap: false,\n    45→    // Increase chunk size warning limit\n    46→    chunkSizeWarningLimit: 1000,\n    47→    rollupOptions: {\n    48→      output: {\n    49→        // Manual chunks to optimize bundle splitting\n    50→        manualChunks(id) {\n    51→          // React ecosystem\n    52→          if (id.includes(\"node_modules/react\") ||\n    53→              id.includes(\"node_modules/react-dom\") ||\n    54→              id.includes(\"node_modules/react-router\")) {\n    55→            return \"vendor-react\";\n    56→          }\n    57→          // Solana SDK (if present - transitively imported by wallet mock)\n    58→          if (id.includes(\"node_modules/@solana\")) {\n    59→            return \"vendor-solana\";\n    60→          }\n    61→        },\n    62→      },\n    63→    },\n    64→  },\n    65→});\n    66→"}]},"parent_tool_use_id":"toolu_01RSNKsJ9LwH8tq4QtDRv8zk","session_id":"3203ecf8-5327-4c6a-a3f1-03636bd6e7bf","uuid":"a4734fca-1408-4328-b0a2-3522d18b0d04"}
