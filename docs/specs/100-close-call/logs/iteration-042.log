\"alert\");\n   260→\n   261→        const message = document.createElement(\"span\");\n   262→        message.className = \"rng-toast__message\";\n   263→        message.textContent = \"Transaction cancelled by user.\";\n   264→\n   265→        const close = document.createElement(\"button\");\n   266→        close.className = \"rng-toast__close\";\n   267→        close.setAttribute(\"type\", \"button\");\n   268→        close.textContent = \"×\";\n   269→\n   270→        toast.append(message, close);\n   271→        wrapper.appendChild(toast);\n   272→        document.body.appendChild(wrapper);\n   273→      });\n   274→\n   275→      await stablePage.waitForTimeout(300);\n   276→      await expect(stablePage).toHaveScreenshot(\"coinflip-error-toast-position.png\", { fullPage: true });\n   277→    });\n   278→  });\n   279→});\n   280→"}]},"parent_tool_use_id":"toolu_01W1oVvLDGY6k672bAvcK4Hb","session_id":"3203ecf8-5327-4c6a-a3f1-03636bd6e7bf","uuid":"c4a934f3-000f-40fb-99f1-43e99e7cbf9e"}
