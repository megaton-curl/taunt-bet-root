{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M8A4T8TtNT6QL4PeCpLsu4","type":"tool_result","content":"     1→/**\n     2→ * Devnet E2E test for Close Call (Pyth oracle integration).\n     3→ *\n     4→ * Two test tiers:\n     5→ *   1. Infra (always runs): closecall program deployed, Pyth BTC/USD price\n     6→ *      account readable, backend closecall API responding, settled round data\n     7→ *      has real oracle prices.\n     8→ *   2. Lifecycle (conditional): place bets on both sides → wait for settlement\n     9→ *      → verify outcome + payouts. Skipped if clock worker has no active round\n    10→ *      (Pyth devnet prices update ~every 5 min and may be stale).\n    11→ */\n    12→import { test, expect } from \"./fixtures\";\n    13→import type { Page } from \"@playwright/test\";\n    14→import { Connection, LAMPORTS_PER_SOL, PublicKey } from \"@solana/web3.js\";\n    15→import { PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    16→import {\n    17→  validateDevnetEnv,\n    18→  verifyFairnessBackend,\n    19→  type DevnetConfig,\n    20→} from \"./helpers/env\";\n    21→import { withRetry } from \"./helpers/retry\";\n    22→\n    23→// ── Constants ────────────────────────────────────────────────────────\n    24→\n    25→/** Pyth BTC/USD push oracle price account on devnet. */\n    26→const PYTH_BTC_USD_DEVNET = new PublicKey(\n    27→  \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    28→);\n    29→\n    30→const MIN_BALANCE_SOL = 0.1;\n    31→/** Wait up to 90s for clock worker to produce a round. */\n    32→const ROUND_WAIT_TIMEOUT_MS = 90_000;\n    33→/** Wait up to 120s for settlement after candle close. */\n    34→const SETTLEMENT_TIMEOUT_MS = 120_000;\n    35→/** Minimum remaining betting window to attempt placing bets (ms). */\n    36→const MIN_BETTING_WINDOW_MS = 12_000;\n    37→const BET_AMOUNT_SOL = \"0.005\";\n    38→/** On-chain betting window duration (must match CloseCallConfig). */\n    39→const BETTING_WINDOW_SECS = 30;\n    40→\n    41→/** Devnet console noise patterns to ignore. */\n    42→const DEVNET_NOISE = [\n    43→  \"favicon.ico\",\n    44→  \"downloadable font\",\n    45→  \"third-party cookie\",\n    46→  \"429\",\n    47→  \"Too Many Requests\",\n    48→  \"WebSocket\",\n    49→  \"ECONNRESET\",\n    50→  \"socket hang up\",\n    51→  \"FetchError\",\n    52→  \"NetworkError\",\n    53→  \"net::ERR_\",\n    54→  \"ERR_BLOCKED_BY\",\n    55→  \"Failed to load resource\",\n    56→  \"NS_ERROR\",\n    57→  \"Failed to fetch\",\n    58→  \"Loading chunk\",\n    59→];\n    60→\n    61→function filterNoise(errors: string[]): string[] {\n    62→  return errors.filter(\n    63→    (e) => !DEVNET_NOISE.some((p) => e.includes(p)),\n    64→  );\n    65→}\n    66→\n    67→// ── Backend API helpers ──────────────────────────────────────────────\n    68→\n    69→interface BackendCloseCallRound {\n    70→  roundId: string;\n    71→  pda: string;\n    72→  phase: \"open\" | \"settled\" | \"refunded\";\n    73→  openPrice: number;\n    74→  openPriceExpo: number;\n    75→  closePrice: number | null;\n    76→  outcome: \"pending\" | \"green\" | \"red\" | \"refund\";\n    77→  greenPool: number;\n    78→  redPool: number;\n    79→  totalPool: number;\n    80→  totalFee: number;\n    81→  greenEntries: Array<{ player: string; amountLamports: number }>;\n    82→  redEntries: Array<{ player: string; amountLamports: number }>;\n    83→  greenCount: number;\n    84→  redCount: number;\n    85→  settleTx: string | null;\n    86→  createdAt: string;\n    87→  settledAt: string | null;\n    88→}\n    89→\n    90→async function fetchCurrentRound(\n    91→  config: DevnetConfig,\n    92→): Promise<BackendCloseCallRound | null> {\n    93→  const resp = await fetch(\n    94→    `${config.fairnessBackendUrl}/closecall/current-round`,\n    95→  );\n    96→  if (!resp.ok) return null;\n    97→  const data = (await resp.json()) as { round: BackendCloseCallRound | null };\n    98→  return data.round;\n    99→}\n   100→\n   101→async function fetchHistory(\n   102→  config: DevnetConfig,\n   103→  limit = 5,\n   104→): Promise<BackendCloseCallRound[]> {\n   105→  const resp = await fetch(\n   106→    `${config.fairnessBackendUrl}/closecall/history?limit=${limit}`,\n   107→  );\n   108→  if (!resp.ok) return [];\n   109→  const data = (await resp.json()) as { rounds: BackendCloseCallRound[] };\n   110→  return data.rounds;\n   111→}\n   112→\n   113→/** Remaining ms in the betting window for a round. */\n   114→function remainingBettingMs(round: BackendCloseCallRound): number {\n   115→  const bettingEndsAt =\n   116→    new Date(round.createdAt).getTime() + BETTING_WINDOW_SECS * 1_000;\n   117→  return bettingEndsAt - Date.now();\n   118→}\n   119→\n   120→/**\n   121→ * Wait for a round whose betting window has enough time remaining\n   122→ * for both players to place bets.\n   123→ */\n   124→async function waitForBettableRound(\n   125→  config: DevnetConfig,\n   126→): Promise<BackendCloseCallRound | null> {\n   127→  const start = Date.now();\n   128→  while (Date.now() - start < ROUND_WAIT_TIMEOUT_MS) {\n   129→    const round = await fetchCurrentRound(config);\n   130→    if (round && round.phase === \"open\") {\n   131→      const remaining = remainingBettingMs(round);\n   132→      if (remaining >= MIN_BETTING_WINDOW_MS) {\n   133→        return round;\n   134→      }\n   135→      // Betting window too short — wait for next round\n   136→      console.log(\n   137→        `[wait] Round ${round.roundId} has ${Math.round(remaining / 1_000)}s left — ` +\n   138→          `need ${MIN_BETTING_WINDOW_MS / 1_000}s, waiting for next round...`,\n   139→      );\n   140→    }\n   141→    await new Promise((r) => setTimeout(r, 3_000));\n   142→  }\n   143→  return null;\n   144→}\n   145→\n   146→async function waitForSettledRound(\n   147→  config: DevnetConfig,\n   148→  roundId: string,\n   149→): Promise<BackendCloseCallRound> {\n   150→  const start = Date.now();\n   151→  while (Date.now() - start < SETTLEMENT_TIMEOUT_MS) {\n   152→    // Check history for the settled round (it leaves current-round on settle)\n   153→    const history = await fetchHistory(config, 10);\n   154→    const settled = history.find((r) => r.roundId === roundId);\n   155→    if (\n   156→      settled &&\n   157→      (settled.phase === \"settled\" || settled.phase === \"refunded\")\n   158→    ) {\n   159→      return settled;\n   160→    }\n   161→    await new Promise((r) => setTimeout(r, 3_000));\n   162→  }\n   163→  throw new Error(\n   164→    `Timed out waiting for closecall round ${roundId} to settle`,\n   165→  );\n   166→}\n   167→\n   168→// ── Wallet funding check ─────────────────────────────────────────────\n   169→\n   170→async function ensureFunded(\n   171→  connection: Connection,\n   172→  pubkey: PublicKey,\n   173→  label: string,\n   174→): Promise<void> {\n   175→  const balance = await connection.getBalance(pubkey);\n   176→  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n   177→    console.log(\n   178→      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL ✓`,\n   179→    );\n   180→    return;\n   181→  }\n   182→  throw new Error(\n   183→    `${label} has ${(balance / LAMPORTS_PER_SOL).toFixed(6)} SOL; ` +\n   184→      `requires at least ${MIN_BALANCE_SOL} SOL. ` +\n   185→      `Fund ${pubkey.toBase58()} and rerun.`,\n   186→  );\n   187→}\n   188→\n   189→// ── Console tracking ─────────────────────────────────────────────────\n   190→\n   191→function trackConsoleErrors(page: Page): { errors: string[] } {\n   192→  const sink = { errors: [] as string[] };\n   193→  page.on(\"console\", (msg) => {\n   194→    if (msg.type() === \"error\") {\n   195→      sink.errors.push(msg.text());\n   196→    }\n   197→  });\n   198→  page.on(\"pageerror\", (err) => {\n   199→    sink.errors.push(`[pageerror] ${err.message}`);\n   200→  });\n   201→  return sink;\n   202→}\n   203→\n   204→// ── Tests ────────────────────────────────────────────────────────────\n   205→\n   206→test.describe(\"closecall devnet oracle E2E\", () => {\n   207→  test.beforeAll(async () => {\n   208→    const config = validateDevnetEnv();\n   209→    if (!config.closecallProgramId) {\n   210→      console.log(\n   211→        \"VITE_CLOSECALL_PROGRAM_ID not set — skipping Close Call E2E\",\n   212→      );\n   213→      return;\n   214→    }\n   215→    await verifyFairnessBackend(config);\n   216→    console.log(\"Close Call devnet E2E: checking wallet funding...\");\n   217→    const connection = new Connection(config.rpcUrl, \"confirmed\");\n   218→    await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n   219→    await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n   220→  });\n   221→\n   222→  test(\"closecall infra: program deployed, Pyth readable, backend API responding\", async ({\n   223→    devnetConfig,\n   224→    connection,\n   225→  }) => {\n   226→    if (!devnetConfig.closecallProgramId) {\n   227→      test.skip(true, \"VITE_CLOSECALL_PROGRAM_ID not configured\");\n   228→      return;\n   229→    }\n   230→\n   231→    // 1. Closecall program deployed + executable\n   232→    const programAccount = await connection.getAccountInfo(\n   233→      devnetConfig.closecallProgramId,\n   234→    );\n   235→    expect(programAccount).not.toBeNull();\n   236→    expect(programAccount!.executable).toBe(true);\n   237→    console.log(\n   238→      `[infra] Closecall program deployed at ${devnetConfig.closecallProgramId.toBase58()} ✓`,\n   239→    );\n   240→\n   241→    // 2. Pyth BTC/USD price account exists and is readable\n   242→    const pythAccount = await connection.getAccountInfo(PYTH_BTC_USD_DEVNET);\n   243→    expect(pythAccount).not.toBeNull();\n   244→    expect(pythAccount!.data.length).toBeGreaterThan(0);\n   245→    console.log(\n   246→      `[infra] Pyth BTC/USD account readable (${pythAccount!.data.length} bytes) ✓`,\n   247→    );\n   248→\n   249→    // 3. Backend closecall API responds\n   250→    const currentResp = await fetch(\n   251→      `${devnetConfig.fairnessBackendUrl}/closecall/current-round`,\n   252→    );\n   253→    expect(currentResp.ok).toBe(true);\n   254→    const currentData = (await currentResp.json()) as {\n   255→      round: BackendCloseCallRound | null;\n   256→    };\n   257→    console.log(\n   258→      `[infra] GET /closecall/current-round: ${currentData.round ? \"round active\" : \"no active round\"} ✓`,\n   259→    );\n   260→\n   261→    const historyResp = await fetch(\n   262→      `${devnetConfig.fairnessBackendUrl}/closecall/history?limit=5`,\n   263→    );\n   264→    expect(historyResp.ok).toBe(true);\n   265→    const historyData = (await historyResp.json()) as {\n   266→      rounds: BackendCloseCallRound[];\n   267→    };\n   268→    console.log(\n   269→      `[infra] GET /closecall/history: ${historyData.rounds.length} settled round(s) ✓`,\n   270→    );\n   271→\n   272→    // 4. If history has rounds, verify data shape (real Pyth prices)\n   273→    if (historyData.rounds.length > 0) {\n   274→      const sample = historyData.rounds[0];\n   275→      expect(sample.roundId).toBeTruthy();\n   276→      expect(sample.pda).toBeTruthy();\n   277→      expect(sample.openPrice).toBeDefined();\n   278→      expect(sample.openPriceExpo).toBeDefined();\n   279→      expect([\"settled\", \"refunded\"]).toContain(sample.phase);\n   280→      console.log(\n   281→        `[infra] Sample round ${sample.roundId}: ` +\n   282→          `openPrice=${sample.openPrice}×10^${sample.openPriceExpo}, ` +\n   283→          `outcome=${sample.outcome} ✓`,\n   284→      );\n   285→    }\n   286→  });\n   287→\n   288→  test(\"closecall lifecycle: bet both sides → settlement → verify\", async ({\n   289→    playerAPage,\n   290→    playerBPage,\n   291→    devnetConfig,\n   292→  }) => {\n   293→    if (!devnetConfig.closecallProgramId) {\n   294→      test.skip(true, \"VITE_CLOSECALL_PROGRAM_ID not configured\");\n   295→      return;\n   296→    }\n   297→\n   298→    test.setTimeout(300_000);\n   299→\n   300→    const consoleA = trackConsoleErrors(playerAPage);\n   301→    const consoleB = trackConsoleErrors(playerBPage);\n   302→\n   303→    // ── Phase 1: Wait for an open round with enough betting time ───────\n   304→    console.log(\n   305→      \"[phase-1] Waiting for clock worker to create a bettable round...\",\n   306→    );\n   307→    const openRound = await waitForBettableRound(devnetConfig);\n   308→\n   309→    if (!openRound) {\n   310→      console.warn(\n   311→        \"[phase-1] No bettable round within 90s — clock worker likely cannot \" +\n   312→          \"create rounds (Pyth devnet prices may be stale, ~5 min update interval). \" +\n   313→          \"Skipping lifecycle test. Infra test above validates oracle integration.\",\n   314→      );\n   315→      test.skip(\n   316→        true,\n   317→        \"No closecall round available (Pyth devnet price staleness)\",\n   318→      );\n   319→      return;\n   320→    }\n   321→\n   322→    const roundId = openRound.roundId;\n   323→    const remaining = remainingBettingMs(openRound);\n   324→    console.log(\n   325→      `[phase-1] Open round: ${roundId}, ` +\n   326→        `openPrice=${openRound.openPrice}×10^${openRound.openPriceExpo}, ` +\n   327→        `${Math.round(remaining / 1_000)}s betting window remaining ✓`,\n   328→    );\n   329→\n   330→    // ── Phase 2: Player A bets GREEN ───────────────────────────────────\n   331→    console.log(\"[phase-2] Player A navigating to /close-call...\");\n   332→    await playerAPage.goto(\"/close-call\");\n   333→    await playerAPage\n   334→      .waitForLoadState(\"networkidle\", { timeout: 15_000 })\n   335→      .catch(() => {});\n   336→\n   337→    // Wait for bet buttons to appear (proves round data loaded)\n   338→    await expect(\n   339→      playerAPage.locator(\".close-call-side-btn--green\").first(),\n   340→    ).toBeVisible({ timeout: 30_000 });\n   341→    console.log(\"[phase-2] Player A sees bet buttons ✓\");\n   342→\n   343→    // Input bet amount and click GREEN\n   344→    const inputA = playerAPage.locator(\".close-call-bet-input__field\");\n   345→    await inputA.fill(BET_AMOUNT_SOL);\n   346→    await playerAPage.locator(\".close-call-side-btn--green\").click();\n   347→    console.log(\"[phase-2] Player A clicked GREEN, waiting for tx...\");\n   348→\n   349→    // Wait for bet to register (selected state or user bet display)\n   350→    await expect(\n   351→      playerAPage\n   352→        .locator(\n   353→          \".close-call-pool-bar__user-bet, .close-call-side-btn--selected\",\n   354→        )\n   355→        .first(),\n   356→    ).toBeVisible({ timeout: 30_000 });\n   357→    console.log(\"[phase-2] Player A bet confirmed in UI ✓\");\n   358→\n   359→    // Verify bet on-chain via backend API\n   360→    await withRetry(\n   361→      async () => {\n   362→        const round = await fetchCurrentRound(devnetConfig);\n   363→        expect(round).not.toBeNull();\n   364→        const hasPlayerA = round!.greenEntries.some(\n   365→          (e) => e.player === PLAYER_A.publicKey.toBase58(),\n   366→        );\n   367→        expect(hasPlayerA).toBe(true);\n   368→      },\n   369→      { label: \"verifyPlayerABet\", retries: 5, delayMs: 2_000 },\n   370→    );\n   371→    console.log(\"[phase-2] Player A GREEN bet verified in backend ✓\");\n   372→\n   373→    // ── Phase 3: Player B bets RED ─────────────────────────────────────\n   374→    console.log(\"[phase-3] Player B navigating to /close-call...\");\n   375→    await playerBPage.goto(\"/close-call\");\n   376→    await playerBPage\n   377→      .waitForLoadState(\"networkidle\", { timeout: 15_000 })\n   378→      .catch(() => {});\n   379→\n   380→    await expect(\n   381→      playerBPage.locator(\".close-call-side-btn--red\").first(),\n   382→    ).toBeVisible({ timeout: 30_000 });\n   383→\n   384→    const inputB = playerBPage.locator(\".close-call-bet-input__field\");\n   385→    await inputB.fill(BET_AMOUNT_SOL);\n   386→    await playerBPage.locator(\".close-call-side-btn--red\").click();\n   387→    console.log(\"[phase-3] Player B clicked RED, waiting for tx...\");\n   388→\n   389→    await expect(\n   390→      playerBPage\n   391→        .locator(\n   392→          \".close-call-pool-bar__user-bet, .close-call-side-btn--selected\",\n   393→        )\n   394→        .first(),\n   395→    ).toBeVisible({ timeout: 30_000 });\n   396→    console.log(\"[phase-3] Player B bet confirmed in UI ✓\");\n   397→\n   398→    await withRetry(\n   399→      async () => {\n   400→        const round = await fetchCurrentRound(devnetConfig);\n   401→        expect(round).not.toBeNull();\n   402→        const hasPlayerB = round!.redEntries.some(\n   403→          (e) => e.player === PLAYER_B.publicKey.toBase58(),\n   404→        );\n   405→        expect(hasPlayerB).toBe(true);\n   406→      },\n   407→      { label: \"verifyPlayerBBet\", retries: 5, delayMs: 2_000 },\n   408→    );\n   409→    console.log(\"[phase-3] Player B RED bet verified in backend ✓\");\n   410→\n   411→    // ── Phase 4: Wait for settlement ───────────────────────────────────\n   412→    console.log(\"[phase-4] Waiting for oracle settlement...\");\n   413→    const settledRound = await waitForSettledRound(devnetConfig, roundId);\n   414→    console.log(\n   415→      `[phase-4] Round settled: outcome=${settledRound.outcome}, ` +\n   416→        `closePrice=${settledRound.closePrice}×10^${settledRound.openPriceExpo}`,\n   417→    );\n   418→\n   419→    // Verify settlement data\n   420→    expect([\"green\", \"red\", \"refund\"]).toContain(settledRound.outcome);\n   421→    expect(settledRound.closePrice).not.toBeNull();\n   422→    expect(settledRound.settleTx).toBeTruthy();\n   423→    expect(settledRound.settledAt).toBeTruthy();\n   424→\n   425→    if (\n   426→      settledRound.outcome === \"green\" ||\n   427→      settledRound.outcome === \"red\"\n   428→    ) {\n   429→      // Decisive round — fee should be collected\n   430→      expect(settledRound.totalFee).toBeGreaterThan(0);\n   431→      console.log(\n   432→        `[phase-4] Decisive outcome: ${settledRound.outcome.toUpperCase()}, ` +\n   433→          `fee=${settledRound.totalFee} lamports ✓`,\n   434→      );\n   435→    } else {\n   436→      // Refund (equal price) — no fee\n   437→      expect(settledRound.totalFee).toBe(0);\n   438→      console.log(\"[phase-4] Equal price → refund, no fee ✓\");\n   439→    }\n   440→\n   441→    // ── Phase 5: Verify round details page ─────────────────────────────\n   442→    console.log(\"[phase-5] Verifying round details page...\");\n   443→    await playerAPage.goto(`/close-call/${roundId}`);\n   444→    await expect(\n   445→      playerAPage.locator(\"h2, h3\").filter({ hasText: /Round Details/i }),\n   446→    ).toBeVisible({ timeout: 15_000 });\n   447→\n   448→    // Round ID should appear on the page\n   449→    await expect(\n   450→      playerAPage.getByText(roundId).first(),\n   451→    ).toBeVisible({ timeout: 5_000 });\n   452→    console.log(\"[phase-5] Round details page verified ✓\");\n   453→\n   454→    // ── Console error check ────────────────────────────────────────────\n   455→    const errA = filterNoise(consoleA.errors);\n   456→    const errB = filterNoise(consoleB.errors);\n   457→    if (errA.length > 0) console.warn(\"[console] Player A errors:\", errA);\n   458→    if (errB.length > 0) console.warn(\"[console] Player B errors:\", errB);\n   459→    expect(errA).toEqual([]);\n   460→    expect(errB).toEqual([]);\n   461→  });\n   462→});\n   463→"}]},"parent_tool_use_id":"toolu_01TLYzMfT9TdEHmVyfNA8V39","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"54462b4f-4b37-488b-b438-db5f33f3e01b"}
