{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qi5WiSUDSPdA2CEcB6cKQL","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Minimum wager in lamports: 0.001 SOL\n     4→pub const MIN_WAGER_LAMPORTS: u64 = 1_000_000;\n     5→\n     6→/// Maximum wager in lamports: 100 SOL\n     7→pub const MAX_WAGER_LAMPORTS: u64 = 100_000_000_000;\n     8→\n     9→/// Validates that a wager amount is within platform limits.\n    10→pub fn validate_wager(amount: u64) -> Result<()> {\n    11→    require!(amount >= MIN_WAGER_LAMPORTS, WagerError::BelowMinimum);\n    12→    require!(amount <= MAX_WAGER_LAMPORTS, WagerError::AboveMaximum);\n    13→    Ok(())\n    14→}\n    15→\n    16→#[error_code]\n    17→pub enum WagerError {\n    18→    #[msg(\"Wager amount below minimum (0.001 SOL)\")]\n    19→    BelowMinimum,\n    20→    #[msg(\"Wager amount above maximum (100 SOL)\")]\n    21→    AboveMaximum,\n    22→}\n    23→"}]},"parent_tool_use_id":"toolu_012FZFQthTpmV4TStVPM7FGb","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"6a024a0e-5f24-4451-8045-5bfd367b5878"}
