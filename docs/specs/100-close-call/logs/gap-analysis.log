   </div>\n   275→                <div className=\"close-call-history-modal__row\">\n   276→                  <span>Outcome</span>\n   277→                  <span\n   278→                    style={{\n   279→                      color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   280→                      textShadow: round.outcome ? `0 0 4px ${SIDE_COLORS[round.outcome]}` : undefined,\n   281→                    }}\n   282→                  >\n   283→                    {round.outcome?.toUpperCase() ?? \"?\"}\n   284→                  </span>\n   285→                </div>\n   286→                <div className=\"close-call-history-modal__row\">\n   287→                  <span>Result</span>\n   288→                  <span style={{ color: won ? SIDE_COLORS.green : \"#d45d5d\" }}>\n   289→                    {won ? \"WON!\" : \"LOST\"}\n   290→                  </span>\n   291→                </div>\n   292→                <div className=\"close-call-history-modal__row close-call-history-modal__row--highlight\">\n   293→                  <span>Payout</span>\n   294→                  <span className={won ? \"close-call-history-modal__highlight\" : \"\"}>\n   295→                    {won ? `+${payout.toFixed(4)} SOL` : `-${bet.amount.toFixed(4)} SOL`}\n   296→                  </span>\n   297→                </div>\n   298→              </div>\n   299→\n   300→              {/* Candle data */}\n   301→              {round.resultCandle && (\n   302→                <div className=\"close-call-history-modal__section\">\n   303→                  <h4 className=\"close-call-history-modal__section-title\">Candle Data</h4>\n   304→                  <div className=\"close-call-history-modal__row\">\n   305→                    <span>Open</span>\n   306→                    <span>${round.resultCandle.open.toFixed(2)}</span>\n   307→                  </div>\n   308→                  <div className=\"close-call-history-modal__row\">\n   309→                    <span>Close</span>\n   310→                    <span>${round.resultCandle.close.toFixed(2)}</span>\n   311→                  </div>\n   312→                  <div className=\"close-call-history-modal__row\">\n   313→                    <span>Change</span>\n   314→                    <span\n   315→                      style={{\n   316→                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   317→                      }}\n   318→                    >\n   319→                      {round.outcome === \"green\" ? \"+\" : \"\"}\n   320→                      {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n   321→                    </span>\n   322→                  </div>\n   323→                </div>\n   324→              )}\n   325→\n   326→              {/* Round info (oracle-resolved, no commit-reveal) */}\n   327→              <div className=\"close-call-history-modal__section\">\n   328→                <h4 className=\"close-call-history-modal__section-title\">\n   329→                  <span className=\"close-call-history-modal__lock\">🔒</span>\n   330→                  Oracle Verification\n   331→                </h4>\n   332→                <div className=\"close-call-history-modal__row\">\n   333→                  <span>Round ID</span>\n   334→                  <span className=\"close-call-history-modal__hash\" title={round.id}>\n   335→                    {round.id}\n   336→                  </span>\n   337→                </div>\n   338→                <div className=\"close-call-history-modal__row\">\n   339→                  <span>Oracle</span>\n   340→                  <span className=\"close-call-history-modal__hash\">Pyth BTC/USD</span>\n   341→                </div>\n   342→                {round.settleTx && (\n   343→                  <div className=\"close-call-history-modal__row\">\n   344→                    <span>Settlement Tx</span>\n   345→                    <span className=\"close-call-history-modal__hash close-call-history-modal__hash--revealed\" title={round.settleTx}>\n   346→                      {round.settleTx}\n   347→                    </span>\n   348→                  </div>\n   349→                )}\n   350→              </div>\n   351→\n   352→              {/* Verify link */}\n   353→              <Link to={`/close-call/${round.id}`} className=\"close-call-history-modal__verify-link\">\n   354→                View Round Details →\n   355→              </Link>\n   356→            </div>\n   357→          );\n   358→        })()}\n   359→      </Modal>\n   360→    </>\n   361→  );\n   362→}\n   363→\n   364→export function CloseCallPage() {\n   365→  return (\n   366→    <CloseCallProvider>\n   367→      <CloseCallPageContent />\n   368→    </CloseCallProvider>\n   369→  );\n   370→}\n   371→"}]},"parent_tool_use_id":null,"session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"b42ab257-81c4-453a-94e4-34d9c2e3247d","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/pages/CloseCallPage.tsx","content":"import { useState } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport { GameLayout, Modal, RoundResultBanner, type HistoryEntry } from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport {\n  CloseCallProvider,\n  useCloseCall,\n  CandlestickChart,\n  BetAmountInput,\n  SideSelector,\n  PoolDistribution,\n  SIDE_COLORS,\n  type UserRoundHistory,\n  type BetSide,\n} from \"../features/close-call\";\n\nfunction CloseCallPageContent() {\n  const { connected, connect, getBalance, address } = useWallet();\n  const {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    potentialPayout,\n    clearCompletedRound,\n  } = useCloseCall();\n\n  // State for history modal\n  const [selectedHistory, setSelectedHistory] = useState<UserRoundHistory | null>(null);\n\n  // Get user's bet in the completed round (if any)\n  const completedRoundUserBet = completedRound && address\n    ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n        (b) => b.address === address\n      ) ?? null\n    : null;\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((entry) => {\n    const sideColor = SIDE_COLORS[entry.userBet.side];\n    const outcomeColor = entry.won ? SIDE_COLORS.green : \"#d45d5d\";\n\n    return {\n      roundId: entry.round.id.slice(-8),\n      result: (\n        <span className=\"close-call-history-result\">\n          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n            {entry.userBet.side.toUpperCase()}\n          </span>\n          <span className=\"close-call-history-result__separator\">|</span>\n          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {entry.won ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: entry.won ? entry.payout : -entry.userBet.amount,\n      timestamp: new Date(entry.round.resolvedAt ?? entry.round.createdAt),\n      verified: true,\n      won: entry.won,\n      onClick: () => setSelectedHistory(entry),\n    };\n  });\n\n  // Handle placing bet with side selection\n  const handlePlaceBetWithSide = async (side: BetSide) => {\n    setPendingSide(side);\n    try {\n      await placeBet(side);\n    } catch (error) {\n      console.error(\"Failed to place bet:\", error);\n    }\n  };\n\n  // Determine if betting window is open (round is open and within betting time)\n  const isBettingOpen = currentRound?.phase === \"open\" && Date.now() < (currentRound?.bettingEndsAt ?? 0);\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"close-call-sidebar\">\n      {/* Bet amount input */}\n      <div className=\"close-call-sidebar__section\">\n        <BetAmountInput\n          value={pendingAmount}\n          onChange={setPendingAmount}\n          onAdjust={adjustBetAmount}\n          disabled={placingBet || !!userBet}\n          maxAmount={getBalance?.() ?? 10}\n        />\n      </div>\n\n      {/* Side selector - buttons place bets directly */}\n      <div className=\"close-call-sidebar__section\">\n        {!connected ? (\n          <button\n            type=\"button\"\n            className=\"close-call-action-btn\"\n            onClick={connect}\n          >\n            Connect Wallet\n          </button>\n        ) : (\n          <SideSelector\n            selectedSide={userBet?.side ?? pendingSide}\n            onSelect={handlePlaceBetWithSide}\n            disabled={!isBettingOpen || placingBet || pendingAmount <= 0 || !!userBet}\n            placingBet={placingBet}\n          />\n        )}\n      </div>\n\n      {/* Pool distribution - under the buttons */}\n      {currentRound && (\n        <div className=\"close-call-sidebar__section\">\n          <PoolDistribution\n            pool={currentRound.pool}\n            userBet={userBet}\n            potentialPayout={potentialPayout}\n            roundOutcome={currentRound.outcome}\n            isRoundComplete={currentRound.phase === \"settled\" || currentRound.phase === \"refunded\"}\n          />\n        </div>\n      )}\n\n      {/* Auto-payout message for winners - shown under prize pool */}\n      {completedRound && (() => {\n        const completedUserBet = address\n          ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n              (b) => b.address === address\n            ) ?? null\n          : null;\n        const isWinner = completedUserBet && completedRound.winners?.includes(completedUserBet.address);\n        const payout = completedUserBet && completedRound.payouts?.[completedUserBet.address];\n\n        if (isWinner && payout) {\n          return (\n            <div className=\"close-call-payout-received\">\n              <span className=\"close-call-payout-received__label\">Payout Received!</span>\n              <span className=\"close-call-payout-received__amount\">{`+${payout.toFixed(4)} SOL`}</span>\n            </div>\n          );\n        }\n        return null;\n      })()}\n\n      {/* Round info */}\n      {currentRound && (\n        <div className=\"close-call-sidebar__fairness\">\n          <h4 className=\"close-call-sidebar__fairness-title\">Round Info</h4>\n          <div className=\"close-call-sidebar__fairness-row\">\n            <span>Round ID</span>\n            <span className=\"close-call-sidebar__hash\" title={currentRound.id}>\n              {currentRound.id.slice(-12)}\n            </span>\n          </div>\n          <div className=\"close-call-sidebar__fairness-row\">\n            <span>Oracle</span>\n            <span className=\"close-call-sidebar__hash\">Pyth BTC/USD</span>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Close Call\"\n        gameDescription=\"A pari-mutuel prediction market game\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"close-call-main\">\n          {/* Result banner - positioned above the chart */}\n          {completedRound && (() => {\n            const outcome = completedRound.outcome;\n            const isUserWinner = completedRoundUserBet && completedRound.winners?.includes(completedRoundUserBet.address);\n            const userPayout = completedRoundUserBet && completedRound.payouts?.[completedRoundUserBet.address];\n            const outcomeColor = outcome === \"green\"\n              ? SIDE_COLORS.green\n              : outcome === \"red\"\n              ? SIDE_COLORS.red\n              : SIDE_COLORS.refund;\n\n            return (\n              <RoundResultBanner\n                outcomeText={outcome === \"refund\" ? \"REFUND\" : `${outcome?.toUpperCase()} WINS`}\n                outcomeColor={outcomeColor}\n                userWon={!!isUserWinner}\n                userLost={!!completedRoundUserBet && !isUserWinner && outcome !== \"refund\"}\n                statusText={\n                  !completedRoundUserBet\n                    ? undefined\n                    : isUserWinner\n                    ? \"You Won!\"\n                    : outcome === \"refund\"\n                    ? \"Bet refunded\"\n                    : \"You Lost\"\n                }\n                payoutAmount={\n                  completedRoundUserBet\n                    ? isUserWinner\n                      ? userPayout ?? undefined\n                      : outcome === \"refund\"\n                      ? undefined\n                      : -completedRoundUserBet.amount\n                    : undefined\n                }\n                onDismiss={clearCompletedRound}\n              />\n            );\n          })()}\n\n          {/* Banner: betting on current candle */}\n          <div className=\"close-call-main__banner\">\n            <span>\n              Will the current candle close{\" \"}\n              <span style={{ color: SIDE_COLORS.green }}>GREEN</span> or{\" \"}\n              <span style={{ color: SIDE_COLORS.red }}>RED</span>?\n            </span>\n          </div>\n\n          {/* Candlestick chart */}\n          {!loading && recentCandles.length > 0 ? (\n            <CandlestickChart\n              candles={recentCandles}\n              currentPrice={currentPrice}\n              progress={candleProgress}\n            />\n          ) : (\n            <div className=\"close-call-main__loading\">\n              <div className=\"close-call-main__spinner\" />\n              <span>Loading chart...</span>\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* History detail modal */}\n      <Modal\n        isOpen={selectedHistory !== null}\n        onClose={() => setSelectedHistory(null)}\n        title=\"Round Details\"\n      >\n        {selectedHistory && (() => {\n          const { round, userBet: bet, payout, won } = selectedHistory;\n          const sideColor = SIDE_COLORS[bet.side];\n\n          return (\n            <div className=\"close-call-history-modal\">\n              {/* Round stats */}\n              <div className=\"close-call-history-modal__section\">\n                <h4 className=\"close-call-history-modal__section-title\">Round Stats</h4>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {bet.side.toUpperCase()}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Your Stake</span>\n                  <span>{`${bet.amount.toFixed(4)} SOL`}</span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    style={{\n                      color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n                      textShadow: round.outcome ? `0 0 4px ${SIDE_COLORS[round.outcome]}` : undefined,\n                    }}\n                  >\n                    {round.outcome?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Result</span>\n                  <span style={{ color: won ? SIDE_COLORS.green : \"#d45d5d\" }}>\n                    {won ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row close-call-history-modal__row--highlight\">\n                  <span>Payout</span>\n                  <span className={won ? \"close-call-history-modal__highlight\" : \"\"}>\n                    {won ? `+${payout.toFixed(4)} SOL` : `-${bet.amount.toFixed(4)} SOL`}\n                  </span>\n                </div>\n              </div>\n\n              {/* Candle data */}\n              {round.resultCandle && (\n                <div className=\"close-call-history-modal__section\">\n                  <h4 className=\"close-call-history-modal__section-title\">Candle Data</h4>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Open</span>\n                    <span>${round.resultCandle.open.toFixed(2)}</span>\n                  </div>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Close</span>\n                    <span>${round.resultCandle.close.toFixed(2)}</span>\n                  </div>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Change</span>\n                    <span\n                      style={{\n                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n                      }}\n                    >\n                      {round.outcome === \"green\" ? \"+\" : \"\"}\n                      {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n                    </span>\n                  </div>\n                </div>\n              )}\n\n              {/* Round info (oracle-resolved, no commit-reveal) */}\n              <div className=\"close-call-history-modal__section\">\n                <h4 className=\"close-call-history-modal__section-title\">\n                  <span className=\"close-call-history-modal__lock\">🔒</span>\n                  Oracle Verification\n                </h4>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Round ID</span>\n                  <span className=\"close-call-history-modal__hash\" title={round.id}>\n                    {round.id}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Oracle</span>\n                  <span className=\"close-call-history-modal__hash\">Pyth BTC/USD</span>\n                </div>\n                {round.settleTx && (\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Settlement Tx</span>\n                    <span className=\"close-call-history-modal__hash close-call-history-modal__hash--revealed\" title={round.settleTx}>\n                      {round.settleTx}\n                    </span>\n                  </div>\n                )}\n              </div>\n\n              {/* Verify link */}\n              <Link to={`/close-call/${round.id}`} className=\"close-call-history-modal__verify-link\">\n                View Round Details →\n              </Link>\n            </div>\n          );\n        })()}\n      </Modal>\n    </>\n  );\n}\n\nexport function CloseCallPage() {\n  return (\n    <CloseCallProvider>\n      <CloseCallPageContent />\n    </CloseCallProvider>\n  );\n}\n","numLines":371,"startLine":1,"totalLines":371}}}
