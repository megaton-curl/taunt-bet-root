{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016r1dhfwRkwDXzVyf3rqdEe","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  created_at: Date;\n    74→  updated_at: Date;\n    75→}\n    76→\n    77→export interface InsertRoundParams {\n    78→  pda: string;\n    79→  game: string;\n    80→  creator: string;\n    81→  serverKey: string;\n    82→  secret: Buffer;\n    83→  commitment: Buffer;\n    84→  amountLamports: number;\n    85→  side: number;\n    86→  matchId: string;\n    87→  phase: RoundPhase;\n    88→}\n    89→\n    90→export interface OperatorEvent {\n    91→  id: string;\n    92→  pda: string | null;\n    93→  event_type: OperatorEventType;\n    94→  payload: unknown;\n    95→  created_at: Date;\n    96→}\n    97→\n    98→// ---------------------------------------------------------------------------\n    99→// Phase transition guard\n   100→// ---------------------------------------------------------------------------\n   101→\n   102→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   103→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   104→  created: [\"locked\", \"expired\"],\n   105→  locked: [\"settling\"],\n   106→  settling: [\"settled\"],\n   107→  settled: [],\n   108→  expired: [],\n   109→};\n   110→\n   111→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   112→  const allowed = VALID_TRANSITIONS[from];\n   113→  if (!allowed.includes(to)) {\n   114→    throw new Error(\n   115→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   116→    );\n   117→  }\n   118→}\n   119→\n   120→// ---------------------------------------------------------------------------\n   121→// DB client\n   122→// ---------------------------------------------------------------------------\n   123→\n   124→export interface Db {\n   125→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   126→  insertRound(params: InsertRoundParams): Promise<Round>;\n   127→\n   128→  /** Delete a round by PDA. Returns true if a row was removed. */\n   129→  deleteRoundByPda(pda: string): Promise<boolean>;\n   130→\n   131→  /** Transition a round's phase. Enforces unidirectional state machine.\n   132→   *  Optional `updates` can set additional columns alongside the phase change. */\n   133→  updateRoundPhase(\n   134→    pda: string,\n   135→    newPhase: RoundPhase,\n   136→    updates?: Partial<\n   137→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   138→    >,\n   139→  ): Promise<Round>;\n   140→\n   141→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   142→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   143→\n   144→  /** Get all rounds matching a given phase. */\n   145→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   146→\n   147→  /** Append an operator event to the audit log. */\n   148→  insertOperatorEvent(\n   149→    pda: string | null,\n   150→    eventType: OperatorEventType,\n   151→    payload?: unknown,\n   152→  ): Promise<OperatorEvent>;\n   153→\n   154→  /** Get the latest operator event for a PDA + type. */\n   155→  getLatestOperatorEvent(\n   156→    pda: string,\n   157→    eventType: OperatorEventType,\n   158→  ): Promise<OperatorEvent | undefined>;\n   159→\n   160→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   161→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   162→\n   163→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   164→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   165→\n   166→  // -------------------------------------------------------------------------\n   167→  // Close Call rounds\n   168→  // -------------------------------------------------------------------------\n   169→\n   170→  /** Insert a new Close Call round. */\n   171→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   172→\n   173→  /** Get a Close Call round by round_id (16-char hex). */\n   174→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   175→\n   176→  /** Get the current active (open) Close Call round. */\n   177→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   178→\n   179→  /** Get the most recent settled/refunded Close Call rounds. */\n   180→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   181→\n   182→  /** Update a Close Call round after settlement. */\n   183→  settleCloseCallRound(\n   184→    roundId: string,\n   185→    updates: {\n   186→      phase: CloseCallPhase;\n   187→      outcome: CloseCallOutcome;\n   188→      closePrice?: number;\n   189→      greenPool?: number;\n   190→      redPool?: number;\n   191→      totalFee?: number;\n   192→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   193→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   194→      settleTx?: string;\n   195→    },\n   196→  ): Promise<CloseCallRound>;\n   197→\n   198→  /** Gracefully close the connection pool. */\n   199→  close(): Promise<void>;\n   200→}\n   201→\n   202→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   203→  return {\n   204→    ...row,\n   205→    open_price: Number(row.open_price),\n   206→    open_price_expo: Number(row.open_price_expo),\n   207→    close_price: row.close_price === null ? null : Number(row.close_price),\n   208→    green_pool: Number(row.green_pool),\n   209→    red_pool: Number(row.red_pool),\n   210→    total_fee: Number(row.total_fee),\n   211→    // JSONB comes back as parsed objects from postgres.js\n   212→    green_entries: Array.isArray(row.green_entries)\n   213→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   214→      : [],\n   215→    red_entries: Array.isArray(row.red_entries)\n   216→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   217→      : [],\n   218→  };\n   219→}\n   220→\n   221→function normalizeRound(row: Round): Round {\n   222→  return {\n   223→    ...row,\n   224→    amount_lamports: Number(row.amount_lamports),\n   225→    side: Number(row.side),\n   226→    settle_attempts: Number(row.settle_attempts),\n   227→    result_side: row.result_side === null ? null : Number(row.result_side),\n   228→  };\n   229→}\n   230→\n   231→export function createDb(databaseUrl: string): Db {\n   232→  const sql = postgres(databaseUrl);\n   233→\n   234→  return {\n   235→    async insertRound(params) {\n   236→      const rows = await sql<Round[]>`\n   237→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)\n   238→        VALUES (\n   239→          ${params.pda},\n   240→          ${params.game},\n   241→          ${params.creator},\n   242→          ${params.serverKey},\n   243→          ${params.secret},\n   244→          ${params.commitment},\n   245→          ${params.amountLamports},\n   246→          ${params.side},\n   247→          ${params.matchId},\n   248→          ${params.phase}\n   249→        )\n   250→        RETURNING *\n   251→      `;\n   252→      return normalizeRound(rows[0]!);\n   253→    },\n   254→\n   255→    async deleteRoundByPda(pda) {\n   256→      const rows = await sql<{ pda: string }[]>`\n   257→        DELETE FROM rounds WHERE pda = ${pda}\n   258→        RETURNING pda\n   259→      `;\n   260→      return rows.length > 0;\n   261→    },\n   262→\n   263→    async updateRoundPhase(pda, newPhase, updates) {\n   264→      // Fetch current phase to validate transition\n   265→      const current = await sql<Pick<Round, \"phase\">[]>`\n   266→        SELECT phase FROM rounds WHERE pda = ${pda}\n   267→      `;\n   268→\n   269→      if (current.length === 0) {\n   270→        throw new Error(`Round not found: ${pda}`);\n   271→      }\n   272→\n   273→      const currentPhase = current[0]!.phase as RoundPhase;\n   274→      assertPhaseTransition(currentPhase, newPhase);\n   275→\n   276→      // Build the update — always set phase + updated_at\n   277→      const rows = await sql<Round[]>`\n   278→        UPDATE rounds SET\n   279→          phase = ${newPhase},\n   280→          updated_at = now(),\n   281→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   282→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   283→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   284→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   285→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   286→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   287→        WHERE pda = ${pda}\n   288→        RETURNING *\n   289→      `;\n   290→\n   291→      return normalizeRound(rows[0]!);\n   292→    },\n   293→\n   294→    async getRoundByPda(pda) {\n   295→      const rows = await sql<Round[]>`\n   296→        SELECT * FROM rounds WHERE pda = ${pda}\n   297→      `;\n   298→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   299→    },\n   300→\n   301→    async getRoundByMatchId(matchId) {\n   302→      const rows = await sql<Round[]>`\n   303→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   304→      `;\n   305→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   306→    },\n   307→\n   308→    async getRoundsByPhase(phase) {\n   309→      const rows = await sql<Round[]>`\n   310→        SELECT * FROM rounds WHERE phase = ${phase}\n   311→      `;\n   312→      return rows.map(normalizeRound);\n   313→    },\n   314→\n   315→    async insertOperatorEvent(pda, eventType, payload) {\n   316→      const rows = await sql<OperatorEvent[]>`\n   317→        INSERT INTO operator_events (pda, event_type, payload)\n   318→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   319→        RETURNING *\n   320→      `;\n   321→      return rows[0]!;\n   322→    },\n   323→\n   324→    async getLatestOperatorEvent(pda, eventType) {\n   325→      const rows = await sql<OperatorEvent[]>`\n   326→        SELECT * FROM operator_events\n   327→        WHERE pda = ${pda} AND event_type = ${eventType}\n   328→        ORDER BY id DESC\n   329→        LIMIT 1\n   330→      `;\n   331→      return rows[0];\n   332→    },\n   333→\n   334→    async getUnsettledStats() {\n   335→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   336→        SELECT\n   337→          COUNT(*)::text AS count,\n   338→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   339→        FROM rounds\n   340→        WHERE phase NOT IN ('settled', 'expired')\n   341→      `;\n   342→      const row = rows[0]!;\n   343→      return {\n   344→        count: parseInt(row.count, 10),\n   345→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   346→      };\n   347→    },\n   348→\n   349→    // -----------------------------------------------------------------------\n   350→    // Close Call rounds\n   351→    // -----------------------------------------------------------------------\n   352→\n   353→    async insertCloseCallRound(params) {\n   354→      const rows = await sql<CloseCallRound[]>`\n   355→        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   356→        VALUES (\n   357→          ${params.roundId},\n   358→          ${params.pda},\n   359→          ${params.serverKey},\n   360→          ${params.openPrice},\n   361→          ${params.openPriceExpo}\n   362→        )\n   363→        RETURNING *\n   364→      `;\n   365→      return normalizeCloseCallRound(rows[0]!);\n   366→    },\n   367→\n   368→    async getCloseCallRound(roundId) {\n   369→      const rows = await sql<CloseCallRound[]>`\n   370→        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   371→      `;\n   372→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   373→    },\n   374→\n   375→    async getCloseCallCurrentRound() {\n   376→      const rows = await sql<CloseCallRound[]>`\n   377→        SELECT * FROM closecall_rounds\n   378→        WHERE phase = 'open'\n   379→        ORDER BY created_at DESC\n   380→        LIMIT 1\n   381→      `;\n   382→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   383→    },\n   384→\n   385→    async getCloseCallHistory(limit) {\n   386→      const rows = await sql<CloseCallRound[]>`\n   387→        SELECT * FROM closecall_rounds\n   388→        WHERE phase IN ('settled', 'refunded')\n   389→        ORDER BY settled_at DESC\n   390→        LIMIT ${limit}\n   391→      `;\n   392→      return rows.map(normalizeCloseCallRound);\n   393→    },\n   394→\n   395→    async settleCloseCallRound(roundId, updates) {\n   396→      const rows = await sql<CloseCallRound[]>`\n   397→        UPDATE closecall_rounds SET\n   398→          phase = ${updates.phase},\n   399→          outcome = ${updates.outcome},\n   400→          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   401→          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   402→          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   403→          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   404→          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   405→          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   406→          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   407→          settled_at = now()\n   408→        WHERE round_id = ${roundId}\n   409→        RETURNING *\n   410→      `;\n   411→      if (rows.length === 0) {\n   412→        throw new Error(`Close Call round not found: ${roundId}`);\n   413→      }\n   414→      return normalizeCloseCallRound(rows[0]!);\n   415→    },\n   416→\n   417→    async close() {\n   418→      await sql.end();\n   419→    },\n   420→  };\n   421→}\n   422→"}]},"parent_tool_use_id":"toolu_01GaMdELGmU7U8bC6tXEpTmX","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"c35b5ef4-d481-49d8-999d-048d30fadf02"}
