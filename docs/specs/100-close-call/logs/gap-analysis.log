{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VHuDYvhzBt2DPfaQLeNugZ","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useEffect,\n     6→  useCallback,\n     7→  ReactNode,\n     8→} from \"react\";\n     9→import { Asset, PriceData, PYTH_FEED_IDS } from \"./types\";\n    10→\n    11→interface PriceFeedContextValue {\n    12→  prices: Map<Asset, PriceData>;\n    13→  subscribe: (asset: Asset) => () => void;\n    14→  getPrice: (asset: Asset) => PriceData | null;\n    15→}\n    16→\n    17→const PriceFeedContext = createContext<PriceFeedContextValue | null>(null);\n    18→\n    19→interface PriceFeedProviderProps {\n    20→  children: ReactNode;\n    21→  pythEndpoint?: string;\n    22→}\n    23→\n    24→const DEFAULT_PYTH_ENDPOINT = \"https://hermes.pyth.network\";\n    25→\n    26→export function PriceFeedProvider({\n    27→  children,\n    28→  pythEndpoint = DEFAULT_PYTH_ENDPOINT,\n    29→}: PriceFeedProviderProps) {\n    30→  const [prices, setPrices] = useState<Map<Asset, PriceData>>(new Map());\n    31→  const [subscriptions, setSubscriptions] = useState<Set<Asset>>(new Set());\n    32→\n    33→  useEffect(() => {\n    34→    if (subscriptions.size === 0) return;\n    35→\n    36→    const feedIds = Array.from(subscriptions).map((asset) => PYTH_FEED_IDS[asset]);\n    37→\n    38→    // Create WebSocket connection to Pyth\n    39→    const ws = new WebSocket(`${pythEndpoint.replace(\"https\", \"wss\")}/ws`);\n    40→\n    41→    ws.onopen = () => {\n    42→      ws.send(\n    43→        JSON.stringify({\n    44→          type: \"subscribe\",\n    45→          ids: feedIds,\n    46→        })\n    47→      );\n    48→    };\n    49→\n    50→    ws.onmessage = (event) => {\n    51→      try {\n    52→        const data = JSON.parse(event.data);\n    53→        if (data.type === \"price_update\") {\n    54→          const feedId = data.price_feed.id;\n    55→          const asset = (Object.entries(PYTH_FEED_IDS).find(\n    56→            ([, id]) => id === feedId\n    57→          )?.[0] ?? null) as Asset | null;\n    58→\n    59→          if (asset) {\n    60→            const priceData: PriceData = {\n    61→              asset,\n    62→              price: parseFloat(data.price_feed.price.price) *\n    63→                Math.pow(10, data.price_feed.price.expo),\n    64→              confidence: parseFloat(data.price_feed.price.conf) *\n    65→                Math.pow(10, data.price_feed.price.expo),\n    66→              timestamp: Date.now(),\n    67→              publishTime: data.price_feed.price.publish_time * 1000,\n    68→            };\n    69→\n    70→            setPrices((prev) => new Map(prev).set(asset, priceData));\n    71→          }\n    72→        }\n    73→      } catch {\n    74→        // Ignore parse errors\n    75→      }\n    76→    };\n    77→\n    78→    ws.onerror = (error) => {\n    79→      console.error(\"Price feed WebSocket error:\", error);\n    80→    };\n    81→\n    82→    return () => {\n    83→      ws.close();\n    84→    };\n    85→  }, [subscriptions, pythEndpoint]);\n    86→\n    87→  const subscribe = useCallback((asset: Asset) => {\n    88→    setSubscriptions((prev) => new Set(prev).add(asset));\n    89→    return () => {\n    90→      setSubscriptions((prev) => {\n    91→        const next = new Set(prev);\n    92→        next.delete(asset);\n    93→        return next;\n    94→      });\n    95→    };\n    96→  }, []);\n    97→\n    98→  const getPrice = useCallback(\n    99→    (asset: Asset) => prices.get(asset) ?? null,\n   100→    [prices]\n   101→  );\n   102→\n   103→  return (\n   104→    <PriceFeedContext.Provider value={{ prices, subscribe, getPrice }}>\n   105→      {children}\n   106→    </PriceFeedContext.Provider>\n   107→  );\n   108→}\n   109→\n   110→export function usePriceSubscription(asset: Asset): PriceData | null {\n   111→  const context = useContext(PriceFeedContext);\n   112→  if (!context) {\n   113→    throw new Error(\"usePriceSubscription must be used within PriceFeedProvider\");\n   114→  }\n   115→\n   116→  const { subscribe, getPrice } = context;\n   117→\n   118→  useEffect(() => {\n   119→    return subscribe(asset);\n   120→  }, [asset, subscribe]);\n   121→\n   122→  return getPrice(asset);\n   123→}\n   124→"}]},"parent_tool_use_id":"toolu_01FXsjh7md8SDg3DtRL2sVq3","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"739ec35c-b2f9-4241-b61b-c33e4c8709eb"}
