{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RhVicyWVeoFZg76L5VaeBA","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→import { ClosecallIDL } from \"@rng-utopia/anchor-client\";\n     3→\n     4→// ============ Program IDs ============\n     5→\n     6→export const CLOSECALL_PROGRAM_ID = new PublicKey(\n     7→  ClosecallIDL.address\n     8→);\n     9→\n    10→// ============ PDA Derivation ============\n    11→\n    12→/**\n    13→ * Derive the round PDA.\n    14→ * Seeds: [\"cc_round\", round_id (8 bytes)]\n    15→ */\n    16→export function getCloseCallRoundPda(\n    17→  roundId: Uint8Array\n    18→): [PublicKey, number] {\n    19→  return PublicKey.findProgramAddressSync(\n    20→    [Buffer.from(\"cc_round\"), Buffer.from(roundId)],\n    21→    CLOSECALL_PROGRAM_ID\n    22→  );\n    23→}\n    24→\n    25→/**\n    26→ * Derive the global config PDA.\n    27→ * Seeds: [\"closecall_config\"]\n    28→ */\n    29→export function getCloseCallConfigPda(): [PublicKey, number] {\n    30→  return PublicKey.findProgramAddressSync(\n    31→    [Buffer.from(\"closecall_config\")],\n    32→    CLOSECALL_PROGRAM_ID\n    33→  );\n    34→}\n    35→"}]},"parent_tool_use_id":"toolu_01FXsjh7md8SDg3DtRL2sVq3","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"04207893-605a-4742-b56d-28b578b33c41"}
