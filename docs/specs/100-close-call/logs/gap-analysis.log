{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PuHMMEkz4wYiPYQrmkTc7D","type":"tool_result","content":"     1→/**\n     2→ * Close Call API routes.\n     3→ *\n     4→ * GET /closecall/current-round — active round + pool state\n     5→ * GET /closecall/history       — last N settled/refunded rounds\n     6→ */\n     7→\n     8→import { Hono } from \"hono\";\n     9→import type { CloseCallRound, Db } from \"../db.js\";\n    10→\n    11→export interface CloseCallRoutesDeps {\n    12→  db: Db;\n    13→}\n    14→\n    15→function formatCloseCallRound(round: CloseCallRound) {\n    16→  const totalPool = round.green_pool + round.red_pool;\n    17→  return {\n    18→    roundId: round.round_id,\n    19→    pda: round.pda,\n    20→    phase: round.phase,\n    21→    openPrice: round.open_price,\n    22→    openPriceExpo: round.open_price_expo,\n    23→    closePrice: round.close_price,\n    24→    outcome: round.outcome,\n    25→    greenPool: round.green_pool,\n    26→    redPool: round.red_pool,\n    27→    totalPool,\n    28→    totalFee: round.total_fee,\n    29→    greenEntries: round.green_entries,\n    30→    redEntries: round.red_entries,\n    31→    greenCount: round.green_entries.length,\n    32→    redCount: round.red_entries.length,\n    33→    settleTx: round.settle_tx,\n    34→    createdAt: round.created_at.toISOString(),\n    35→    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n    36→  };\n    37→}\n    38→\n    39→export function createCloseCallRoutes(deps: CloseCallRoutesDeps): Hono {\n    40→  const { db } = deps;\n    41→  const app = new Hono();\n    42→\n    43→  app.get(\"/current-round\", async (c) => {\n    44→    const round = await db.getCloseCallCurrentRound();\n    45→    if (!round) {\n    46→      return c.json({ round: null });\n    47→    }\n    48→    return c.json({ round: formatCloseCallRound(round) });\n    49→  });\n    50→\n    51→  app.get(\"/history\", async (c) => {\n    52→    const limitParam = c.req.query(\"limit\");\n    53→    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n    54→    const rounds = await db.getCloseCallHistory(limit);\n    55→    return c.json({ rounds: rounds.map(formatCloseCallRound) });\n    56→  });\n    57→\n    58→  return app;\n    59→}\n    60→"}]},"parent_tool_use_id":"toolu_01GaMdELGmU7U8bC6tXEpTmX","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"e051a50e-1a88-420a-b3ec-cb6beb45f461"}
