{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013BKhw8FEfHrqx2sL7BhKr3","type":"tool_result","content":"     1→import type { PoolState, PlayerBet, CandleOutcome } from \"../types\";\n     2→import { SIDE_COLORS, PLATFORM_FEE } from \"../types\";\n     3→\n     4→interface PoolDistributionProps {\n     5→  pool: PoolState;\n     6→  userBet?: PlayerBet | null;\n     7→  potentialPayout?: number;\n     8→  roundOutcome?: CandleOutcome | null;\n     9→  isRoundComplete?: boolean;\n    10→}\n    11→\n    12→export function PoolDistribution({\n    13→  pool,\n    14→  userBet,\n    15→  potentialPayout = 0,\n    16→  roundOutcome,\n    17→  isRoundComplete = false,\n    18→}: PoolDistributionProps) {\n    19→  // Determine if user won or lost\n    20→  const userWon = isRoundComplete && userBet && roundOutcome && userBet.side === roundOutcome;\n    21→  const userLost = isRoundComplete && userBet && roundOutcome && roundOutcome !== \"refund\" && userBet.side !== roundOutcome;\n    22→  const totalPool = pool.totalPool;\n    23→\n    24→  // Calculate percentages\n    25→  const greenPercent = pool.totalPool > 0 ? (pool.greenPool / pool.totalPool) * 100 : 50;\n    26→  const redPercent = pool.totalPool > 0 ? (pool.redPool / pool.totalPool) * 100 : 50;\n    27→\n    28→  // Calculate odds multiplier for each side\n    29→  const netPool = totalPool * (1 - PLATFORM_FEE);\n    30→  const greenOdds = pool.greenPool > 0 ? netPool / pool.greenPool : 0;\n    31→  const redOdds = pool.redPool > 0 ? netPool / pool.redPool : 0;\n    32→\n    33→  // Format odds display\n    34→  const formatOdds = (odds: number): string => {\n    35→    if (odds === 0) return \"∞\";\n    36→    return `${odds.toFixed(2)}x`;\n    37→  };\n    38→\n    39→  return (\n    40→    <div className=\"close-call-pool-bar\">\n    41→      {/* Percentages only - no GREEN/RED labels */}\n    42→      <div className=\"close-call-pool-bar__labels\">\n    43→        <span\n    44→          className=\"close-call-pool-bar__label close-call-pool-bar__label--green\"\n    45→          style={{ color: SIDE_COLORS.green }}\n    46→        >\n    47→          {greenPercent.toFixed(0)}%\n    48→        </span>\n    49→        <span\n    50→          className=\"close-call-pool-bar__label close-call-pool-bar__label--red\"\n    51→          style={{ color: SIDE_COLORS.red }}\n    52→        >\n    53→          {redPercent.toFixed(0)}%\n    54→        </span>\n    55→      </div>\n    56→\n    57→      {/* Progress bar */}\n    58→      <div className=\"close-call-pool-bar__track\">\n    59→        <div\n    60→          className=\"close-call-pool-bar__fill close-call-pool-bar__fill--green\"\n    61→          style={{\n    62→            width: `${greenPercent}%`,\n    63→            backgroundColor: SIDE_COLORS.green,\n    64→          }}\n    65→        />\n    66→        <div\n    67→          className=\"close-call-pool-bar__fill close-call-pool-bar__fill--red\"\n    68→          style={{\n    69→            width: `${redPercent}%`,\n    70→            backgroundColor: SIDE_COLORS.red,\n    71→          }}\n    72→        />\n    73→      </div>\n    74→\n    75→      {/* Pool amounts and multipliers */}\n    76→      <div className=\"close-call-pool-bar__stats\">\n    77→        <div className=\"close-call-pool-bar__stat close-call-pool-bar__stat--green\">\n    78→          <span className=\"close-call-pool-bar__pool-amount\" style={{ color: SIDE_COLORS.green }}>\n    79→            {pool.greenPool.toFixed(4)} SOL\n    80→          </span>\n    81→          <span className=\"close-call-pool-bar__odds\" style={{ color: SIDE_COLORS.green }}>\n    82→            ~{formatOdds(greenOdds)}\n    83→          </span>\n    84→        </div>\n    85→        <div className=\"close-call-pool-bar__stat close-call-pool-bar__stat--red\">\n    86→          <span className=\"close-call-pool-bar__pool-amount\" style={{ color: SIDE_COLORS.red }}>\n    87→            {pool.redPool.toFixed(4)} SOL\n    88→          </span>\n    89→          <span className=\"close-call-pool-bar__odds\" style={{ color: SIDE_COLORS.red }}>\n    90→            ~{formatOdds(redOdds)}\n    91→          </span>\n    92→        </div>\n    93→      </div>\n    94→\n    95→      {/* Prize Pool - striking display */}\n    96→      <div className=\"close-call-pool-bar__prize\">\n    97→        <div className=\"close-call-pool-bar__prize-label\">PRIZE POOL</div>\n    98→        <div className=\"close-call-pool-bar__prize-amount\">\n    99→          <span className=\"close-call-pool-bar__prize-sol\">{totalPool.toFixed(4)} SOL</span>\n   100→        </div>\n   101→\n   102→        {/* User's bet stats when they have an active bet */}\n   103→        {userBet && (\n   104→          <div className={`close-call-pool-bar__user-bet ${userWon ? \"close-call-pool-bar__user-bet--won\" : \"\"} ${userLost ? \"close-call-pool-bar__user-bet--lost\" : \"\"}`}>\n   105→            {/* Win animation */}\n   106→            {userWon && (\n   107→              <div className=\"close-call-pool-bar__win-animation\">\n   108→                <div className=\"close-call-pool-bar__stars\">\n   109→                  {[...Array(6)].map((_, i) => (\n   110→                    <span key={i} className=\"close-call-pool-bar__star\" style={{ \"--star-index\": i } as React.CSSProperties}>★</span>\n   111→                  ))}\n   112→                </div>\n   113→                <div className=\"close-call-pool-bar__coins\">\n   114→                  {[...Array(4)].map((_, i) => (\n   115→                    <span key={i} className=\"close-call-pool-bar__coin\" style={{ \"--coin-index\": i } as React.CSSProperties}>●</span>\n   116→                  ))}\n   117→                </div>\n   118→              </div>\n   119→            )}\n   120→\n   121→            {/* Loss animation */}\n   122→            {userLost && (\n   123→              <div className=\"close-call-pool-bar__loss-animation\">\n   124→                <span className=\"close-call-pool-bar__heartbreak\">💔</span>\n   125→              </div>\n   126→            )}\n   127→\n   128→            {/* Header: Joined GREEN/RED */}\n   129→            <div\n   130→              className=\"close-call-pool-bar__user-bet-header\"\n   131→              style={{ color: SIDE_COLORS[userBet.side] }}\n   132→            >\n   133→              Joined {userBet.side.toUpperCase()}\n   134→            </div>\n   135→\n   136→            {/* Amount row */}\n   137→            <div className=\"close-call-pool-bar__user-bet-row\">\n   138→              <span className=\"close-call-pool-bar__user-bet-label\">Amount</span>\n   139→              <span className=\"close-call-pool-bar__user-bet-value\">\n   140→                {userBet.amount.toFixed(4)} SOL\n   141→              </span>\n   142→            </div>\n   143→\n   144→            {/* Potential Payout row */}\n   145→            {potentialPayout > 0 && (\n   146→              <div className=\"close-call-pool-bar__user-bet-row close-call-pool-bar__user-bet-row--payout\">\n   147→                <span className=\"close-call-pool-bar__user-bet-label\">\n   148→                  {userWon ? \"Payout\" : \"Potential Payout\"}\n   149→                </span>\n   150→                <span className={`close-call-pool-bar__user-bet-value ${userWon ? \"close-call-pool-bar__user-bet-value--won\" : \"\"}`}>\n   151→                  {potentialPayout.toFixed(4)} SOL\n   152→                </span>\n   153→              </div>\n   154→            )}\n   155→          </div>\n   156→        )}\n   157→      </div>\n   158→    </div>\n   159→  );\n   160→}\n   161→"}]},"parent_tool_use_id":"toolu_01RpjArQNMWSuEkvHoxYSREy","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"dd45b7da-ff52-4777-adf5-31fd3def1032"}
