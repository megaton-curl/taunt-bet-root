{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NRik35ZTrGCu8UkwSgHSJS","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::system_program;\n     3→\n     4→/// Error codes for escrow operations.\n     5→#[error_code]\n     6→pub enum EscrowError {\n     7→    /// The escrow PDA does not hold enough lamports for the requested transfer.\n     8→    #[msg(\"Insufficient escrow balance\")]\n     9→    InsufficientEscrowBalance,\n    10→}\n    11→\n    12→/// Transfers lamports from a PDA to a recipient using direct lamport manipulation.\n    13→///\n    14→/// This is the standard pattern for moving funds out of a program-owned PDA\n    15→/// (e.g., paying out a winner, refunding a player, sending fees to treasury).\n    16→///\n    17→/// # Example\n    18→/// ```ignore\n    19→/// transfer_lamports_from_pda(\n    20→///     &ctx.accounts.coinflip_match.to_account_info(),\n    21→///     &ctx.accounts.winner.to_account_info(),\n    22→///     payout_amount,\n    23→/// )?;\n    24→/// ```\n    25→pub fn transfer_lamports_from_pda(\n    26→    pda: &AccountInfo,\n    27→    recipient: &AccountInfo,\n    28→    amount: u64,\n    29→) -> Result<()> {\n    30→    let pda_balance = pda.lamports();\n    31→    require!(pda_balance >= amount, EscrowError::InsufficientEscrowBalance);\n    32→\n    33→    **pda.try_borrow_mut_lamports()? -= amount;\n    34→    **recipient.try_borrow_mut_lamports()? += amount;\n    35→\n    36→    Ok(())\n    37→}\n    38→\n    39→/// Drains all remaining lamports from a PDA to a recipient and zeros the\n    40→/// account data. The Solana runtime garbage-collects zero-lamport accounts.\n    41→///\n    42→/// Use after all explicit transfers (payouts, fees, refunds) are done.\n    43→pub fn close_pda(pda: &AccountInfo, recipient: &AccountInfo) -> Result<()> {\n    44→    let remaining = pda.lamports();\n    45→    **recipient.try_borrow_mut_lamports()? += remaining;\n    46→    **pda.try_borrow_mut_lamports()? = 0;\n    47→    pda.data.borrow_mut().fill(0);\n    48→    Ok(())\n    49→}\n    50→\n    51→/// Transfers lamports from a signer to a PDA using system program CPI.\n    52→///\n    53→/// This is the standard pattern for depositing funds into an escrow PDA\n    54→/// (e.g., a player funding a match entry).\n    55→///\n    56→/// # Example\n    57→/// ```ignore\n    58→/// transfer_lamports_to_pda(\n    59→///     &ctx.accounts.creator.to_account_info(),\n    60→///     &ctx.accounts.coinflip_match.to_account_info(),\n    61→///     entry_amount,\n    62→///     &ctx.accounts.system_program.to_account_info(),\n    63→/// )?;\n    64→/// ```\n    65→pub fn transfer_lamports_to_pda<'a>(\n    66→    from: &AccountInfo<'a>,\n    67→    pda: &AccountInfo<'a>,\n    68→    amount: u64,\n    69→    system_program_info: &AccountInfo<'a>,\n    70→) -> Result<()> {\n    71→    system_program::transfer(\n    72→        CpiContext::new(\n    73→            system_program_info.clone(),\n    74→            system_program::Transfer {\n    75→                from: from.clone(),\n    76→                to: pda.clone(),\n    77→            },\n    78→        ),\n    79→        amount,\n    80→    )\n    81→}\n    82→"}]},"parent_tool_use_id":"toolu_012FZFQthTpmV4TStVPM7FGb","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"55486489-90b5-434c-b8b4-f71a902799e8"}
