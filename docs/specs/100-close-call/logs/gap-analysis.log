{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XyuQ9zU4C1ukjVV9cRyPDv","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createAuthRoutes } from \"./routes/auth.js\";\n    15→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    16→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    17→import { createSettlementWorker } from \"./worker/settlement.js\";\n    18→import { settleRound } from \"./worker/settle-tx.js\";\n    19→import { createRetrySettler } from \"./worker/retry.js\";\n    20→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    21→import { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    22→import { logger } from \"./logger.js\";\n    23→\n    24→const config = loadConfig();\n    25→\n    26→// Shared postgres connection for both game DB and auth DB\n    27→const sql = postgres(config.databaseUrl);\n    28→const db = createDb(config.databaseUrl);\n    29→const authDb = createAuthDb(sql);\n    30→\n    31→const connection = new Connection(config.rpcUrl, {\n    32→  commitment: \"confirmed\",\n    33→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    34→});\n    35→\n    36→const app = new Hono();\n    37→\n    38→app.use(\n    39→  \"*\",\n    40→  cors({\n    41→    origin: \"*\",\n    42→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    43→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    44→  }),\n    45→);\n    46→\n    47→// Request logging — correlate frontend fetch timing with server-side processing\n    48→app.use(\"*\", async (c, next) => {\n    49→  const start = Date.now();\n    50→  await next();\n    51→  const ms = Date.now() - start;\n    52→  const method = c.req.method;\n    53→  const path = c.req.path;\n    54→  // Skip noisy health checks and OPTIONS preflight\n    55→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    56→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    57→});\n    58→\n    59→// Auth routes — no JWT middleware (these are the login endpoints)\n    60→// Lighter rate limiting by IP for auth endpoints\n    61→app.use(\n    62→  \"/auth/*\",\n    63→  createRateLimitMiddleware({\n    64→    perWallet: 20,\n    65→    global: config.rateLimitGlobal,\n    66→    windowMs: 60_000,\n    67→  }),\n    68→);\n    69→\n    70→app.route(\n    71→  \"/auth\",\n    72→  createAuthRoutes({\n    73→    authDb,\n    74→    jwtSecret: config.jwtSecret,\n    75→    cluster: config.cluster,\n    76→    challengeTtlSeconds: config.challengeTtlSeconds,\n    77→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    78→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    79→  }),\n    80→);\n    81→\n    82→// JWT auth middleware for fairness endpoints\n    83→app.use(\n    84→  \"/fairness/*\",\n    85→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n    86→);\n    87→\n    88→// Rate limiting — per-wallet and global limits on POST requests\n    89→app.use(\n    90→  \"/fairness/*\",\n    91→  createRateLimitMiddleware({\n    92→    perWallet: config.rateLimitPerWallet,\n    93→    global: config.rateLimitGlobal,\n    94→    windowMs: 60_000,\n    95→  }),\n    96→);\n    97→\n    98→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n    99→const entropyAccount = new PublicKey(config.entropyAccount);\n   100→const retrySettler = createRetrySettler({\n   101→  db,\n   102→  connection,\n   103→  settleRound: (pda) =>\n   104→    settleRound(\n   105→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n   106→      pda,\n   107→    ),\n   108→});\n   109→\n   110→// PDA watcher — WebSocket-based instant join detection\n   111→const pdaWatcher = createPdaWatcher({\n   112→  connection,\n   113→  serverKey: config.serverKeypair.publicKey,\n   114→  onJoinDetected: async (pda, targetSlot) => {\n   115→    // Update DB phase if still in 'created'\n   116→    const round = await db.getRoundByPda(pda);\n   117→    if (round && round.phase === \"created\") {\n   118→      await db.updateRoundPhase(pda, \"locked\", {\n   119→        target_slot: targetSlot.toString(),\n   120→      });\n   121→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   122→        targetSlot: targetSlot.toString(),\n   123→        source: \"pda-watcher\",\n   124→        game: round.game,\n   125→      });\n   126→    }\n   127→\n   128→    // Check if target slot already passed — settle immediately if so\n   129→    const currentSlot = await connection.getSlot();\n   130→    if (BigInt(currentSlot) >= targetSlot) {\n   131→      await retrySettler.attemptSettle(pda);\n   132→      pdaWatcher.unwatch(pda);\n   133→    }\n   134→    // If target slot not reached yet, poll worker will pick it up next cycle\n   135→  },\n   136→});\n   137→\n   138→const worker = createSettlementWorker({\n   139→  db,\n   140→  connection,\n   141→  serverKey: config.serverKeypair.publicKey,\n   142→  pollIntervalMs: config.workerPollIntervalMs,\n   143→  onSettleReady: async (pda) => {\n   144→    await retrySettler.attemptSettle(pda);\n   145→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   146→  },\n   147→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   148→});\n   149→worker.start();\n   150→"}]},"parent_tool_use_id":"toolu_01GaMdELGmU7U8bC6tXEpTmX","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"d4da8531-805b-4f80-88eb-1d0e7cdfc8e5"}
