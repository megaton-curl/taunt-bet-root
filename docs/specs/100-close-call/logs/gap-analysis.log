{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UdXV2KASgv9RmBur4cUiSA","type":"tool_result","content":"     1→import { useEffect, useState } from \"react\";\n     2→import type { Round, PlayerBet } from \"../types\";\n     3→import { SIDE_COLORS } from \"../types\";\n     4→\n     5→interface RoundResultOverlayProps {\n     6→  round: Round;\n     7→  userBet: PlayerBet | null;\n     8→  onClose: () => void;\n     9→}\n    10→\n    11→export function RoundResultOverlay({\n    12→  round,\n    13→  userBet,\n    14→  onClose,\n    15→}: RoundResultOverlayProps) {\n    16→  const [isVisible, setIsVisible] = useState(false);\n    17→\n    18→  // Animate in\n    19→  useEffect(() => {\n    20→    const timer = setTimeout(() => setIsVisible(true), 50);\n    21→    return () => clearTimeout(timer);\n    22→  }, []);\n    23→\n    24→  // Auto-close after delay\n    25→  useEffect(() => {\n    26→    const timer = setTimeout(() => {\n    27→      setIsVisible(false);\n    28→      setTimeout(onClose, 300);\n    29→    }, 5000);\n    30→\n    31→    return () => clearTimeout(timer);\n    32→  }, [onClose]);\n    33→\n    34→  // Determine result\n    35→  const outcome = round.outcome;\n    36→  const isUserWinner = userBet && round.winners?.includes(userBet.address);\n    37→  const userPayout = userBet && round.payouts?.[userBet.address];\n    38→\n    39→  // Get outcome color\n    40→  const outcomeColor = outcome === \"green\"\n    41→    ? SIDE_COLORS.green\n    42→    : outcome === \"red\"\n    43→    ? SIDE_COLORS.red\n    44→    : SIDE_COLORS.refund;\n    45→\n    46→  // Get result text\n    47→  const getResultText = () => {\n    48→    if (!userBet) {\n    49→      if (outcome === \"refund\") return \"REFUND - Bets Returned!\";\n    50→      return `${outcome?.toUpperCase()} WINS!`;\n    51→    }\n    52→\n    53→    if (outcome === \"refund\") {\n    54→      return \"REFUND - Bet Returned!\";\n    55→    }\n    56→\n    57→    if (isUserWinner) {\n    58→      return \"YOU WON!\";\n    59→    }\n    60→\n    61→    return \"YOU LOST\";\n    62→  };\n    63→\n    64→  // Get payout text\n    65→  const getPayoutText = () => {\n    66→    if (!userBet) return null;\n    67→\n    68→    if (outcome === \"refund\") {\n    69→      return \"Your bet has been refunded\";\n    70→    }\n    71→\n    72→    if (isUserWinner && userPayout != null) {\n    73→      const profit = userPayout - userBet.amount;\n    74→      return `+${userPayout.toFixed(4)} SOL (+${profit.toFixed(4)} profit)`;\n    75→    }\n    76→\n    77→    return `-${userBet.amount.toFixed(4)} SOL`;\n    78→  };\n    79→\n    80→  return (\n    81→    <div\n    82→      className={`close-call-result-overlay ${isVisible ? \"close-call-result-overlay--visible\" : \"\"}`}\n    83→      onClick={onClose}\n    84→    >\n    85→      <div\n    86→        className={`close-call-result-overlay__content ${\n    87→          outcome === \"refund\"\n    88→            ? \"close-call-result-overlay__content--refund\"\n    89→            : isUserWinner\n    90→            ? \"close-call-result-overlay__content--win\"\n    91→            : \"close-call-result-overlay__content--loss\"\n    92→        }`}\n    93→        onClick={(e) => e.stopPropagation()}\n    94→      >\n    95→        {/* Win Animation - Coin fountain */}\n    96→        {isUserWinner && (\n    97→          <div className=\"close-call-win-animation\">\n    98→            <div className=\"close-call-win-animation__stars\">\n    99→              {[...Array(8)].map((_, i) => (\n   100→                <span key={i} className=\"close-call-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n   101→              ))}\n   102→            </div>\n   103→            <div className=\"close-call-win-animation__coins\">\n   104→              {[...Array(6)].map((_, i) => (\n   105→                <span key={i} className=\"close-call-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n   106→              ))}\n   107→            </div>\n   108→          </div>\n   109→        )}\n   110→\n   111→        {/* Candle result visualization */}\n   112→        <div className=\"close-call-result-overlay__candle\">\n   113→          <div\n   114→            className={`close-call-result-overlay__candle-body close-call-result-overlay__candle-body--${outcome}`}\n   115→            style={{ backgroundColor: outcomeColor }}\n   116→          />\n   117→        </div>\n   118→\n   119→        {/* Result text */}\n   120→        <div\n   121→          className=\"close-call-result-overlay__result\"\n   122→          style={{ color: outcomeColor }}\n   123→        >\n   124→          {getResultText()}\n   125→        </div>\n   126→\n   127→        {/* Payout */}\n   128→        {userBet && (\n   129→          <div\n   130→            className={`close-call-result-overlay__payout ${\n   131→              isUserWinner ? \"close-call-result-overlay__payout--win\" : \"\"\n   132→            }`}\n   133→          >\n   134→            {getPayoutText()}\n   135→          </div>\n   136→        )}\n   137→\n   138→        {/* Candle details */}\n   139→        {round.resultCandle && (\n   140→          <div className=\"close-call-result-overlay__details\">\n   141→            <div className=\"close-call-result-overlay__price\">\n   142→              Open: ${round.resultCandle.open.toFixed(2)}\n   143→            </div>\n   144→            <div className=\"close-call-result-overlay__price\">\n   145→              Close: ${round.resultCandle.close.toFixed(2)}\n   146→            </div>\n   147→            <div\n   148→              className=\"close-call-result-overlay__change\"\n   149→              style={{ color: outcomeColor }}\n   150→            >\n   151→              {outcome === \"green\" ? \"+\" : outcome === \"red\" ? \"\" : \"~\"}\n   152→              {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n   153→            </div>\n   154→          </div>\n   155→        )}\n   156→\n   157→        {/* Round info */}\n   158→        <div className=\"close-call-result-overlay__fairness\">\n   159→          <div className=\"close-call-result-overlay__fairness-row\">\n   160→            <span>Round ID</span>\n   161→            <span className=\"close-call-result-overlay__hash\">\n   162→              {round.id.slice(-12)}\n   163→            </span>\n   164→          </div>\n   165→          {round.settleTx && (\n   166→            <div className=\"close-call-result-overlay__fairness-row\">\n   167→              <span>Settlement Tx</span>\n   168→              <span className=\"close-call-result-overlay__hash close-call-result-overlay__hash--revealed\">\n   169→                {round.settleTx.slice(0, 8)}...{round.settleTx.slice(-4)}\n   170→              </span>\n   171→            </div>\n   172→          )}\n   173→        </div>\n   174→\n   175→        {/* Close button */}\n   176→        <button\n   177→          type=\"button\"\n   178→          className=\"close-call-result-overlay__close\"\n   179→          onClick={onClose}\n   180→        >\n   181→          Continue\n   182→        </button>\n   183→      </div>\n   184→    </div>\n   185→  );\n   186→}\n   187→"}]},"parent_tool_use_id":"toolu_01RpjArQNMWSuEkvHoxYSREy","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"e243bc85-36b3-4261-b0b7-e1ae00619aa0"}
