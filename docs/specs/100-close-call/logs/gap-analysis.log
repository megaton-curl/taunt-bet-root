{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YTRft7qKsqN2Ef3aqAXrL7","type":"tool_result","content":"     1→import {\n     2→  Connection,\n     3→  Keypair,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→  TransactionInstruction,\n     8→} from \"@solana/web3.js\";\n     9→import { deriveMatchPda } from \"./fairness.js\";\n    10→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    11→\n    12→export const COINFLIP_PROGRAM_ID = new PublicKey(coinflipIdl.address);\n    13→export const LORDOFRNGS_PROGRAM_ID = new PublicKey(lordIdl.address);\n    14→export const CLOSECALL_PROGRAM_ID = new PublicKey(closecallIdl.address);\n    15→\n    16→function getInstructionDiscriminator(\n    17→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    18→  instructionName: string,\n    19→): Buffer {\n    20→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    21→  if (!instruction) {\n    22→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    23→  }\n    24→  return Buffer.from(instruction.discriminator);\n    25→}\n    26→\n    27→const CREATE_MATCH_DISCRIMINATOR = getInstructionDiscriminator(\n    28→  coinflipIdl,\n    29→  \"create_match\",\n    30→);\n    31→const CREATE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(\n    32→  lordIdl,\n    33→  \"create_round\",\n    34→);\n    35→\n    36→/** Derive the coinflip config PDA (seeds: [\"coinflip_config\"]). */\n    37→function deriveConfigPda(): [PublicKey, number] {\n    38→  return PublicKey.findProgramAddressSync(\n    39→    [Buffer.from(\"coinflip_config\")],\n    40→    COINFLIP_PROGRAM_ID,\n    41→  );\n    42→}\n    43→\n    44→function deriveLordConfigPda(): [PublicKey, number] {\n    45→  return PublicKey.findProgramAddressSync(\n    46→    [Buffer.from(\"lord_config\")],\n    47→    LORDOFRNGS_PROGRAM_ID,\n    48→  );\n    49→}\n    50→\n    51→export function deriveLordRoundPda(matchId: Buffer): [PublicKey, number] {\n    52→  return PublicKey.findProgramAddressSync(\n    53→    [Buffer.from(\"jackpot_round\"), matchId],\n    54→    LORDOFRNGS_PROGRAM_ID,\n    55→  );\n    56→}\n    57→\n    58→/**\n    59→ * Borsh-encode the create_match instruction data.\n    60→ * Layout: discriminator(8) + commitment(32) + amount(8, u64 LE) + side(1) + matchId(8) = 57 bytes\n    61→ */\n    62→function encodeCreateMatchData(\n    63→  commitment: Buffer,\n    64→  amountLamports: number,\n    65→  side: number,\n    66→  matchId: Buffer,\n    67→): Buffer {\n    68→  const amount = Buffer.alloc(8);\n    69→  amount.writeBigUInt64LE(BigInt(amountLamports));\n    70→  return Buffer.concat([\n    71→    CREATE_MATCH_DISCRIMINATOR,\n    72→    commitment,\n    73→    amount,\n    74→    Buffer.from([side]),\n    75→    matchId,\n    76→  ]);\n    77→}\n    78→\n    79→function encodeCreateRoundData(\n    80→  commitment: Buffer,\n    81→  amountLamports: number,\n    82→  matchId: Buffer,\n    83→): Buffer {\n    84→  const amount = Buffer.alloc(8);\n    85→  amount.writeBigUInt64LE(BigInt(amountLamports));\n    86→  return Buffer.concat([CREATE_ROUND_DISCRIMINATOR, commitment, amount, matchId]);\n    87→}\n    88→\n    89→export interface BuildCreateMatchTxParams {\n    90→  connection: Connection;\n    91→  creator: PublicKey;\n    92→  serverKeypair: Keypair;\n    93→  commitment: Buffer;\n    94→  amountLamports: number;\n    95→  side: number;\n    96→  matchId: Buffer;\n    97→}\n    98→\n    99→export interface BuildCreateMatchTxResult {\n   100→  /** Base64-serialized partially-signed transaction. */\n   101→  transaction: string;\n   102→  /** The match PDA address. */\n   103→  matchPda: PublicKey;\n   104→  /** Block height limit paired with the pinned recent blockhash. */\n   105→  lastValidBlockHeight: number;\n   106→}\n   107→\n   108→export interface BuildCreateLordRoundTxParams {\n   109→  connection: Connection;\n   110→  creator: PublicKey;\n   111→  serverKeypair: Keypair;\n   112→  commitment: Buffer;\n   113→  amountLamports: number;\n   114→  matchId: Buffer;\n   115→}\n   116→\n   117→export interface BuildCreateLordRoundTxResult {\n   118→  transaction: string;\n   119→  roundPda: PublicKey;\n   120→  lastValidBlockHeight: number;\n   121→}\n   122→\n   123→/**\n   124→ * Build a `create_match` transaction, partially signed by the server.\n   125→ *\n   126→ * - Creator wallet is set as fee payer (server pays zero on-chain cost).\n   127→ * - Server keypair partially signs (as the `server: Signer` account).\n   128→ * - Recent blockhash is fetched at build time.\n   129→ * - Returns base64-serialized tx for the client to co-sign and submit.\n   130→ */\n   131→export async function buildCreateMatchTx(\n   132→  params: BuildCreateMatchTxParams,\n   133→): Promise<BuildCreateMatchTxResult> {\n   134→  const { connection, creator, serverKeypair, commitment, amountLamports, side, matchId } =\n   135→    params;\n   136→\n   137→  const [matchPda] = deriveMatchPda(creator, matchId);\n   138→  const [configPda] = deriveConfigPda();\n   139→\n   140→  const data = encodeCreateMatchData(commitment, amountLamports, side, matchId);\n   141→\n   142→  const tx = new Transaction();\n   143→\n   144→  tx.add(\n   145→    new TransactionInstruction({\n   146→    keys: [\n   147→      { pubkey: creator, isSigner: true, isWritable: true },\n   148→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: false },\n   149→      { pubkey: matchPda, isSigner: false, isWritable: true },\n   150→      { pubkey: configPda, isSigner: false, isWritable: false },\n   151→      {\n   152→        pubkey: SystemProgram.programId,\n   153→        isSigner: false,\n   154→        isWritable: false,\n   155→      },\n   156→    ],\n   157→    programId: COINFLIP_PROGRAM_ID,\n   158→    data,\n   159→    }),\n   160→  );\n   161→\n   162→  const { blockhash, lastValidBlockHeight } =\n   163→    await connection.getLatestBlockhash();\n   164→\n   165→  tx.feePayer = creator;\n   166→  tx.recentBlockhash = blockhash;\n   167→  tx.lastValidBlockHeight = lastValidBlockHeight;\n   168→\n   169→  // Partially sign with server keypair only — creator signs client-side\n   170→  tx.partialSign(serverKeypair);\n   171→\n   172→  const serialized = tx\n   173→    .serialize({ requireAllSignatures: false })\n   174→    .toString(\"base64\");\n   175→\n   176→  return { transaction: serialized, matchPda, lastValidBlockHeight };\n   177→}\n   178→\n   179→export async function buildCreateLordRoundTx(\n   180→  params: BuildCreateLordRoundTxParams,\n   181→): Promise<BuildCreateLordRoundTxResult> {\n   182→  const { connection, creator, serverKeypair, commitment, amountLamports, matchId } =\n   183→    params;\n   184→\n   185→  const [roundPda] = deriveLordRoundPda(matchId);\n   186→  const [configPda] = deriveLordConfigPda();\n   187→  const data = encodeCreateRoundData(commitment, amountLamports, matchId);\n   188→\n   189→  const tx = new Transaction();\n   190→  tx.add(\n   191→    new TransactionInstruction({\n   192→      keys: [\n   193→        { pubkey: creator, isSigner: true, isWritable: true },\n   194→        { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // pays rent\n   195→        { pubkey: configPda, isSigner: false, isWritable: false },\n   196→        { pubkey: roundPda, isSigner: false, isWritable: true },\n   197→        { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   198→      ],\n   199→      programId: LORDOFRNGS_PROGRAM_ID,\n   200→      data,\n   201→    }),\n   202→  );\n   203→\n   204→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   205→\n   206→  tx.feePayer = creator;\n   207→  tx.recentBlockhash = blockhash;\n   208→  tx.lastValidBlockHeight = lastValidBlockHeight;\n   209→  tx.partialSign(serverKeypair);\n   210→\n   211→  const serialized = tx\n   212→    .serialize({ requireAllSignatures: false })\n   213→    .toString(\"base64\");\n   214→\n   215→  return { transaction: serialized, roundPda, lastValidBlockHeight };\n   216→}\n   217→"}]},"parent_tool_use_id":"toolu_01GaMdELGmU7U8bC6tXEpTmX","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"4ff65547-84a3-4623-a170-a34b616d669e"}
