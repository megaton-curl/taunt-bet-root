n\">\n   124→                <span className=\"close-call-pool-bar__heartbreak\">💔</span>\n   125→              </div>\n   126→            )}\n   127→\n   128→            {/* Header: Joined GREEN/RED */}\n   129→            <div\n   130→              className=\"close-call-pool-bar__user-bet-header\"\n   131→              style={{ color: SIDE_COLORS[userBet.side] }}\n   132→            >\n   133→              Joined {userBet.side.toUpperCase()}\n   134→            </div>\n   135→\n   136→            {/* Amount row */}\n   137→            <div className=\"close-call-pool-bar__user-bet-row\">\n   138→              <span className=\"close-call-pool-bar__user-bet-label\">Amount</span>\n   139→              <span className=\"close-call-pool-bar__user-bet-value\">\n   140→                {userBet.amount.toFixed(4)} SOL\n   141→              </span>\n   142→            </div>\n   143→\n   144→            {/* Potential Payout row */}\n   145→            {potentialPayout > 0 && (\n   146→              <div className=\"close-call-pool-bar__user-bet-row close-call-pool-bar__user-bet-row--payout\">\n   147→                <span className=\"close-call-pool-bar__user-bet-label\">\n   148→                  {userWon ? \"Payout\" : \"Potential Payout\"}\n   149→                </span>\n   150→                <span className={`close-call-pool-bar__user-bet-value ${userWon ? \"close-call-pool-bar__user-bet-value--won\" : \"\"}`}>\n   151→                  {potentialPayout.toFixed(4)} SOL\n   152→                </span>\n   153→              </div>\n   154→            )}\n   155→          </div>\n   156→        )}\n   157→      </div>\n   158→    </div>\n   159→  );\n   160→}\n   161→"}]},"parent_tool_use_id":null,"session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"9a8537ef-47bc-4c44-9416-be3e1e530d91","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/components/PoolDistribution.tsx","content":"import type { PoolState, PlayerBet, CandleOutcome } from \"../types\";\nimport { SIDE_COLORS, PLATFORM_FEE } from \"../types\";\n\ninterface PoolDistributionProps {\n  pool: PoolState;\n  userBet?: PlayerBet | null;\n  potentialPayout?: number;\n  roundOutcome?: CandleOutcome | null;\n  isRoundComplete?: boolean;\n}\n\nexport function PoolDistribution({\n  pool,\n  userBet,\n  potentialPayout = 0,\n  roundOutcome,\n  isRoundComplete = false,\n}: PoolDistributionProps) {\n  // Determine if user won or lost\n  const userWon = isRoundComplete && userBet && roundOutcome && userBet.side === roundOutcome;\n  const userLost = isRoundComplete && userBet && roundOutcome && roundOutcome !== \"refund\" && userBet.side !== roundOutcome;\n  const totalPool = pool.totalPool;\n\n  // Calculate percentages\n  const greenPercent = pool.totalPool > 0 ? (pool.greenPool / pool.totalPool) * 100 : 50;\n  const redPercent = pool.totalPool > 0 ? (pool.redPool / pool.totalPool) * 100 : 50;\n\n  // Calculate odds multiplier for each side\n  const netPool = totalPool * (1 - PLATFORM_FEE);\n  const greenOdds = pool.greenPool > 0 ? netPool / pool.greenPool : 0;\n  const redOdds = pool.redPool > 0 ? netPool / pool.redPool : 0;\n\n  // Format odds display\n  const formatOdds = (odds: number): string => {\n    if (odds === 0) return \"∞\";\n    return `${odds.toFixed(2)}x`;\n  };\n\n  return (\n    <div className=\"close-call-pool-bar\">\n      {/* Percentages only - no GREEN/RED labels */}\n      <div className=\"close-call-pool-bar__labels\">\n        <span\n          className=\"close-call-pool-bar__label close-call-pool-bar__label--green\"\n          style={{ color: SIDE_COLORS.green }}\n        >\n          {greenPercent.toFixed(0)}%\n        </span>\n        <span\n          className=\"close-call-pool-bar__label close-call-pool-bar__label--red\"\n          style={{ color: SIDE_COLORS.red }}\n        >\n          {redPercent.toFixed(0)}%\n        </span>\n      </div>\n\n      {/* Progress bar */}\n      <div className=\"close-call-pool-bar__track\">\n        <div\n          className=\"close-call-pool-bar__fill close-call-pool-bar__fill--green\"\n          style={{\n            width: `${greenPercent}%`,\n            backgroundColor: SIDE_COLORS.green,\n          }}\n        />\n        <div\n          className=\"close-call-pool-bar__fill close-call-pool-bar__fill--red\"\n          style={{\n            width: `${redPercent}%`,\n            backgroundColor: SIDE_COLORS.red,\n          }}\n        />\n      </div>\n\n      {/* Pool amounts and multipliers */}\n      <div className=\"close-call-pool-bar__stats\">\n        <div className=\"close-call-pool-bar__stat close-call-pool-bar__stat--green\">\n          <span className=\"close-call-pool-bar__pool-amount\" style={{ color: SIDE_COLORS.green }}>\n            {pool.greenPool.toFixed(4)} SOL\n          </span>\n          <span className=\"close-call-pool-bar__odds\" style={{ color: SIDE_COLORS.green }}>\n            ~{formatOdds(greenOdds)}\n          </span>\n        </div>\n        <div className=\"close-call-pool-bar__stat close-call-pool-bar__stat--red\">\n          <span className=\"close-call-pool-bar__pool-amount\" style={{ color: SIDE_COLORS.red }}>\n            {pool.redPool.toFixed(4)} SOL\n          </span>\n          <span className=\"close-call-pool-bar__odds\" style={{ color: SIDE_COLORS.red }}>\n            ~{formatOdds(redOdds)}\n          </span>\n        </div>\n      </div>\n\n      {/* Prize Pool - striking display */}\n      <div className=\"close-call-pool-bar__prize\">\n        <div className=\"close-call-pool-bar__prize-label\">PRIZE POOL</div>\n        <div className=\"close-call-pool-bar__prize-amount\">\n          <span className=\"close-call-pool-bar__prize-sol\">{totalPool.toFixed(4)} SOL</span>\n        </div>\n\n        {/* User's bet stats when they have an active bet */}\n        {userBet && (\n          <div className={`close-call-pool-bar__user-bet ${userWon ? \"close-call-pool-bar__user-bet--won\" : \"\"} ${userLost ? \"close-call-pool-bar__user-bet--lost\" : \"\"}`}>\n            {/* Win animation */}\n            {userWon && (\n              <div className=\"close-call-pool-bar__win-animation\">\n                <div className=\"close-call-pool-bar__stars\">\n                  {[...Array(6)].map((_, i) => (\n                    <span key={i} className=\"close-call-pool-bar__star\" style={{ \"--star-index\": i } as React.CSSProperties}>★</span>\n                  ))}\n                </div>\n                <div className=\"close-call-pool-bar__coins\">\n                  {[...Array(4)].map((_, i) => (\n                    <span key={i} className=\"close-call-pool-bar__coin\" style={{ \"--coin-index\": i } as React.CSSProperties}>●</span>\n                  ))}\n                </div>\n              </div>\n            )}\n\n            {/* Loss animation */}\n            {userLost && (\n              <div className=\"close-call-pool-bar__loss-animation\">\n                <span className=\"close-call-pool-bar__heartbreak\">💔</span>\n              </div>\n            )}\n\n            {/* Header: Joined GREEN/RED */}\n            <div\n              className=\"close-call-pool-bar__user-bet-header\"\n              style={{ color: SIDE_COLORS[userBet.side] }}\n            >\n              Joined {userBet.side.toUpperCase()}\n            </div>\n\n            {/* Amount row */}\n            <div className=\"close-call-pool-bar__user-bet-row\">\n              <span className=\"close-call-pool-bar__user-bet-label\">Amount</span>\n              <span className=\"close-call-pool-bar__user-bet-value\">\n                {userBet.amount.toFixed(4)} SOL\n              </span>\n            </div>\n\n            {/* Potential Payout row */}\n            {potentialPayout > 0 && (\n              <div className=\"close-call-pool-bar__user-bet-row close-call-pool-bar__user-bet-row--payout\">\n                <span className=\"close-call-pool-bar__user-bet-label\">\n                  {userWon ? \"Payout\" : \"Potential Payout\"}\n                </span>\n                <span className={`close-call-pool-bar__user-bet-value ${userWon ? \"close-call-pool-bar__user-bet-value--won\" : \"\"}`}>\n                  {potentialPayout.toFixed(4)} SOL\n                </span>\n              </div>\n            )}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n","numLines":161,"startLine":1,"totalLines":161}}}
