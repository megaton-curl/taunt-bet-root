{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_014hqsnr75isTwP5RWckLvCp","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01J9VuVfTGNF3wyokigJSVNr","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/pause.rs"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":4,"cache_creation_input_tokens":489,"cache_read_input_tokens":46182,"cache_creation":{"ephemeral_5m_input_tokens":489,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_012FZFQthTpmV4TStVPM7FGb","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"21e6b2f4-76f1-4a09-bafa-b7558b0f6f59"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wg3pEhxq56YSbQFno2uaws","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { AnchorError, Program, Wallet } from \"@coral-xyz/anchor\";\n     5→import anchor from \"@coral-xyz/anchor\";\n     6→const { BN } = anchor;\n     7→import {\n     8→  Keypair,\n     9→  PublicKey,\n    10→  SystemProgram,\n    11→  LAMPORTS_PER_SOL,\n    12→} from \"@solana/web3.js\";\n    13→import { Clock } from \"solana-bankrun\";\n    14→import { randomBytes } from \"node:crypto\";\n    15→import type { Closecall } from \"../target/types/closecall\";\n    16→import { readFileSync } from \"fs\";\n    17→import { dirname, join } from \"path\";\n    18→import { fileURLToPath } from \"url\";\n    19→\n    20→const __filename = fileURLToPath(import.meta.url);\n    21→const __dirname = dirname(__filename);\n    22→\n    23→const IDL = JSON.parse(\n    24→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"closecall.json\"), \"utf8\")\n    25→);\n    26→const PROGRAM_ID = new PublicKey(IDL.address);\n    27→\n    28→// ---------------------------------------------------------------------------\n    29→// Constants matching on-chain program\n    30→// ---------------------------------------------------------------------------\n    31→const MIN_WAGER = 1_000_000; // 0.001 SOL (shared wager.rs MIN_WAGER_LAMPORTS)\n    32→const DEFAULT_BET = 5_000_000; // 0.005 SOL\n    33→const BETTING_WINDOW_SECS = 30;\n    34→const CANDLE_DURATION_SECS = 60;\n    35→const RESOLVE_TIMEOUT_SECS = 300;\n    36→const MAX_ENTRIES_PER_SIDE = 32;\n    37→const TOTAL_FEE_BPS = 300; // 3%\n    38→const SIDE_GREEN = 0;\n    39→const SIDE_RED = 1;\n    40→\n    41→// Arbitrary Pyth feed ID for BTC/USD (used in config + mock accounts)\n    42→const PYTH_BTC_USD_FEED_ID = Buffer.alloc(32);\n    43→PYTH_BTC_USD_FEED_ID.write(\"e62df6c8b4a85fe1a67db44dc12de5db\", 0, 16, \"hex\");\n    44→PYTH_BTC_USD_FEED_ID.write(\"330f7ac66b72dc658afedf0f4a415b43\", 16, 16, \"hex\");\n    45→\n    46→// ---------------------------------------------------------------------------\n    47→// Mock Pyth PriceUpdateV2 account builder\n    48→// ---------------------------------------------------------------------------\n    49→function buildMockPythAccount(\n    50→  price: bigint,\n    51→  exponent: number,\n    52→  feedId: Buffer,\n    53→  publishTime: bigint\n    54→): Buffer {\n    55→  // Layout: [8 disc][32 write_auth][1 verif_level][32 feed_id][8 price][8 conf]\n    56→  //         [4 expo][8 publish_time][8 prev_publish_time][8 ema_price][8 ema_conf][8 posted_slot]\n    57→  const buf = Buffer.alloc(133);\n    58→  let offset = 0;\n    59→\n    60→  // Discriminator (8 bytes — arbitrary, program skips these)\n    61→  buf.fill(0xde, offset, offset + 8);\n    62→  offset += 8;\n    63→\n    64→  // write_authority (32 bytes — zeros)\n    65→  offset += 32;\n    66→\n    67→  // verification_level: Full = variant index 1\n    68→  buf.writeUInt8(1, offset);\n    69→  offset += 1;\n    70→\n    71→  // feed_id (32 bytes)\n    72→  feedId.copy(buf, offset);\n    73→  offset += 32;\n    74→\n    75→  // price (i64 LE)\n    76→  buf.writeBigInt64LE(price, offset);\n    77→  offset += 8;\n    78→\n    79→  // conf (u64 LE)\n    80→  buf.writeBigUInt64LE(100n, offset);\n    81→  offset += 8;\n    82→\n    83→  // exponent (i32 LE)\n    84→  buf.writeInt32LE(exponent, offset);\n    85→  offset += 4;\n    86→\n    87→  // publish_time (i64 LE)\n    88→  buf.writeBigInt64LE(publishTime, offset);\n    89→  offset += 8;\n    90→\n    91→  // prev_publish_time (i64 LE)\n    92→  buf.writeBigInt64LE(publishTime - 1n, offset);\n    93→  offset += 8;\n    94→\n    95→  // ema_price (i64 LE)\n    96→  buf.writeBigInt64LE(price, offset);\n    97→  offset += 8;\n    98→\n    99→  // ema_conf (u64 LE)\n   100→  buf.writeBigUInt64LE(100n, offset);\n   101→  offset += 8;\n   102→\n   103→  // posted_slot (u64 LE)\n   104→  buf.writeBigUInt64LE(100n, offset);\n   105→\n   106→  return buf;\n   107→}\n   108→\n   109→// ---------------------------------------------------------------------------\n   110→// PDA helpers\n   111→// ---------------------------------------------------------------------------\n   112→function getConfigPda(): PublicKey {\n   113→  const [pda] = PublicKey.findProgramAddressSync(\n   114→    [Buffer.from(\"closecall_config\")],\n   115→    PROGRAM_ID\n   116→  );\n   117→  return pda;\n   118→}\n   119→\n   120→function getRoundPda(roundId: number[]): PublicKey {\n   121→  const [pda] = PublicKey.findProgramAddressSync(\n   122→    [Buffer.from(\"cc_round\"), Buffer.from(roundId)],\n   123→    PROGRAM_ID\n   124→  );\n   125→  return pda;\n   126→}\n   127→\n   128→function generateRoundId(): number[] {\n   129→  return Array.from(randomBytes(8));\n   130→}\n   131→\n   132→// ---------------------------------------------------------------------------\n   133→// Test context factory\n   134→// ---------------------------------------------------------------------------\n   135→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n   136→  return {\n   137→    lamports,\n   138→    data: Buffer.alloc(0),\n   139→    owner: SystemProgram.programId,\n   140→    executable: false,\n   141→  };\n   142→}\n   143→\n   144→interface TestContext {\n   145→  context: Awaited<ReturnType<typeof startAnchor>>;\n   146→  authority: PublicKey;\n   147→  treasury: Keypair;\n   148→  server: Keypair;\n   149→  player1: Keypair;\n   150→  player2: Keypair;\n   151→  authorityProgram: Program<Closecall>;\n   152→  serverProgram: Program<Closecall>;\n   153→  player1Program: Program<Closecall>;\n   154→  player2Program: Program<Closecall>;\n   155→  configPda: PublicKey;\n   156→}\n   157→\n   158→async function createTestContext(): Promise<TestContext> {\n   159→  const treasury = Keypair.generate();\n   160→  const server = Keypair.generate();\n   161→  const player1 = Keypair.generate();\n   162→  const player2 = Keypair.generate();\n   163→\n   164→  const context = await startAnchor(\"./\", [], [\n   165→    { address: treasury.publicKey, info: fundedAccountData() },\n   166→    { address: server.publicKey, info: fundedAccountData() },\n   167→    { address: player1.publicKey, info: fundedAccountData() },\n   168→    { address: player2.publicKey, info: fundedAccountData() },\n   169→  ]);\n   170→\n   171→  const authorityProvider = new BankrunProvider(context);\n   172→  const authorityProgram = new Program<Closecall>(IDL, authorityProvider);\n   173→\n   174→  const serverProvider = new BankrunProvider(context, new Wallet(server));\n   175→  const serverProgram = new Program<Closecall>(IDL, serverProvider);\n   176→\n   177→  const player1Provider = new BankrunProvider(context, new Wallet(player1));\n   178→  const player1Program = new Program<Closecall>(IDL, player1Provider);\n   179→\n   180→  const player2Provider = new BankrunProvider(context, new Wallet(player2));\n   181→  const player2Program = new Program<Closecall>(IDL, player2Provider);\n   182→\n   183→  const authority = authorityProvider.wallet.publicKey;\n   184→  const configPda = getConfigPda();\n   185→\n   186→  return {\n   187→    context,\n   188→    authority,\n   189→    treasury,\n   190→    server,\n   191→    player1,\n   192→    player2,\n   193→    authorityProgram,\n   194→    serverProgram,\n   195→    player1Program,\n   196→    player2Program,\n   197→    configPda,\n   198→  };\n   199→}\n   200→\n   201→// ---------------------------------------------------------------------------\n   202→// Mock Pyth account helper\n   203→// ---------------------------------------------------------------------------\n   204→function setMockPythAccount(\n   205→  t: TestContext,\n   206→  key: PublicKey,\n   207→  price: bigint,\n   208→  exponent: number,\n   209→  publishTime: bigint\n   210→) {\n   211→  const data = buildMockPythAccount(price, exponent, PYTH_BTC_USD_FEED_ID, publishTime);\n   212→  t.context.setAccount(key, {\n   213→    lamports: LAMPORTS_PER_SOL,\n   214→    data,\n   215→    owner: SystemProgram.programId,\n   216→    executable: false,\n   217→  });\n   218→}\n   219→\n   220→// ---------------------------------------------------------------------------\n   221→// Clock helpers\n   222→// ---------------------------------------------------------------------------\n   223→async function getCurrentTime(t: TestContext): Promise<bigint> {\n   224→  const clock = await t.context.banksClient.getClock();\n   225→  return clock.unixTimestamp;\n   226→}\n   227→\n   228→async function warpTime(t: TestContext, deltaSeconds: number) {\n   229→  const clock = await t.context.banksClient.getClock();\n   230→  t.context.setClock(\n   231→    new Clock(\n   232→      clock.slot + BigInt(deltaSeconds * 2),\n   233→      clock.epochStartTimestamp,\n   234→      clock.epoch,\n   235→      clock.leaderScheduleEpoch,\n   236→      clock.unixTimestamp + BigInt(deltaSeconds)\n   237→    )\n   238→  );\n   239→}\n   240→\n   241→// ---------------------------------------------------------------------------\n   242→// Instruction helpers\n   243→// ---------------------------------------------------------------------------\n   244→async function initConfig(t: TestContext) {\n   245→  await t.authorityProgram.methods\n   246→    .initializeConfig(\n   247→      t.treasury.publicKey,\n   248→      Array.from(PYTH_BTC_USD_FEED_ID),\n   249→      BETTING_WINDOW_SECS,\n   250→      MAX_ENTRIES_PER_SIDE\n   251→    )\n   252→    .accounts({\n   253→      authority: t.authority,\n   254→      config: t.configPda,\n   255→      systemProgram: SystemProgram.programId,\n   256→    })\n   257→    .rpc();\n   258→}\n   259→\n   260→async function createRound(\n   261→  t: TestContext,\n   262→  roundId: number[],\n   263→  priceUpdateKey: PublicKey\n   264→): Promise<PublicKey> {\n   265→  const roundPda = getRoundPda(roundId);\n   266→  await t.serverProgram.methods\n   267→    .createRound(roundId)\n   268→    .accounts({\n   269→      server: t.server.publicKey,\n   270→      config: t.configPda,\n   271→      round: roundPda,\n   272→      priceUpdate: priceUpdateKey,\n   273→      systemProgram: SystemProgram.programId,\n   274→    })\n   275→    .rpc();\n   276→  return roundPda;\n   277→}\n   278→\n   279→async function placeBet(\n   280→  program: Program<Closecall>,\n   281→  player: PublicKey,\n   282→  configPda: PublicKey,\n   283→  roundId: number[],\n   284→  side: number,\n   285→  amount: number\n   286→) {\n   287→  const roundPda = getRoundPda(roundId);\n   288→  await program.methods\n   289→    .placeBet(roundId, side, new BN(amount))\n   290→    .accounts({\n   291→      player,\n   292→      config: configPda,\n   293→      round: roundPda,\n   294→      systemProgram: SystemProgram.programId,\n   295→    })\n   296→    .rpc();\n   297→}\n   298→\n   299→async function settleRound(\n   300→  t: TestContext,\n   301→  roundId: number[],\n   302→  priceUpdateKey: PublicKey,\n   303→  playerAccounts: PublicKey[]\n   304→) {\n   305→  const roundPda = getRoundPda(roundId);\n   306→  await t.serverProgram.methods\n   307→    .settleRound(roundId)\n   308→    .accounts({\n   309→      caller: t.server.publicKey,\n   310→      round: roundPda,\n   311→      config: t.configPda,\n   312→      priceUpdate: priceUpdateKey,\n   313→      treasury: t.treasury.publicKey,\n   314→      rentReceiver: t.server.publicKey,\n   315→    })\n   316→    .remainingAccounts(\n   317→      playerAccounts.map((pk) => ({\n   318→        pubkey: pk,\n   319→        isSigner: false,\n   320→        isWritable: true,\n   321→      }))\n   322→    )\n   323→    .rpc();\n   324→}\n   325→\n   326→async function timeoutRefund(\n   327→  program: Program<Closecall>,\n   328→  caller: PublicKey,\n   329→  t: TestContext,\n   330→  roundId: number[],\n   331→  playerAccounts: PublicKey[]\n   332→) {\n   333→  const roundPda = getRoundPda(roundId);\n   334→  await program.methods\n   335→    .timeoutRefund(roundId)\n   336→    .accounts({\n   337→      caller,\n   338→      round: roundPda,\n   339→      config: t.configPda,\n   340→      rentReceiver: t.server.publicKey,\n   341→    })\n   342→    .remainingAccounts(\n   343→      playerAccounts.map((pk) => ({\n   344→        pubkey: pk,\n   345→        isSigner: false,\n   346→        isWritable: true,\n   347→      }))\n   348→    )\n   349→    .rpc();\n   350→}\n   351→\n   352→async function forceClose(\n   353→  t: TestContext,\n   354→  roundId: number[],\n   355→  playerAccounts: PublicKey[]\n   356→) {\n   357→  const roundPda = getRoundPda(roundId);\n   358→  await t.authorityProgram.methods\n   359→    .forceClose(roundId)\n   360→    .accounts({\n   361→      authority: t.authority,\n   362→      round: roundPda,\n   363→      config: t.configPda,\n   364→      rentReceiver: t.server.publicKey,\n   365→    })\n   366→    .remainingAccounts(\n   367→      playerAccounts.map((pk) => ({\n   368→        pubkey: pk,\n   369→        isSigner: false,\n   370→        isWritable: true,\n   371→      }))\n   372→    )\n   373→    .rpc();\n   374→}\n   375→\n   376→// ---------------------------------------------------------------------------\n   377→// Balance helper\n   378→// ---------------------------------------------------------------------------\n   379→async function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n   380→  const account = await t.context.banksClient.getAccount(pubkey);\n   381→  return account ? Number(account.lamports) : 0;\n   382→}\n   383→\n   384→// ---------------------------------------------------------------------------\n   385→// Fee calculation (matches shared/fees.rs)\n   386→// ---------------------------------------------------------------------------\n   387→function calculateFee(amount: number): number {\n   388→  return Math.floor((amount * TOTAL_FEE_BPS) / 10_000);\n   389→}\n   390→\n   391→// ---------------------------------------------------------------------------\n   392→// Common test setup: config + round + Pyth mock\n   393→// ---------------------------------------------------------------------------\n   394→async function setupRoundWithBets(\n   395→  t: TestContext,\n   396→  openPrice: bigint,\n   397→  opts?: {\n   398→    greenBets?: { player: Keypair; program: Program<Closecall>; amount: number }[];\n   399→    redBets?: { player: Keypair; program: Program<Closecall>; amount: number }[];\n   400→  }\n   401→) {\n   402→  await initConfig(t);\n   403→\n   404→  const now = await getCurrentTime(t);\n   405→  const openPriceKey = Keypair.generate();\n   406→  setMockPythAccount(t, openPriceKey.publicKey, openPrice, -8, now);\n   407→\n   408→  const roundId = generateRoundId();\n   409→  const roundPda = await createRound(t, roundId, openPriceKey.publicKey);\n   410→\n   411→  // Place green bets\n   412→  for (const bet of opts?.greenBets ?? []) {\n   413→    await placeBet(bet.program, bet.player.publicKey, t.configPda, roundId, SIDE_GREEN, bet.amount);\n   414→  }\n   415→\n   416→  // Place red bets\n   417→  for (const bet of opts?.redBets ?? []) {\n   418→    await placeBet(bet.program, bet.player.publicKey, t.configPda, roundId, SIDE_RED, bet.amount);\n   419→  }\n   420→\n   421→  return { roundId, roundPda };\n   422→}\n   423→\n   424→// ---------------------------------------------------------------------------\n   425→// Tests\n   426→// ---------------------------------------------------------------------------\n   427→describe(\"closecall\", () => {\n   428→  // =========================================================================\n   429→  // initialize_config\n   430→  // =========================================================================\n   431→  describe(\"initialize_config\", () => {\n   432→    it(\"creates config with correct fields\", async () => {\n   433→      const t = await createTestContext();\n   434→      await initConfig(t);\n   435→\n   436→      const config = await t.authorityProgram.account.closeCallConfig.fetch(t.configPda);\n   437→      expect(config.authority.toBase58()).to.equal(t.authority.toBase58());\n   438→      expect(config.treasury.toBase58()).to.equal(t.treasury.publicKey.toBase58());\n   439→      expect(Array.from(config.pythFeedId as number[])).to.deep.equal(\n   440→        Array.from(PYTH_BTC_USD_FEED_ID)\n   441→      );\n   442→      expect(config.bettingWindowSecs).to.equal(BETTING_WINDOW_SECS);\n   443→      expect(config.maxEntriesPerSide).to.equal(MAX_ENTRIES_PER_SIDE);\n   444→      expect(config.paused).to.equal(false);\n   445→    });\n   446→  });\n   447→\n   448→  // =========================================================================\n   449→  // create_round\n   450→  // =========================================================================\n   451→  describe(\"create_round\", () => {\n   452→    it(\"creates round with Pyth open price and correct timing\", async () => {\n   453→      const t = await createTestContext();\n   454→      await initConfig(t);\n   455→\n   456→      const now = await getCurrentTime(t);\n   457→      const openPrice = 5000000000000n; // $50,000.00000000\n   458→      const priceKey = Keypair.generate();\n   459→      setMockPythAccount(t, priceKey.publicKey, openPrice, -8, now);\n   460→\n   461→      const roundId = generateRoundId();\n   462→      const roundPda = await createRound(t, roundId, priceKey.publicKey);\n   463→\n   464→      const round = await t.authorityProgram.account.closeCallRound.fetch(roundPda);\n   465→      expect(Array.from(round.roundId as number[])).to.deep.equal(roundId);\n   466→      expect(round.server.toBase58()).to.equal(t.server.publicKey.toBase58());\n   467→      expect(JSON.stringify(round.phase)).to.equal(JSON.stringify({ open: {} }));\n   468→      expect(round.greenEntries).to.have.length(0);\n   469→      expect(round.redEntries).to.have.length(0);\n   470→      expect(round.greenPool.toNumber()).to.equal(0);\n   471→      expect(round.redPool.toNumber()).to.equal(0);\n   472→      expect(round.openPrice.toNumber()).to.equal(Number(openPrice));\n   473→      expect(round.openPriceExpo).to.equal(-8);\n   474→      expect(round.closePrice.toNumber()).to.equal(0);\n   475→      expect(round.createdAt.toNumber()).to.be.greaterThan(0);\n   476→      expect(round.bettingEndsAt.toNumber()).to.equal(\n   477→        round.createdAt.toNumber() + BETTING_WINDOW_SECS\n   478→      );\n   479→      expect(round.resolveDeadline.toNumber()).to.equal(\n   480→        round.createdAt.toNumber() + CANDLE_DURATION_SECS + RESOLVE_TIMEOUT_SECS\n   481→      );\n   482→      expect(JSON.stringify(round.outcome)).to.equal(JSON.stringify({ pending: {} }));\n   483→    });\n   484→  });\n   485→\n   486→  // =========================================================================\n   487→  // place_bet\n   488→  // =========================================================================\n   489→  describe(\"place_bet\", () => {\n   490→    it(\"places a green bet correctly\", async () => {\n   491→      const t = await createTestContext();\n   492→      await initConfig(t);\n   493→\n   494→      const now = await getCurrentTime(t);\n   495→      const priceKey = Keypair.generate();\n   496→      setMockPythAccount(t, priceKey.publicKey, 100000n, -8, now);\n   497→\n   498→      const roundId = generateRoundId();\n   499→      const roundPda = await createRound(t, roundId, priceKey.publicKey);\n   500→\n   501→      await placeBet(t.player1Program, t.player1.publicKey, t.configPda, roundId, SIDE_GREEN, DEFAULT_BET);\n   502→\n   503→      const round = await t.authorityProgram.account.closeCallRound.fetch(roundPda);\n   504→      expect(round.greenEntries).to.have.length(1);\n   505→      expect(round.greenEntries[0].player.toBase58()).to.equal(t.player1.publicKey.toBase58());\n   506→      expect(round.greenEntries[0].amountLamports.toNumber()).to.equal(DEFAULT_BET);\n   507→      expect(round.greenPool.toNumber()).to.equal(DEFAULT_BET);\n   508→      expect(round.redEntries).to.have.length(0);\n   509→      expect(round.redPool.toNumber()).to.equal(0);\n   510→    });\n   511→\n   512→    it(\"places a red bet correctly\", async () => {\n   513→      const t = await createTestContext();\n   514→      await initConfig(t);\n   515→\n   516→      const now = await getCurrentTime(t);\n   517→      const priceKey = Keypair.generate();\n   518→      setMockPythAccount(t, priceKey.publicKey, 100000n, -8, now);\n   519→\n   520→      const roundId = generateRoundId();\n   521→      await createRound(t, roundId, priceKey.publicKey);\n   522→\n   523→      await placeBet(t.player1Program, t.player1.publicKey, t.configPda, roundId, SIDE_RED, DEFAULT_BET);\n   524→\n   525→      const round = await t.authorityProgram.account.closeCallRound.fetch(getRoundPda(roundId));\n   526→      expect(round.redEntries).to.have.length(1);\n   527→      expect(round.redEntries[0].player.toBase58()).to.equal(t.player1.publicKey.toBase58());\n   528→      expect(round.redPool.toNumber()).to.equal(DEFAULT_BET);\n   529→    });\n   530→\n   531→    it(\"rejects duplicate bet (same player, same round)\", async () => {\n   532→      const t = await createTestContext();\n   533→      await initConfig(t);\n   534→\n   535→      const now = await getCurrentTime(t);\n   536→      const priceKey = Keypair.generate();\n   537→      setMockPythAccount(t, priceKey.publicKey, 100000n, -8, now);\n   538→\n   539→      const roundId = generateRoundId();\n   540→      await createRound(t, roundId, priceKey.publicKey);\n   541→      await placeBet(t.player1Program, t.player1.publicKey, t.configPda, roundId, SIDE_GREEN, DEFAULT_BET);\n   542→\n   543→      try {\n   544→        await placeBet(t.player1Program, t.player1.publicKey, t.configPda, roundId, SIDE_RED, DEFAULT_BET);\n   545→        expect.fail(\"Expected PlayerAlreadyBet error\");\n   546→      } catch (err) {\n   547→        expect((err as AnchorError).error.errorCode.code).to.equal(\"PlayerAlreadyBet\");\n   548→      }\n   549→    });\n   550→\n   551→    it(\"rejects bet after betting window closes\", async () => {\n   552→      const t = await createTestContext();\n   553→      await initConfig(t);\n   554→\n   555→      const now = await getCurrentTime(t);\n   556→      const priceKey = Keypair.generate();\n   557→      setMockPythAccount(t, priceKey.publicKey, 100000n, -8, now);\n   558→\n   559→      const roundId = generateRoundId();\n   560→      await createRound(t, roundId, priceKey.publicKey);\n   561→\n   562→      // Warp past betting window\n   563→      await warpTime(t, BETTING_WINDOW_SECS + 1);\n   564→\n   565→      try {\n   566→        await placeBet(t.player1Program, t.player1.publicKey, t.configPda, roundId, SIDE_GREEN, DEFAULT_BET);\n   567→        expect.fail(\"Expected BettingClosed error\");\n   568→      } catch (err) {\n   569→        expect((err as AnchorError).error.errorCode.code).to.equal(\"BettingClosed\");\n   570→      }\n   571→    });\n   572→\n   573→    it(\"rejects wager below minimum\", async () => {\n   574→      const t = await createTestContext();\n   575→      await initConfig(t);\n   576→\n   577→      const now = await getCurrentTime(t);\n   578→      const priceKey = Keypair.generate();\n   579→      setMockPythAccount(t, priceKey.publicKey, 100000n, -8, now);\n   580→\n   581→      const roundId = generateRoundId();\n   582→      await createRound(t, roundId, priceKey.publicKey);\n   583→\n   584→      try {\n   585→        await placeBet(t.player1Program, t.player1.publicKey, t.configPda, roundId, SIDE_GREEN, MIN_WAGER - 1);\n   586→        expect.fail(\"Expected WagerBelowMinimum error\");\n   587→      } catch (err) {\n   588→        expect((err as AnchorError).error.errorCode.code).to.equal(\"WagerBelowMinimum\");\n   589→      }\n   590→    });\n   591→\n   592→    it(\"rejects invalid side\", async () => {\n   593→      const t = await createTestContext();\n   594→      await initConfig(t);\n   595→\n   596→      const now = await getCurrentTime(t);\n   597→      const priceKey = Keypair.generate();\n   598→      setMockPythAccount(t, priceKey.publicKey, 100000n, -8, now);\n   599→\n   600→      const roundId = generateRoundId();\n   601→      await createRound(t, roundId, priceKey.publicKey);\n   602→\n   603→      try {\n   604→        await placeBet(t.player1Program, t.player1.publicKey, t.configPda, roundId, 2, DEFAULT_BET);\n   605→        expect.fail(\"Expected InvalidSide error\");\n   606→      } catch (err) {\n   607→        expect((err as AnchorError).error.errorCode.code).to.equal(\"InvalidSide\");\n   608→      }\n   609→    });\n   610→  });\n   611→\n   612→  // =========================================================================\n   613→  // settle_round — decisive outcomes\n   614→  // =========================================================================\n   615→  describe(\"settle_round\", () => {\n   616→    it(\"green wins — auto-payout to green bettors with fee\", async () => {\n   617→      const t = await createTestContext();\n   618→      const openPrice = 100000n;\n   619→      const closePrice = 100001n; // Green wins (close > open)\n   620→\n   621→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   622→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   623→        redBets: [{ player: t.player2, program: t.player2Program, amount: DEFAULT_BET }],\n   624→      });\n   625→\n   626→      const player1Before = await getBalance(t, t.player1.publicKey);\n   627→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   628→\n   629→      // Warp past candle close\n   630→      await warpTime(t, CANDLE_DURATION_SECS + 1);\n   631→\n   632→      const now = await getCurrentTime(t);\n   633→      const closePriceKey = Keypair.generate();\n   634→      setMockPythAccount(t, closePriceKey.publicKey, closePrice, -8, now);\n   635→\n   636→      // Settle — remaining_accounts = green bettors only (winner)\n   637→      await settleRound(t, roundId, closePriceKey.publicKey, [t.player1.publicKey]);\n   638→\n   639→      const player1After = await getBalance(t, t.player1.publicKey);\n   640→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   641→\n   642→      const totalPool = DEFAULT_BET * 2;\n   643→      const expectedFee = calculateFee(totalPool);\n   644→      const expectedPayout = totalPool - expectedFee;\n   645→\n   646→      expect(player1After - player1Before).to.equal(expectedPayout);\n   647→      expect(treasuryAfter - treasuryBefore).to.equal(expectedFee);\n   648→\n   649→      // Round PDA closed\n   650→      const roundAccount = await t.context.banksClient.getAccount(getRoundPda(roundId));\n   651→      expect(roundAccount).to.be.null;\n   652→    });\n   653→\n   654→    it(\"red wins — auto-payout to red bettors with fee\", async () => {\n   655→      const t = await createTestContext();\n   656→      const openPrice = 100000n;\n   657→      const closePrice = 99999n; // Red wins (close < open)\n   658→\n   659→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   660→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   661→        redBets: [{ player: t.player2, program: t.player2Program, amount: DEFAULT_BET }],\n   662→      });\n   663→\n   664→      const player2Before = await getBalance(t, t.player2.publicKey);\n   665→\n   666→      await warpTime(t, CANDLE_DURATION_SECS + 1);\n   667→\n   668→      const now = await getCurrentTime(t);\n   669→      const closePriceKey = Keypair.generate();\n   670→      setMockPythAccount(t, closePriceKey.publicKey, closePrice, -8, now);\n   671→\n   672→      // Settle — remaining_accounts = red bettors only (winner)\n   673→      await settleRound(t, roundId, closePriceKey.publicKey, [t.player2.publicKey]);\n   674→\n   675→      const player2After = await getBalance(t, t.player2.publicKey);\n   676→      const totalPool = DEFAULT_BET * 2;\n   677→      const expectedFee = calculateFee(totalPool);\n   678→      const expectedPayout = totalPool - expectedFee;\n   679→\n   680→      expect(player2After - player2Before).to.equal(expectedPayout);\n   681→    });\n   682→\n   683→    it(\"multi-winner proportional payout\", async () => {\n   684→      const t = await createTestContext();\n   685→\n   686→      // Create a 3rd player\n   687→      const player3 = Keypair.generate();\n   688→      t.context.setAccount(player3.publicKey, fundedAccountData());\n   689→      const player3Provider = new BankrunProvider(t.context, new Wallet(player3));\n   690→      const player3Program = new Program<Closecall>(IDL, player3Provider);\n   691→\n   692→      const openPrice = 100000n;\n   693→      const greenAmount1 = 3_000_000;\n   694→      const greenAmount2 = 2_000_000;\n   695→      const redAmount = 5_000_000;\n   696→\n   697→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   698→        greenBets: [\n   699→          { player: t.player1, program: t.player1Program, amount: greenAmount1 },\n   700→          { player: player3, program: player3Program, amount: greenAmount2 },\n   701→        ],\n   702→        redBets: [{ player: t.player2, program: t.player2Program, amount: redAmount }],\n   703→      });\n   704→\n   705→      const player1Before = await getBalance(t, t.player1.publicKey);\n   706→      const player3Before = await getBalance(t, player3.publicKey);\n   707→\n   708→      await warpTime(t, CANDLE_DURATION_SECS + 1);\n   709→\n   710→      const now = await getCurrentTime(t);\n   711→      const closePriceKey = Keypair.generate();\n   712→      setMockPythAccount(t, closePriceKey.publicKey, 100001n, -8, now); // Green wins\n   713→\n   714→      await settleRound(t, roundId, closePriceKey.publicKey, [\n   715→        t.player1.publicKey,\n   716→        player3.publicKey,\n   717→      ]);\n   718→\n   719→      const player1After = await getBalance(t, t.player1.publicKey);\n   720→      const player3After = await getBalance(t, player3.publicKey);\n   721→\n   722→      const totalPool = greenAmount1 + greenAmount2 + redAmount;\n   723→      const fee = calculateFee(totalPool);\n   724→      const netPool = totalPool - fee;\n   725→      const greenPool = greenAmount1 + greenAmount2;\n   726→\n   727→      // player1: 3M/5M * netPool\n   728→      const expectedPayout1 = Math.floor((greenAmount1 * netPool) / greenPool);\n   729→      // player3 (last winner): remainder\n   730→      const expectedPayout3 = netPool - expectedPayout1;\n   731→\n   732→      expect(player1After - player1Before).to.equal(expectedPayout1);\n   733→      expect(player3After - player3Before).to.equal(expectedPayout3);\n   734→    });\n   735→\n   736→    // -----------------------------------------------------------------------\n   737→    // Refund scenarios\n   738→    // -----------------------------------------------------------------------\n   739→    it(\"equal price — full refund, no fee\", async () => {\n   740→      const t = await createTestContext();\n   741→      const openPrice = 100000n;\n   742→\n   743→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   744→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   745→        redBets: [{ player: t.player2, program: t.player2Program, amount: DEFAULT_BET }],\n   746→      });\n   747→\n   748→      const player1Before = await getBalance(t, t.player1.publicKey);\n   749→      const player2Before = await getBalance(t, t.player2.publicKey);\n   750→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   751→\n   752→      await warpTime(t, CANDLE_DURATION_SECS + 1);\n   753→\n   754→      const now = await getCurrentTime(t);\n   755→      const closePriceKey = Keypair.generate();\n   756→      setMockPythAccount(t, closePriceKey.publicKey, openPrice, -8, now); // Equal!\n   757→\n   758→      // Refund — remaining_accounts = [green, red] all players\n   759→      await settleRound(t, roundId, closePriceKey.publicKey, [\n   760→        t.player1.publicKey,\n   761→        t.player2.publicKey,\n   762→      ]);\n   763→\n   764→      const player1After = await getBalance(t, t.player1.publicKey);\n   765→      const player2After = await getBalance(t, t.player2.publicKey);\n   766→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   767→\n   768→      // Exact refund\n   769→      expect(player1After - player1Before).to.equal(DEFAULT_BET);\n   770→      expect(player2After - player2Before).to.equal(DEFAULT_BET);\n   771→      // No fee\n   772→      expect(treasuryAfter - treasuryBefore).to.equal(0);\n   773→    });\n   774→\n   775→    it(\"one-sided pool (all green) — full refund, no fee\", async () => {\n   776→      const t = await createTestContext();\n   777→      const openPrice = 100000n;\n   778→\n   779→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   780→        greenBets: [\n   781→          { player: t.player1, program: t.player1Program, amount: DEFAULT_BET },\n   782→          { player: t.player2, program: t.player2Program, amount: DEFAULT_BET },\n   783→        ],\n   784→      });\n   785→\n   786→      const player1Before = await getBalance(t, t.player1.publicKey);\n   787→      const player2Before = await getBalance(t, t.player2.publicKey);\n   788→\n   789→      await warpTime(t, CANDLE_DURATION_SECS + 1);\n   790→\n   791→      const now = await getCurrentTime(t);\n   792→      const closePriceKey = Keypair.generate();\n   793→      setMockPythAccount(t, closePriceKey.publicKey, 100001n, -8, now);\n   794→\n   795→      // Refund — all players\n   796→      await settleRound(t, roundId, closePriceKey.publicKey, [\n   797→        t.player1.publicKey,\n   798→        t.player2.publicKey,\n   799→      ]);\n   800→\n   801→      const player1After = await getBalance(t, t.player1.publicKey);\n   802→      const player2After = await getBalance(t, t.player2.publicKey);\n   803→\n   804→      expect(player1After - player1Before).to.equal(DEFAULT_BET);\n   805→      expect(player2After - player2Before).to.equal(DEFAULT_BET);\n   806→    });\n   807→\n   808→    it(\"single player — full refund, no fee\", async () => {\n   809→      const t = await createTestContext();\n   810→      const openPrice = 100000n;\n   811→\n   812→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   813→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   814→      });\n   815→\n   816→      const player1Before = await getBalance(t, t.player1.publicKey);\n   817→\n   818→      await warpTime(t, CANDLE_DURATION_SECS + 1);\n   819→\n   820→      const now = await getCurrentTime(t);\n   821→      const closePriceKey = Keypair.generate();\n   822→      setMockPythAccount(t, closePriceKey.publicKey, 100001n, -8, now);\n   823→\n   824→      await settleRound(t, roundId, closePriceKey.publicKey, [t.player1.publicKey]);\n   825→\n   826→      const player1After = await getBalance(t, t.player1.publicKey);\n   827→      expect(player1After - player1Before).to.equal(DEFAULT_BET);\n   828→    });\n   829→\n   830→    it(\"no bets — clean close\", async () => {\n   831→      const t = await createTestContext();\n   832→      await initConfig(t);\n   833→\n   834→      const now = await getCurrentTime(t);\n   835→      const priceKey = Keypair.generate();\n   836→      setMockPythAccount(t, priceKey.publicKey, 100000n, -8, now);\n   837→\n   838→      const roundId = generateRoundId();\n   839→      const roundPda = await createRound(t, roundId, priceKey.publicKey);\n   840→\n   841→      await warpTime(t, CANDLE_DURATION_SECS + 1);\n   842→\n   843→      const now2 = await getCurrentTime(t);\n   844→      const closePriceKey = Keypair.generate();\n   845→      setMockPythAccount(t, closePriceKey.publicKey, 100001n, -8, now2);\n   846→\n   847→      await settleRound(t, roundId, closePriceKey.publicKey, []);\n   848→\n   849→      // Round PDA closed\n   850→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   851→      expect(roundAccount).to.be.null;\n   852→    });\n   853→\n   854→    it(\"rejects settlement before candle close\", async () => {\n   855→      const t = await createTestContext();\n   856→      const openPrice = 100000n;\n   857→\n   858→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   859→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   860→        redBets: [{ player: t.player2, program: t.player2Program, amount: DEFAULT_BET }],\n   861→      });\n   862→\n   863→      // Don't warp — candle not closed yet\n   864→      const now = await getCurrentTime(t);\n   865→      const closePriceKey = Keypair.generate();\n   866→      setMockPythAccount(t, closePriceKey.publicKey, 100001n, -8, now);\n   867→\n   868→      try {\n   869→        await settleRound(t, roundId, closePriceKey.publicKey, [t.player1.publicKey]);\n   870→        expect.fail(\"Expected CandleNotClosed error\");\n   871→      } catch (err) {\n   872→        expect((err as AnchorError).error.errorCode.code).to.equal(\"CandleNotClosed\");\n   873→      }\n   874→    });\n   875→  });\n   876→\n   877→  // =========================================================================\n   878→  // timeout_refund\n   879→  // =========================================================================\n   880→  describe(\"timeout_refund\", () => {\n   881→    it(\"refunds all players after resolve deadline\", async () => {\n   882→      const t = await createTestContext();\n   883→      const openPrice = 100000n;\n   884→\n   885→      const { roundId, roundPda } = await setupRoundWithBets(t, openPrice, {\n   886→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   887→        redBets: [{ player: t.player2, program: t.player2Program, amount: DEFAULT_BET }],\n   888→      });\n   889→\n   890→      const player1Before = await getBalance(t, t.player1.publicKey);\n   891→      const player2Before = await getBalance(t, t.player2.publicKey);\n   892→\n   893→      // Warp past resolve deadline\n   894→      await warpTime(t, CANDLE_DURATION_SECS + RESOLVE_TIMEOUT_SECS + 1);\n   895→\n   896→      // Anyone can trigger\n   897→      await timeoutRefund(t.player1Program, t.player1.publicKey, t, roundId, [\n   898→        t.player1.publicKey,\n   899→        t.player2.publicKey,\n   900→      ]);\n   901→\n   902→      const player1After = await getBalance(t, t.player1.publicKey);\n   903→      const player2After = await getBalance(t, t.player2.publicKey);\n   904→\n   905→      // player2 gets exact refund (not signer of timeout_refund tx)\n   906→      expect(player2After - player2Before).to.equal(DEFAULT_BET);\n   907→      // player1 gets refund minus tx fee (is signer)\n   908→      expect(player1After - player1Before).to.be.greaterThanOrEqual(DEFAULT_BET - 10_000);\n   909→\n   910→      // Round PDA closed\n   911→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   912→      expect(roundAccount).to.be.null;\n   913→    });\n   914→\n   915→    it(\"rejects before resolve deadline\", async () => {\n   916→      const t = await createTestContext();\n   917→      const openPrice = 100000n;\n   918→\n   919→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   920→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   921→      });\n   922→\n   923→      // Warp past candle close but NOT past resolve deadline\n   924→      await warpTime(t, CANDLE_DURATION_SECS + 10);\n   925→\n   926→      try {\n   927→        await timeoutRefund(t.player1Program, t.player1.publicKey, t, roundId, [\n   928→          t.player1.publicKey,\n   929→        ]);\n   930→        expect.fail(\"Expected DeadlineNotReached error\");\n   931→      } catch (err) {\n   932→        expect((err as AnchorError).error.errorCode.code).to.equal(\"DeadlineNotReached\");\n   933→      }\n   934→    });\n   935→  });\n   936→\n   937→  // =========================================================================\n   938→  // force_close\n   939→  // =========================================================================\n   940→  describe(\"force_close\", () => {\n   941→    it(\"admin force-closes and refunds all players\", async () => {\n   942→      const t = await createTestContext();\n   943→      const openPrice = 100000n;\n   944→\n   945→      const { roundId, roundPda } = await setupRoundWithBets(t, openPrice, {\n   946→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   947→        redBets: [{ player: t.player2, program: t.player2Program, amount: DEFAULT_BET }],\n   948→      });\n   949→\n   950→      const player1Before = await getBalance(t, t.player1.publicKey);\n   951→      const player2Before = await getBalance(t, t.player2.publicKey);\n   952→\n   953→      await forceClose(t, roundId, [t.player1.publicKey, t.player2.publicKey]);\n   954→\n   955→      const player1After = await getBalance(t, t.player1.publicKey);\n   956→      const player2After = await getBalance(t, t.player2.publicKey);\n   957→\n   958→      expect(player1After - player1Before).to.equal(DEFAULT_BET);\n   959→      expect(player2After - player2Before).to.equal(DEFAULT_BET);\n   960→\n   961→      const roundAccount = await t.context.banksClient.getAccount(roundPda);\n   962→      expect(roundAccount).to.be.null;\n   963→    });\n   964→\n   965→    it(\"rejects non-admin caller\", async () => {\n   966→      const t = await createTestContext();\n   967→      const openPrice = 100000n;\n   968→\n   969→      const { roundId } = await setupRoundWithBets(t, openPrice, {\n   970→        greenBets: [{ player: t.player1, program: t.player1Program, amount: DEFAULT_BET }],\n   971→      });\n   972→\n   973→      try {\n   974→        // player1 is not the authority\n   975→        const roundPda = getRoundPda(roundId);\n   976→        await t.player1Program.methods\n   977→          .forceClose(roundId)\n   978→          .accounts({\n   979→            authority: t.player1.publicKey,\n   980→            round: roundPda,\n   981→            config: t.configPda,\n   982→            rentReceiver: t.server.publicKey,\n   983→          })\n   984→          .remainingAccounts([\n   985→            { pubkey: t.player1.publicKey, isSigner: false, isWritable: true },\n   986→          ])\n   987→          .rpc();\n   988→        expect.fail(\"Expected error for non-admin\");\n   989→      } catch (err) {\n   990→        // Anchor has_one constraint error (ConstraintHasOne = 2001)\n   991→        expect((err as AnchorError).error.errorCode.number).to.equal(2001);\n   992→      }\n   993→    });\n   994→  });\n   995→});\n   996→"}]},"parent_tool_use_id":"toolu_01TLYzMfT9TdEHmVyfNA8V39","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"713640ee-9a3b-48a5-a74c-7019dc62ac5c"}
