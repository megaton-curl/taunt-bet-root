{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017gsbUrGvcF3hrCD2G4eWy5","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→use rng_shared::timeout::is_expired;\n     4→\n     5→use crate::error::CloseCallError;\n     6→use crate::state::{CloseCallConfig, CloseCallPhase, CloseCallRound, Outcome};\n     7→\n     8→#[derive(Accounts)]\n     9→#[instruction(round_id: [u8; 8])]\n    10→pub struct TimeoutRefund<'info> {\n    11→    /// Any signer can trigger a timeout refund (permissionless after deadline).\n    12→    #[account(mut)]\n    13→    pub caller: Signer<'info>,\n    14→\n    15→    /// The round PDA (closed after refunds — rent goes to server).\n    16→    #[account(\n    17→        mut,\n    18→        close = rent_receiver,\n    19→        seeds = [b\"cc_round\", &round_id],\n    20→        bump = round.bump,\n    21→    )]\n    22→    pub round: Account<'info, CloseCallRound>,\n    23→\n    24→    /// Config PDA (for validation only).\n    25→    #[account(\n    26→        seeds = [b\"closecall_config\"],\n    27→        bump = config.bump,\n    28→    )]\n    29→    pub config: Account<'info, CloseCallConfig>,\n    30→\n    31→    /// Server wallet that paid rent (receives rent on close).\n    32→    /// CHECK: Validated against round.server in handler.\n    33→    #[account(mut)]\n    34→    pub rent_receiver: AccountInfo<'info>,\n    35→\n    36→    // Remaining accounts: all player wallets [green_0..green_n, red_0..red_m].\n    37→}\n    38→\n    39→pub fn handler<'info>(\n    40→    ctx: Context<'_, '_, 'info, 'info, TimeoutRefund<'info>>,\n    41→    _round_id: [u8; 8],\n    42→) -> Result<()> {\n    43→    let round = &ctx.accounts.round;\n    44→    require!(\n    45→        round.phase == CloseCallPhase::Open,\n    46→        CloseCallError::InvalidPhase\n    47→    );\n    48→\n    49→    require_keys_eq!(\n    50→        ctx.accounts.rent_receiver.key(),\n    51→        round.server,\n    52→        CloseCallError::AccountMismatch\n    53→    );\n    54→\n    55→    let now = Clock::get()?.unix_timestamp;\n    56→    require!(\n    57→        is_expired(round.resolve_deadline, now),\n    58→        CloseCallError::DeadlineNotReached\n    59→    );\n    60→\n    61→    let green_count = round.green_entries.len();\n    62→    let red_count = round.red_entries.len();\n    63→    let total_count = green_count + red_count;\n    64→    let remaining = ctx.remaining_accounts;\n    65→\n    66→    if total_count > 0 {\n    67→        require!(\n    68→            remaining.len() == total_count,\n    69→            CloseCallError::RemainingAccountsMismatch\n    70→        );\n    71→\n    72→        let round_info = ctx.accounts.round.to_account_info();\n    73→\n    74→        for (i, entry) in round.green_entries.iter().enumerate() {\n    75→            let player_account = &remaining[i];\n    76→            require_keys_eq!(\n    77→                player_account.key(),\n    78→                entry.player,\n    79→                CloseCallError::AccountMismatch\n    80→            );\n    81→            transfer_lamports_from_pda(&round_info, player_account, entry.amount_lamports)?;\n    82→        }\n    83→\n    84→        for (i, entry) in round.red_entries.iter().enumerate() {\n    85→            let player_account = &remaining[green_count + i];\n    86→            require_keys_eq!(\n    87→                player_account.key(),\n    88→                entry.player,\n    89→                CloseCallError::AccountMismatch\n    90→            );\n    91→            transfer_lamports_from_pda(&round_info, player_account, entry.amount_lamports)?;\n    92→        }\n    93→    }\n    94→\n    95→    let round = &mut ctx.accounts.round;\n    96→    round.phase = CloseCallPhase::Refunded;\n    97→    round.outcome = Outcome::Refund;\n    98→\n    99→    Ok(())\n   100→}\n   101→"}]},"parent_tool_use_id":"toolu_012FZFQthTpmV4TStVPM7FGb","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"ffc96d66-2972-4761-8cc2-7a4e36d9cfe2"}
