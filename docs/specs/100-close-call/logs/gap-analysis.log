{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LeEjCu3x9jJBksf8jCg4fi","type":"tool_result","content":"     1→import { useState, useCallback } from \"react\";\n     2→import { MIN_BET_AMOUNT, MAX_BET_AMOUNT } from \"../types\";\n     3→\n     4→interface BetAmountInputProps {\n     5→  value: number;\n     6→  onChange: (value: number) => void;\n     7→  onAdjust: (adjustment: \"half\" | \"double\" | \"max\") => void;\n     8→  disabled?: boolean;\n     9→  maxAmount?: number;\n    10→}\n    11→\n    12→export function BetAmountInput({\n    13→  value,\n    14→  onChange,\n    15→  onAdjust,\n    16→  disabled = false,\n    17→  maxAmount = MAX_BET_AMOUNT,\n    18→}: BetAmountInputProps) {\n    19→  const [inputValue, setInputValue] = useState(value.toString());\n    20→\n    21→  // Handle input change\n    22→  const handleChange = useCallback(\n    23→    (e: React.ChangeEvent<HTMLInputElement>) => {\n    24→      const raw = e.target.value;\n    25→\n    26→      // Allow empty or partial input\n    27→      if (raw === \"\" || raw === \".\") {\n    28→        setInputValue(raw);\n    29→        return;\n    30→      }\n    31→\n    32→      // Parse as number\n    33→      const parsed = parseFloat(raw);\n    34→\n    35→      if (isNaN(parsed)) return;\n    36→\n    37→      // Update input display\n    38→      setInputValue(raw);\n    39→\n    40→      // Clamp and update value\n    41→      const clamped = Math.min(Math.max(parsed, 0), maxAmount);\n    42→      onChange(clamped);\n    43→    },\n    44→    [onChange, maxAmount]\n    45→  );\n    46→\n    47→  // Handle blur - validate and format\n    48→  const handleBlur = useCallback(() => {\n    49→    const parsed = parseFloat(inputValue);\n    50→\n    51→    if (isNaN(parsed) || parsed < MIN_BET_AMOUNT) {\n    52→      setInputValue(MIN_BET_AMOUNT.toString());\n    53→      onChange(MIN_BET_AMOUNT);\n    54→    } else {\n    55→      const clamped = Math.min(parsed, maxAmount);\n    56→      setInputValue(clamped.toString());\n    57→      onChange(clamped);\n    58→    }\n    59→  }, [inputValue, onChange, maxAmount]);\n    60→\n    61→  // Update input when value changes externally\n    62→  const handleFocus = useCallback(() => {\n    63→    setInputValue(value.toString());\n    64→  }, [value]);\n    65→\n    66→  // Handle adjustment buttons\n    67→  const handleAdjust = useCallback(\n    68→    (adjustment: \"half\" | \"double\" | \"max\") => {\n    69→      onAdjust(adjustment);\n    70→\n    71→      // Update input display\n    72→      let newValue: number;\n    73→      switch (adjustment) {\n    74→        case \"half\":\n    75→          newValue = Math.max(MIN_BET_AMOUNT, value / 2);\n    76→          break;\n    77→        case \"double\":\n    78→          newValue = Math.min(maxAmount, value * 2);\n    79→          break;\n    80→        case \"max\":\n    81→          newValue = maxAmount;\n    82→          break;\n    83→      }\n    84→      setInputValue(Math.round(newValue * 100) / 100 + \"\");\n    85→    },\n    86→    [onAdjust, value, maxAmount]\n    87→  );\n    88→\n    89→  return (\n    90→    <div className={`close-call-bet-input ${disabled ? \"close-call-bet-input--disabled\" : \"\"}`}>\n    91→      <div className=\"close-call-bet-input__header\">\n    92→        <label className=\"close-call-bet-input__label\">\n    93→          Bet Amount ($)\n    94→        </label>\n    95→      </div>\n    96→\n    97→      <div className=\"close-call-bet-input__row\">\n    98→        <input\n    99→          type=\"text\"\n   100→          inputMode=\"decimal\"\n   101→          className=\"close-call-bet-input__field\"\n   102→          value={inputValue}\n   103→          onChange={handleChange}\n   104→          onBlur={handleBlur}\n   105→          onFocus={handleFocus}\n   106→          disabled={disabled}\n   107→          placeholder={MIN_BET_AMOUNT.toString()}\n   108→        />\n   109→        <button\n   110→          type=\"button\"\n   111→          className=\"close-call-bet-input__btn\"\n   112→          onClick={() => handleAdjust(\"half\")}\n   113→          disabled={disabled}\n   114→        >\n   115→          ½\n   116→        </button>\n   117→        <button\n   118→          type=\"button\"\n   119→          className=\"close-call-bet-input__btn\"\n   120→          onClick={() => handleAdjust(\"double\")}\n   121→          disabled={disabled}\n   122→        >\n   123→          2x\n   124→        </button>\n   125→        <button\n   126→          type=\"button\"\n   127→          className=\"close-call-bet-input__btn close-call-bet-input__btn--max\"\n   128→          onClick={() => handleAdjust(\"max\")}\n   129→          disabled={disabled}\n   130→        >\n   131→          MAX\n   132→        </button>\n   133→      </div>\n   134→\n   135→      <div className=\"close-call-bet-input__range\">\n   136→        <span>Min: {MIN_BET_AMOUNT}</span>\n   137→        <span>Max: {maxAmount.toFixed(2)}</span>\n   138→      </div>\n   139→    </div>\n   140→  );\n   141→}\n   142→"}]},"parent_tool_use_id":"toolu_01RpjArQNMWSuEkvHoxYSREy","session_id":"efe120e9-7ceb-4e75-b227-230da807bdef","uuid":"38f1870e-3e77-40dc-809f-2366b3d0d22f"}
