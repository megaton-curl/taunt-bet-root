{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EKeEeTRZ98G42ixRRbrf8P","type":"tool_result","content":"     1→export type CoinSide = \"heads\" | \"tails\";\n     2→export type CoinflipPhase = \"created\" | \"ready\" | \"countdown\" | \"flipping\" | \"complete\";\n     3→\n     4→export interface UIMatch {\n     5→  id: string;\n     6→  matchId: string; // hex string of the 8-byte match identifier\n     7→  entryAmount: number; // in SOL\n     8→\n     9→  // Player 1 (creator)\n    10→  player1: string; // wallet address\n    11→  player1Side: CoinSide;\n    12→\n    13→  // Player 2 (joiner)\n    14→  player2: string | null;\n    15→  player2Side: CoinSide | null;\n    16→\n    17→  // Server (settlement authority) — absent for settled matches loaded from backend\n    18→  server?: string;\n    19→\n    20→  // Match state\n    21→  phase: CoinflipPhase;\n    22→  createdAt: number; // timestamp\n    23→  lockedAt?: number; // when match entered LOCKED phase (ms)\n    24→  countdownStartedAt?: number; // when countdown started\n    25→  completedAt?: number;\n    26→  targetSlot?: number; // slot at which entropy is read (set on join)\n    27→\n    28→  // Result\n    29→  result: CoinSide | null;\n    30→  winner: string | null;\n    31→\n    32→  // Payout\n    33→  payoutAmount: number; // amount winner receives\n    34→\n    35→  // Provably Fair - Commit-Reveal verification\n    36→  commitment: string; // hex of sha256(secret) — committed at create time\n    37→  secret?: string; // hex of revealed secret (set after settlement)\n    38→  entropy?: string; // hex of entropy bytes used\n    39→  resultHash?: string; // hex of derived result hash\n    40→}\n    41→\n    42→export interface MatchFilter {\n    43→  status?: \"open\" | \"all\";\n    44→}\n    45→\n    46→export interface CreateMatchParams {\n    47→  amountSol: number;\n    48→  side: CoinSide;\n    49→}\n    50→\n    51→export interface JoinMatchParams {\n    52→  matchId: string;\n    53→}\n    54→"}]},"parent_tool_use_id":"toolu_01MPoXotPwuktccSSbk63gaM","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"a2c2f4ac-ada0-47fa-8f2a-11fc115c2ff9"}
