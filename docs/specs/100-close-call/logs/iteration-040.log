{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HJ2zkSpn11W2RE7C8DsGUv","type":"tool_result","content":"     1→import type { UIMatch } from \"../types\";\n     2→import { PlayerAvatar, getDisplayName } from \"../../player-profile\";\n     3→\n     4→interface MatchCardProps {\n     5→  match: UIMatch;\n     6→  onJoin?: () => void;\n     7→  isOwn?: boolean;\n     8→  canJoin?: boolean;\n     9→  joining?: boolean;\n    10→}\n    11→\n    12→/** Small coin indicator for match cards */\n    13→function CoinBadge({ side }: { side: string }) {\n    14→  const isHeads = side === \"heads\";\n    15→  return (\n    16→    <svg width={28} height={28} viewBox=\"0 0 28 28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n    17→      <circle cx=\"14\" cy=\"14\" r=\"12\" fill={isHeads ? \"#00cc88\" : \"#ff6644\"} opacity=\"0.2\" />\n    18→      <circle cx=\"14\" cy=\"14\" r=\"12\" stroke={isHeads ? \"#00cc88\" : \"#ff6644\"} strokeWidth=\"1.5\" />\n    19→      <text\n    20→        x=\"14\"\n    21→        y=\"19\"\n    22→        textAnchor=\"middle\"\n    23→        fill={isHeads ? \"#00cc88\" : \"#ff6644\"}\n    24→        fontSize=\"13\"\n    25→        fontWeight=\"900\"\n    26→        fontFamily=\"var(--font-heading), Arial Black, sans-serif\"\n    27→      >\n    28→        {isHeads ? \"H\" : \"T\"}\n    29→      </text>\n    30→    </svg>\n    31→  );\n    32→}\n    33→\n    34→export function MatchCard({\n    35→  match,\n    36→  onJoin,\n    37→  isOwn = false,\n    38→  canJoin = true,\n    39→  joining = false,\n    40→}: MatchCardProps) {\n    41→  const timeAgo = getTimeAgo(match.createdAt);\n    42→\n    43→  return (\n    44→    <div\n    45→      className={`coinflip-match-card ${isOwn ? \"coinflip-match-card--own\" : \"\"}`}\n    46→      data-match-id={match.id}\n    47→    >\n    48→      <div className=\"coinflip-match-card__creator\">\n    49→        <PlayerAvatar address={match.player1} size=\"sm\" />\n    50→        <div className=\"coinflip-match-card__info\">\n    51→          <span className=\"coinflip-match-card__address\">\n    52→            {getDisplayName(match.player1)}\n    53→          </span>\n    54→          <span className=\"coinflip-match-card__time\">{timeAgo}</span>\n    55→        </div>\n    56→      </div>\n    57→\n    58→      <div className=\"coinflip-match-card__bet\">\n    59→        <div\n    60→          className={`coinflip-match-card__side coinflip-match-card__side--${match.player1Side}`}\n    61→        >\n    62→          <CoinBadge side={match.player1Side} />\n    63→        </div>\n    64→        <div className=\"coinflip-match-card__amount\">\n    65→          {match.entryAmount} SOL\n    66→        </div>\n    67→      </div>\n    68→\n    69→      <div className=\"coinflip-match-card__actions\">\n    70→        {!isOwn && onJoin && (\n    71→          <button\n    72→            type=\"button\"\n    73→            className=\"coinflip-match-card__join-btn\"\n    74→            onClick={onJoin}\n    75→            disabled={!canJoin || joining}\n    76→          >\n    77→            {joining ? \"Joining...\" : \"Join\"}\n    78→          </button>\n    79→        )}\n    80→        {isOwn && (\n    81→          <span className=\"coinflip-match-card__status\">Waiting...</span>\n    82→        )}\n    83→      </div>\n    84→    </div>\n    85→  );\n    86→}\n    87→\n    88→function getTimeAgo(timestamp: number): string {\n    89→  const seconds = Math.floor((Date.now() - timestamp) / 1000);\n    90→\n    91→  if (seconds < 60) return `${seconds}s ago`;\n    92→  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ago`;\n    93→  if (seconds < 86400) return `${Math.floor(seconds / 3600)}h ago`;\n    94→  return `${Math.floor(seconds / 86400)}d ago`;\n    95→}\n    96→"}]},"parent_tool_use_id":"toolu_01MPoXotPwuktccSSbk63gaM","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"97185ac5-4c6b-4026-bd68-6f78ebbe4c59"}
