{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ASdLv6b4Km4h2C9DMrwUk2","type":"tool_result","content":"     1→/**\n     2→ * Pari-Mutuel Payout Calculator for Close Call\n     3→ *\n     4→ * Formula:\n     5→ *   totalPool = greenPool + redPool\n     6→ *   netPool = totalPool × 0.97 (3% fee)\n     7→ *   playerPayout = (playerBet / winningPool) × netPool\n     8→ */\n     9→\n    10→import type { BetSide, CandleOutcome, Candle, PoolState } from \"../types\";\n    11→import { PLATFORM_FEE } from \"../types\";\n    12→\n    13→export interface PayoutResult {\n    14→  winner: BetSide | null;\n    15→  payouts: Record<string, number>;\n    16→  totalPayout: number;\n    17→  platformFee: number;\n    18→}\n    19→\n    20→/**\n    21→ * Determine the outcome of a candle (strict comparison, no threshold)\n    22→ */\n    23→export function determineOutcome(candle: Candle): CandleOutcome {\n    24→  const diff = candle.close - candle.open;\n    25→\n    26→  if (diff === 0) {\n    27→    return \"refund\";\n    28→  }\n    29→\n    30→  return diff > 0 ? \"green\" : \"red\";\n    31→}\n    32→\n    33→/**\n    34→ * Calculate payouts for all winners\n    35→ */\n    36→export function calculatePayouts(\n    37→  pool: PoolState,\n    38→  outcome: CandleOutcome\n    39→): PayoutResult {\n    40→  const totalPool = pool.totalPool;\n    41→\n    42→  // Handle refund - no winners, full refund, no fee\n    43→  if (outcome === \"refund\") {\n    44→    return {\n    45→      winner: null,\n    46→      payouts: {},\n    47→      totalPayout: 0,\n    48→      platformFee: 0,\n    49→    };\n    50→  }\n    51→\n    52→  // Determine winning side\n    53→  const winner: BetSide = outcome;\n    54→  const winningBets = outcome === \"green\" ? pool.greenBets : pool.redBets;\n    55→  const winningPool = outcome === \"green\" ? pool.greenPool : pool.redPool;\n    56→  const losingPool = outcome === \"green\" ? pool.redPool : pool.greenPool;\n    57→\n    58→  // Handle one-sided pool: no losers means refund, no fee\n    59→  if (losingPool === 0 || winningPool === 0 || winningBets.length === 0) {\n    60→    return {\n    61→      winner,\n    62→      payouts: {},\n    63→      totalPayout: 0,\n    64→      platformFee: 0,\n    65→    };\n    66→  }\n    67→\n    68→  // Calculate platform fee (3% of total pool on decisive rounds only)\n    69→  const platformFee = totalPool * PLATFORM_FEE;\n    70→  const netPool = totalPool - platformFee;\n    71→\n    72→  // Calculate individual payouts\n    73→  const payouts: Record<string, number> = {};\n    74→  let totalPayout = 0;\n    75→\n    76→  for (const bet of winningBets) {\n    77→    const share = bet.amount / winningPool;\n    78→    const payout = netPool * share;\n    79→    payouts[bet.address] = payout;\n    80→    totalPayout += payout;\n    81→  }\n    82→\n    83→  return {\n    84→    winner,\n    85→    payouts,\n    86→    totalPayout,\n    87→    platformFee,\n    88→  };\n    89→}\n    90→\n    91→/**\n    92→ * Calculate potential payout for a hypothetical bet\n    93→ */\n    94→export function calculatePotentialPayout(\n    95→  betAmount: number,\n    96→  betSide: BetSide,\n    97→  pool: PoolState\n    98→): number {\n    99→  // Calculate what the pool would look like with this bet\n   100→  const newWinningPool =\n   101→    betSide === \"green\" ? pool.greenPool + betAmount : pool.redPool + betAmount;\n   102→  const newTotalPool = pool.totalPool + betAmount;\n   103→  const netPool = newTotalPool * (1 - PLATFORM_FEE);\n   104→\n   105→  // Player's share of winning pool\n   106→  const share = betAmount / newWinningPool;\n   107→\n   108→  return netPool * share;\n   109→}\n   110→\n   111→/**\n   112→ * Calculate odds multiplier for a side\n   113→ * Returns how much $1 would win (e.g., 2.0 means double your money)\n   114→ */\n   115→export function calculateOddsMultiplier(\n   116→  side: BetSide,\n   117→  pool: PoolState\n   118→): number {\n   119→  const winningPool = side === \"green\" ? pool.greenPool : pool.redPool;\n   120→  const totalPool = pool.totalPool;\n   121→\n   122→  if (winningPool === 0 || totalPool === 0) {\n   123→    return 0;\n   124→  }\n   125→\n   126→  const netPool = totalPool * (1 - PLATFORM_FEE);\n   127→  return netPool / winningPool;\n   128→}\n   129→\n   130→/**\n   131→ * Calculate percentage of pool on each side\n   132→ */\n   133→export function calculatePoolDistribution(pool: PoolState): {\n   134→  greenPercent: number;\n   135→  redPercent: number;\n   136→} {\n   137→  if (pool.totalPool === 0) {\n   138→    return { greenPercent: 50, redPercent: 50 };\n   139→  }\n   140→\n   141→  return {\n   142→    greenPercent: (pool.greenPool / pool.totalPool) * 100,\n   143→    redPercent: (pool.redPool / pool.totalPool) * 100,\n   144→  };\n   145→}\n   146→\n   147→/**\n   148→ * Format amount for display\n   149→ */\n   150→export function formatAmount(amount: number, decimals: number = 4): string {\n   151→  return amount.toFixed(decimals);\n   152→}\n   153→\n   154→/**\n   155→ * Format USD amount for display\n   156→ */\n   157→export function formatUsd(amount: number): string {\n   158→  return amount.toLocaleString(\"en-US\", {\n   159→    style: \"currency\",\n   160→    currency: \"USD\",\n   161→    minimumFractionDigits: 2,\n   162→    maximumFractionDigits: 2,\n   163→  });\n   164→}\n   165→"}]},"parent_tool_use_id":"toolu_01WW4EWX9A8Sn6WMA6YLDyWK","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"61f80a28-d225-4a03-b5d0-609c90362f38"}
