 minimum (3s)\n   173→  const countdownTimerRef = useRef<number | null>(null);\n   174→  const flipTimerRef = useRef<number | null>(null);\n   175→  const refreshInFlightRef = useRef(false);\n   176→  const activeMatchFetchInFlightRef = useRef(false);\n   177→\n   178→  // Ref to prevent polling races from restoring a dismissed match.\n   179→  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n   180→  // from the previous poll interval may resolve and call setActiveMatch,\n   181→  // putting them back on the match view. This ref blocks that.\n   182→  const dismissedMatchRef = useRef<string | null>(null);\n   183→\n   184→  /** Send transaction, wait for on-chain confirmation, and refresh balance.\n   185→   *  Retries on blockhash expiry (devnet tx drops) up to 3 times. */\n   186→  const sendAndConfirm = useCallback(\n   187→    async (transaction: Transaction): Promise<string> => {\n   188→      const hasPartialSignatures = transaction.signatures.some(\n   189→        (entry) => entry.signature !== null\n   190→      );\n   191→      const preservesExternalSignature =\n   192→        hasPartialSignatures &&\n   193→        typeof transaction.recentBlockhash === \"string\";\n   194→      const hasPinnedBlockhash =\n   195→        preservesExternalSignature &&\n   196→        typeof transaction.lastValidBlockHeight === \"number\";\n   197→\n   198→      if (preservesExternalSignature && !hasPinnedBlockhash) {\n   199→        throw new Error(\n   200→          \"Backend transaction is missing lastValidBlockHeight. Refusing to send with an incomplete confirmation contract.\",\n   201→        );\n   202→      }\n   203→\n   204→      // Pre-flight simulation for diagnostics (best-effort, unsigned).\n   205→      // Abort early on InstructionError — the tx will fail on-chain too.\n   206→      // The blockhash fetched here is reused for the first send attempt.\n   207→      let cachedBlockhash: string | undefined;\n   208→      let cachedHeight: number | undefined;\n   209→      try {\n   210→        if (!preservesExternalSignature) {\n   211→          const { blockhash, lastValidBlockHeight } =\n   212→            await connection.getLatestBlockhash(\"confirmed\");\n   213→          cachedBlockhash = blockhash;\n   214→          cachedHeight = lastValidBlockHeight;\n   215→          transaction.recentBlockhash = blockhash;\n   216→        }\n   217→\n   218→        const simResult = await connection.simulateTransaction(transaction);\n   219→        if (simResult.value.err) {\n   220→          console.error(\n   221→            \"[coinflip] simulation failed BEFORE wallet send:\",\n   222→            JSON.stringify(simResult.value.err),\n   223→          );\n   224→          if (simResult.value.logs) {\n   225→            console.error(\n   226→              \"[coinflip] simulation logs:\\n\" + simResult.value.logs.join(\"\\n\"),\n   227→            );\n   228→          }\n   229→          const err = simResult.value.err;\n   230→          if (typeof err === \"object\" && err !== null && \"InstructionError\" in err) {\n   231→            throw new Error(`Transaction will fail: ${JSON.stringify(err)}`);\n   232→          }\n   233→        }\n   234→      } catch (simErr) {\n   235→        if (simErr instanceof Error && simErr.message.startsWith(\"Transaction will fail:\")) {\n   236→          throw simErr;\n   237→        }\n   238→        console.error(\"[coinflip] simulation RPC error:\", simErr);\n   239→      }\n   240→\n   241→      // Send with retry — devnet txs can be dropped by validators/RPCs.\n   242→      const MAX_SEND_ATTEMPTS = preservesExternalSignature ? 1 : 3;\n   243→      for (let attempt = 1; attempt <= MAX_SEND_ATTEMPTS; attempt++) {\n   244→        let blockhash: string;\n   245→        let lastValidBlockHeight: number;\n   246→        if (preservesExternalSignature) {\n   247→          blockhash = transaction.recentBlockhash!;\n   248→          lastValidBlockHeight = transaction.lastValidBlockHeight ?? 0;\n   249→        } else if (attempt === 1 && cachedBlockhash && cachedHeight) {\n   250→          // Reuse simulation blockhash for first attempt (saves an RPC call)\n   251→          blockhash = cachedBlockhash;\n   252→          lastValidBlockHeight = cachedHeight;\n   253→        } else {\n   254→          // Fresh blockhash for retries (previous one may have expired)\n   255→          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n   256→          blockhash = fresh.blockhash;\n   257→          lastValidBlockHeight = fresh.lastValidBlockHeight;\n   258→        }\n   259→        if (!preservesExternalSignature) {\n   260→          transaction.recentBlockhash = blockhash;\n   261→        }\n   262→\n   263→        const signature = await sendTransaction(transaction);\n   264→        console.log(`[coinflip] tx sent (attempt ${attempt}/${MAX_SEND_ATTEMPTS}): ${signature}`);\n   265→\n   266→        const controller = new AbortController();\n   267→        const timeout = setTimeout(() => controller.abort(), 30_000);\n   268→        try {\n   269→          if (preservesExternalSignature) {\n   270→            await connection.confirmTransaction(\n   271→              { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n   272→              \"confirmed\",\n   273→            );\n   274→          } else {\n   275→            await connection.confirmTransaction(\n   276→              { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n   277→              \"confirmed\",\n   278→            );\n   279→          }\n   280→          // Success — refresh balance and return\n   281→          await refreshBalance();\n   282→          return signature;\n   283→        } catch (confirmErr) {\n   284→          const msg = confirmErr instanceof Error ? confirmErr.message : String(confirmErr);\n   285→          const isExpired = msg.includes(\"expired\") || msg.includes(\"block height exceeded\");\n   286→          const isAborted = msg.includes(\"aborted\");\n   287→\n   288→          if ((isExpired || isAborted) && attempt < MAX_SEND_ATTEMPTS) {\n   289→            // Before retrying, check if the tx actually landed despite confirm failure\n   290→            // (common when devnet WebSocket drops the subscription notification)\n   291→            try {\n   292→              const status = await connection.getSignatureStatus(signature);\n   293→              if (\n   294→                status.value?.confirmationStatus === \"confirmed\" ||\n   295→                status.value?.confirmationStatus === \"finalized\"\n   296→              ) {\n   297→                console.log(`[coinflip] tx ${signature} confirmed via fallback status check`);\n   298→                await refreshBalance();\n   299→                return signature;\n   300→              }\n   301→            } catch {\n   302→              // Status check failed — fall through to retry\n   303→            }\n   304→            console.warn(`[coinflip] tx dropped/expired on attempt ${attempt}, retrying...`);\n   305→            continue;\n   306→          }\n   307→          throw confirmErr;\n   308→        } finally {\n   309→          clearTimeout(timeout);\n   310→        }\n   311→      }\n   312→\n   313→      throw new Error(\"Transaction failed after max retry attempts\");\n   314→    },\n   315→    [connection, sendTransaction, refreshBalance],\n   316→  );\n   317→\n   318→  // Fetch open matches + claimable matches from on-chain (lobby data).\n   319→  // Only called when the user is in the lobby — NOT during an active match.\n   320→  const refreshMatches = useCallback(async () => {\n   321→    if (refreshInFlightRef.current) return;\n   322→    refreshInFlightRef.current = true;\n   323→\n   324→    try {\n   325→      const [matches, claimable] = await Promise.all([\n   326→        fetchAllOpenMatches(connection),\n   327→        publicKey\n   328→          ? fetchClaimableMatches(connection, publicKey)\n   329→          : Promise.resolve([]),\n   330→      ]);\n   331→\n   332→      setOpenMatches(matches);\n   333→      setClaimableMatches(claimable);\n   334→    } catch {"}]},"parent_tool_use_id":null,"session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"82f22d61-85e3-4b43-9ec7-fa152757217f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx","content":"  timeoutRefund: () => Promise<void>;\n  clearActiveMatch: () => void;\n  selectMatch: (match: UIMatch) => void;\n  refreshMatches: () => void;\n}\n\nconst CoinflipContext = createContext<CoinflipContextValue | null>(null);\n\nexport function CoinflipProvider({ children }: { children: ReactNode }) {\n  const { connected, publicKey, sendTransaction } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n  const { accessToken, isAuthenticated, authenticate } = useSession();\n\n  // Selection state\n  const [wagerAmount, setWagerAmount] = useState<number | null>(null);\n  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n\n  // Match state\n  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n  const [userHistory] = useState<UIMatch[]>([]);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [creating, setCreating] = useState(false);\n  const [joining, setJoining] = useState(false);\n  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n\n  // Error state\n  const [error, setError] = useState<string | null>(null);\n  const clearError = useCallback(() => setError(null), []);\n\n  // Verification — last settle tx signature for fairness verification\n  const [lastSettleSignature, setLastSettleSignature] = useState<string | null>(null);\n\n  // Timer ref for countdown (3s) then flip animation minimum (3s)\n  const countdownTimerRef = useRef<number | null>(null);\n  const flipTimerRef = useRef<number | null>(null);\n  const refreshInFlightRef = useRef(false);\n  const activeMatchFetchInFlightRef = useRef(false);\n\n  // Ref to prevent polling races from restoring a dismissed match.\n  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n  // from the previous poll interval may resolve and call setActiveMatch,\n  // putting them back on the match view. This ref blocks that.\n  const dismissedMatchRef = useRef<string | null>(null);\n\n  /** Send transaction, wait for on-chain confirmation, and refresh balance.\n   *  Retries on blockhash expiry (devnet tx drops) up to 3 times. */\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const hasPartialSignatures = transaction.signatures.some(\n        (entry) => entry.signature !== null\n      );\n      const preservesExternalSignature =\n        hasPartialSignatures &&\n        typeof transaction.recentBlockhash === \"string\";\n      const hasPinnedBlockhash =\n        preservesExternalSignature &&\n        typeof transaction.lastValidBlockHeight === \"number\";\n\n      if (preservesExternalSignature && !hasPinnedBlockhash) {\n        throw new Error(\n          \"Backend transaction is missing lastValidBlockHeight. Refusing to send with an incomplete confirmation contract.\",\n        );\n      }\n\n      // Pre-flight simulation for diagnostics (best-effort, unsigned).\n      // Abort early on InstructionError — the tx will fail on-chain too.\n      // The blockhash fetched here is reused for the first send attempt.\n      let cachedBlockhash: string | undefined;\n      let cachedHeight: number | undefined;\n      try {\n        if (!preservesExternalSignature) {\n          const { blockhash, lastValidBlockHeight } =\n            await connection.getLatestBlockhash(\"confirmed\");\n          cachedBlockhash = blockhash;\n          cachedHeight = lastValidBlockHeight;\n          transaction.recentBlockhash = blockhash;\n        }\n\n        const simResult = await connection.simulateTransaction(transaction);\n        if (simResult.value.err) {\n          console.error(\n            \"[coinflip] simulation failed BEFORE wallet send:\",\n            JSON.stringify(simResult.value.err),\n          );\n          if (simResult.value.logs) {\n            console.error(\n              \"[coinflip] simulation logs:\\n\" + simResult.value.logs.join(\"\\n\"),\n            );\n          }\n          const err = simResult.value.err;\n          if (typeof err === \"object\" && err !== null && \"InstructionError\" in err) {\n            throw new Error(`Transaction will fail: ${JSON.stringify(err)}`);\n          }\n        }\n      } catch (simErr) {\n        if (simErr instanceof Error && simErr.message.startsWith(\"Transaction will fail:\")) {\n          throw simErr;\n        }\n        console.error(\"[coinflip] simulation RPC error:\", simErr);\n      }\n\n      // Send with retry — devnet txs can be dropped by validators/RPCs.\n      const MAX_SEND_ATTEMPTS = preservesExternalSignature ? 1 : 3;\n      for (let attempt = 1; attempt <= MAX_SEND_ATTEMPTS; attempt++) {\n        let blockhash: string;\n        let lastValidBlockHeight: number;\n        if (preservesExternalSignature) {\n          blockhash = transaction.recentBlockhash!;\n          lastValidBlockHeight = transaction.lastValidBlockHeight ?? 0;\n        } else if (attempt === 1 && cachedBlockhash && cachedHeight) {\n          // Reuse simulation blockhash for first attempt (saves an RPC call)\n          blockhash = cachedBlockhash;\n          lastValidBlockHeight = cachedHeight;\n        } else {\n          // Fresh blockhash for retries (previous one may have expired)\n          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n          blockhash = fresh.blockhash;\n          lastValidBlockHeight = fresh.lastValidBlockHeight;\n        }\n        if (!preservesExternalSignature) {\n          transaction.recentBlockhash = blockhash;\n        }\n\n        const signature = await sendTransaction(transaction);\n        console.log(`[coinflip] tx sent (attempt ${attempt}/${MAX_SEND_ATTEMPTS}): ${signature}`);\n\n        const controller = new AbortController();\n        const timeout = setTimeout(() => controller.abort(), 30_000);\n        try {\n          if (preservesExternalSignature) {\n            await connection.confirmTransaction(\n              { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n              \"confirmed\",\n            );\n          } else {\n            await connection.confirmTransaction(\n              { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n              \"confirmed\",\n            );\n          }\n          // Success — refresh balance and return\n          await refreshBalance();\n          return signature;\n        } catch (confirmErr) {\n          const msg = confirmErr instanceof Error ? confirmErr.message : String(confirmErr);\n          const isExpired = msg.includes(\"expired\") || msg.includes(\"block height exceeded\");\n          const isAborted = msg.includes(\"aborted\");\n\n          if ((isExpired || isAborted) && attempt < MAX_SEND_ATTEMPTS) {\n            // Before retrying, check if the tx actually landed despite confirm failure\n            // (common when devnet WebSocket drops the subscription notification)\n            try {\n              const status = await connection.getSignatureStatus(signature);\n              if (\n                status.value?.confirmationStatus === \"confirmed\" ||\n                status.value?.confirmationStatus === \"finalized\"\n              ) {\n                console.log(`[coinflip] tx ${signature} confirmed via fallback status check`);\n                await refreshBalance();\n                return signature;\n              }\n            } catch {\n              // Status check failed — fall through to retry\n            }\n            console.warn(`[coinflip] tx dropped/expired on attempt ${attempt}, retrying...`);\n            continue;\n          }\n          throw confirmErr;\n        } finally {\n          clearTimeout(timeout);\n        }\n      }\n\n      throw new Error(\"Transaction failed after max retry attempts\");\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // Fetch open matches + claimable matches from on-chain (lobby data).\n  // Only called when the user is in the lobby — NOT during an active match.\n  const refreshMatches = useCallback(async () => {\n    if (refreshInFlightRef.current) return;\n    refreshInFlightRef.current = true;\n\n    try {\n      const [matches, claimable] = await Promise.all([\n        fetchAllOpenMatches(connection),\n        publicKey\n          ? fetchClaimableMatches(connection, publicKey)\n          : Promise.resolve([]),\n      ]);\n\n      setOpenMatches(matches);\n      setClaimableMatches(claimable);\n    } catch {","numLines":200,"startLine":135,"totalLines":875}}}
