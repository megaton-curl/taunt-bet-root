{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LJn9gEBdDnk2V4qSdDJRA3","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  COIN_SIDE_VALUES,\n    11→  type CoinSide,\n    12→} from \"@rng-utopia/game-engine/browser\";\n    13→import type { UIMatch } from \"../types\";\n    14→\n    15→// ============ Constants ============\n    16→\n    17→export const COINFLIP_PROGRAM_ID = new PublicKey(\n    18→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    19→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    20→);\n    21→\n    22→const FAIRNESS_BACKEND_URL = (\n    23→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    24→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    25→).replace(/\\/$/, \"\");\n    26→\n    27→// Phase constants matching on-chain\n    28→const PHASE_WAITING = 0;\n    29→const PHASE_LOCKED = 1;\n    30→const PHASE_SETTLED = 2;\n    31→const PHASE_REFUNDED = 3;\n    32→\n    33→export interface BackendCreateMatchResponse {\n    34→  transaction: string;\n    35→  matchPda: string;\n    36→  matchId: string;\n    37→  commitment: string;\n    38→  lastValidBlockHeight: number;\n    39→}\n    40→\n    41→export interface BackendRoundResponse {\n    42→  pda: string;\n    43→  game: string;\n    44→  phase: \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    45→  creator: string;\n    46→  commitment: string;\n    47→  amountLamports: number;\n    48→  side: number;\n    49→  matchId: string;\n    50→  createdAt: string;\n    51→  updatedAt: string;\n    52→  targetSlot?: number;\n    53→  secret?: string;\n    54→  resultHash?: string | null;\n    55→  resultSide?: number | null;\n    56→  winner?: string | null;\n    57→  settleTx?: string | null;\n    58→}\n    59→\n    60→export class BackendRequestError extends Error {\n    61→  status: number;\n    62→\n    63→  constructor(status: number, message: string) {\n    64→    super(message);\n    65→    this.name = \"BackendRequestError\";\n    66→    this.status = status;\n    67→  }\n    68→}\n    69→\n    70→// ============ PDA Derivation ============\n    71→\n    72→export function getMatchPda(creator: PublicKey, matchId: Uint8Array): [PublicKey, number] {\n    73→  return PublicKey.findProgramAddressSync(\n    74→    [Buffer.from(\"match\"), creator.toBuffer(), Buffer.from(matchId)],\n    75→    COINFLIP_PROGRAM_ID\n    76→  );\n    77→}\n    78→\n    79→export function getConfigPda(): [PublicKey, number] {\n    80→  return PublicKey.findProgramAddressSync(\n    81→    [Buffer.from(\"coinflip_config\")],\n    82→    COINFLIP_PROGRAM_ID\n    83→  );\n    84→}\n    85→\n    86→function getFairnessBackendRoundUrl(matchPda: string): string {\n    87→  return `${FAIRNESS_BACKEND_URL}/fairness/rounds/${matchPda}`;\n    88→}\n    89→\n    90→function getFairnessBackendCreateUrl(): string {\n    91→  return `${FAIRNESS_BACKEND_URL}/fairness/coinflip/create`;\n    92→}\n    93→\n    94→async function parseBackendResponse<T>(response: Response): Promise<T> {\n    95→  let json: unknown = null;\n    96→  try {\n    97→    json = await response.json();\n    98→  } catch {\n    99→    json = null;\n   100→  }\n   101→\n   102→  if (!response.ok) {\n   103→    const errorMessage =\n   104→      typeof json === \"object\" &&\n   105→      json !== null &&\n   106→      \"error\" in json &&\n   107→      typeof (json as { error: unknown }).error === \"string\"\n   108→        ? (json as { error: string }).error\n   109→        : `Backend request failed (${response.status})`;\n   110→    throw new BackendRequestError(response.status, errorMessage);\n   111→  }\n   112→\n   113→  return json as T;\n   114→}\n   115→\n   116→function sideFromBackendResult(resultSide: number | null | undefined): CoinSide | null {\n   117→  if (resultSide === 0) return \"heads\";\n   118→  if (resultSide === 1) return \"tails\";\n   119→  return null;\n   120→}\n   121→\n   122→// ============ Program Instances ============\n   123→\n   124→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n   125→  // Read-only provider (no wallet needed for queries)\n   126→  const provider = new AnchorProvider(\n   127→    connection,\n   128→    {} as AnchorProvider[\"wallet\"],\n   129→    { commitment: \"confirmed\" }\n   130→  );\n   131→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n   132→}\n   133→\n   134→// ============ On-Chain Account Types ============\n   135→\n   136→interface OnChainMatch {\n   137→  creator: PublicKey;\n   138→  opponent: PublicKey;\n   139→  server: PublicKey;\n   140→  entryAmount: { toNumber(): number };\n   141→  creatorSide: number;\n   142→  phase: number;\n   143→  commitment: number[];\n   144→  algorithmVer: number;\n   145→  targetSlot: { toNumber(): number };\n   146→  resolveDeadline: { toNumber(): number };\n   147→  resultHash: number[];\n   148→  result: number;\n   149→  winner: PublicKey;\n   150→  createdAt: { toNumber(): number };\n   151→  matchId: number[];\n   152→  bump: number;\n   153→}\n   154→\n   155→// ============ Converters ============\n   156→\n   157→function sideFromIndex(index: number): CoinSide {\n   158→  return index === 0 ? \"heads\" : \"tails\";\n   159→}\n   160→\n   161→function phaseToUI(phase: number): UIMatch[\"phase\"] {\n   162→  if (phase === PHASE_WAITING) return \"created\";\n   163→  if (phase === PHASE_LOCKED) return \"ready\";\n   164→  if (phase === PHASE_SETTLED) return \"complete\";\n   165→  return \"created\";\n   166→}\n   167→\n   168→const DEFAULT_PUBKEY = PublicKey.default;\n   169→\n   170→function isDefaultPubkey(key: PublicKey): boolean {\n   171→  return key.equals(DEFAULT_PUBKEY);\n   172→}\n   173→\n   174→import { bytesToHex, sha256 } from \"./crypto\";\n   175→\n   176→export function onChainMatchToUI(\n   177→  matchPda: PublicKey,\n   178→  data: OnChainMatch\n   179→): UIMatch {\n   180→  const creatorSide = sideFromIndex(data.creatorSide);\n   181→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   182→  const phase = phaseToUI(data.phase);\n   183→  const isSettled = data.phase === PHASE_SETTLED;\n   184→\n   185→  const entryAmountSol = data.entryAmount.toNumber() / 1e9;\n   186→  const totalPool = entryAmountSol * 2;\n   187→  const payoutAmount = totalPool * 0.97;\n   188→\n   189→  return {\n   190→    id: matchPda.toBase58(),\n   191→    matchId: bytesToHex(data.matchId),\n   192→    entryAmount: entryAmountSol,\n   193→    player1: data.creator.toBase58(),\n   194→    player1Side: creatorSide,\n   195→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   196→    player2Side: hasOpponent\n   197→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   198→      : null,\n   199→    server: data.server.toBase58(),\n   200→    phase,\n   201→    createdAt: data.createdAt.toNumber() * 1000,\n   202→    lockedAt: data.phase >= PHASE_LOCKED && data.resolveDeadline.toNumber() > 0\n   203→      ? (data.resolveDeadline.toNumber() - 86400) * 1000\n   204→      : undefined,\n   205→    result: isSettled ? sideFromIndex(data.result) : null,\n   206→    winner: isSettled && !isDefaultPubkey(data.winner)\n   207→      ? data.winner.toBase58()\n   208→      : null,\n   209→    payoutAmount,\n   210→    commitment: bytesToHex(data.commitment),\n   211→    resultHash: isSettled ? bytesToHex(data.resultHash) : undefined,\n   212→    targetSlot: data.targetSlot.toNumber() || undefined,\n   213→  };\n   214→}\n   215→\n   216→// ============ Account Queries ============\n   217→\n   218→export async function fetchAllOpenMatches(\n   219→  connection: Connection\n   220→): Promise<UIMatch[]> {\n   221→  const program = getCoinflipProgram(connection);\n   222→  const accounts = await program.account.coinflipMatch.all([\n   223→    { dataSize: program.account.coinflipMatch.size },\n   224→  ]);\n   225→\n   226→  return accounts\n   227→    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n   228→    .map((acc) =>\n   229→      onChainMatchToUI(\n   230→        acc.publicKey,\n   231→        acc.account as unknown as OnChainMatch\n   232→      )\n   233→    );\n   234→}\n   235→\n   236→/**\n   237→ * Fetch all matches where playerPubkey is creator OR opponent,\n   238→ * phase is non-terminal (not refunded/settled with PDA closed).\n   239→ * Uses memcmp filters for efficient on-chain filtering.\n   240→ *\n   241→ * Account layout offsets (after 8-byte discriminator):\n   242→ *   creator:  8   (32 bytes)\n   243→ *   opponent: 40  (32 bytes)\n   244→ */\n   245→export async function fetchClaimableMatches(\n   246→  connection: Connection,\n   247→  playerPubkey: PublicKey\n   248→): Promise<UIMatch[]> {\n   249→  const program = getCoinflipProgram(connection);\n   250→  const playerBase58 = playerPubkey.toBase58();\n   251→\n   252→  const [asCreator, asOpponent] = await Promise.all([\n   253→    program.account.coinflipMatch.all([\n   254→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   255→      { dataSize: program.account.coinflipMatch.size },\n   256→    ]),\n   257→    program.account.coinflipMatch.all([\n   258→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   259→      { dataSize: program.account.coinflipMatch.size },\n   260→    ]),\n   261→  ]);\n   262→\n   263→  // Merge and deduplicate by public key\n   264→  const seen = new Set<string>();\n   265→  const matches: UIMatch[] = [];\n   266→\n   267→  for (const acc of [...asCreator, ...asOpponent]) {\n   268→    const key = acc.publicKey.toBase58();\n   269→    if (seen.has(key)) continue;\n   270→    seen.add(key);\n   271→\n   272→    const data = acc.account as unknown as OnChainMatch;\n   273→    // Skip terminal phases\n   274→    if (data.phase === PHASE_REFUNDED || data.phase === PHASE_SETTLED) continue;\n   275→\n   276→    matches.push(onChainMatchToUI(acc.publicKey, data));\n   277→  }\n   278→\n   279→  return matches;\n   280→}\n   281→\n   282→/**\n   283→ * Find all active (non-terminal) matches for a creator using memcmp filters.\n   284→ * Returns all matches, not just the first one (supports multiple concurrent matches).\n   285→ */\n   286→export async function fetchMatchesByCreator(\n   287→  connection: Connection,\n   288→  creator: PublicKey\n   289→): Promise<UIMatch[]> {\n   290→  const program = getCoinflipProgram(connection);\n   291→\n   292→  const matches = await program.account.coinflipMatch.all([\n   293→    { memcmp: { offset: 8, bytes: creator.toBase58() } },\n   294→    { dataSize: program.account.coinflipMatch.size },\n   295→  ]);\n   296→\n   297→  return matches\n   298→    .filter((acc) => {\n   299→      const data = acc.account as unknown as OnChainMatch;\n   300→      return data.phase !== PHASE_REFUNDED && data.phase !== PHASE_SETTLED;\n   301→    })\n   302→    .map((acc) => onChainMatchToUI(acc.publicKey, acc.account as unknown as OnChainMatch));\n   303→}\n   304→\n   305→/**\n   306→ * Find the first active (non-terminal) match for a creator.\n   307→ * Returns null if no active match exists.\n   308→ */\n   309→export async function fetchMatchByCreator(\n   310→  connection: Connection,\n   311→  creator: PublicKey\n   312→): Promise<UIMatch | null> {\n   313→  const matches = await fetchMatchesByCreator(connection, creator);\n   314→  return matches[0] ?? null;\n   315→}\n   316→\n   317→export async function fetchMatch(\n   318→  connection: Connection,\n   319→  matchPda: PublicKey\n   320→): Promise<UIMatch | null> {\n   321→  const program = getCoinflipProgram(connection);\n   322→\n   323→  try {\n   324→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   325→    const data = account as unknown as OnChainMatch;\n   326→    const uiMatch = onChainMatchToUI(matchPda, data);\n   327→    if (uiMatch.phase !== \"complete\") {\n   328→      return uiMatch;\n   329→    }\n   330→\n   331→    try {\n   332→      const round = await fetchRoundVerification(matchPda.toBase58());\n   333→      return round ? applyBackendRoundToMatch(uiMatch, round) : uiMatch;\n   334→    } catch {\n   335→      return uiMatch;\n   336→    }\n   337→  } catch {\n   338→    return null;\n   339→  }\n   340→}\n   341→\n   342→// ============ Crypto Helpers ============\n   343→\n   344→/** Generate a random 32-byte secret for commit-reveal. */\n   345→export function generateSecret(): Uint8Array {\n   346→  const secret = new Uint8Array(32);\n   347→  crypto.getRandomValues(secret);\n   348→  return secret;\n   349→}\n   350→\n   351→/** Compute commitment = SHA-256(secret). */\n   352→export async function computeCommitment(secret: Uint8Array): Promise<Uint8Array> {\n   353→  return sha256(secret);\n   354→}\n   355→\n   356→/**\n   357→ * Fetch a match by its hex matchId via the backend, then load on-chain state.\n   358→ * Used for deep-link restore when we only have the matchId from the URL.\n   359→ */\n   360→export async function fetchMatchByMatchId(\n   361→  connection: Connection,\n   362→  matchId: string,\n   363→): Promise<UIMatch | null> {\n   364→  const response = await fetch(`${FAIRNESS_BACKEND_URL}/fairness/rounds/by-id/${matchId}`);\n   365→  if (!response.ok) return null;\n   366→  const backendRound = (await response.json()) as BackendRoundResponse;\n   367→\n   368→  const matchPda = new PublicKey(backendRound.pda);\n   369→  const onChainMatch = await fetchMatch(connection, matchPda);\n   370→  if (onChainMatch) return onChainMatch;\n   371→\n   372→  // Match PDA closed (settled) — build UI from backend data\n   373→  if (backendRound.phase === \"settled\") {\n   374→    return {\n   375→      id: backendRound.pda,\n   376→      matchId: backendRound.matchId ?? matchId,\n   377→      entryAmount: backendRound.amountLamports / 1e9,\n   378→      player1: backendRound.creator,\n   379→      player1Side: backendRound.side === 0 ? \"heads\" : \"tails\",\n   380→      player2: backendRound.winner ?? null,\n   381→      player2Side: backendRound.side === 0 ? \"tails\" : \"heads\",\n   382→      phase: \"complete\",\n   383→      createdAt: Date.parse(backendRound.createdAt),\n   384→      completedAt: Date.parse(backendRound.updatedAt),\n   385→      result: sideFromBackendResult(backendRound.resultSide),\n   386→      winner: backendRound.winner ?? null,\n   387→      payoutAmount: (backendRound.amountLamports * 2 * 0.97) / 1e9,\n   388→      commitment: backendRound.commitment,\n   389→      secret: backendRound.secret,\n   390→      resultHash: backendRound.resultHash ?? undefined,\n   391→    };\n   392→  }\n   393→\n   394→  return null;\n   395→}\n   396→\n   397→export async function fetchRoundVerification(\n   398→  matchPda: string\n   399→): Promise<BackendRoundResponse | null> {\n   400→  const response = await fetch(getFairnessBackendRoundUrl(matchPda));\n   401→  if (response.status === 404) {\n   402→    return null;\n   403→  }\n   404→  return parseBackendResponse<BackendRoundResponse>(response);\n   405→}\n   406→\n   407→export function applyBackendRoundToMatch(\n   408→  match: UIMatch,\n   409→  round: BackendRoundResponse\n   410→): UIMatch {\n   411→  return {\n   412→    ...match,\n   413→    phase: round.phase === \"settled\" ? \"complete\" : match.phase,\n   414→    commitment: round.commitment,\n   415→    secret: round.secret ?? match.secret,\n   416→    resultHash: round.resultHash ?? undefined,\n   417→    result: sideFromBackendResult(round.resultSide) ?? match.result,\n   418→    winner: round.winner ?? match.winner,\n   419→    completedAt: Date.parse(round.updatedAt),\n   420→  };\n   421→}\n   422→\n   423→// ============ Settlement Event Helpers ============\n   424→\n   425→export interface MatchSettledEventData {\n   426→  creator: PublicKey;\n   427→  opponent: PublicKey;\n   428→  winner: PublicKey;\n   429→  commitment: number[];\n   430→  secret: number[];\n   431→  entropy: number[];\n   432→  resultHash: number[];\n   433→  resultSide: number;\n   434→  payoutAmount: { toNumber(): number };\n   435→  feeAmount: { toNumber(): number };\n   436→}\n   437→\n   438→/**\n   439→ * Apply data from an on-chain MatchSettled event to a UIMatch.\n   440→ * Used by the settlement event subscription to instantly update the UI\n   441→ * without waiting for getAccountInfo to reflect the closed PDA.\n   442→ */\n   443→export function applySettlementEventToMatch(\n   444→  match: UIMatch,\n   445→  event: MatchSettledEventData,\n   446→): UIMatch {\n   447→  const resultSide = sideFromIndex(event.resultSide);\n   448→  return {\n   449→    ...match,\n   450→    phase: \"complete\",\n   451→    result: resultSide,\n   452→    winner: event.winner.toBase58(),\n   453→    secret: bytesToHex(event.secret),\n   454→    entropy: bytesToHex(event.entropy),\n   455→    resultHash: bytesToHex(event.resultHash),\n   456→    commitment: bytesToHex(event.commitment),\n   457→    payoutAmount: event.payoutAmount.toNumber() / 1e9,\n   458→    completedAt: Date.now(),\n   459→  };\n   460→}\n   461→\n   462→export async function buildBackendCreateMatchTx(\n   463→  creator: PublicKey,\n   464→  amountSol: number,\n   465→  side: CoinSide,\n   466→  accessToken: string,\n   467→): Promise<{ transaction: Transaction; matchPda: PublicKey; commitment: string }> {\n   468→  const payload = {\n   469→    wallet: creator.toBase58(),\n   470→    amountLamports: Math.round(amountSol * 1e9),\n   471→    side: COIN_SIDE_VALUES[side],\n   472→  };\n   473→\n   474→  const response = await fetch(getFairnessBackendCreateUrl(), {\n   475→    method: \"POST\",\n   476→    headers: {\n   477→      \"Content-Type\": \"application/json\",\n   478→      \"Authorization\": `Bearer ${accessToken}`,\n   479→    },\n   480→    body: JSON.stringify(payload),\n   481→  });\n   482→\n   483→  const json = await parseBackendResponse<BackendCreateMatchResponse>(response);\n   484→\n   485→  return {\n   486→    transaction: (() => {\n   487→      const transaction = Transaction.from(Buffer.from(json.transaction, \"base64\"));\n   488→      transaction.lastValidBlockHeight = json.lastValidBlockHeight;\n   489→      return transaction;\n   490→    })(),\n   491→    matchPda: new PublicKey(json.matchPda),\n   492→    commitment: json.commitment,\n   493→  };\n   494→}\n   495→\n   496→// ============ Instruction Builders ============\n   497→\n   498→export async function buildJoinMatchTx(\n   499→  connection: Connection,\n   500→  opponent: PublicKey,\n   501→  matchPda: PublicKey\n   502→): Promise<Transaction> {\n   503→  const program = getCoinflipProgram(connection);\n   504→  const [configPda] = getConfigPda();\n   505→\n   506→  const ix = await program.methods\n   507→    .joinMatch()\n   508→    .accountsStrict({\n   509→      opponent,\n   510→      coinflipMatch: matchPda,\n   511→      config: configPda,\n   512→      systemProgram: SystemProgram.programId,\n   513→    })\n   514→    .instruction();\n   515→\n   516→  const tx = new Transaction().add(ix);\n   517→  tx.feePayer = opponent;\n   518→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   519→\n   520→  return tx;\n   521→}\n   522→\n   523→export async function buildCancelMatchTx(\n   524→  connection: Connection,\n   525→  creator: PublicKey,\n   526→  matchPda: PublicKey,\n   527→  server: PublicKey,\n   528→): Promise<Transaction> {\n   529→  const program = getCoinflipProgram(connection);\n   530→\n   531→  const ix = await program.methods\n   532→    .cancelMatch()\n   533→    .accountsStrict({\n   534→      creator,\n   535→      coinflipMatch: matchPda,\n   536→      server,\n   537→      systemProgram: SystemProgram.programId,\n   538→    })\n   539→    .instruction();\n   540→\n   541→  const tx = new Transaction().add(ix);\n   542→  tx.feePayer = creator;\n   543→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   544→\n   545→  return tx;\n   546→}\n   547→\n   548→export async function buildTimeoutRefundTx(\n   549→  connection: Connection,\n   550→  caller: PublicKey,\n   551→  matchPda: PublicKey,\n   552→  matchCreator: PublicKey,\n   553→  opponent: PublicKey,\n   554→  server: PublicKey,\n   555→): Promise<Transaction> {\n   556→  const program = getCoinflipProgram(connection);\n   557→\n   558→  const ix = await program.methods\n   559→    .timeoutRefund()\n   560→    .accountsStrict({\n   561→      caller,\n   562→      creator: matchCreator,\n   563→      opponent,\n   564→      server,\n   565→      coinflipMatch: matchPda,\n   566→    })\n   567→    .instruction();\n   568→\n   569→  const tx = new Transaction().add(ix);\n   570→  tx.feePayer = caller;\n   571→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   572→\n   573→  return tx;\n   574→}\n   575→\n   576→export async function buildSettleTx(\n   577→  connection: Connection,\n   578→  caller: PublicKey,\n   579→  matchPda: PublicKey,\n   580→  matchCreator: PublicKey,\n   581→  opponent: PublicKey,\n   582→  secret: Uint8Array,\n   583→  entropyPubkey: PublicKey,\n   584→): Promise<Transaction> {\n   585→  const program = getCoinflipProgram(connection);\n   586→  const [configPda] = getConfigPda();\n   587→\n   588→  // Fetch config to get treasury address\n   589→  const config = await program.account.coinflipConfig.fetch(configPda);\n   590→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   591→\n   592→  const ix = await program.methods\n   593→    .settle(Array.from(secret) as unknown as number[])\n   594→    .accountsStrict({\n   595→      caller,\n   596→      coinflipMatch: matchPda,\n   597→      config: configPda,\n   598→      slotHashes: entropyPubkey,\n   599→      treasury,\n   600→      creator: matchCreator,\n   601→      opponent,\n   602→      systemProgram: SystemProgram.programId,\n   603→    })\n   604→    .instruction();\n   605→\n   606→  const tx = new Transaction().add(ix);\n   607→  tx.feePayer = caller;\n   608→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   609→\n   610→  return tx;\n   611→}\n   612→\n   613→"}]},"parent_tool_use_id":"toolu_01MPoXotPwuktccSSbk63gaM","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"f7068c78-3ce9-4aa1-bd4d-c4fc93432c51"}
