{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CumcxmXm7ArxdX7GprLCPV","type":"tool_result","content":"     1→/**\n     2→ * Program IDL in camelCase format in order to be used in JS/TS.\n     3→ *\n     4→ * Note that this is only a type helper and is not the actual IDL. The original\n     5→ * IDL can be found at `target/idl/coinflip.json`.\n     6→ */\n     7→export type Coinflip = {\n     8→  \"address\": \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n     9→  \"metadata\": {\n    10→    \"name\": \"coinflip\",\n    11→    \"version\": \"0.1.0\",\n    12→    \"spec\": \"0.1.0\"\n    13→  },\n    14→  \"instructions\": [\n    15→    {\n    16→      \"name\": \"cancelMatch\",\n    17→      \"discriminator\": [\n    18→        142,\n    19→        136,\n    20→        247,\n    21→        45,\n    22→        92,\n    23→        112,\n    24→        180,\n    25→        83\n    26→      ],\n    27→      \"accounts\": [\n    28→        {\n    29→          \"name\": \"creator\",\n    30→          \"docs\": [\n    31→            \"The creator cancelling their match.\"\n    32→          ],\n    33→          \"writable\": true,\n    34→          \"signer\": true\n    35→        },\n    36→        {\n    37→          \"name\": \"coinflipMatch\",\n    38→          \"docs\": [\n    39→            \"The match PDA (closed on cancel).\"\n    40→          ],\n    41→          \"writable\": true\n    42→        },\n    43→        {\n    44→          \"name\": \"server\",\n    45→          \"docs\": [\n    46→            \"Server wallet that co-signed creation — receives rent refund on close.\"\n    47→          ],\n    48→          \"writable\": true\n    49→        },\n    50→        {\n    51→          \"name\": \"systemProgram\",\n    52→          \"address\": \"11111111111111111111111111111111\"\n    53→        }\n    54→      ],\n    55→      \"args\": []\n    56→    },\n    57→    {\n    58→      \"name\": \"createMatch\",\n    59→      \"discriminator\": [\n    60→        107,\n    61→        2,\n    62→        184,\n    63→        145,\n    64→        70,\n    65→        142,\n    66→        17,\n    67→        165\n    68→      ],\n    69→      \"accounts\": [\n    70→        {\n    71→          \"name\": \"creator\",\n    72→          \"docs\": [\n    73→            \"The player creating the match. Must sign and fund the escrow.\"\n    74→          ],\n    75→          \"writable\": true,\n    76→          \"signer\": true\n    77→        },\n    78→        {\n    79→          \"name\": \"server\",\n    80→          \"docs\": [\n    81→            \"The server that co-signs match creation and will later settle.\"\n    82→          ],\n    83→          \"signer\": true\n    84→        },\n    85→        {\n    86→          \"name\": \"coinflipMatch\",\n    87→          \"docs\": [\n    88→            \"The match PDA. Seeds include match_id for uniqueness across matches.\"\n    89→          ],\n    90→          \"writable\": true,\n    91→          \"pda\": {\n    92→            \"seeds\": [\n    93→              {\n    94→                \"kind\": \"const\",\n    95→                \"value\": [\n    96→                  109,\n    97→                  97,\n    98→                  116,\n    99→                  99,\n   100→                  104\n   101→                ]\n   102→              },\n   103→              {\n   104→                \"kind\": \"account\",\n   105→                \"path\": \"creator\"\n   106→              },\n   107→              {\n   108→                \"kind\": \"arg\",\n   109→                \"path\": \"matchId\"\n   110→              }\n   111→            ]\n   112→          }\n   113→        },\n   114→        {\n   115→          \"name\": \"config\",\n   116→          \"docs\": [\n   117→            \"The config PDA (read-only, for pause check).\"\n   118→          ],\n   119→          \"pda\": {\n   120→            \"seeds\": [\n   121→              {\n   122→                \"kind\": \"const\",\n   123→                \"value\": [\n   124→                  99,\n   125→                  111,\n   126→                  105,\n   127→                  110,\n   128→                  102,\n   129→                  108,\n   130→                  105,\n   131→                  112,\n   132→                  95,\n   133→                  99,\n   134→                  111,\n   135→                  110,\n   136→                  102,\n   137→                  105,\n   138→                  103\n   139→                ]\n   140→              }\n   141→            ]\n   142→          }\n   143→        },\n   144→        {\n   145→          \"name\": \"systemProgram\",\n   146→          \"address\": \"11111111111111111111111111111111\"\n   147→        }\n   148→      ],\n   149→      \"args\": [\n   150→        {"}]},"parent_tool_use_id":"toolu_01MPoXotPwuktccSSbk63gaM","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"4761c399-e5f6-426d-b51d-61eb9f0b5c49"}
