{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GerB4jaVeZxd1TTfj1LcvB","type":"tool_result","content":"   490→    })(),\n   491→    matchPda: new PublicKey(json.matchPda),\n   492→    commitment: json.commitment,\n   493→  };\n   494→}\n   495→\n   496→// ============ Instruction Builders ============\n   497→\n   498→export async function buildJoinMatchTx(\n   499→  connection: Connection,\n   500→  opponent: PublicKey,\n   501→  matchPda: PublicKey\n   502→): Promise<Transaction> {\n   503→  const program = getCoinflipProgram(connection);\n   504→  const [configPda] = getConfigPda();\n   505→\n   506→  const ix = await program.methods\n   507→    .joinMatch()\n   508→    .accountsStrict({\n   509→      opponent,\n   510→      coinflipMatch: matchPda,\n   511→      config: configPda,\n   512→      systemProgram: SystemProgram.programId,\n   513→    })\n   514→    .instruction();\n   515→\n   516→  const tx = new Transaction().add(ix);\n   517→  tx.feePayer = opponent;\n   518→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   519→\n   520→  return tx;\n   521→}\n   522→\n   523→export async function buildCancelMatchTx(\n   524→  connection: Connection,\n   525→  creator: PublicKey,\n   526→  matchPda: PublicKey,\n   527→  server: PublicKey,\n   528→): Promise<Transaction> {\n   529→  const program = getCoinflipProgram(connection);\n   530→\n   531→  const ix = await program.methods\n   532→    .cancelMatch()\n   533→    .accountsStrict({\n   534→      creator,\n   535→      coinflipMatch: matchPda,\n   536→      server,\n   537→      systemProgram: SystemProgram.programId,\n   538→    })\n   539→    .instruction();\n   540→\n   541→  const tx = new Transaction().add(ix);\n   542→  tx.feePayer = creator;\n   543→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   544→\n   545→  return tx;\n   546→}\n   547→\n   548→export async function buildTimeoutRefundTx(\n   549→  connection: Connection,\n   550→  caller: PublicKey,\n   551→  matchPda: PublicKey,\n   552→  matchCreator: PublicKey,\n   553→  opponent: PublicKey,\n   554→  server: PublicKey,\n   555→): Promise<Transaction> {\n   556→  const program = getCoinflipProgram(connection);\n   557→\n   558→  const ix = await program.methods\n   559→    .timeoutRefund()\n   560→    .accountsStrict({\n   561→      caller,\n   562→      creator: matchCreator,\n   563→      opponent,\n   564→      server,\n   565→      coinflipMatch: matchPda,\n   566→    })\n   567→    .instruction();\n   568→\n   569→  const tx = new Transaction().add(ix);\n   570→  tx.feePayer = caller;\n   571→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   572→\n   573→  return tx;\n   574→}\n   575→\n   576→export async function buildSettleTx(\n   577→  connection: Connection,\n   578→  caller: PublicKey,\n   579→  matchPda: PublicKey,\n   580→  matchCreator: PublicKey,\n   581→  opponent: PublicKey,\n   582→  secret: Uint8Array,\n   583→  entropyPubkey: PublicKey,\n   584→): Promise<Transaction> {\n   585→  const program = getCoinflipProgram(connection);\n   586→  const [configPda] = getConfigPda();\n   587→\n   588→  // Fetch config to get treasury address\n   589→  const config = await program.account.coinflipConfig.fetch(configPda);"}]},"parent_tool_use_id":null,"session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"6730317a-5018-4641-82b3-c717e3bfcb6e","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts","content":"    })(),\n    matchPda: new PublicKey(json.matchPda),\n    commitment: json.commitment,\n  };\n}\n\n// ============ Instruction Builders ============\n\nexport async function buildJoinMatchTx(\n  connection: Connection,\n  opponent: PublicKey,\n  matchPda: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [configPda] = getConfigPda();\n\n  const ix = await program.methods\n    .joinMatch()\n    .accountsStrict({\n      opponent,\n      coinflipMatch: matchPda,\n      config: configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = opponent;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildCancelMatchTx(\n  connection: Connection,\n  creator: PublicKey,\n  matchPda: PublicKey,\n  server: PublicKey,\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n\n  const ix = await program.methods\n    .cancelMatch()\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      server,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildTimeoutRefundTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchPda: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey,\n  server: PublicKey,\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n\n  const ix = await program.methods\n    .timeoutRefund()\n    .accountsStrict({\n      caller,\n      creator: matchCreator,\n      opponent,\n      server,\n      coinflipMatch: matchPda,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildSettleTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchPda: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey,\n  secret: Uint8Array,\n  entropyPubkey: PublicKey,\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get treasury address\n  const config = await program.account.coinflipConfig.fetch(configPda);","numLines":100,"startLine":490,"totalLines":613}}}
