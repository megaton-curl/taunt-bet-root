IDS,\n  getMatchPda,\n  getConfigPda,\n  getEntryAmount,\n  calculatePotentialPayout,\n  getOppositeSide,\n  determineWinnerFromRandomness,\n} from \"./coinflip\";\n\n// Close Call game client\nexport {\n  CLOSECALL_PROGRAM_ID,\n  getCloseCallRoundPda,\n  getCloseCallConfigPda,\n} from \"./closecall\";\n\n// Lord of the RNGs game client\nexport {\n  LORDOFRNGS_PROGRAM_ID,\n  getRoundPda,\n  getConfigPda as getLordConfigPda,\n  determineWinnerFromRandomness as determineLordWinnerFromRandomness,\n  mapOffsetToPlayer as mapSlotToPlayer,\n  mapOffsetToPlayer,\n  verifyLordRound,\n  calculateJackpotPayout,\n  type LordPlayerEntry,\n  type RoundSettledEvent,\n  type LordVerificationResult,\n} from \"./lordofrngs\";\n","numLines":81,"startLine":1,"totalLines":81}}}
