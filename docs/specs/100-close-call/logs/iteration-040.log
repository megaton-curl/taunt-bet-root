{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ho43K672x3SDU4UAT5inJH","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useEffect,\n     6→  useCallback,\n     7→  useMemo,\n     8→  useRef,\n     9→  type ReactNode,\n    10→} from \"react\";\n    11→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    12→import { usePriceSubscription } from \"@rng-utopia/price-feeds\";\n    13→import type {\n    14→  Round,\n    15→  BetSide,\n    16→  Candle,\n    17→  PlayerBet,\n    18→  UserRoundHistory,\n    19→  RoundPhase,\n    20→  CandleOutcome,\n    21→  CloseCallContextValue,\n    22→} from \"../types\";\n    23→import {\n    24→  DEFAULT_BET_AMOUNT,\n    25→  MIN_BET_AMOUNT,\n    26→  MAX_BET_AMOUNT,\n    27→  BETTING_WINDOW_MS,\n    28→} from \"../types\";\n    29→import { calculatePotentialPayout } from \"../utils/payout-calculator\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Backend API\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→const FAIRNESS_BACKEND_URL = (\n    36→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    37→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    38→).replace(/\\/$/, \"\");\n    39→\n    40→const ROUND_POLL_MS = 2000;\n    41→const LAMPORTS_PER_SOL = 1_000_000_000;\n    42→\n    43→interface BackendRoundResponse {\n    44→  roundId: string;\n    45→  pda: string;\n    46→  phase: string;\n    47→  openPrice: number;\n    48→  openPriceExpo: number;\n    49→  closePrice: number | null;\n    50→  outcome: string;\n    51→  greenPool: number;\n    52→  redPool: number;\n    53→  totalPool: number;\n    54→  totalFee: number;\n    55→  greenEntries: Array<{ player: string; amountLamports: number }>;\n    56→  redEntries: Array<{ player: string; amountLamports: number }>;\n    57→  greenCount: number;\n    58→  redCount: number;\n    59→  settleTx: string | null;\n    60→  createdAt: string;\n    61→  settledAt: string | null;\n    62→}\n    63→\n    64→function backendToRound(br: BackendRoundResponse): Round {\n    65→  const greenBets: PlayerBet[] = br.greenEntries.map((e) => ({\n    66→    address: e.player,\n    67→    side: \"green\" as const,\n    68→    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    69→    timestamp: new Date(br.createdAt).getTime(),\n    70→  }));\n    71→  const redBets: PlayerBet[] = br.redEntries.map((e) => ({\n    72→    address: e.player,\n    73→    side: \"red\" as const,\n    74→    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    75→    timestamp: new Date(br.createdAt).getTime(),\n    76→  }));\n    77→  const greenPool = greenBets.reduce((s, b) => s + b.amount, 0);\n    78→  const redPool = redBets.reduce((s, b) => s + b.amount, 0);\n    79→\n    80→  return {\n    81→    id: br.roundId,\n    82→    phase: br.phase as RoundPhase,\n    83→    pool: {\n    84→      greenPool,\n    85→      redPool,\n    86→      totalPool: greenPool + redPool,\n    87→      playerCount: greenBets.length + redBets.length,\n    88→      greenBets,\n    89→      redBets,\n    90→    },\n    91→    createdAt: new Date(br.createdAt).getTime(),\n    92→    bettingEndsAt: new Date(br.createdAt).getTime() + BETTING_WINDOW_MS,\n    93→    resolvedAt: br.settledAt ? new Date(br.settledAt).getTime() : undefined,\n    94→    targetCandleTime: new Date(br.createdAt).getTime(),\n    95→    outcome: br.outcome === \"pending\" ? undefined : (br.outcome as CandleOutcome),\n    96→    openPrice: br.openPrice,\n    97→    openPriceExpo: br.openPriceExpo,\n    98→    closePrice: br.closePrice ?? undefined,\n    99→    settleTx: br.settleTx ?? undefined,\n   100→  };\n   101→}\n   102→\n   103→async function fetchCurrentRound(): Promise<Round | null> {\n   104→  try {\n   105→    const res = await fetch(`${FAIRNESS_BACKEND_URL}/closecall/current-round`);\n   106→    if (!res.ok) return null;\n   107→    const data = (await res.json()) as { round: BackendRoundResponse | null };\n   108→    if (!data.round) return null;\n   109→    return backendToRound(data.round);\n   110→  } catch {\n   111→    return null;\n   112→  }\n   113→}\n   114→\n   115→async function fetchRoundHistory(limit = 20): Promise<Round[]> {\n   116→  try {\n   117→    const res = await fetch(\n   118→      `${FAIRNESS_BACKEND_URL}/closecall/history?limit=${limit}`,\n   119→    );\n   120→    if (!res.ok) return [];\n   121→    const data = (await res.json()) as { rounds: BackendRoundResponse[] };\n   122→    return data.rounds.map(backendToRound);\n   123→  } catch {\n   124→    return [];\n   125→  }\n   126→}\n   127→\n   128→// ---------------------------------------------------------------------------\n   129→// Local candle builder — accumulates 1-min OHLC from live Pyth price ticks\n   130→// ---------------------------------------------------------------------------\n   131→\n   132→function getMinuteBoundary(ts: number): number {\n   133→  return Math.floor(ts / 60_000) * 60_000;\n   134→}\n   135→\n   136→// ---------------------------------------------------------------------------\n   137→// Context\n   138→// ---------------------------------------------------------------------------\n   139→\n   140→const defaultContextValue: CloseCallContextValue = {\n   141→  currentRound: null,\n   142→  completedRound: null,\n   143→  recentCandles: [],\n   144→  currentPrice: 0,\n   145→  candleProgress: 0,\n   146→  userHistory: [],\n   147→  pendingAmount: DEFAULT_BET_AMOUNT,\n   148→  pendingSide: null,\n   149→  userBet: null,\n   150→  loading: true,\n   151→  placingBet: false,\n   152→  setPendingAmount: () => {},\n   153→  setPendingSide: () => {},\n   154→  placeBet: async () => {},\n   155→  adjustBetAmount: () => {},\n   156→  clearCompletedRound: () => {},\n   157→  potentialPayout: 0,\n   158→  userOdds: 0,\n   159→  refreshRound: () => {},\n   160→};\n   161→\n   162→const CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n   163→\n   164→export function CloseCallProvider({ children }: { children: ReactNode }) {\n   165→  const { address, getBalance } = useWallet();\n   166→\n   167→  // Live BTC price from Pyth via price-feeds package\n   168→  const btcPrice = usePriceSubscription(\"BTC\");\n   169→\n   170→  // Round state\n   171→  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n   172→  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n   173→  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n   174→  const [currentPrice, setCurrentPrice] = useState(0);\n   175→  const [candleProgress, setCandleProgress] = useState(0);\n   176→\n   177→  // User state\n   178→  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n   179→  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n   180→  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n   181→\n   182→  // Loading states\n   183→  const [loading, setLoading] = useState(true);\n   184→  const [placingBet, setPlacingBet] = useState(false);\n   185→\n   186→  // Candle builder refs\n   187→  const candlesRef = useRef<Candle[]>([]);\n   188→  const currentCandleRef = useRef<Candle | null>(null);\n   189→\n   190→  // Track previous round id to detect round transitions\n   191→  const prevRoundIdRef = useRef<string | null>(null);\n   192→\n   193→  // -----------------------------------------------------------------------\n   194→  // Update currentPrice from Pyth subscription\n   195→  // -----------------------------------------------------------------------\n   196→  useEffect(() => {\n   197→    if (btcPrice && btcPrice.price > 0) {\n   198→      setCurrentPrice(btcPrice.price);\n   199→    }\n   200→  }, [btcPrice]);\n   201→\n   202→  // -----------------------------------------------------------------------\n   203→  // Build local candles from live price ticks\n   204→  // -----------------------------------------------------------------------\n   205→  useEffect(() => {\n   206→    if (!btcPrice || btcPrice.price <= 0) return;\n   207→\n   208→    const price = btcPrice.price;\n   209→    const now = Date.now();\n   210→    const minuteStart = getMinuteBoundary(now);\n   211→\n   212→    const current = currentCandleRef.current;\n   213→    if (!current || current.openTime !== minuteStart) {\n   214→      // New minute boundary — close previous candle\n   215→      if (current) {\n   216→        candlesRef.current = [...candlesRef.current.slice(-14), current];\n   217→      }\n   218→      currentCandleRef.current = {\n   219→        open: price,\n   220→        high: price,\n   221→        low: price,\n   222→        close: price,\n   223→        openTime: minuteStart,\n   224→        closeTime: minuteStart + 60_000,\n   225→      };\n   226→    } else {\n   227→      // Update current candle tick\n   228→      currentCandleRef.current = {\n   229→        ...current,\n   230→        high: Math.max(current.high, price),\n   231→        low: Math.min(current.low, price),\n   232→        close: price,\n   233→      };\n   234→    }\n   235→\n   236→    // Push to state so chart re-renders\n   237→    const forming = currentCandleRef.current;\n   238→    setRecentCandles(forming ? [...candlesRef.current, forming] : candlesRef.current);\n   239→  }, [btcPrice]);\n   240→\n   241→  // -----------------------------------------------------------------------\n   242→  // Candle progress timer (100ms tick)\n   243→  // -----------------------------------------------------------------------\n   244→  useEffect(() => {\n   245→    const timer = setInterval(() => {\n   246→      const now = Date.now();\n   247→      const minuteStart = getMinuteBoundary(now);\n   248→      const progress = (now - minuteStart) / 60_000;\n   249→      setCandleProgress(Math.min(progress, 1));\n   250→    }, 100);\n   251→    return () => clearInterval(timer);\n   252→  }, []);\n   253→\n   254→  // -----------------------------------------------------------------------\n   255→  // Poll backend for current round (every 2s)\n   256→  // -----------------------------------------------------------------------\n   257→  useEffect(() => {\n   258→    let cancelled = false;\n   259→\n   260→    async function poll() {\n   261→      const round = await fetchCurrentRound();\n   262→      if (cancelled) return;\n   263→\n   264→      if (round) {\n   265→        // Detect round transition: previous round settled/refunded\n   266→        if (prevRoundIdRef.current && prevRoundIdRef.current !== round.id) {\n   267→          // Fetch the completed round from history for result overlay\n   268→          const history = await fetchRoundHistory(1);\n   269→          const prev = history[0];\n   270→          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n   271→            setCompletedRound(prev);\n   272→          }\n   273→        }\n   274→        prevRoundIdRef.current = round.id;\n   275→        setCurrentRound(round);\n   276→      } else {\n   277→        // No active round — check if previous round just settled\n   278→        if (prevRoundIdRef.current) {\n   279→          const history = await fetchRoundHistory(1);\n   280→          const prev = history[0];\n   281→          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n   282→            setCompletedRound(prev);\n   283→          }\n   284→          prevRoundIdRef.current = null;\n   285→        }\n   286→        setCurrentRound(null);\n   287→      }\n   288→      setLoading(false);\n   289→    }\n   290→\n   291→    // Initial fetch\n   292→    poll();\n   293→\n   294→    const interval = setInterval(poll, ROUND_POLL_MS);\n   295→    return () => {\n   296→      cancelled = true;\n   297→      clearInterval(interval);\n   298→    };\n   299→  }, []);\n   300→\n   301→  // -----------------------------------------------------------------------\n   302→  // Derive user bet from current round\n   303→  // -----------------------------------------------------------------------\n   304→  const userBet = useMemo(() => {\n   305→    if (!currentRound || !address) return null;\n   306→    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n   307→    return allBets.find((b) => b.address === address) ?? null;\n   308→  }, [currentRound, address]);\n   309→\n   310→  // -----------------------------------------------------------------------\n   311→  // Build user history from settled rounds\n   312→  // -----------------------------------------------------------------------\n   313→  useEffect(() => {\n   314→    if (!address) {\n   315→      setUserHistory([]);\n   316→      return;\n   317→    }\n   318→\n   319→    let cancelled = false;\n   320→\n   321→    async function loadHistory() {\n   322→      const rounds = await fetchRoundHistory(20);\n   323→      if (cancelled) return;\n   324→\n   325→      const history: UserRoundHistory[] = [];\n   326→      for (const round of rounds) {\n   327→        const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n   328→        const bet = allBets.find((b) => b.address === address);\n   329→        if (bet) {\n   330→          const won = round.outcome === bet.side;\n   331→          history.push({\n   332→            round,\n   333→            userBet: bet,\n   334→            payout: won ? calculatePotentialPayout(bet.amount, bet.side, round.pool) : 0,\n   335→            won,\n   336→          });\n   337→        }\n   338→      }\n   339→      setUserHistory(history);\n   340→    }\n   341→\n   342→    loadHistory();\n   343→\n   344→    return () => { cancelled = true; };\n   345→  }, [address, currentRound?.phase]);\n   346→\n   347→  // -----------------------------------------------------------------------\n   348→  // Potential payout\n   349→  // -----------------------------------------------------------------------\n   350→  const potentialPayout = useMemo(() => {\n   351→    if (!currentRound) return 0;\n   352→\n   353→    if (userBet) {\n   354→      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n   355→    }\n   356→\n   357→    if (!pendingSide || pendingAmount <= 0) return 0;\n   358→\n   359→    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n   360→  }, [pendingAmount, pendingSide, currentRound, userBet]);\n   361→\n   362→  // User odds (share of winning pool)\n   363→  const userOdds = useMemo(() => {\n   364→    if (!userBet || !currentRound) return 0;\n   365→    const winningPool =\n   366→      userBet.side === \"green\"\n   367→        ? currentRound.pool.greenPool\n   368→        : currentRound.pool.redPool;\n   369→    if (winningPool === 0) return 0;\n   370→    return (userBet.amount / winningPool) * 100;\n   371→  }, [userBet, currentRound]);\n   372→\n   373→  // -----------------------------------------------------------------------\n   374→  // Place bet — stub that does local validation only (wallet tx in next iteration)\n   375→  // -----------------------------------------------------------------------\n   376→  const placeBet = useCallback(\n   377→    async (sideOverride?: BetSide) => {\n   378→      if (!address) throw new Error(\"Wallet not connected\");\n   379→\n   380→      const side = sideOverride ?? pendingSide;\n   381→      if (!side) throw new Error(\"Select GREEN or RED\");\n   382→\n   383→      if (pendingAmount < MIN_BET_AMOUNT) {\n   384→        throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n   385→      }\n   386→      if (pendingAmount > MAX_BET_AMOUNT) {\n   387→        throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n   388→      }\n   389→\n   390→      const currentBalance = getBalance?.();\n   391→      if (currentBalance !== undefined && pendingAmount > currentBalance) {\n   392→        throw new Error(\"Insufficient balance\");\n   393→      }\n   394→\n   395→      setPlacingBet(true);\n   396→      try {\n   397→        // TODO: Build and send place_bet transaction via anchor-client (next iteration)\n   398→        await new Promise((resolve) => setTimeout(resolve, 500));\n   399→        setPendingSide(null);\n   400→      } finally {\n   401→        setPlacingBet(false);\n   402→      }\n   403→    },\n   404→    [address, pendingSide, pendingAmount, getBalance],\n   405→  );\n   406→\n   407→  // -----------------------------------------------------------------------\n   408→  // Adjust bet amount\n   409→  // -----------------------------------------------------------------------\n   410→  const adjustBetAmount = useCallback(\n   411→    (adjustment: \"half\" | \"double\" | \"max\") => {\n   412→      let newAmount: number;\n   413→      const currentBalance = getBalance?.();\n   414→\n   415→      switch (adjustment) {\n   416→        case \"half\":\n   417→          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n   418→          break;\n   419→        case \"double\":\n   420→          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n   421→          break;\n   422→        case \"max\":\n   423→          newAmount =\n   424→            currentBalance !== undefined\n   425→              ? Math.min(currentBalance, MAX_BET_AMOUNT)\n   426→              : MAX_BET_AMOUNT;\n   427→          break;\n   428→      }\n   429→\n   430→      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n   431→    },\n   432→    [pendingAmount, getBalance],\n   433→  );\n   434→\n   435→  // -----------------------------------------------------------------------\n   436→  // Refresh round data on demand\n   437→  // -----------------------------------------------------------------------\n   438→  const refreshRound = useCallback(() => {\n   439→    fetchCurrentRound().then((round) => {\n   440→      if (round) setCurrentRound(round);\n   441→    });\n   442→  }, []);\n   443→\n   444→  // Clear completed round (after user dismisses result overlay)\n   445→  const clearCompletedRound = useCallback(() => {\n   446→    setCompletedRound(null);\n   447→  }, []);\n   448→\n   449→  const contextValue: CloseCallContextValue = {\n   450→    currentRound,\n   451→    completedRound,\n   452→    recentCandles,\n   453→    currentPrice,\n   454→    candleProgress,\n   455→    userHistory,\n   456→    pendingAmount,\n   457→    pendingSide,\n   458→    userBet,\n   459→    loading,\n   460→    placingBet,\n   461→    setPendingAmount,\n   462→    setPendingSide,\n   463→    placeBet,\n   464→    adjustBetAmount,\n   465→    clearCompletedRound,\n   466→    potentialPayout,\n   467→    userOdds,\n   468→    refreshRound,\n   469→  };\n   470→\n   471→  return (\n   472→    <CloseCallContext.Provider value={contextValue}>\n   473→      {children}\n   474→    </CloseCallContext.Provider>\n   475→  );\n   476→}\n   477→\n   478→export function useCloseCall(): CloseCallContextValue {\n   479→  const context = useContext(CloseCallContext);\n   480→  if (!context) {\n   481→    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n   482→  }\n   483→  return context;\n   484→}\n   485→"}]},"parent_tool_use_id":null,"session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"66c8300a-3cd6-4999-8713-c3bb754b7050","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  useMemo,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { usePriceSubscription } from \"@rng-utopia/price-feeds\";\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  PlayerBet,\n  UserRoundHistory,\n  RoundPhase,\n  CandleOutcome,\n  CloseCallContextValue,\n} from \"../types\";\nimport {\n  DEFAULT_BET_AMOUNT,\n  MIN_BET_AMOUNT,\n  MAX_BET_AMOUNT,\n  BETTING_WINDOW_MS,\n} from \"../types\";\nimport { calculatePotentialPayout } from \"../utils/payout-calculator\";\n\n// ---------------------------------------------------------------------------\n// Backend API\n// ---------------------------------------------------------------------------\n\nconst FAIRNESS_BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\nconst ROUND_POLL_MS = 2000;\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\ninterface BackendRoundResponse {\n  roundId: string;\n  pda: string;\n  phase: string;\n  openPrice: number;\n  openPriceExpo: number;\n  closePrice: number | null;\n  outcome: string;\n  greenPool: number;\n  redPool: number;\n  totalPool: number;\n  totalFee: number;\n  greenEntries: Array<{ player: string; amountLamports: number }>;\n  redEntries: Array<{ player: string; amountLamports: number }>;\n  greenCount: number;\n  redCount: number;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n}\n\nfunction backendToRound(br: BackendRoundResponse): Round {\n  const greenBets: PlayerBet[] = br.greenEntries.map((e) => ({\n    address: e.player,\n    side: \"green\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const redBets: PlayerBet[] = br.redEntries.map((e) => ({\n    address: e.player,\n    side: \"red\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const greenPool = greenBets.reduce((s, b) => s + b.amount, 0);\n  const redPool = redBets.reduce((s, b) => s + b.amount, 0);\n\n  return {\n    id: br.roundId,\n    phase: br.phase as RoundPhase,\n    pool: {\n      greenPool,\n      redPool,\n      totalPool: greenPool + redPool,\n      playerCount: greenBets.length + redBets.length,\n      greenBets,\n      redBets,\n    },\n    createdAt: new Date(br.createdAt).getTime(),\n    bettingEndsAt: new Date(br.createdAt).getTime() + BETTING_WINDOW_MS,\n    resolvedAt: br.settledAt ? new Date(br.settledAt).getTime() : undefined,\n    targetCandleTime: new Date(br.createdAt).getTime(),\n    outcome: br.outcome === \"pending\" ? undefined : (br.outcome as CandleOutcome),\n    openPrice: br.openPrice,\n    openPriceExpo: br.openPriceExpo,\n    closePrice: br.closePrice ?? undefined,\n    settleTx: br.settleTx ?? undefined,\n  };\n}\n\nasync function fetchCurrentRound(): Promise<Round | null> {\n  try {\n    const res = await fetch(`${FAIRNESS_BACKEND_URL}/closecall/current-round`);\n    if (!res.ok) return null;\n    const data = (await res.json()) as { round: BackendRoundResponse | null };\n    if (!data.round) return null;\n    return backendToRound(data.round);\n  } catch {\n    return null;\n  }\n}\n\nasync function fetchRoundHistory(limit = 20): Promise<Round[]> {\n  try {\n    const res = await fetch(\n      `${FAIRNESS_BACKEND_URL}/closecall/history?limit=${limit}`,\n    );\n    if (!res.ok) return [];\n    const data = (await res.json()) as { rounds: BackendRoundResponse[] };\n    return data.rounds.map(backendToRound);\n  } catch {\n    return [];\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Local candle builder — accumulates 1-min OHLC from live Pyth price ticks\n// ---------------------------------------------------------------------------\n\nfunction getMinuteBoundary(ts: number): number {\n  return Math.floor(ts / 60_000) * 60_000;\n}\n\n// ---------------------------------------------------------------------------\n// Context\n// ---------------------------------------------------------------------------\n\nconst defaultContextValue: CloseCallContextValue = {\n  currentRound: null,\n  completedRound: null,\n  recentCandles: [],\n  currentPrice: 0,\n  candleProgress: 0,\n  userHistory: [],\n  pendingAmount: DEFAULT_BET_AMOUNT,\n  pendingSide: null,\n  userBet: null,\n  loading: true,\n  placingBet: false,\n  setPendingAmount: () => {},\n  setPendingSide: () => {},\n  placeBet: async () => {},\n  adjustBetAmount: () => {},\n  clearCompletedRound: () => {},\n  potentialPayout: 0,\n  userOdds: 0,\n  refreshRound: () => {},\n};\n\nconst CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n\nexport function CloseCallProvider({ children }: { children: ReactNode }) {\n  const { address, getBalance } = useWallet();\n\n  // Live BTC price from Pyth via price-feeds package\n  const btcPrice = usePriceSubscription(\"BTC\");\n\n  // Round state\n  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n  const [currentPrice, setCurrentPrice] = useState(0);\n  const [candleProgress, setCandleProgress] = useState(0);\n\n  // User state\n  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [placingBet, setPlacingBet] = useState(false);\n\n  // Candle builder refs\n  const candlesRef = useRef<Candle[]>([]);\n  const currentCandleRef = useRef<Candle | null>(null);\n\n  // Track previous round id to detect round transitions\n  const prevRoundIdRef = useRef<string | null>(null);\n\n  // -----------------------------------------------------------------------\n  // Update currentPrice from Pyth subscription\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (btcPrice && btcPrice.price > 0) {\n      setCurrentPrice(btcPrice.price);\n    }\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Build local candles from live price ticks\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!btcPrice || btcPrice.price <= 0) return;\n\n    const price = btcPrice.price;\n    const now = Date.now();\n    const minuteStart = getMinuteBoundary(now);\n\n    const current = currentCandleRef.current;\n    if (!current || current.openTime !== minuteStart) {\n      // New minute boundary — close previous candle\n      if (current) {\n        candlesRef.current = [...candlesRef.current.slice(-14), current];\n      }\n      currentCandleRef.current = {\n        open: price,\n        high: price,\n        low: price,\n        close: price,\n        openTime: minuteStart,\n        closeTime: minuteStart + 60_000,\n      };\n    } else {\n      // Update current candle tick\n      currentCandleRef.current = {\n        ...current,\n        high: Math.max(current.high, price),\n        low: Math.min(current.low, price),\n        close: price,\n      };\n    }\n\n    // Push to state so chart re-renders\n    const forming = currentCandleRef.current;\n    setRecentCandles(forming ? [...candlesRef.current, forming] : candlesRef.current);\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Candle progress timer (100ms tick)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    const timer = setInterval(() => {\n      const now = Date.now();\n      const minuteStart = getMinuteBoundary(now);\n      const progress = (now - minuteStart) / 60_000;\n      setCandleProgress(Math.min(progress, 1));\n    }, 100);\n    return () => clearInterval(timer);\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Poll backend for current round (every 2s)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    let cancelled = false;\n\n    async function poll() {\n      const round = await fetchCurrentRound();\n      if (cancelled) return;\n\n      if (round) {\n        // Detect round transition: previous round settled/refunded\n        if (prevRoundIdRef.current && prevRoundIdRef.current !== round.id) {\n          // Fetch the completed round from history for result overlay\n          const history = await fetchRoundHistory(1);\n          const prev = history[0];\n          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n            setCompletedRound(prev);\n          }\n        }\n        prevRoundIdRef.current = round.id;\n        setCurrentRound(round);\n      } else {\n        // No active round — check if previous round just settled\n        if (prevRoundIdRef.current) {\n          const history = await fetchRoundHistory(1);\n          const prev = history[0];\n          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n            setCompletedRound(prev);\n          }\n          prevRoundIdRef.current = null;\n        }\n        setCurrentRound(null);\n      }\n      setLoading(false);\n    }\n\n    // Initial fetch\n    poll();\n\n    const interval = setInterval(poll, ROUND_POLL_MS);\n    return () => {\n      cancelled = true;\n      clearInterval(interval);\n    };\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Derive user bet from current round\n  // -----------------------------------------------------------------------\n  const userBet = useMemo(() => {\n    if (!currentRound || !address) return null;\n    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    return allBets.find((b) => b.address === address) ?? null;\n  }, [currentRound, address]);\n\n  // -----------------------------------------------------------------------\n  // Build user history from settled rounds\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!address) {\n      setUserHistory([]);\n      return;\n    }\n\n    let cancelled = false;\n\n    async function loadHistory() {\n      const rounds = await fetchRoundHistory(20);\n      if (cancelled) return;\n\n      const history: UserRoundHistory[] = [];\n      for (const round of rounds) {\n        const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n        const bet = allBets.find((b) => b.address === address);\n        if (bet) {\n          const won = round.outcome === bet.side;\n          history.push({\n            round,\n            userBet: bet,\n            payout: won ? calculatePotentialPayout(bet.amount, bet.side, round.pool) : 0,\n            won,\n          });\n        }\n      }\n      setUserHistory(history);\n    }\n\n    loadHistory();\n\n    return () => { cancelled = true; };\n  }, [address, currentRound?.phase]);\n\n  // -----------------------------------------------------------------------\n  // Potential payout\n  // -----------------------------------------------------------------------\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    if (userBet) {\n      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n    }\n\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // User odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n    if (winningPool === 0) return 0;\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // -----------------------------------------------------------------------\n  // Place bet — stub that does local validation only (wallet tx in next iteration)\n  // -----------------------------------------------------------------------\n  const placeBet = useCallback(\n    async (sideOverride?: BetSide) => {\n      if (!address) throw new Error(\"Wallet not connected\");\n\n      const side = sideOverride ?? pendingSide;\n      if (!side) throw new Error(\"Select GREEN or RED\");\n\n      if (pendingAmount < MIN_BET_AMOUNT) {\n        throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n      }\n      if (pendingAmount > MAX_BET_AMOUNT) {\n        throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n      }\n\n      const currentBalance = getBalance?.();\n      if (currentBalance !== undefined && pendingAmount > currentBalance) {\n        throw new Error(\"Insufficient balance\");\n      }\n\n      setPlacingBet(true);\n      try {\n        // TODO: Build and send place_bet transaction via anchor-client (next iteration)\n        await new Promise((resolve) => setTimeout(resolve, 500));\n        setPendingSide(null);\n      } finally {\n        setPlacingBet(false);\n      }\n    },\n    [address, pendingSide, pendingAmount, getBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Adjust bet amount\n  // -----------------------------------------------------------------------\n  const adjustBetAmount = useCallback(\n    (adjustment: \"half\" | \"double\" | \"max\") => {\n      let newAmount: number;\n      const currentBalance = getBalance?.();\n\n      switch (adjustment) {\n        case \"half\":\n          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n          break;\n        case \"double\":\n          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n          break;\n        case \"max\":\n          newAmount =\n            currentBalance !== undefined\n              ? Math.min(currentBalance, MAX_BET_AMOUNT)\n              : MAX_BET_AMOUNT;\n          break;\n      }\n\n      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n    },\n    [pendingAmount, getBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Refresh round data on demand\n  // -----------------------------------------------------------------------\n  const refreshRound = useCallback(() => {\n    fetchCurrentRound().then((round) => {\n      if (round) setCurrentRound(round);\n    });\n  }, []);\n\n  // Clear completed round (after user dismisses result overlay)\n  const clearCompletedRound = useCallback(() => {\n    setCompletedRound(null);\n  }, []);\n\n  const contextValue: CloseCallContextValue = {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    clearCompletedRound,\n    potentialPayout,\n    userOdds,\n    refreshRound,\n  };\n\n  return (\n    <CloseCallContext.Provider value={contextValue}>\n      {children}\n    </CloseCallContext.Provider>\n  );\n}\n\nexport function useCloseCall(): CloseCallContextValue {\n  const context = useContext(CloseCallContext);\n  if (!context) {\n    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n  }\n  return context;\n}\n","numLines":485,"startLine":1,"totalLines":485}}}
