{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K68UnuZC7xFNjmEs4UBb7t","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useEffect,\n     6→  useCallback,\n     7→  useMemo,\n     8→  useRef,\n     9→  type ReactNode,\n    10→} from \"react\";\n    11→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    12→import { usePriceSubscription } from \"@rng-utopia/price-feeds\";\n    13→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n    14→import {\n    15→  PublicKey,\n    16→  SystemProgram,\n    17→  Transaction,\n    18→  type Connection,\n    19→} from \"@solana/web3.js\";\n    20→import { ClosecallIDL, type Closecall } from \"@rng-utopia/anchor-client\";\n    21→import {\n    22→  getCloseCallConfigPda,\n    23→  getCloseCallRoundPda,\n    24→} from \"@rng-utopia/game-engine\";\n    25→import type {\n    26→  Round,\n    27→  BetSide,\n    28→  Candle,\n    29→  PlayerBet,\n    30→  UserRoundHistory,\n    31→  RoundPhase,\n    32→  CandleOutcome,\n    33→  CloseCallContextValue,\n    34→} from \"../types\";\n    35→import {\n    36→  DEFAULT_BET_AMOUNT,\n    37→  MIN_BET_AMOUNT,\n    38→  MAX_BET_AMOUNT,\n    39→  BETTING_WINDOW_MS,\n    40→} from \"../types\";\n    41→import { calculatePotentialPayout } from \"../utils/payout-calculator\";\n    42→\n    43→// ---------------------------------------------------------------------------\n    44→// Backend API\n    45→// ---------------------------------------------------------------------------\n    46→\n    47→const FAIRNESS_BACKEND_URL = (\n    48→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    49→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    50→).replace(/\\/$/, \"\");\n    51→\n    52→const ROUND_POLL_MS = 2000;\n    53→const LAMPORTS_PER_SOL = 1_000_000_000;\n    54→\n    55→interface BackendRoundResponse {\n    56→  roundId: string;\n    57→  pda: string;\n    58→  phase: string;\n    59→  openPrice: number;\n    60→  openPriceExpo: number;\n    61→  closePrice: number | null;\n    62→  outcome: string;\n    63→  greenPool: number;\n    64→  redPool: number;\n    65→  totalPool: number;\n    66→  totalFee: number;\n    67→  greenEntries: Array<{ player: string; amountLamports: number }>;\n    68→  redEntries: Array<{ player: string; amountLamports: number }>;\n    69→  greenCount: number;\n    70→  redCount: number;\n    71→  settleTx: string | null;\n    72→  createdAt: string;\n    73→  settledAt: string | null;\n    74→}\n    75→\n    76→function backendToRound(br: BackendRoundResponse): Round {\n    77→  const greenBets: PlayerBet[] = br.greenEntries.map((e) => ({\n    78→    address: e.player,\n    79→    side: \"green\" as const,\n    80→    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    81→    timestamp: new Date(br.createdAt).getTime(),\n    82→  }));\n    83→  const redBets: PlayerBet[] = br.redEntries.map((e) => ({\n    84→    address: e.player,\n    85→    side: \"red\" as const,\n    86→    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    87→    timestamp: new Date(br.createdAt).getTime(),\n    88→  }));\n    89→  const greenPool = greenBets.reduce((s, b) => s + b.amount, 0);\n    90→  const redPool = redBets.reduce((s, b) => s + b.amount, 0);\n    91→\n    92→  return {\n    93→    id: br.roundId,\n    94→    phase: br.phase as RoundPhase,\n    95→    pool: {\n    96→      greenPool,\n    97→      redPool,\n    98→      totalPool: greenPool + redPool,\n    99→      playerCount: greenBets.length + redBets.length,\n   100→      greenBets,\n   101→      redBets,\n   102→    },\n   103→    createdAt: new Date(br.createdAt).getTime(),\n   104→    bettingEndsAt: new Date(br.createdAt).getTime() + BETTING_WINDOW_MS,\n   105→    resolvedAt: br.settledAt ? new Date(br.settledAt).getTime() : undefined,\n   106→    targetCandleTime: new Date(br.createdAt).getTime(),\n   107→    outcome: br.outcome === \"pending\" ? undefined : (br.outcome as CandleOutcome),\n   108→    openPrice: br.openPrice,\n   109→    openPriceExpo: br.openPriceExpo,\n   110→    closePrice: br.closePrice ?? undefined,\n   111→    settleTx: br.settleTx ?? undefined,\n   112→  };\n   113→}\n   114→\n   115→async function fetchCurrentRound(): Promise<Round | null> {\n   116→  try {\n   117→    const res = await fetch(`${FAIRNESS_BACKEND_URL}/closecall/current-round`);\n   118→    if (!res.ok) return null;\n   119→    const data = (await res.json()) as { round: BackendRoundResponse | null };\n   120→    if (!data.round) return null;\n   121→    return backendToRound(data.round);\n   122→  } catch {\n   123→    return null;\n   124→  }\n   125→}\n   126→\n   127→async function fetchRoundHistory(limit = 20): Promise<Round[]> {\n   128→  try {\n   129→    const res = await fetch(\n   130→      `${FAIRNESS_BACKEND_URL}/closecall/history?limit=${limit}`,\n   131→    );\n   132→    if (!res.ok) return [];\n   133→    const data = (await res.json()) as { rounds: BackendRoundResponse[] };\n   134→    return data.rounds.map(backendToRound);\n   135→  } catch {\n   136→    return [];\n   137→  }\n   138→}\n   139→\n   140→// ---------------------------------------------------------------------------\n   141→// Local candle builder — accumulates 1-min OHLC from live Pyth price ticks\n   142→// ---------------------------------------------------------------------------\n   143→\n   144→function getMinuteBoundary(ts: number): number {\n   145→  return Math.floor(ts / 60_000) * 60_000;\n   146→}\n   147→\n   148→// ---------------------------------------------------------------------------\n   149→// Context\n   150→// ---------------------------------------------------------------------------\n   151→\n   152→const defaultContextValue: CloseCallContextValue = {\n   153→  currentRound: null,\n   154→  completedRound: null,\n   155→  recentCandles: [],\n   156→  currentPrice: 0,\n   157→  candleProgress: 0,\n   158→  userHistory: [],\n   159→  pendingAmount: DEFAULT_BET_AMOUNT,\n   160→  pendingSide: null,\n   161→  userBet: null,\n   162→  loading: true,\n   163→  placingBet: false,\n   164→  setPendingAmount: () => {},\n   165→  setPendingSide: () => {},\n   166→  placeBet: async () => {},\n   167→  adjustBetAmount: () => {},\n   168→  clearCompletedRound: () => {},\n   169→  potentialPayout: 0,\n   170→  userOdds: 0,\n   171→  refreshRound: () => {},\n   172→};\n   173→\n   174→const CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n   175→\n   176→export function CloseCallProvider({ children }: { children: ReactNode }) {\n   177→  const { address, getBalance } = useWallet();\n   178→\n   179→  // Live BTC price from Pyth via price-feeds package\n   180→  const btcPrice = usePriceSubscription(\"BTC\");\n   181→\n   182→  // Round state\n   183→  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n   184→  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n   185→  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n   186→  const [currentPrice, setCurrentPrice] = useState(0);\n   187→  const [candleProgress, setCandleProgress] = useState(0);\n   188→\n   189→  // User state\n   190→  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n   191→  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n   192→  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n   193→\n   194→  // Loading states\n   195→  const [loading, setLoading] = useState(true);\n   196→  const [placingBet, setPlacingBet] = useState(false);\n   197→\n   198→  // Candle builder refs\n   199→  const candlesRef = useRef<Candle[]>([]);\n   200→  const currentCandleRef = useRef<Candle | null>(null);\n   201→\n   202→  // Track previous round id to detect round transitions\n   203→  const prevRoundIdRef = useRef<string | null>(null);\n   204→\n   205→  // -----------------------------------------------------------------------\n   206→  // Update currentPrice from Pyth subscription\n   207→  // -----------------------------------------------------------------------\n   208→  useEffect(() => {\n   209→    if (btcPrice && btcPrice.price > 0) {\n   210→      setCurrentPrice(btcPrice.price);\n   211→    }\n   212→  }, [btcPrice]);\n   213→\n   214→  // -----------------------------------------------------------------------\n   215→  // Build local candles from live price ticks\n   216→  // -----------------------------------------------------------------------\n   217→  useEffect(() => {\n   218→    if (!btcPrice || btcPrice.price <= 0) return;\n   219→\n   220→    const price = btcPrice.price;\n   221→    const now = Date.now();\n   222→    const minuteStart = getMinuteBoundary(now);\n   223→\n   224→    const current = currentCandleRef.current;\n   225→    if (!current || current.openTime !== minuteStart) {\n   226→      // New minute boundary — close previous candle\n   227→      if (current) {\n   228→        candlesRef.current = [...candlesRef.current.slice(-14), current];\n   229→      }\n   230→      currentCandleRef.current = {\n   231→        open: price,\n   232→        high: price,\n   233→        low: price,\n   234→        close: price,\n   235→        openTime: minuteStart,\n   236→        closeTime: minuteStart + 60_000,\n   237→      };\n   238→    } else {\n   239→      // Update current candle tick\n   240→      currentCandleRef.current = {\n   241→        ...current,\n   242→        high: Math.max(current.high, price),\n   243→        low: Math.min(current.low, price),\n   244→        close: price,\n   245→      };\n   246→    }\n   247→\n   248→    // Push to state so chart re-renders\n   249→    const forming = currentCandleRef.current;\n   250→    setRecentCandles(forming ? [...candlesRef.current, forming] : candlesRef.current);\n   251→  }, [btcPrice]);\n   252→\n   253→  // -----------------------------------------------------------------------\n   254→  // Candle progress timer (100ms tick)\n   255→  // -----------------------------------------------------------------------\n   256→  useEffect(() => {\n   257→    const timer = setInterval(() => {\n   258→      const now = Date.now();\n   259→      const minuteStart = getMinuteBoundary(now);\n   260→      const progress = (now - minuteStart) / 60_000;\n   261→      setCandleProgress(Math.min(progress, 1));\n   262→    }, 100);\n   263→    return () => clearInterval(timer);\n   264→  }, []);\n   265→\n   266→  // -----------------------------------------------------------------------\n   267→  // Poll backend for current round (every 2s)\n   268→  // -----------------------------------------------------------------------\n   269→  useEffect(() => {\n   270→    let cancelled = false;\n   271→\n   272→    async function poll() {\n   273→      const round = await fetchCurrentRound();\n   274→      if (cancelled) return;\n   275→\n   276→      if (round) {\n   277→        // Detect round transition: previous round settled/refunded\n   278→        if (prevRoundIdRef.current && prevRoundIdRef.current !== round.id) {\n   279→          // Fetch the completed round from history for result overlay\n   280→          const history = await fetchRoundHistory(1);\n   281→          const prev = history[0];\n   282→          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n   283→            setCompletedRound(prev);\n   284→          }\n   285→        }\n   286→        prevRoundIdRef.current = round.id;\n   287→        setCurrentRound(round);\n   288→      } else {\n   289→        // No active round — check if previous round just settled\n   290→        if (prevRoundIdRef.current) {\n   291→          const history = await fetchRoundHistory(1);\n   292→          const prev = history[0];\n   293→          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n   294→            setCompletedRound(prev);\n   295→          }\n   296→          prevRoundIdRef.current = null;\n   297→        }\n   298→        setCurrentRound(null);\n   299→      }\n   300→      setLoading(false);\n   301→    }\n   302→\n   303→    // Initial fetch\n   304→    poll();\n   305→\n   306→    const interval = setInterval(poll, ROUND_POLL_MS);\n   307→    return () => {\n   308→      cancelled = true;\n   309→      clearInterval(interval);\n   310→    };\n   311→  }, []);\n   312→\n   313→  // -----------------------------------------------------------------------\n   314→  // Derive user bet from current round\n   315→  // -----------------------------------------------------------------------\n   316→  const userBet = useMemo(() => {\n   317→    if (!currentRound || !address) return null;\n   318→    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n   319→    return allBets.find((b) => b.address === address) ?? null;\n   320→  }, [currentRound, address]);\n   321→\n   322→  // -----------------------------------------------------------------------\n   323→  // Build user history from settled rounds\n   324→  // -----------------------------------------------------------------------\n   325→  useEffect(() => {\n   326→    if (!address) {\n   327→      setUserHistory([]);\n   328→      return;\n   329→    }\n   330→\n   331→    let cancelled = false;\n   332→\n   333→    async function loadHistory() {\n   334→      const rounds = await fetchRoundHistory(20);\n   335→      if (cancelled) return;\n   336→\n   337→      const history: UserRoundHistory[] = [];\n   338→      for (const round of rounds) {\n   339→        const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n   340→        const bet = allBets.find((b) => b.address === address);\n   341→        if (bet) {\n   342→          const won = round.outcome === bet.side;\n   343→          history.push({\n   344→            round,\n   345→            userBet: bet,\n   346→            payout: won ? calculatePotentialPayout(bet.amount, bet.side, round.pool) : 0,\n   347→            won,\n   348→          });\n   349→        }\n   350→      }\n   351→      setUserHistory(history);\n   352→    }\n   353→\n   354→    loadHistory();\n   355→\n   356→    return () => { cancelled = true; };\n   357→  }, [address, currentRound?.phase]);\n   358→\n   359→  // -----------------------------------------------------------------------\n   360→  // Potential payout\n   361→  // -----------------------------------------------------------------------\n   362→  const potentialPayout = useMemo(() => {\n   363→    if (!currentRound) return 0;\n   364→\n   365→    if (userBet) {\n   366→      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n   367→    }\n   368→\n   369→    if (!pendingSide || pendingAmount <= 0) return 0;\n   370→\n   371→    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n   372→  }, [pendingAmount, pendingSide, currentRound, userBet]);\n   373→\n   374→  // User odds (share of winning pool)\n   375→  const userOdds = useMemo(() => {\n   376→    if (!userBet || !currentRound) return 0;\n   377→    const winningPool =\n   378→      userBet.side === \"green\"\n   379→        ? currentRound.pool.greenPool\n   380→        : currentRound.pool.redPool;\n   381→    if (winningPool === 0) return 0;\n   382→    return (userBet.amount / winningPool) * 100;\n   383→  }, [userBet, currentRound]);\n   384→\n   385→  // -----------------------------------------------------------------------\n   386→  // Place bet — stub that does local validation only (wallet tx in next iteration)\n   387→  // -----------------------------------------------------------------------\n   388→  const placeBet = useCallback(\n   389→    async (sideOverride?: BetSide) => {\n   390→      if (!address) throw new Error(\"Wallet not connected\");\n   391→\n   392→      const side = sideOverride ?? pendingSide;\n   393→      if (!side) throw new Error(\"Select GREEN or RED\");\n   394→\n   395→      if (pendingAmount < MIN_BET_AMOUNT) {\n   396→        throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n   397→      }\n   398→      if (pendingAmount > MAX_BET_AMOUNT) {\n   399→        throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n   400→      }\n   401→\n   402→      const currentBalance = getBalance?.();\n   403→      if (currentBalance !== undefined && pendingAmount > currentBalance) {\n   404→        throw new Error(\"Insufficient balance\");\n   405→      }\n   406→\n   407→      setPlacingBet(true);\n   408→      try {\n   409→        // TODO: Build and send place_bet transaction via anchor-client (next iteration)\n   410→        await new Promise((resolve) => setTimeout(resolve, 500));\n   411→        setPendingSide(null);\n   412→      } finally {\n   413→        setPlacingBet(false);\n   414→      }\n   415→    },\n   416→    [address, pendingSide, pendingAmount, getBalance],\n   417→  );\n   418→\n   419→  // -----------------------------------------------------------------------\n   420→  // Adjust bet amount\n   421→  // -----------------------------------------------------------------------\n   422→  const adjustBetAmount = useCallback(\n   423→    (adjustment: \"half\" | \"double\" | \"max\") => {\n   424→      let newAmount: number;\n   425→      const currentBalance = getBalance?.();\n   426→\n   427→      switch (adjustment) {\n   428→        case \"half\":\n   429→          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n   430→          break;\n   431→        case \"double\":\n   432→          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n   433→          break;\n   434→        case \"max\":\n   435→          newAmount =\n   436→            currentBalance !== undefined\n   437→              ? Math.min(currentBalance, MAX_BET_AMOUNT)\n   438→              : MAX_BET_AMOUNT;\n   439→          break;\n   440→      }\n   441→\n   442→      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n   443→    },\n   444→    [pendingAmount, getBalance],\n   445→  );\n   446→\n   447→  // -----------------------------------------------------------------------\n   448→  // Refresh round data on demand\n   449→  // -----------------------------------------------------------------------\n   450→  const refreshRound = useCallback(() => {\n   451→    fetchCurrentRound().then((round) => {\n   452→      if (round) setCurrentRound(round);\n   453→    });\n   454→  }, []);\n   455→\n   456→  // Clear completed round (after user dismisses result overlay)\n   457→  const clearCompletedRound = useCallback(() => {\n   458→    setCompletedRound(null);\n   459→  }, []);\n   460→\n   461→  const contextValue: CloseCallContextValue = {\n   462→    currentRound,\n   463→    completedRound,\n   464→    recentCandles,\n   465→    currentPrice,\n   466→    candleProgress,\n   467→    userHistory,\n   468→    pendingAmount,\n   469→    pendingSide,\n   470→    userBet,\n   471→    loading,\n   472→    placingBet,\n   473→    setPendingAmount,\n   474→    setPendingSide,\n   475→    placeBet,\n   476→    adjustBetAmount,\n   477→    clearCompletedRound,\n   478→    potentialPayout,\n   479→    userOdds,\n   480→    refreshRound,\n   481→  };\n   482→\n   483→  return (\n   484→    <CloseCallContext.Provider value={contextValue}>\n   485→      {children}\n   486→    </CloseCallContext.Provider>\n   487→  );\n   488→}\n   489→\n   490→export function useCloseCall(): CloseCallContextValue {\n   491→  const context = useContext(CloseCallContext);\n   492→  if (!context) {\n   493→    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n   494→  }\n   495→  return context;\n   496→}\n   497→"}]},"parent_tool_use_id":null,"session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"45879d54-c313-420c-9b9d-9d3b69623252","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  useMemo,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\nimport { usePriceSubscription } from \"@rng-utopia/price-feeds\";\nimport { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  type Connection,\n} from \"@solana/web3.js\";\nimport { ClosecallIDL, type Closecall } from \"@rng-utopia/anchor-client\";\nimport {\n  getCloseCallConfigPda,\n  getCloseCallRoundPda,\n} from \"@rng-utopia/game-engine\";\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  PlayerBet,\n  UserRoundHistory,\n  RoundPhase,\n  CandleOutcome,\n  CloseCallContextValue,\n} from \"../types\";\nimport {\n  DEFAULT_BET_AMOUNT,\n  MIN_BET_AMOUNT,\n  MAX_BET_AMOUNT,\n  BETTING_WINDOW_MS,\n} from \"../types\";\nimport { calculatePotentialPayout } from \"../utils/payout-calculator\";\n\n// ---------------------------------------------------------------------------\n// Backend API\n// ---------------------------------------------------------------------------\n\nconst FAIRNESS_BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\nconst ROUND_POLL_MS = 2000;\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\ninterface BackendRoundResponse {\n  roundId: string;\n  pda: string;\n  phase: string;\n  openPrice: number;\n  openPriceExpo: number;\n  closePrice: number | null;\n  outcome: string;\n  greenPool: number;\n  redPool: number;\n  totalPool: number;\n  totalFee: number;\n  greenEntries: Array<{ player: string; amountLamports: number }>;\n  redEntries: Array<{ player: string; amountLamports: number }>;\n  greenCount: number;\n  redCount: number;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n}\n\nfunction backendToRound(br: BackendRoundResponse): Round {\n  const greenBets: PlayerBet[] = br.greenEntries.map((e) => ({\n    address: e.player,\n    side: \"green\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const redBets: PlayerBet[] = br.redEntries.map((e) => ({\n    address: e.player,\n    side: \"red\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const greenPool = greenBets.reduce((s, b) => s + b.amount, 0);\n  const redPool = redBets.reduce((s, b) => s + b.amount, 0);\n\n  return {\n    id: br.roundId,\n    phase: br.phase as RoundPhase,\n    pool: {\n      greenPool,\n      redPool,\n      totalPool: greenPool + redPool,\n      playerCount: greenBets.length + redBets.length,\n      greenBets,\n      redBets,\n    },\n    createdAt: new Date(br.createdAt).getTime(),\n    bettingEndsAt: new Date(br.createdAt).getTime() + BETTING_WINDOW_MS,\n    resolvedAt: br.settledAt ? new Date(br.settledAt).getTime() : undefined,\n    targetCandleTime: new Date(br.createdAt).getTime(),\n    outcome: br.outcome === \"pending\" ? undefined : (br.outcome as CandleOutcome),\n    openPrice: br.openPrice,\n    openPriceExpo: br.openPriceExpo,\n    closePrice: br.closePrice ?? undefined,\n    settleTx: br.settleTx ?? undefined,\n  };\n}\n\nasync function fetchCurrentRound(): Promise<Round | null> {\n  try {\n    const res = await fetch(`${FAIRNESS_BACKEND_URL}/closecall/current-round`);\n    if (!res.ok) return null;\n    const data = (await res.json()) as { round: BackendRoundResponse | null };\n    if (!data.round) return null;\n    return backendToRound(data.round);\n  } catch {\n    return null;\n  }\n}\n\nasync function fetchRoundHistory(limit = 20): Promise<Round[]> {\n  try {\n    const res = await fetch(\n      `${FAIRNESS_BACKEND_URL}/closecall/history?limit=${limit}`,\n    );\n    if (!res.ok) return [];\n    const data = (await res.json()) as { rounds: BackendRoundResponse[] };\n    return data.rounds.map(backendToRound);\n  } catch {\n    return [];\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Local candle builder — accumulates 1-min OHLC from live Pyth price ticks\n// ---------------------------------------------------------------------------\n\nfunction getMinuteBoundary(ts: number): number {\n  return Math.floor(ts / 60_000) * 60_000;\n}\n\n// ---------------------------------------------------------------------------\n// Context\n// ---------------------------------------------------------------------------\n\nconst defaultContextValue: CloseCallContextValue = {\n  currentRound: null,\n  completedRound: null,\n  recentCandles: [],\n  currentPrice: 0,\n  candleProgress: 0,\n  userHistory: [],\n  pendingAmount: DEFAULT_BET_AMOUNT,\n  pendingSide: null,\n  userBet: null,\n  loading: true,\n  placingBet: false,\n  setPendingAmount: () => {},\n  setPendingSide: () => {},\n  placeBet: async () => {},\n  adjustBetAmount: () => {},\n  clearCompletedRound: () => {},\n  potentialPayout: 0,\n  userOdds: 0,\n  refreshRound: () => {},\n};\n\nconst CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n\nexport function CloseCallProvider({ children }: { children: ReactNode }) {\n  const { address, getBalance } = useWallet();\n\n  // Live BTC price from Pyth via price-feeds package\n  const btcPrice = usePriceSubscription(\"BTC\");\n\n  // Round state\n  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n  const [currentPrice, setCurrentPrice] = useState(0);\n  const [candleProgress, setCandleProgress] = useState(0);\n\n  // User state\n  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [placingBet, setPlacingBet] = useState(false);\n\n  // Candle builder refs\n  const candlesRef = useRef<Candle[]>([]);\n  const currentCandleRef = useRef<Candle | null>(null);\n\n  // Track previous round id to detect round transitions\n  const prevRoundIdRef = useRef<string | null>(null);\n\n  // -----------------------------------------------------------------------\n  // Update currentPrice from Pyth subscription\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (btcPrice && btcPrice.price > 0) {\n      setCurrentPrice(btcPrice.price);\n    }\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Build local candles from live price ticks\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!btcPrice || btcPrice.price <= 0) return;\n\n    const price = btcPrice.price;\n    const now = Date.now();\n    const minuteStart = getMinuteBoundary(now);\n\n    const current = currentCandleRef.current;\n    if (!current || current.openTime !== minuteStart) {\n      // New minute boundary — close previous candle\n      if (current) {\n        candlesRef.current = [...candlesRef.current.slice(-14), current];\n      }\n      currentCandleRef.current = {\n        open: price,\n        high: price,\n        low: price,\n        close: price,\n        openTime: minuteStart,\n        closeTime: minuteStart + 60_000,\n      };\n    } else {\n      // Update current candle tick\n      currentCandleRef.current = {\n        ...current,\n        high: Math.max(current.high, price),\n        low: Math.min(current.low, price),\n        close: price,\n      };\n    }\n\n    // Push to state so chart re-renders\n    const forming = currentCandleRef.current;\n    setRecentCandles(forming ? [...candlesRef.current, forming] : candlesRef.current);\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Candle progress timer (100ms tick)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    const timer = setInterval(() => {\n      const now = Date.now();\n      const minuteStart = getMinuteBoundary(now);\n      const progress = (now - minuteStart) / 60_000;\n      setCandleProgress(Math.min(progress, 1));\n    }, 100);\n    return () => clearInterval(timer);\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Poll backend for current round (every 2s)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    let cancelled = false;\n\n    async function poll() {\n      const round = await fetchCurrentRound();\n      if (cancelled) return;\n\n      if (round) {\n        // Detect round transition: previous round settled/refunded\n        if (prevRoundIdRef.current && prevRoundIdRef.current !== round.id) {\n          // Fetch the completed round from history for result overlay\n          const history = await fetchRoundHistory(1);\n          const prev = history[0];\n          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n            setCompletedRound(prev);\n          }\n        }\n        prevRoundIdRef.current = round.id;\n        setCurrentRound(round);\n      } else {\n        // No active round — check if previous round just settled\n        if (prevRoundIdRef.current) {\n          const history = await fetchRoundHistory(1);\n          const prev = history[0];\n          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n            setCompletedRound(prev);\n          }\n          prevRoundIdRef.current = null;\n        }\n        setCurrentRound(null);\n      }\n      setLoading(false);\n    }\n\n    // Initial fetch\n    poll();\n\n    const interval = setInterval(poll, ROUND_POLL_MS);\n    return () => {\n      cancelled = true;\n      clearInterval(interval);\n    };\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Derive user bet from current round\n  // -----------------------------------------------------------------------\n  const userBet = useMemo(() => {\n    if (!currentRound || !address) return null;\n    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    return allBets.find((b) => b.address === address) ?? null;\n  }, [currentRound, address]);\n\n  // -----------------------------------------------------------------------\n  // Build user history from settled rounds\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!address) {\n      setUserHistory([]);\n      return;\n    }\n\n    let cancelled = false;\n\n    async function loadHistory() {\n      const rounds = await fetchRoundHistory(20);\n      if (cancelled) return;\n\n      const history: UserRoundHistory[] = [];\n      for (const round of rounds) {\n        const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n        const bet = allBets.find((b) => b.address === address);\n        if (bet) {\n          const won = round.outcome === bet.side;\n          history.push({\n            round,\n            userBet: bet,\n            payout: won ? calculatePotentialPayout(bet.amount, bet.side, round.pool) : 0,\n            won,\n          });\n        }\n      }\n      setUserHistory(history);\n    }\n\n    loadHistory();\n\n    return () => { cancelled = true; };\n  }, [address, currentRound?.phase]);\n\n  // -----------------------------------------------------------------------\n  // Potential payout\n  // -----------------------------------------------------------------------\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    if (userBet) {\n      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n    }\n\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // User odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n    if (winningPool === 0) return 0;\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // -----------------------------------------------------------------------\n  // Place bet — stub that does local validation only (wallet tx in next iteration)\n  // -----------------------------------------------------------------------\n  const placeBet = useCallback(\n    async (sideOverride?: BetSide) => {\n      if (!address) throw new Error(\"Wallet not connected\");\n\n      const side = sideOverride ?? pendingSide;\n      if (!side) throw new Error(\"Select GREEN or RED\");\n\n      if (pendingAmount < MIN_BET_AMOUNT) {\n        throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n      }\n      if (pendingAmount > MAX_BET_AMOUNT) {\n        throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n      }\n\n      const currentBalance = getBalance?.();\n      if (currentBalance !== undefined && pendingAmount > currentBalance) {\n        throw new Error(\"Insufficient balance\");\n      }\n\n      setPlacingBet(true);\n      try {\n        // TODO: Build and send place_bet transaction via anchor-client (next iteration)\n        await new Promise((resolve) => setTimeout(resolve, 500));\n        setPendingSide(null);\n      } finally {\n        setPlacingBet(false);\n      }\n    },\n    [address, pendingSide, pendingAmount, getBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Adjust bet amount\n  // -----------------------------------------------------------------------\n  const adjustBetAmount = useCallback(\n    (adjustment: \"half\" | \"double\" | \"max\") => {\n      let newAmount: number;\n      const currentBalance = getBalance?.();\n\n      switch (adjustment) {\n        case \"half\":\n          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n          break;\n        case \"double\":\n          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n          break;\n        case \"max\":\n          newAmount =\n            currentBalance !== undefined\n              ? Math.min(currentBalance, MAX_BET_AMOUNT)\n              : MAX_BET_AMOUNT;\n          break;\n      }\n\n      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n    },\n    [pendingAmount, getBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Refresh round data on demand\n  // -----------------------------------------------------------------------\n  const refreshRound = useCallback(() => {\n    fetchCurrentRound().then((round) => {\n      if (round) setCurrentRound(round);\n    });\n  }, []);\n\n  // Clear completed round (after user dismisses result overlay)\n  const clearCompletedRound = useCallback(() => {\n    setCompletedRound(null);\n  }, []);\n\n  const contextValue: CloseCallContextValue = {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    clearCompletedRound,\n    potentialPayout,\n    userOdds,\n    refreshRound,\n  };\n\n  return (\n    <CloseCallContext.Provider value={contextValue}>\n      {children}\n    </CloseCallContext.Provider>\n  );\n}\n\nexport function useCloseCall(): CloseCallContextValue {\n  const context = useContext(CloseCallContext);\n  if (!context) {\n    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n  }\n  return context;\n}\n","numLines":497,"startLine":1,"totalLines":497}}}
