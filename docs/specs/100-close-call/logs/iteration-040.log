{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lk1QvvZa4St3TpmtUzTQf5","type":"tool_result","content":"     1→/**\n     2→ * Mock Simulation for Close Call\n     3→ *\n     4→ * Manages round lifecycle, betting, and settlement in mock mode.\n     5→ * Uses on-chain-aligned phases: open → settled/refunded\n     6→ */\n     7→\n     8→import type {\n     9→  Round,\n    10→  BetSide,\n    11→  Candle,\n    12→  PlayerBet,\n    13→  PoolState,\n    14→  UserRoundHistory,\n    15→} from \"../types\";\n    16→import { BETTING_WINDOW_MS, MIN_BET_AMOUNT, MAX_BET_AMOUNT } from \"../types\";\n    17→import { getReplayEngine, type CandleReplayEngine } from \"./candle-replay\";\n    18→import { calculatePayouts, determineOutcome } from \"./payout-calculator\";\n    19→import { emitCloseCallComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\n    20→import { emitCloseCallResults } from \"../../player-profile/utils/profile-event-bus\";\n    21→\n    22→// ============ Store ============\n    23→\n    24→interface MockStore {\n    25→  currentRound: Round | null;\n    26→  completedRound: Round | null; // Most recently completed round (for result display)\n    27→  roundHistory: Round[];\n    28→  userHistory: Map<string, UserRoundHistory[]>;\n    29→  listeners: Set<(round: Round) => void>;\n    30→  completedListeners: Set<(round: Round) => void>;\n    31→  replayEngine: CandleReplayEngine | null;\n    32→  mockBetTimers: ReturnType<typeof setTimeout>[];\n    33→  isInitialized: boolean;\n    34→}\n    35→\n    36→const store: MockStore = {\n    37→  currentRound: null,\n    38→  completedRound: null,\n    39→  roundHistory: [],\n    40→  userHistory: new Map(),\n    41→  listeners: new Set(),\n    42→  completedListeners: new Set(),\n    43→  replayEngine: null,\n    44→  mockBetTimers: [],\n    45→  isInitialized: false,\n    46→};\n    47→\n    48→// ============ Helpers ============\n    49→\n    50→function generateRoundId(): string {\n    51→  return `cc-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n    52→}\n    53→\n    54→// ============ Mock Address Generation ============\n    55→\n    56→const MOCK_ADDRESSES = [\n    57→  \"7xKQ...nM4p\", \"3vBr...8sYq\", \"9aZm...kL2x\", \"5hTn...jR7w\",\n    58→  \"2cVp...9fGd\", \"8kLm...4nHs\", \"1qWe...6bYt\", \"4rTy...0mXz\",\n    59→  \"6uIo...2pAw\", \"0oKj...5nBv\", \"Ax7K...mN3p\", \"Bv8L...nO4q\",\n    60→  \"Cw9M...oP5r\", \"Dx0N...pQ6s\", \"Ey1O...qR7t\", \"Fz2P...rS8u\",\n    61→];\n    62→\n    63→function generateMockAddress(): string {\n    64→  const index = Math.floor(Math.random() * MOCK_ADDRESSES.length);\n    65→  return MOCK_ADDRESSES[index]!;\n    66→}\n    67→\n    68→// ============ Round Management ============\n    69→\n    70→function createEmptyPool(): PoolState {\n    71→  return {\n    72→    greenPool: 0,\n    73→    redPool: 0,\n    74→    totalPool: 0,\n    75→    playerCount: 0,\n    76→    greenBets: [],\n    77→    redBets: [],\n    78→  };\n    79→}\n    80→\n    81→function createNewRound(targetCandleTime: number): Round {\n    82→  const roundId = generateRoundId();\n    83→\n    84→  const round: Round = {\n    85→    id: roundId,\n    86→    phase: \"open\",\n    87→    pool: createEmptyPool(),\n    88→    createdAt: Date.now(),\n    89→    bettingEndsAt: Date.now() + BETTING_WINDOW_MS,\n    90→    targetCandleTime,\n    91→  };\n    92→\n    93→  store.currentRound = round;\n    94→  notifyListeners(round);\n    95→\n    96→  // Schedule mock bets\n    97→  scheduleMockBets(round.id);\n    98→\n    99→  return round;\n   100→}\n   101→\n   102→function resolveRound(resultCandle: Candle): void {\n   103→  if (!store.currentRound) return;\n   104→  if (store.currentRound.phase !== \"open\") return;\n   105→\n   106→  const round = store.currentRound;\n   107→  round.resultCandle = resultCandle;\n   108→\n   109→  // Determine outcome\n   110→  const outcome = determineOutcome(resultCandle);\n   111→  round.outcome = outcome;\n   112→\n   113→  // Calculate payouts\n   114→  const payoutResult = calculatePayouts(round.pool, outcome);\n   115→  round.winners = Object.keys(payoutResult.payouts);\n   116→  round.payouts = payoutResult.payouts;\n   117→  round.payoutAmount = payoutResult.totalPayout;\n   118→\n   119→  // Set final phase\n   120→  round.phase = outcome === \"refund\" || payoutResult.totalPayout === 0 ? \"refunded\" : \"settled\";\n   121→  round.resolvedAt = Date.now();\n   122→\n   123→  // Store as completed round for result display\n   124→  store.completedRound = { ...round, pool: { ...round.pool } };\n   125→\n   126→  // Archive round\n   127→  store.roundHistory.unshift(round);\n   128→\n   129→  // Update user histories\n   130→  updateUserHistories(round);\n   131→\n   132→  // Notify completed round listeners\n   133→  notifyCompletedListeners(store.completedRound);\n   134→\n   135→  // Emit event for Boss Raid\n   136→  const allBets = [...round.pool.greenBets, ...round.pool.redBets].map((b) => ({\n   137→    address: b.address,\n   138→    amount: b.amount,\n   139→  }));\n   140→  if (allBets.length > 0) {\n   141→    emitCloseCallComplete(round.id, allBets);\n   142→  }\n   143→\n   144→  // Emit event for Player Profile (XP and stats tracking)\n   145→  const profileResults = [...round.pool.greenBets, ...round.pool.redBets].map((bet) => {\n   146→    const payout = round.payouts?.[bet.address] ?? 0;\n   147→    const won = payout > 0;\n   148→    return {\n   149→      address: bet.address,\n   150→      wager: bet.amount,\n   151→      outcome: (won ? \"win\" : \"loss\") as \"win\" | \"loss\",\n   152→      payout,\n   153→    };\n   154→  });\n   155→  if (profileResults.length > 0) {\n   156→    emitCloseCallResults(round.id, profileResults);\n   157→  }\n   158→}\n   159→\n   160→function updateUserHistories(round: Round): void {\n   161→  const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n   162→\n   163→  for (const bet of allBets) {\n   164→    const payout = round.payouts?.[bet.address] ?? 0;\n   165→    const won = payout > 0;\n   166→\n   167→    const historyEntry: UserRoundHistory = {\n   168→      round,\n   169→      userBet: bet,\n   170→      payout,\n   171→      won,\n   172→    };\n   173→\n   174→    const userHistory = store.userHistory.get(bet.address) ?? [];\n   175→    userHistory.unshift(historyEntry);\n   176→    store.userHistory.set(bet.address, userHistory);\n   177→  }\n   178→}\n   179→\n   180→// ============ Betting ============\n   181→\n   182→export function placeBet(playerAddress: string, side: BetSide, amount: number): Round {\n   183→  const round = store.currentRound;\n   184→\n   185→  if (!round) {\n   186→    throw new Error(\"No active round\");\n   187→  }\n   188→\n   189→  if (round.phase !== \"open\") {\n   190→    throw new Error(\"Betting is closed for this round\");\n   191→  }\n   192→\n   193→  // Check if betting window has closed\n   194→  if (Date.now() >= round.bettingEndsAt) {\n   195→    throw new Error(\"Betting window has closed\");\n   196→  }\n   197→\n   198→  if (amount < MIN_BET_AMOUNT) {\n   199→    throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n   200→  }\n   201→\n   202→  if (amount > MAX_BET_AMOUNT) {\n   203→    throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n   204→  }\n   205→\n   206→  // Check for existing bet\n   207→  const existingBet = [...round.pool.greenBets, ...round.pool.redBets].find(\n   208→    (b) => b.address === playerAddress\n   209→  );\n   210→\n   211→  if (existingBet) {\n   212→    throw new Error(\"You have already bet on this round\");\n   213→  }\n   214→\n   215→  // Create bet\n   216→  const bet: PlayerBet = {\n   217→    address: playerAddress,\n   218→    side,\n   219→    amount,\n   220→    timestamp: Date.now(),\n   221→  };\n   222→\n   223→  // Add to pool\n   224→  if (side === \"green\") {\n   225→    round.pool.greenBets.push(bet);\n   226→    round.pool.greenPool += amount;\n   227→  } else {\n   228→    round.pool.redBets.push(bet);\n   229→    round.pool.redPool += amount;\n   230→  }\n   231→\n   232→  round.pool.totalPool += amount;\n   233→  round.pool.playerCount++;\n   234→\n   235→  // Emit wager placed event (triggers RNG buff chest drop check)\n   236→  emitWagerPlaced(\"close-call\", round.id, playerAddress, amount);\n   237→\n   238→  notifyListeners(round);\n   239→  return round;\n   240→}\n   241→\n   242→// ============ Mock Bets ============\n   243→\n   244→function scheduleMockBets(roundId: string): void {\n   245→  clearMockBetTimers();\n   246→\n   247→  // Schedule 3-7 mock bets within the betting window\n   248→  const betCount = 3 + Math.floor(Math.random() * 5);\n   249→  const bettingDuration = BETTING_WINDOW_MS - 1000; // Leave 1s buffer\n   250→\n   251→  for (let i = 0; i < betCount; i++) {\n   252→    const delay = Math.random() * bettingDuration;\n   253→    const timer = setTimeout(() => {\n   254→      if (store.currentRound?.id !== roundId) return;\n   255→      if (store.currentRound?.phase !== \"open\") return;\n   256→      if (Date.now() >= (store.currentRound?.bettingEndsAt ?? 0)) return;\n   257→\n   258→      addMockBet();\n   259→    }, delay);\n   260→\n   261→    store.mockBetTimers.push(timer);\n   262→  }\n   263→}\n   264→\n   265→function addMockBet(): void {\n   266→  if (!store.currentRound || store.currentRound.phase !== \"open\") return;\n   267→  if (Date.now() >= store.currentRound.bettingEndsAt) return;\n   268→\n   269→  const address = generateMockAddress();\n   270→\n   271→  // Check if this mock address already bet\n   272→  const existingBet = [\n   273→    ...store.currentRound.pool.greenBets,\n   274→    ...store.currentRound.pool.redBets,\n   275→  ].find((b) => b.address === address);\n   276→\n   277→  if (existingBet) return;\n   278→\n   279→  // Random side (slightly biased toward current minority for balance)\n   280→  const greenRatio =\n   281→    store.currentRound.pool.totalPool > 0\n   282→      ? store.currentRound.pool.greenPool / store.currentRound.pool.totalPool\n   283→      : 0.5;\n   284→\n   285→  // Bias toward minority side for more balanced pools\n   286→  const greenProbability = greenRatio < 0.5 ? 0.6 : 0.4;\n   287→  const side: BetSide = Math.random() < greenProbability ? \"green\" : \"red\";\n   288→\n   289→  // Random amount (weighted toward smaller bets)\n   290→  const amount = Math.round((0.05 + Math.random() * Math.random() * 2) * 1000) / 1000;\n   291→\n   292→  try {\n   293→    placeBet(address, side, Math.max(MIN_BET_AMOUNT, amount));\n   294→  } catch {\n   295→    // Ignore bet errors for mock bets\n   296→  }\n   297→}\n   298→\n   299→function clearMockBetTimers(): void {\n   300→  for (const timer of store.mockBetTimers) {\n   301→    clearTimeout(timer);\n   302→  }\n   303→  store.mockBetTimers = [];\n   304→}\n   305→\n   306→// ============ Subscription ============\n   307→\n   308→function notifyListeners(round: Round): void {\n   309→  const roundCopy = { ...round, pool: { ...round.pool } };\n   310→  for (const listener of store.listeners) {\n   311→    try {\n   312→      listener(roundCopy);\n   313→    } catch (error) {\n   314→      console.error(\"Listener error:\", error);\n   315→    }\n   316→  }\n   317→}\n   318→\n   319→function notifyCompletedListeners(round: Round): void {\n   320→  const roundCopy = { ...round, pool: { ...round.pool } };\n   321→  for (const listener of store.completedListeners) {\n   322→    try {\n   323→      listener(roundCopy);\n   324→    } catch (error) {\n   325→      console.error(\"Completed listener error:\", error);\n   326→    }\n   327→  }\n   328→}\n   329→\n   330→export function subscribeToRound(callback: (round: Round) => void): () => void {\n   331→  store.listeners.add(callback);\n   332→\n   333→  // Immediately emit current round if exists\n   334→  if (store.currentRound) {\n   335→    callback({ ...store.currentRound, pool: { ...store.currentRound.pool } });\n   336→  }\n   337→\n   338→  return () => {\n   339→    store.listeners.delete(callback);\n   340→  };\n   341→}\n   342→\n   343→export function subscribeToCompletedRound(callback: (round: Round) => void): () => void {\n   344→  store.completedListeners.add(callback);\n   345→\n   346→  return () => {\n   347→    store.completedListeners.delete(callback);\n   348→  };\n   349→}\n   350→\n   351→// ============ Game Initialization ============\n   352→\n   353→export function initializeGame(): void {\n   354→  if (store.isInitialized) return;\n   355→\n   356→  store.replayEngine = getReplayEngine();\n   357→\n   358→  store.replayEngine.start({\n   359→    onCandleStart: (candle) => {\n   360→      // Create new round - users bet on THIS candle's outcome\n   361→      createNewRound(candle.openTime);\n   362→    },\n   363→\n   364→    onCandleComplete: (candle) => {\n   365→      // Resolve current round when candle closes\n   366→      if (store.currentRound?.phase === \"open\") {\n   367→        // Clear mock bet timers before resolve\n   368→        clearMockBetTimers();\n   369→        resolveRound(candle);\n   370→      }\n   371→    },\n   372→\n   373→    onPriceTick: () => {\n   374→      // No-op: betting window is enforced by time check in placeBet\n   375→    },\n   376→  });\n   377→\n   378→  store.isInitialized = true;\n   379→}\n   380→\n   381→export function stopGame(): void {\n   382→  if (store.replayEngine) {\n   383→    store.replayEngine.stop();\n   384→  }\n   385→  clearMockBetTimers();\n   386→  store.isInitialized = false;\n   387→}\n   388→\n   389→// ============ Getters ============\n   390→\n   391→export function getCurrentRound(): Round | null {\n   392→  return store.currentRound;\n   393→}\n   394→\n   395→export function getCompletedRound(): Round | null {\n   396→  return store.completedRound;\n   397→}\n   398→\n   399→export function clearCompletedRound(): void {\n   400→  store.completedRound = null;\n   401→}\n   402→\n   403→export function getRoundHistory(): Round[] {\n   404→  return store.roundHistory;\n   405→}\n   406→\n   407→export function getUserHistory(address: string): UserRoundHistory[] {\n   408→  return store.userHistory.get(address) ?? [];\n   409→}\n   410→\n   411→export function getRecentCandles(count: number = 15): Candle[] {\n   412→  if (!store.replayEngine) return [];\n   413→  return store.replayEngine.getCandlesUpToCurrent(count);\n   414→}\n   415→\n   416→export function getCurrentCandle(): Candle | null {\n   417→  if (!store.replayEngine) return null;\n   418→  return store.replayEngine.getCurrentCandle();\n   419→}\n   420→\n   421→export function getCandleProgress(): number {\n   422→  if (!store.replayEngine) return 0;\n   423→  return store.replayEngine.getProgress();\n   424→}\n   425→\n   426→export function getTimeRemaining(): number {\n   427→  if (!store.replayEngine) return 0;\n   428→  return store.replayEngine.getTimeRemaining();\n   429→}\n   430→\n   431→export function isGameInitialized(): boolean {\n   432→  return store.isInitialized;\n   433→}\n   434→\n   435→// ============ Utility ============\n   436→\n   437→export function truncateAddress(address: string): string {\n   438→  if (address.length <= 10) return address;\n   439→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n   440→}\n   441→"}]},"parent_tool_use_id":"toolu_01WW4EWX9A8Sn6WMA6YLDyWK","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"c6ea88ca-a9ac-49ea-9631-10d51db2a792"}
