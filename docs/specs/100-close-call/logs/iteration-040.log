{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_011fwsWV8c5xmdP2MihZgiJV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013dYVAGjNXeaZLsTLBpn4vt","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","old_string":"// ---------------------------------------------------------------------------\n// Anchor program + transaction builder\n// ---------------------------------------------------------------------------\n\nfunction getClosecallProgram(connection: Connection): Program<Closecall> {","new_string":"// ---------------------------------------------------------------------------\n// PDA derivation (local — game-engine uses Buffer which breaks browser build)\n// ---------------------------------------------------------------------------\n\nconst CLOSECALL_PROGRAM_ID = new PublicKey(ClosecallIDL.address);\n\nfunction getCloseCallConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"closecall_config\")],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\nfunction getCloseCallRoundPda(roundIdBytes: Uint8Array): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), Buffer.from(roundIdBytes)],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Anchor program + transaction builder\n// ---------------------------------------------------------------------------\n\nfunction getClosecallProgram(connection: Connection): Program<Closecall> {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":522,"cache_read_input_tokens":97157,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":522},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"dad08c3c-7248-433f-a337-fd82f62df649"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013dYVAGjNXeaZLsTLBpn4vt","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"e83071f8-a063-4465-8481-84466c331b4d","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","oldString":"// ---------------------------------------------------------------------------\n// Anchor program + transaction builder\n// ---------------------------------------------------------------------------\n\nfunction getClosecallProgram(connection: Connection): Program<Closecall> {","newString":"// ---------------------------------------------------------------------------\n// PDA derivation (local — game-engine uses Buffer which breaks browser build)\n// ---------------------------------------------------------------------------\n\nconst CLOSECALL_PROGRAM_ID = new PublicKey(ClosecallIDL.address);\n\nfunction getCloseCallConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"closecall_config\")],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\nfunction getCloseCallRoundPda(roundIdBytes: Uint8Array): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), Buffer.from(roundIdBytes)],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Anchor program + transaction builder\n// ---------------------------------------------------------------------------\n\nfunction getClosecallProgram(connection: Connection): Program<Closecall> {","originalFile":"import {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  useMemo,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\nimport { usePriceSubscription } from \"@rng-utopia/price-feeds\";\nimport { Program, AnchorProvider, BN, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  type Connection,\n} from \"@solana/web3.js\";\nimport { ClosecallIDL, type Closecall } from \"@rng-utopia/anchor-client\";\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  PlayerBet,\n  UserRoundHistory,\n  RoundPhase,\n  CandleOutcome,\n  CloseCallContextValue,\n} from \"../types\";\nimport {\n  DEFAULT_BET_AMOUNT,\n  MIN_BET_AMOUNT,\n  MAX_BET_AMOUNT,\n  BETTING_WINDOW_MS,\n} from \"../types\";\nimport { calculatePotentialPayout } from \"../utils/payout-calculator\";\n\n// ---------------------------------------------------------------------------\n// Backend API\n// ---------------------------------------------------------------------------\n\nconst FAIRNESS_BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\nconst ROUND_POLL_MS = 2000;\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\ninterface BackendRoundResponse {\n  roundId: string;\n  pda: string;\n  phase: string;\n  openPrice: number;\n  openPriceExpo: number;\n  closePrice: number | null;\n  outcome: string;\n  greenPool: number;\n  redPool: number;\n  totalPool: number;\n  totalFee: number;\n  greenEntries: Array<{ player: string; amountLamports: number }>;\n  redEntries: Array<{ player: string; amountLamports: number }>;\n  greenCount: number;\n  redCount: number;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n}\n\nfunction backendToRound(br: BackendRoundResponse): Round {\n  const greenBets: PlayerBet[] = br.greenEntries.map((e) => ({\n    address: e.player,\n    side: \"green\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const redBets: PlayerBet[] = br.redEntries.map((e) => ({\n    address: e.player,\n    side: \"red\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const greenPool = greenBets.reduce((s, b) => s + b.amount, 0);\n  const redPool = redBets.reduce((s, b) => s + b.amount, 0);\n\n  return {\n    id: br.roundId,\n    phase: br.phase as RoundPhase,\n    pool: {\n      greenPool,\n      redPool,\n      totalPool: greenPool + redPool,\n      playerCount: greenBets.length + redBets.length,\n      greenBets,\n      redBets,\n    },\n    createdAt: new Date(br.createdAt).getTime(),\n    bettingEndsAt: new Date(br.createdAt).getTime() + BETTING_WINDOW_MS,\n    resolvedAt: br.settledAt ? new Date(br.settledAt).getTime() : undefined,\n    targetCandleTime: new Date(br.createdAt).getTime(),\n    outcome: br.outcome === \"pending\" ? undefined : (br.outcome as CandleOutcome),\n    openPrice: br.openPrice,\n    openPriceExpo: br.openPriceExpo,\n    closePrice: br.closePrice ?? undefined,\n    settleTx: br.settleTx ?? undefined,\n  };\n}\n\nasync function fetchCurrentRound(): Promise<Round | null> {\n  try {\n    const res = await fetch(`${FAIRNESS_BACKEND_URL}/closecall/current-round`);\n    if (!res.ok) return null;\n    const data = (await res.json()) as { round: BackendRoundResponse | null };\n    if (!data.round) return null;\n    return backendToRound(data.round);\n  } catch {\n    return null;\n  }\n}\n\nasync function fetchRoundHistory(limit = 20): Promise<Round[]> {\n  try {\n    const res = await fetch(\n      `${FAIRNESS_BACKEND_URL}/closecall/history?limit=${limit}`,\n    );\n    if (!res.ok) return [];\n    const data = (await res.json()) as { rounds: BackendRoundResponse[] };\n    return data.rounds.map(backendToRound);\n  } catch {\n    return [];\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Anchor program + transaction builder\n// ---------------------------------------------------------------------------\n\nfunction getClosecallProgram(connection: Connection): Program<Closecall> {\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" },\n  );\n  return new Program(ClosecallIDL as Idl as Closecall, provider);\n}\n\nasync function buildPlaceBetTx(\n  connection: Connection,\n  player: PublicKey,\n  roundId: string,\n  side: BetSide,\n  amountSol: number,\n): Promise<Transaction> {\n  const program = getClosecallProgram(connection);\n  const [configPda] = getCloseCallConfigPda();\n\n  // Round ID is a hex string (16 chars = 8 bytes)\n  const roundIdBytes = Array.from(Buffer.from(roundId, \"hex\"));\n  const [roundPda] = getCloseCallRoundPda(new Uint8Array(roundIdBytes));\n\n  const sideValue = side === \"green\" ? 0 : 1;\n  const amountLamports = new BN(Math.round(amountSol * LAMPORTS_PER_SOL));\n\n  const ix = await program.methods\n    .placeBet(roundIdBytes as unknown as number[], sideValue, amountLamports)\n    .accountsStrict({\n      player,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = player;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\n// ---------------------------------------------------------------------------\n// Error parsing (user-friendly messages)\n// ---------------------------------------------------------------------------\n\nfunction parseTransactionError(err: unknown): string {\n  const msg = err instanceof Error ? err.message : String(err);\n\n  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    return \"Transaction cancelled by user.\";\n  }\n  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n  }\n  if (msg.includes(\"BettingClosed\") || msg.includes(\"BettingWindowClosed\")) {\n    return \"Betting window has closed for this round. Wait for the next round.\";\n  }\n  if (msg.includes(\"AlreadyBet\") || msg.includes(\"already\")) {\n    return \"You already placed a bet on this round.\";\n  }\n  if (msg.includes(\"MaxEntriesReached\")) {\n    return \"This round is full. Wait for the next round.\";\n  }\n  if (msg.includes(\"Paused\") || msg.includes(\"GamePaused\")) {\n    return \"Game is currently paused.\";\n  }\n  if (msg.includes(\"InvalidPhase\")) {\n    return \"This round is no longer accepting bets.\";\n  }\n  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    return \"Network error. Please check your connection and try again.\";\n  }\n  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    return \"Transaction simulation failed. The round may no longer be open for bets.\";\n  }\n  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    return \"Transaction expired. Please try again.\";\n  }\n\n  console.error(\"[closecall] unhandled transaction error:\", err);\n  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n}\n\n// ---------------------------------------------------------------------------\n// Local candle builder — accumulates 1-min OHLC from live Pyth price ticks\n// ---------------------------------------------------------------------------\n\nfunction getMinuteBoundary(ts: number): number {\n  return Math.floor(ts / 60_000) * 60_000;\n}\n\n// ---------------------------------------------------------------------------\n// Context\n// ---------------------------------------------------------------------------\n\nconst defaultContextValue: CloseCallContextValue = {\n  currentRound: null,\n  completedRound: null,\n  recentCandles: [],\n  currentPrice: 0,\n  candleProgress: 0,\n  userHistory: [],\n  pendingAmount: DEFAULT_BET_AMOUNT,\n  pendingSide: null,\n  userBet: null,\n  loading: true,\n  placingBet: false,\n  setPendingAmount: () => {},\n  setPendingSide: () => {},\n  placeBet: async () => {},\n  adjustBetAmount: () => {},\n  clearCompletedRound: () => {},\n  potentialPayout: 0,\n  userOdds: 0,\n  refreshRound: () => {},\n};\n\nconst CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n\nexport function CloseCallProvider({ children }: { children: ReactNode }) {\n  const { address, publicKey, sendTransaction, getBalance } = useWallet();\n  const { connection } = useConnection();\n  const { refresh: refreshBalance } = useBalance();\n\n  // Live BTC price from Pyth via price-feeds package\n  const btcPrice = usePriceSubscription(\"BTC\");\n\n  // Round state\n  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n  const [currentPrice, setCurrentPrice] = useState(0);\n  const [candleProgress, setCandleProgress] = useState(0);\n\n  // User state\n  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [placingBet, setPlacingBet] = useState(false);\n\n  // Candle builder refs\n  const candlesRef = useRef<Candle[]>([]);\n  const currentCandleRef = useRef<Candle | null>(null);\n\n  // Track previous round id to detect round transitions\n  const prevRoundIdRef = useRef<string | null>(null);\n\n  // -----------------------------------------------------------------------\n  // Update currentPrice from Pyth subscription\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (btcPrice && btcPrice.price > 0) {\n      setCurrentPrice(btcPrice.price);\n    }\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Build local candles from live price ticks\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!btcPrice || btcPrice.price <= 0) return;\n\n    const price = btcPrice.price;\n    const now = Date.now();\n    const minuteStart = getMinuteBoundary(now);\n\n    const current = currentCandleRef.current;\n    if (!current || current.openTime !== minuteStart) {\n      // New minute boundary — close previous candle\n      if (current) {\n        candlesRef.current = [...candlesRef.current.slice(-14), current];\n      }\n      currentCandleRef.current = {\n        open: price,\n        high: price,\n        low: price,\n        close: price,\n        openTime: minuteStart,\n        closeTime: minuteStart + 60_000,\n      };\n    } else {\n      // Update current candle tick\n      currentCandleRef.current = {\n        ...current,\n        high: Math.max(current.high, price),\n        low: Math.min(current.low, price),\n        close: price,\n      };\n    }\n\n    // Push to state so chart re-renders\n    const forming = currentCandleRef.current;\n    setRecentCandles(forming ? [...candlesRef.current, forming] : candlesRef.current);\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Candle progress timer (100ms tick)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    const timer = setInterval(() => {\n      const now = Date.now();\n      const minuteStart = getMinuteBoundary(now);\n      const progress = (now - minuteStart) / 60_000;\n      setCandleProgress(Math.min(progress, 1));\n    }, 100);\n    return () => clearInterval(timer);\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Poll backend for current round (every 2s)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    let cancelled = false;\n\n    async function poll() {\n      const round = await fetchCurrentRound();\n      if (cancelled) return;\n\n      if (round) {\n        // Detect round transition: previous round settled/refunded\n        if (prevRoundIdRef.current && prevRoundIdRef.current !== round.id) {\n          // Fetch the completed round from history for result overlay\n          const history = await fetchRoundHistory(1);\n          const prev = history[0];\n          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n            setCompletedRound(prev);\n          }\n        }\n        prevRoundIdRef.current = round.id;\n        setCurrentRound(round);\n      } else {\n        // No active round — check if previous round just settled\n        if (prevRoundIdRef.current) {\n          const history = await fetchRoundHistory(1);\n          const prev = history[0];\n          if (!cancelled && prev && prev.id === prevRoundIdRef.current) {\n            setCompletedRound(prev);\n          }\n          prevRoundIdRef.current = null;\n        }\n        setCurrentRound(null);\n      }\n      setLoading(false);\n    }\n\n    // Initial fetch\n    poll();\n\n    const interval = setInterval(poll, ROUND_POLL_MS);\n    return () => {\n      cancelled = true;\n      clearInterval(interval);\n    };\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Derive user bet from current round\n  // -----------------------------------------------------------------------\n  const userBet = useMemo(() => {\n    if (!currentRound || !address) return null;\n    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    return allBets.find((b) => b.address === address) ?? null;\n  }, [currentRound, address]);\n\n  // -----------------------------------------------------------------------\n  // Build user history from settled rounds\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!address) {\n      setUserHistory([]);\n      return;\n    }\n\n    let cancelled = false;\n\n    async function loadHistory() {\n      const rounds = await fetchRoundHistory(20);\n      if (cancelled) return;\n\n      const history: UserRoundHistory[] = [];\n      for (const round of rounds) {\n        const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n        const bet = allBets.find((b) => b.address === address);\n        if (bet) {\n          const won = round.outcome === bet.side;\n          history.push({\n            round,\n            userBet: bet,\n            payout: won ? calculatePotentialPayout(bet.amount, bet.side, round.pool) : 0,\n            won,\n          });\n        }\n      }\n      setUserHistory(history);\n    }\n\n    loadHistory();\n\n    return () => { cancelled = true; };\n  }, [address, currentRound?.phase]);\n\n  // -----------------------------------------------------------------------\n  // Potential payout\n  // -----------------------------------------------------------------------\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    if (userBet) {\n      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n    }\n\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // User odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n    if (winningPool === 0) return 0;\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // -----------------------------------------------------------------------\n  // Refresh round data on demand\n  // -----------------------------------------------------------------------\n  const refreshRound = useCallback(() => {\n    fetchCurrentRound().then((round) => {\n      if (round) setCurrentRound(round);\n    });\n  }, []);\n\n  // Clear completed round (after user dismisses result overlay)\n  const clearCompletedRound = useCallback(() => {\n    setCompletedRound(null);\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Send + confirm helper (retries on blockhash expiry)\n  // -----------------------------------------------------------------------\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const MAX_SEND_ATTEMPTS = 3;\n      let cachedBlockhash: string | undefined;\n      let cachedHeight: number | undefined;\n\n      // Pre-flight simulation\n      try {\n        const { blockhash, lastValidBlockHeight } =\n          await connection.getLatestBlockhash(\"confirmed\");\n        cachedBlockhash = blockhash;\n        cachedHeight = lastValidBlockHeight;\n        transaction.recentBlockhash = blockhash;\n\n        const simResult = await connection.simulateTransaction(transaction);\n        if (simResult.value.err) {\n          console.error(\"[closecall] simulation failed:\", JSON.stringify(simResult.value.err));\n          if (simResult.value.logs) {\n            console.error(\"[closecall] simulation logs:\\n\" + simResult.value.logs.join(\"\\n\"));\n          }\n          const err = simResult.value.err;\n          if (typeof err === \"object\" && err !== null && \"InstructionError\" in err) {\n            throw new Error(`Transaction will fail: ${JSON.stringify(err)}`);\n          }\n        }\n      } catch (simErr) {\n        if (simErr instanceof Error && simErr.message.startsWith(\"Transaction will fail:\")) {\n          throw simErr;\n        }\n        console.error(\"[closecall] simulation RPC error:\", simErr);\n      }\n\n      for (let attempt = 1; attempt <= MAX_SEND_ATTEMPTS; attempt++) {\n        let blockhash: string;\n        let lastValidBlockHeight: number;\n\n        if (attempt === 1 && cachedBlockhash && cachedHeight) {\n          blockhash = cachedBlockhash;\n          lastValidBlockHeight = cachedHeight;\n        } else {\n          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n          blockhash = fresh.blockhash;\n          lastValidBlockHeight = fresh.lastValidBlockHeight;\n        }\n        transaction.recentBlockhash = blockhash;\n\n        const signature = await sendTransaction(transaction);\n        console.log(`[closecall] tx sent (attempt ${attempt}/${MAX_SEND_ATTEMPTS}): ${signature}`);\n\n        const controller = new AbortController();\n        const timeout = setTimeout(() => controller.abort(), 30_000);\n        try {\n          await connection.confirmTransaction(\n            { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n            \"confirmed\",\n          );\n          await refreshBalance();\n          return signature;\n        } catch (confirmErr) {\n          const confirmMsg = confirmErr instanceof Error ? confirmErr.message : String(confirmErr);\n          const isExpired = confirmMsg.includes(\"expired\") || confirmMsg.includes(\"block height exceeded\");\n          const isAborted = confirmMsg.includes(\"aborted\");\n\n          if ((isExpired || isAborted) && attempt < MAX_SEND_ATTEMPTS) {\n            try {\n              const status = await connection.getSignatureStatus(signature);\n              if (\n                status.value?.confirmationStatus === \"confirmed\" ||\n                status.value?.confirmationStatus === \"finalized\"\n              ) {\n                console.log(`[closecall] tx ${signature} confirmed via fallback status check`);\n                await refreshBalance();\n                return signature;\n              }\n            } catch {\n              // Status check failed — fall through to retry\n            }\n            console.warn(`[closecall] tx dropped/expired on attempt ${attempt}, retrying...`);\n            continue;\n          }\n          throw confirmErr;\n        } finally {\n          clearTimeout(timeout);\n        }\n      }\n\n      throw new Error(\"Transaction failed after max retry attempts\");\n    },\n    [connection, sendTransaction, refreshBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Place bet — builds and sends on-chain place_bet transaction\n  // -----------------------------------------------------------------------\n  const placeBet = useCallback(\n    async (sideOverride?: BetSide) => {\n      if (!address || !publicKey) throw new Error(\"Wallet not connected\");\n\n      const side = sideOverride ?? pendingSide;\n      if (!side) throw new Error(\"Select GREEN or RED\");\n\n      if (pendingAmount < MIN_BET_AMOUNT) {\n        throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n      }\n      if (pendingAmount > MAX_BET_AMOUNT) {\n        throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n      }\n\n      const currentBalance = getBalance?.();\n      if (currentBalance !== undefined && pendingAmount > currentBalance) {\n        throw new Error(\"Insufficient balance\");\n      }\n\n      if (!currentRound || currentRound.phase !== \"open\") {\n        throw new Error(\"No active round to bet on\");\n      }\n\n      if (Date.now() > currentRound.bettingEndsAt) {\n        throw new Error(\"Betting window has closed. Wait for the next round.\");\n      }\n\n      setPlacingBet(true);\n      try {\n        const transaction = await buildPlaceBetTx(\n          connection,\n          publicKey,\n          currentRound.id,\n          side,\n          pendingAmount,\n        );\n\n        await sendAndConfirm(transaction);\n\n        // Clear pending side on success\n        setPendingSide(null);\n\n        // Refresh round data to reflect the new bet\n        refreshRound();\n      } catch (err) {\n        const userMsg = parseTransactionError(err);\n\n        // If betting closed race condition, refresh round state\n        if (userMsg.includes(\"closed\") || userMsg.includes(\"no longer\")) {\n          refreshRound();\n        }\n\n        throw new Error(userMsg);\n      } finally {\n        setPlacingBet(false);\n      }\n    },\n    [address, publicKey, pendingSide, pendingAmount, getBalance, currentRound, connection, sendAndConfirm, refreshRound],\n  );\n\n  // -----------------------------------------------------------------------\n  // Adjust bet amount\n  // -----------------------------------------------------------------------\n  const adjustBetAmount = useCallback(\n    (adjustment: \"half\" | \"double\" | \"max\") => {\n      let newAmount: number;\n      const currentBalance = getBalance?.();\n\n      switch (adjustment) {\n        case \"half\":\n          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n          break;\n        case \"double\":\n          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n          break;\n        case \"max\":\n          newAmount =\n            currentBalance !== undefined\n              ? Math.min(currentBalance, MAX_BET_AMOUNT)\n              : MAX_BET_AMOUNT;\n          break;\n      }\n\n      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n    },\n    [pendingAmount, getBalance],\n  );\n\n  const contextValue: CloseCallContextValue = {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    clearCompletedRound,\n    potentialPayout,\n    userOdds,\n    refreshRound,\n  };\n\n  return (\n    <CloseCallContext.Provider value={contextValue}>\n      {children}\n    </CloseCallContext.Provider>\n  );\n}\n\nexport function useCloseCall(): CloseCallContextValue {\n  const context = useContext(CloseCallContext);\n  if (!context) {\n    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n  }\n  return context;\n}\n","structuredPatch":[{"oldStart":134,"oldLines":6,"newStart":134,"newLines":26,"lines":[" }"," "," // ---------------------------------------------------------------------------","+// PDA derivation (local — game-engine uses Buffer which breaks browser build)","+// ---------------------------------------------------------------------------","+","+const CLOSECALL_PROGRAM_ID = new PublicKey(ClosecallIDL.address);","+","+function getCloseCallConfigPda(): [PublicKey, number] {","+  return PublicKey.findProgramAddressSync(","+    [Buffer.from(\"closecall_config\")],","+    CLOSECALL_PROGRAM_ID,","+  );","+}","+","+function getCloseCallRoundPda(roundIdBytes: Uint8Array): [PublicKey, number] {","+  return PublicKey.findProgramAddressSync(","+    [Buffer.from(\"cc_round\"), Buffer.from(roundIdBytes)],","+    CLOSECALL_PROGRAM_ID,","+  );","+}","+","+// ---------------------------------------------------------------------------"," // Anchor program + transaction builder"," // ---------------------------------------------------------------------------"," "]}],"userModified":false,"replaceAll":false}}
