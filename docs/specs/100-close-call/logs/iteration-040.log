tSettleSignature(round.settleTx ?? null);\n   526→\n   527→                  if (activeMatch.phase === \"flipping\") {\n   528→                    if (flipTimerRef.current === null) {\n   529→                      logLife(\"phase → complete (PDA gone, flip timer done)\");\n   530→                      setActiveMatch(completedMatch);\n   531→                    } else {\n   532→                      logLife(\"stash result from backend (flip timer pending)\");\n   533→                      setActiveMatch({ ...completedMatch, phase: \"flipping\" });\n   534→                    }\n   535→                    return;\n   536→                  }\n   537→\n   538→                  if (activeMatch.phase === \"countdown\") {\n   539→                    // In countdown — stash result, timers will handle transition\n   540→                    setActiveMatch((current) => {\n   541→                      if (!current || current.phase !== \"countdown\") return current;\n   542→                      return { ...completedMatch, phase: \"countdown\", countdownStartedAt: current.countdownStartedAt };\n   543→                    });\n   544→                    return;\n   545→                  }\n   546→\n   547→                  if (activeMatch.phase === \"ready\" || activeMatch.phase === \"created\") {\n   548→                    // Haven't started animation yet — kick off the full sequence\n   549→                    startFlipSequence(completedMatch);\n   550→                    return;\n   551→                  }\n   552→\n   553→                  setActiveMatch(completedMatch);\n   554→                  return;\n   555→                }\n   556→\n   557→                // Match account closed without a settled backend record (cancel/refund path).\n   558→                setActiveMatch(null);\n   559→              }\n   560→            })\n   561→            .catch(() => {\n   562→              // Ignore polling errors\n   563→            })\n   564→            .finally(() => {\n   565→              activeMatchFetchInFlightRef.current = false;\n   566→            });\n   567→        }\n   568→      } else {\n   569→        // Lobby: poll open matches + claimable\n   570→        void refreshMatches();\n   571→      }\n   572→    }, pollInterval);\n   573→    return () => clearInterval(interval);\n   574→  }, [refreshMatches, activeMatch, connection, pollInterval, startFlipSequence]);\n   575→\n   576→  // Cleanup timers on unmount\n   577→  useEffect(() => {\n   578→    return () => {\n   579→      if (countdownTimerRef.current !== null) clearTimeout(countdownTimerRef.current);\n   580→      if (flipTimerRef.current !== null) clearTimeout(flipTimerRef.current);\n   581→    };\n   582→  }, []);\n   583→\n   584→  const createMatch = useCallback(async () => {\n   585→    if (!connected || !publicKey) {\n   586→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   587→      return;\n   588→    }\n   589→    if (!wagerAmount || !selectedSide) {\n   590→      setError(\"Select wager amount and side first.\");\n   591→      return;\n   592→    }\n   593→\n   594→    // Ensure authenticated — trigger sign-in if needed\n   595→    if (!isAuthenticated || !accessToken) {\n   596→      try {\n   597→        await authenticate();\n   598→      } catch {\n   599→        setError(\"Authentication required. Please approve the sign-in message.\");\n   600→        return;\n   601→      }\n   602→    }\n   603→\n   604→    // After inline authenticate(), the closure's accessToken may be stale\n   605→    // (React hasn't re-rendered yet). Read fresh token from the store.\n   606→    const token = accessToken ?? getAccessToken();\n   607→    if (!token) {\n   608→      setError(\"Authentication failed. Please try again.\");\n   609→      return;\n   610→    }\n   611→\n   612→    setCreating(true);\n   613→    setError(null);\n   614→    setLastSettleSignature(null);\n   615→    try {\n   616→      logLife(\"createMatch: building tx\", { amount: wagerAmount, side: selectedSide });\n   617→      const { transaction, matchPda } = await buildBackendCreateMatchTx(\n   618→        publicKey,\n   619→        wagerAmount,\n   620→        selectedSide,\n   621→        token,\n   622→      );\n   623→\n   624→      logLife(\"createMatch: sending tx\", { pda: matchPda.toBase58().slice(0, 12) });\n   625→      await sendAndConfirm(transaction);\n   626→      logLife(\"createMatch: confirmed\", { pda: matchPda.toBase58().slice(0, 12) });\n   627→\n   628→      dismissedMatchRef.current = null;\n   629→\n   630→      const match = await fetchMatch(connection, matchPda);\n   631→      if (match) {\n   632→        logLife(\"createMatch: fetched, phase=\" + match.phase);\n   633→        setActiveMatch(match);\n   634→      }\n   635→\n   636→      setSelectedSide(null);\n   637→      refreshMatches();\n   638→    } catch (err) {\n   639→      // Handle 401 from backend: attempt refresh, retry once\n   640→      if (err instanceof BackendRequestError && err.status === 401) {\n   641→        try {\n   642→          await authenticate();\n   643→          setError(\"Session refreshed. Please try again.\");\n   644→        } catch {\n   645→          setError(\"Session expired. Please reconnect your wallet.\");\n   646→        }\n   647→        return;\n   648→      }\n   649→      setError(parseTransactionError(err));\n   650→    } finally {\n   651→      setCreating(false);\n   652→    }\n   653→  }, [connected, publicKey, wagerAmount, selectedSide, connection, sendAndConfirm, refreshMatches, isAuthenticated, accessToken, authenticate]);\n   654→\n   655→  const joinMatch = useCallback(\n   656→    async (matchId: string) => {\n   657→      if (!connected || !publicKey) {\n   658→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   659→        return;\n   660→      }\n   661→\n   662→      setJoining(true);\n   663→      setJoiningMatchId(matchId);\n   664→      setError(null);\n   665→      setLastSettleSignature(null);\n   666→      try {\n   667→        // matchId is the match PDA base58 — fetch to get the creator\n   668→        const matchPda = new PublicKey(matchId);\n   669→        const existingMatch = await fetchMatch(connection, matchPda);\n   670→        if (!existingMatch) {\n   671→          setError(\"Match not found. It may have been cancelled.\");\n   672→          return;\n   673→        }\n   674→\n   675→        const transaction = await buildJoinMatchTx(\n   676→          connection,\n   677→          publicKey,\n   678→          matchPda\n   679→        );\n   680→\n   681→        await sendAndConfirm(transaction);\n   682→\n   683→        // Clear dismissed ref — this is a new intentional match\n   684→        dismissedMatchRef.current = null;\n   685→\n   686→        // Fetch updated match\n   687→        const updated = await fetchMatch(connection, matchPda);\n   688→        if (updated) {\n   689→          if (updated.phase === \"ready\") {\n   690→            if (countdownTimerRef.current) clearTimeout(countdownTimerRef.current);\n   691→            if (flipTimerRef.current) clearTimeout(flipTimerRef.current);\n   692→\n   693→            setActiveMatch({\n   694→              ...updated,\n   695→              phase: \"countdown\",\n   696→              countdownStartedAt: Date.now(),\n   697→            });\n   698→\n   699→            countdownTimerRef.current = window.setTimeout(() => {\n   700→              countdownTimerRef.current = null;\n   701→              setActiveMatch((current) => {\n   702→                if (!current || current.phase !== \"countdown\") return current;\n   703→                return { ...current, phase: \"flipping\" };\n   704→              });\n   705→\n   706→              flipTimerRef.current = window.setTimeout(() => {\n   707→                flipTimerRef.current = null;\n   708→                setActiveMatch((current) => {\n   709→                  if (!current || current.phase !== \"flipping\") return current;\n   710→                  if (current.winner) {\n   711→                    return { ...current, phase: \"complete\" };\n   712→                  }\n   713→                  return current;\n   714→                });\n   715→              }, 3000);\n   716→            }, 3000);\n   717→          } else {\n   718→            setActiveMatch(updated);\n   719→          }\n   720→        }\n   721→\n   722→        refreshMatches();\n   723→      } catch (err) {\n   724→        setError(parseTransactionError(err));\n   725→      } finally {\n   726→        setJoining(false);\n   727→        setJoiningMatchId(null);\n   728→      }\n   729→    },\n   730→    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n   731→  );\n   732→\n   733→  const cancelMatch = useCallback(async () => {\n   734→    if (!connected || !publicKey || !activeMatch || !activeMatch.server) {\n   735→      setError(\"No active match to cancel.\");\n   736→      return;\n   737→    }\n   738→\n   739→    setError(null);\n   740→    try {\n   741→      const matchPda = new PublicKey(activeMatch.id);\n   742→      const transaction = await buildCancelMatchTx(connection, publicKey, matchPda, new PublicKey(activeMatch.server));\n   743→      await sendAndConfirm(transaction);\n   744→      setActiveMatch(null);\n   745→      refreshMatches();\n   746→    } catch (err) {\n   747→      setError(parseTransactionError(err));\n   748→    }\n   749→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   750→\n   751→  const timeoutRefund = useCallback(async () => {\n   752→    if (!connected || !publicKey || !activeMatch || !activeMatch.server) {\n   753→      setError(\"No active match to cancel.\");\n   754→      return;\n   755→    }\n   756→    if (!activeMatch.player2) {\n   757→      setError(\"Match has no opponent.\");\n   758→      return;\n   759→    }\n   760→\n   761→    setError(null);\n   762→    try {\n   763→      const matchPda = new PublicKey(activeMatch.id);\n   764→      const matchCreator = new PublicKey(activeMatch.player1);\n   765→      const opponent = new PublicKey(activeMatch.player2);\n   766→\n   767→      const transaction = await buildTimeoutRefundTx(\n   768→        connection,\n   769→        publicKey,\n   770→        matchPda,\n   771→        matchCreator,\n   772→        opponent,\n   773→        new PublicKey(activeMatch.server),\n   774→      );\n   775→      await sendAndConfirm(transaction);\n   776→      setActiveMatch(null);\n   777→      refreshMatches();\n   778→    } catch (err) {\n   779→      // If timeout refund failed, the server may have settled in the meantime.\n   780→      // Re-fetch the match to update the UI.\n   781→      const matchPda = new PublicKey(activeMatch.id);\n   782→      const refreshed = await fetchMatch(connection, matchPda).catch(() => null);\n   783→      if (refreshed && refreshed.phase === \"complete\") {\n   784→        setActiveMatch(refreshed);\n   785→        setError(\"Match was already settled by the server.\");\n   786→        return;\n   787→      }\n   788→\n   789→      setError(parseTransactionError(err));\n   790→    }\n   791→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   792→\n   793→  /** Open a match from the claimable list in ActiveMatchView. */\n   794→  const selectMatch = useCallback((match: UIMatch) => {\n   795→    dismissedMatchRef.current = null;\n   796→    setActiveMatch(match);\n   797→  }, []);\n   798→\n   799→  const clearActiveMatch = useCallback(() => {\n   800→    // Record the dismissed match ID so in-flight polls don't restore it\n   801→    dismissedMatchRef.current = activeMatch?.id ?? null;\n   802→    setActiveMatch(null);\n   803→    setLastSettleSignature(null);\n   804→    setError(null);\n   805→    refreshMatches();\n   806→  }, [activeMatch, refreshMatches]);\n   807→\n   808→  // No auto-restore on wallet connect — user picks from lobby or uses deep-link\n   809→\n   810→  // Deep-link restore: if URL has /coinflip/:matchId and no active match, load it\n   811→  useEffect(() => {\n   812→    if (activeMatch) return;\n   813→    const match = window.location.pathname.match(/^\\/coinflip\\/([0-9a-f]{16})$/i);\n   814→    if (!match) return;\n   815→    const urlMatchId = match[1]!;\n   816→    fetchMatchByMatchId(connection, urlMatchId)\n   817→      .then((loaded) => {\n   818→        if (loaded) setActiveMatch(loaded);\n   819→      })\n   820→      .catch(() => {});\n   821→  // eslint-disable-next-line react-hooks/exhaustive-deps\n   822→  }, [connection]);\n   823→\n   824→  // Sync URL with active match — replaceState avoids React Router remount\n   825→  useEffect(() => {\n   826→    if (activeMatch?.matchId) {\n   827→      const target = `/coinflip/${activeMatch.matchId}`;\n   828→      if (window.location.pathname !== target) {\n   829→        window.history.replaceState(null, \"\", target);\n   830→      }\n   831→    } else if (window.location.pathname.startsWith(\"/coinflip/\")) {\n   832→      window.history.replaceState(null, \"\", \"/coinflip\");\n   833→    }\n   834→  }, [activeMatch]);\n   835→\n   836→  const value: CoinflipContextValue = {\n   837→    activeMatch,\n   838→    openMatches,\n   839→    claimableMatches,\n   840→    userHistory,\n   841→    wagerAmount,\n   842→    selectedSide,\n   843→    loading,\n   844→    creating,\n   845→    joining,\n   846→    joiningMatchId,\n   847→    error,\n   848→    clearError,\n   849→    lastSettleSignature,\n   850→    setWagerAmount,\n   851→    setSelectedSide,\n   852→    createMatch,\n   853→    joinMatch,\n   854→    cancelMatch,\n   855→    timeoutRefund,\n   856→    clearActiveMatch,\n   857→    selectMatch,\n   858→    refreshMatches,\n   859→  };\n   860→\n   861→  return (\n   862→    <CoinflipContext.Provider value={value}>\n   863→      {children}\n   864→    </CoinflipContext.Provider>\n   865→  );\n   866→}\n   867→\n   868→export function useCoinflip(): CoinflipContextValue {\n   869→  const context = useContext(CoinflipContext);\n   870→  if (!context) {\n   871→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   872→  }\n   873→  return context;\n   874→}\n   875→"}]},"parent_tool_use_id":"toolu_01MPoXotPwuktccSSbk63gaM","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"c43332a9-f37d-4ca2-b309-aeef3c6f8f10"}
