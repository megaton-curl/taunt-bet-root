{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JzgrksXbWDJbGxd9y7aQFK","type":"tool_result","content":"     1→import { useState, useEffect } from \"react\";\n     2→import { useConnection } from \"@rng-utopia/wallet/hooks\";\n     3→import type { UIMatch } from \"../types\";\n     4→import type { VerificationResult } from \"../utils/verification\";\n     5→import { CoinAnimation } from \"./CoinAnimation\";\n     6→import { SlotProgress } from \"./SlotProgress\";\n     7→import { getOppositeSide } from \"../utils/helpers\";\n     8→import { PlayerAvatarCompact } from \"../../player-profile\";\n     9→\n    10→const LOCK_TIMEOUT_MS = 86_400_000; // 24 hours\n    11→\n    12→interface ActiveMatchViewProps {\n    13→  match: UIMatch;\n    14→  currentUserAddress: string;\n    15→  onCancel?: () => void;\n    16→  onTimeoutRefund?: () => void;\n    17→  onClearMatch?: () => void;\n    18→  onRematch?: () => void;\n    19→  cancelling?: boolean;\n    20→  rematching?: boolean;\n    21→  // Verification\n    22→  settleTxSignature?: string | null;\n    23→  verificationResult?: VerificationResult | null;\n    24→  verifying?: boolean;\n    25→  onVerify?: () => void;\n    26→}\n    27→\n    28→export function ActiveMatchView({\n    29→  match,\n    30→  currentUserAddress,\n    31→  onCancel,\n    32→  onTimeoutRefund,\n    33→  onClearMatch,\n    34→  onRematch,\n    35→  cancelling,\n    36→  rematching,\n    37→  settleTxSignature,\n    38→  verificationResult,\n    39→  verifying,\n    40→  onVerify,\n    41→}: ActiveMatchViewProps) {\n    42→  const { connection } = useConnection();\n    43→  const isPlayer1 = match.player1 === currentUserAddress;\n    44→  const isWinner = match.winner === currentUserAddress;\n    45→\n    46→  const yourSide = isPlayer1 ? match.player1Side : match.player2Side;\n    47→  const opponentSide = yourSide ? getOppositeSide(yourSide) : null;\n    48→  const opponent = isPlayer1 ? match.player2 : match.player1;\n    49→\n    50→  // Track whether lock timeout has elapsed (for timeout cancel button)\n    51→  const [lockTimedOut, setLockTimedOut] = useState(false);\n    52→  const [cancellingTimeout, setCancellingTimeout] = useState(false);\n    53→  // Show timeout refund option after 30s of flipping (something went wrong)\n    54→  const [showRefundInFlip, setShowRefundInFlip] = useState(false);\n    55→\n    56→  useEffect(() => {\n    57→    if (match.phase !== \"flipping\") {\n    58→      setShowRefundInFlip(false);\n    59→      return;\n    60→    }\n    61→    const timer = setTimeout(() => setShowRefundInFlip(true), 30_000);\n    62→    return () => clearTimeout(timer);\n    63→  }, [match.phase]);\n    64→\n    65→  useEffect(() => {\n    66→    const isLocked = match.phase === \"ready\" || match.phase === \"flipping\" || match.phase === \"countdown\";\n    67→    if (!isLocked || !match.lockedAt) {\n    68→      setLockTimedOut(false);\n    69→      return;\n    70→    }\n    71→\n    72→    const remaining = match.lockedAt + LOCK_TIMEOUT_MS - Date.now();\n    73→    if (remaining <= 0) {\n    74→      setLockTimedOut(true);\n    75→      return;\n    76→    }\n    77→\n    78→    setLockTimedOut(false);\n    79→    const timer = setTimeout(() => setLockTimedOut(true), remaining);\n    80→    return () => clearTimeout(timer);\n    81→  }, [match.phase, match.lockedAt]);\n    82→\n    83→  // Countdown timer\n    84→  const [countdown, setCountdown] = useState(3);\n    85→\n    86→  useEffect(() => {\n    87→    if (match.phase === \"countdown\" && match.countdownStartedAt) {\n    88→      // Always start at 3\n    89→      setCountdown(3);\n    90→\n    91→      const updateCountdown = () => {\n    92→        const elapsed = Date.now() - match.countdownStartedAt!;\n    93→        // Each number shows for exactly 1 second:\n    94→        // 0-999ms: show 3\n    95→        // 1000-1999ms: show 2\n    96→        // 2000-2999ms: show 1\n    97→        if (elapsed < 1000) {\n    98→          setCountdown(3);\n    99→        } else if (elapsed < 2000) {\n   100→          setCountdown(2);\n   101→        } else {\n   102→          setCountdown(1);\n   103→        }\n   104→      };\n   105→\n   106→      const interval = setInterval(updateCountdown, 50);\n   107→      return () => {\n   108→        clearInterval(interval);\n   109→        // Reset for next countdown\n   110→        setCountdown(3);\n   111→      };\n   112→    }\n   113→  }, [match.phase, match.countdownStartedAt]);\n   114→\n   115→  return (\n   116→    <div className=\"coinflip-active-match\">\n   117→      {/* Waiting for opponent */}\n   118→      {match.phase === \"created\" && (\n   119→        <div className=\"coinflip-active-match__waiting\">\n   120→          <h3 className=\"coinflip-active-match__title\">Waiting for Opponent</h3>\n   121→          <div className=\"coinflip-active-match__info\">\n   122→            <p>\n   123→              Your side: <strong className={`side-${match.player1Side}`}>\n   124→                {match.player1Side.toUpperCase()}\n   125→              </strong>\n   126→            </p>\n   127→            <p>Entry: <strong>{\"$\"}{match.entryAmount}</strong></p>\n   128→          </div>\n   129→          <div className=\"coinflip-waiting__spinner\" />\n   130→          <p className=\"coinflip-active-match__hint\">\n   131→            Someone will join soon...\n   132→          </p>\n   133→          {onCancel && (\n   134→            <button\n   135→              type=\"button\"\n   136→              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   137→              onClick={onCancel}\n   138→              disabled={cancelling}\n   139→            >\n   140→              {cancelling ? \"Cancelling...\" : \"Cancel Match\"}\n   141→            </button>\n   142→          )}\n   143→        </div>\n   144→      )}\n   145→\n   146→      {/* Countdown — \"3... 2... 1...\" before flip starts */}\n   147→      {m