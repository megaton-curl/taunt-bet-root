ned;\n   484→\n   485→      // Pre-flight simulation\n   486→      try {\n   487→        const { blockhash, lastValidBlockHeight } =\n   488→          await connection.getLatestBlockhash(\"confirmed\");\n   489→        cachedBlockhash = blockhash;\n   490→        cachedHeight = lastValidBlockHeight;\n   491→        transaction.recentBlockhash = blockhash;\n   492→\n   493→        const simResult = await connection.simulateTransaction(transaction);\n   494→        if (simResult.value.err) {\n   495→          console.error(\"[closecall] simulation failed:\", JSON.stringify(simResult.value.err));\n   496→          if (simResult.value.logs) {\n   497→            console.error(\"[closecall] simulation logs:\\n\" + simResult.value.logs.join(\"\\n\"));\n   498→          }\n   499→          const err = simResult.value.err;\n   500→          if (typeof err === \"object\" && err !== null && \"InstructionError\" in err) {\n   501→            throw new Error(`Transaction will fail: ${JSON.stringify(err)}`);\n   502→          }\n   503→        }\n   504→      } catch (simErr) {\n   505→        if (simErr instanceof Error && simErr.message.startsWith(\"Transaction will fail:\")) {\n   506→          throw simErr;\n   507→        }\n   508→        console.error(\"[closecall] simulation RPC error:\", simErr);\n   509→      }\n   510→\n   511→      for (let attempt = 1; attempt <= MAX_SEND_ATTEMPTS; attempt++) {\n   512→        let blockhash: string;\n   513→        let lastValidBlockHeight: number;\n   514→\n   515→        if (attempt === 1 && cachedBlockhash && cachedHeight) {\n   516→          blockhash = cachedBlockhash;\n   517→          lastValidBlockHeight = cachedHeight;\n   518→        } else {\n   519→          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n   520→          blockhash = fresh.blockhash;\n   521→          lastValidBlockHeight = fresh.lastValidBlockHeight;\n   522→        }\n   523→        transaction.recentBlockhash = blockhash;\n   524→\n   525→        const signature = await sendTransaction(transaction);\n   526→        console.log(`[closecall] tx sent (attempt ${attempt}/${MAX_SEND_ATTEMPTS}): ${signature}`);\n   527→\n   528→        const controller = new AbortController();\n   529→        const timeout = setTimeout(() => controller.abort(), 30_000);\n   530→        try {\n   531→          await connection.confirmTransaction(\n   532→            { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n   533→            \"confirmed\",\n   534→          );\n   535→          await refreshBalance();\n   536→          return signature;\n   537→        } catch (confirmErr) {\n   538→          const confirmMsg = confirmErr instanceof Error ? confirmErr.message : String(confirmErr);\n   539→          const isExpired = confirmMsg.includes(\"expired\") || confirmMsg.includes(\"block height exceeded\");\n   540→          const isAborted = confirmMsg.includes(\"aborted\");\n   541→\n   542→          if ((isExpired || isAborted) && attempt < MAX_SEND_ATTEMPTS) {\n   543→            try {\n   544→              const status = await connection.getSignatureStatus(signature);\n   545→              if (\n   546→                status.value?.confirmationStatus === \"confirmed\" ||\n   547→                status.value?.confirmationStatus === \"finalized\"\n   548→              ) {\n   549→                console.log(`[closecall] tx ${signature} confirmed via fallback status check`);\n   550→                await refreshBalance();\n   551→                return signature;\n   552→              }\n   553→            } catch {\n   554→              // Status check failed — fall through to retry\n   555→            }\n   556→            console.warn(`[closecall] tx dropped/expired on attempt ${attempt}, retrying...`);\n   557→            continue;\n   558→          }\n   559→          throw confirmErr;"}]},"parent_tool_use_id":null,"session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"43dae776-ec31-43ef-872e-76805e5a9397","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","content":"        }\n      }\n      setUserHistory(history);\n    }\n\n    loadHistory();\n\n    return () => { cancelled = true; };\n  }, [address, currentRound?.phase]);\n\n  // -----------------------------------------------------------------------\n  // Potential payout\n  // -----------------------------------------------------------------------\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    if (userBet) {\n      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n    }\n\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // User odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n    if (winningPool === 0) return 0;\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // -----------------------------------------------------------------------\n  // Send + confirm helper (retries on blockhash expiry)\n  // -----------------------------------------------------------------------\n  const sendAndConfirm = useCallback(\n    async (transaction: Transaction): Promise<string> => {\n      const MAX_SEND_ATTEMPTS = 3;\n      let cachedBlockhash: string | undefined;\n      let cachedHeight: number | undefined;\n\n      // Pre-flight simulation\n      try {\n        const { blockhash, lastValidBlockHeight } =\n          await connection.getLatestBlockhash(\"confirmed\");\n        cachedBlockhash = blockhash;\n        cachedHeight = lastValidBlockHeight;\n        transaction.recentBlockhash = blockhash;\n\n        const simResult = await connection.simulateTransaction(transaction);\n        if (simResult.value.err) {\n          console.error(\"[closecall] simulation failed:\", JSON.stringify(simResult.value.err));\n          if (simResult.value.logs) {\n            console.error(\"[closecall] simulation logs:\\n\" + simResult.value.logs.join(\"\\n\"));\n          }\n          const err = simResult.value.err;\n          if (typeof err === \"object\" && err !== null && \"InstructionError\" in err) {\n            throw new Error(`Transaction will fail: ${JSON.stringify(err)}`);\n          }\n        }\n      } catch (simErr) {\n        if (simErr instanceof Error && simErr.message.startsWith(\"Transaction will fail:\")) {\n          throw simErr;\n        }\n        console.error(\"[closecall] simulation RPC error:\", simErr);\n      }\n\n      for (let attempt = 1; attempt <= MAX_SEND_ATTEMPTS; attempt++) {\n        let blockhash: string;\n        let lastValidBlockHeight: number;\n\n        if (attempt === 1 && cachedBlockhash && cachedHeight) {\n          blockhash = cachedBlockhash;\n          lastValidBlockHeight = cachedHeight;\n        } else {\n          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n          blockhash = fresh.blockhash;\n          lastValidBlockHeight = fresh.lastValidBlockHeight;\n        }\n        transaction.recentBlockhash = blockhash;\n\n        const signature = await sendTransaction(transaction);\n        console.log(`[closecall] tx sent (attempt ${attempt}/${MAX_SEND_ATTEMPTS}): ${signature}`);\n\n        const controller = new AbortController();\n        const timeout = setTimeout(() => controller.abort(), 30_000);\n        try {\n          await connection.confirmTransaction(\n            { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n            \"confirmed\",\n          );\n          await refreshBalance();\n          return signature;\n        } catch (confirmErr) {\n          const confirmMsg = confirmErr instanceof Error ? confirmErr.message : String(confirmErr);\n          const isExpired = confirmMsg.includes(\"expired\") || confirmMsg.includes(\"block height exceeded\");\n          const isAborted = confirmMsg.includes(\"aborted\");\n\n          if ((isExpired || isAborted) && attempt < MAX_SEND_ATTEMPTS) {\n            try {\n              const status = await connection.getSignatureStatus(signature);\n              if (\n                status.value?.confirmationStatus === \"confirmed\" ||\n                status.value?.confirmationStatus === \"finalized\"\n              ) {\n                console.log(`[closecall] tx ${signature} confirmed via fallback status check`);\n                await refreshBalance();\n                return signature;\n              }\n            } catch {\n              // Status check failed — fall through to retry\n            }\n            console.warn(`[closecall] tx dropped/expired on attempt ${attempt}, retrying...`);\n            continue;\n          }\n          throw confirmErr;","numLines":120,"startLine":440,"totalLines":711}}}
