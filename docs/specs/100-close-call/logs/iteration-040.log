{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mw3txA4MJrTJioHXw1vVg6","type":"tool_result","content":"     1→import { useState } from \"react\";\n     2→import type { UIMatch } from \"../types\";\n     3→import { MatchCard } from \"./MatchCard\";\n     4→\n     5→type SortOption = \"newest\" | \"oldest\" | \"amount\";\n     6→\n     7→interface OpenMatchesListProps {\n     8→  matches: UIMatch[];\n     9→  loading: boolean;\n    10→  onJoin: (matchId: string) => void;\n    11→  joiningMatchId: string | null;\n    12→  currentUserAddress: string | null;\n    13→  isConnected: boolean;\n    14→}\n    15→\n    16→function sortMatches(matches: UIMatch[], sort: SortOption): UIMatch[] {\n    17→  return [...matches].sort((a, b) => {\n    18→    switch (sort) {\n    19→      case \"newest\":\n    20→        return b.createdAt - a.createdAt;\n    21→      case \"oldest\":\n    22→        return a.createdAt - b.createdAt;\n    23→      case \"amount\":\n    24→        return b.entryAmount - a.entryAmount;\n    25→    }\n    26→  });\n    27→}\n    28→\n    29→export function OpenMatchesList({\n    30→  matches,\n    31→  loading,\n    32→  onJoin,\n    33→  joiningMatchId,\n    34→  currentUserAddress,\n    35→  isConnected,\n    36→}: OpenMatchesListProps) {\n    37→  const [sortBy, setSortBy] = useState<SortOption>(\"newest\");\n    38→\n    39→  // Apply sort\n    40→  const sortedMatches = sortMatches(matches, sortBy);\n    41→\n    42→  if (loading) {\n    43→    return (\n    44→      <div className=\"coinflip-matches coinflip-matches--loading\">\n    45→        <div className=\"coinflip-matches__spinner\" />\n    46→        <p>Loading games...</p>\n    47→      </div>\n    48→    );\n    49→  }\n    50→\n    51→  if (sortedMatches.length === 0) {\n    52→    return (\n    53→      <div className=\"coinflip-matches coinflip-matches--empty\">\n    54→        <p className=\"coinflip-matches__empty-text\">\n    55→          No open games available\n    56→        </p>\n    57→        <p className=\"coinflip-matches__empty-hint\">\n    58→          Create a game or wait for someone to create one\n    59→        </p>\n    60→      </div>\n    61→    );\n    62→  }\n    63→\n    64→  return (\n    65→    <div className=\"coinflip-matches\">\n    66→      <div className=\"coinflip-matches__header\">\n    67→        <h3 className=\"coinflip-matches__title\">Open Games</h3>\n    68→        <div className=\"coinflip-matches__controls\">\n    69→          <select\n    70→            className=\"coinflip-matches__sort\"\n    71→            value={sortBy}\n    72→            onChange={(e) => setSortBy(e.target.value as SortOption)}\n    73→          >\n    74→            <option value=\"newest\">Newest</option>\n    75→            <option value=\"oldest\">Oldest</option>\n    76→            <option value=\"amount\">Amount</option>\n    77→          </select>\n    78→          <span className=\"coinflip-matches__count\">\n    79→            {sortedMatches.length} available\n    80→          </span>\n    81→        </div>\n    82→      </div>\n    83→\n    84→      <div className=\"coinflip-matches__list\">\n    85→        {sortedMatches.map((match) => {\n    86→          const isOwn = currentUserAddress === match.player1;\n    87→          const canJoin = isConnected && !isOwn;\n    88→\n    89→          return (\n    90→            <MatchCard\n    91→              key={match.id}\n    92→              match={match}\n    93→              onJoin={() => onJoin(match.id)}\n    94→              isOwn={isOwn}\n    95→              canJoin={canJoin}\n    96→              joining={joiningMatchId === match.id}\n    97→            />\n    98→          );\n    99→        })}\n   100→      </div>\n   101→    </div>\n   102→  );\n   103→}\n   104→"}]},"parent_tool_use_id":"toolu_01MPoXotPwuktccSSbk63gaM","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"41ae3039-a53b-409d-98a1-a52979249682"}
