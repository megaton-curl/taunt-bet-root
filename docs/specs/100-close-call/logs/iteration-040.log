{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FRuwTycV3tbXxT8JUDjBBw","type":"tool_result","content":"     1→import type { CoinSide } from \"../types\";\n     2→\n     3→export function truncateAddress(address: string): string {\n     4→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n     5→}\n     6→\n     7→export function getOppositeSide(side: CoinSide): CoinSide {\n     8→  return side === \"heads\" ? \"tails\" : \"heads\";\n     9→}\n    10→"}]},"parent_tool_use_id":"toolu_01MPoXotPwuktccSSbk63gaM","session_id":"69ec7f4b-ea2c-48d6-9a60-da2ab1703b1a","uuid":"995536e1-1118-4241-8a01-839b17bf3f79"}
