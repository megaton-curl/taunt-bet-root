{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GNcXRhUiLKprVxE8TFWQ3A","type":"tool_result","content":"     1→/**\n     2→ * Devnet E2E smoke test.\n     3→ *\n     4→ * Validates the devnet environment contract (env vars + deployed programs)\n     5→ * and verifies the app loads against the devnet RPC.\n     6→ */\n     7→import { test, expect } from \"./fixtures\";\n     8→import { verifyDevnetDeployments } from \"./helpers/env\";\n     9→\n    10→test.describe(\"devnet smoke\", () => {\n    11→  test(\"devnet deployments are reachable and valid\", async ({\n    12→    devnetConfig,\n    13→  }) => {\n    14→    // Verifies: RPC health, coinflip/platform/orao programs deployed, VRF initialized\n    15→    await verifyDevnetDeployments(devnetConfig);\n    16→  });\n    17→\n    18→  test(\"app loads against devnet\", async ({ playerAPage }) => {\n    19→    await playerAPage.goto(\"/\");\n    20→    // App should render the main layout (not a blank screen or error page)\n    21→    await expect(playerAPage.locator(\"body\")).not.toBeEmpty();\n    22→    // Navigation should be present (proves React rendered)\n    23→    await expect(\n    24→      playerAPage.locator(\"nav, [class*='sidebar'], [class*='nav']\").first(),\n    25→    ).toBeVisible({ timeout: 15_000 });\n    26→  });\n    27→\n    28→  test(\"wallet connects with test keypair on devnet\", async ({\n    29→    playerAPage,\n    30→    playerAKeypair,\n    31→  }) => {\n    32→    await playerAPage.goto(\"/\");\n    33→    // Wait for wallet to auto-connect via TestWalletProvider\n    34→    const pubkeyShort = playerAKeypair.publicKey.toBase58().slice(0, 4);\n    35→    // The wallet address (or a truncated version) should appear somewhere in the UI\n    36→    await expect(playerAPage.getByText(pubkeyShort).first()).toBeVisible({\n    37→      timeout: 15_000,\n    38→    });\n    39→  });\n    40→});\n    41→"}]},"parent_tool_use_id":"toolu_01J4DkMj6TbDT24GtmVyAJQv","session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"839a8022-0611-4de0-b42a-f4113d6db29e"}
