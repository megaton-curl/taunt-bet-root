{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NqovTHMTz9HZqmHrhsWx2A","type":"tool_result","content":"     1→/**\n     2→ * Devnet E2E environment contract.\n     3→ *\n     4→ * Validates that all required environment variables are present and well-formed\n     5→ * before any devnet test runs. Fails fast with clear error messages so CI\n     6→ * doesn't waste time on doomed runs.\n     7→ *\n     8→ * Required env vars:\n     9→ *   VITE_RPC_URL             — Devnet RPC endpoint (https URL)\n    10→ *   VITE_COINFLIP_PROGRAM_ID — Deployed coinflip program address (base58)\n    11→ *   VITE_PLATFORM_PROGRAM_ID — Deployed platform program address (base58)\n    12→ *   VITE_FAIRNESS_BACKEND_URL — Running fairness backend base URL (http(s) URL)\n    13→ *\n    14→ * Optional (with defaults):\n    15→ *   VITE_SOLANA_NETWORK      — Cluster name (default: \"devnet\")\n    16→ */\n    17→\n    18→import { Connection, PublicKey } from \"@solana/web3.js\";\n    19→\n    20→/** Validated devnet configuration. */\n    21→export interface DevnetConfig {\n    22→  rpcUrl: string;\n    23→  network: string;\n    24→  fairnessBackendUrl: string;\n    25→  coinflipProgramId: PublicKey;\n    26→  platformProgramId: PublicKey;\n    27→  /** Optional — falls back to IDL address if env var missing. */\n    28→  lordofrngsProgramId: PublicKey | null;\n    29→}\n    30→\n    31→/** Validate a base58 public key string. Throws if invalid. */\n    32→function parsePublicKey(value: string, label: string): PublicKey {\n    33→  try {\n    34→    return new PublicKey(value);\n    35→  } catch {\n    36→    throw new Error(\n    37→      `${label} is not a valid Solana address (base58): \"${value}\"`,\n    38→    );\n    39→  }\n    40→}\n    41→\n    42→/** Validate a URL string. Throws if malformed. */\n    43→function parseUrl(value: string, label: string): string {\n    44→  try {\n    45→    const url = new URL(value);\n    46→    if (![\"http:\", \"https:\"].includes(url.protocol)) {\n    47→      throw new Error(\"not http(s)\");\n    48→    }\n    49→    return value;\n    50→  } catch {\n    51→    throw new Error(\n    52→      `${label} is not a valid HTTP(S) URL: \"${value}\"`,\n    53→    );\n    54→  }\n    55→}\n    56→\n    57→/**\n    58→ * Read and validate all required devnet env vars.\n    59→ * Throws with a consolidated error listing every missing/invalid variable.\n    60→ */\n    61→export function validateDevnetEnv(): DevnetConfig {\n    62→  const errors: string[] = [];\n    63→\n    64→  // --- Required ---\n    65→  const rpcUrl = process.env.VITE_RPC_URL;\n    66→  if (!rpcUrl) {\n    67→    errors.push(\"VITE_RPC_URL is required (devnet RPC endpoint)\");\n    68→  }\n    69→\n    70→  const coinflipId = process.env.VITE_COINFLIP_PROGRAM_ID;\n    71→  if (!coinflipId) {\n    72→    errors.push(\n    73→      \"VITE_COINFLIP_PROGRAM_ID is required (deployed coinflip program address)\",\n    74→    );\n    75→  }\n    76→\n    77→  const platformId = process.env.VITE_PLATFORM_PROGRAM_ID;\n    78→  if (!platformId) {\n    79→    errors.push(\n    80→      \"VITE_PLATFORM_PROGRAM_ID is required (deployed platform program address)\",\n    81→    );\n    82→  }\n    83→\n    84→  const fairnessBackendUrl = process.env.VITE_FAIRNESS_BACKEND_URL;\n    85→  if (!fairnessBackendUrl) {\n    86→    errors.push(\n    87→      \"VITE_FAIRNESS_BACKEND_URL is required (running backend base URL)\",\n    88→    );\n    89→  }\n    90→\n    91→  // Fail fast if any required var is missing\n    92→  if (errors.length > 0) {\n    93→    throw new Error(\n    94→      `Devnet E2E env validation failed:\\n  - ${errors.join(\"\\n  - \")}\\n\\n` +\n    95→        `Hint: copy .env.devnet to .env.local and update program IDs, ` +\n    96→        `or export the variables before running tests.`,\n    97→    );\n    98→  }\n    99→\n   100→  // --- Format validation ---\n   101→  const validatedUrl = parseUrl(rpcUrl!, \"VITE_RPC_URL\");\n   102→  const validatedBackendUrl = parseUrl(\n   103→    fairnessBackendUrl!,\n   104→    \"VITE_FAIRNESS_BACKEND_URL\",\n   105→  );\n   106→  const coinflipProgramId = parsePublicKey(\n   107→    coinflipId!,\n   108→    \"VITE_COINFLIP_PROGRAM_ID\",\n   109→  );\n   110→  const platformProgramId = parsePublicKey(\n   111→    platformId!,\n   112→    \"VITE_PLATFORM_PROGRAM_ID\",\n   113→  );\n   114→\n   115→  // --- Optional with default ---\n   116→  const network = process.env.VITE_SOLANA_NETWORK ?? \"devnet\";\n   117→\n   118→  // --- Optional lordofrngs (IDL fallback if env var missing) ---\n   119→  const lordofrngsIdStr = process.env.VITE_LORDOFRNGS_PROGRAM_ID;\n   120→  let lordofrngsProgramId: PublicKey | null = null;\n   121→  if (lordofrngsIdStr) {\n   122→    try {\n   123→      lordofrngsProgramId = parsePublicKey(lordofrngsIdStr, \"VITE_LORDOFRNGS_PROGRAM_ID\");\n   124→    } catch {\n   125→      console.warn(`VITE_LORDOFRNGS_PROGRAM_ID is invalid: \"${lordofrngsIdStr}\" — Lord tests will skip`);\n   126→    }\n   127→  }\n   128→\n   129→  return {\n   130→    rpcUrl: validatedUrl,\n   131→    network,\n   132→    fairnessBackendUrl: validatedBackendUrl.replace(/\\/$/, \"\"),\n   133→    coinflipProgramId,\n   134→    platformProgramId,\n   135→    lordofrngsProgramId,\n   136→  };\n   137→}\n   138→\n   139→/**\n   140→ * Verify that the devnet RPC is reachable and that required programs\n   141→ * are deployed. Call this once in globalSetup or the first test's beforeAll.\n   142→ */\n   143→export async function verifyDevnetDeployments(\n   144→  config: DevnetConfig,\n   145→): Promise<void> {\n   146→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n   147→\n   148→  // 1. RPC health check\n   149→  try {\n   150→    await connection.getLatestBlockhash();\n   151→  } catch (err) {\n   152→    throw new Error(\n   153→      `Cannot reach devnet RPC at ${config.rpcUrl}: ${err instanceof Error ? err.message : err}`,\n   154→    );\n   155→  }\n   156→\n   157→  // 2. Coinflip program deployed\n   158→  const coinflipAccount = await connection.getAccountInfo(\n   159→    config.coinflipProgramId,\n   160→  );\n   161→  if (!coinflipAccount || !coinflipAccount.executable) {\n   162→    throw new Error(\n   163→      `Coinflip program not found or not executable at ${config.coinflipProgramId.toBase58()}`,\n   164→    );\n   165→  }\n   166→\n   167→  // 3. Platform program deployed\n   168→  const platformAccount = await connection.getAccountInfo(\n   169→    config.platformProgramId,\n   170→  );\n   171→  if (!platformAccount || !platformAccount.executable) {\n   172→    throw new Error(\n   173→      `Platform program not found or not executable at ${config.platformProgramId.toBase58()}`,\n   174→    );\n   175→  }\n   176→\n   177→  // 4. Lord of RNGs program deployed (optional — skip if not configured)\n   178→  if (config.lordofrngsProgramId) {\n   179→    const lordAccount = await connection.getAccountInfo(\n   180→      config.lordofrngsProgramId,\n   181→    );\n   182→    if (!lordAccount || !lordAccount.executable) {\n   183→      throw new Error(\n   184→        `Lord of RNGs program not found or not executable at ${config.lordofrngsProgramId.toBase58()}`,\n   185→      );\n   186→    }\n   187→  }\n   188→}\n   189→\n   190→export async function verifyFairnessBackend(\n   191→  config: DevnetConfig,\n   192→): Promise<void> {\n   193→  const response = await fetch(`${config.fairnessBackendUrl}/health`);\n   194→  if (!response.ok) {\n   195→    throw new Error(\n   196→      `Fairness backend health check failed: ${response.status} ${response.statusText}`,\n   197→    );\n   198→  }\n   199→\n   200→  const json = (await response.json()) as {\n   201→    dbConnected?: boolean;\n   202→    workerRunning?: boolean;\n   203→    solBalance?: number;\n   204→  };\n   205→\n   206→  if (!json.dbConnected) {\n   207→    throw new Error(\"Fairness backend reports database disconnected\");\n   208→  }\n   209→  if (!json.workerRunning) {\n   210→    throw new Error(\"Fairness backend worker is not running\");\n   211→  }\n   212→  if (typeof json.solBalance !== \"number\" || json.solBalance <= 0) {\n   213→    throw new Error(\"Fairness backend server wallet is unfunded\");\n   214→  }\n   215→}\n   216→"}]},"parent_tool_use_id":null,"session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"0ce1adec-f24d-4a10-aef1-8f1a8907b671","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/helpers/env.ts","content":"/**\n * Devnet E2E environment contract.\n *\n * Validates that all required environment variables are present and well-formed\n * before any devnet test runs. Fails fast with clear error messages so CI\n * doesn't waste time on doomed runs.\n *\n * Required env vars:\n *   VITE_RPC_URL             — Devnet RPC endpoint (https URL)\n *   VITE_COINFLIP_PROGRAM_ID — Deployed coinflip program address (base58)\n *   VITE_PLATFORM_PROGRAM_ID — Deployed platform program address (base58)\n *   VITE_FAIRNESS_BACKEND_URL — Running fairness backend base URL (http(s) URL)\n *\n * Optional (with defaults):\n *   VITE_SOLANA_NETWORK      — Cluster name (default: \"devnet\")\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\n\n/** Validated devnet configuration. */\nexport interface DevnetConfig {\n  rpcUrl: string;\n  network: string;\n  fairnessBackendUrl: string;\n  coinflipProgramId: PublicKey;\n  platformProgramId: PublicKey;\n  /** Optional — falls back to IDL address if env var missing. */\n  lordofrngsProgramId: PublicKey | null;\n}\n\n/** Validate a base58 public key string. Throws if invalid. */\nfunction parsePublicKey(value: string, label: string): PublicKey {\n  try {\n    return new PublicKey(value);\n  } catch {\n    throw new Error(\n      `${label} is not a valid Solana address (base58): \"${value}\"`,\n    );\n  }\n}\n\n/** Validate a URL string. Throws if malformed. */\nfunction parseUrl(value: string, label: string): string {\n  try {\n    const url = new URL(value);\n    if (![\"http:\", \"https:\"].includes(url.protocol)) {\n      throw new Error(\"not http(s)\");\n    }\n    return value;\n  } catch {\n    throw new Error(\n      `${label} is not a valid HTTP(S) URL: \"${value}\"`,\n    );\n  }\n}\n\n/**\n * Read and validate all required devnet env vars.\n * Throws with a consolidated error listing every missing/invalid variable.\n */\nexport function validateDevnetEnv(): DevnetConfig {\n  const errors: string[] = [];\n\n  // --- Required ---\n  const rpcUrl = process.env.VITE_RPC_URL;\n  if (!rpcUrl) {\n    errors.push(\"VITE_RPC_URL is required (devnet RPC endpoint)\");\n  }\n\n  const coinflipId = process.env.VITE_COINFLIP_PROGRAM_ID;\n  if (!coinflipId) {\n    errors.push(\n      \"VITE_COINFLIP_PROGRAM_ID is required (deployed coinflip program address)\",\n    );\n  }\n\n  const platformId = process.env.VITE_PLATFORM_PROGRAM_ID;\n  if (!platformId) {\n    errors.push(\n      \"VITE_PLATFORM_PROGRAM_ID is required (deployed platform program address)\",\n    );\n  }\n\n  const fairnessBackendUrl = process.env.VITE_FAIRNESS_BACKEND_URL;\n  if (!fairnessBackendUrl) {\n    errors.push(\n      \"VITE_FAIRNESS_BACKEND_URL is required (running backend base URL)\",\n    );\n  }\n\n  // Fail fast if any required var is missing\n  if (errors.length > 0) {\n    throw new Error(\n      `Devnet E2E env validation failed:\\n  - ${errors.join(\"\\n  - \")}\\n\\n` +\n        `Hint: copy .env.devnet to .env.local and update program IDs, ` +\n        `or export the variables before running tests.`,\n    );\n  }\n\n  // --- Format validation ---\n  const validatedUrl = parseUrl(rpcUrl!, \"VITE_RPC_URL\");\n  const validatedBackendUrl = parseUrl(\n    fairnessBackendUrl!,\n    \"VITE_FAIRNESS_BACKEND_URL\",\n  );\n  const coinflipProgramId = parsePublicKey(\n    coinflipId!,\n    \"VITE_COINFLIP_PROGRAM_ID\",\n  );\n  const platformProgramId = parsePublicKey(\n    platformId!,\n    \"VITE_PLATFORM_PROGRAM_ID\",\n  );\n\n  // --- Optional with default ---\n  const network = process.env.VITE_SOLANA_NETWORK ?? \"devnet\";\n\n  // --- Optional lordofrngs (IDL fallback if env var missing) ---\n  const lordofrngsIdStr = process.env.VITE_LORDOFRNGS_PROGRAM_ID;\n  let lordofrngsProgramId: PublicKey | null = null;\n  if (lordofrngsIdStr) {\n    try {\n      lordofrngsProgramId = parsePublicKey(lordofrngsIdStr, \"VITE_LORDOFRNGS_PROGRAM_ID\");\n    } catch {\n      console.warn(`VITE_LORDOFRNGS_PROGRAM_ID is invalid: \"${lordofrngsIdStr}\" — Lord tests will skip`);\n    }\n  }\n\n  return {\n    rpcUrl: validatedUrl,\n    network,\n    fairnessBackendUrl: validatedBackendUrl.replace(/\\/$/, \"\"),\n    coinflipProgramId,\n    platformProgramId,\n    lordofrngsProgramId,\n  };\n}\n\n/**\n * Verify that the devnet RPC is reachable and that required programs\n * are deployed. Call this once in globalSetup or the first test's beforeAll.\n */\nexport async function verifyDevnetDeployments(\n  config: DevnetConfig,\n): Promise<void> {\n  const connection = new Connection(config.rpcUrl, \"confirmed\");\n\n  // 1. RPC health check\n  try {\n    await connection.getLatestBlockhash();\n  } catch (err) {\n    throw new Error(\n      `Cannot reach devnet RPC at ${config.rpcUrl}: ${err instanceof Error ? err.message : err}`,\n    );\n  }\n\n  // 2. Coinflip program deployed\n  const coinflipAccount = await connection.getAccountInfo(\n    config.coinflipProgramId,\n  );\n  if (!coinflipAccount || !coinflipAccount.executable) {\n    throw new Error(\n      `Coinflip program not found or not executable at ${config.coinflipProgramId.toBase58()}`,\n    );\n  }\n\n  // 3. Platform program deployed\n  const platformAccount = await connection.getAccountInfo(\n    config.platformProgramId,\n  );\n  if (!platformAccount || !platformAccount.executable) {\n    throw new Error(\n      `Platform program not found or not executable at ${config.platformProgramId.toBase58()}`,\n    );\n  }\n\n  // 4. Lord of RNGs program deployed (optional — skip if not configured)\n  if (config.lordofrngsProgramId) {\n    const lordAccount = await connection.getAccountInfo(\n      config.lordofrngsProgramId,\n    );\n    if (!lordAccount || !lordAccount.executable) {\n      throw new Error(\n        `Lord of RNGs program not found or not executable at ${config.lordofrngsProgramId.toBase58()}`,\n      );\n    }\n  }\n}\n\nexport async function verifyFairnessBackend(\n  config: DevnetConfig,\n): Promise<void> {\n  const response = await fetch(`${config.fairnessBackendUrl}/health`);\n  if (!response.ok) {\n    throw new Error(\n      `Fairness backend health check failed: ${response.status} ${response.statusText}`,\n    );\n  }\n\n  const json = (await response.json()) as {\n    dbConnected?: boolean;\n    workerRunning?: boolean;\n    solBalance?: number;\n  };\n\n  if (!json.dbConnected) {\n    throw new Error(\"Fairness backend reports database disconnected\");\n  }\n  if (!json.workerRunning) {\n    throw new Error(\"Fairness backend worker is not running\");\n  }\n  if (typeof json.solBalance !== \"number\" || json.solBalance <= 0) {\n    throw new Error(\"Fairness backend server wallet is unfunded\");\n  }\n}\n","numLines":216,"startLine":1,"totalLines":216}}}
