{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019b2eev11dHARtBHatErRMS","type":"tool_result","content":"     1→/**\n     2→ * On-chain pre-flight cleanup for deterministic devnet wallets.\n     3→ *\n     4→ * Deterministic wallets share match PDAs across test runs. Before creating\n     5→ * a new match, this module checks the on-chain state and clears stale\n     6→ * matches via direct on-chain transactions that match the current\n     7→ * backend-assisted commit-reveal contract.\n     8→ */\n     9→import {\n    10→  Connection,\n    11→  Keypair,\n    12→  PublicKey,\n    13→  SystemProgram,\n    14→  type TransactionInstruction,\n    15→} from \"@solana/web3.js\";\n    16→import {\n    17→  getCoinflipProgram,\n    18→  COINFLIP_PHASE_LOCKED,\n    19→  COINFLIP_PHASE_SETTLED,\n    20→  COINFLIP_PHASE_REFUNDED,\n    21→  COINFLIP_PHASE_WAITING,\n    22→  type MatchAccount,\n    23→} from \"../../local/helpers/on-chain\";\n    24→import { sendSignedTx } from \"./tx-utils\";\n    25→\n    26→/** Match phase extracted from the current numeric phase field. */\n    27→export type MatchPhase = \"waiting\" | \"locked\" | null;\n    28→\n    29→function toMatchPhase(phase: number): MatchPhase {\n    30→  switch (phase) {\n    31→    case COINFLIP_PHASE_WAITING:\n    32→      return \"waiting\";\n    33→    case COINFLIP_PHASE_LOCKED:\n    34→      return \"locked\";\n    35→    case COINFLIP_PHASE_SETTLED:\n    36→    case COINFLIP_PHASE_REFUNDED:\n    37→      return null;\n    38→    default:\n    39→      return null;\n    40→  }\n    41→}\n    42→\n    43→/**\n    44→ * Check the on-chain match state for a creator.\n    45→ * Uses memcmp filter to find any active match regardless of nonce.\n    46→ * Returns the phase string or null if no match PDA exists.\n    47→ */\n    48→export async function checkMatchState(\n    49→  connection: Connection,\n    50→  creator: PublicKey,\n    51→): Promise<{ phase: MatchPhase; match: MatchAccount | null; matchPda: PublicKey }> {\n    52→  const program = getCoinflipProgram(connection);\n    53→  const matches = await program.account.coinflipMatch.all([\n    54→    { memcmp: { offset: 8, bytes: creator.toBase58() } },\n    55→    { dataSize: program.account.coinflipMatch.size },\n    56→  ]);\n    57→  const activeMatches = matches.filter((m) => {\n    58→    const match = m.account as unknown as MatchAccount;\n    59→    return (\n    60→      match.phase !== COINFLIP_PHASE_SETTLED &&\n    61→      match.phase !== COINFLIP_PHASE_REFUNDED\n    62→    );\n    63→  });\n    64→\n    65→  if (activeMatches.length === 0) {\n    66→    return { phase: null, match: null, matchPda: PublicKey.default };\n    67→  }\n    68→\n    69→  const acc = activeMatches[0];\n    70→  const match = acc.account as unknown as MatchAccount;\n    71→  const matchPda = acc.publicKey;\n    72→  const phase = toMatchPhase(match.phase);\n    73→  return { phase, match, matchPda };\n    74→}\n    75→\n    76→async function buildCancelMatchIx(\n    77→  connection: Connection,\n    78→  creator: PublicKey,\n    79→  matchPda: PublicKey,\n    80→  server: PublicKey,\n    81→): Promise<TransactionInstruction> {\n    82→  const program = getCoinflipProgram(connection);\n    83→  return program.methods\n    84→    .cancelMatch()\n    85→    .accountsStrict({\n    86→      creator,\n    87→      coinflipMatch: matchPda,\n    88→      server,\n    89→      systemProgram: SystemProgram.programId,\n    90→    })\n    91→    .instruction();\n    92→}\n    93→\n    94→async function buildTimeoutRefundIx(\n    95→  connection: Connection,\n    96→  caller: PublicKey,\n    97→  matchPda: PublicKey,\n    98→  creator: PublicKey,\n    99→  opponent: PublicKey,\n   100→  server: PublicKey,\n   101→): Promise<TransactionInstruction> {\n   102→  const program = getCoinflipProgram(connection);\n   103→  return program.methods\n   104→    .timeoutRefund()\n   105→    .accountsStrict({\n   106→      caller,\n   107→      creator,\n   108→      opponent,\n   109→      server,\n   110→      coinflipMatch: matchPda,\n   111→    })\n   112→    .instruction();\n   113→}\n   114→\n   115→async function sendCleanupTx(\n   116→  connection: Connection,\n   117→  creatorKeypair: Keypair,\n   118→  phase: \"waiting\" | \"locked\",\n   119→  match: MatchAccount,\n   120→  matchPda: PublicKey,\n   121→  label: string,\n   122→): Promise<string> {\n   123→  const creator = creatorKeypair.publicKey;\n   124→\n   125→  if (phase === \"waiting\") {\n   126→    const ix = await buildCancelMatchIx(connection, creator, matchPda, match.server);\n   127→    return sendSignedTx(connection, [ix], creatorKeypair, `${label} cancelMatch`);\n   128→  }\n   129→\n   130→  // Locked phase: can only clean up via timeoutRefund after deadline expires\n   131→  const deadline = match.resolveDeadline.toNumber();\n   132→  const now = Math.floor(Date.now() / 1_000);\n   133→  if (!(deadline > 0 && now > deadline)) {\n   134→    throw new Error(\n   135→      `Settlement in-flight: ${label} has stale locked match (deadline=${deadline}, now=${now}). ` +\n   136→        `Wait for backend settlement or deadline expiry, then rerun. ` +\n   137→        `PDA: ${matchPda.toBase58()}`,\n   138→    );\n   139→  }\n   140→\n   141→  const ix = await buildTimeoutRefundIx(\n   142→    connection,\n   143→    creator,\n   144→    matchPda,\n   145→    match.creator,\n   146→    match.opponent,\n   147→    match.server,\n   148→  );\n   149→  return sendSignedTx(connection, [ix], creatorKeypair, `${label} timeoutRefund`);\n   150→}\n   151→\n   152→/**\n   153→ * Ensure a clean state for a deterministic wallet before creating a new match.\n   154→ *\n   155→ * - No match PDA → clean, return immediately\n   156→ * - \"waiting\" → on-chain cancelMatch\n   157→ * - \"locked\" + expired deadline → on-chain timeoutRefund\n   158→ * - \"locked\" + not yet expired → throw\n   159→ *\n   160→ * On tx failure, re-checks on-chain state before retrying. The tx may have\n   161→ * landed despite the error.\n   162→ */\n   163→export async function ensureCleanState(\n   164→  connection: Connection,\n   165→  creatorKeypair: Keypair,\n   166→  label: string,\n   167→): Promise<void> {\n   168→  const creator = creatorKeypair.publicKey;\n   169→  const MAX_ATTEMPTS = 2;\n   170→\n   171→  for (let attempt = 1; attempt <= MAX_ATTEMPTS; attempt += 1) {\n   172→    const { phase, match, matchPda } = await checkMatchState(connection, creator);\n   173→\n   174→    if (!phase || !match) {\n   175→      console.log(\n   176→        attempt === 1\n   177→          ? `[cleanup] ${label}: no stale match PDA — clean`\n   178→          : `[cleanup] ${label}: match PDA gone after attempt ${attempt - 1} — clean`,\n   179→      );\n   180→      return;\n   181→    }\n   182→\n   183→    console.log(\n   184→      `[cleanup] ${label}: stale match detected (phase=\"${phase}\", pda=${matchPda.toBase58()}, attempt=${attempt})`,\n   185→    );\n   186→\n   187→    try {\n   188→      await sendCleanupTx(connection, creatorKeypair, phase, match, matchPda, label);\n   189→    } catch (err) {\n   190→      const msg = err instanceof Error ? err.message : String(err);\n   191→      console.log(`[cleanup] ${label}: tx attempt ${attempt} failed — ${msg}`);\n   192→      if (attempt === MAX_ATTEMPTS) {\n   193→        const finalState = await checkMatchState(connection, creator);\n   194→        if (!finalState.phase) {\n   195→          console.log(`[cleanup] ${label}: match PDA gone despite tx error — clean`);\n   196→          return;\n   197→        }\n   198→        throw new Error(\n   199→          `[cleanup] ${label}: cleanup failed after ${MAX_ATTEMPTS} attempts. ` +\n   200→            `Last error: ${msg}. Match PDA still exists (phase=\"${finalState.phase}\").`,\n   201→        );\n   202→      }\n   203→      await new Promise((r) => setTimeout(r, 3_000));\n   204→      continue;\n   205→    }\n   206→\n   207→    const postCleanup = await checkMatchState(connection, creator);\n   208→    if (!postCleanup.phase) {\n   209→      console.log(`[cleanup] ${label}: cleanup complete — clean state verified`);\n   210→      return;\n   211→    }\n   212→\n   213→    console.log(\n   214→      `[cleanup] ${label}: WARNING — tx confirmed but match PDA persists (phase=\"${postCleanup.phase}\")`,\n   215→    );\n   216→  }\n   217→}\n   218→"}]},"parent_tool_use_id":"toolu_01J4DkMj6TbDT24GtmVyAJQv","session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"34f5129c-6ea9-4732-8c5d-674707753d08"}
