{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mvid6zoVCBpkqsLEUMdM4i","type":"tool_result","content":"     1→/**\n     2→ * Dual-browser-context fixture for devnet E2E tests.\n     3→ *\n     4→ * Same isolated dual-player pattern as local fixtures, but connects\n     5→ * to the devnet RPC instead of a local validator. The RPC URL comes\n     6→ * from the validated devnet env config.\n     7→ *\n     8→ * Usage in tests:\n     9→ * ```ts\n    10→ * import { test, expect } from \"./fixtures\";\n    11→ *\n    12→ * test(\"devnet lifecycle\", async ({ playerAPage, playerBPage, connection }) => {\n    13→ *   // playerAPage and playerBPage target devnet via real RPC\n    14→ * });\n    15→ * ```\n    16→ */\n    17→import { test as base, type BrowserContext, type Page } from \"@playwright/test\";\n    18→import { Keypair, Connection } from \"@solana/web3.js\";\n    19→import { PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    20→import { type DevnetConfig, validateDevnetEnv } from \"./helpers/env\";\n    21→\n    22→export interface DevnetDualPlayerFixtures {\n    23→  /** Validated devnet configuration (RPC URL, program IDs). */\n    24→  devnetConfig: DevnetConfig;\n    25→  /** Isolated browser context for player A (keypair injected). */\n    26→  playerAContext: BrowserContext;\n    27→  /** Isolated browser context for player B (keypair injected). */\n    28→  playerBContext: BrowserContext;\n    29→  /** Page within player A's context. */\n    30→  playerAPage: Page;\n    31→  /** Page within player B's context. */\n    32→  playerBPage: Page;\n    33→  /** Player A's deterministic keypair. */\n    34→  playerAKeypair: Keypair;\n    35→  /** Player B's deterministic keypair. */\n    36→  playerBKeypair: Keypair;\n    37→  /** Shared RPC connection to the devnet cluster. */\n    38→  connection: Connection;\n    39→}\n    40→\n    41→/**\n    42→ * Inject a 32-byte keypair seed into a new browser context via addInitScript.\n    43→ */\n    44→async function createPlayerContext(\n    45→  browser: BrowserContext[\"browser\"],\n    46→  keypair: Keypair,\n    47→): Promise<BrowserContext> {\n    48→  const context = await browser!.newContext();\n    49→  const seedArray = Array.from(keypair.secretKey.slice(0, 32));\n    50→  await context.addInitScript((seed: number[]) => {\n    51→    (window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ =\n    52→      new Uint8Array(seed);\n    53→  }, seedArray);\n    54→  return context;\n    55→}\n    56→\n    57→export const test = base.extend<DevnetDualPlayerFixtures>({\n    58→  // Validate devnet env once per test (sync, cached by Playwright)\n    59→  // eslint-disable-next-line no-empty-pattern\n    60→  devnetConfig: async ({}, use) => {\n    61→    const config = validateDevnetEnv();\n    62→    await use(config);\n    63→  },\n    64→\n    65→  // Expose keypairs as fixtures\n    66→  playerAKeypair: [PLAYER_A, { option: true }],\n    67→  playerBKeypair: [PLAYER_B, { option: true }],\n    68→\n    69→  // Shared connection to devnet\n    70→  connection: async ({ devnetConfig }, use) => {\n    71→    const conn = new Connection(devnetConfig.rpcUrl, {\n    72→      commitment: \"confirmed\",\n    73→      confirmTransactionInitialTimeout: 120_000,\n    74→    });\n    75→    await use(conn);\n    76→  },\n    77→\n    78→  // --- Player A context + page ---\n    79→  playerAContext: async ({ browser, playerAKeypair }, use) => {\n    80→    const context = await createPlayerContext(browser, playerAKeypair);\n    81→    await use(context);\n    82→    await context.close();\n    83→  },\n    84→\n    85→  playerAPage: async ({ playerAContext }, use) => {\n    86→    const page = await playerAContext.newPage();\n    87→    await use(page);\n    88→  },\n    89→\n    90→  // --- Player B context + page ---\n    91→  playerBContext: async ({ browser, playerBKeypair }, use) => {\n    92→    const context = await createPlayerContext(browser, playerBKeypair);\n    93→    await use(context);\n    94→    await context.close();\n    95→  },\n    96→\n    97→  playerBPage: async ({ playerBContext }, use) => {\n    98→    const page = await playerBContext.newPage();\n    99→    await use(page);\n   100→  },\n   101→});\n   102→\n   103→export { expect } from \"@playwright/test\";\n   104→"}]},"parent_tool_use_id":null,"session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"5aa75adb-56ad-4b32-a81d-9715bf4878db","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/fixtures.ts","content":"/**\n * Dual-browser-context fixture for devnet E2E tests.\n *\n * Same isolated dual-player pattern as local fixtures, but connects\n * to the devnet RPC instead of a local validator. The RPC URL comes\n * from the validated devnet env config.\n *\n * Usage in tests:\n * ```ts\n * import { test, expect } from \"./fixtures\";\n *\n * test(\"devnet lifecycle\", async ({ playerAPage, playerBPage, connection }) => {\n *   // playerAPage and playerBPage target devnet via real RPC\n * });\n * ```\n */\nimport { test as base, type BrowserContext, type Page } from \"@playwright/test\";\nimport { Keypair, Connection } from \"@solana/web3.js\";\nimport { PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\nimport { type DevnetConfig, validateDevnetEnv } from \"./helpers/env\";\n\nexport interface DevnetDualPlayerFixtures {\n  /** Validated devnet configuration (RPC URL, program IDs). */\n  devnetConfig: DevnetConfig;\n  /** Isolated browser context for player A (keypair injected). */\n  playerAContext: BrowserContext;\n  /** Isolated browser context for player B (keypair injected). */\n  playerBContext: BrowserContext;\n  /** Page within player A's context. */\n  playerAPage: Page;\n  /** Page within player B's context. */\n  playerBPage: Page;\n  /** Player A's deterministic keypair. */\n  playerAKeypair: Keypair;\n  /** Player B's deterministic keypair. */\n  playerBKeypair: Keypair;\n  /** Shared RPC connection to the devnet cluster. */\n  connection: Connection;\n}\n\n/**\n * Inject a 32-byte keypair seed into a new browser context via addInitScript.\n */\nasync function createPlayerContext(\n  browser: BrowserContext[\"browser\"],\n  keypair: Keypair,\n): Promise<BrowserContext> {\n  const context = await browser!.newContext();\n  const seedArray = Array.from(keypair.secretKey.slice(0, 32));\n  await context.addInitScript((seed: number[]) => {\n    (window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ =\n      new Uint8Array(seed);\n  }, seedArray);\n  return context;\n}\n\nexport const test = base.extend<DevnetDualPlayerFixtures>({\n  // Validate devnet env once per test (sync, cached by Playwright)\n  // eslint-disable-next-line no-empty-pattern\n  devnetConfig: async ({}, use) => {\n    const config = validateDevnetEnv();\n    await use(config);\n  },\n\n  // Expose keypairs as fixtures\n  playerAKeypair: [PLAYER_A, { option: true }],\n  playerBKeypair: [PLAYER_B, { option: true }],\n\n  // Shared connection to devnet\n  connection: async ({ devnetConfig }, use) => {\n    const conn = new Connection(devnetConfig.rpcUrl, {\n      commitment: \"confirmed\",\n      confirmTransactionInitialTimeout: 120_000,\n    });\n    await use(conn);\n  },\n\n  // --- Player A context + page ---\n  playerAContext: async ({ browser, playerAKeypair }, use) => {\n    const context = await createPlayerContext(browser, playerAKeypair);\n    await use(context);\n    await context.close();\n  },\n\n  playerAPage: async ({ playerAContext }, use) => {\n    const page = await playerAContext.newPage();\n    await use(page);\n  },\n\n  // --- Player B context + page ---\n  playerBContext: async ({ browser, playerBKeypair }, use) => {\n    const context = await createPlayerContext(browser, playerBKeypair);\n    await use(context);\n    await context.close();\n  },\n\n  playerBPage: async ({ playerBContext }, use) => {\n    const page = await playerBContext.newPage();\n    await use(page);\n  },\n});\n\nexport { expect } from \"@playwright/test\";\n","numLines":104,"startLine":1,"totalLines":104}}}
