{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_013zJ4BfCEHrFA9TZJPkktnX","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LZrd6qDdzKSRVjVcYFALVB","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/closecall-lifecycle.spec.ts","old_string":"  test(\"closecall lifecycle: bet both sides → settlement → verify\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n    devnetConfig,\n  }) => {","new_string":"  test(\"closecall lifecycle: bet both sides → settlement → verify\", async ({\n    playerAPage,\n    playerBPage,\n    devnetConfig,\n  }) => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":536,"cache_read_input_tokens":93574,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":536},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"dc4e0adb-a191-4f3c-a9c3-3d582b6caa06"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LZrd6qDdzKSRVjVcYFALVB","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/closecall-lifecycle.spec.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"e28046ee-fb65-4db2-a345-cd1ad1b8f946","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/closecall-lifecycle.spec.ts","oldString":"  test(\"closecall lifecycle: bet both sides → settlement → verify\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n    devnetConfig,\n  }) => {","newString":"  test(\"closecall lifecycle: bet both sides → settlement → verify\", async ({\n    playerAPage,\n    playerBPage,\n    devnetConfig,\n  }) => {","originalFile":"/**\n * Devnet E2E test for Close Call (Pyth oracle integration).\n *\n * Two test tiers:\n *   1. Infra (always runs): closecall program deployed, Pyth BTC/USD price\n *      account readable, backend closecall API responding, settled round data\n *      has real oracle prices.\n *   2. Lifecycle (conditional): place bets on both sides → wait for settlement\n *      → verify outcome + payouts. Skipped if clock worker has no active round\n *      (Pyth devnet prices update ~every 5 min and may be stale).\n */\nimport { test, expect } from \"./fixtures\";\nimport type { Page } from \"@playwright/test\";\nimport { Connection, LAMPORTS_PER_SOL, PublicKey } from \"@solana/web3.js\";\nimport { PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\nimport {\n  validateDevnetEnv,\n  verifyFairnessBackend,\n  type DevnetConfig,\n} from \"./helpers/env\";\nimport { withRetry } from \"./helpers/retry\";\n\n// ── Constants ────────────────────────────────────────────────────────\n\n/** Pyth BTC/USD push oracle price account on devnet. */\nconst PYTH_BTC_USD_DEVNET = new PublicKey(\n  \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n);\n\nconst MIN_BALANCE_SOL = 0.1;\n/** Wait up to 90s for clock worker to produce a round. */\nconst ROUND_WAIT_TIMEOUT_MS = 90_000;\n/** Wait up to 120s for settlement after candle close. */\nconst SETTLEMENT_TIMEOUT_MS = 120_000;\n/** Minimum remaining betting window to attempt placing bets (ms). */\nconst MIN_BETTING_WINDOW_MS = 12_000;\nconst BET_AMOUNT_SOL = \"0.005\";\n/** On-chain betting window duration (must match CloseCallConfig). */\nconst BETTING_WINDOW_SECS = 30;\n\n/** Devnet console noise patterns to ignore. */\nconst DEVNET_NOISE = [\n  \"favicon.ico\",\n  \"downloadable font\",\n  \"third-party cookie\",\n  \"429\",\n  \"Too Many Requests\",\n  \"WebSocket\",\n  \"ECONNRESET\",\n  \"socket hang up\",\n  \"FetchError\",\n  \"NetworkError\",\n  \"net::ERR_\",\n  \"ERR_BLOCKED_BY\",\n  \"Failed to load resource\",\n  \"NS_ERROR\",\n  \"Failed to fetch\",\n  \"Loading chunk\",\n];\n\nfunction filterNoise(errors: string[]): string[] {\n  return errors.filter(\n    (e) => !DEVNET_NOISE.some((p) => e.includes(p)),\n  );\n}\n\n// ── Backend API helpers ──────────────────────────────────────────────\n\ninterface BackendCloseCallRound {\n  roundId: string;\n  pda: string;\n  phase: \"open\" | \"settled\" | \"refunded\";\n  openPrice: number;\n  openPriceExpo: number;\n  closePrice: number | null;\n  outcome: \"pending\" | \"green\" | \"red\" | \"refund\";\n  greenPool: number;\n  redPool: number;\n  totalPool: number;\n  totalFee: number;\n  greenEntries: Array<{ player: string; amountLamports: number }>;\n  redEntries: Array<{ player: string; amountLamports: number }>;\n  greenCount: number;\n  redCount: number;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n}\n\nasync function fetchCurrentRound(\n  config: DevnetConfig,\n): Promise<BackendCloseCallRound | null> {\n  const resp = await fetch(\n    `${config.fairnessBackendUrl}/closecall/current-round`,\n  );\n  if (!resp.ok) return null;\n  const data = (await resp.json()) as { round: BackendCloseCallRound | null };\n  return data.round;\n}\n\nasync function fetchHistory(\n  config: DevnetConfig,\n  limit = 5,\n): Promise<BackendCloseCallRound[]> {\n  const resp = await fetch(\n    `${config.fairnessBackendUrl}/closecall/history?limit=${limit}`,\n  );\n  if (!resp.ok) return [];\n  const data = (await resp.json()) as { rounds: BackendCloseCallRound[] };\n  return data.rounds;\n}\n\n/** Remaining ms in the betting window for a round. */\nfunction remainingBettingMs(round: BackendCloseCallRound): number {\n  const bettingEndsAt =\n    new Date(round.createdAt).getTime() + BETTING_WINDOW_SECS * 1_000;\n  return bettingEndsAt - Date.now();\n}\n\n/**\n * Wait for a round whose betting window has enough time remaining\n * for both players to place bets.\n */\nasync function waitForBettableRound(\n  config: DevnetConfig,\n): Promise<BackendCloseCallRound | null> {\n  const start = Date.now();\n  while (Date.now() - start < ROUND_WAIT_TIMEOUT_MS) {\n    const round = await fetchCurrentRound(config);\n    if (round && round.phase === \"open\") {\n      const remaining = remainingBettingMs(round);\n      if (remaining >= MIN_BETTING_WINDOW_MS) {\n        return round;\n      }\n      // Betting window too short — wait for next round\n      console.log(\n        `[wait] Round ${round.roundId} has ${Math.round(remaining / 1_000)}s left — ` +\n          `need ${MIN_BETTING_WINDOW_MS / 1_000}s, waiting for next round...`,\n      );\n    }\n    await new Promise((r) => setTimeout(r, 3_000));\n  }\n  return null;\n}\n\nasync function waitForSettledRound(\n  config: DevnetConfig,\n  roundId: string,\n): Promise<BackendCloseCallRound> {\n  const start = Date.now();\n  while (Date.now() - start < SETTLEMENT_TIMEOUT_MS) {\n    // Check history for the settled round (it leaves current-round on settle)\n    const history = await fetchHistory(config, 10);\n    const settled = history.find((r) => r.roundId === roundId);\n    if (\n      settled &&\n      (settled.phase === \"settled\" || settled.phase === \"refunded\")\n    ) {\n      return settled;\n    }\n    await new Promise((r) => setTimeout(r, 3_000));\n  }\n  throw new Error(\n    `Timed out waiting for closecall round ${roundId} to settle`,\n  );\n}\n\n// ── Wallet funding check ─────────────────────────────────────────────\n\nasync function ensureFunded(\n  connection: Connection,\n  pubkey: PublicKey,\n  label: string,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    console.log(\n      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL ✓`,\n    );\n    return;\n  }\n  throw new Error(\n    `${label} has ${(balance / LAMPORTS_PER_SOL).toFixed(6)} SOL; ` +\n      `requires at least ${MIN_BALANCE_SOL} SOL. ` +\n      `Fund ${pubkey.toBase58()} and rerun.`,\n  );\n}\n\n// ── Console tracking ─────────────────────────────────────────────────\n\nfunction trackConsoleErrors(page: Page): { errors: string[] } {\n  const sink = { errors: [] as string[] };\n  page.on(\"console\", (msg) => {\n    if (msg.type() === \"error\") {\n      sink.errors.push(msg.text());\n    }\n  });\n  page.on(\"pageerror\", (err) => {\n    sink.errors.push(`[pageerror] ${err.message}`);\n  });\n  return sink;\n}\n\n// ── Tests ────────────────────────────────────────────────────────────\n\ntest.describe(\"closecall devnet oracle E2E\", () => {\n  test.beforeAll(async () => {\n    const config = validateDevnetEnv();\n    if (!config.closecallProgramId) {\n      console.log(\n        \"VITE_CLOSECALL_PROGRAM_ID not set — skipping Close Call E2E\",\n      );\n      return;\n    }\n    await verifyFairnessBackend(config);\n    console.log(\"Close Call devnet E2E: checking wallet funding...\");\n    const connection = new Connection(config.rpcUrl, \"confirmed\");\n    await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n    await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n  });\n\n  test(\"closecall infra: program deployed, Pyth readable, backend API responding\", async ({\n    devnetConfig,\n    connection,\n  }) => {\n    if (!devnetConfig.closecallProgramId) {\n      test.skip(true, \"VITE_CLOSECALL_PROGRAM_ID not configured\");\n      return;\n    }\n\n    // 1. Closecall program deployed + executable\n    const programAccount = await connection.getAccountInfo(\n      devnetConfig.closecallProgramId,\n    );\n    expect(programAccount).not.toBeNull();\n    expect(programAccount!.executable).toBe(true);\n    console.log(\n      `[infra] Closecall program deployed at ${devnetConfig.closecallProgramId.toBase58()} ✓`,\n    );\n\n    // 2. Pyth BTC/USD price account exists and is readable\n    const pythAccount = await connection.getAccountInfo(PYTH_BTC_USD_DEVNET);\n    expect(pythAccount).not.toBeNull();\n    expect(pythAccount!.data.length).toBeGreaterThan(0);\n    console.log(\n      `[infra] Pyth BTC/USD account readable (${pythAccount!.data.length} bytes) ✓`,\n    );\n\n    // 3. Backend closecall API responds\n    const currentResp = await fetch(\n      `${devnetConfig.fairnessBackendUrl}/closecall/current-round`,\n    );\n    expect(currentResp.ok).toBe(true);\n    const currentData = (await currentResp.json()) as {\n      round: BackendCloseCallRound | null;\n    };\n    console.log(\n      `[infra] GET /closecall/current-round: ${currentData.round ? \"round active\" : \"no active round\"} ✓`,\n    );\n\n    const historyResp = await fetch(\n      `${devnetConfig.fairnessBackendUrl}/closecall/history?limit=5`,\n    );\n    expect(historyResp.ok).toBe(true);\n    const historyData = (await historyResp.json()) as {\n      rounds: BackendCloseCallRound[];\n    };\n    console.log(\n      `[infra] GET /closecall/history: ${historyData.rounds.length} settled round(s) ✓`,\n    );\n\n    // 4. If history has rounds, verify data shape (real Pyth prices)\n    if (historyData.rounds.length > 0) {\n      const sample = historyData.rounds[0];\n      expect(sample.roundId).toBeTruthy();\n      expect(sample.pda).toBeTruthy();\n      expect(sample.openPrice).toBeDefined();\n      expect(sample.openPriceExpo).toBeDefined();\n      expect([\"settled\", \"refunded\"]).toContain(sample.phase);\n      console.log(\n        `[infra] Sample round ${sample.roundId}: ` +\n          `openPrice=${sample.openPrice}×10^${sample.openPriceExpo}, ` +\n          `outcome=${sample.outcome} ✓`,\n      );\n    }\n  });\n\n  test(\"closecall lifecycle: bet both sides → settlement → verify\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n    devnetConfig,\n  }) => {\n    if (!devnetConfig.closecallProgramId) {\n      test.skip(true, \"VITE_CLOSECALL_PROGRAM_ID not configured\");\n      return;\n    }\n\n    test.setTimeout(300_000);\n\n    const consoleA = trackConsoleErrors(playerAPage);\n    const consoleB = trackConsoleErrors(playerBPage);\n\n    // ── Phase 1: Wait for an open round with enough betting time ───────\n    console.log(\n      \"[phase-1] Waiting for clock worker to create a bettable round...\",\n    );\n    const openRound = await waitForBettableRound(devnetConfig);\n\n    if (!openRound) {\n      console.warn(\n        \"[phase-1] No bettable round within 90s — clock worker likely cannot \" +\n          \"create rounds (Pyth devnet prices may be stale, ~5 min update interval). \" +\n          \"Skipping lifecycle test. Infra test above validates oracle integration.\",\n      );\n      test.skip(\n        true,\n        \"No closecall round available (Pyth devnet price staleness)\",\n      );\n      return;\n    }\n\n    const roundId = openRound.roundId;\n    const remaining = remainingBettingMs(openRound);\n    console.log(\n      `[phase-1] Open round: ${roundId}, ` +\n        `openPrice=${openRound.openPrice}×10^${openRound.openPriceExpo}, ` +\n        `${Math.round(remaining / 1_000)}s betting window remaining ✓`,\n    );\n\n    // ── Phase 2: Player A bets GREEN ───────────────────────────────────\n    console.log(\"[phase-2] Player A navigating to /close-call...\");\n    await playerAPage.goto(\"/close-call\");\n    await playerAPage\n      .waitForLoadState(\"networkidle\", { timeout: 15_000 })\n      .catch(() => {});\n\n    // Wait for bet buttons to appear (proves round data loaded)\n    await expect(\n      playerAPage.locator(\".close-call-side-btn--green\").first(),\n    ).toBeVisible({ timeout: 30_000 });\n    console.log(\"[phase-2] Player A sees bet buttons ✓\");\n\n    // Input bet amount and click GREEN\n    const inputA = playerAPage.locator(\".close-call-bet-input__field\");\n    await inputA.fill(BET_AMOUNT_SOL);\n    await playerAPage.locator(\".close-call-side-btn--green\").click();\n    console.log(\"[phase-2] Player A clicked GREEN, waiting for tx...\");\n\n    // Wait for bet to register (selected state or user bet display)\n    await expect(\n      playerAPage\n        .locator(\n          \".close-call-pool-bar__user-bet, .close-call-side-btn--selected\",\n        )\n        .first(),\n    ).toBeVisible({ timeout: 30_000 });\n    console.log(\"[phase-2] Player A bet confirmed in UI ✓\");\n\n    // Verify bet on-chain via backend API\n    await withRetry(\n      async () => {\n        const round = await fetchCurrentRound(devnetConfig);\n        expect(round).not.toBeNull();\n        const hasPlayerA = round!.greenEntries.some(\n          (e) => e.player === PLAYER_A.publicKey.toBase58(),\n        );\n        expect(hasPlayerA).toBe(true);\n      },\n      { label: \"verifyPlayerABet\", retries: 5, delayMs: 2_000 },\n    );\n    console.log(\"[phase-2] Player A GREEN bet verified in backend ✓\");\n\n    // ── Phase 3: Player B bets RED ─────────────────────────────────────\n    console.log(\"[phase-3] Player B navigating to /close-call...\");\n    await playerBPage.goto(\"/close-call\");\n    await playerBPage\n      .waitForLoadState(\"networkidle\", { timeout: 15_000 })\n      .catch(() => {});\n\n    await expect(\n      playerBPage.locator(\".close-call-side-btn--red\").first(),\n    ).toBeVisible({ timeout: 30_000 });\n\n    const inputB = playerBPage.locator(\".close-call-bet-input__field\");\n    await inputB.fill(BET_AMOUNT_SOL);\n    await playerBPage.locator(\".close-call-side-btn--red\").click();\n    console.log(\"[phase-3] Player B clicked RED, waiting for tx...\");\n\n    await expect(\n      playerBPage\n        .locator(\n          \".close-call-pool-bar__user-bet, .close-call-side-btn--selected\",\n        )\n        .first(),\n    ).toBeVisible({ timeout: 30_000 });\n    console.log(\"[phase-3] Player B bet confirmed in UI ✓\");\n\n    await withRetry(\n      async () => {\n        const round = await fetchCurrentRound(devnetConfig);\n        expect(round).not.toBeNull();\n        const hasPlayerB = round!.redEntries.some(\n          (e) => e.player === PLAYER_B.publicKey.toBase58(),\n        );\n        expect(hasPlayerB).toBe(true);\n      },\n      { label: \"verifyPlayerBBet\", retries: 5, delayMs: 2_000 },\n    );\n    console.log(\"[phase-3] Player B RED bet verified in backend ✓\");\n\n    // ── Phase 4: Wait for settlement ───────────────────────────────────\n    console.log(\"[phase-4] Waiting for oracle settlement...\");\n    const settledRound = await waitForSettledRound(devnetConfig, roundId);\n    console.log(\n      `[phase-4] Round settled: outcome=${settledRound.outcome}, ` +\n        `closePrice=${settledRound.closePrice}×10^${settledRound.openPriceExpo}`,\n    );\n\n    // Verify settlement data\n    expect([\"green\", \"red\", \"refund\"]).toContain(settledRound.outcome);\n    expect(settledRound.closePrice).not.toBeNull();\n    expect(settledRound.settleTx).toBeTruthy();\n    expect(settledRound.settledAt).toBeTruthy();\n\n    if (\n      settledRound.outcome === \"green\" ||\n      settledRound.outcome === \"red\"\n    ) {\n      // Decisive round — fee should be collected\n      expect(settledRound.totalFee).toBeGreaterThan(0);\n      console.log(\n        `[phase-4] Decisive outcome: ${settledRound.outcome.toUpperCase()}, ` +\n          `fee=${settledRound.totalFee} lamports ✓`,\n      );\n    } else {\n      // Refund (equal price) — no fee\n      expect(settledRound.totalFee).toBe(0);\n      console.log(\"[phase-4] Equal price → refund, no fee ✓\");\n    }\n\n    // ── Phase 5: Verify round details page ─────────────────────────────\n    console.log(\"[phase-5] Verifying round details page...\");\n    await playerAPage.goto(`/close-call/${roundId}`);\n    await expect(\n      playerAPage.locator(\"h2, h3\").filter({ hasText: /Round Details/i }),\n    ).toBeVisible({ timeout: 15_000 });\n\n    // Round ID should appear on the page\n    await expect(\n      playerAPage.getByText(roundId).first(),\n    ).toBeVisible({ timeout: 5_000 });\n    console.log(\"[phase-5] Round details page verified ✓\");\n\n    // ── Console error check ────────────────────────────────────────────\n    const errA = filterNoise(consoleA.errors);\n    const errB = filterNoise(consoleB.errors);\n    if (errA.length > 0) console.warn(\"[console] Player A errors:\", errA);\n    if (errB.length > 0) console.warn(\"[console] Player B errors:\", errB);\n    expect(errA).toEqual([]);\n    expect(errB).toEqual([]);\n  });\n});\n","structuredPatch":[{"oldStart":288,"oldLines":7,"newStart":288,"newLines":6,"lines":["   test(\"closecall lifecycle: bet both sides → settlement → verify\", async ({","     playerAPage,","     playerBPage,","-    connection,","     devnetConfig,","   }) => {","     if (!devnetConfig.closecallProgramId) {"]}],"userModified":false,"replaceAll":false}}
