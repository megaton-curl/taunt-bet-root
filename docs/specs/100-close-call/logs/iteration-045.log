{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Su54ZsJqcNGMWw2aAUTe37","type":"tool_result","content":"     1→/**\n     2→ * Generic retry wrapper for on-chain assertions on devnet.\n     3→ *\n     4→ * Devnet RPC reads may lag behind state changes. This utility retries\n     5→ * an async assertion function with configurable delay and attempt count,\n     6→ * logging each attempt for observability.\n     7→ */\n     8→\n     9→export interface RetryOptions {\n    10→  /** Maximum number of attempts (default: 3). */\n    11→  retries?: number;\n    12→  /** Delay between retries in milliseconds (default: 2000). */\n    13→  delayMs?: number;\n    14→  /** Human-readable label for log messages. */\n    15→  label?: string;\n    16→}\n    17→\n    18→/**\n    19→ * Retry an async function up to `retries` times with a fixed delay between attempts.\n    20→ * The last error is re-thrown if all attempts fail.\n    21→ */\n    22→export async function withRetry<T>(\n    23→  fn: () => Promise<T>,\n    24→  opts: RetryOptions = {},\n    25→): Promise<T> {\n    26→  const { retries = 3, delayMs = 2_000, label = \"withRetry\" } = opts;\n    27→\n    28→  let lastError: unknown;\n    29→  for (let attempt = 1; attempt <= retries; attempt++) {\n    30→    try {\n    31→      return await fn();\n    32→    } catch (err) {\n    33→      lastError = err;\n    34→      if (attempt < retries) {\n    35→        console.log(\n    36→          `[retry] ${label}: attempt ${attempt}/${retries} failed, retrying in ${delayMs}ms — ${err instanceof Error ? err.message : String(err)}`,\n    37→        );\n    38→        await new Promise((r) => setTimeout(r, delayMs));\n    39→      }\n    40→    }\n    41→  }\n    42→  console.log(\n    43→    `[retry] ${label}: all ${retries} attempts exhausted`,\n    44→  );\n    45→  throw lastError;\n    46→}\n    47→"}]},"parent_tool_use_id":null,"session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"c774b8aa-aca2-4fca-86ec-89fb75cae85f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/helpers/retry.ts","content":"/**\n * Generic retry wrapper for on-chain assertions on devnet.\n *\n * Devnet RPC reads may lag behind state changes. This utility retries\n * an async assertion function with configurable delay and attempt count,\n * logging each attempt for observability.\n */\n\nexport interface RetryOptions {\n  /** Maximum number of attempts (default: 3). */\n  retries?: number;\n  /** Delay between retries in milliseconds (default: 2000). */\n  delayMs?: number;\n  /** Human-readable label for log messages. */\n  label?: string;\n}\n\n/**\n * Retry an async function up to `retries` times with a fixed delay between attempts.\n * The last error is re-thrown if all attempts fail.\n */\nexport async function withRetry<T>(\n  fn: () => Promise<T>,\n  opts: RetryOptions = {},\n): Promise<T> {\n  const { retries = 3, delayMs = 2_000, label = \"withRetry\" } = opts;\n\n  let lastError: unknown;\n  for (let attempt = 1; attempt <= retries; attempt++) {\n    try {\n      return await fn();\n    } catch (err) {\n      lastError = err;\n      if (attempt < retries) {\n        console.log(\n          `[retry] ${label}: attempt ${attempt}/${retries} failed, retrying in ${delayMs}ms — ${err instanceof Error ? err.message : String(err)}`,\n        );\n        await new Promise((r) => setTimeout(r, delayMs));\n      }\n    }\n  }\n  console.log(\n    `[retry] ${label}: all ${retries} attempts exhausted`,\n  );\n  throw lastError;\n}\n","numLines":47,"startLine":1,"totalLines":47}}}
