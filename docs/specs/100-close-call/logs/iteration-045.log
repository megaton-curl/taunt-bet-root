{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ZY2UGACpr4bXXDPNppxnh","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# run-e2e-devnet.sh — Single-entrypoint for devnet E2E tests.\n     3→# Runs Playwright tests against deployed devnet contracts with the fairness\n     4→# backend create/settle/verify flow.\n     5→set -euo pipefail\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n     8→APP_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     9→MONOREPO_DIR=\"$(cd \"$APP_DIR/../..\" && pwd)\"\n    10→BACKEND_DIR=\"$MONOREPO_DIR/services/backend\"\n    11→\n    12→# --- Auto-source env files (fill gaps, don't override existing vars) ---\n    13→# Source platform .env.local or .env.devnet for VITE_* vars\n    14→for envfile in \"$APP_DIR/.env.local\" \"$APP_DIR/.env.devnet\"; do\n    15→  if [ -f \"$envfile\" ]; then\n    16→    while IFS='=' read -r key value; do\n    17→      # Skip comments and empty lines\n    18→      [[ \"$key\" =~ ^[[:space:]]*# ]] && continue\n    19→      [[ -z \"$key\" ]] && continue\n    20→      key=\"$(echo \"$key\" | xargs)\"   # trim whitespace\n    21→      value=\"$(echo \"$value\" | xargs)\"\n    22→      # Only set if not already in environment\n    23→      if [ -z \"${!key:-}\" ]; then\n    24→        export \"$key=$value\"\n    25→      fi\n    26→    done < \"$envfile\"\n    27→    break  # use first file found\n    28→  fi\n    29→done\n    30→\n    31→# Source backend .env for DATABASE_URL, SERVER_KEYPAIR, RPC_URL\n    32→if [ -f \"$BACKEND_DIR/.env\" ]; then\n    33→  while IFS='=' read -r key value; do\n    34→    [[ \"$key\" =~ ^[[:space:]]*# ]] && continue\n    35→    [[ -z \"$key\" ]] && continue\n    36→    key=\"$(echo \"$key\" | xargs)\"\n    37→    value=\"$(echo \"$value\" | xargs)\"\n    38→    if [ -z \"${!key:-}\" ]; then\n    39→      export \"$key=$value\"\n    40→    fi\n    41→  done < \"$BACKEND_DIR/.env\"\n    42→fi\n    43→\n    44→# --- Ensure PostgreSQL is running ---\n    45→if ! pg_isready -q 2>/dev/null; then\n    46→  echo \"==> Starting PostgreSQL…\"\n    47→  pg_ctlcluster 16 main start 2>/dev/null || sudo pg_ctlcluster 16 main start 2>/dev/null || true\n    48→  for i in $(seq 1 10); do\n    49→    pg_isready -q 2>/dev/null && break\n    50→    sleep 1\n    51→  done\n    52→  if ! pg_isready -q 2>/dev/null; then\n    53→    echo \"❌ Could not start PostgreSQL\"\n    54→    exit 1\n    55→  fi\n    56→fi\n    57→\n    58→# Default devnet RPC for E2E runs unless caller overrides VITE_RPC_URL.\n    59→: \"${VITE_RPC_URL:=https://lb.drpc.live/solana-devnet/AvfNVeH0_E7ajvkIaZ0OS6SPdEhxK_YR8JjnEjfP07KJ}\"\n    60→: \"${VITE_FAIRNESS_BACKEND_URL:=http://127.0.0.1:3100}\"\n    61→: \"${RPC_URL:=$VITE_RPC_URL}\"\n    62→\n    63→# --- Env validation (fast-fail before starting Vite) ---\n    64→MISSING=()\n    65→[ -z \"${VITE_RPC_URL:-}\" ] && MISSING+=(\"VITE_RPC_URL\")\n    66→[ -z \"${VITE_COINFLIP_PROGRAM_ID:-}\" ] && MISSING+=(\"VITE_COINFLIP_PROGRAM_ID\")\n    67→[ -z \"${VITE_PLATFORM_PROGRAM_ID:-}\" ] && MISSING+=(\"VITE_PLATFORM_PROGRAM_ID\")\n    68→[ -z \"${VITE_FAIRNESS_BACKEND_URL:-}\" ] && MISSING+=(\"VITE_FAIRNESS_BACKEND_URL\")\n    69→\n    70→if [ ${#MISSING[@]} -gt 0 ]; then\n    71→  echo \"❌ Missing required env vars for devnet E2E: ${MISSING[*]}\"\n    72→  echo \"   Set them in your shell or in a .env.devnet file.\"\n    73→  exit 1\n    74→fi\n    75→\n    76→echo \"==> Devnet E2E config:\"\n    77→echo \"    RPC_URL:              $VITE_RPC_URL\"\n    78→echo \"    COINFLIP_PROGRAM_ID:  $VITE_COINFLIP_PROGRAM_ID\"\n    79→echo \"    PLATFORM_PROGRAM_ID:  $VITE_PLATFORM_PROGRAM_ID\"\n    80→echo \"    FAIRNESS_BACKEND_URL: $VITE_FAIRNESS_BACKEND_URL\"\n    81→echo \"    NETWORK:              ${VITE_SOLANA_NETWORK:-devnet}\"\n    82→\n    83→wait_for_health() {\n    84→  local url=\"$1\"\n    85→  local attempts=30\n    86→\n    87→  for ((i=1; i<=attempts; i++)); do\n    88→    if curl -fsS \"$url\" >/dev/null 2>&1; then\n    89→      return 0\n    90→    fi\n    91→    sleep 2\n    92→  done\n    93→\n    94→  return 1\n    95→}\n    96→\n    97→free_port_if_busy() {\n    98→  local port=\"$1\"\n    99→  local pids\n   100→  pids=\"$(lsof -ti \":$port\" 2>/dev/null || true)\"\n   101→  if [ -z \"$pids\" ]; then\n   102→    return 0\n   103→  fi\n   104→\n   105→  echo \"==> Reclaiming port $port from stale process(es): $pids\"\n   106→  while IFS= read -r pid; do\n   107→    [ -z \"$pid\" ] && continue\n   108→    kill \"$pid\" >/dev/null 2>&1 || true\n   109→  done <<< \"$pids\"\n   110→\n   111→  sleep 1\n   112→}\n   113→\n   114→cleanup() {\n   115→  if [ -n \"${BACKEND_PID:-}\" ]; then\n   116→    kill \"$BACKEND_PID\" >/dev/null 2>&1 || true\n   117→    wait \"$BACKEND_PID\" >/dev/null 2>&1 || true\n   118→  fi\n   119→}\n   120→\n   121→trap cleanup EXIT\n   122→\n   123→# --- Backend bootstrap / health ---\n   124→if curl -fsS \"${VITE_FAIRNESS_BACKEND_URL}/health\" >/dev/null 2>&1; then\n   125→  echo \"==> Using existing fairness backend\"\n   126→else\n   127→  [ -z \"${DATABASE_URL:-}\" ] && MISSING+=(\"DATABASE_URL\")\n   128→  [ -z \"${SERVER_KEYPAIR:-}\" ] && MISSING+=(\"SERVER_KEYPAIR\")\n   129→\n   130→  if [ ${#MISSING[@]} -gt 0 ]; then\n   131→    echo \"❌ Missing required env vars to boot the fairness backend: ${MISSING[*]}\"\n   132→    echo \"   Either start the backend manually or export DATABASE_URL and SERVER_KEYPAIR.\"\n   133→    exit 1\n   134→  fi\n   135→\n   136→  echo \"==> Running backend migrations…\"\n   137→  (\n   138→    cd \"$MONOREPO_DIR\"\n   139→    DATABASE_URL=\"$DATABASE_URL\" \\\n   140→    RPC_URL=\"$RPC_URL\" \\\n   141→    SERVER_KEYPAIR=\"$SERVER_KEYPAIR\" \\\n   142→    pnpm --filter @rng-utopia/backend migrate\n   143→  )\n   144→\n   145→  echo \"==> Starting fairness backend…\"\n   146→  BACKEND_LOG=\"$(mktemp -t rng-utopia-backend-devnet.XXXXXX.log)\"\n   147→  (\n   148→    cd \"$MONOREPO_DIR\"\n   149→    DATABASE_URL=\"$DATABASE_URL\" \\\n   150→    RPC_URL=\"$RPC_URL\" \\\n   151→    SERVER_KEYPAIR=\"$SERVER_KEYPAIR\" \\\n   152→    PORT=\"${PORT:-3100}\" \\\n   153→    pnpm --filter @rng-utopia/backend dev\n   154→  ) >\"$BACKEND_LOG\" 2>&1 &\n   155→  BACKEND_PID=$!\n   156→\n   157→  if ! wait_for_health \"${VITE_FAIRNESS_BACKEND_URL}/health\"; then\n   158→    echo \"❌ Fairness backend failed to become healthy\"\n   159→    echo \"   Log: $BACKEND_LOG\"\n   160→    exit 1\n   161→  fi\n   162→fi\n   163→\n   164→# --- Run tests ---\n   165→echo \"==> Running devnet E2E tests…\"\n   166→free_port_if_busy 3003\n   167→cd \"$APP_DIR\" && npx playwright test --config playwright.devnet.config.ts \"$@\"\n   168→\n   169→echo \"✅ Devnet E2E tests passed\"\n   170→"}]},"parent_tool_use_id":"toolu_01J4DkMj6TbDT24GtmVyAJQv","session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"525548c5-c6a7-455b-8721-80a0ab2cb8ce"}
