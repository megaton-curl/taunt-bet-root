{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012AmzgH7SJRsdeSRHRdh24a","type":"tool_result","content":"     1→/**\n     2→ * Shared E2E page-object helpers for coinflip tests.\n     3→ *\n     4→ * CSS-class-based selectors matching the actual component markup.\n     5→ * Provides create, join, claim, cancel actions and reusable wait/assert primitives.\n     6→ */\n     7→import { type Page, type Locator, expect } from \"@playwright/test\";\n     8→\n     9→// ---------------------------------------------------------------------------\n    10→// Selectors (CSS classes from CoinflipPage, ActiveMatchView, OpenMatchesList)\n    11→// ---------------------------------------------------------------------------\n    12→\n    13→export const sel = {\n    14→  // Page structure\n    15→  lobby: \".coinflip-lobby\",\n    16→  sidebar: \".coinflip-sidebar\",\n    17→  main: \".coinflip-main\",\n    18→\n    19→  // Sidebar — create flow\n    20→  sidebarTitle: \".coinflip-sidebar__title\",\n    21→  tierSelector: \".rng-tier-selector\",\n    22→  tierButton: (tier: string) => `.rng-tier-btn:has(.rng-tier-gem--${tier})`,\n    23→  tierButtonSelected: \".rng-tier-btn--selected\",\n    24→  sideSelector: \".coinflip-side-selector\",\n    25→  sideButtonHeads: \".coinflip-side-btn--heads\",\n    26→  sideButtonTails: \".coinflip-side-btn--tails\",\n    27→  sideButtonSelected: \".coinflip-side-btn--selected\",\n    28→  summary: \".coinflip-sidebar__summary\",\n    29→  actionButton: \".coinflip-action-btn\",\n    30→  actionButtonSecondary: \".coinflip-action-btn--secondary\",\n    31→\n    32→  // Lobby — open matches\n    33→  matchesList: \".coinflip-matches__list\",\n    34→  matchesCount: \".coinflip-matches__count\",\n    35→  matchCard: \".coinflip-match-card\",\n    36→  matchCardOwn: \".coinflip-match-card--own\",\n    37→  matchCardClaimable: \".coinflip-match-card--claimable\",\n    38→  matchCardJoinBtn: \".coinflip-match-card__join-btn\",\n    39→  matchCardAmount: \".coinflip-match-card__amount\",\n    40→  matchCardAddress: \".coinflip-match-card__address\",\n    41→\n    42→  // Active match view\n    43→  activeMatch: \".coinflip-active-match\",\n    44→  activeMatchTitle: \".coinflip-active-match__title\",\n    45→  activeMatchTitleWon: \".coinflip-active-match__title--won\",\n    46→  activeMatchTitleLost: \".coinflip-active-match__title--lost\",\n    47→  activeMatchWaiting: \".coinflip-active-match__waiting\",\n    48→  activeMatchPlaying: \".coinflip-active-match__playing\",\n    49→\n    50→  // Result\n    51→  resultOutcome: \".coinflip-result__outcome\",\n    52→  resultPayout: \".coinflip-result__payout\",\n    53→\n    54→  // Post-claim\n    55→  postClaim: \".coinflip-active-match__post-claim\",\n    56→\n    57→  // Error\n    58→  errorToast: \".rng-toast--error\",\n    59→  toastMessage: \".rng-toast__message\",\n    60→\n    61→  // Sidebar — active match info\n    62→  sidebarStatus: \".coinflip-sidebar__status\",\n    63→  sidebarPot: \".coinflip-sidebar__pot\",\n    64→} as const;\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Types\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export type CoinSide = \"heads\" | \"tails\";\n    71→\n    72→// ---------------------------------------------------------------------------\n    73→// Page-object actions\n    74→// ---------------------------------------------------------------------------\n    75→\n    76→/**\n    77→ * Navigate to the coinflip page and wait for the lobby to render.\n    78→ */\n    79→export async function navigateToCoinflip(page: Page): Promise<void> {\n    80→  await page.goto(\"/coinflip\", { waitUntil: \"domcontentloaded\" });\n    81→  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 15_000 });\n    82→}\n    83→\n    84→/**\n    85→ * Enter a wager amount in SOL into the WagerInput.\n    86→ */\n    87→export async function enterWager(page: Page, amountSol: number): Promise<void> {\n    88→  const input = page.locator(\".rng-wager-input__input\").first();\n    89→  await expect(input).toBeVisible({ timeout: 15_000 });\n    90→  await input.fill(amountSol.toString());\n    91→}\n    92→\n    93→/**\n    94→ * @deprecated Use enterWager instead.\n    95→ * Legacy tier selection — clicks a preset amount button that matches the old tier amount.\n    96→ */\n    97→export async function selectTier(page: Page, _tier: string): Promise<void> {\n    98→  // After tier→amount migration, select the 0.005 SOL preset (matches old \"iron\" tier)\n    99→  await enterWager(page, 0.005);\n   100→}\n   101→\n   102→/**\n   103→ * Select a coin side (heads or tails) in the sidebar.\n   104→ */\n   105→export async function selectSide(page: Page, side: CoinSide): Promise<void> {\n   106→  const selector =\n   107→    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n   108→  await page.click(selector);\n   109→  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n   110→}\n   111→\n   112→/**\n   113→ * Create a match: enter wager amount, select side, click \"Create Game\".\n   114→ * Returns when the active match view (waiting state) is visible.\n   115→ */\n   116→export async function createMatch(\n   117→  page: Page,\n   118→  amountOrTier: number | string,\n   119→  side: CoinSide,\n   120→  options?: { timeout?: number },\n   121→): Promise<void> {\n   122→  // Support both new amount (number) and legacy tier name (string)\n   123→  const amount = typeof amountOrTier === \"number\" ? amountOrTier : 0.005;\n   124→  await enterWager(page, amount);\n   125→  await selectSide(page, side);\n   126→\n   127→  // Click create — button text is \"Create Game\"\n   128→  const createBtn = page.locator(sel.actionButton, {\n   129→    hasText: \"Create Game\",\n   130→  });\n   131→  await expect(createBtn).toBeEnabled();\n   132→  await createBtn.click();\n   133→\n   134→  // Wait for transition to active match (waiting for opponent).\n   135→  // Default 15s is fine for local; devnet callers should pass a longer timeout.\n   136→  await page.waitForSelector(sel.activeMatch, {\n   137→    state: \"visible\",\n   138→    timeout: options?.timeout ?? 15_000,\n   139→  });\n   140→}\n   141→\n   142→/**\n   143→ * Join a match visible in the lobby. If `matchIndex` is provided, join that\n   144→ * specific card (0-based). Otherwise joins the first joinable match.\n   145→ */\n   146→export async function joinMatch(\n   147→  page: Page,\n   148→  matchIndex = 0,\n   149→): Promise<void> {\n   150→  const cards = page.locator("}]},"parent_tool_use_id":"toolu_01J4DkMj6TbDT24GtmVyAJQv","session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"34e3fe90-07d6-408d-975f-07d54d009e53"}
