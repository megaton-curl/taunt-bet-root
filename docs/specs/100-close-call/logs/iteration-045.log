{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DS3MmdNbmH2h1avqycCsRw","type":"tool_result","content":"     1→/**\n     2→ * On-chain pre-flight cleanup for Lord of RNGs devnet tests.\n     3→ *\n     4→ * Lord now settles through the backend-assisted commit-reveal path. Once a round\n     5→ * has two distinct players it remains `active` until either:\n     6→ * - the backend calls `claim_payout` after countdown + entropy slot, or\n     7→ * - anyone calls `timeout_refund` after the resolve deadline.\n     8→ *\n     9→ * There is no user-facing cancel path for a waiting round, so non-expired stale\n    10→ * waiting/active rounds must be surfaced as blockers instead of being \"cleaned\"\n    11→ * with old VRF-era fallback logic.\n    12→ */\n    13→import {\n    14→  Connection,\n    15→  Keypair,\n    16→  PublicKey,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import bs58 from \"bs58\";\n    20→import { LordofrngsIDL } from \"@rng-utopia/anchor-client\";\n    21→import { readFileSync } from \"node:fs\";\n    22→import { homedir } from \"node:os\";\n    23→import { join } from \"node:path\";\n    24→import {\n    25→  getLordProgram,\n    26→  getLordConfigPda,\n    27→  LORDOFRNGS_PROGRAM_ID,\n    28→  type JackpotRoundAccount,\n    29→} from \"../../local/helpers/on-chain\";\n    30→import { sendSignedTx } from \"./tx-utils\";\n    31→\n    32→function getInstructionDiscriminator(instructionName: string): Buffer {\n    33→  const instruction = LordofrngsIDL.instructions.find(\n    34→    (entry) => entry.name === instructionName,\n    35→  );\n    36→  if (!instruction) {\n    37→    throw new Error(`Instruction ${instructionName} not found in Lord IDL`);\n    38→  }\n    39→  return Buffer.from(instruction.discriminator);\n    40→}\n    41→\n    42→const LORD_TIMEOUT_REFUND_DISC = getInstructionDiscriminator(\"timeout_refund\");\n    43→const LORD_FORCE_CLOSE_DISC = getInstructionDiscriminator(\"force_close\");\n    44→\n    45→let cachedAuthorityKeypair: Keypair | null | undefined;\n    46→\n    47→function getDistinctPlayersInOrder(round: JackpotRoundAccount): PublicKey[] {\n    48→  const seen = new Set<string>();\n    49→  const players: PublicKey[] = [];\n    50→  for (const entry of round.entries) {\n    51→    const key = entry.player.toBase58();\n    52→    if (seen.has(key)) continue;\n    53→    seen.add(key);\n    54→    players.push(entry.player);\n    55→  }\n    56→  return players;\n    57→}\n    58→\n    59→/** Find all active (unclosed) jackpot rounds involving a player. */\n    60→async function findPlayerRounds(\n    61→  connection: Connection,\n    62→  player: PublicKey,\n    63→): Promise<{ roundPda: PublicKey; round: JackpotRoundAccount }[]> {\n    64→  const program = getLordProgram(connection);\n    65→  const discriminator = LordofrngsIDL.accounts.find(\n    66→    (entry) => entry.name === \"JackpotRound\",\n    67→  )?.discriminator;\n    68→  if (!discriminator) {\n    69→    throw new Error(\"jackpotRound discriminator not found in Lord IDL\");\n    70→  }\n    71→\n    72→  const accounts = await connection.getProgramAccounts(LORDOFRNGS_PROGRAM_ID, {\n    73→    filters: [\n    74→      {\n    75→        memcmp: {\n    76→          offset: 0,\n    77→          bytes: bs58.encode(Uint8Array.from(discriminator)),\n    78→        },\n    79→      },\n    80→    ],\n    81→  });\n    82→\n    83→  return accounts\n    84→    .map((account) => {\n    85→      try {\n    86→        const round = program.coder.accounts.decode(\n    87→          \"jackpotRound\",\n    88→          account.account.data,\n    89→        ) as JackpotRoundAccount;\n    90→        return { roundPda: account.pubkey, round };\n    91→      } catch {\n    92→        return null;\n    93→      }\n    94→    })\n    95→    .filter((entry): entry is { roundPda: PublicKey; round: JackpotRoundAccount } => entry !== null)\n    96→    .filter(({ round }) => {\n    97→      return (\n    98→        round.creator.equals(player) ||\n    99→        round.entries.some((entry) => entry.player.equals(player))\n   100→      );\n   101→    });\n   102→}\n   103→\n   104→/** Build a timeout_refund instruction for a Lord round. */\n   105→function buildTimeoutRefundIx(\n   106→  caller: PublicKey,\n   107→  roundPda: PublicKey,\n   108→  round: JackpotRoundAccount,\n   109→): TransactionInstruction {\n   110→  const [configPda] = getLordConfigPda();\n   111→  const data = Buffer.alloc(16);\n   112→  LORD_TIMEOUT_REFUND_DISC.copy(data, 0);\n   113→  Buffer.from(round.matchId as number[]).copy(data, 8);\n   114→\n   115→  const keys = [\n   116→    { pubkey: caller, isSigner: true, isWritable: true },\n   117→    { pubkey: roundPda, isSigner: false, isWritable: true },\n   118→    { pubkey: configPda, isSigner: false, isWritable: false },\n   119→    { pubkey: round.server, isSigner: false, isWritable: true }, // rent_receiver\n   120→    ...getDistinctPlayersInOrder(round).map((player) => ({\n   121→      pubkey: player,\n   122→      isSigner: false,\n   123→      isWritable: true,\n   124→    })),\n   125→  ];\n   126→\n   127→  return new TransactionInstruction({\n   128→    programId: LORDOFRNGS_PROGRAM_ID,\n   129→    keys,\n   130→    data,\n   131→  });\n   132→}\n   133→\n   134→function loadAuthorityKeypair(expectedAuthority: PublicKey): Keypair | null {\n   135→  if (cachedAuthorityKeypair !== undefined) {\n   136→    return cachedAuthorityKeypair;\n   137→  }\n   138→\n   139→  try {\n   140→    const keypairPath = join(homedir(), \".config\", \"solana\", \"id.json\");\n   141→    const secret = JSON.parse(readFileSync(keypairPath, \"utf8\")) as number[];\n   142→    const signer = Keypair.fromSecretKey(Uint8Array.from(secret));\n   143→    cachedAuthorityKeypair = signer.publicKey.equals(expectedAuthority) ? signer : null;\n   144→  } catch {\n   145→    cachedAuthorityKeypair = null;\n   146→  }\n   147→\n   148→  return cachedAuthorityKeypair;\n   149→}\n   150→\n   151→function buildForceCloseIx(\n   152→  authority: PublicKey,\n   153→  roundPda: PublicKey,\n   154→  round: JackpotRoundAccount,\n   155→): TransactionInstruction {\n   156→  const [configPda] = getLordConfigPda();\n   157→  const data = Buffer.alloc(16);\n   158→  LORD_FORCE_CLOSE_DISC.copy(data, 0);\n   159→  Buffer.from(round.matchId as number[]).copy(data, 8);\n   160→\n   161→  const keys = [\n   162→    { pubkey: authority, isSigner: true, isWritable: false },\n   163→    { pubkey: roundPda, isSigner: false, isWritable: true },\n   164→    { pubkey: configPda, isSigner: false, isWritable: false },\n   165→    { pubkey: round.server, isSigner: false, isWritable: true }, // rent_receiver\n   166→    ...getDistinctPlayersInOrder(round).map((player) => ({\n   167→      pubkey: player,\n   168→      isSigner: false,\n   169→      isWritable: true,\n   170→    })),\n   171→  ];\n   172→\n   173→  return new TransactionInstruction({\n   174→    programId: LORDOFRNGS_PROGRAM_ID,\n   175→    keys,\n   176→    data,\n   177→  });\n   178→}\n   179→\n   180→/**\n   181→ * Ensure a clean state for Lord of RNGs devnet tests.\n   182→ * Finds and cleans any stale rounds involving the given player.\n   183→ */\n   184→export async function ensureLordCleanState(\n   185→  connection: Connection,\n   186→  playerKeypair: Keypair,\n   187→  label: string,\n   188→): Promise<void> {\n   189→  const program = getLordProgram(connection);\n   190→  const [configPda] = getLordConfigPda();\n   191→  const config = await program.account.lordConfig.fetch(configPda);\n   192→  const authority = (config as { authority: PublicKey }).authority;\n   193→  const authorityKeypair = loadAuthorityKeypair(authority);\n   194→  const player = playerKeypair.publicKey;\n   195→  const rounds = await findPlayerRounds(connection, player);\n   196→\n   197→  if (rounds.length === 0) {\n   198→    console.log(`[lord-cleanup] ${label}: no stale rounds — clean`);\n   199→    return;\n   200→  }\n   201→\n   202→  for (const { roundPda, round } of rounds) {\n   203→    const phase = Object.keys(round.phase)[0] ?? \"unknown\";\n   204→    const resolveDeadline = round.resolveDeadline.toNumber();\n   205→    const now = Math.floor(Date.now() / 1_000);\n   206→\n   207→    console.log(\n   208→      `[lord-cleanup] ${label}: stale round detected (matchId=${Array.from(round.matchId as number[]).map((b: number) => b.toString(16).padStart(2, \"0\")).join(\"\")}, phase=\"${phase}\", pda=${roundPda.toBase58()})`,\n   209→    );\n   210→\n   211→    if (phase === \"active\" && resolveDeadline > 0 && now > resolveDeadline) {\n   212→      console.log(\n   213→        `[lord-cleanup] ${label}: resolve deadline passed — using timeoutRefund`,\n   214→      );\n   215→      const ix = buildTimeoutRefundIx(player, roundPda, round);\n   216→      await sendSignedTx(\n   217→        connection,\n   218→        [ix],\n   219→        playerKeypair,\n   220→        `${label} lordTimeoutRefund`,\n   221→      );\n   222→      console.log(`[lord-cleanup] ${label}: round cleaned via timeoutRefund`);\n   223→      continue;\n   224→    }\n   225→\n   226→    if (phase === \"waiting\" || phase === \"active\") {\n   227→      if (authorityKeypair) {\n   228→        console.log(\n   229→          `[lord-cleanup] ${label}: ${phase} round requires admin cleanup — using forceClose`,\n   230→        );\n   231→        const ix = buildForceCloseIx(authorityKeypair.publicKey, roundPda, round);\n   232→        await sendSignedTx(\n   233→          connection,\n   234→          [ix],\n   235→          authorityKeypair,\n   236→          `${label} lordForceClose`,\n   237→        );\n   238→        console.log(`[lord-cleanup] ${label}: round cleaned via forceClose`);\n   239→        continue;\n   240→      }\n   241→\n   242→      throw new Error(\n   243→        `Settlement in-flight or admin cleanup required: ${label} has stale ${phase} round ` +\n   244→          `(deadline=${resolveDeadline}, now=${now}). ` +\n   245→          `PDA: ${roundPda.toBase58()}`,\n   246→      );\n   247→    }\n   248→\n   249→    console.log(\n   250→      `[lord-cleanup] ${label}: round in unexpected phase \"${phase}\" — ignoring`,\n   251→    );\n   252→  }\n   253→}\n   254→"}]},"parent_tool_use_id":"toolu_01J4DkMj6TbDT24GtmVyAJQv","session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"b704a362-9d86-469c-93a3-35ed9613ed29"}
