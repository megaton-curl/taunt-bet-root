{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WMRtQ8gouAET5vh6EsT62H","type":"tool_result","content":"     1→/**\n     2→ * Devnet lifecycle E2E test for Lord of the RNGs:\n     3→ * UI create → UI join → countdown → backend settle → verify.\n     4→ */\n     5→import { test, expect } from \"./fixtures\";\n     6→import type { Page } from \"@playwright/test\";\n     7→import bs58 from \"bs58\";\n     8→import { LordofrngsIDL } from \"@rng-utopia/anchor-client\";\n     9→import * as po from \"../local/helpers/lord-page-objects\";\n    10→import { PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    11→import {\n    12→  validateDevnetEnv,\n    13→  verifyFairnessBackend,\n    14→  type DevnetConfig,\n    15→} from \"./helpers/env\";\n    16→import { withRetry } from \"./helpers/retry\";\n    17→import { ensureLordCleanState } from \"./helpers/lord-on-chain-cleanup\";\n    18→import {\n    19→  getLordProgram,\n    20→  getLordConfigPda,\n    21→  fetchLordRound,\n    22→  assertLordRoundClosed,\n    23→  assertLordTreasuryFee,\n    24→  snapshotBalance,\n    25→  LORDOFRNGS_PROGRAM_ID,\n    26→  type JackpotRoundAccount,\n    27→} from \"../local/helpers/on-chain\";\n    28→import { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n    29→\n    30→// ── Devnet wallet funding ─────────────────────────────────────────────\n    31→\n    32→const MIN_BALANCE_SOL = 0.1;\n    33→\n    34→async function ensureFunded(\n    35→  connection: Connection,\n    36→  pubkey: PublicKey,\n    37→  label: string,\n    38→): Promise<void> {\n    39→  const balance = await connection.getBalance(pubkey);\n    40→  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    41→    console.log(\n    42→      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL ✓`,\n    43→    );\n    44→    return;\n    45→  }\n    46→  throw new Error(\n    47→    `${label} has ${(balance / LAMPORTS_PER_SOL).toFixed(6)} SOL; ` +\n    48→      `requires at least ${MIN_BALANCE_SOL.toFixed(3)} SOL. ` +\n    49→      `Fund ${pubkey.toBase58()} and rerun.`,\n    50→  );\n    51→}\n    52→\n    53→// ── On-chain constants ───────────────────────────────────────────────\n    54→\n    55→const SETTLEMENT_TIMEOUT_MS = 180_000;\n    56→\n    57→interface BackendLordRoundResponse {\n    58→  pda: string;\n    59→  phase: \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    60→  commitment: string;\n    61→  matchId: string;\n    62→  secret?: string;\n    63→  resultHash?: string | null;\n    64→  winner?: string | null;\n    65→  settleTx?: string | null;\n    66→  entropy?: string | null;\n    67→  winningOffset?: string | null;\n    68→  winningEntryIndex?: number | null;\n    69→  payoutAmount?: number | null;\n    70→  feeAmount?: number | null;\n    71→  rentRefund?: number | null;\n    72→  totalAmountLamports?: number | null;\n    73→}\n    74→\n    75→/** Devnet console noise patterns to ignore. */\n    76→const DEVNET_NOISE = [\n    77→  \"favicon.ico\",\n    78→  \"downloadable font\",\n    79→  \"third-party cookie\",\n    80→  \"429\",\n    81→  \"Too Many Requests\",\n    82→  \"WebSocket\",\n    83→  \"ECONNRESET\",\n    84→  \"socket hang up\",\n    85→  \"FetchError\",\n    86→  \"NetworkError\",\n    87→  \"net::ERR_\",\n    88→  \"ERR_BLOCKED_BY\",\n    89→  \"Failed to load resource\",\n    90→  \"NS_ERROR\",\n    91→  // Expected race: browser auto-claim fires after programmatic claim already closed the round\n    92→  \"AccountNotInitialized\",\n    93→  \"simulation failed BEFORE wallet send\",\n    94→  \"Transaction will fail\",\n    95→];\n    96→\n    97→function filterNoise(errors: string[]): string[] {\n    98→  return errors.filter(\n    99→    (e) => !DEVNET_NOISE.some((p) => e.includes(p)),\n   100→  );\n   101→}\n   102→\n   103→/** Capture [settlement-event] console lines from a page. */\n   104→function captureSettlementEvents(page: Page): string[] {\n   105→  const lines: string[] = [];\n   106→  page.on(\"console\", (msg) => {\n   107→    if (\n   108→      msg.text().includes(\"[settlement-event]\") ||\n   109→      msg.text().includes(\"[lord-of-rngs] settlement-event\")\n   110→    ) {\n   111→      lines.push(msg.text());\n   112→    }\n   113→  });\n   114→  return lines;\n   115→}\n   116→\n   117→async function fetchBackendRound(\n   118→  config: DevnetConfig,\n   119→  roundPda: string,\n   120→): Promise<BackendLordRoundResponse | null> {\n   121→  const response = await fetch(\n   122→    `${config.fairnessBackendUrl}/fairness/rounds/${roundPda}`,\n   123→  );\n   124→  if (response.status === 404) {\n   125→    return null;\n   126→  }\n   127→  if (!response.ok) {\n   128→    throw new Error(\n   129→      `Backend round lookup failed (${response.status} ${response.statusText})`,\n   130→    );\n   131→  }\n   132→  return (await response.json()) as BackendLordRoundResponse;\n   133→}\n   134→\n   135→async function waitForSettledRound(\n   136→  config: DevnetConfig,\n   137→  roundPda: string,\n   138→): Promise<BackendLordRoundResponse> {\n   139→  const start = Date.now();\n   140→\n   141→  while (Date.now() - start < SETTLEMENT_TIMEOUT_MS) {\n   142→    const round = await fetchBackendRound(config, roundPda);\n   143→    if (round?.phase === \"settled\" && round.secret && round.settleTx) {\n   144→      return round;\n   145→    }\n   146→    await new Promise((resolve) => setTimeout(resolve, 2_000));\n   147→  }\n   148→\n   149→  throw new Error(`Timed out waiting for backend to settle round ${roundPda}`);\n   150→}\n   151→\n   152→async function findLatestPlayerRound(\n   153→  connection: Connection,\n   154→  player: PublicKey,\n   155→): Promise<{ roundPda: PublicKey; round: JackpotRoundAccount }> {\n   156→  const program = getLordProgram(connection);\n   157→  const discriminator = LordofrngsIDL.accounts.find(\n   158→    (entry) => entry.name === \"JackpotRound\",\n   159→  )?.discriminator;\n   160→  if (!discriminator) {\n   161→    throw new Error(\"JackpotRound discriminator not found in Lord IDL\");\n   162→  }\n   163→\n   164→  const accounts = await connection.getProgramAccounts(LORDOFRNGS_PROGRAM_ID, {\n   165→    filters: [\n   166→      {\n   167→        memcmp: {\n   168→          offset: 0,\n   169→          bytes: bs58.encode(Uint8Array.from(discriminator)),\n   170→        },\n   171→      },\n   172→    ],\n   173→  });\n   174→\n   175→  const rounds = accounts\n   176→    .map((account) => {\n   177→      try {\n   178→        const round = program.coder.accounts.decode(\n   179→          \"jackpotRound\",\n   180→          account.account.data,\n   181→        ) as JackpotRoundAccount;\n   182→        return { roundPda: account.pubkey, round };\n   183→      } catch {\n   184→        return null;\n   185→      }\n   186→    })\n   187→    .filter(\n   188→      (\n   189→        entry,\n   190→      ): entry is { roundPda: PublicKey; round: JackpotRoundAccount } =>\n   191→        entry !== null,\n   192→    )\n   193→    .filter(({ round }) =>\n   194→      round.entries.some((entry) => entry.player.equals(player)),\n   195→    )\n   196→    .sort((a, b) => b.round.createdAt.toNumber() - a.round.createdAt.toNumber());\n   197→\n   198→  const latest = rounds[0];\n   199→  if (!latest) {\n   200→    throw new Error(`No Lord round found for ${player.toBase58()}`);\n   201→  }\n   202→\n   203→  return latest;\n   204→}\n   205→\n   206→// ── Suite setup ────────────────────────────────────────────────────────\n   207→\n   208→test.beforeAll(async () => {\n   209→  const config = validateDevnetEnv();\n   210→  if (!config.lordofrngsProgramId) {\n   211→    console.log(\"VITE_LORDOFRNGS_PROGRAM_ID not set — skipping Lord lifecycle\");\n   212→    return;\n   213→  }\n   214→  await verifyFairnessBackend(config);\n   215→  console.log(\"Lord devnet lifecycle: checking wallet funding...\");\n   216→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n   217→  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n   218→  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n   219→});\n   220→\n   221→// ── Full lifecycle test ───────────────────────────────────────────────\n   222→\n   223→test(\"lord lifecycle: UI create → UI join → countdown → backend settle → verify\", async ({\n   224→  playerAPage,\n   225→  playerBPage,\n   226→  connection,\n   227→  devnetConfig,\n   228→}) => {\n   229→  if (!devnetConfig.lordofrngsProgramId) {\n   230→    test.skip(true, \"VITE_LORDOFRNGS_PROGRAM_ID not configured\");\n   231→    return;\n   232→  }\n   233→\n   234→  test.setTimeout(300_000);\n   235→\n   236→  // ── Pre-flight: clean stale rounds ──────────────────────────────────\n   237→  const cleanupResults = await Promise.allSettled([\n   238→    ensureLordCleanState(connection, PLAYER_A, \"Player A\"),\n   239→    ensureLordCleanState(connection, PLAYER_B, \"Player B\"),\n   240→  ]);\n   241→  for (const result of cleanupResults) {\n   242→    if (result.status === \"rejected\") {\n   243→      const err = result.reason;\n   244→      if (\n   245→        err instanceof Error &&\n   246→        err.message.includes(\"Settlement in-flight\")\n   247→      ) {\n   248→        test.skip(true, err.message);\n   249→      }\n   250→      throw err;\n   251→    }\n   252→  }\n   253→\n   254→  const consoleA = po.trackConsoleErrors(playerAPage);\n   255→  const consoleB = po.trackConsoleErrors(playerBPage);\n   256→\n   257→  // Capture settlement event WebSocket logs from both players\n   258→  const settlementEventsA = captureSettlementEvents(playerAPage);\n   259→  const settlementEventsB = captureSettlementEvents(playerBPage);\n   260→\n   261→  console.log(\"[phase-1] Player A navigating to Lord of RNGs...\");\n   262→  await po.navigateToLord(playerAPage);\n   263→\n   264→  const startBtn = playerAPage.locator(po.sel.actionButton, {\n   265→    hasText: /Start Round/i,\n   266→  });\n   267→  await expect(startBtn).toBeVisible({ timeout: 10_000 });\n   268→  console.log(\"[phase-1] 'Start Round' button visible ✓\");\n   269→\n   270→  await startBtn.click();\n   271→  console.log(\"[phase-1] Clicked 'Start Round', waiting for round to appear...\");\n   272→\n   273→  await playerAPage.waitForSelector(\n   274→    `${po.sel.activeRound}, ${po.sel.wheelLegendItem}`,\n   275→    { state: \"visible\", timeout: 60_000 },\n   276→  );\n   277→  console.log(\"[phase-1] Player A round created via UI ✓\");\n   278→\n   279→  const { roundPda, round: createdOnChainRound } = await withRetry(\n   280→    () =>\n   281→      findLatestPlayerRound(\n   282→        connection,\n   283→        PLAYER_A.publicKey,\n   284→      ),\n   285→    { label: \"findLatestPlayerRound\", retries: 10, delayMs: 1_000 },\n   286→  );\n   287→  let round = createdOnChainRound;\n   288→  const matchIdHex = Array.from(round.matchId as number[]).map((b: number) => b.toString(16).padStart(2, \"0\")).join(\"\");\n   289→  console.log(`[on-chain] Round PDA: ${roundPda.toBase58().slice(0, 12)}…, matchId=${matchIdHex}`);\n   290→  expect(round.entries.length).toBe(1);\n   291→\n   292→  const createdRound = await withRetry(\n   293→    async () => {\n   294→      const backendRound = await fetchBackendRound(devnetConfig, roundPda.toBase58());\n   295→      expect(backendRound).not.toBeNull();\n   296→      expect(backendRound?.phase).toBe(\"created\");\n   297→      expect(backendRound?.secret).toBeUndefined();\n   298→      return backendRound!;\n   299→    },\n   300→    { label: \"backend lord round created\", retries: 10, delayMs: 1_000 },\n   301→  );\n   302→  console.log(\n   303→    `[backend] Round created with commitment ${createdRound.commitment.slice(0, 12)}...`,\n   304→  );\n   305→\n   306→  console.log(\"[phase-2] Player B navigating...\");\n   307→  await po.navigateToLord(playerBPage);\n   308→  await expect(playerBPage.locator(po.sel.tierCard).first()).toBeVisible({\n   309→    timeout: 15_000,\n   310→  });\n   311→  await po.selectTier(playerBPage, 0);\n   312→\n   313→  // \"Join Round\" must be visible — proves Player B sees the existing round\n   314→  const joinBtn = playerBPage.locator(po.sel.actionButton, {\n   315→    hasText: /Join Round/i,\n   316→  });\n   317→  await expect(joinBtn).toBeVisible({ timeout: 15_000 });\n   318→  console.log(\"[phase-2] 'Join Round' button visible ✓\");\n   319→\n   320→  await joinBtn.click();\n   321→  console.log(\"[phase-2] Clicked 'Join Round', waiting for UI update...\");\n   322→\n   323→  await playerBPage.waitForSelector(\n   324→    `${po.sel.activeRound}, ${po.sel.wheelLegendItem}`,\n   325→    { state: \"visible\", timeout: 60_000 },\n   326→  );\n   327→  console.log(\"[phase-2] Player B joined via UI ✓\");\n   328→\n   329→  round = await withRetry(\n   330→    async () => {\n   331→      const r = await fetchLordRound(connection, roundPda);\n   332→      if (!r) throw new Error(\"Round PDA not found\");\n   333→      if (r.entries.length < 2) throw new Error(`Only ${r.entries.length} entry(s)`);\n   334→      return r;\n   335→    },\n   336→    { label: \"verifyTwoEntries\", retries: 5, delayMs: 3_000 },\n   337→  );\n   338→  expect(round.entries.length).toBe(2);\n   339→  const phase = Object.keys(round.phase)[0];\n   340→  console.log(`[on-chain] phase=\"${phase}\", entries=${round.entries.length} ✓`);\n   341→  expect(phase).toBe(\"active\");\n   342→\n   343→  const lordProgram = getLordProgram(connection);\n   344→  const [lordConfigPda] = getLordConfigPda();\n   345→  const lordConfig = await lordProgram.account.lordConfig.fetch(lordConfigPda);\n   346→  const treasury = (lordConfig as unknown as { treasury: PublicKey }).treasury;\n   347→  const treasuryBefore = await snapshotBalance(connection, treasury);\n   348→\n   349→  const settledRound = await waitForSettledRound(\n   350→    devnetConfig,\n   351→    roundPda.toBase58(),\n   352→  );\n   353→  console.log(`[backend] Round settled via ${settledRound.settleTx}`);\n   354→\n   355→  await Promise.all([\n   356→    po.waitForSettlementUi(playerAPage, 120_000),\n   357→    po.waitForSettlementUi(playerBPage, 120_000),\n   358→  ]);\n   359→  expect([\n   360→    PLAYER_A.publicKey.toBase58(),\n   361→    PLAYER_B.publicKey.toBase58(),\n   362→  ]).toContain(settledRound.winner);\n   363→\n   364→  expect(settledRound.secret).toMatch(/^[0-9a-f]{64}$/i);\n   365→  expect(settledRound.commitment).toMatch(/^[0-9a-f]{64}$/i);\n   366→  expect(settledRound.resultHash ?? \"\").toMatch(/^[0-9a-f]{64}$/i);\n   367→  expect(settledRound.entropy ?? \"\").toMatch(/^[0-9a-f]{64}$/i);\n   368→  expect(settledRound.winner).toBeTruthy();\n   369→  expect(settledRound.settleTx).toBeTruthy();\n   370→\n   371→  await withRetry(\n   372→    () => assertLordRoundClosed(connection, roundPda),\n   373→    { label: \"assertRoundClosed\" },\n   374→  );\n   375→  console.log(\"[phase-3] Round PDA closed after backend settlement ✓\");\n   376→\n   377→  await withRetry(\n   378→    () =>\n   379→      assertLordTreasuryFee(\n   380→        connection,\n   381→        treasury,\n   382→        treasuryBefore,\n   383→        settledRound.totalAmountLamports ?? round.totalAmountLamports.toNumber(),\n   384→      ),\n   385→    { label: \"assertTreasuryFee\" },\n   386→  );\n   387→  console.log(\"[phase-3] Treasury fee verified ✓\");\n   388→\n   389→  // ── Verify settlement event subscription fired ─────────────────────\n   390→  const allSettlementEvents = [...settlementEventsA, ...settlementEventsB];\n   391→  console.log(\n   392→    `[settlement-event] captured ${allSettlementEvents.length} event log(s):`,\n   393→  );\n   394→  allSettlementEvents.forEach((line) => console.log(`  ${line}`));\n   395→\n   396→  const subscribed = allSettlementEvents.some((l) => l.includes(\"subscribed\"));\n   397→  const matched = allSettlementEvents.some(\n   398→    (l) => l.includes(\"matched\") || l.includes(\"settlement-event received\"),\n   399→  );\n   400→  expect(subscribed).toBe(true);\n   401→  if (!matched) {\n   402→    console.warn(\n   403→      \"[settlement-event] WARNING: event subscription was active but \" +\n   404→        \"roundSettled event was not detected — polling won the race.\",\n   405→    );\n   406→  } else {\n   407→    console.log(\"[settlement-event] roundSettled event detected via WebSocket ✓\");\n   408→  }\n   409→\n   410→  const errA = filterNoise(consoleA.errors);\n   411→  const errB = filterNoise(consoleB.errors);\n   412→  expect(errA).toEqual([]);\n   413→  expect(errB).toEqual([]);\n   414→});\n   415→"}]},"parent_tool_use_id":"toolu_01J4DkMj6TbDT24GtmVyAJQv","session_id":"1de1cbce-bcf6-4659-9a0e-c65f55d25303","uuid":"240be93d-6f41-437b-a992-a7357e60c22e"}
