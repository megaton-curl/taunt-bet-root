     `,\n    41→      });\n    42→\n    43→      // Settle time for UI to stabilize\n    44→      await stablePage.waitForTimeout(300);\n    45→\n    46→      await expect(stablePage).toHaveScreenshot(\"home-connected.png\", { fullPage: true });\n    47→    });\n    48→  });\n    49→\n    50→  test.describe(\"Profile page\", () => {\n    51→    test(\"wallet connected\", async ({ stablePage }) => {\n    52→      // Clear persisted state first so connect generates fresh from seeded PRNG\n    53→      await stablePage.addInitScript(() => {\n    54→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n    55→      });\n    56→      await stablePage.goto(\"/profile\");\n    57→\n    58→      // Click the wallet connect button\n    59→      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n    60→\n    61→      // Wait for connected state\n    62→      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n    63→        timeout: 5000,\n    64→      });\n    65→\n    66→      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n    67→      await stablePage.addStyleTag({\n    68→        content: `\n    69→          *, *::before, *::after {\n    70→            animation-duration: 0s !important;\n    71→            animation-delay: 0s !important;\n    72→            transition-duration: 0s !important;\n    73→            transition-delay: 0s !important;\n    74→            scroll-behavior: auto !important;\n    75→          }\n    76→          svg { animation-play-state: paused !important; }\n    77→        `,\n    78→      });\n    79→\n    80→      // Settle time for UI to stabilize\n    81→      await stablePage.waitForTimeout(300);\n    82→\n    83→      // Avatar SVG has sub-pixel rendering variance; allow slightly higher threshold\n    84→      await expect(stablePage).toHaveScreenshot(\"profile-connected.png\", {\n    85→        fullPage: true,\n    86→        maxDiffPixelRatio: 0.03,\n    87→      });\n    88→    });\n    89→  });\n    90→\n    91→  test.describe(\"Lord of the RNGs page\", () => {\n    92→    test(\"round lobby — wallet disconnected\", async ({ stablePage }) => {\n    93→      await stablePage.addInitScript(() => {\n    94→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n    95→      });\n    96→      await stablePage.goto(\"/lord-of-rngs\");\n    97→\n    98→      // Wait for lobby to render (round cards or \"No open rounds\" message)\n    99→      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n   100→\n   101→      await expect(stablePage).toHaveScreenshot(\"lotr-lobby-disconnected.png\", { fullPage: true });\n   102→    });\n   103→\n   104→    test(\"round selected — shows sidebar and round view\", async ({ stablePage }) => {\n   105→      await stablePage.addInitScript(() => {\n   106→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   107→      });\n   108→      await stablePage.goto(\"/lord-of-rngs\");\n   109→\n   110→      // Wait for lobby to render\n   111→      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n   112→\n   113→      // Click the first round card if available\n   114→      const card = stablePage.locator(\".lotr-tier-card\").first();\n   115→      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n   116→        await card.click();\n   117→        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n   118→      }\n   119→\n   120→      // Settle UI transitions\n   121→      await stablePage.waitForTimeout(300);\n   122→\n   123→      await expect(stablePage).toHaveScreenshot(\"lotr-tier-selected.png\", { fullPage: true });\n   124→    });\n   125→\n   126→    test(\"round selected — wallet connected with sidebar controls\", async ({ stablePage }) => {\n   127→      await stablePage.addInitScript(() => {\n   128→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   129→      })