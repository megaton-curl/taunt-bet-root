{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016C4t1KaY3wBMLXCEMMK6A1","type":"tool_result","content":"     1→import { defineConfig, devices } from \"@playwright/test\";\n     2→\n     3→const visualPort = Number(process.env.PLAYWRIGHT_PLATFORM_PORT ?? \"3000\");\n     4→const visualBaseUrl = `http://127.0.0.1:${visualPort}`;\n     5→\n     6→export default defineConfig({\n     7→  testDir: \"./e2e\",\n     8→  fullyParallel: true,\n     9→  forbidOnly: !!process.env.CI,\n    10→  retries: 0,\n    11→  workers: 1,\n    12→  reporter: \"list\",\n    13→\n    14→  snapshotPathTemplate:\n    15→    \"{testDir}/__snapshots__/{testFilePath}/{arg}{ext}\",\n    16→\n    17→  expect: {\n    18→    toHaveScreenshot: {\n    19→      maxDiffPixelRatio: 0.015,\n    20→    },\n    21→  },\n    22→\n    23→  use: {\n    24→    baseURL: visualBaseUrl,\n    25→    screenshot: \"off\",\n    26→    trace: \"off\",\n    27→    ...devices[\"Desktop Chrome\"],\n    28→    viewport: { width: 1280, height: 1080 },\n    29→  },\n    30→\n    31→  projects: [\n    32→    {\n    33→      name: \"chromium\",\n    34→      testMatch: \"visual/**/*.spec.ts\",\n    35→      use: { ...devices[\"Desktop Chrome\"], viewport: { width: 1280, height: 1080 } },\n    36→    },\n    37→  ],\n    38→\n    39→  webServer: {\n    40→    command: `npx vite --port ${visualPort}`,\n    41→    url: visualBaseUrl,\n    42→    reuseExistingServer: !process.env.CI,\n    43→    timeout: 30_000,\n    44→    env: {\n    45→      VITE_MOCK_MODE: \"true\",\n    46→    },\n    47→  },\n    48→});\n    49→"}]},"parent_tool_use_id":"toolu_015vPNsbnN89k8x4Vzo53PNA","session_id":"c8c62976-263f-4cf9-9e61-e0f9f45b35cf","uuid":"69180558-1cb0-48d6-a9cc-2a91384b7b51"}
