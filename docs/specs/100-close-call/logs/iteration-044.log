{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K1CfAyoVBmVuGkAo6xBDes","type":"tool_result","content":"     1→import { useEffect, useRef, useState } from \"react\";\n     2→import {\n     3→  createChart,\n     4→  CandlestickSeries,\n     5→  type IChartApi,\n     6→  type ISeriesApi,\n     7→  type CandlestickData,\n     8→  type Time,\n     9→} from \"lightweight-charts\";\n    10→import type { Candle } from \"../types\";\n    11→import { SIDE_COLORS, CANDLE_DURATION_MS, BETTING_WINDOW_MS } from \"../types\";\n    12→\n    13→// Muted colors for history candles\n    14→const HISTORY_COLORS = {\n    15→  up: \"rgba(69, 176, 88, 0.35)\",\n    16→  down: \"rgba(220, 53, 69, 0.35)\",\n    17→};\n    18→\n    19→interface CandlestickChartProps {\n    20→  candles: Candle[];\n    21→  currentPrice: number;\n    22→  progress: number;\n    23→}\n    24→\n    25→export function CandlestickChart({\n    26→  candles,\n    27→  currentPrice,\n    28→  progress,\n    29→}: CandlestickChartProps) {\n    30→  const chartContainerRef = useRef<HTMLDivElement>(null);\n    31→  const chartRef = useRef<IChartApi | null>(null);\n    32→  const historySeriesRef = useRef<ISeriesApi<\"Candlestick\"> | null>(null);\n    33→  const currentSeriesRef = useRef<ISeriesApi<\"Candlestick\"> | null>(null);\n    34→\n    35→  // Track the forming candle using a ref to avoid stale closures\n    36→  const formingCandleRef = useRef<{\n    37→    openTime: number;\n    38→    open: number;\n    39→    high: number;\n    40→    low: number;\n    41→  } | null>(null);\n    42→\n    43→  // Force re-render when forming candle changes\n    44→  const [, forceUpdate] = useState(0);\n    45→\n    46→  // Get the current forming candle (last in array)\n    47→  const currentCandle = candles.length > 0 ? candles[candles.length - 1]! : null;\n    48→\n    49→  // Get history candles (5 before the current one)\n    50→  const historyCandles = candles.length > 1 ? candles.slice(-6, -1) : [];\n    51→\n    52→  // Reset forming candle when a new candle starts (openTime changes)\n    53→  // For mock mode, use actual candle OHLC for realistic initial display\n    54→  if (currentCandle) {\n    55→    const forming = formingCandleRef.current;\n    56→    if (!forming || forming.openTime !== currentCandle.openTime) {\n    57→      formingCandleRef.current = {\n    58→        openTime: currentCandle.openTime,\n    59→        open: currentCandle.open,\n    60→        high: currentCandle.high,\n    61→        low: currentCandle.low,\n    62→      };\n    63→    }\n    64→  }\n    65→\n    66→  // Update high/low as price changes\n    67→  useEffect(() => {\n    68→    const forming = formingCandleRef.current;\n    69→    if (!forming || currentPrice <= 0) return;\n    70→\n    71→    const newHigh = Math.max(forming.high, currentPrice);\n    72→    const newLow = Math.min(forming.low, currentPrice);\n    73→\n    74→    if (newHigh !== forming.high || newLow !== forming.low) {\n    75→      forming.high = newHigh;\n    76→      forming.low = newLow;\n    77→      forceUpdate(n => n + 1);\n    78→    }\n    79→  }, [currentPrice]);\n    80→\n    81→  // Calculate display values for current candle\n    82→  // Only use currentPrice if it's a valid positive number (avoids 0 on initial load)\n    83→  const forming = formingCandleRef.current;\n    84→  const validPrice = currentPrice > 0 ? currentPrice : null;\n    85→  const displayOpen = forming?.open ?? currentCandle?.open ?? 0;\n    86→  const displayHigh = forming\n    87→    ? Math.max(forming.high, validPrice ?? forming.high)\n    88→    : validPrice ?? currentCandle?.high ?? displayOpen;\n    89→  const displayLow = forming\n    90→    ? Math.min(forming.low, validPrice ?? forming.low)\n    91→    : validPrice ?? currentCandle?.low ?? displayOpen;\n    92→  const displayClose = validPrice ?? displayOpen;\n    93→\n    94→  const isUp = displayClose >= displayOpen;\n    95→\n    96→  // Format price for display\n    97→  const formatPrice = (price: number): string => {\n    98→    return price.toLocaleString(\"en-US\", {\n    99→      minimumFractionDigits: 2,\n   100→      maximumFractionDigits: 2,"}]},"parent_tool_use_id":"toolu_01Q4RnwHp9k8Rw4qk4bmE7TV","session_id":"c8c62976-263f-4cf9-9e61-e0f9f45b35cf","uuid":"438c7a7e-f52d-4e42-9a14-b82fdac7496b"}
