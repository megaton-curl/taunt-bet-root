{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E7f34LjNAb5xuQzXF3AtRa","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useEffect,\n     6→  useCallback,\n     7→  useMemo,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    11→import type {\n    12→  Round,\n    13→  BetSide,\n    14→  Candle,\n    15→  UserRoundHistory,\n    16→  CloseCallContextValue,\n    17→} from \"../types\";\n    18→import {\n    19→  DEFAULT_BET_AMOUNT,\n    20→  MIN_BET_AMOUNT,\n    21→  MAX_BET_AMOUNT,\n    22→} from \"../types\";\n    23→import {\n    24→  initializeGame,\n    25→  subscribeToRound,\n    26→  subscribeToCompletedRound,\n    27→  placeBet as mockPlaceBet,\n    28→  getCurrentRound,\n    29→  getUserHistory,\n    30→  getRecentCandles,\n    31→  getCurrentCandle,\n    32→  getCandleProgress,\n    33→  isGameInitialized,\n    34→  clearCompletedRound as mockClearCompletedRound,\n    35→} from \"../utils/mock-simulation\";\n    36→import { calculatePotentialPayout } from \"../utils/payout-calculator\";\n    37→\n    38→// Default context value\n    39→const defaultContextValue: CloseCallContextValue = {\n    40→  currentRound: null,\n    41→  completedRound: null,\n    42→  recentCandles: [],\n    43→  currentPrice: 0,\n    44→  candleProgress: 0,\n    45→  userHistory: [],\n    46→  pendingAmount: DEFAULT_BET_AMOUNT,\n    47→  pendingSide: null,\n    48→  userBet: null,\n    49→  loading: true,\n    50→  placingBet: false,\n    51→  setPendingAmount: () => {},\n    52→  setPendingSide: () => {},\n    53→  placeBet: async () => {},\n    54→  adjustBetAmount: () => {},\n    55→  clearCompletedRound: () => {},\n    56→  potentialPayout: 0,\n    57→  userOdds: 0,\n    58→  refreshRound: () => {},\n    59→};\n    60→\n    61→const CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n    62→\n    63→export function CloseCallProvider({ children }: { children: ReactNode }) {\n    64→  const { address, getBalance } = useWallet();\n    65→\n    66→  // Round state\n    67→  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n    68→  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n    69→  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n    70→  const [currentPrice, setCurrentPrice] = useState(0);\n    71→  const [candleProgress, setCandleProgress] = useState(0);\n    72→\n    73→  // User state\n    74→  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n    75→  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n    76→  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n    77→\n    78→  // Loading states\n    79→  const [loading, setLoading] = useState(true);\n    80→  const [placingBet, setPlacingBet] = useState(false);\n    81→\n    82→  // Get user's bet in current round\n    83→  const userBet = useMemo(() => {\n    84→    if (!currentRound || !address) return null;\n    85→\n    86→    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    87→    return allBets.find((b) => b.address === address) ?? null;\n    88→  }, [currentRound, address]);\n    89→\n    90→  // Calculate potential payout\n    91→  const potentialPayout = useMemo(() => {\n    92→    if (!currentRound) return 0;\n    93→\n    94→    // If user has an active bet, calculate payout based on their bet\n    95→    if (userBet) {\n    96→      return calculatePotentialPayout(\n    97→        userBet.amount,\n    98→        userBet.side,\n    99→        currentRound.pool\n   100→      );\n   101→    }\n   102→\n   103→    // Otherwise show preview based on pending selection\n   104→    if (!pendingSide || pendingAmount <= 0) return 0;\n   105→\n   106→    return calculatePotentialPayout(\n   107→      pendingAmount,\n   108→      pendingSide,\n   109→      currentRound.pool\n   110→    );\n   111→  }, [pendingAmount, pendingSide, currentRound, userBet]);\n   112→\n   113→  // Calculate user's odds (share of winning pool)\n   114→  const userOdds = useMemo(() => {\n   115→    if (!userBet || !currentRound) return 0;\n   116→\n   117→    const winningPool =\n   118→      userBet.side === \"green\"\n   119→        ? currentRound.pool.greenPool\n   120→        : currentRound.pool.redPool;\n   121→\n   122→    if (winningPool === 0) return 0;\n   123→\n   124→    return (userBet.amount / winningPool) * 100;\n   125→  }, [userBet, currentRound]);\n   126→\n   127→  // Initialize game on mount\n   128→  useEffect(() => {\n   129→    if (!isGameInitialized()) {\n   130→      initializeGame();\n   131→    }\n   132→\n   133→    // Set initial state\n   134→    const round = getCurrentRound();\n   135→    if (round) {\n   136→      setCurrentRound(round);\n   137→    }\n   138→\n   139→    // Build candles array: completed candles + current forming candle\n   140→    const completedCandles = getRecentCandles(15);\n   141→    const currentCandle = getCurrentCandle();\n   142→    if (currentCandle) {\n   143→      setRecentCandles([...completedCandles, currentCandle]);\n   144→    } else {\n   145→      setRecentCandles(completedCandles);\n   146→    }\n   147→    setLoading(false);\n   148→\n   149→    // Subscribe to round updates\n   150→    const unsubscribeRound = subscribeToRound((round) => {\n   151→      setCurrentRound(round);\n   152→\n   153→      // Update candles: completed + current forming\n   154→      const completed = getRecentCandles(15);\n   155→      const current = getCurrentCandle();\n   156→      if (current) {\n   157→        setRecentCandles([...completed, current]);\n   158→      } else {\n   159→        setRecentCandles(completed);\n   160→      }\n   161→    });\n   162→\n   163→    // Subscribe to completed round updates\n   164→    const unsubscribeCompleted = subscribeToCompletedRound((round) => {\n   165→      setCompletedRound(round);\n   166→    });\n   167→\n   168→    // Poll for price/progress updates\n   169→    const pollInterval = setInterval(() => {\n   170→      const candle = getCurrentCandle();\n   171→      if (candle) {\n   172→        const progress = getCandleProgress();\n   173→        setCandleProgress(progress);\n   174→\n   175→        // Interpolate current price\n   176→        const { open, high, low, close } = candle;\n   177→        const isBullish = close > open;\n   178→\n   179→        let price: number;\n   180→        if (isBullish) {\n   181→          if (progress < 0.2) {\n   182→            price = open + (low - open) * (progress / 0.2) * 0.7;\n   183→          } else if (progress < 0.7) {\n   184→            const lowPoint = open + (low - open) * 0.7;\n   185→            price = lowPoint + (high - lowPoint) * ((progress - 0.2) / 0.5);\n   186→          } else {\n   187→            price = high + (close - high) * ((progress - 0.7) / 0.3);\n   188→          }\n   189→        } else {\n   190→          if (progress < 0.2) {\n   191→            price = open + (high - open) * (progress / 0.2) * 0.7;\n   192→          } else if (progress < 0.7) {\n   193→            const highPoint = open + (high - open) * 0.7;\n   194→            price = highPoint + (low - highPoint) * ((progress - 0.2) / 0.5);\n   195→          } else {\n   196→            price = low + (close - low) * ((progress - 0.7) / 0.3);\n   197→          }\n   198→        }\n   199→\n   200→        setCurrentPrice(price);\n   201→\n   202→        // Update candles: completed + current forming\n   203→        const completed = getRecentCandles(15);\n   204→        setRecentCandles([...completed, candle]);\n   205→      }\n   206→    }, 100);\n   207→\n   208→    return () => {\n   209→      unsubscribeRound();\n   210→      unsubscribeCompleted();\n   211→      clearInterval(pollInterval);\n   212→    };\n   213→  }, []);\n   214→\n   215→  // Update user history when address changes\n   216→  useEffect(() => {\n   217→    if (address) {\n   218→      const history = getUserHistory(address).sort(\n   219→        (a, b) => (b.round.resolvedAt ?? b.round.createdAt) - (a.round.resolvedAt ?? a.round.createdAt)\n   220→      );\n   221→      setUserHistory(history);\n   222→    } else {\n   223→      setUserHistory([]);\n   224→    }\n   225→  }, [address, currentRound?.phase]);\n   226→\n   227→  // Place bet action - accepts optional side override for direct button clicks\n   228→  const placeBet = useCallback(async (sideOverride?: BetSide) => {\n   229→    if (!address) {\n   230→      throw new Error(\"Wallet not connected\");\n   231→    }\n   232→\n   233→    const side = sideOverride ?? pendingSide;\n   234→    if (!side) {\n   235→      throw new Error(\"Select GREEN or RED\");\n   236→    }\n   237→\n   238→    if (pendingAmount < MIN_BET_AMOUNT) {\n   239→      throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n   240→    }\n   241→\n   242→    if (pendingAmount > MAX_BET_AMOUNT) {\n   243→      throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n   244→    }\n   245→\n   246→    const currentBalance = getBalance?.();\n   247→    if (currentBalance !== undefined && pendingAmount > currentBalance) {\n   248→      throw new Error(\"Insufficient balance\");\n   249→    }\n   250→\n   251→    setPlacingBet(true);\n   252→\n   253→    try {\n   254→      // Simulate transaction delay\n   255→      await new Promise((resolve) => setTimeout(resolve, 500));\n   256→\n   257→      mockPlaceBet(address, side, pendingAmount);\n   258→\n   259→      // Reset selection after bet\n   260→      setPendingSide(null);\n   261→    } finally {\n   262→      setPlacingBet(false);\n   263→    }\n   264→  }, [address, pendingSide, pendingAmount, getBalance]);\n   265→\n   266→  // Adjust bet amount\n   267→  const adjustBetAmount = useCallback(\n   268→    (adjustment: \"half\" | \"double\" | \"max\") => {\n   269→      let newAmount: number;\n   270→      const currentBalance = getBalance?.();\n   271→\n   272→      switch (adjustment) {\n   273→        case \"half\":\n   274→          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n   275→          break;\n   276→        case \"double\":\n   277→          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n   278→          break;\n   279→        case \"max\":\n   280→          newAmount = currentBalance !== undefined ? Math.min(currentBalance, MAX_BET_AMOUNT) : MAX_BET_AMOUNT;\n   281→          break;\n   282→      }\n   283→\n   284→      // Round to 4 decimal places\n   285→      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n   286→    },\n   287→    [pendingAmount, getBalance]\n   288→  );\n   289→\n   290→  // Refresh round data\n   291→  const refreshRound = useCallback(() => {\n   292→    const round = getCurrentRound();\n   293→    if (round) {\n   294→      setCurrentRound(round);\n   295→    }\n   296→    // Build candles: completed + current forming\n   297→    const completed = getRecentCandles(15);\n   298→    const current = getCurrentCandle();\n   299→    if (current) {\n   300→      setRecentCandles([...completed, current]);\n   301→    } else {\n   302→      setRecentCandles(completed);\n   303→    }\n   304→  }, []);\n   305→\n   306→  // Clear completed round (after user dismisses result overlay)\n   307→  const clearCompletedRound = useCallback(() => {\n   308→    setCompletedRound(null);\n   309→    mockClearCompletedRound();\n   310→  }, []);\n   311→\n   312→  const contextValue: CloseCallContextValue = {\n   313→    currentRound,\n   314→    completedRound,\n   315→    recentCandles,\n   316→    currentPrice,\n   317→    candleProgress,\n   318→    userHistory,\n   319→    pendingAmount,\n   320→    pendingSide,\n   321→    userBet,\n   322→    loading,\n   323→    placingBet,\n   324→    setPendingAmount,\n   325→    setPendingSide,\n   326→    placeBet,\n   327→    adjustBetAmount,\n   328→    clearCompletedRound,\n   329→    potentialPayout,\n   330→    userOdds,\n   331→    refreshRound,\n   332→  };\n   333→\n   334→  return (\n   335→    <CloseCallContext.Provider value={contextValue}>\n   336→      {children}\n   337→    </CloseCallContext.Provider>\n   338→  );\n   339→}\n   340→\n   341→export function useCloseCall(): CloseCallContextValue {\n   342→  const context = useContext(CloseCallContext);\n   343→  if (!context) {\n   344→    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n   345→  }\n   346→  return context;\n   347→}\n   348→"}]},"parent_tool_use_id":"toolu_01Sj627SozxTZzCGuEffmwa8","session_id":"06801c0c-3d75-4002-a1f5-bd8cb617d345","uuid":"4eee11ba-e6d5-4b95-8eba-9d1c56d9af9a"}
