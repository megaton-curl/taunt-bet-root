{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EMLnpVHBHgx653XmGypZBn","type":"tool_result","content":"     1→export type Asset = \"BTC\" | \"ETH\" | \"SOL\";\n     2→\n     3→export const SUPPORTED_ASSETS: Asset[] = [\"BTC\", \"ETH\", \"SOL\"];\n     4→\n     5→// Pyth price feed IDs (mainnet)\n     6→export const PYTH_FEED_IDS: Record<Asset, string> = {\n     7→  BTC: \"0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43\",\n     8→  ETH: \"0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace\",\n     9→  SOL: \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\",\n    10→};\n    11→\n    12→export interface PriceData {\n    13→  asset: Asset;\n    14→  price: number;\n    15→  confidence: number;\n    16→  timestamp: number;\n    17→  publishTime: number;\n    18→}\n    19→\n    20→export interface Candle {\n    21→  asset: Asset;\n    22→  open: number;\n    23→  high: number;\n    24→  low: number;\n    25→  close: number;\n    26→  openTime: number;\n    27→  closeTime: number;\n    28→}\n    29→"}]},"parent_tool_use_id":"toolu_01VjBSw9tMWntCUQGUX3iNN9","session_id":"402c21eb-b534-4fb0-8000-5dcbddbea423","uuid":"51e73597-417c-4a0e-8ee2-742aed119368"}
