{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0199YvRWpANa1vnpihjyo6Rw","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Rag6gjXecQcYUjerBJQJk5","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  useMemo,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { usePriceSubscription } from \"@rng-utopia/price-feeds\";\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  PlayerBet,\n  UserRoundHistory,\n  RoundPhase,\n  CandleOutcome,\n  CloseCallContextValue,\n} from \"../types\";\nimport {\n  DEFAULT_BET_AMOUNT,\n  MIN_BET_AMOUNT,\n  MAX_BET_AMOUNT,\n  BETTING_WINDOW_MS,\n} from \"../types\";\nimport { calculatePotentialPayout } from \"../utils/payout-calculator\";\n\n// ---------------------------------------------------------------------------\n// Backend API\n// ---------------------------------------------------------------------------\n\nconst FAIRNESS_BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\nconst ROUND_POLL_MS = 2000;\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\ninterface BackendRoundResponse {\n  roundId: string;\n  pda: string;\n  phase: string;\n  openPrice: number;\n  openPriceExpo: number;\n  closePrice: number | null;\n  outcome: string;\n  greenPool: number;\n  redPool: number;\n  totalPool: number;\n  totalFee: number;\n  greenEntries: Array<{ player: string; amountLamports: number }>;\n  redEntries: Array<{ player: string; amountLamports: number }>;\n  greenCount: number;\n  redCount: number;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n}\n\nfunction backendToRound(br: BackendRoundResponse): Round {\n  const greenBets: PlayerBet[] = br.greenEntries.map((e) => ({\n    address: e.player,\n    side: \"green\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const redBets: PlayerBet[] = br.redEntries.map((e) => ({\n    address: e.player,\n    side: \"red\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const greenPool = greenBets.reduce((s, b) => s + b.amount, 0);\n  const redPool = redBets.reduce((s, b) => s + b.amount, 0);\n\n  return {\n    id: br.roundId,\n    phase: br.phase as RoundPhase,\n    pool: {\n      greenPool,\n      redPool,\n      totalPool: greenPool + redPool,\n      playerCount: greenBets.length + redBets.length,\n      greenBets,\n      redBets,\n    },\n    createdAt: new Date(br.createdAt).getTime(),\n    bettingEndsAt: new Date(br.createdAt).getTime() + BETTING_WINDOW_MS,\n    resolvedAt: br.settledAt ? new Date(br.settledAt).getTime() : undefined,\n    targetCandleTime: new Date(br.createdAt).getTime(),\n    outcome: br.outcome === \"pending\" ? undefined : (br.outcome as CandleOutcome),\n    openPrice: br.openPrice,\n    openPriceExpo: br.openPriceExpo,\n    closePrice: br.closePrice ?? undefined,\n    settleTx: br.settleTx ?? undefined,\n  };\n}\n\nasync function fetchCurrentRound(): Promise<Round | null> {\n  try {\n    const res = await fetch(`${FAIRNESS_BACKEND_URL}/closecall/current-round`);\n    if (!res.ok) return null;\n    const data = (await res.json()) as { round: BackendRoundResponse | null };\n    if (!data.round) return null;\n    return backendToRound(data.round);\n  } catch {\n    return null;\n  }\n}\n\nasync function fetchRoundHistory(limit = 20): Promise<Round[]> {\n  try {\n    const res = await fetch(\n      `${FAIRNESS_BACKEND_URL}/closecall/history?limit=${limit}`,\n    );\n    if (!res.ok) return [];\n    const data = (await res.json()) as { rounds: BackendRoundResponse[] };\n    return data.rounds.map(backendToRound);\n  } catch {\n    return [];\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Local candle builder — accumulates 1-min OHLC from live Pyth price ticks\n// ---------------------------------------------------------------------------\n\nfunction getMinuteBoundary(ts: number): number {\n  return Math.floor(ts / 60_000) * 60_000;\n}\n\n// ---------------------------------------------------------------------------\n// Context\n// ---------------------------------------------------------------------------\n\nconst defaultContextValue: CloseCallContextValue = {\n  currentRound: null,\n  completedRound: null,\n  recentCandles: [],\n  currentPrice: 0,\n  candleProgress: 0,\n  userHistory: [],\n  pendingAmount: DEFAULT_BET_AMOUNT,\n  pendingSide: null,\n  userBet: null,\n  loading: true,\n  placingBet: false,\n  setPendingAmount: () => {},\n  setPendingSide: () => {},\n  placeBet: async () => {},\n  adjustBetAmount: () => {},\n  clearCompletedRound: () => {},\n  potentialPayout: 0,\n  userOdds: 0,\n  refreshRound: () => {},\n};\n\nconst CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n\nexport function CloseCallProvider({ children }: { children: ReactNode }) {\n  const { address, getBalance } = useWallet();\n\n  // Live BTC price from Pyth via price-feeds package\n  const btcPrice = usePriceSubscription(\"BTC\");\n\n  // Round state\n  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n  const [currentPrice, setCurrentPrice] = useState(0);\n  const [candleProgress, setCandleProgress] = useState(0);\n\n  // User state\n  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [placingBet, setPlacingBet] = useState(false);\n\n  // Candle builder refs\n  const candlesRef = useRef<Candle[]>([]);\n  const currentCandleRef = useRef<Candle | null>(null);\n\n  // Track previous round id to detect round transitions\n  const prevRoundIdRef = useRef<string | null>(null);\n\n  // -----------------------------------------------------------------------\n  // Update currentPrice from Pyth subscription\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (btcPrice && btcPrice.price > 0) {\n      setCurrentPrice(btcPrice.price);\n    }\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Build local candles from live price ticks\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!btcPrice || btcPrice.price <= 0) return;\n\n    const price = btcPrice.price;\n    const now = Date.now();\n    const minuteStart = getMinuteBoundary(now);\n\n    const current = currentCandleRef.current;\n    if (!current || current.openTime !== minuteStart) {\n      // New minute boundary — close previous candle\n      if (current) {\n        candlesRef.current = [...candlesRef.current.slice(-14), current];\n      }\n      currentCandleRef.current = {\n        open: price,\n        high: price,\n        low: price,\n        close: price,\n        openTime: minuteStart,\n        closeTime: minuteStart + 60_000,\n      };\n    } else {\n      // Update current candle tick\n      currentCandleRef.current = {\n        ...current,\n        high: Math.max(current.high, price),\n        low: Math.min(current.low, price),\n        close: price,\n      };\n    }\n\n    // Push to state so chart re-renders\n    const forming = currentCandleRef.current;\n    setRecentCandles(forming ? [...candlesRef.current, forming] : candlesRef.current);\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Candle progress timer (100ms tick)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    const timer = setInterval(() => {\n      const now = Date.now();\n      const minuteStart = getMinuteBoundary(now);\n      const progress = (now - minuteStart) / 60_000;\n      setCandleProgress(Math.min(progress, 1));\n    }, 100);\n    return () => clearInterval(timer);\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Poll backend for current round (every 2s)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    let cancelled = false;\n\n    async function poll() {\n      const round = await fetchCurrentRound();\n      if (cancelled) return;\n\n      if (round) {\n        // Detect round transition: previous round settled/refunded\n        if (prevRoundIdRef.current && prevRoundIdRef.current !== round.id) {\n          // Fetch the completed round from history for result overlay\n          const history = await fetchRoundHistory(1);\n          if (!cancelled && history.length > 0 && history[0].id === prevRoundIdRef.current) {\n            setCompletedRound(history[0]);\n          }\n        }\n        prevRoundIdRef.current = round.id;\n        setCurrentRound(round);\n      } else {\n        // No active round — check if previous round just settled\n        if (prevRoundIdRef.current) {\n          const history = await fetchRoundHistory(1);\n          if (!cancelled && history.length > 0 && history[0].id === prevRoundIdRef.current) {\n            setCompletedRound(history[0]);\n          }\n          prevRoundIdRef.current = null;\n        }\n        setCurrentRound(null);\n      }\n      setLoading(false);\n    }\n\n    // Initial fetch\n    poll();\n\n    const interval = setInterval(poll, ROUND_POLL_MS);\n    return () => {\n      cancelled = true;\n      clearInterval(interval);\n    };\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Derive user bet from current round\n  // -----------------------------------------------------------------------\n  const userBet = useMemo(() => {\n    if (!currentRound || !address) return null;\n    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    return allBets.find((b) => b.address === address) ?? null;\n  }, [currentRound, address]);\n\n  // -----------------------------------------------------------------------\n  // Build user history from settled rounds\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!address) {\n      setUserHistory([]);\n      return;\n    }\n\n    let cancelled = false;\n\n    async function loadHistory() {\n      const rounds = await fetchRoundHistory(20);\n      if (cancelled) return;\n\n      const history: UserRoundHistory[] = [];\n      for (const round of rounds) {\n        const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n        const bet = allBets.find((b) => b.address === address);\n        if (bet) {\n          const won = round.outcome === bet.side;\n          history.push({\n            round,\n            userBet: bet,\n            payout: won ? calculatePotentialPayout(bet.amount, bet.side, round.pool) : 0,\n            won,\n          });\n        }\n      }\n      setUserHistory(history);\n    }\n\n    loadHistory();\n\n    return () => { cancelled = true; };\n  }, [address, currentRound?.phase]);\n\n  // -----------------------------------------------------------------------\n  // Potential payout\n  // -----------------------------------------------------------------------\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    if (userBet) {\n      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n    }\n\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // User odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n    if (winningPool === 0) return 0;\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // -----------------------------------------------------------------------\n  // Place bet — stub that does local validation only (wallet tx in next iteration)\n  // -----------------------------------------------------------------------\n  const placeBet = useCallback(\n    async (sideOverride?: BetSide) => {\n      if (!address) throw new Error(\"Wallet not connected\");\n\n      const side = sideOverride ?? pendingSide;\n      if (!side) throw new Error(\"Select GREEN or RED\");\n\n      if (pendingAmount < MIN_BET_AMOUNT) {\n        throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n      }\n      if (pendingAmount > MAX_BET_AMOUNT) {\n        throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n      }\n\n      const currentBalance = getBalance?.();\n      if (currentBalance !== undefined && pendingAmount > currentBalance) {\n        throw new Error(\"Insufficient balance\");\n      }\n\n      setPlacingBet(true);\n      try {\n        // TODO: Build and send place_bet transaction via anchor-client (next iteration)\n        await new Promise((resolve) => setTimeout(resolve, 500));\n        setPendingSide(null);\n      } finally {\n        setPlacingBet(false);\n      }\n    },\n    [address, pendingSide, pendingAmount, getBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Adjust bet amount\n  // -----------------------------------------------------------------------\n  const adjustBetAmount = useCallback(\n    (adjustment: \"half\" | \"double\" | \"max\") => {\n      let newAmount: number;\n      const currentBalance = getBalance?.();\n\n      switch (adjustment) {\n        case \"half\":\n          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n          break;\n        case \"double\":\n          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n          break;\n        case \"max\":\n          newAmount =\n            currentBalance !== undefined\n              ? Math.min(currentBalance, MAX_BET_AMOUNT)\n              : MAX_BET_AMOUNT;\n          break;\n      }\n\n      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n    },\n    [pendingAmount, getBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Refresh round data on demand\n  // -----------------------------------------------------------------------\n  const refreshRound = useCallback(() => {\n    fetchCurrentRound().then((round) => {\n      if (round) setCurrentRound(round);\n    });\n  }, []);\n\n  // Clear completed round (after user dismisses result overlay)\n  const clearCompletedRound = useCallback(() => {\n    setCompletedRound(null);\n  }, []);\n\n  const contextValue: CloseCallContextValue = {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    clearCompletedRound,\n    potentialPayout,\n    userOdds,\n    refreshRound,\n  };\n\n  return (\n    <CloseCallContext.Provider value={contextValue}>\n      {children}\n    </CloseCallContext.Provider>\n  );\n}\n\nexport function useCloseCall(): CloseCallContextValue {\n  const context = useContext(CloseCallContext);\n  if (!context) {\n    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n  }\n  return context;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":331,"cache_read_input_tokens":82450,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":331},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"402c21eb-b534-4fb0-8000-5dcbddbea423","uuid":"8824d343-dc26-424c-8393-cb8ef7ce0470"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rag6gjXecQcYUjerBJQJk5","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"402c21eb-b534-4fb0-8000-5dcbddbea423","uuid":"3556c675-dbd3-4a0f-98e5-06e30a3ef486","tool_use_result":{"type":"update","filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  useMemo,\n  useRef,\n  type ReactNode,\n} from \"react\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { usePriceSubscription } from \"@rng-utopia/price-feeds\";\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  PlayerBet,\n  UserRoundHistory,\n  RoundPhase,\n  CandleOutcome,\n  CloseCallContextValue,\n} from \"../types\";\nimport {\n  DEFAULT_BET_AMOUNT,\n  MIN_BET_AMOUNT,\n  MAX_BET_AMOUNT,\n  BETTING_WINDOW_MS,\n} from \"../types\";\nimport { calculatePotentialPayout } from \"../utils/payout-calculator\";\n\n// ---------------------------------------------------------------------------\n// Backend API\n// ---------------------------------------------------------------------------\n\nconst FAIRNESS_BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\nconst ROUND_POLL_MS = 2000;\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\ninterface BackendRoundResponse {\n  roundId: string;\n  pda: string;\n  phase: string;\n  openPrice: number;\n  openPriceExpo: number;\n  closePrice: number | null;\n  outcome: string;\n  greenPool: number;\n  redPool: number;\n  totalPool: number;\n  totalFee: number;\n  greenEntries: Array<{ player: string; amountLamports: number }>;\n  redEntries: Array<{ player: string; amountLamports: number }>;\n  greenCount: number;\n  redCount: number;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n}\n\nfunction backendToRound(br: BackendRoundResponse): Round {\n  const greenBets: PlayerBet[] = br.greenEntries.map((e) => ({\n    address: e.player,\n    side: \"green\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const redBets: PlayerBet[] = br.redEntries.map((e) => ({\n    address: e.player,\n    side: \"red\" as const,\n    amount: e.amountLamports / LAMPORTS_PER_SOL,\n    timestamp: new Date(br.createdAt).getTime(),\n  }));\n  const greenPool = greenBets.reduce((s, b) => s + b.amount, 0);\n  const redPool = redBets.reduce((s, b) => s + b.amount, 0);\n\n  return {\n    id: br.roundId,\n    phase: br.phase as RoundPhase,\n    pool: {\n      greenPool,\n      redPool,\n      totalPool: greenPool + redPool,\n      playerCount: greenBets.length + redBets.length,\n      greenBets,\n      redBets,\n    },\n    createdAt: new Date(br.createdAt).getTime(),\n    bettingEndsAt: new Date(br.createdAt).getTime() + BETTING_WINDOW_MS,\n    resolvedAt: br.settledAt ? new Date(br.settledAt).getTime() : undefined,\n    targetCandleTime: new Date(br.createdAt).getTime(),\n    outcome: br.outcome === \"pending\" ? undefined : (br.outcome as CandleOutcome),\n    openPrice: br.openPrice,\n    openPriceExpo: br.openPriceExpo,\n    closePrice: br.closePrice ?? undefined,\n    settleTx: br.settleTx ?? undefined,\n  };\n}\n\nasync function fetchCurrentRound(): Promise<Round | null> {\n  try {\n    const res = await fetch(`${FAIRNESS_BACKEND_URL}/closecall/current-round`);\n    if (!res.ok) return null;\n    const data = (await res.json()) as { round: BackendRoundResponse | null };\n    if (!data.round) return null;\n    return backendToRound(data.round);\n  } catch {\n    return null;\n  }\n}\n\nasync function fetchRoundHistory(limit = 20): Promise<Round[]> {\n  try {\n    const res = await fetch(\n      `${FAIRNESS_BACKEND_URL}/closecall/history?limit=${limit}`,\n    );\n    if (!res.ok) return [];\n    const data = (await res.json()) as { rounds: BackendRoundResponse[] };\n    return data.rounds.map(backendToRound);\n  } catch {\n    return [];\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Local candle builder — accumulates 1-min OHLC from live Pyth price ticks\n// ---------------------------------------------------------------------------\n\nfunction getMinuteBoundary(ts: number): number {\n  return Math.floor(ts / 60_000) * 60_000;\n}\n\n// ---------------------------------------------------------------------------\n// Context\n// ---------------------------------------------------------------------------\n\nconst defaultContextValue: CloseCallContextValue = {\n  currentRound: null,\n  completedRound: null,\n  recentCandles: [],\n  currentPrice: 0,\n  candleProgress: 0,\n  userHistory: [],\n  pendingAmount: DEFAULT_BET_AMOUNT,\n  pendingSide: null,\n  userBet: null,\n  loading: true,\n  placingBet: false,\n  setPendingAmount: () => {},\n  setPendingSide: () => {},\n  placeBet: async () => {},\n  adjustBetAmount: () => {},\n  clearCompletedRound: () => {},\n  potentialPayout: 0,\n  userOdds: 0,\n  refreshRound: () => {},\n};\n\nconst CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n\nexport function CloseCallProvider({ children }: { children: ReactNode }) {\n  const { address, getBalance } = useWallet();\n\n  // Live BTC price from Pyth via price-feeds package\n  const btcPrice = usePriceSubscription(\"BTC\");\n\n  // Round state\n  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n  const [currentPrice, setCurrentPrice] = useState(0);\n  const [candleProgress, setCandleProgress] = useState(0);\n\n  // User state\n  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [placingBet, setPlacingBet] = useState(false);\n\n  // Candle builder refs\n  const candlesRef = useRef<Candle[]>([]);\n  const currentCandleRef = useRef<Candle | null>(null);\n\n  // Track previous round id to detect round transitions\n  const prevRoundIdRef = useRef<string | null>(null);\n\n  // -----------------------------------------------------------------------\n  // Update currentPrice from Pyth subscription\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (btcPrice && btcPrice.price > 0) {\n      setCurrentPrice(btcPrice.price);\n    }\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Build local candles from live price ticks\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!btcPrice || btcPrice.price <= 0) return;\n\n    const price = btcPrice.price;\n    const now = Date.now();\n    const minuteStart = getMinuteBoundary(now);\n\n    const current = currentCandleRef.current;\n    if (!current || current.openTime !== minuteStart) {\n      // New minute boundary — close previous candle\n      if (current) {\n        candlesRef.current = [...candlesRef.current.slice(-14), current];\n      }\n      currentCandleRef.current = {\n        open: price,\n        high: price,\n        low: price,\n        close: price,\n        openTime: minuteStart,\n        closeTime: minuteStart + 60_000,\n      };\n    } else {\n      // Update current candle tick\n      currentCandleRef.current = {\n        ...current,\n        high: Math.max(current.high, price),\n        low: Math.min(current.low, price),\n        close: price,\n      };\n    }\n\n    // Push to state so chart re-renders\n    const forming = currentCandleRef.current;\n    setRecentCandles(forming ? [...candlesRef.current, forming] : candlesRef.current);\n  }, [btcPrice]);\n\n  // -----------------------------------------------------------------------\n  // Candle progress timer (100ms tick)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    const timer = setInterval(() => {\n      const now = Date.now();\n      const minuteStart = getMinuteBoundary(now);\n      const progress = (now - minuteStart) / 60_000;\n      setCandleProgress(Math.min(progress, 1));\n    }, 100);\n    return () => clearInterval(timer);\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Poll backend for current round (every 2s)\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    let cancelled = false;\n\n    async function poll() {\n      const round = await fetchCurrentRound();\n      if (cancelled) return;\n\n      if (round) {\n        // Detect round transition: previous round settled/refunded\n        if (prevRoundIdRef.current && prevRoundIdRef.current !== round.id) {\n          // Fetch the completed round from history for result overlay\n          const history = await fetchRoundHistory(1);\n          if (!cancelled && history.length > 0 && history[0].id === prevRoundIdRef.current) {\n            setCompletedRound(history[0]);\n          }\n        }\n        prevRoundIdRef.current = round.id;\n        setCurrentRound(round);\n      } else {\n        // No active round — check if previous round just settled\n        if (prevRoundIdRef.current) {\n          const history = await fetchRoundHistory(1);\n          if (!cancelled && history.length > 0 && history[0].id === prevRoundIdRef.current) {\n            setCompletedRound(history[0]);\n          }\n          prevRoundIdRef.current = null;\n        }\n        setCurrentRound(null);\n      }\n      setLoading(false);\n    }\n\n    // Initial fetch\n    poll();\n\n    const interval = setInterval(poll, ROUND_POLL_MS);\n    return () => {\n      cancelled = true;\n      clearInterval(interval);\n    };\n  }, []);\n\n  // -----------------------------------------------------------------------\n  // Derive user bet from current round\n  // -----------------------------------------------------------------------\n  const userBet = useMemo(() => {\n    if (!currentRound || !address) return null;\n    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    return allBets.find((b) => b.address === address) ?? null;\n  }, [currentRound, address]);\n\n  // -----------------------------------------------------------------------\n  // Build user history from settled rounds\n  // -----------------------------------------------------------------------\n  useEffect(() => {\n    if (!address) {\n      setUserHistory([]);\n      return;\n    }\n\n    let cancelled = false;\n\n    async function loadHistory() {\n      const rounds = await fetchRoundHistory(20);\n      if (cancelled) return;\n\n      const history: UserRoundHistory[] = [];\n      for (const round of rounds) {\n        const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n        const bet = allBets.find((b) => b.address === address);\n        if (bet) {\n          const won = round.outcome === bet.side;\n          history.push({\n            round,\n            userBet: bet,\n            payout: won ? calculatePotentialPayout(bet.amount, bet.side, round.pool) : 0,\n            won,\n          });\n        }\n      }\n      setUserHistory(history);\n    }\n\n    loadHistory();\n\n    return () => { cancelled = true; };\n  }, [address, currentRound?.phase]);\n\n  // -----------------------------------------------------------------------\n  // Potential payout\n  // -----------------------------------------------------------------------\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    if (userBet) {\n      return calculatePotentialPayout(userBet.amount, userBet.side, currentRound.pool);\n    }\n\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(pendingAmount, pendingSide, currentRound.pool);\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // User odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n    if (winningPool === 0) return 0;\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // -----------------------------------------------------------------------\n  // Place bet — stub that does local validation only (wallet tx in next iteration)\n  // -----------------------------------------------------------------------\n  const placeBet = useCallback(\n    async (sideOverride?: BetSide) => {\n      if (!address) throw new Error(\"Wallet not connected\");\n\n      const side = sideOverride ?? pendingSide;\n      if (!side) throw new Error(\"Select GREEN or RED\");\n\n      if (pendingAmount < MIN_BET_AMOUNT) {\n        throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n      }\n      if (pendingAmount > MAX_BET_AMOUNT) {\n        throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n      }\n\n      const currentBalance = getBalance?.();\n      if (currentBalance !== undefined && pendingAmount > currentBalance) {\n        throw new Error(\"Insufficient balance\");\n      }\n\n      setPlacingBet(true);\n      try {\n        // TODO: Build and send place_bet transaction via anchor-client (next iteration)\n        await new Promise((resolve) => setTimeout(resolve, 500));\n        setPendingSide(null);\n      } finally {\n        setPlacingBet(false);\n      }\n    },\n    [address, pendingSide, pendingAmount, getBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Adjust bet amount\n  // -----------------------------------------------------------------------\n  const adjustBetAmount = useCallback(\n    (adjustment: \"half\" | \"double\" | \"max\") => {\n      let newAmount: number;\n      const currentBalance = getBalance?.();\n\n      switch (adjustment) {\n        case \"half\":\n          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n          break;\n        case \"double\":\n          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n          break;\n        case \"max\":\n          newAmount =\n            currentBalance !== undefined\n              ? Math.min(currentBalance, MAX_BET_AMOUNT)\n              : MAX_BET_AMOUNT;\n          break;\n      }\n\n      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n    },\n    [pendingAmount, getBalance],\n  );\n\n  // -----------------------------------------------------------------------\n  // Refresh round data on demand\n  // -----------------------------------------------------------------------\n  const refreshRound = useCallback(() => {\n    fetchCurrentRound().then((round) => {\n      if (round) setCurrentRound(round);\n    });\n  }, []);\n\n  // Clear completed round (after user dismisses result overlay)\n  const clearCompletedRound = useCallback(() => {\n    setCompletedRound(null);\n  }, []);\n\n  const contextValue: CloseCallContextValue = {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    clearCompletedRound,\n    potentialPayout,\n    userOdds,\n    refreshRound,\n  };\n\n  return (\n    <CloseCallContext.Provider value={contextValue}>\n      {children}\n    </CloseCallContext.Provider>\n  );\n}\n\nexport function useCloseCall(): CloseCallContextValue {\n  const context = useContext(CloseCallContext);\n  if (!context) {\n    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n  }\n  return context;\n}\n","structuredPatch":[{"oldStart":5,"oldLines":37,"newStart":5,"newLines":138,"lines":["   useEffect,","   useCallback,","   useMemo,","+  useRef,","   type ReactNode,"," } from \"react\";"," import { useWallet } from \"@rng-utopia/wallet/hooks\";","+import { usePriceSubscription } from \"@rng-utopia/price-feeds\";"," import type {","   Round,","   BetSide,","   Candle,","+  PlayerBet,","   UserRoundHistory,","+  RoundPhase,","+  CandleOutcome,","   CloseCallContextValue,"," } from \"../types\";"," import {","   DEFAULT_BET_AMOUNT,","   MIN_BET_AMOUNT,","   MAX_BET_AMOUNT,","+  BETTING_WINDOW_MS,"," } from \"../types\";","-import {","-  initializeGame,","-  subscribeToRound,","-  subscribeToCompletedRound,","-  placeBet as mockPlaceBet,","-  getCurrentRound,","-  getUserHistory,","-  getRecentCandles,","-  getCurrentCandle,","-  getCandleProgress,","-  isGameInitialized,","-  clearCompletedRound as mockClearCompletedRound,","-} from \"../utils/mock-simulation\";"," import { calculatePotentialPayout } from \"../utils/payout-calculator\";"," ","-// Default context value","+// ---------------------------------------------------------------------------","+// Backend API","+// ---------------------------------------------------------------------------","+","+const FAIRNESS_BACKEND_URL = (","+  (import.meta as unknown as { env: Record<string, string | undefined> }).env","+    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"","+).replace(/\\/$/, \"\");","+","+const ROUND_POLL_MS = 2000;","+const LAMPORTS_PER_SOL = 1_000_000_000;","+","+interface BackendRoundResponse {","+  roundId: string;","+  pda: 