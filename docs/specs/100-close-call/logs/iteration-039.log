{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XZxS8CAyDVytVPohFVZRu2","type":"tool_result","content":"     1→import { useState, useEffect, useRef } from \"react\";\n     2→import { BrowserRouter, Routes, Route, Link } from \"react-router-dom\";\n     3→import { Header } from \"./components/Header\";\n     4→import { Sidebar } from \"./components/Sidebar\";\n     5→import { Ticker } from \"./components/Ticker\";\n     6→import { BackgroundEffects } from \"./components/BackgroundEffects\";\n     7→import { CoinflipPage } from \"./pages/CoinflipPage\";\n     8→import { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\n     9→import { CloseCallPage } from \"./pages/CloseCallPage\";\n    10→import { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\n    11→import { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\n    12→import { BossRaidProvider } from \"./features/boss-raid\";\n    13→import { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatarCompact } from \"./features/player-profile\";\n    14→import { QuestsProvider, ChestDropNotification } from \"./features/quests\";\n    15→import { QuestsPage } from \"./pages/QuestsPage\";\n    16→import { LootPage } from \"./pages/LootPage\";\n    17→import { CoinflipRoundPage } from \"./pages/CoinflipRoundPage\";\n    18→import { LordRoundPage } from \"./pages/LordRoundPage\";\n    19→import { FairnessPage } from \"./pages/FairnessPage\";\n    20→import { BuildBadge } from \"./components/BuildBadge\";\n    21→\n    22→\n    23→export function App() {\n    24→  return (\n    25→    <BrowserRouter>\n    26→      <PlayerProfileProvider>\n    27→        <QuestsProvider>\n    28→          <BossRaidProvider>\n    29→            <AppContent />\n    30→          </BossRaidProvider>\n    31→        </QuestsProvider>\n    32→      </PlayerProfileProvider>\n    33→    </BrowserRouter>\n    34→  );\n    35→}\n    36→\n    37→\n    38→// Chat icon SVG\n    39→const ChatIcon = () => (\n    40→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    41→    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    42→    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    43→    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    44→    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n    45→  </svg>\n    46→);\n    47→\n    48→// Footer component with terms and FAQ modals\n    49→function Footer() {\n    50→  const [showTerms, setShowTerms] = useState(false);\n    51→  const [showFAQ, setShowFAQ] = useState(false);\n    52→  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n    53→  const termsModalRef = useRef<HTMLDivElement>(null);\n    54→  const faqModalRef = useRef<HTMLDivElement>(null);\n    55→\n    56→  // Close modal on outside click\n    57→  useEffect(() => {\n    58→    if (!showTerms && !showFAQ) return;\n    59→\n    60→    const handleClickOutside = (e: MouseEvent) => {\n    61→      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n    62→        setShowTerms(false);\n    63→      }\n    64→      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n    65→        setShowFAQ(false);\n    66→      }\n    67→    };\n    68→\n    69→    document.addEventListener(\"mousedown\", handleClickOutside);\n    70→    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n    71→  }, [showTerms, showFAQ]);\n    72→\n    73→  // Close on escape\n    74→  useEffect(() => {\n    75→    if (!showTerms && !showFAQ) return;\n    76→\n    77→    const handleEscape = (e: KeyboardEvent) => {\n    78→      if (e.key === \"Escape\") {\n    79→        setShowTerms(false);\n    80→        setShowFAQ(false);\n    81→      }\n    82→    };\n    83→\n    84→    document.addEventListener(\"keydown\", handleEscape);\n    85→    return () => document.removeEventListener(\"keydown\", handleEscape);\n    86→  }, [showTerms, showFAQ]);\n    87→\n    88→  const toggleFAQSection = (section: string) => {\n    89→    setExpandedFAQ(expandedFAQ === section ? null : section);\n    90→  };\n    91→\n    92→  const faqSections = [\n    93→    {\n    94→      id: \"fees\",\n    95→      title: \"Platform Fees\",\n    96→      content: `TAUNT charges a 3% platform fee on all games. This means 97% of all wagered funds go directly to winners.\n    97→\n    98→Fee breakdown:\n    99→• 1% goes to player incentives (Dogpile Raid reward pool, future promotions)\n   100→• 2% goes to platform treasury (server costs, development, operations)\n   101→\n   102→What you get:\n   103→• Winners receive: 97% of the pot\n   104→• No hidden fees or withdrawal charges\n   105→• Part of your wagers fund rewards you can win back through Dogpile Raid`\n   106→    },\n   107→    {\n   108→      id: \"raid-boss\",\n   109→      title: \"What is Dogpile Raid?\",\n   110→      content: `Dogpile Raid is a community reward mechanic where players collectively take down a Mark by playing games.\n   111→\n   112→How it works:\n   113→• A new Mark spawns every hour with a 50-minute active phase\n   114→• Every wager you make in any game lands \"hits\" on the Mark\n   115→• The Mark's Armor drains over time - it's always dropped when the timer ends\n   116→• When dropped, the reward pool is distributed to all participants\n   117→\n   118→Rewards:\n   119→• Your share is proportional to your hit contribution\n   120→• The reward pool grows from 1% of all wagers during the raid\n   121→• Higher total community hits = better loot tier = bigger multipliers\n   122→• Bonus loot is occasionally added for extra rewards\n   123→\n   124→Loot Tiers (based on total hits):\n   125→• Bronze: 0-10 SOL in hits\n   126→• Silver: 10-50 SOL in hits\n   127→• Gold: 50-150 SOL in hits\n   128→• Platinum: 150-500 SOL in hits\n   129→• Diamond: 500+ SOL in hits`\n   130→    },\n   131→    {\n   132→      id: \"pvp\",\n   133→      title: \"Why PvP Games?\",\n   134→      content: `Unlike traditional house-edge gambling where you play against the casino, TAUNT is 100% player-vs-player. This creates a fundamentally fairer system:\n   135→\n   136→• No house edge exploiting players\n   137→• Prize pools come entirely from player wagers\n   138→• The platform only takes a small facilitation fee\n   139→• Better odds than any traditional casino\n   140→• Transparent, skill-independent wagering`\n   141→    },\n   142→    {\n   143→      id: \"tiers\",\n   144→      title: \"Wagering Tiers\",\n   145→      content: `TAUNT uses wagering tiers to match players with similar risk appetites together. Each tier has a fixed SOL amount - you play against others wagering the same amount.\n   146→\n   147→Available Tiers:\n   148→• Iron: 0.005 SOL\n   149→• Bronze: 0.01 SOL\n   150→• Silver: 0.1 SOL\n   151→• Gold: 0.25 SOL\n   152→• Platinum: 0.5 SOL\n   153→• Diamond: 1 SOL\n   154→\n   155→How it works:\n   156→• Each game has separate lobbies for each tier\n   157→• Select your tier before joining a game\n   158→• You're matched only with players in the same tier\n   159→• Everyone in the round wagers the exact same amount\n   160→\n   161→Benefits:\n   162→• Fair matchmaking - compete on equal footing\n   163→• Choose the risk level you're comfortable with\n   164→• No whales dominating smaller players`\n   165→    },\n   166→    {\n   167→      id: \"leaderboard\",\n   168→      title: \"Leaderboard System\",\n   169→      content: `Leaderboard system details coming soon.\n   170→\n   171→We're working on implementing competitive leaderboards to track and reward top players. Stay tuned for updates!`\n   172→    },\n   173→    {\n   174→      id: \"fairness\",\n   175→      title: \"On-Chain Fairness\",\n   176→      content: `All game outcomes are provably fair using cryptographic verification:\n   177→\n   178→Commit-Reveal Pattern (Crash, Close Call):\n   179→1. Server publishes a hash of its seed before betting\n   180→2. Solana blockhash becomes the public seed\n   181→3. After the round, server reveals its seed\n   182→4. Anyone can verify the outcome matches\n   183→\n   184→On-Chain VRF (Jackpot, Flip You):\n   185→1. Game requests randomness from VRF provider\n   186→2. VRF generates verifiable random bytes\n   187→3. Result and proof stored on Solana blockchain\n   188→4. Anyone can verify using blockchain explorer\n   189→\n   190→Visit the Fairness page in the header for verification tools.`\n   191→    },\n   192→    {\n   193→      id: \"rng-buff\",\n   194→      title: \"Heater\",\n   195→      content: `The Heater is a powerful temporary bonus granted to players who help drop the Mark before the timer expires.\n   196→\n   197→How to get the Heater:\n   198→1. Participate in the hourly Dogpile Raid by wagering in any game\n   199→2. Your wagers land \"hits\" on the Mark\n   200→3. If the Mark is dropped before time runs out, ALL participants receive the Heater\n   201→4. The Heater lasts for 1 hour (until the next raid starts)\n   202→\n   203→Heater Benefits:\n   204→• Golden glowing border on your avatar (visible to all players)\n   205→• Chance to drop crates when wagering\n   206→• Drop chance scales with wager amount (1% base + 5% per SOL, max 25%)\n   207→\n   208→Visual Indicators:\n   209→• Golden pulsing border around your avatar everywhere in the app\n   210→• Heater icon with countdown timer in your profile header\n   211→• Star icon with timer in the main header\n   212→\n   213→The Heater expires when the next raid begins, so make the most of it!`\n   214→    },\n   215→    {\n   216→      id: \"treasure-chests\",\n   217→      title: \"Crates\",\n   218→      content: `Crates are mystery rewards that contain XP and SOL prizes. Open them in the Loot page.\n   219→\n   220→How to earn crates:\n   221→• Heater drops: Random chance when wagering with active Heater\n   222→• Complete ALL daily quests: 1 crate\n   223→• Complete weekly quests: 1 crate per quest (3 total)\n   224→• Complete ALL weekly quests: +2 bonus crates (5 total)\n   225→\n   226→Heater crate drop rates:\n   227→• Base chance: 1% per wager\n   228→• Bonus: +5% per 1 SOL wagered\n   229→• Maximum: 25% chance per wager\n   230→\n   231→Crate rarity (determined when opened):\n   232→• Common (50%): 50-100 XP, 0.001-0.005 SOL\n   233→• Uncommon (30%): 100-250 XP, 0.005-0.01 SOL\n   234→• Rare (15%): 250-500 XP, 0.01-0.025 SOL\n   235→• Epic (4%): 500-1000 XP, 0.025-0.05 SOL\n   236→• Legendary (1%): 1000-2500 XP, 0.05-0.1 SOL\n   237→\n   238→SOL rewards are paid from the platform treasury. May the RNG gods smile upon you!`\n   239→    },\n   240→  ];\n   241→\n   242→  return (\n   243→    <>\n   244→      <footer className=\"footer-v2\">\n   245→        <div className=\"ft-logo\">TAUNT<em>.</em></div>\n   246→        <div className=\"ft-links\">\n   247→          <button type=\"button\" className=\"ft-lnk\" onClick={() => setShowFAQ(true)}>FAQ</button>\n   248→          <button type=\"button\" className=\"ft-lnk\" onClick={() => setShowTerms(true)}>Terms</button>\n   249→          <a href=\"https://x.com/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"ft-lnk\">Twitter</a>\n   250→          <a href=\"https://t.me/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"ft-lnk\">Telegram</a>\n   251→        </div>\n   252→        <div className=\"ft-tag\">taunt.bet &middot; Provably Fair &middot; Solana</div>\n   253→      </footer>\n   254→\n   255→      {/* Terms Modal */}\n   256→      {showTerms && (\n   257→        <div className=\"footer-terms-overlay\">\n   258→          <div className=\"footer-terms-modal\" ref={termsModalRef}>\n   259→            <button\n   260→              type=\"button\"\n   261→              className=\"footer-terms-close\"\n   262→              onClick={() => setShowTerms(false)}\n   263→            >\n   264→              ×\n   265→            </button>\n   266→            <h3 className=\"footer-terms-title\">Terms of Use</h3>\n   267→            <div className=\"footer-terms-content\">\n   268→              <p>\n   269→                By accessing and using TAUNT, you confirm that you are not a citizen,\n   270→                resident, or located within any jurisdiction where online gambling is prohibited\n   271→                or restricted by law, including but not limited to: the United States,\n   272→                United Kingdom, France, Germany, Spain, the Netherlands, or any other\n   273→                jurisdiction with similar regulations.\n   274→              </p>\n   275→              <p>\n   276→                You are solely responsible for determining whether your use of this platform\n   277→                is lawful in your country or region of residence. TAUNT does not provide\n   278→                legal advice and assumes no liability for users who access the platform in\n   279→                violation of applicable laws.\n   280→              </p>\n   281→              <p>\n   282→                By continuing to use this service, you acknowledge and accept these terms.\n   283→              </p>\n   284→            </div>\n   285→            <button\n   286→              type=\"button\"\n   287→              className=\"footer-terms-accept\"\n   288→              onClick={() => setShowTerms(false)}\n   289→            >\n   290→              I Understand\n   291→            </button>\n   292→          </div>\n   293→        </div>\n   294→      )}\n   295→\n   296→      {/* FAQ Modal */}\n   297→      {showFAQ && (\n   298→        <div className=\"footer-faq-overlay\">\n   299→          <div className=\"footer-faq-modal\" ref={faqModalRef}>\n   300→            <button\n   301→              type=\"button\"\n   302→              className=\"footer-faq-close\"\n   303→              onClick={() => setShowFAQ(false)}\n   304→            >\n   305→              ×\n   306→            </button>\n   307→            <h3 className=\"footer-faq-title\">Frequently Asked Questions</h3>\n   308→            <div className=\"footer-faq-content\">\n   309→              {faqSections.map((section) => (\n   310→                <div key={section.id} className=\"faq-section\">\n   311→                  <button\n   312→                    type=\"button\"\n   313→                    className={`faq-section-header ${expandedFAQ === section.id ? \"expanded\" : \"\"}`}\n   314→                    onClick={() => toggleFAQSection(section.id)}\n   315→                  >\n   316→                    <span className=\"faq-section-title\">{section.title}</span>\n   317→                    <span className=\"faq-section-arrow\">{expandedFAQ === section.id ? \"−\" : \"+\"}</span>\n   318→                  </button>\n   319→                  {expandedFAQ === section.id && (\n   320→                    <div className=\"faq-section-content\">\n   321→                      {section.content.split(\"\\n\\n\").map((paragraph, idx) => (\n   322→                        <p key={idx}>{paragraph}</p>\n   323→                      ))}\n   324→                    </div>\n   325→                  )}\n   326→                </div>\n   327→              ))}\n   328→            </div>\n   329→            <button\n   330→              type=\"button\"\n   331→              className=\"footer-faq-close-btn\"\n   332→              onClick={() => setShowFAQ(false)}\n   333→            >\n   334→              Close\n   335→            </button>\n   336→          </div>\n   337→        </div>\n   338→      )}\n   339→    </>\n   340→  );\n   341→}\n   342→\n   343→function AppContent() {\n   344→  const [chatExpanded, setChatExpanded] = useState(false);\n   345→  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);\n   346→\n   347→  const toggleSidebar = () => {\n   348→    setSidebarCollapsed(!sidebarCollapsed);\n   349→    document.body.classList.toggle(\"nc\", !sidebarCollapsed);\n   350→  };\n   351→\n   352→  return (\n   353→    <div className=\"app\">\n   354→      <BackgroundEffects />\n   355→\n   356→      {/* Fixed top bar */}\n   357→      <div className=\"top-bar\">\n   358→        <Header />\n   359→        <Ticker />\n   360→      </div>\n   361→\n   362→      {/* Fixed sidebar */}\n   363→      <Sidebar collapsed={sidebarCollapsed} onToggle={toggleSidebar} />\n   364→\n   365→      <main className=\"main\">\n   366→        <Routes>\n   367→          <Route path=\"/\" element={<HomePage />} />\n   368→          <Route path=\"/coinflip\" element={<CoinflipPage />} />\n   369→          <Route path=\"/coinflip/:matchId\" element={<CoinflipPage />} />\n   370→          <Route path=\"/lord-of-rngs\" element={<LordOfRngsPage />} />\n   371→          <Route path=\"/lord-of-rngs/:matchId\" element={<LordOfRngsPage />} />\n   372→          <Route path=\"/close-call\" element={<CloseCallPage />} />\n   373→          <Route path=\"/crash\" element={<CryptoCrashPage />} />\n   374→          <Route path=\"/game-of-trades\" element={<GameOfTradesPage />} />\n   375→          <Route path=\"/profile\" element={<ProfilePage />} />\n   376→          <Route path=\"/loot\" element={<LootPage />} />\n   377→          <Route path=\"/quests\" element={<QuestsPage />} />\n   378→          <Route path=\"/fairness\" element={<FairnessPage />} />\n   379→          <Route path=\"/coinflip/:matchId/proof\" element={<CoinflipRoundPage />} />\n   380→          <Route path=\"/lord-of-rngs/:matchId/proof\" element={<LordRoundPage />} />\n   381→          <Route path=\"*\" element={<NotFoundPage />} />\n   382→        </Routes>\n   383→        <Footer />\n   384→      </main>\n   385→\n   386→      <BuildBadge />\n   387→\n   388→      {/* Floating chat button */}\n   389→      <div className=\"chat-float\">\n   390→        <button type=\"button\" className=\"chat-float__btn\" onClick={() => setChatExpanded(!chatExpanded)}>\n   391→          <ChatIcon />\n   392→          <span className=\"chat-float__dot\" />\n   393→        </button>\n   394→        {chatExpanded && (\n   395→          <div className=\"chat-float__panel\">\n   396→            <div className=\"chat-panel-header\">\n   397→              <h4>Global Chat</h4>\n   398→              <button className=\"chat-close\" onClick={() => setChatExpanded(false)}>×</button>\n   399→            </div>\n   400→            <div className=\"chat-messages\">\n   401→              <div className=\"chat-message\">\n   402→                <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   403→                <span className=\"text\">gg nice flip!</span>\n   404→              </div>\n   405→              <div className=\"chat-message\">\n   406→                <PlayerAvatarCompact address=\"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   407→                <span className=\"text\">who's ready for crash?</span>\n   408→              </div>\n   409→              <div className=\"chat-message\">\n   410→                <PlayerAvatarCompact address=\"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   411→                <span className=\"text\">close call is rigged lol jk</span>\n   412→              </div>\n   413→              <div className=\"chat-message\">\n   414→                <PlayerAvatarCompact address=\"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   415→                <span className=\"text\">just hit 5x on crash!</span>\n   416→              </div>\n   417→              <div className=\"chat-message\">\n   418→                <PlayerAvatarCompact address=\"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n   419→                <span className=\"text\">coinflip is where it's at</span>\n   420→              </div>\n   421→            </div>\n   422→            <div className=\"chat-input-container\">\n   423→              <input type=\"text\" className=\"chat-input\" placeholder=\"Type a message...\" />\n   424→              <button className=\"chat-send-btn\">Send</button>\n   425→            </div>\n   426→          </div>\n   427→        )}\n   428→      </div>\n   429→\n   430→      <MiniProfileModal />\n   431→      <ChestDropNotification />\n   432→    </div>\n   433→  );\n   434→}\n   435→\n   436→// Mock recent winners data\n   437→const RECENT_WINNERS = [\n   438→  { player: \"CryptoSavage.eth\", game: \"FLIP YOU\", amount: \"+$194.00\", positive: true, taunt: \"later, bitch\", color: \"#FFB800\" },\n   439→  { player: \"degen_whale_99\", game: \"MOON OR REKT\", amount: \"+$407.40\", positive: true, taunt: \"gg ez lmao\", color: \"#FF2D55\" },\n   440→  { player: \"0x9f…22b1\", game: \"JACKPOT\", amount: \"+$38.80\", positive: true, taunt: null, color: \"#FF1F8E\" },\n   441→  { player: \"paper_hands_pete\", game: \"FLIP YOU\", amount: \"-$10.00\", positive: false, taunt: \"skill issue ngl\", color: \"#FFB800\" },\n   442→  { player: \"sol_degen_88\", game: \"GAME OF TRADES\", amount: \"+$30.00\", positive: true, taunt: null, color: \"#3D7FFF\" },\n   443→  { player: \"anon_8821\", game: \"JACKPOT\", amount: \"+$146.55\", positive: true, taunt: \"the RNG chose me\", color: \"#FF1F8E\" },\n   444→  { player: \"0x3b…81a2\", game: \"CLOSE CALL\", amount: \"+$18.40\", positive: true, taunt: null, color: \"#00E676\" },\n   445→  { player: \"moon_maxi_99\", game: \"CRYPTO CRASH\", amount: \"+$82.10\", positive: true, taunt: \"rekt. bye.\", color: \"#FF2D55\" },\n   446→];\n   447→\n   448→function HomePage() {\n   449→  return (\n   450→    <>\n   451→      {/* Page header */}\n   452→      <div className=\"page-hd\">\n   453→        <div>\n   454→          <div className=\"pg-title\">The <span className=\"pk\">Pit.</span></div>\n   455→          <div className=\"pg-sub\">Five ways to ruin someone's day</div>\n   456→        </div>\n   457→        <div className=\"pg-tags\">\n   458→          <div className=\"ptag on\">Floor Open · 24/7</div>\n   459→          <div className=\"ptag\">3% Flat Fee · Zero House Edge</div>\n   460→          <div className=\"ptag\">Provably Fair · Solana</div>\n   461→        </div>\n   462→      </div>\n   463→\n   464→      {/* Game grid */}\n   465→      <div className=\"game-grid\">\n   466→        <GameCardV2\n   467→          name=\"Flip You\"\n   468→          subtitle=\"$0.50 — $100 · P2P · 1v1\"\n   469→          description=\"Pure 50/50. One winner takes the pot. Your opponent sees your taunt the moment they lose.\"\n   470→          path=\"/coinflip\"\n   471→          visual=\"coinflip\"\n   472→          mode=\"VRF · On-chain\"\n   473→          colorClass=\"y\"\n   474→          stats={[\n   475→            { value: \"18\", label: \"Open Games\" },\n   476→            { value: \"6\", label: \"Tiers\" },\n   477→            { value: \"97%\", label: \"Payout\" },\n   478→          ]}\n   479→        />\n   480→        <GameCardV2\n   481→          name=\"Jackpot\"\n   482→          subtitle=\"$0.50 — $100 · P2P · Lottery\"\n   483→          description=\"Buy tickets, buy odds. One spin decides everything. The wheel doesn't care how many you own.\"\n   484→          path=\"/lord-of-rngs\"\n   485→          visual=\"lotr\"\n   486→          mode=\"VRF · On-chain\"\n   487→          colorClass=\"pk\"\n   488→          stats={[\n   489→            { value: \"$146\", label: \"Top Jackpot\" },\n   490→            { value: \"6\", label: \"Active\" },\n   491→            { value: \"VRF\", label: \"Randomness\" },\n   492→          ]}\n   493→        />\n   494→        <GameCardV2\n   495→          name=\"Close Call\"\n   496→          subtitle=\"$0.50 — $100 · P2P · Binary\"\n   497→          description=\"Green or red. Lock in before the round closes. Winners split the losers' side pro-rata.\"\n   498→          path=\"/close-call\"\n   499→          visual=\"close-call\"\n   500→          mode=\"Commit-Reveal\"\n   501→          colorClass=\"g\"\n   502→          stats={[\n   503→            { value: \"$892\", label: \"Active Pool\" },\n   504→            { value: \"1.46×\", label: \"Green Odds\" },\n   505→            { value: \"43s\", label: \"Time Left\" },\n   506→          ]}\n   507→        />\n   508→        <GameCardV2\n   509→          name=\"Crypto Crash\"\n   510→          subtitle=\"$0.50 — $100 · P2P · Crash\"\n   511→          description=\"Multiplier climbs. Cash out before it crashes. The last player in wins the Diamond pot.\"\n   512→          path=\"/crash\"\n   513→          visual=\"crash\"\n   514→          mode=\"Commit-Reveal\"\n   515→          colorClass=\"r\"\n   516→          stats={[\n   517→            { value: \"1.84×\", label: \"Live Multi\" },\n   518→            { value: \"$1,842\", label: \"Diamond Pot\" },\n   519→            { value: \"CR\", label: \"Provably Fair\" },\n   520→          ]}\n   521→        />\n   522→        <GameCardV2\n   523→          name=\"Game of Trades\"\n   524→          subtitle=\"$0.50 — $100 · P2P · Sim\"\n   525→          description=\"$10k paper balance. 100× leverage. 60 seconds on a live chart. Best PnL takes the pot.\"\n   526→          path=\"/game-of-trades\"\n   527→          visual=\"trades\"\n   528→          mode=\"100× Leverage\"\n   529→          colorClass=\"b\"\n   530→          stats={[\n   531→            { value: \"$600\", label: \"Largest Pot\" },\n   532→            { value: \"32\", label: \"In Lobbies\" },\n   533→            { value: \"60s\", label: \"Round Time\" },\n   534→          ]}\n   535→        />\n   536→      </div>\n   537→\n   538→      {/* Recent winners strip */}\n   539→      <div className=\"wins-strip\">\n   540→        <div className=\"wins-hd\"><div className=\"pdot\" />Recent Winners</div>\n   541→        <div className=\"wins-in\">\n   542→          {RECENT_WINNERS.map((w, i) => (\n   543→            <div key={i} className=\"wchip\" style={{ \"--wc\": w.color } as React.CSSProperties}>\n   544→              <div>\n   545→                <div className=\"wchip-player\">{w.player}</div>\n   546→                <div className=\"wchip-game\">{w.game}</div>\n   547→                {w.taunt && <div className=\"wchip-taunt\">\"{w.taunt}\"</div>}\n   548→              </div>\n   549→              <div className={`wchip-amt ${w.positive ? \"p\" : \"n\"}`}>{w.amount}</div>\n   550→            </div>\n   551→          ))}\n   552→        </div>\n   553→      </div>\n   554→    </>\n   555→  );\n   556→}\n   557→\n   558→interface GameCardV2Props {\n   559→  name: string;\n   560→  subtitle: string;\n   561→  description: string;\n   562→  path: string;\n   563→  visual: string;\n   564→  mode: string;\n   565→  colorClass: string;\n   566→  stats: { value: string; label: string }[];\n   567→}\n   568→\n   569→function GameCardV2({ name, subtitle, description, path, visual, mode, colorClass, stats }: GameCardV2Props) {\n   570→  return (\n   571→    <Link to={path} className={`gcard gc-${colorClass}`}>\n   572→      <div className=\"gcard-accent\" />\n   573→      <div className=\"gcard-vis\">\n   574→        <div className=\"gcard-bg\" />\n   575→        <GameVisualV2 type={visual} />\n   576→      </div>\n   577→      <div className=\"gcard-info\">\n   578→        <div className=\"gcard-hd\">\n   579→          <div>\n   580→            <div className=\"gcard-name\">{name}</div>\n   581→            <div className=\"gcard-sub2\">{subtitle}</div>\n   582→          </div>\n   583→          <div className=\"gcard-mode\">{mode}</div>\n   584→        </div>\n   585→        <div className=\"gcard-line\">{description}</div>\n   586→        <div className=\"gcard-stats\">\n   587→          {stats.map((s, i) => (\n   588→            <div key={i} className=\"gstat\">\n   589→              <div className=\"gstat-n\">{s.value}</div>\n   590→              <div className=\"gstat-l\">{s.label}</div>\n   591→            </div>\n   592→          ))}\n   593→        </div>\n   594→        <button type=\"button\" className=\"gcard-btn\" onClick={(e) => e.preventDefault()}>\n   595→          <div className=\"gcard-bf\" />\n   596→          <span className=\"gcard-btxt\">Enter Game</span>\n   597→          <span className=\"gcard-arr\">&rarr;</span>\n   598→        </button>\n   599→      </div>\n   600→    </Link>\n   601→  );\n   602→}\n   603→\n   604→function GameVisualV2({ type }: { type: string }) {\n   605→  switch (type) {\n   606→    case \"coinflip\":\n   607→      return (\n   608→        <svg className=\"gcard-ico coin-flip\" viewBox=\"0 0 135 135\" fill=\"none\">\n   609→          <circle cx=\"67.5\" cy=\"67.5\" r=\"60\" fill=\"#111118\" stroke=\"#FFB800\" strokeWidth=\"2.5\" />\n   610→          <circle cx=\"67.5\" cy=\"67.5\" r=\"52\" fill=\"none\" stroke=\"rgba(255,184,0,0.12)\" strokeWidth=\"1\" />\n   611→          <circle cx=\"67.5\" cy=\"67.5\" r=\"43\" fill=\"none\" stroke=\"rgba(255,184,0,0.07)\" strokeWidth=\"1\" strokeDasharray=\"5 5\" />\n   612→          <path d=\"M22 44 A60 60 0 0 1 113 44\" stroke=\"rgba(255,184,0,0.28)\" strokeWidth=\"3.5\" strokeLinecap=\"round\" fill=\"none\" />\n   613→          <text x=\"67.5\" y=\"86\" textAnchor=\"middle\" fontFamily=\"'Bebas Neue', sans-serif\" fontSize=\"46\" fill=\"#FFB800\" letterSpacing=\"2\">H</text>\n   614→          <circle cx=\"67.5\" cy=\"11\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n   615→          <circle cx=\"67.5\" cy=\"124\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n   616→          <circle cx=\"11\" cy=\"67.5\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n   617→          <circle cx=\"124\" cy=\"67.5\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n   618→        </svg>\n   619→      );\n   620→\n   621→    case \"lotr\":\n   622→      return (\n   623→        <svg className=\"gcard-ico\" viewBox=\"0 0 135 135\" fill=\"none\">\n   624→          <circle cx=\"67.5\" cy=\"67.5\" r=\"62\" fill=\"#111118\" stroke=\"#FF1F8E\" strokeWidth=\"2\" />\n   625→          <g className=\"spin-slow\">\n   626→            <path d=\"M67.5 67.5L67.