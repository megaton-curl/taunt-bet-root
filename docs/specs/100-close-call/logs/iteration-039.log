{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019gN5fQ4fMA3bq4FffedeWf","type":"tool_result","content":"   150→  createdAt: { toNumber(): number };\n   151→  matchId: number[];\n   152→  bump: number;\n   153→}\n   154→\n   155→// ============ Converters ============\n   156→\n   157→function sideFromIndex(index: number): CoinSide {\n   158→  return index === 0 ? \"heads\" : \"tails\";\n   159→}\n   160→\n   161→function phaseToUI(phase: number): UIMatch[\"phase\"] {\n   162→  if (phase === PHASE_WAITING) return \"created\";\n   163→  if (phase === PHASE_LOCKED) return \"ready\";\n   164→  if (phase === PHASE_SETTLED) return \"complete\";\n   165→  return \"created\";\n   166→}\n   167→\n   168→const DEFAULT_PUBKEY = PublicKey.default;\n   169→\n   170→function isDefaultPubkey(key: PublicKey): boolean {\n   171→  return key.equals(DEFAULT_PUBKEY);\n   172→}\n   173→\n   174→import { bytesToHex, sha256 } from \"./crypto\";\n   175→\n   176→export function onChainMatchToUI(\n   177→  matchPda: PublicKey,\n   178→  data: OnChainMatch\n   179→): UIMatch {\n   180→  const creatorSide = sideFromIndex(data.creatorSide);\n   181→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   182→  const phase = phaseToUI(data.phase);\n   183→  const isSettled = data.phase === PHASE_SETTLED;\n   184→\n   185→  const entryAmountSol = data.entryAmount.toNumber() / 1e9;\n   186→  const totalPool = entryAmountSol * 2;\n   187→  const payoutAmount = totalPool * 0.97;\n   188→\n   189→  return {\n   190→    id: matchPda.toBase58(),\n   191→    matchId: bytesToHex(data.matchId),\n   192→    entryAmount: entryAmountSol,\n   193→    player1: data.creator.toBase58(),\n   194→    player1Side: creatorSide,\n   195→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   196→    player2Side: hasOpponent\n   197→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   198→      : null,\n   199→    server: data.server.toBase58(),\n   200→    phase,\n   201→    createdAt: data.createdAt.toNumber() * 1000,\n   202→    lockedAt: data.phase >= PHASE_LOCKED && data.resolveDeadline.toNumber() > 0\n   203→      ? (data.resolveDeadline.toNumber() - 86400) * 1000\n   204→      : undefined,\n   205→    result: isSettled ? sideFromIndex(data.result) : null,\n   206→    winner: isSettled && !isDefaultPubkey(data.winner)\n   207→      ? data.winner.toBase58()\n   208→      : null,\n   209→    payoutAmount,\n   210→    commitment: bytesToHex(data.commitment),\n   211→    resultHash: isSettled ? bytesToHex(data.resultHash) : undefined,\n   212→    targetSlot: data.targetSlot.toNumber() || undefined,\n   213→  };\n   214→}\n   215→\n   216→// ============ Account Queries ============\n   217→\n   218→export async function fetchAllOpenMatches(\n   219→  connection: Connection\n   220→): Promise<UIMatch[]> {\n   221→  const program = getCoinflipProgram(connection);\n   222→  const accounts = await program.account.coinflipMatch.all([\n   223→    { dataSize: program.account.coinflipMatch.size },\n   224→  ]);\n   225→\n   226→  return accounts\n   227→    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n   228→    .map((acc) =>\n   229→      onChainMatchToUI(\n   230→        acc.publicKey,\n   231→        acc.account as unknown as OnChainMatch\n   232→      )\n   233→    );\n   234→}\n   235→\n   236→/**\n   237→ * Fetch all matches where playerPubkey is creator OR opponent,\n   238→ * phase is non-terminal (not refunded/settled with PDA closed).\n   239→ * Uses memcmp filters for efficient on-chain filtering.\n   240→ *\n   241→ * Account layout offsets (after 8-byte discriminator):\n   242→ *   creator:  8   (32 bytes)\n   243→ *   opponent: 40  (32 bytes)\n   244→ */\n   245→export async function fetchClaimableMatches(\n   246→  connection: Connection,\n   247→  playerPubkey: PublicKey\n   248→): Promise<UIMatch[]> {\n   249→  const program = getCoinflipProgram(connection);\n   250→  const playerBase58 = playerPubkey.toBase58();\n   251→\n   252→  const [asCreator, asOpponent] = await Promise.all([\n   253→    program.account.coinflipMatch.all([\n   254→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   255→      { dataSize: program.account.coinflipMatch.size },\n   256→    ]),\n   257→    program.account.coinflipMatch.all([\n   258→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   259→      { dataSize: program.account.coinflipMatch.size },\n   260→    ]),\n   261→  ]);\n   262→\n   263→  // Merge and deduplicate by public key\n   264→  const seen = new Set<string>();\n   265→  const matches: UIMatch[] = [];\n   266→\n   267→  for (const acc of [...asCreator, ...asOpponent]) {\n   268→    const key = acc.publicKey.toBase58();\n   269→    if (seen.has(key)) continue;\n   270→    seen.add(key);\n   271→\n   272→    const data = acc.account as unknown as OnChainMatch;\n   273→    // Skip terminal phases\n   274→    if (data.phase === PHASE_REFUNDED || data.phase === PHASE_SETTLED) continue;\n   275→\n   276→    matches.push(onChainMatchToUI(acc.publicKey, data));\n   277→  }\n   278→\n   279→  return matches;\n   280→}\n   281→\n   282→/**\n   283→ * Find all active (non-terminal) matches for a creator using memcmp filters.\n   284→ * Returns all matches, not just the first one (supports multiple concurrent matches).\n   285→ */\n   286→export async function fetchMatchesByCreator(\n   287→  connection: Connection,\n   288→  creator: PublicKey\n   289→): Promise<UIMatch[]> {\n   290→  const program = getCoinflipProgram(connection);\n   291→\n   292→  const matches = await program.account.coinflipMatch.all([\n   293→    { memcmp: { offset: 8, bytes: creator.toBase58() } },\n   294→    { dataSize: program.account.coinflipMatch.size },\n   295→  ]);\n   296→\n   297→  return matches\n   298→    .filter((acc) => {\n   299→      const data = acc.account as unknown as OnChainMatch;"}]},"parent_tool_use_id":"toolu_01VjBSw9tMWntCUQGUX3iNN9","session_id":