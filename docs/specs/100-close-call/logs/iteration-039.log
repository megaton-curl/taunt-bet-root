 prevRoundIdRef.current !== round.id) {\n          // Fetch the completed round from history for result overlay\n          const history = await fetchRoundHistory(1);\n          if (!cancelled && history.length > 0 && history[0].id === prevRoundIdRef.current) {\n            setCompletedRound(history[0]);\n          }\n        }\n        prevRoundIdRef.current = round.id;\n        setCurrentRound(round);\n      } else {\n        // No active round — check if previous round just settled\n        if (prevRoundIdRef.current) {\n          const history = await fetchRoundHistory(1);\n          if (!cancelled && history.length > 0 && history[0].id === prevRoundIdRef.current) {\n            setCompletedRound(history[0]);\n          }\n          prevRoundIdRef.current = null;\n        }\n        setCurrentRound(null);\n      }\n      setLoading(false);\n    }\n\n    // Initial fetch","numLines":30,"startLine":260,"totalLines":483}}}
