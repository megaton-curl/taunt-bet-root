{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XVhYG3BNm2CDhS1HzePtyM","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey, type Transaction } from \"@solana/web3.js\";\n    11→import type { UIMatch, CoinSide } from \"../types\";\n    12→import {\n    13→  fetchAllOpenMatches,\n    14→  fetchClaimableMatches,\n    15→  fetchMatch,\n    16→  buildJoinMatchTx,\n    17→  buildCancelMatchTx,\n    18→  buildTimeoutRefundTx,\n    19→  buildBackendCreateMatchTx,\n    20→  fetchRoundVerification,\n    21→  applyBackendRoundToMatch,\n    22→  fetchMatchByMatchId,\n    23→  BackendRequestError,\n    24→} from \"../utils/chain\";\n    25→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    26→import { useSession } from \"../../../context/SessionContext\";\n    27→import { getAccessToken } from \"../../../lib/auth-store\";\n    28→import { useSettlementEvent } from \"../../../lib/useSettlementEvent\";\n    29→\n    30→// ---------------------------------------------------------------------------\n    31→// Lifecycle logger — helps trace phase transitions and settlement timing.\n    32→// All logs use a shared tag so they can be filtered in devtools:\n    33→//   console filter: [coinflip]\n    34→// ---------------------------------------------------------------------------\n    35→function logLife(event: string, data?: Record<string, unknown>) {\n    36→  const ts = new Date().toISOString().slice(11, 23); // HH:mm:ss.SSS\n    37→  const extra = data ? \" \" + JSON.stringify(data) : \"\";\n    38→  // eslint-disable-next-line no-console\n    39→  console.log(`[coinflip] ${ts} ${event}${extra}`);\n    40→}\n    41→\n    42→/** Parse Solana/wallet errors into user-friendly messages */\n    43→function parseTransactionError(err: unknown): string {\n    44→  if (err instanceof BackendRequestError) {\n    45→    if (err.status === 401) {\n    46→      return \"Backend authentication failed. Please approve message signing and try again.\";\n    47→    }\n    48→    if (err.status === 409) {\n    49→      return \"Match creation failed — please retry.\";\n    50→    }\n    51→    if (err.status === 429) {\n    52→      return \"Too many create attempts. Please wait a moment and try again.\";\n    53→    }\n    54→    return err.message;\n    55→  }\n    56→\n    57→  const msg = err instanceof Error ? err.message : String(err);\n    58→\n    59→  // Wallet not connected\n    60→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    61→    return \"Wallet not connected. Please connect your wallet first.\";\n    62→  }\n    63→\n    64→  // User rejected\n    65→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    66→    return \"Transaction cancelled by user.\";\n    67→  }\n    68→\n    69→  // Insufficient funds (Solana runtime error)\n    70→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    71→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    72→  }\n    73→\n    74→  // Account already in use (match already exists)\n    75→  if (msg.includes(\"already in use\")) {\n    76→    return \"You already have an active match. Cancel it before creating a new one.\";\n    77→  }\n    78→\n    79→  // Network / RPC errors\n    80→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    81→    return \"Network error. Please check your connection and try again.\";\n    82→  }\n    83→\n    84→  // Anchor program errors\n    85→  if (msg.includes(\"InvalidPhase\")) {\n    86→    return \"This match is no longer available.\";\n    87→  }\n    88→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    89→    return \"You cannot join your own match.\";\n    90→  }\n    91→\n    92→  // Simulation / preflight failures\n    93→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    94→    return \"Transaction simulation failed. The match may no longer be available.\";\n    95→  }\n    96→\n    97→  // Blockhash expiry\n    98→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    99→    return \"Transaction expired. Please try again.\";\n   100→  }\n   101→\n   102→  // Generic fallback — log full error for debugging\n   103→  console.error(\"[coinflip] unhandled transaction error:\", err);\n   104→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n   105→}\n   106→\n   107→interface CoinflipContextValue {\n   108→  // State\n   109→  activeMatch: UIMatch | null;\n   110→  openMatches: UIMatch[];\n   111→  claimableMatches: UIMatch[];\n   112→  userHistory: UIMatch[];\n   113→  wagerAmount: number | null;\n   114→  selectedSide: CoinSide | null;\n   115→\n   116→  // Loading states\n   117→  loading: boolean;\n   118→  creating: boolean;\n   119→  joining: boolean;\n   120→  joiningMatchId: string | null;\n   121→\n   122→  // Error state\n   123→  error: string | null;\n   124→  clearError: () => void;\n   125→\n   126→  // Verification\n   127→  lastSettleSignature: string | null;\n   128→\n   129→  // Actions\n   130→  setWagerAmount: (amount: number | null) => void;\n   131→  setSelectedSide: (side: CoinSide | null) => void;\n   132→  createMatch: () => Promise<void>;\n   133→  joinMatch: (matchId: string) => Promise<void>;\n   134→  cancelMatch: () => Promise<void>;\n   135→  timeoutRefund: () => Promise<void>;\n   136→  clearActiveMatch: () => void;\n   137→  selectMatch: (match: UIMatch) => void;\n   138→  refreshMatches: () => void;\n   139→}\n   140→\n   141→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n   142→\n   143→export function CoinflipProvider({ children }: { children: ReactNode }) {\n   144→  const { connected, publicKey, sendTransaction } = useWallet();\n   145→  const { connection } = useConnection();\n   146→  const { refresh: refreshBalance } = useBalance();\n   147→  const { accessToken, isAuthenticated, authenticate } = useSession();\n   148→\n   149→  // Selection state\n   150→  const [wagerAmount, setWagerAmount] = useState<number | null>(null);\n   151→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   152→\n   153→  // Match state\n   154→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   155→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   156→  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n   157→  const [userHistory] = useState<UIMatch[]>([]);\n   158→\n   159→  // Loading states\n   160→  const [loading, setLoading] = useState(true);\n   161→  const [creating, setCreating] = useState(false);\n   162→  const [joining, setJoining] = useState(false);\n   163→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   164→\n   165→  // Error state\n   166→  const [error, setError] = useState<string | null>(null);\n   167→  const clearError = useCallback(() => setError(null), []);\n   168→\n   169→  // Verification — last settle tx signature for fairness verification\n   170→  const [lastSettleSignature, setLastSettleSignature] = useState<string | null>(null);\n   171→\n   172→  // Timer ref for countdown (3s) then flip animation minimum (3s)\n   173→  const countdownTimerRef = useRef<number | null>(null);\n   174→  const flipTimerRef = useRef<number | null>(null);\n   175→  const refreshInFlightRef = useRef(false);\n   176→  const activeMatchFetchInFlightRef = useRef(false);\n   177→\n   178→  // Ref to prevent polling races from restoring a dismissed match.\n   179→  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n   180→  // from the previous poll interval may resolve and call setActiveMatch,\n   181→  // putting them back on the match view. This ref blocks that.\n   182→  const dismissedMatchRef = useRef<string | null>(null);\n   183→\n   184→  /** Send transaction, wait for on-chain confirmation, and refresh balance.\n   185→   *  Retries on blockhash expiry (devnet tx drops) up to 3 times. */\n   186→  const sendAndConfirm = useCallback(\n   187→    async (transaction: Transaction): Promise<string> => {\n   188→      const hasPartialSignatures = transaction.signatures.some(\n   189→        (entry) => entry.signature !== null\n   190→      );\n   191→      const preservesExternalSignature =\n   192→        hasPartialSignatures &&\n   193→        typeof transaction.recentBlockhash === \"string\";\n   194→      const hasPinnedBlockhash =\n   195→        preservesExternalSignature &&\n   196→        typeof transaction.lastValidBlockHeight === \"number\";\n   197→\n   198→      if (preservesExternalSignature && !hasPinnedBlockhash) {\n   199→        throw new Error(\n   200→          \"Backend transaction is missing lastValidBlockHeight. Refusing to send with an incomplete confirmation contract.\",\n   201→        );\n   202→      }\n   203→\n   204→      // Pre-flight simulation for diagnostics (best-effort, unsigned).\n   205→      // Abort early on InstructionError — the tx will fail on-chain too.\n   206→      // The blockhash fetched here is reused for the first send attempt.\n   207→      let cachedBlockhash: string | undefined;\n   208→      let cachedHeight: number | undefined;\n   209→      try {\n   210→        if (!preservesExternalSignature) {\n   211→          const { blockhash, lastValidBlockHeight } =\n   212→            await connection.getLatestBlockhash(\"confirmed\");\n   213→          cachedBlockhash = blockhash;\n   214→          cachedHeight = lastValidBlockHeight;\n   215→          transaction.recentBlockhash = blockhash;\n   216→        }\n   217→\n   218→        const simResult = await connection.simulateTransaction(transaction);\n   219→        if (simResult.value.err) {\n   220→          console.error(\n   221→            \"[coinflip] simulation failed BEFORE wallet send:\",\n   222→            JSON.stringify(simResult.value.err),\n   223→          );\n   224→          if (simResult.value.logs) {\n   225→            console.error(\n   226→              \"[coinflip] simulation logs:\\n\" + simResult.value.logs.join(\"\\n\"),\n   227→            );\n   228→          }\n   229→          const err = simResult.value.err;\n   230→          if (typeof err === \"object\" && err !== null && \"InstructionError\" in err) {\n   231→            throw new Error(`Transaction will fail: ${JSON.stringify(err)}`);\n   232→          }\n   233→        }\n   234→      } catch (simErr) {\n   235→        if (simErr instanceof Error && simErr.message.startsWith(\"Transaction will fail:\")) {\n   236→          throw simErr;\n   237→        }\n   238→        console.error(\"[coinflip] simulation RPC error:\", simErr);\n   239→      }\n   240→\n   241→      // Send with retry — devnet txs can be dropped by validators/RPCs.\n   242→      const MAX_SEND_ATTEMPTS = preservesExternalSignature ? 1 : 3;\n   243→      for (let attempt = 1; attempt <= MAX_SEND_ATTEMPTS; attempt++) {\n   244→        let blockhash: string;\n   245→        let lastValidBlockHeight: number;\n   246→        if (preservesExternalSignature) {\n   247→          blockhash = transaction.recentBlockhash!;\n   248→          lastValidBlockHeight = transaction.lastValidBlockHeight ?? 0;\n   249→        } else if (attempt === 1 && cachedBlockhash && cachedHeight) {\n   250→          // Reuse simulation blockhash for first attempt (saves an RPC call)\n   251→          blockhash = cachedBlockhash;\n   252→          lastValidBlockHeight = cachedHeight;\n   253→        } else {\n   254→          // Fresh blockhash for retries (previous one may have expired)\n   255→          const fresh = await connection.getLatestBlockhash(\"confirmed\");\n   256→          blockhash = fresh.blockhash;\n   257→          lastValidBlockHeight = fresh.lastValidBlockHeight;\n   258→        }\n   259→        if (!preservesExternalSignature) {\n   260→          transaction.recentBlockhash = blockhash;\n   261→        }\n   262→\n   263→        const signature = await sendTransaction(transaction);\n   264→        console.log(`[coinflip] tx sent (attempt ${attempt}/${MAX_SEND_ATTEMPTS}): ${signature}`);\n   265→\n   266→        const controller = new AbortController();\n   267→        const timeout = setTimeout(() => controller.abort(), 30_000);\n   268→        try {\n   269→          if (preservesExternalSignature) {\n   270→            await connection.confirmTransaction(\n   271→              { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n   272→              \"confirmed\",\n   273→            );\n   274→          } else {\n   275→            await connection.confirmTransaction(\n   276→              { signature, blockhash, lastValidBlockHeight, abortSignal: controller.signal },\n   277→              \"confirmed\",\n   278→            );\n   279→          }\n   280→          // Success — refresh balance and return\n   281→          await refreshBalance();\n   282→          return signature;\n   283→        } catch (confirmErr) {\n   284→          const msg = confirmErr instanceof Error ? confirmErr.message : String(confirmErr);\n   285→          const isExpired = msg.includes(\"expired\") || msg.includes(\"block height exceeded\");\n   286→          const isAborted = msg.includes(\"aborted\");\n   287→\n   288→          if ((isExpired || isAborted) && attempt < MAX_SEND_ATTEMPTS) {\n   289→            // Before retrying, check if the tx actually landed despite confirm failure\n   290→            // (common when devnet WebSocket drops the subscription notification)\n   291→            try {\n   292→              const status = await connection.getSignatureStatus(signature);\n   293→              if (\n   294→                status.value?.confirmationStatus === \"confirmed\" ||\n   295→                status.value?.confirmationStatus === \"finalized\"\n   296→              ) {\n   297→                console.log(`[coinflip] tx ${signature} confirmed via fallback status check`);\n   298→                await refreshBalance();\n   299→                return signature;\n   300→              }\n   301→            } catch {\n   302→              // Status check failed — fall through to retry\n   303→            }\n   304→            console.warn(`[coinflip] tx dropped/expired on attempt ${attempt}, retrying...`);\n   305→            continue;\n   306→          }\n   307→          throw confirmErr;\n   308→        } finally {\n   309→          clearTimeout(timeout);\n   310→        }\n   311→      }\n   312→\n   313→      throw new Error(\"Transaction failed after max retry attempts\");\n   314→    },\n   315→    [connection, sendTransaction, refreshBalance],\n   316→  );\n   317→\n   318→  // Fetch open matches + claimable matches from on-chain (lobby data).\n   319→  // Only called when the user is in the lobby — NOT during an active match.\n   320→  const refreshMatches = useCallback(async () => {\n   321→    if (refreshInFlightRef.current) return;\n   322→    refreshInFlightRef.current = true;\n   323→\n   324→    try {\n   325→      const [matches, claimable] = await Promise.all([\n   326→        fetchAllOpenMatches(connection),\n   327→        publicKey\n   328→          ? fetchClaimableMatches(connection, publicKey)\n   329→          : Promise.resolve([]),\n   330→      ]);\n   331→\n   332→      setOpenMatches(matches);\n   333→      setClaimableMatches(claimable);\n   334→    } catch {\n   335→      // Ignore transient RPC failures; polling will retry on next cycle.\n   336→    } finally {\n   337→      setLoading(false);\n   338→      refreshInFlightRef.current = false;\n   339→    }\n   340→  }, [connection, publicKey]);\n   341→\n   342→  // Initial load\n   343→  useEffect(() => {\n   344→    setLoading(true);\n   345→    void refreshMatches();\n   346→  }, [refreshMatches]);\n   347→\n   348→  // startFlipSequence — kicks off countdown → flipping → complete animation\n   349→  const startFlipSequence = useCallback((matchData: UIMatch) => {\n   350→    logLife(\"startFlipSequence\", { from: matchData.phase, targetSlot: matchData.targetSlot });\n   351→    // Phase 1: countdown (3s) — \"3... 2... 1...\"\n   352→    if (countdownTimerRef.current) clearTimeout(countdownTimerRef.current);\n   353→    if (flipTimerRef.current) clearTimeout(flipTimerRef.current);\n   354→\n   355→    logLife(\"phase → countdown\");\n   356→    setActiveMatch({\n   357→      ...matchData,\n   358→      phase: \"countdown\",\n   359→      countdownStartedAt: Date.now(),\n   360→    });\n   361→\n   362→    // Phase 2: after 3s countdown → start spinning\n   363→    countdownTimerRef.current = window.setTimeout(() => {\n   364→      countdownTimerRef.current = null;\n   365→      logLife(\"phase → flipping\");\n   366→      setActiveMatch((current) => {\n   367→        if (!current || current.phase !== \"countdown\") return current;\n   368→        return { ...current, phase: \"flipping\" };\n   369→      });\n   370→\n   371→      // Phase 3: min 3s of spinning, then show result if available\n   372→      flipTimerRef.current = window.setTimeout(() => {\n   373→        flipTimerRef.current = null;\n   374→        logLife(\"flipTimer elapsed\", { checkingWinner: true });\n   375→        setActiveMatch((current) => {\n   376→          if (current?.phase !== \"flipping\") return current;\n   377→          if (current.winner) {\n   378→            logLife(\"phase → complete (winner stashed)\");\n   379→            return { ...current, phase: \"complete\" };\n   380→          }\n   381→          logLife(\"flipTimer: no winner yet, staying in flipping\");\n   382→          return current; // still flipping, waiting for settlement\n   383→        });\n   384→      }, 3000);\n   385→    }, 3000);\n   386→  }, []);\n   387→\n   388→  // --- Settlement detection via WebSocket (onAccountChange) ---\n   389→  // Watches the match PDA for closure (lamports→0). When detected, fetches\n   390→  // settlement data from the backend and applies it to the UI.\n   391→  useSettlementEvent({\n   392→    connection,\n   393→    accountAddress: activeMatch?.id ?? null,\n   394→    enabled: !!activeMatch && activeMatch.phase !== \"complete\",\n   395→    onClosed: () => {\n   396→      if (!activeMatch) return;\n   397→      logLife(\"WS: PDA closed — fetching backend round\");\n   398→      const matchPda = new PublicKey(activeMatch.id);\n   399→      fetchRoundVerification(matchPda.toBase58())\n   400→        .then((round) => {\n   401→          if (!round || round.phase !== \"settled\") return;\n   402→          logLife(\"WS: backend round settled\", {\n   403→            winner: round.winner?.slice(0, 8),\n   404→            settleTx: round.settleTx?.slice(0, 12),\n   405→            animPhase: activeMatch.phase,\n   406→          });\n   407→          const completedMatch = applyBackendRoundToMatch(activeMatch, round);\n   408→          setLastSettleSignature(round.settleTx ?? null);\n   409→\n   410→          const currentPhase = activeMatch.phase;\n   411→          if (currentPhase === \"countdown\") {\n   412→            setActiveMatch((current) => {\n   413→              if (!current || current.phase !== \"countdown\") return current;\n   414→              return { ...completedMatch, phase: \"countdown\", countdownStartedAt: current.countdownStartedAt };\n   415→            });\n   416→          } else if (currentPhase === \"flipping\") {\n   417→            if (flipTimerRef.current !== null) {\n   418→              logLife(\"WS: stash result (flip timer pending)\");\n   419→              setActiveMatch((current) => {\n   420→                if (!current || current.phase !== \"flipping\") return current;\n   421→                return { ...completedMatch, phase: \"flipping\" };\n   422→              });\n   423→            } else {\n   424→              logLife(\"WS: phase → complete (timer done)\");\n   425→              setActiveMatch(completedMatch);\n   426→            }\n   427→          } else if (currentPhase === \"created\" || currentPhase === \"ready\") {\n   428→            startFlipSequence(completedMatch);\n   429→          } else {\n   430→            setActiveMatch(completedMatch);\n   431→          }\n   432→        })\n   433→        .catch(() => {});\n   434→    },\n   435→  });\n   436→\n   437→  // Poll interval — events handle fast detection, polling is fallback.\n   438→  // 2s during animation (fallback), 5s for other active phases, 30s for lobby.\n   439→  const pollInterval = activeMatch\n   440→    ? (activeMatch.phase === \"countdown\" || activeMatch.phase === \"flipping\" ? 2000 : 5000)\n   441→    : 30000;\n   442→\n   443→  useEffect(() => {\n   444→    const interval = setInterval(() => {\n   445→      if (activeMatch) {\n   446→        // In-game: only poll the active match — no lobby or claimable fetches.\n   447→        if (\n   448→          activeMatch.phase !== \"complete\" &&\n   449→          !activeMatchFetchInFlightRef.current\n   450→        ) {\n   451→          activeMatchFetchInFlightRef.current = true;\n   452→          const matchPda = new PublicKey(activeMatch.id);\n   453→          fetchMatch(connection, matchPda)\n   454→            .then(async (updated) => {\n   455→              if (dismissedMatchRef.current === matchPda.toBase58()) return;\n   456→\n   457→              if (updated) {\n   458→                // --- Transition logic ---\n   459→                logLife(\"poll\", {\n   460→                  prev: activeMatch.phase,\n   461→                  next: updated.phase,\n   462→                  winner: updated.winner?.slice(0, 8) ?? null,\n   463→                  targetSlot: updated.targetSlot,\n   464→                });\n   465→\n   466→                // Opponent just joined → start countdown → flip sequence\n   467→                if (activeMatch.phase === \"created\" && updated.phase === \"ready\") {\n   468→                  logLife(\"join detected (created → ready)\");\n   469→                  startFlipSequence(updated);\n   470→                }\n   471→                // Already in countdown or flipping — stash result if settled, or just wait\n   472→                else if (\n   473→                  (activeMatch.phase === \"countdown\" || activeMatch.phase === \"flipping\") &&\n   474→                  (updated.phase === \"complete\" || updated.phase === \"ready\")\n   475→                ) {\n   476→                  if (updated.winner) {\n   477→                    logLife(\"stash result during animation\", { animPhase: activeMatch.phase, winner: updated.winner.slice(0, 8) });\n   478→                  }\n   479→                  // Update match data (keeps animation phase), will transition on flipTimer or next poll\n   480→                  setActiveMatch((current) => {\n   481→                    if (!current) return current;\n   482→                    if (current.phase === \"countdown\" || current.phase === \"flipping\") {\n   483→                      return { ...updated, phase: current.phase, countdownStartedAt: current.countdownStartedAt };\n   484→                    }\n   485→                    return updated;\n   486→                  });\n   487→                }\n   488→                // Settlement arrived directly from ready (fast settle or page reload)\n   489→                else if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n   490→                  logLife(\"fast settle (ready → complete)\");\n   491→                  startFlipSequence(updated);\n   492→                }\n   493→                // Match was already in ready when we first polled (e.g. page refresh)\n   494→                else if (activeMatch.phase === \"created\" && updated.phase === \"complete\") {\n   495→                  logLife(\"instant settle (created → complete)\");\n   496→                  startFlipSequence(updated);\n   497→                }\n   498→                // Flipping done, result available, no timer pending\n   499→                else if (activeMatch.phase === \"flipping\" && updated.phase === \"complete\" && flipTimerRef.current === null) {\n   500→                  logLife(\"phase → complete (direct, timer done)\");\n   501→                  setActiveMatch(updated);\n   502→                }\n   503→                else if (\n   504→                  updated.phase !== activeMatch.phase ||\n   505→                  updated.player2 !== activeMatch.player2 ||\n   506→                  updated.winner !== activeMatch.winner\n   507→                ) {\n   508→                  // Only update state when meaningful fields changed\n   509→                  setActiveMatch(updated);\n   510→                }\n   511→              } else {\n   512→                // Match PDA disappears after server settlement because settle drains and zeroes it.\n   513→                logLife(\"PDA disappeared — fetching backend round\", { phase: activeMatch.phase });\n   514→                const round = await fetchRoundVerification(matchPda.toBase58()).catch(\n   515→                  () => null\n   516→                );\n   517→\n   518→                if (round?.phase === \"settled\") {\n   519→                  logLife(\"backend round settled\", {\n   520→                    winner: round.winner?.slice(0, 8),\n   521→                    settleTx: round.settleTx?.slice(0, 12),\n   522→                    animPhase: activeMatch.phase,\n   523→                  });\n   524→                  const completedMatch = applyBackendRoundToMatch(activeMatch, round);\n   525→                  setLastSettleSignature(round.settleTx ?? null);\n   526→\n   527→                  if (activeMatch.phase === \"flipping\") {\n   528→                    if (flipTimerRef.current === null) {\n   529→                      logLife(\"phase → complete (PDA gone, flip timer done)\");\n   530→                      setActiveMatch(completedMatch);\n   531→                    } else {\n   532→                      logLife(\"stash result from backend (flip timer pending)\");\n   533→                      setActiveMatch({ ...completedMatch, phase: \"flipping\" });\n   534→                    }\n   535→                    return;\n   536→                  }\n   537→\n   538→                  if (activeMatch.phase === \"countdown\") {\n   539→                    // In countdown — stash result, timers will handle transition\n   540→                    setActiveMatch((current) => {\n   541→                      if (!current || current.phase !== \"countdown\") return current;\n   542→                      return { ...completedMatch, phase: \"countdown\", countdownStartedAt: current.countdownStartedAt };\n   543→                    });\n   544→                    return;\n   545→                  }\n   546→\n   547→                  if (activeMatch.phase === \"ready\" || activeMatch.phase === \"created\") {\n   548→                    // Haven't started animation yet — kick off the full sequence\n   549→                    startFlipSequence(completedMatch);\n   550→                    return;\n   551→                  }\n   552→\n   553→                  setActiveMatch(completedMatch);\n   554→                  return;\n   555→                }\n   556→\n   557→                // Match account closed without a settled backend record (cancel/refund path).\n   558→                setActiveMatch(null);\n   559→              }\n   560→            })\n   561→            .catch(() => {\n   562→              // Ignore polling errors\n   563→            })\n   564→            .finally(() => {\n   565→              activeMatchFetchInFlightRef.current = false;\n   566→            });\n   567→        }\n   568→      } else {\n   569→        // Lobby: poll open matches + claimable\n   570→        void refreshMatches();\n   571→      }\n   572→    }, pollInterval);\n   573→    return () => clearInterval(interval);\n   574→  }, [refreshMatches, activeMatch, connection, pollInterval, startFlipSequence]);\n   575→\n   576→  // Cleanup timers on unmount\n   577→  useEffect(() => {\n   578→    return () => {\n   579→      if (countdownTimerRef.current !== null) clearTimeout(countdownTimerRef.current);\n   580→      if (flipTimerRef.current !== null) clearTimeout(flipTimerRef.current);\n   581→    };\n   582→  }, []);\n   583→\n   584→  const createMatch = useCallback(async () => {\n   585→    if (!connected || !publicKey) {\n   586→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   587→      return;\n   588→    }\n   589→    if (!wagerAmount || !selectedSide) {\n   590→      setError(\"Select wager amount and side first.\");\n   591→      return;\n   592→    }\n   593→\n   594→    // Ensure authenticated — trigger sign-in if needed\n   595→    if (!isAuthenticated || !accessToken) {\n   596→      try {\n   597→        await authenticate();\n   598→      } catch {\n   599→        setError(\"Authentication required. Please approve the sign-in message.\");\n   600→        return;\n   601→      }\n   602→    }\n   603→\n   604→    // After inline authenticate(), the closure's accessToken may be stale\n   605→    // (React hasn't re-rendered yet). Read fresh token from the store.\n   606→    const token = accessToken ?? getAccessToken();\n   607→    if (!token) {\n   608→      setError(\"Authentication failed. Please try again.\");\n   609→      return;\n   610→    }\n   611→\n   612→    setCreating(true);\n   613→    setError(null);\n   614→    setLastSettleSignature(null);\n   615→    try {\n   616→      logLife(\"createMatch: building tx\", { amount: wagerAmount, side: selectedSide });\n   617→      const { transaction, matchPda } = await buildBackendCreateMatchTx(\n   618→        publicKey,\n   619→        wagerAmount,\n   620→        selectedSide,\n   621→        token,\n   622→      );\n   623→\n   624→      logLife(\"createMatch: sending tx\", { pda: matchPda.toBase58().slice(0, 12) });\n   625→      await sendAndConfirm(transaction);\n   626→      logLife(\"createMatch: confirmed\", { pda: matchPda.toBase58().slice(0, 12) });\n   627→\n   628→      dismissedMatchRef.current = null;\n   629→\n   630→      const match = await fetchMatch(connection, matchPda);\n   631→      if (match) {\n   632→        logLife(\"createMatch: fetched, phase=\" + match.phase);\n   633→        setActiveMatch(match);\n   634→      }\n   635→\n   636→      setSelectedSide(null);\n   637→      refreshMatches();\n   638→    } catch (err) {\n   639→      // Handle 401 from backend: attempt refresh, retry once\n   640→      if (err instanceof BackendRequestError && err.status === 401) {\n   641→        try {\n   642→          await authenticate();\n   643→          setError(\"Session refreshed. Please try again.\");\n   644→        } catch {\n   645→          setError(\"Session expired. Please reconnect your wallet.\");\n   646→        }\n   647→        return;\n   648→      }\n   649→      setError(parseTransactionError(err));\n   650→    } finally {\n   651→      setCreating(false);\n   652→    }\n   653→  }, [connected, publicKey, wagerAmount, selectedSide, connection, sendAndConfirm, refreshMatches, isAuthenticated, accessToken, authenticate]);\n   654→\n   655→  const joinMatch = useCallback(\n   656→    async (matchId: string) => {\n   657→      if (!connected || !publicKey) {\n   658→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   659→        return;\n   660→      }\n   661→\n   662→      setJoining(true);\n   663→      setJoiningMatchId(matchId);\n   664→      setError(null);\n   665→      setLastSettleSignature(null);\n   666→      try {\n   667→        // matchId is the match PDA base58 — fetch to get the creator\n   668→        const matchPda = new PublicKey(matchId);\n   669→        const existingMatch = await fetchMatch(connection, matchPda);\n   670→        if (!existingMatch) {\n   671→          setError(\"Match not found. It may have been cancelled.\");\n   672→          return;\n   673→        }\n   674→\n   675→        const transaction = await buildJoinMatchTx(\n   676→          connection,\n   677→          publicKey,\n   678→          matchPda\n   679→        );\n   680→\n   681→        await sendAndConfirm(transaction);\n   682→\n   683→        // Clear dismissed ref — this is a new intentional match\n   684→        dismissedMatchRef.current = null;\n   685→\n   686→        // Fetch updated match\n   687→        const updated = await fetchMatch(connection, matchPda);\n   688→        if (updated) {\n   689→          if (updated.phase === \"ready\") {\n   690→            if (countdownTimerRef.current) clearTimeout(countdownTimerRef.current);\n   691→            if (flipTimerRef.current) clearTimeout(flipTimerRef.current);\n   692→\n   693→            setActiveMatch({\n   694→              ...updated,\n   695→              phase: \"countdown\",\n   696→              countdownStartedAt: Date.now(),\n   697→            });\n   698→\n   699→            countdownTimerRef.current = window.setTimeout(() => {\n   700→              countdownTimerRef.current = null;\n   701→              setActiveMatch((current) => {\n   702→                if (!current || current.phase !== \"countdown\") return current;\n   703→                return { ...current, phase: \"flipping\" };\n   704→              });\n   705→\n   706→              flipTimerRef.current = window.setTimeout(() => {\n   707→                flipTimerRef.current = null;\n   708→                setActiveMatch((current) => {\n   709→                  if (!current || current.phase !== \"flipping\") return current;\n   710→                  if (current.winner) {\n   711→                    return { ...current, phase: \"complete\" };\n   712→                  }\n   713→                  return current;\n   714→                });\n   715→              }, 3000);\n   716→            }, 3000);\n   717→          } else {\n   718→            setActiveMatch(updated);\n   719→          }\n   720→        }\n   721→\n   722→        refreshMatches();\n   723→      } catch (err) {\n   724→        setError(parseTransactionError(err));\n   725→      } finally {\n   726→        setJoining(false);\n   727→        setJoiningMatchId(null);\n   728→      }\n   729→    },\n   730→    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n   731→  );\n   732→\n   733→  const cancelMatch = useCallback(async () => {\n   734→    if (!connected || !publicKey || !activeMatch || !activeMatch.server) {\n   735→      setError(\"No active match to cancel.\");\n   736→      return;\n   737→    }\n   738→\n   739→    setError(null);\n   740→    try {\n   741→      const matchPda = new PublicKey(activeMatch.id);\n   742→      const transaction = await buildCancelMatchTx(connection, publicKey, matchPda, new PublicKey(activeMatch.server));\n   743→      await sendAndConfirm(transaction);\n   744→      setActiveMatch(null);\n   745→      refreshMatches();\n   746→    } catch (err) {\n   747→      setError(parseTransactionError(err));\n   748→    }\n   749→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   750→\n   751→  const timeoutRefund = useCallback(async () => {\n   752→    if (!connected || !publicKey || !activeMatch || !activeMatch.server) {\n   753→      setError(\"No active match to cancel.\");\n   754→      return;\n   755→    }\n   756→    if (!activeMatch.player2) {\n   757→      setError(\"Match has no opponent.\");\n   758→      return;\n   759→    }\n   760→\n   761→    setError(null);\n   762→    try {\n   763→      const matchPda = new PublicKey(activeMatch.id);\n   764→      const matchCreator = new PublicKey(activeMatch.player1);\n   765→      const opponent = new PublicKey(activeMatch.player2);\n   766→\n   767→      const transaction = await buildTimeoutRefundTx(\n   768→        connection,\n   769→        publicKey,\n   770→        matchPda,\n   771→        matchCreator,\n   772→        opponent,\n   773→        new PublicKey(activeMatch.server),\n   774→      );\n   775→      await sendAndConfirm(transaction);\n   776→      setActiveMatch(null);\n   777→      refreshMatches();\n   778→    } catch (err) {\n   779→      // If timeout refund failed, the server may have settled in the meantime.\n   780→      // Re-fetch the match to update the UI.\n   781→      const matchPda = new PublicKey(activeMatch.id);\n   782→      const refreshed = await fetchMatch(connection, matchPda).catch(() => null);\n   783→      if (refreshed && refreshed.phase === \"complete\") {\n   784→        setActiveMatch(refreshed);\n   785→        setError(\"Match was already settled by the server.\");\n   786→        return;\n   787→      }\n   788→\n   789→      setError(parseTransactionError(err));\n   790→    }\n   791→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   792→\n   793→  /** Open a match from the claimable list in ActiveMatchView. */\n   794→  const selectMatch = useCallback((match: UIMatch) => {\n   795→    dismissedMatchRef.current = null;\n   796→    setActiveMatch(match);\n   797→  }, []);\n   798→\n   799→  const clearActiveMatch = useCallback(() => {\n   800→    // Record the dismissed match ID so in-flight polls don't restore it\n   801→    dismissedMatchRef.current = activeMatch?.id ?? null;\n   802→    setActiveMatch(null);\n   803→    setLastSettleSignature(null);\n   804→    setError(null);\n   805→    refreshMatches();\n   806→  }, [activeMatch, refreshMatches]);\n   807→\n   808→  // No auto-restore on wallet connect — user picks from lobby or uses deep-link\n   809→\n   810→  // Deep-link restore: if URL has /coinflip/:matchId and no active match, load it\n   811→  useEffect(() => {\n   812→    if (activeMatch) return;\n   813→    const match = window.location.pathname.match(/^\\/coinflip\\/([0-9a-f]{16})$/i);\n   814→    if (!match) return;\n   815→    const urlMatchId = match[1]!;\n   816→    fetchMatchByMatchId(connection, urlMatchId)\n   817→      .then((loaded) => {\n   818→        if (loaded) setActiveMatch(loaded);\n   819→      })\n   820→      .catch(() => {});\n   821→  // eslint-disable-next-line react-hooks/exhaustive-deps\n   822→  }, [connection]);\n   823→\n   824→  // Sync URL with active match — replaceState avoids React Router remount\n   825→  useEffect(() => {\n   826→    if (activeMatch?.matchId) {\n   827→      const target = `/coinflip/${activeMatch.matchId}`;\n   828→      if (window.location.pathname !== target) {\n   829→        window.history.replaceState(null, \"\", target);\n   830→      }\n   831→    } else if (window.location.pathname.startsWith(\"/coinflip/\")) {\n   832→      window.history.replaceState(null, \"\", \"/coinflip\");\n   833→    }\n   834→  }, [activeMatch]);\n   835→\n   836→  const value: CoinflipContextValue = {\n   837→    activeMatch,\n   838→    openMatches,\n   839→    claimableMatches,\n   840→    userHistory,\n   841→    wagerAmount,\n   842→    selectedSide,\n   843→    loading,\n   844→    creating,\n   845→    joining,\n   846→    joiningMatchId,\n   847→    error,\n   848→    clearError,\n   849→    lastSettleSignature,\n   850→    setWagerAmount,\n   851→    setSelectedSide,\n   852→    createMatch,\n   853→    joinMatch,\n   854→    cancelMatch,\n   855→    timeoutRefund,\n   856→    clearActiveMatch,\n   857→    selectMatch,\n   858→    refreshMatches,\n   859→  };\n   860→\n   861→  return (\n   862→    <CoinflipContext.Provider value={value}>\n   863→      {children}\n   864→    </CoinflipContext.Provider>\n   865→  );\n   866→}\n   867→\n   868→export function useCoinflip(): CoinflipContextValue {\n   869→  const context = useContext(CoinflipContext);\n   870→  if (!context) {\n   871→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   872→  }\n   873→  return context;\n   874→}\n   875→"}]},"parent_tool_use_id":"toolu_01VjBSw9tMWntCUQGUX3iNN9","session_id":"402c21eb-b534-4fb0-8000-5dcbddbea423","uuid":"f63a21bc-4099-4186-b140-2632fa5e9356"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013idP585BTLxETj2jaqMZZ6","type":"tool_result","content":"     1→/**\n     2→ * Close Call API routes.\n     3→ *\n     4→ * GET /closecall/current-round — active round + pool state\n     5→ * GET /closecall/history       — last N settled/refunded rounds\n     6→ */\n     7→\n     8→import { Hono } from \"hono\";\n     9→import type { CloseCallRound, Db } from \"../db.js\";\n    10→\n    11→export interface CloseCallRoutesDeps {\n    12→  db: Db;\n    13→}\n    14→\n    15→function formatCloseCallRound(round: CloseCallRound) {\n    16→  const totalPool = round.green_pool + round.red_pool;\n    17→  return {\n    18→    roundId: round.round_id,\n    19→    pda: round.pda,\n    20→    phase: round.phase,\n    21→    openPrice: round.open_price,\n    22→    openPriceExpo: round.open_price_expo,\n    23→    closePrice: round.close_price,\n    24→    outcome: round.outcome,\n    25→    greenPool: round.green_pool,\n    26→    redPool: round.red_pool,\n    27→    totalPool,\n    28→    totalFee: round.total_fee,\n    29→    greenEntries: round.green_entries,\n    30→    redEntries: round.red_entries,\n    31→    greenCount: round.green_entries.length,\n    32→    redCount: round.red_entries.length,\n    33→    settleTx: round.settle_tx,\n    34→    createdAt: round.created_at.toISOString(),\n    35→    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n    36→  };\n    37→}\n    38→\n    39→export function createCloseCallRoutes(deps: CloseCallRoutesDeps): Hono {\n    40→  const { db } = deps;\n    41→  const app = new Hono();\n    42→\n    43→  app.get(\"/current-round\", async (c) => {\n    44→    const round = await db.getCloseCallCurrentRound();\n    45→    if (!round) {\n    46→      return c.json({ round: null });\n    47→    }\n    48→    return c.json({ round: formatCloseCallRound(round) });\n    49→  });\n    50→\n    51→  app.get(\"/history\", async (c) => {\n    52→    const limitParam = c.req.query(\"limit\");\n    53→    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n    54→    const rounds = await db.getCloseCallHistory(limit);\n    55→    return c.json({ rounds: rounds.map(formatCloseCallRound) });\n    56→  });\n    57→\n    58→  return app;\n    59→}\n    60→"}]},"parent_tool_use_id":"toolu_01VjBSw9tMWntCUQGUX3iNN9","session_id":"402c21eb-b534-4fb0-8000-5dcbddbea423","uuid":"64898020-2556-4c3e-96c8-6bd40939b719"}
