{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HfnxRqaJaXA951se3JTFKc","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  COIN_SIDE_VALUES,\n    11→  type CoinSide,\n    12→} from \"@rng-utopia/game-engine/browser\";\n    13→import type { UIMatch } from \"../types\";\n    14→\n    15→// ============ Constants ============\n    16→\n    17→export const COINFLIP_PROGRAM_ID = new PublicKey(\n    18→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    19→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    20→);\n    21→\n    22→const FAIRNESS_BACKEND_URL = (\n    23→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    24→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    25→).replace(/\\/$/, \"\");\n    26→\n    27→// Phase constants matching on-chain\n    28→const PHASE_WAITING = 0;\n    29→const PHASE_LOCKED = 1;\n    30→const PHASE_SETTLED = 2;\n    31→const PHASE_REFUNDED = 3;\n    32→\n    33→export interface BackendCreateMatchResponse {\n    34→  transaction: string;\n    35→  matchPda: string;\n    36→  matchId: string;\n    37→  commitment: string;\n    38→  lastValidBlockHeight: number;\n    39→}\n    40→\n    41→export interface BackendRoundResponse {\n    42→  pda: string;\n    43→  game: string;\n    44→  phase: \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    45→  creator: string;\n    46→  commitment: string;\n    47→  amountLamports: number;\n    48→  side: number;\n    49→  matchId: string;\n    50→  createdAt: string;\n    51→  updatedAt: string;\n    52→  targetSlot?: number;\n    53→  secret?: string;\n    54→  resultHash?: string | null;\n    55→  resultSide?: number | null;\n    56→  winner?: string | null;\n    57→  settleTx?: string | null;\n    58→}\n    59→\n    60→export class BackendRequestError extends Error {\n    61→  status: number;\n    62→\n    63→  constructor(status: number, message: string) {\n    64→    super(message);\n    65→    this.name = \"BackendRequestError\";\n    66→    this.status = status;\n    67→  }\n    68→}\n    69→\n    70→// ============ PDA Derivation ============\n    71→\n    72→export function getMatchPda(creator: PublicKey, matchId: Uint8Array): [PublicKey, number] {\n    73→  return PublicKey.findProgramAddressSync(\n    74→    [Buffer.from(\"match\"), creator.toBuffer(), Buffer.from(matchId)],\n    75→    COINFLIP_PROGRAM_ID\n    76→  );\n    77→}\n    78→\n    79→export function getConfigPda(): [PublicKey, number] {\n    80→  return PublicKey.findProgramAddressSync(\n    81→    [Buffer.from(\"coinflip_config\")],\n    82→    COINFLIP_PROGRAM_ID\n    83→  );\n    84→}\n    85→\n    86→function getFairnessBackendRoundUrl(matchPda: string): string {\n    87→  return `${FAIRNESS_BACKEND_URL}/fairness/rounds/${matchPda}`;\n    88→}\n    89→\n    90→function getFairnessBackendCreateUrl(): string {\n    91→  return `${FAIRNESS_BACKEND_URL}/fairness/coinflip/create`;\n    92→}\n    93→\n    94→async function parseBackendResponse<T>(response: Response): Promise<T> {\n    95→  let json: unknown = null;\n    96→  try {\n    97→    json = await response.json();\n    98→  } catch {\n    99→    json = null;\n   100→  }\n   101→\n   102→  if (!response.ok) {\n   103→    const errorMessage =\n   104→      typeof json === \"object\" &&\n   105→      json !== null &&\n   106→      \"error\" in json &&\n   107→      typeof (json as { error: unknown }).error === \"string\"\n   108→        ? (json as { error: string }).error\n   109→        : `Backend request failed (${response.status})`;\n   110→    throw new BackendRequestError(response.status, errorMessage);\n   111→  }\n   112→\n   113→  return json as T;\n   114→}\n   115→\n   116→function sideFromBackendResult(resultSide: number | null | undefined): CoinSide | null {\n   117→  if (resultSide === 0) return \"heads\";\n   118→  if (resultSide === 1) return \"tails\";\n   119→  return null;\n   120→}\n   121→\n   122→// ============ Program Instances ============\n   123→\n   124→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n   125→  // Read-only provider (no wallet needed for queries)\n   126→  const provider = new AnchorProvider(\n   127→    connection,\n   128→    {} as AnchorProvider[\"wallet\"],\n   129→    { commitment: \"confirmed\" }\n   130→  );\n   131→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n   132→}\n   133→\n   134→// ============ On-Chain Account Types ============\n   135→\n   136→interface OnChainMatch {\n   137→  creator: PublicKey;\n   138→  opponent: PublicKey;\n   139→  server: PublicKey;\n   140→  entryAmount: { toNumber(): number };\n   141→  creatorSide: number;\n   142→  phase: number;\n   143→  commitment: number[];\n   144→  algorithmVer: number;\n   145→  targetSlot: { toNumber(): number };\n   146→  resolveDeadline: { toNumber(): number };\n   147→  resultHash: number[];\n   148→  result: number;\n   149→  winner: PublicKey;\n   150→  createdAt: { toNumber(): number };"}]},"parent_tool_use_id":"toolu_01VjBSw9tMWntCUQGUX3iNN9","session_id":"402c21eb-b534-4fb0-8000-5dcbddbea423","uuid":"966fda35-aaff-44f9-a7d7-de0e276677b0"}
