{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019Q25BQgaiDc24YkYKvQQpr","type":"tool_result","content":"export async function buildBackendCreateMatchTx(\n  creator: PublicKey,\n  amountSol: number,\n  side: CoinSide,\n  accessToken: string,\n): Promise<{ transaction: Transaction; matchPda: PublicKey; commitment: string }> {\n  const payload = {\n    wallet: creator.toBase58(),\n    amountLamports: Math.round(amountSol * 1e9),\n    side: COIN_SIDE_VALUES[side],\n  };\n\n  const response = await fetch(getFairnessBackendCreateUrl(), {\n    method: \"POST\",\n    headers: {\n      \"Content-Type\": \"application/json\",\n      \"Authorization\": `Bearer ${accessToken}`,\n    },\n    body: JSON.stringify(payload),\n  });","is_error":false}]},"parent_tool_use_id":"toolu_01VjBSw9tMWntCUQGUX3iNN9","session_id":"402c21eb-b534-4fb0-8000-5dcbddbea423","uuid":"2813e992-6af8-4130-afed-cc0245e2f207"}
