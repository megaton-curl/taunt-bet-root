→      pendingSide,\n   109→      currentRound.pool\n   110→    );\n   111→  }, [pendingAmount, pendingSide, currentRound, userBet]);\n   112→\n   113→  // Calculate user's odds (share of winning pool)\n   114→  const userOdds = useMemo(() => {\n   115→    if (!userBet || !currentRound) return 0;\n   116→\n   117→    const winningPool =\n   118→      userBet.side === \"green\"\n   119→        ? currentRound.pool.greenPool\n   120→        : currentRound.pool.redPool;\n   121→\n   122→    if (winningPool === 0) return 0;\n   123→\n   124→    return (userBet.amount / winningPool) * 100;\n   125→  }, [userBet, currentRound]);\n   126→\n   127→  // Initialize game on mount\n   128→  useEffect(() => {\n   129→    if (!isGameInitialized()) {\n   130→      initializeGame();\n   131→    }\n   132→\n   133→    // Set initial state\n   134→    const round = getCurrentRound();\n   135→    if (round) {\n   136→      setCurrentRound(round);\n   137→    }\n   138→\n   139→    // Build candles array: completed candles + current forming candle\n   140→    const completedCandles = getRecentCandles(15);\n   141→    const currentCandle = getCurrentCandle();\n   142→    if (currentCandle) {\n   143→      setRecentCandles([...completedCandles, currentCandle]);\n   144→    } else {\n   145→      setRecentCandles(completedCandles);\n   146→    }\n   147→    setLoading(false);\n   148→\n   149→    // Subscribe to round updates\n   150→    const unsubscribeRound = subscribeToRound((round) => {\n   151→      setCurrentRound(round);\n   152→\n   153→      // Update candles: completed + current forming\n   154→      const completed = getRecentCandles(15);\n   155→      const current = getCurrentCandle();\n   156→      if (current) {\n   157→        setRecentCandles([...completed, current]);\n   158→      } else {\n   159→        setRecentCandles(completed);\n   160→      }\n   161→    });\n   162→\n   163→    // Subscribe to completed round updates\n   164→    const unsubscribeCompleted = subscribeToCompletedRound((round) => {\n   165→      setCompletedRound(round);\n   166→    });\n   167→\n   168→    // Poll for price/progress updates\n   169→    const pollInterval = setInterval(() => {\n   170→      const candle = getCurrentCandle();\n   171→      if (candle) {\n   172→        const progress = getCandleProgress();\n   173→        setCandleProgress(progress);\n   174→\n   175→        // Interpolate current price\n   176→        const { open, high, low, close } = candle;\n   177→        const isBullish = close > open;\n   178→\n   179→        let price: number;\n   180→        if (isBullish) {\n   181→          if (progress < 0.2) {\n   182→            price = open + (low - open) * (progress / 0.2) * 0.7;\n   183→          } else if (progress < 0.7) {\n   184→            const lowPoint = open + (low - open) * 0.7;\n   185→            price = lowPoint + (high - lowPoint) * ((progress - 0.2) / 0.5);\n   186→          } else {\n   187→            price = high + (close - high) * ((progress - 0.7) / 0.3);\n   188→          }\n   189→        } else {\n   190→          if (progress < 0.2) {\n   191→            price = open + (high - open) * (progress / 0.2) * 0.7;\n   192→          } else if (progress < 0.7) {\n   193→            const highPoint = open + (high - open) * 0.7;\n   194→            price = highPoint + (low - highPoint) * ((progress - 0.2) / 0.5);\n   195→          } else {\n   196→            price = low + (close - low) * ((progress - 0.7) / 0.3);\n   197→          }\n   198→        }\n   199→\n   200→        setCurrentPrice(price);\n   201→\n   202→        // Update candles: completed + current forming\n   203→        const completed = getRecentCandles(15);\n   204→        setRecentCandles([...completed, candle]);\n   205→      }\n   206→    }, 100);\n   207→\n   208→    return () => {\n   209→      unsubscribeRound();\n   210→      unsubscribeCompleted();\n   211→      clearInterval(pollInterval);\n   212→    };\n   213→  }, []);\n   214→\n   215→  // Update user history when address changes\n   216→  useEffect(() => {\n   217→    if (address) {\n   218→      const history = getUserHistory(address).sort(\n   219→        (a, b) => (b.round.resolvedAt ?? b.round.createdAt) - (a.round.resolvedAt ?? a.round.createdAt)\n   220→      );\n   221→      setUserHistory(history);\n   222→    } else {\n   223→      setUserHistory([]);\n   224→    }\n   225→  }, [address, currentRound?.phase]);\n   226→\n   227→  // Place bet action - accepts optional side override for direct button clicks\n   228→  const placeBet = useCallback(async (sideOverride?: BetSide) => {\n   229→    if (!address) {\n   230→      throw new Error(\"Wallet not connected\");\n   231→    }\n   232→\n   233→    const side = sideOverride ?? pendingSide;\n   234→    if (!side) {\n   235→      throw new Error(\"Select GREEN or RED\");\n   236→    }\n   237→\n   238→    if (pendingAmount < MIN_BET_AMOUNT) {\n   239→      throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n   240→    }\n   241→\n   242→    if (pendingAmount > MAX_BET_AMOUNT) {\n   243→      throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n   244→    }\n   245→\n   246→    const currentBalance = getBalance?.();\n   247→    if (currentBalance !== undefined && pendingAmount > currentBalance) {\n   248→      throw new Error(\"Insufficient balance\");\n   249→    }\n   250→\n   251→    setPlacingBet(true);\n   252→\n   253→    try {\n   254→      // Simulate transaction delay\n   255→      await new Promise((resolve) => setTimeout(resolve, 500));\n   256→\n   257→      mockPlaceBet(address, side, pendingAmount);\n   258→\n   259→      // Reset selection after bet\n   260→      setPendingSide(null);\n   261→    } finally {\n   262→      setPlacingBet(false);\n   263→    }\n   264→  }, [address, pendingSide, pendingAmount, getBalance]);\n   265→\n   266→  // Adjust bet amount\n   267→  const adjustBetAmount = useCallback(\n   268→    (adjustment: \"half\" | \"double\" | \"max\") => {\n   269→      let newAmount: number;\n   270→      const currentBalance = getBalance?.();\n   271→\n   272→      switch (adjustment) {\n   273→        case \"half\":\n   274→          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n   275→          break;\n   276→        case \"double\":\n   277→          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n   278→          break;\n   279→        case \"max\":\n   280→          newAmount = currentBalance !== undefined ? Math.min(currentBalance, MAX_BET_AMOUNT) : MAX_BET_AMOUNT;\n   281→          break;\n   282→      }\n   283→\n   284→      // Round to 4 decimal places\n   285→      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n   286→    },\n   287→    [pendingAmount, getBalance]\n   288→  );\n   289→\n   290→  // Refresh round data\n   291→  const refreshRound = useCallback(() => {\n   292→    const round = getCurrentRound();\n   293→    if (round) {\n   294→      setCurrentRound(round);\n   295→    }\n   296→    // Build candles: completed + current forming\n   297→    const completed = getRecentCandles(15);\n   298→    const current = getCurrentCandle();\n   299→    if (current) {\n   300→      setRecentCandles([...completed, current]);\n   301→    } else {\n   302→      setRecentCandles(completed);\n   303→    }\n   304→  }, []);\n   305→\n   306→  // Clear completed round (after user dismisses result overlay)\n   307→  const clearCompletedRound = useCallback(() => {\n   308→    setCompletedRound(null);\n   309→    mockClearCompletedRound();\n   310→  }, []);\n   311→\n   312→  const contextValue: CloseCallContextValue = {\n   313→    currentRound,\n   314→    completedRound,\n   315→    recentCandles,\n   316→    currentPrice,\n   317→    candleProgress,\n   318→    userHistory,\n   319→    pendingAmount,\n   320→    pendingSide,\n   321→    userBet,\n   322→    loading,\n   323→    placingBet,\n   324→    setPendingAmount,\n   325→    setPendingSide,\n   326→    placeBet,\n   327→    adjustBetAmount,\n   328→    clearCompletedRound,\n   329→    potentialPayout,\n   330→    userOdds,\n   331→    refreshRound,\n   332→  };\n   333→\n   334→  return (\n   335→    <CloseCallContext.Provider value={contextValue}>\n   336→      {children}\n   337→    </CloseCallContext.Provider>\n   338→  );\n   339→}\n   340→\n   341→export function useCloseCall(): CloseCallContextValue {\n   342→  const context = useContext(CloseCallContext);\n   343→  if (!context) {\n   344→    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n   345→  }\n   346→  return context;\n   347→}\n   348→"}]},"parent_tool_use_id":null,"session_id":"402c21eb-b534-4fb0-8000-5dcbddbea423","uuid":"658152c0-6afd-4119-8590-dbd6877de13c","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  UserRoundHistory,\n  CloseCallContextValue,\n} from \"../types\";\nimport {\n  DEFAULT_BET_AMOUNT,\n  MIN_BET_AMOUNT,\n  MAX_BET_AMOUNT,\n} from \"../types\";\nimport {\n  initializeGame,\n  subscribeToRound,\n  subscribeToCompletedRound,\n  placeBet as mockPlaceBet,\n  getCurrentRound,\n  getUserHistory,\n  getRecentCandles,\n  getCurrentCandle,\n  getCandleProgress,\n  isGameInitialized,\n  clearCompletedRound as mockClearCompletedRound,\n} from \"../utils/mock-simulation\";\nimport { calculatePotentialPayout } from \"../utils/payout-calculator\";\n\n// Default context value\nconst defaultContextValue: CloseCallContextValue = {\n  currentRound: null,\n  completedRound: null,\n  recentCandles: [],\n  currentPrice: 0,\n  candleProgress: 0,\n  userHistory: [],\n  pendingAmount: DEFAULT_BET_AMOUNT,\n  pendingSide: null,\n  userBet: null,\n  loading: true,\n  placingBet: false,\n  setPendingAmount: () => {},\n  setPendingSide: () => {},\n  placeBet: async () => {},\n  adjustBetAmount: () => {},\n  clearCompletedRound: () => {},\n  potentialPayout: 0,\n  userOdds: 0,\n  refreshRound: () => {},\n};\n\nconst CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n\nexport function CloseCallProvider({ children }: { children: ReactNode }) {\n  const { address, getBalance } = useWallet();\n\n  // Round state\n  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n  const [currentPrice, setCurrentPrice] = useState(0);\n  const [candleProgress, setCandleProgress] = useState(0);\n\n  // User state\n  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [placingBet, setPlacingBet] = useState(false);\n\n  // Get user's bet in current round\n  const userBet = useMemo(() => {\n    if (!currentRound || !address) return null;\n\n    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    return allBets.find((b) => b.address === address) ?? null;\n  }, [currentRound, address]);\n\n  // Calculate potential payout\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    // If user has an active bet, calculate payout based on their bet\n    if (userBet) {\n      return calculatePotentialPayout(\n        userBet.amount,\n        userBet.side,\n        currentRound.pool\n      );\n    }\n\n    // Otherwise show preview based on pending selection\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(\n      pendingAmount,\n      pendingSide,\n      currentRound.pool\n    );\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // Calculate user's odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n\n    if (winningPool === 0) return 0;\n\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // Initialize game on mount\n  useEffect(() => {\n    if (!isGameInitialized()) {\n      initializeGame();\n    }\n\n    // Set initial state\n    const round = getCurrentRound();\n    if (round) {\n      setCurrentRound(round);\n    }\n\n    // Build candles array: completed candles + current forming candle\n    const completedCandles = getRecentCandles(15);\n    const currentCandle = getCurrentCandle();\n    if (currentCandle) {\n      setRecentCandles([...completedCandles, currentCandle]);\n    } else {\n      setRecentCandles(completedCandles);\n    }\n    setLoading(false);\n\n    // Subscribe to round updates\n    const unsubscribeRound = subscribeToRound((round) => {\n      setCurrentRound(round);\n\n      // Update candles: completed + current forming\n      const completed = getRecentCandles(15);\n      const current = getCurrentCandle();\n      if (current) {\n        setRecentCandles([...completed, current]);\n      } else {\n        setRecentCandles(completed);\n      }\n    });\n\n    // Subscribe to completed round updates\n    const unsubscribeCompleted = subscribeToCompletedRound((round) => {\n      setCompletedRound(round);\n    });\n\n    // Poll for price/progress updates\n    const pollInterval = setInterval(() => {\n      const candle = getCurrentCandle();\n      if (candle) {\n        const progress = getCandleProgress();\n        setCandleProgress(progress);\n\n        // Interpolate current price\n        const { open, high, low, close } = candle;\n        const isBullish = close > open;\n\n        let price: number;\n        if (isBullish) {\n          if (progress < 0.2) {\n            price = open + (low - open) * (progress / 0.2) * 0.7;\n          } else if (progress < 0.7) {\n            const lowPoint = open + (low - open) * 0.7;\n            price = lowPoint + (high - lowPoint) * ((progress - 0.2) / 0.5);\n          } else {\n            price = high + (close - high) * ((progress - 0.7) / 0.3);\n          }\n        } else {\n          if (progress < 0.2) {\n            price = open + (high - open) * (progress / 0.2) * 0.7;\n          } else if (progress < 0.7) {\n            const highPoint = open + (high - open) * 0.7;\n            price = highPoint + (low - highPoint) * ((progress - 0.2) / 0.5);\n          } else {\n            price = low + (close - low) * ((progress - 0.7) / 0.3);\n          }\n        }\n\n        setCurrentPrice(price);\n\n        // Update candles: completed + current forming\n        const completed = getRecentCandles(15);\n        setRecentCandles([...completed, candle]);\n      }\n    }, 100);\n\n    return () => {\n      unsubscribeRound();\n      unsubscribeCompleted();\n      clearInterval(pollInterval);\n    };\n  }, []);\n\n  // Update user history when address changes\n  useEffect(() => {\n    if (address) {\n      const history = getUserHistory(address).sort(\n        (a, b) => (b.round.resolvedAt ?? b.round.createdAt) - (a.round.resolvedAt ?? a.round.createdAt)\n      );\n      setUserHistory(history);\n    } else {\n      setUserHistory([]);\n    }\n  }, [address, currentRound?.phase]);\n\n  // Place bet action - accepts optional side override for direct button clicks\n  const placeBet = useCallback(async (sideOverride?: BetSide) => {\n    if (!address) {\n      throw new Error(\"Wallet not connected\");\n    }\n\n    const side = sideOverride ?? pendingSide;\n    if (!side) {\n      throw new Error(\"Select GREEN or RED\");\n    }\n\n    if (pendingAmount < MIN_BET_AMOUNT) {\n      throw new Error(`Minimum bet is ${MIN_BET_AMOUNT} SOL`);\n    }\n\n    if (pendingAmount > MAX_BET_AMOUNT) {\n      throw new Error(`Maximum bet is ${MAX_BET_AMOUNT} SOL`);\n    }\n\n    const currentBalance = getBalance?.();\n    if (currentBalance !== undefined && pendingAmount > currentBalance) {\n      throw new Error(\"Insufficient balance\");\n    }\n\n    setPlacingBet(true);\n\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      mockPlaceBet(address, side, pendingAmount);\n\n      // Reset selection after bet\n      setPendingSide(null);\n    } finally {\n      setPlacingBet(false);\n    }\n  }, [address, pendingSide, pendingAmount, getBalance]);\n\n  // Adjust bet amount\n  const adjustBetAmount = useCallback(\n    (adjustment: \"half\" | \"double\" | \"max\") => {\n      let newAmount: number;\n      const currentBalance = getBalance?.();\n\n      switch (adjustment) {\n        case \"half\":\n          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n          break;\n        case \"double\":\n          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n          break;\n        case \"max\":\n          newAmount = currentBalance !== undefined ? Math.min(currentBalance, MAX_BET_AMOUNT) : MAX_BET_AMOUNT;\n          break;\n      }\n\n      // Round to 4 decimal places\n      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n    },\n    [pendingAmount, getBalance]\n  );\n\n  // Refresh round data\n  const refreshRound = useCallback(() => {\n    const round = getCurrentRound();\n    if (round) {\n      setCurrentRound(round);\n    }\n    // Build candles: completed + current forming\n    const completed = getRecentCandles(15);\n    const current = getCurrentCandle();\n    if (current) {\n      setRecentCandles([...completed, current]);\n    } else {\n      setRecentCandles(completed);\n    }\n  }, []);\n\n  // Clear completed round (after user dismisses result overlay)\n  const clearCompletedRound = useCallback(() => {\n    setCompletedRound(null);\n    mockClearCompletedRound();\n  }, []);\n\n  const contextValue: CloseCallContextValue = {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    clearCompletedRound,\n    potentialPayout,\n    userOdds,\n    refreshRound,\n  };\n\n  return (\n    <CloseCallContext.Provider value={contextValue}>\n      {children}\n    </CloseCallContext.Provider>\n  );\n}\n\nexport function useCloseCall(): CloseCallContextValue {\n  const context = useContext(CloseCallContext);\n  if (!context) {\n    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n  }\n  return context;\n}\n","numLines":348,"startLine":1,"totalLines":348}}}
