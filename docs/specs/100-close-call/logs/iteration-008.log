{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SgbiPzDtSSvKDcagGRm9MD","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→import { ClosecallIDL } from \"@rng-utopia/anchor-client\";\n     3→\n     4→// ============ Program IDs ============\n     5→\n     6→export const CLOSECALL_PROGRAM_ID = new PublicKey(\n     7→  ClosecallIDL.address\n     8→);\n     9→\n    10→// ============ PDA Derivation ============\n    11→\n    12→/**\n    13→ * Derive the round PDA.\n    14→ * Seeds: [\"cc_round\", round_id (8 bytes)]\n    15→ */\n    16→export function getCloseCallRoundPda(\n    17→  roundId: Uint8Array\n    18→): [PublicKey, number] {\n    19→  return PublicKey.findProgramAddressSync(\n    20→    [Buffer.from(\"cc_round\"), Buffer.from(roundId)],\n    21→    CLOSECALL_PROGRAM_ID\n    22→  );\n    23→}\n    24→\n    25→/**\n    26→ * Derive the global config PDA.\n    27→ * Seeds: [\"closecall_config\"]\n    28→ */\n    29→export function getCloseCallConfigPda(): [PublicKey, number] {\n    30→  return PublicKey.findProgramAddressSync(\n    31→    [Buffer.from(\"closecall_config\")],\n    32→    CLOSECALL_PROGRAM_ID\n    33→  );\n    34→}\n    35→"}]},"parent_tool_use_id":"toolu_017XRBKQoxZR772p1etsboYg","session_id":"dfed5053-bbec-4b81-a37f-49b6882e5396","uuid":"06437365-823c-4b38-8bbe-ef7dbb3432aa"}
