{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hnp6tKkMcAoahQAodqTRaE","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/solana/scripts/init-devnet-config.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"dfed5053-bbec-4b81-a37f-49b6882e5396","uuid":"6e6175e7-7d76-4248-97e0-1098044e2c93","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/scripts/init-devnet-config.ts","oldString":"  const lordofrngsIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n  );\n\n  const platformProgram = new Program(platformIdl, provider);\n  const coinflipProgram = new Program(coinflipIdl, provider);\n  const lordofrngsProgram = new Program(lordofrngsIdl, provider);","newString":"  const lordofrngsIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n  );\n  const closecallIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"closecall.json\"), \"utf8\")\n  );\n\n  const platformProgram = new Program(platformIdl, provider);\n  const coinflipProgram = new Program(coinflipIdl, provider);\n  const lordofrngsProgram = new Program(lordofrngsIdl, provider);\n  const closecallProgram = new Program(closecallIdl, provider);","originalFile":"/**\n * Initialize platform + coinflip configs on devnet.\n *\n * Usage: npx ts-node --esm scripts/init-devnet-config.ts\n *\n * Prerequisites:\n *   - Programs deployed to devnet (run deploy-devnet.sh first)\n *   - Deployer wallet at ~/.config/solana/id.json\n *   - IDLs generated in target/idl/\n */\n\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { AnchorProvider, Program, Wallet } from \"@coral-xyz/anchor\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nasync function main() {\n  // Load wallet\n  const walletPath = join(\n    process.env.HOME ?? \"~\",\n    \".config/solana/id.json\"\n  );\n  const secretKey = JSON.parse(readFileSync(walletPath, \"utf8\"));\n  const keypair = Keypair.fromSecretKey(Uint8Array.from(secretKey));\n  const wallet = new Wallet(keypair);\n\n  // Connect to devnet\n  const connection = new Connection(\"https://api.devnet.solana.com\", \"confirmed\");\n  const provider = new AnchorProvider(connection, wallet, {\n    commitment: \"confirmed\",\n  });\n\n  console.log(\"=== Init Devnet Config ===\");\n  console.log(\"Authority:\", wallet.publicKey.toBase58());\n  const balance = await connection.getBalance(wallet.publicKey);\n  console.log(\"Balance:\", (balance / 1e9).toFixed(4), \"SOL\");\n\n  // Load IDLs\n  const platformIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n  );\n  const coinflipIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n  );\n  const lordofrngsIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n  );\n\n  const platformProgram = new Program(platformIdl, provider);\n  const coinflipProgram = new Program(coinflipIdl, provider);\n  const lordofrngsProgram = new Program(lordofrngsIdl, provider);\n\n  const treasury = wallet.publicKey; // deployer = treasury for devnet\n\n  // 1. Initialize Platform\n  console.log(\"\\n--- Platform ---\");\n  try {\n    const tx = await (platformProgram.methods as any)\n      .initializePlatform(treasury)\n      .accounts({ authority: wallet.publicKey })\n      .rpc();\n    console.log(\"Platform initialized. tx:\", tx);\n  } catch (e: any) {\n    if (e.message?.includes(\"already in use\")) {\n      console.log(\"Platform config already initialized (skipping).\");\n    } else {\n      throw e;\n    }\n  }\n\n  // 2. Initialize Coinflip Config\n  console.log(\"\\n--- Coinflip ---\");\n  try {\n    const tx = await (coinflipProgram.methods as any)\n      .initializeConfig(treasury)\n      .accounts({ authority: wallet.publicKey })\n      .rpc();\n    console.log(\"Coinflip config initialized. tx:\", tx);\n  } catch (e: any) {\n    if (e.message?.includes(\"already in use\")) {\n      console.log(\"Coinflip config already initialized (skipping).\");\n    } else {\n      throw e;\n    }\n  }\n\n  // 3. Initialize Lord of the RNGs Config\n  console.log(\"\\n--- Lord of the RNGs ---\");\n  try {\n    const tx = await (lordofrngsProgram.methods as any)\n      .initializeConfig(treasury)\n      .accounts({ authority: wallet.publicKey })\n      .rpc();\n    console.log(\"LordOfRngs config initialized. tx:\", tx);\n  } catch (e: any) {\n    if (e.message?.includes(\"already in use\")) {\n      console.log(\"LordOfRngs config already initialized (skipping).\");\n    } else {\n      throw e;\n    }\n  }\n\n  console.log(\"\\n=== Done ===\");\n}\n\nmain().catch((e) => {\n  console.error(e);\n  process.exit(1);\n});\n","structuredPatch":[{"oldStart":49,"oldLines":10,"newStart":49,"newLines":14,"lines":["   const lordofrngsIdl = JSON.parse(","     readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")","   );","+  const closecallIdl = JSON.parse(","+    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"closecall.json\"), \"utf8\")","+  );"," ","   const platformProgram = new Program(platformIdl, provider);","   const coinflipProgram = new Program(coinflipIdl, provider);","   const lordofrngsProgram = new Program(lordofrngsIdl, provider);","+  const closecallProgram = new Program(closecallIdl, provider);"," ","   const treasury = wallet.publicKey; // deployer = treasury for devnet"," "]}],"userModified":false,"replaceAll":false}}
