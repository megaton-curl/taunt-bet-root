round is closed","   try {","     await (program.account as any).closeCallRound.fetch(roundPda);","     console.log(\"  Round account still exists (unexpected)\");","   } catch {","-    console.log(\"  Round PDA closed (rent returned) — as expected\");","+    console.log(\"  Round PDA closed (rent returned)\");","   }"," ","-  console.log(\"\\n=== Summary ===\");","-  console.log(\"Program: 8TXq2XyHsk5AAMkoyk5QtG25xyyY7rTMHXrJRHRwjUpA\");","-  console.log(\"Config PDA: \" + configPda.toBase58());","-  console.log(\"create_round: reads Pyth open price, creates round PDA\");","-  console.log(\"place_bet: deposits SOL into round PDA\");","-  console.log(\"settle_round: reads Pyth close price, refunds single-sided pool, closes PDA\");","+  console.log(\"\\n=== All 3 instructions verified on devnet ===\");"," }"," "," main().catch((e) => {"]}],"originalFile":"/**\n * Quick verification: create_round + place_bet in single tx, then settle after 60s.\n * Usage: NODE_OPTIONS=\"--use-env-proxy\" npx tsx scripts/verify-closecall-quick.ts\n */\nimport { Connection, Keypair, PublicKey, SystemProgram, Transaction } from \"@solana/web3.js\";\nimport { AnchorProvider, Program, Wallet } from \"@coral-xyz/anchor\";\nimport anchor from \"@coral-xyz/anchor\";\nconst { BN } = anchor;\nimport { readFileSync } from \"fs\";\nimport { randomBytes } from \"crypto\";\n\nconst walletPath = \"/home/vscode/.config/solana/id.json\";\nconst secretKey = JSON.parse(readFileSync(walletPath, \"utf8\"));\nconst keypair = Keypair.fromSecretKey(Uint8Array.from(secretKey));\nconst wallet = new Wallet(keypair);\n\nconst connection = new Connection(\"https://api.devnet.solana.com\", {\n  commitment: \"confirmed\",\n  confirmTransactionInitialTimeout: 60_000,\n});\nconst provider = new AnchorProvider(connection, wallet, {\n  commitment: \"confirmed\",\n  skipPreflight: true,\n});\n\nconst closecallIdl = JSON.parse(\n  readFileSync(\"/workspaces/rng-utopia/sources/rng-utopia/solana/target/idl/closecall.json\", \"utf8\")\n);\nconst program = new Program(closecallIdl, provider);\n\nconst PYTH = new PublicKey(\"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\");\n\nasync function pollConfirm(sig: string, maxAttempts = 30): Promise<boolean> {\n  for (let i = 0; i < maxAttempts; i++) {\n    await new Promise((r) => setTimeout(r, 2000));\n    const statuses = await connection.getSignatureStatuses([sig]);\n    const status = statuses?.value?.[0];\n    if (status) {\n      if (status.err) {\n        console.error(\"  Tx failed:\", JSON.stringify(status.err));\n        return false;\n      }\n      if (\n        status.confirmationStatus === \"confirmed\" ||\n        status.confirmationStatus === \"finalized\"\n      ) {\n        console.log(\"  Status:\", status.confirmationStatus);\n        return true;\n      }\n    }\n  }\n  return false;\n}\n\nasync function main() {\n  const roundId = Array.from(randomBytes(8));\n  const roundIdBytes = Uint8Array.from(roundId);\n  const [roundPda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), roundIdBytes],\n    program.programId\n  );\n  const [configPda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"closecall_config\")],\n    program.programId\n  );\n\n  console.log(\"=== CloseCall Devnet Quick Verify ===\");\n  console.log(\"Round PDA:\", roundPda.toBase58());\n\n  // Step 1: create_round + place_bet in one tx\n  console.log(\"\\n--- Step 1: create_round + place_bet ---\");\n  const createIx = await (program.methods as any)\n    .createRound(roundId)\n    .accounts({\n      server: wallet.publicKey,\n      config: configPda,\n      round: roundPda,\n      priceUpdate: PYTH,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const betIx = await (program.methods as any)\n    .placeBet(roundId, 0, new BN(1_000_000))\n    .accounts({\n      player: wallet.publicKey,\n      config: configPda,\n      round: roundPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(createIx).add(betIx);\n  const { blockhash, lastValidBlockHeight } =\n    await connection.getLatestBlockhash(\"confirmed\");\n  tx.recentBlockhash = blockhash;\n  tx.lastValidBlockHeight = lastValidBlockHeight;\n  tx.feePayer = wallet.publicKey;\n  tx.sign(keypair);\n\n  const sig = await connection.sendRawTransaction(tx.serialize());\n  console.log(\"  Tx sig:\", sig);\n\n  const ok = await pollConfirm(sig);\n  if (!ok) {\n    console.error(\"  create_round + place_bet NOT confirmed\");\n    process.exit(1);\n  }\n\n  // Read round\n  const roundData = await (program.account as any).closeCallRound.fetch(roundPda);\n  console.log(\"  Open price:\", roundData.openPrice.toString(), \"x 10^\" + roundData.openPriceExpo);\n  console.log(\"  Phase:\", JSON.stringify(roundData.phase));\n  console.log(\"  Green entries:\", roundData.greenEntries.length);\n  console.log(\"  Green pool:\", roundData.greenPool.toString(), \"lamports\");\n\n  // Step 2: Wait for candle close (60s from round creation)\n  console.log(\"\\n--- Step 2: Wait for candle close ---\");\n  const createdAt = roundData.createdAt.toNumber();\n  const candleClose = createdAt + 60;\n  const nowSec = Math.floor(Date.now() / 1000);\n  const waitSec = Math.max(0, candleClose - nowSec + 5); // +5s buffer\n  console.log(\"  Need to wait ~\" + waitSec + \"s for candle close...\");\n\n  if (waitSec > 0) {\n    await new Promise((r) => setTimeout(r, waitSec * 1000));\n  }\n\n  // Step 3: settle_round (single-sided = refund, no remaining accounts needed for winners)\n  console.log(\"\\n--- Step 3: settle_round ---\");\n  // Single green bet, no red bets → Refund outcome → remaining_accounts = all players [green_0]\n  const settleIx = await (program.methods as any)\n    .settleRound(roundId)\n    .accounts({\n      caller: wallet.publicKey,\n      round: roundPda,\n      config: configPda,\n      priceUpdate: PYTH,\n      treasury: wallet.publicKey,\n      rentReceiver: wallet.publicKey,\n    })\n    .remainingAccounts([\n      { pubkey: wallet.publicKey, isSigner: false, isWritable: true },\n    ])\n    .instruction();\n\n  const tx2 = new Transaction().add(settleIx);\n  const bh2 = await connection.getLatestBlockhash(\"confirmed\");\n  tx2.recentBlockhash = bh2.blockhash;\n  tx2.lastValidBlockHeight = bh2.lastValidBlockHeight;\n  tx2.feePayer = wallet.publicKey;\n  tx2.sign(keypair);\n\n  const sig2 = await connection.sendRawTransaction(tx2.serialize());\n  console.log(\"  Tx sig:\", sig2);\n\n  const ok2 = await pollConfirm(sig2);\n  if (ok2) {\n    console.log(\"  settle_round confirmed (single-sided → refund)\");\n  } else {\n    console.log(\"  settle_round not confirmed within timeout\");\n    // Check if tx succeeded despite timeout\n    const statuses = await connection.getSignatureStatuses([sig2]);\n    console.log(\"  Final status:\", JSON.stringify(statuses?.value?.[0]));\n  }\n\n  // Verify round is closed (account should not exist after close)\n  try {\n    await (program.account as any).closeCallRound.fetch(roundPda);\n    console.log(\"  Round account still exists (unexpected)\");\n  } catch {\n    console.log(\"  Round PDA closed (rent returned) — as expected\");\n  }\n\n  console.log(\"\\n=== Summary ===\");\n  console.log(\"Program: 8TXq2XyHsk5AAMkoyk5QtG25xyyY7rTMHXrJRHRwjUpA\");\n  console.log(\"Config PDA: \" + configPda.toBase58());\n  console.log(\"create_round: reads Pyth open price, creates round PDA\");\n  console.log(\"place_bet: deposits SOL into round PDA\");\n  console.log(\"settle_round: reads Pyth close price, refunds single-sided pool, closes PDA\");\n}\n\nmain().catch((e) => {\n  console.error(e);\n  process.exit(1);\n});\n"}}
