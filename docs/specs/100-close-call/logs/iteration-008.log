{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HiivzZGuHnK5ZdyjAkWNMF","type":"tool_result","content":"     1→/**\n     2→ * Initialize platform + coinflip configs on devnet.\n     3→ *\n     4→ * Usage: npx ts-node --esm scripts/init-devnet-config.ts\n     5→ *\n     6→ * Prerequisites:\n     7→ *   - Programs deployed to devnet (run deploy-devnet.sh first)\n     8→ *   - Deployer wallet at ~/.config/solana/id.json\n     9→ *   - IDLs generated in target/idl/\n    10→ */\n    11→\n    12→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n    13→import { AnchorProvider, Program, Wallet } from \"@coral-xyz/anchor\";\n    14→import { readFileSync } from \"fs\";\n    15→import { dirname, join } from \"path\";\n    16→import { fileURLToPath } from \"url\";\n    17→\n    18→const __filename = fileURLToPath(import.meta.url);\n    19→const __dirname = dirname(__filename);\n    20→\n    21→async function main() {\n    22→  // Load wallet\n    23→  const walletPath = join(\n    24→    process.env.HOME ?? \"~\",\n    25→    \".config/solana/id.json\"\n    26→  );\n    27→  const secretKey = JSON.parse(readFileSync(walletPath, \"utf8\"));\n    28→  const keypair = Keypair.fromSecretKey(Uint8Array.from(secretKey));\n    29→  const wallet = new Wallet(keypair);\n    30→\n    31→  // Connect to devnet\n    32→  const connection = new Connection(\"https://api.devnet.solana.com\", \"confirmed\");\n    33→  const provider = new AnchorProvider(connection, wallet, {\n    34→    commitment: \"confirmed\",\n    35→  });\n    36→\n    37→  console.log(\"=== Init Devnet Config ===\");\n    38→  console.log(\"Authority:\", wallet.publicKey.toBase58());\n    39→  const balance = await connection.getBalance(wallet.publicKey);\n    40→  console.log(\"Balance:\", (balance / 1e9).toFixed(4), \"SOL\");\n    41→\n    42→  // Load IDLs\n    43→  const platformIdl = JSON.parse(\n    44→    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    45→  );\n    46→  const coinflipIdl = JSON.parse(\n    47→    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n    48→  );\n    49→  const lordofrngsIdl = JSON.parse(\n    50→    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n    51→  );\n    52→\n    53→  const platformProgram = new Program(platformIdl, provider);\n    54→  const coinflipProgram = new Program(coinflipIdl, provider);\n    55→  const lordofrngsProgram = new Program(lordofrngsIdl, provider);\n    56→\n    57→  const treasury = wallet.publicKey; // deployer = treasury for devnet\n    58→\n    59→  // 1. Initialize Platform\n    60→  console.log(\"\\n--- Platform ---\");\n    61→  try {\n    62→    const tx = await (platformProgram.methods as any)\n    63→      .initializePlatform(treasury)\n    64→      .accounts({ authority: wallet.publicKey })\n    65→      .rpc();\n    66→    console.log(\"Platform initialized. tx:\", tx);\n    67→  } catch (e: any) {\n    68→    if (e.message?.includes(\"already in use\")) {\n    69→      console.log(\"Platform config already initialized (skipping).\");\n    70→    } else {\n    71→      throw e;\n    72→    }\n    73→  }\n    74→\n    75→  // 2. Initialize Coinflip Config\n    76→  console.log(\"\\n--- Coinflip ---\");\n    77→  try {\n    78→    const tx = await (coinflipProgram.methods as any)\n    79→      .initializeConfig(treasury)\n    80→      .accounts({ authority: wallet.publicKey })\n    81→      .rpc();\n    82→    console.log(\"Coinflip config initialized. tx:\", tx);\n    83→  } catch (e: any) {\n    84→    if (e.message?.includes(\"already in use\")) {\n    85→      console.log(\"Coinflip config already initialized (skipping).\");\n    86→    } else {\n    87→      throw e;\n    88→    }\n    89→  }\n    90→\n    91→  // 3. Initialize Lord of the RNGs Config\n    92→  console.log(\"\\n--- Lord of the RNGs ---\");\n    93→  try {\n    94→    const tx = await (lordofrngsProgram.methods as any)\n    95→      .initializeConfig(treasury)\n    96→      .accounts({ authority: wallet.publicKey })\n    97→      .rpc();\n    98→    console.log(\"LordOfRngs config initialized. tx:\", tx);\n    99→  } catch (e: any) {\n   100→    if (e.message?.includes(\"already in use\")) {\n   101→      console.log(\"LordOfRngs config already initialized (skipping).\");\n   102→    } else {\n   103→      throw e;\n   104→    }\n   105→  }\n   106→\n   107→  console.log(\"\\n=== Done ===\");\n   108→}\n   109→\n   110→main().catch((e) => {\n   111→  console.error(e);\n   112→  process.exit(1);\n   113→});\n   114→"}]},"parent_tool_use_id":null,"session_id":"dfed5053-bbec-4b81-a37f-49b6882e5396","uuid":"c26302dd-c6bb-447b-a3c7-4a665feaa5b0","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/scripts/init-devnet-config.ts","content":"/**\n * Initialize platform + coinflip configs on devnet.\n *\n * Usage: npx ts-node --esm scripts/init-devnet-config.ts\n *\n * Prerequisites:\n *   - Programs deployed to devnet (run deploy-devnet.sh first)\n *   - Deployer wallet at ~/.config/solana/id.json\n *   - IDLs generated in target/idl/\n */\n\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { AnchorProvider, Program, Wallet } from \"@coral-xyz/anchor\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nasync function main() {\n  // Load wallet\n  const walletPath = join(\n    process.env.HOME ?? \"~\",\n    \".config/solana/id.json\"\n  );\n  const secretKey = JSON.parse(readFileSync(walletPath, \"utf8\"));\n  const keypair = Keypair.fromSecretKey(Uint8Array.from(secretKey));\n  const wallet = new Wallet(keypair);\n\n  // Connect to devnet\n  const connection = new Connection(\"https://api.devnet.solana.com\", \"confirmed\");\n  const provider = new AnchorProvider(connection, wallet, {\n    commitment: \"confirmed\",\n  });\n\n  console.log(\"=== Init Devnet Config ===\");\n  console.log(\"Authority:\", wallet.publicKey.toBase58());\n  const balance = await connection.getBalance(wallet.publicKey);\n  console.log(\"Balance:\", (balance / 1e9).toFixed(4), \"SOL\");\n\n  // Load IDLs\n  const platformIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n  );\n  const coinflipIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n  );\n  const lordofrngsIdl = JSON.parse(\n    readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"lordofrngs.json\"), \"utf8\")\n  );\n\n  const platformProgram = new Program(platformIdl, provider);\n  const coinflipProgram = new Program(coinflipIdl, provider);\n  const lordofrngsProgram = new Program(lordofrngsIdl, provider);\n\n  const treasury = wallet.publicKey; // deployer = treasury for devnet\n\n  // 1. Initialize Platform\n  console.log(\"\\n--- Platform ---\");\n  try {\n    const tx = await (platformProgram.methods as any)\n      .initializePlatform(treasury)\n      .accounts({ authority: wallet.publicKey })\n      .rpc();\n    console.log(\"Platform initialized. tx:\", tx);\n  } catch (e: any) {\n    if (e.message?.includes(\"already in use\")) {\n      console.log(\"Platform config already initialized (skipping).\");\n    } else {\n      throw e;\n    }\n  }\n\n  // 2. Initialize Coinflip Config\n  console.log(\"\\n--- Coinflip ---\");\n  try {\n    const tx = await (coinflipProgram.methods as any)\n      .initializeConfig(treasury)\n      .accounts({ authority: wallet.publicKey })\n      .rpc();\n    console.log(\"Coinflip config initialized. tx:\", tx);\n  } catch (e: any) {\n    if (e.message?.includes(\"already in use\")) {\n      console.log(\"Coinflip config already initialized (skipping).\");\n    } else {\n      throw e;\n    }\n  }\n\n  // 3. Initialize Lord of the RNGs Config\n  console.log(\"\\n--- Lord of the RNGs ---\");\n  try {\n    const tx = await (lordofrngsProgram.methods as any)\n      .initializeConfig(treasury)\n      .accounts({ authority: wallet.publicKey })\n      .rpc();\n    console.log(\"LordOfRngs config initialized. tx:\", tx);\n  } catch (e: any) {\n    if (e.message?.includes(\"already in use\")) {\n      console.log(\"LordOfRngs config already initialized (skipping).\");\n    } else {\n      throw e;\n    }\n  }\n\n  console.log(\"\\n=== Done ===\");\n}\n\nmain().catch((e) => {\n  console.error(e);\n  process.exit(1);\n});\n","numLines":114,"startLine":1,"totalLines":114}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GwXJRHZnN8KN7FtaF9UL7W","type":"tool_result","content":"     1→#!/bin/bash\n     2→set -e\n     3→\n     4→# Deploy coinflip + platform programs to Solana devnet with VRF enabled.\n     5→# Usage: ./scripts/deploy-devnet.sh\n     6→#\n     7→# Prerequisites:\n     8→#   - Anchor CLI, Solana CLI installed\n     9→#   - Deployer wallet at ~/.config/solana/id.json with devnet SOL\n    10→#   - Run from solana/ directory (where Anchor.toml lives)\n    11→\n    12→cd \"$(dirname \"$0\")/..\"\n    13→\n    14→echo \"=== RNG Utopia — Devnet Deployment ===\"\n    15→\n    16→# 1. Verify toolchain\n    17→echo \"\"\n    18→echo \"Toolchain:\"\n    19→echo \"  anchor: $(anchor --version)\"\n    20→echo \"  solana: $(solana --version | head -1)\"\n    21→echo \"  cargo-build-sbf: $(cargo-build-sbf --version 2>&1 | head -1)\"\n    22→\n    23→# Preflight: reject known-incompatible SBF toolchains before long builds.\n    24→SBF_VERSION_OUTPUT=\"$(cargo-build-sbf --version 2>&1)\"\n    25→PLATFORM_TOOLS=\"$(printf '%s\\n' \"$SBF_VERSION_OUTPUT\" | sed -n 's/.*platform-tools v\\([0-9][0-9]*\\)\\.\\([0-9][0-9]*\\).*/\\1 \\2/p' | head -1)\"\n    26→if [ -z \"$PLATFORM_TOOLS\" ]; then\n    27→    echo \"ERROR: Could not parse platform-tools version from cargo-build-sbf output.\"\n    28→    echo \"$SBF_VERSION_OUTPUT\"\n    29→    exit 1\n    30→fi\n    31→\n    32→PT_MAJOR=\"$(echo \"$PLATFORM_TOOLS\" | awk '{print $1}')\"\n    33→PT_MINOR=\"$(echo \"$PLATFORM_TOOLS\" | awk '{print $2}')\"\n    34→if [ \"$PT_MAJOR\" -lt 1 ] || { [ \"$PT_MAJOR\" -eq 1 ] && [ \"$PT_MINOR\" -lt 52 ]; }; then\n    35→    echo \"ERROR: platform-tools v1.52+ required (found v${PT_MAJOR}.${PT_MINOR}).\"\n    36→    echo \"Fix: Update your Solana toolchain to a newer version, then retry.\"\n    37→    exit 1\n    38→fi\n    39→\n    40→# 2. Switch to devnet\n    41→echo \"\"\n    42→echo \"Switching to devnet...\"\n    43→solana config set --url devnet\n    44→\n    45→# 3. Check wallet balance\n    46→WALLET=$(solana address)\n    47→echo \"Deployer: $WALLET\"\n    48→BALANCE=$(solana balance --lamports | awk '{print $1}')\n    49→MIN_BALANCE=5000000000  # 5 SOL minimum for deploy\n    50→\n    51→if [ \"$BALANCE\" -lt \"$MIN_BALANCE\" ]; then\n    52→    echo \"Balance: $(solana balance) (insufficient — need ~5 SOL)\"\n    53→    echo \"Requesting airdrop...\"\n    54→    solana airdrop 5 || {\n    55→        echo \"Airdrop failed. Fund manually: solana airdrop 5\"\n    56→        exit 1\n    57→    }\n    58→    echo \"New balance: $(solana balance)\"\n    59→else\n    60→    echo \"Balance: $(solana balance) (OK)\"\n    61→fi\n    62→\n    63→# 4. Build with VRF enabled (no mock-oracle)\n    64→echo \"\"\n    65→echo \"Building programs with VRF enabled (--no-default-features)...\"\n    66→anchor build -- --no-default-features\n    67→\n    68→# 5. Deploy\n    69→echo \"\"\n    70→echo \"Deploying to devnet...\"\n    71→anchor deploy --provider.cluster devnet\n    72→\n    73→# 6. Print program IDs\n    74→echo \"\"\n    75→echo \"=== Deployed Program IDs ===\"\n    76→echo \"coinflip: $(solana address -k target/deploy/coinflip-keypair.json)\"\n    77→echo \"platform: $(solana address -k target/deploy/platform-keypair.json)\"\n    78→echo \"lordofrngs: $(solana address -k target/deploy/lordofrngs-keypair.json)\"\n    79→\n    80→# 7. Initialize config accounts (idempotent — skips if already created)\n    81→echo \"\"\n    82→echo \"Initializing config accounts...\"\n    83→npx tsx scripts/init-devnet-config.ts\n    84→\n    85→echo \"\"\n    86→echo \"=== Deployment complete ===\"\n    87→"}]},"parent_tool_use_id":null,"session_id":"dfed5053-bbec-4b81-a37f-49b6882e5396","uuid":"63292487-3cab-4b46-9e35-4ea0b6412926","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/scripts/deploy-devnet.sh","content":"#!/bin/bash\nset -e\n\n# Deploy coinflip + platform programs to Solana devnet with VRF enabled.\n# Usage: ./scripts/deploy-devnet.sh\n#\n# Prerequisites:\n#   - Anchor CLI, Solana CLI installed\n#   - Deployer wallet at ~/.config/solana/id.json with devnet SOL\n#   - Run from solana/ directory (where Anchor.toml lives)\n\ncd \"$(dirname \"$0\")/..\"\n\necho \"=== RNG Utopia — Devnet Deployment ===\"\n\n# 1. Verify toolchain\necho \"\"\necho \"Toolchain:\"\necho \"  anchor: $(anchor --version)\"\necho \"  solana: $(solana --version | head -1)\"\necho \"  cargo-build-sbf: $(cargo-build-sbf --version 2>&1 | head -1)\"\n\n# Preflight: reject known-incompatible SBF toolchains before long builds.\nSBF_VERSION_OUTPUT=\"$(cargo-build-sbf --version 2>&1)\"\nPLATFORM_TOOLS=\"$(printf '%s\\n' \"$SBF_VERSION_OUTPUT\" | sed -n 's/.*platform-tools v\\([0-9][0-9]*\\)\\.\\([0-9][0-9]*\\).*/\\1 \\2/p' | head -1)\"\nif [ -z \"$PLATFORM_TOOLS\" ]; then\n    echo \"ERROR: Could not parse platform-tools version from cargo-build-sbf output.\"\n    echo \"$SBF_VERSION_OUTPUT\"\n    exit 1\nfi\n\nPT_MAJOR=\"$(echo \"$PLATFORM_TOOLS\" | awk '{print $1}')\"\nPT_MINOR=\"$(echo \"$PLATFORM_TOOLS\" | awk '{print $2}')\"\nif [ \"$PT_MAJOR\" -lt 1 ] || { [ \"$PT_MAJOR\" -eq 1 ] && [ \"$PT_MINOR\" -lt 52 ]; }; then\n    echo \"ERROR: platform-tools v1.52+ required (found v${PT_MAJOR}.${PT_MINOR}).\"\n    echo \"Fix: Update your Solana toolchain to a newer version, then retry.\"\n    exit 1\nfi\n\n# 2. Switch to devnet\necho \"\"\necho \"Switching to devnet...\"\nsolana config set --url devnet\n\n# 3. Check wallet balance\nWALLET=$(solana address)\necho \"Deployer: $WALLET\"\nBALANCE=$(solana balance --lamports | awk '{print $1}')\nMIN_BALANCE=5000000000  # 5 SOL minimum for deploy\n\nif [ \"$BALANCE\" -lt \"$MIN_BALANCE\" ]; then\n    echo \"Balance: $(solana balance) (insufficient — need ~5 SOL)\"\n    echo \"Requesting airdrop...\"\n    solana airdrop 5 || {\n        echo \"Airdrop failed. Fund manually: solana airdrop 5\"\n        exit 1\n    }\n    echo \"New balance: $(solana balance)\"\nelse\n    echo \"Balance: $(solana balance) (OK)\"\nfi\n\n# 4. Build with VRF enabled (no mock-oracle)\necho \"\"\necho \"Building programs with VRF enabled (--no-default-features)...\"\nanchor build -- --no-default-features\n\n# 5. Deploy\necho \"\"\necho \"Deploying to devnet...\"\nanchor deploy --provider.cluster devnet\n\n# 6. Print program IDs\necho \"\"\necho \"=== Deployed Program IDs ===\"\necho \"coinflip: $(solana address -k target/deploy/coinflip-keypair.json)\"\necho \"platform: $(solana address -k target/deploy/platform-keypair.json)\"\necho \"lordofrngs: $(solana address -k target/deploy/lordofrngs-keypair.json)\"\n\n# 7. Initialize config accounts (idempotent — skips if already created)\necho \"\"\necho \"Initializing config accounts...\"\nnpx tsx scripts/init-devnet-config.ts\n\necho \"\"\necho \"=== Deployment complete ===\"\n","numLines":87,"startLine":1,"totalLines":87}}}
