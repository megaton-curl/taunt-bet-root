{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019gKUzE8E3bxvTKgC3UspFb","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { AnchorError, Program, Wallet } from \"@coral-xyz/anchor\";\n     5→import anchor from \"@coral-xyz/anchor\";\n     6→const { BN } = anchor;\n     7→import {\n     8→  Keypair,\n     9→  PublicKey,\n    10→  SystemProgram,\n    11→  LAMPORTS_PER_SOL,\n    12→} from \"@solana/web3.js\";\n    13→import { Clock } from \"solana-bankrun\";\n    14→import { randomBytes } from \"node:crypto\";\n    15→import type { Closecall } from \"../target/types/closecall\";\n    16→import { readFileSync } from \"fs\";\n    17→import { dirname, join } from \"path\";\n    18→import { fileURLToPath } from \"url\";\n    19→\n    20→const __filename = fileURLToPath(import.meta.url);\n    21→const __dirname = dirname(__filename);\n    22→\n    23→const IDL = JSON.parse(\n    24→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"closecall.json\"), \"utf8\")\n    25→);\n    26→const PROGRAM_ID = new PublicKey(IDL.address);\n    27→\n    28→// ---------------------------------------------------------------------------\n    29→// Constants matching on-chain program\n    30→// ---------------------------------------------------------------------------\n    31→const MIN_WAGER = 1_000_000; // 0.001 SOL (shared wager.rs MIN_WAGER_LAMPORTS)\n    32→const DEFAULT_BET = 5_000_000; // 0.005 SOL\n    33→const BETTING_WINDOW_SECS = 30;\n    34→const CANDLE_DURATION_SECS = 60;\n    35→const RESOLVE_TIMEOUT_SECS = 300;\n    36→const MAX_ENTRIES_PER_SIDE = 32;\n    37→const TOTAL_FEE_BPS = 300; // 3%\n    38→const SIDE_GREEN = 0;\n    39→const SIDE_RED = 1;\n    40→\n    41→// Arbitrary Pyth feed ID for BTC/USD (used in config + mock accounts)\n    42→const PYTH_BTC_USD_FEED_ID = Buffer.alloc(32);\n    43→PYTH_BTC_USD_FEED_ID.write(\"e62df6c8b4a85fe1a67db44dc12de5db\", 0, 16, \"hex\");\n    44→PYTH_BTC_USD_FEED_ID.write(\"330f7ac66b72dc658afedf0f4a415b43\", 16, 16, \"hex\");\n    45→\n    46→// ---------------------------------------------------------------------------\n    47→// Mock Pyth PriceUpdateV2 account builder\n    48→// ---------------------------------------------------------------------------\n    49→function buildMockPythAccount(\n    50→  price: bigint,\n    51→  exponent: number,\n    52→  feedId: Buffer,\n    53→  publishTime: bigint\n    54→): Buffer {\n    55→  // Layout: [8 disc][32 write_auth][1 verif_level][32 feed_id][8 price][8 conf]\n    56→  //         [4 expo][8 publish_time][8 prev_publish_time][8 ema_price][8 ema_conf][8 posted_slot]\n    57→  const buf = Buffer.alloc(133);\n    58→  let offset = 0;\n    59→\n    60→  // Discriminator (8 bytes — arbitrary, program skips these)\n    61→  buf.fill(0xde, offset, offset + 8);\n    62→  offset += 8;\n    63→\n    64→  // write_authority (32 bytes — zeros)\n    65→  offset += 32;\n    66→\n    67→  // verification_level: Full = variant index 1\n    68→  buf.writeUInt8(1, offset);\n    69→  offset += 1;\n    70→\n    71→  // feed_id (32 bytes)\n    72→  feedId.copy(buf, offset);\n    73→  offset += 32;\n    74→\n    75→  // price (i64 LE)\n    76→  buf.writeBigInt64LE(price, offset);\n    77→  offset += 8;\n    78→\n    79→  // conf (u64 LE)\n    80→  buf.writeBigUInt64LE(100n, offset);\n    81→  offset += 8;\n    82→\n    83→  // exponent (i32 LE)\n    84→  buf.writeInt32LE(exponent, offset);\n    85→  offset += 4;\n    86→\n    87→  // publish_time (i64 LE)\n    88→  buf.writeBigInt64LE(publishTime, offset);\n    89→  offset += 8;\n    90→\n    91→  // prev_publish_time (i64 LE)\n    92→  buf.writeBigInt64LE(publishTime - 1n, offset);\n    93→  offset += 8;\n    94→\n    95→  // ema_price (i64 LE)\n    96→  buf.writeBigInt64LE(price, offset);\n    97→  offset += 8;\n    98→\n    99→  // ema_conf (u64 LE)\n   100→  buf.writeBigUInt64LE(100n, offset);"}]},"parent_tool_use_id":"toolu_017XRBKQoxZR772p1etsboYg","session_id":"dfed5053-bbec-4b81-a37f-49b6882e5396","uuid":"d38091dc-5716-48d7-a5a8-46559833963e"}
