{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ra6drfdNCkruK73mKg8FR1","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3→\n     4→export interface Config {\n     5→  port: number;\n     6→  databaseUrl: string;\n     7→  dbSchema: string;\n     8→  rpcUrl: string;\n     9→  wsRpcUrl: string | undefined;\n    10→  serverKeypair: Keypair;\n    11→  jwtSecret: Uint8Array;\n    12→  cluster: string;\n    13→  challengeTtlSeconds: number;\n    14→  accessTokenTtlSeconds: number;\n    15→  refreshTokenTtlDays: number;\n    16→  rateLimitPerWallet: number;\n    17→  rateLimitGlobal: number;\n    18→  workerPollIntervalMs: number;\n    19→  entropyAccount: string;\n    20→  pythBtcUsdAccount: string;\n    21→  minSolBalance: number;\n    22→}\n    23→\n    24→function requireEnv(name: string): string {\n    25→  const value = process.env[name];\n    26→  if (!value) {\n    27→    throw new Error(`Missing required environment variable: ${name}`);\n    28→  }\n    29→  return value;\n    30→}\n    31→\n    32→function parseKeypair(raw: string): Keypair {\n    33→  try {\n    34→    const bytes = JSON.parse(raw) as number[];\n    35→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    36→  } catch {\n    37→    throw new Error(\n    38→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    39→    );\n    40→  }\n    41→}\n    42→\n    43→export function loadConfig(): Config {\n    44→  const dbSchema = loadDbSchemaFromEnv();\n    45→\n    46→  return {\n    47→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    48→    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    49→    dbSchema,\n    50→    rpcUrl: requireEnv(\"RPC_URL\"),"}]},"parent_tool_use_id":"toolu_017XRBKQoxZR772p1etsboYg","session_id":"dfed5053-bbec-4b81-a37f-49b6882e5396","uui