{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012tANcsjvTCKUuhSCGPicCY","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::pause::check_not_paused;\n     3→\n     4→use crate::error::CloseCallError;\n     5→use crate::pyth::parse_price_update;\n     6→use crate::state::{CloseCallConfig, CloseCallPhase, CloseCallRound, Outcome};\n     7→\n     8→/// Maximum age of Pyth price data for open price (seconds).\n     9→const MAX_OPEN_PRICE_AGE_SECS: i64 = 60;\n    10→\n    11→/// Duration of a single candle in seconds.\n    12→pub const CANDLE_DURATION_SECS: i64 = 60;\n    13→\n    14→/// Timeout buffer after candle close for server to settle (seconds).\n    15→/// After this, anyone can call timeout_refund.\n    16→pub const RESOLVE_TIMEOUT_SECS: i64 = 300;\n    17→\n    18→#[derive(Accounts)]\n    19→#[instruction(round_id: [u8; 8])]\n    20→pub struct CreateRound<'info> {\n    21→    /// Server wallet — pays rent, will later settle.\n    22→    #[account(mut)]\n    23→    pub server: Signer<'info>,\n    24→\n    25→    #[account(\n    26→        seeds = [b\"closecall_config\"],\n    27→        bump = config.bump,\n    28→    )]\n    29→    pub config: Account<'info, CloseCallConfig>,\n    30→\n    31→    #[account(\n    32→        init,\n    33→        payer = server,\n    34→        space = 8 + CloseCallRound::INIT_SPACE,\n    35→        seeds = [b\"cc_round\", round_id.as_ref()],\n    36→        bump,\n    37→    )]\n    38→    pub round: Account<'info, CloseCallRound>,\n    39→\n    40→    /// Pyth PriceUpdateV2 account for the open price.\n    41→    /// CHECK: Parsed and validated in handler (feed_id, freshness).\n    42→    pub price_update: AccountInfo<'info>,\n    43→\n    44→    pub system_program: Program<'info, System>,\n    45→}\n    46→\n    47→pub fn handler(ctx: Context<CreateRound>, round_id: [u8; 8]) -> Result<()> {\n    48→    check_not_paused(false, ctx.accounts.config.paused)?;\n    49→\n    50→    let now = Clock::get()?.unix_timestamp;\n    51→    let price_data = ctx.accounts.price_update.try_borrow_data()?;\n    52→    let price = parse_price_update(\n    53→        &price_data,\n    54→        &ctx.accounts.config.pyth_feed_id,\n    55→        MAX_OPEN_PRICE_AGE_SECS,\n    56→        now,\n    57→    )?;\n    58→\n    59→    let betting_window = ctx.accounts.config.betting_window_secs as i64;\n    60→\n    61→    let round = &mut ctx.accounts.round;\n    62→    round.round_id = round_id;\n    63→    round.server = ctx.accounts.server.key();\n    64→    round.phase = CloseCallPhase::Open;\n    65→    round.green_entries = Vec::new();\n    66→    round.red_entries = Vec::new();\n    67→    round.green_pool = 0;\n    68→    round.red_pool = 0;\n    69→    round.open_price = price.price;\n    70→    round.open_price_expo = price.exponent;\n    71→    round.close_price = 0;\n    72→    round.created_at = now;\n    73→    round.betting_ends_at = now + betting_window;\n    74→    round.resolve_deadline = now + CANDLE_DURATION_SECS + RESOLVE_TIMEOUT_SECS;\n    75→    round.outcome = Outcome::Pending;\n    76→    round.total_fee = 0;\n    77→    round.bump = ctx.bumps.round;\n    78→\n    79→    Ok(())\n    80→}\n    81→"}]},"parent_tool_use_id":null,"session_id":"dfed5053-bbec-4b81-a37f-49b6882e5396","uuid":"6e025f76-324b-4340-8cf1-0d7dc63745e8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/closecall/src/instructions/create_round.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::pause::check_not_paused;\n\nuse crate::error::CloseCallError;\nuse crate::pyth::parse_price_update;\nuse crate::state::{CloseCallConfig, CloseCallPhase, CloseCallRound, Outcome};\n\n/// Maximum age of Pyth price data for open price (seconds).\nconst MAX_OPEN_PRICE_AGE_SECS: i64 = 60;\n\n/// Duration of a single candle in seconds.\npub const CANDLE_DURATION_SECS: i64 = 60;\n\n/// Timeout buffer after candle close for server to settle (seconds).\n/// After this, anyone can call timeout_refund.\npub const RESOLVE_TIMEOUT_SECS: i64 = 300;\n\n#[derive(Accounts)]\n#[instruction(round_id: [u8; 8])]\npub struct CreateRound<'info> {\n    /// Server wallet — pays rent, will later settle.\n    #[account(mut)]\n    pub server: Signer<'info>,\n\n    #[account(\n        seeds = [b\"closecall_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CloseCallConfig>,\n\n    #[account(\n        init,\n        payer = server,\n        space = 8 + CloseCallRound::INIT_SPACE,\n        seeds = [b\"cc_round\", round_id.as_ref()],\n        bump,\n    )]\n    pub round: Account<'info, CloseCallRound>,\n\n    /// Pyth PriceUpdateV2 account for the open price.\n    /// CHECK: Parsed and validated in handler (feed_id, freshness).\n    pub price_update: AccountInfo<'info>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CreateRound>, round_id: [u8; 8]) -> Result<()> {\n    check_not_paused(false, ctx.accounts.config.paused)?;\n\n    let now = Clock::get()?.unix_timestamp;\n    let price_data = ctx.accounts.price_update.try_borrow_data()?;\n    let price = parse_price_update(\n        &price_data,\n        &ctx.accounts.config.pyth_feed_id,\n        MAX_OPEN_PRICE_AGE_SECS,\n        now,\n    )?;\n\n    let betting_window = ctx.accounts.config.betting_window_secs as i64;\n\n    let round = &mut ctx.accounts.round;\n    round.round_id = round_id;\n    round.server = ctx.accounts.server.key();\n    round.phase = CloseCallPhase::Open;\n    round.green_entries = Vec::new();\n    round.red_entries = Vec::new();\n    round.green_pool = 0;\n    round.red_pool = 0;\n    round.open_price = price.price;\n    round.open_price_expo = price.exponent;\n    round.close_price = 0;\n    round.created_at = now;\n    round.betting_ends_at = now + betting_window;\n    round.resolve_deadline = now + CANDLE_DURATION_SECS + RESOLVE_TIMEOUT_SECS;\n    round.outcome = Outcome::Pending;\n    round.total_fee = 0;\n    round.bump = ctx.bumps.round;\n\n    Ok(())\n}\n","numLines":81,"startLine":1,"totalLines":81}}}
