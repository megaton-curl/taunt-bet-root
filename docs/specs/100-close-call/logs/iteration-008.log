fig::INIT_SPACE,\n        seeds = [b\"closecall_config\"],\n        bump,\n    )]\n    pub config: Account<'info, CloseCallConfig>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(\n    ctx: Context<InitializeConfig>,\n    treasury: Pubkey,\n    pyth_feed_id: [u8; 32],\n    betting_window_secs: u32,\n    max_entries_per_side: u8,\n) -> Result<()> {\n    let config = &mut ctx.accounts.config;\n    config.authority = ctx.accounts.authority.key();\n    config.treasury = treasury;\n    config.pyth_feed_id = pyth_feed_id;\n    config.betting_window_secs = betting_window_secs;\n    config.max_entries_per_side = max_entries_per_side;\n    config.paused = false;\n    config.bump = ctx.bumps.config;\n    Ok(())\n}\n","numLines":39,"startLine":1,"totalLines":39}}}
