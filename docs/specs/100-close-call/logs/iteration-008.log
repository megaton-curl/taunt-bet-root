{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L784Hnjb8jja2n2TeeYhaU","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_to_pda;\n     3→use rng_shared::pause::check_not_paused;\n     4→use rng_shared::wager::validate_wager;\n     5→\n     6→use crate::error::CloseCallError;\n     7→use crate::state::{BetEntry, BetSide, CloseCallConfig, CloseCallPhase, CloseCallRound};\n     8→\n     9→#[derive(Accounts)]\n    10→#[instruction(round_id: [u8; 8])]\n    11→pub struct PlaceBet<'info> {\n    12→    #[account(mut)]\n    13→    pub player: Signer<'info>,\n    14→\n    15→    #[account(\n    16→        seeds = [b\"closecall_config\"],\n    17→        bump = config.bump,\n    18→    )]\n    19→    pub config: Account<'info, CloseCallConfig>,\n    20→\n    21→    #[account(\n    22→        mut,\n    23→        seeds = [b\"cc_round\", round_id.as_ref()],\n    24→        bump = round.bump,\n    25→    )]\n    26→    pub round: Account<'info, CloseCallRound>,\n    27→\n    28→    pub system_program: Program<'info, System>,\n    29→}\n    30→\n    31→pub fn handler(\n    32→    ctx: Context<PlaceBet>,\n    33→    _round_id: [u8; 8],\n    34→    side: u8,\n    35→    amount: u64,\n    36→) -> Result<()> {\n    37→    check_not_paused(false, ctx.accounts.config.paused)?;\n    38→\n    39→    let round = &ctx.accounts.round;\n    40→    require!(round.phase == CloseCallPhase::Open, CloseCallError::InvalidPhase);\n    41→\n    42→    let now = Clock::get()?.unix_timestamp;\n    43→    require!(now < round.betting_ends_at, CloseCallError::BettingClosed);\n    44→\n    45→    validate_wager(amount).map_err(|_| CloseCallError::WagerBelowMinimum)?;\n    46→\n    47→    let bet_side = match side {\n    48→        0 => BetSide::Green,\n    49→        1 => BetSide::Red,\n    50→        _ => return Err(CloseCallError::InvalidSide.into()),\n    51→    };\n    52→\n    53→    let player_key = ctx.accounts.player.key();\n    54→    let max_per_side = ctx.accounts.config.max_entries_per_side as usize;\n    55→\n    56→    // One bet per player per round (either side).\n    57→    let already_bet = ctx\n    58→        .accounts\n    59→        .round\n    60→        .green_entries\n    61→        .iter()\n    62→        .chain(ctx.accounts.round.red_entries.iter())\n    63→        .any(|e| e.player == player_key);\n    64→    require!(!already_bet, CloseCallError::PlayerAlreadyBet);\n    65→\n    66→    // Check max entries per side.\n    67→    match bet_side {\n    68→        BetSide::Green => {\n    69→            require!(\n    70→                ctx.accounts.round.green_entries.len() < max_per_side,\n    71→                CloseCallError::MaxEntriesReached\n    72→            );\n    73→        }\n    74→        BetSide::Red => {\n    75→            require!(\n    76→                ctx.accounts.round.red_entries.len() < max_per_side,\n    77→                CloseCallError::MaxEntriesReached\n    78→            );\n    79→        }\n    80→    }\n    81→\n    82→    // Transfer wager to round PDA.\n    83→    transfer_lamports_to_pda(\n    84→        &ctx.accounts.player.to_account_info(),\n    85→        &ctx.accounts.round.to_account_info(),\n    86→        amount,\n    87→        &ctx.accounts.system_program.to_account_info(),\n    88→    )?;\n    89→\n    90→    let entry = BetEntry {\n    91→        player: player_key,\n    92→        amount_lamports: amount,\n    93→    };\n    94→\n    95→    let round = &mut ctx.accounts.round;\n    96→    match bet_side {\n    97→        BetSide::Green => {\n    98→            round.green_pool = round\n    99→                .green_pool\n   100→                .checked_add(amount)\n   101→                .ok_or(CloseCallError::ArithmeticOverflow)?;\n   102→            round.green_entries.push(entry);\n   103→        }\n   104→        BetSide::Red => {\n   105→            round.red_pool = round\n   106→                .red_pool\n   107→                .checked_add(amount)\n   108→                .ok_or(CloseCallError::ArithmeticOverflow)?;\n   109→            round.red_entries.push(entry);\n   110→        }\n   111→    }\n   112→\n   113→    Ok(())\n   114→}\n   115→"}]},"parent_tool_use_id":null,"session_id":"dfed5053-bbec-4b81-a37f-49b6882e5396","uuid":"92ee811f-5e33-47c4-8add-83de6465e950","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/closecall/src/instructions/place_bet.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_to_pda;\nuse rng_shared::pause::check_not_paused;\nuse rng_shared::wager::validate_wager;\n\nuse crate::error::CloseCallError;\nuse crate::state::{BetEntry, BetSide, CloseCallConfig, CloseCallPhase, CloseCallRound};\n\n#[derive(Accounts)]\n#[instruction(round_id: [u8; 8])]\npub struct PlaceBet<'info> {\n    #[account(mut)]\n    pub player: Signer<'info>,\n\n    #[account(\n        seeds = [b\"closecall_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CloseCallConfig>,\n\n    #[account(\n        mut,\n        seeds = [b\"cc_round\", round_id.as_ref()],\n        bump = round.bump,\n    )]\n    pub round: Account<'info, CloseCallRound>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(\n    ctx: Context<PlaceBet>,\n    _round_id: [u8; 8],\n    side: u8,\n    amount: u64,\n) -> Result<()> {\n    check_not_paused(false, ctx.accounts.config.paused)?;\n\n    let round = &ctx.accounts.round;\n    require!(round.phase == CloseCallPhase::Open, CloseCallError::InvalidPhase);\n\n    let now = Clock::get()?.unix_timestamp;\n    require!(now < round.betting_ends_at, CloseCallError::BettingClosed);\n\n    validate_wager(amount).map_err(|_| CloseCallError::WagerBelowMinimum)?;\n\n    let bet_side = match side {\n        0 => BetSide::Green,\n        1 => BetSide::Red,\n        _ => return Err(CloseCallError::InvalidSide.into()),\n    };\n\n    let player_key = ctx.accounts.player.key();\n    let max_per_side = ctx.accounts.config.max_entries_per_side as usize;\n\n    // One bet per player per round (either side).\n    let already_bet = ctx\n        .accounts\n        .round\n        .green_entries\n        .iter()\n        .chain(ctx.accounts.round.red_entries.iter())\n        .any(|e| e.player == player_key);\n    require!(!already_bet, CloseCallError::PlayerAlreadyBet);\n\n    // Check max entries per side.\n    match bet_side {\n        BetSide::Green => {\n            require!(\n                ctx.accounts.round.green_entries.len() < max_per_side,\n                CloseCallError::MaxEntriesReached\n            );\n        }\n        BetSide::Red => {\n            require!(\n                ctx.accounts.round.red_entries.len() < max_per_side,\n                CloseCallError::MaxEntriesReached\n            );\n        }\n    }\n\n    // Transfer wager to round PDA.\n    transfer_lamports_to_pda(\n        &ctx.accounts.player.to_account_info(),\n        &ctx.accounts.round.to_account_info(),\n        amount,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    let entry = BetEntry {\n        player: player_key,\n        amount_lamports: amount,\n    };\n\n    let round = &mut ctx.accounts.round;\n    match bet_side {\n        BetSide::Green => {\n            round.green_pool = round\n                .green_pool\n                .checked_add(amount)\n                .ok_or(CloseCallError::ArithmeticOverflow)?;\n            round.green_entries.push(entry);\n        }\n        BetSide::Red => {\n            round.red_pool = round\n                .red_pool\n                .checked_add(amount)\n                .ok_or(CloseCallError::ArithmeticOverflow)?;\n            round.red_entries.push(entry);\n        }\n    }\n\n    Ok(())\n}\n","numLines":115,"startLine":1,"totalLines":115}}}
