{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QwvMj1AxKpoUGkiAvcZxX2","type":"tool_result","content":"     1→// Round state machine\n     2→export { RoundStateMachine, type RoundState, type RoundPhase } from \"./RoundStateMachine\";\n     3→\n     4→// Payout calculations (UI-side, verification only - on-chain is authoritative)\n     5→export {\n     6→  calculatePariMutuelPayout,\n     7→  calculateWinnerPayout,\n     8→  verifyPayoutInvariant,\n     9→} from \"./payouts\";\n    10→\n    11→// Event emitter for UI updates\n    12→export { GameEventEmitter, type GameEvent, type GameEventType } from \"./GameEventEmitter\";\n    13→\n    14→// Legacy instruction builders (deprecated - use game-specific modules)\n    15→export { buildEntryInstruction, buildCashoutInstruction } from \"./instructions\";\n    16→\n    17→// Types\n    18→export type {\n    19→  Pool,\n    20→  PoolPhase,\n    21→  PlayerEntry,\n    22→  Side,\n    23→  GameConfig,\n    24→  GameId,\n    25→  Tier,\n    26→  // Coinflip types\n    27→  CoinSide,\n    28→  CoinflipPhase,\n    29→  CoinflipState,\n    30→  CoinflipMatch,\n    31→  // Legacy types\n    32→  PoolState,\n    33→  LegacyPlayerEntry,\n    34→} from \"./types\";\n    35→\n    36→export {\n    37→  MIN_WAGER_SOL,\n    38→  MIN_WAGER_LAMPORTS,\n    39→  TIER_AMOUNTS,\n    40→  POOL_PHASE_VALUES,\n    41→  SIDE_VALUES,\n    42→  COIN_SIDE_VALUES,\n    43→  COINFLIP_PHASE_VALUES,\n    44→  GAME_IDS,\n    45→  FEE_CONSTANTS,\n    46→} from \"./types\";\n    47→\n    48→// Coinflip game client\n    49→export {\n    50→  COINFLIP_PROGRAM_ID,\n    51→  PROGRAM_IDS,\n    52→  getMatchPda,\n    53→  getConfigPda,\n    54→  getEntryAmount,\n    55→  calculatePotentialPayout,\n    56→  getOppositeSide,\n    57→  determineWinnerFromRandomness,\n    58→} from \"./coinflip\";\n    59→\n    60→// Lord of the RNGs game client\n    61→export {\n    62→  LORDOFRNGS_PROGRAM_ID,\n    63→  getRoundPda,\n    64→  getConfigPda as getLordConfigPda,\n    65→  determineWinnerFromRandomness as determineLordWinnerFromRandomness,\n    66→  mapOffsetToPlayer as mapSlotToPlayer,\n    67→  mapOffsetToPlayer,\n    68→  verifyLordRound,\n    69→  calculateJackpotPayout,\n    70→  type LordPlayerEntry,\n    71→  type RoundSettledEvent,\n    72→  type LordVerificationResult,\n    73→} from \"./lordofrngs\";\n    74→"}]},"parent_tool_use_id":"toolu_01SJ3Eb7WNmRTFD5C4heGtA4","session_id":"ca44bf8e-b3d0-49be-94bb-b1cdc247762d","uuid":"e93cd525-707b-45d2-87b6-2a8fd277006e"}
