{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RjA9h6NeDLRtEsX8JJ5FVq","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→import { CoinflipIDL } from \"@rng-utopia/anchor-client\";\n     3→import { TIER_AMOUNTS, type CoinSide, type Tier } from \"./types\";\n     4→\n     5→// ============ Program IDs ============\n     6→\n     7→export const COINFLIP_PROGRAM_ID = new PublicKey(\n     8→  CoinflipIDL.address\n     9→);\n    10→\n    11→/** @deprecated Use COINFLIP_PROGRAM_ID instead */\n    12→export const PROGRAM_IDS = {\n    13→  COINFLIP: COINFLIP_PROGRAM_ID,\n    14→};\n    15→\n    16→// ============ PDA Derivation ============\n    17→\n    18→/**\n    19→ * Derive the match PDA for a creator + matchId.\n    20→ * Seeds: [\"match\", creator.toBytes(), matchId]\n    21→ */\n    22→export function getMatchPda(creator: PublicKey, matchId: Uint8Array): [PublicKey, number] {\n    23→  return PublicKey.findProgramAddressSync(\n    24→    [Buffer.from(\"match\"), creator.toBuffer(), Buffer.from(matchId)],\n    25→    COINFLIP_PROGRAM_ID\n    26→  );\n    27→}\n    28→\n    29→/**\n    30→ * Derive the global config PDA.\n    31→ * Seeds: [\"coinflip_config\"]\n    32→ */\n    33→export function getConfigPda(): [PublicKey, number] {\n    34→  return PublicKey.findProgramAddressSync(\n    35→    [Buffer.from(\"coinflip_config\")],\n    36→    COINFLIP_PROGRAM_ID\n    37→  );\n    38→}\n    39→\n    40→// ============ Helper Functions ============\n    41→\n    42→/**\n    43→ * Calculate potential payout for a coinflip at a given entry amount (in SOL).\n    44→ * Winner gets total minus 3% fee.\n    45→ */\n    46→export function getEntryAmount(tier: Tier): number {\n    47→  return TIER_AMOUNTS[tier];\n    48→}\n    49→\n    50→export function calculatePotentialPayout(entryAmountSol: number | Tier): number {\n    51→  const resolvedEntryAmount =\n    52→    typeof entryAmountSol === \"string\" ? getEntryAmount(entryAmountSol) : entryAmountSol;\n    53→  const totalPool = resolvedEntryAmount * 2; // Two players\n    54→  const fee = Math.floor(totalPool * 0.03);\n    55→  return totalPool - fee;\n    56→}\n    57→\n    58→/**\n    59→ * Get the opposite coin side\n    60→ */\n    61→export function getOppositeSide(side: CoinSide): CoinSide {\n    62→  return side === \"heads\" ? \"tails\" : \"heads\";\n    63→}\n    64→\n    65→/**\n    66→ * Determine winner from randomness bytes\n    67→ */\n    68→export function determineWinnerFromRandomness(\n    69→  randomness: Uint8Array,\n    70→  player1Side: CoinSide\n    71→): { result: CoinSide; player1Wins: boolean } {\n    72→  // Match the on-chain logic: first byte % 2\n    73→  const firstByte = randomness[0] ?? 0;\n    74→  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n    75→  const player1Wins = player1Side === result;\n    76→  return { result, player1Wins };\n    77→}\n    78→"}]},"parent_tool_use_id":null,"session_id":"ca44bf8e-b3d0-49be-94bb-b1cdc247762d","uuid":"2210274b-02d7-4ba5-9bd2-d15e4b40563f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/coinflip.ts","content":"import { PublicKey } from \"@solana/web3.js\";\nimport { CoinflipIDL } from \"@rng-utopia/anchor-client\";\nimport { TIER_AMOUNTS, type CoinSide, type Tier } from \"./types\";\n\n// ============ Program IDs ============\n\nexport const COINFLIP_PROGRAM_ID = new PublicKey(\n  CoinflipIDL.address\n);\n\n/** @deprecated Use COINFLIP_PROGRAM_ID instead */\nexport const PROGRAM_IDS = {\n  COINFLIP: COINFLIP_PROGRAM_ID,\n};\n\n// ============ PDA Derivation ============\n\n/**\n * Derive the match PDA for a creator + matchId.\n * Seeds: [\"match\", creator.toBytes(), matchId]\n */\nexport function getMatchPda(creator: PublicKey, matchId: Uint8Array): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer(), Buffer.from(matchId)],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n/**\n * Derive the global config PDA.\n * Seeds: [\"coinflip_config\"]\n */\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n// ============ Helper Functions ============\n\n/**\n * Calculate potential payout for a coinflip at a given entry amount (in SOL).\n * Winner gets total minus 3% fee.\n */\nexport function getEntryAmount(tier: Tier): number {\n  return TIER_AMOUNTS[tier];\n}\n\nexport function calculatePotentialPayout(entryAmountSol: number | Tier): number {\n  const resolvedEntryAmount =\n    typeof entryAmountSol === \"string\" ? getEntryAmount(entryAmountSol) : entryAmountSol;\n  const totalPool = resolvedEntryAmount * 2; // Two players\n  const fee = Math.floor(totalPool * 0.03);\n  return totalPool - fee;\n}\n\n/**\n * Get the opposite coin side\n */\nexport function getOppositeSide(side: CoinSide): CoinSide {\n  return side === \"heads\" ? \"tails\" : \"heads\";\n}\n\n/**\n * Determine winner from randomness bytes\n */\nexport function determineWinnerFromRandomness(\n  randomness: Uint8Array,\n  player1Side: CoinSide\n): { result: CoinSide; player1Wins: boolean } {\n  // Match the on-chain logic: first byte % 2\n  const firstByte = randomness[0] ?? 0;\n  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n  const player1Wins = player1Side === result;\n  return { result, player1Wins };\n}\n","numLines":78,"startLine":1,"totalLines":78}}}
