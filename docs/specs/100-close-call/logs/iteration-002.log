{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019P3GDGzUpegyxSDG3cRd2Y","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→import { LordofrngsIDL } from \"@rng-utopia/anchor-client\";\n     3→\n     4→// ============ Program IDs ============\n     5→\n     6→export const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n     7→  LordofrngsIDL.address\n     8→);\n     9→\n    10→// ============ PDA Derivation ============\n    11→\n    12→/**\n    13→ * Derive the round PDA.\n    14→ * Seeds: [\"jackpot_round\", round_number (8 bytes LE)]\n    15→ */\n    16→export function getRoundPda(\n    17→  roundNumber: bigint | number\n    18→): [PublicKey, number] {\n    19→  const roundBuf = Buffer.alloc(8);\n    20→  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n    21→  return PublicKey.findProgramAddressSync(\n    22→    [Buffer.from(\"jackpot_round\"), roundBuf],\n    23→    LORDOFRNGS_PROGRAM_ID\n    24→  );\n    25→}\n    26→\n    27→/**\n    28→ * Derive the global config PDA.\n    29→ * Seeds: [\"lord_config\"]\n    30→ */\n    31→export function getConfigPda(): [PublicKey, number] {\n    32→  return PublicKey.findProgramAddressSync(\n    33→    [Buffer.from(\"lord_config\")],\n    34→    LORDOFRNGS_PROGRAM_ID\n    35→  );\n    36→}\n    37→\n    38→// ============ Helper Types ============\n    39→\n    40→export interface LordPlayerEntry {\n    41→  player: PublicKey;\n    42→  amountLamports: bigint;\n    43→}\n    44→\n    45→/** Data extracted from a RoundSettled event (on-chain log). */\n    46→export interface RoundSettledEvent {\n    47→  roundNumber: bigint;\n    48→  commitment: Uint8Array;\n    49→  secret: Uint8Array;\n    50→  entropy: Uint8Array;\n    51→  resultHash: Uint8Array;\n    52→  totalAmountLamports: bigint;\n    53→  winner: PublicKey;\n    54→  winningOffset: bigint;\n    55→  winningEntryIndex: number;\n    56→  payoutAmount: bigint;\n    57→  feeAmount: bigint;\n    58→}\n    59→\n    60→/** Result of verifying a Lord of the RNGs round. */\n    61→export interface LordVerificationResult {\n    62→  valid: boolean;\n    63→  errors: string[];\n    64→  computedWinningOffset?: bigint;\n    65→  computedWinner?: PublicKey;\n    66→  computedWinningEntryIndex?: number;\n    67→}\n    68→\n    69→// ============ Helper Functions ============\n    70→\n    71→/**\n    72→ * Determine the winning entry from deterministic result bytes.\n    73→ * Matches on-chain logic: u64::from_le_bytes(randomness[0..8]) % total_entries\n    74→ */\n    75→export function determineWinnerFromRandomness(\n    76→  resultHash: Uint8Array,\n    77→  totalAmountLamports: bigint,\n    78→  players: LordPlayerEntry[]\n    79→): { winningOffset: bigint; winner: PublicKey; winningEntryIndex: number } {\n    80→  const winningOffset = deriveWinningOffset(resultHash, totalAmountLamports);\n    81→  const { winner, winningEntryIndex } = mapOffsetToPlayer(winningOffset, players);\n    82→  return { winningOffset, winner, winningEntryIndex };\n    83→}\n    84→\n    85→/**\n    86→ * Derive the winning weighted offset from raw result bytes.\n    87→ * Uses first 8 bytes as little-endian u64, then mod total_amount_lamports.\n    88→ */\n    89→function deriveWinningOffset(\n    90→  resultHash: Uint8Array,\n    91→  totalAmountLamports: bigint\n    92→): bigint {\n    93→  const view = new DataView(resultHash.buffer, resultHash.byteOffset, 8);\n    94→  const raw = view.getBigUint64(0, true); // little-endian\n    95→  return raw % totalAmountLamports;\n    96→}\n    97→\n    98→/**\n    99→ * Map a winning weighted offset to the player whose entry owns that amount range.\n   100→ */\n   101→export function mapOffsetToPlayer(\n   102→  winningOffset: bigint,\n   103→  players: LordPlayerEntry[]\n   104→): { winner: PublicKey; winningEntryIndex: number } {\n   105→  let cumulative = 0n;\n   106→  for (const [index, p] of players.entries()) {\n   107→    cumulative += p.amountLamports;\n   108→    if (winningOffset < cumulative) {\n   109→      return { winner: p.player, winningEntryIndex: index };\n   110→    }\n   111→  }\n   112→  throw new Error(\n   113→    `Winning offset ${winningOffset} exceeds total amount ${cumulative}`\n   114→  );\n   115→}\n   116→\n   117→// ============ Verification ============\n   118→\n   119→/**\n   120→ * Verify a Lord of the RNGs round's fairness.\n   121→ *\n   122→ * Given the RoundSettled event data and the player list from the round,\n   123→ * re-derives the winning offset from the deterministic result hash and checks that it\n   124→ * matches the claimed winner.\n   125→ *\n   126→ * @param event  - Data extracted from the on-chain RoundSettled event\n   127→ * @param players - Player entries from the round (order must match on-chain Vec)\n   128→ */\n   129→export function verifyLordRound(\n   130→  event: RoundSettledEvent,\n   131→  players: LordPlayerEntry[]\n   132→): LordVerificationResult {\n   133→  const errors: string[] = [];\n   134→\n   135→  const { winningOffset: computedOffset, winner: computedWinner, winningEntryIndex } =\n   136→    determineWinnerFromRandomness(\n   137→      event.resultHash,\n   138→      event.totalAmountLamports,\n   139→      players\n   140→    );\n   141→\n   142→  if (computedOffset !== event.winningOffset) {\n   143→    errors.push(\n   144→      `Winning offset mismatch: computed ${computedOffset}, event claims ${event.winningOffset}`\n   145→    );\n   146→  }\n   147→\n   148→  if (!computedWinner.equals(event.winner)) {\n   149→    errors.push(\n   150→      `Winner mismatch: computed ${computedWinner.toBase58()}, event claims ${event.winner.toBase58()}`\n   151→    );\n   152→  }\n   153→\n   154→  if (winningEntryIndex !== event.winningEntryIndex) {\n   155→    errors.push(\n   156→      `Winning entry index mismatch: computed ${winningEntryIndex}, event claims ${event.winningEntryIndex}`\n   157→    );\n   158→  }\n   159→\n   160→  const totalPool = event.payoutAmount + event.feeAmount;\n   161→  if (totalPool !== event.totalAmountLamports) {\n   162→    errors.push(\n   163→      `Pool mismatch: payout + fee = ${totalPool}, totalAmountLamports = ${event.totalAmountLamports}`\n   164→    );\n   165→  }\n   166→\n   167→  const expectedFee = (totalPool * 3n) / 100n;\n   168→  if (event.feeAmount !== expectedFee) {\n   169→    errors.push(\n   170→      `Fee mismatch: expected ${expectedFee} (3% of ${totalPool}), got ${event.feeAmount}`\n   171→    );\n   172→  }\n   173→\n   174→  return {\n   175→    valid: errors.length === 0,\n   176→    errors,\n   177→    computedWinningOffset: computedOffset,\n   178→    computedWinner,\n   179→    computedWinningEntryIndex: winningEntryIndex,\n   180→  };\n   181→}\n   182→\n   183→/**\n   184→ * Calculate total jackpot payout from a lamport-denominated total pool.\n   185→ */\n   186→export function calculateJackpotPayout(\n   187→  totalPoolLamports: bigint\n   188→): number {\n   189→  const fee = Number((totalPoolLamports * 3n) / 100n);\n   190→  return Number(totalPoolLamports) - fee;\n   191→}\n   192→"}]},"parent_tool_use_id":null,"session_id":"ca44bf8e-b3d0-49be-94bb-b1cdc247762d","uuid":"a04a7045-fc75-47ab-9e48-dc27858f01a7","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/lordofrngs.ts","content":"import { PublicKey } from \"@solana/web3.js\";\nimport { LordofrngsIDL } from \"@rng-utopia/anchor-client\";\n\n// ============ Program IDs ============\n\nexport const LORDOFRNGS_PROGRAM_ID = new PublicKey(\n  LordofrngsIDL.address\n);\n\n// ============ PDA Derivation ============\n\n/**\n * Derive the round PDA.\n * Seeds: [\"jackpot_round\", round_number (8 bytes LE)]\n */\nexport function getRoundPda(\n  roundNumber: bigint | number\n): [PublicKey, number] {\n  const roundBuf = Buffer.alloc(8);\n  roundBuf.writeBigUInt64LE(BigInt(roundNumber));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"jackpot_round\"), roundBuf],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\n/**\n * Derive the global config PDA.\n * Seeds: [\"lord_config\"]\n */\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"lord_config\")],\n    LORDOFRNGS_PROGRAM_ID\n  );\n}\n\n// ============ Helper Types ============\n\nexport interface LordPlayerEntry {\n  player: PublicKey;\n  amountLamports: bigint;\n}\n\n/** Data extracted from a RoundSettled event (on-chain log). */\nexport interface RoundSettledEvent {\n  roundNumber: bigint;\n  commitment: Uint8Array;\n  secret: Uint8Array;\n  entropy: Uint8Array;\n  resultHash: Uint8Array;\n  totalAmountLamports: bigint;\n  winner: PublicKey;\n  winningOffset: bigint;\n  winningEntryIndex: number;\n  payoutAmount: bigint;\n  feeAmount: bigint;\n}\n\n/** Result of verifying a Lord of the RNGs round. */\nexport interface LordVerificationResult {\n  valid: boolean;\n  errors: string[];\n  computedWinningOffset?: bigint;\n  computedWinner?: PublicKey;\n  computedWinningEntryIndex?: number;\n}\n\n// ============ Helper Functions ============\n\n/**\n * Determine the winning entry from deterministic result bytes.\n * Matches on-chain logic: u64::from_le_bytes(randomness[0..8]) % total_entries\n */\nexport function determineWinnerFromRandomness(\n  resultHash: Uint8Array,\n  totalAmountLamports: bigint,\n  players: LordPlayerEntry[]\n): { winningOffset: bigint; winner: PublicKey; winningEntryIndex: number } {\n  const winningOffset = deriveWinningOffset(resultHash, totalAmountLamports);\n  const { winner, winningEntryIndex } = mapOffsetToPlayer(winningOffset, players);\n  return { winningOffset, winner, winningEntryIndex };\n}\n\n/**\n * Derive the winning weighted offset from raw result bytes.\n * Uses first 8 bytes as little-endian u64, then mod total_amount_lamports.\n */\nfunction deriveWinningOffset(\n  resultHash: Uint8Array,\n  totalAmountLamports: bigint\n): bigint {\n  const view = new DataView(resultHash.buffer, resultHash.byteOffset, 8);\n  const raw = view.getBigUint64(0, true); // little-endian\n  return raw % totalAmountLamports;\n}\n\n/**\n * Map a winning weighted offset to the player whose entry owns that amount range.\n */\nexport function mapOffsetToPlayer(\n  winningOffset: bigint,\n  players: LordPlayerEntry[]\n): { winner: PublicKey; winningEntryIndex: number } {\n  let cumulative = 0n;\n  for (const [index, p] of players.entries()) {\n    cumulative += p.amountLamports;\n    if (winningOffset < cumulative) {\n      return { winner: p.player, winningEntryIndex: index };\n    }\n  }\n  throw new Error(\n    `Winning offset ${winningOffset} exceeds total amount ${cumulative}`\n  );\n}\n\n// ============ Verification ============\n\n/**\n * Verify a Lord of the RNGs round's fairness.\n *\n * Given the RoundSettled event data and the player list from the round,\n * re-derives the winning offset from the deterministic result hash and checks that it\n * matches the claimed winner.\n *\n * @param event  - Data extracted from the on-chain RoundSettled event\n * @param players - Player entries from the round (order must match on-chain Vec)\n */\nexport function verifyLordRound(\n  event: RoundSettledEvent,\n  players: LordPlayerEntry[]\n): LordVerificationResult {\n  const errors: string[] = [];\n\n  const { winningOffset: computedOffset, winner: computedWinner, winningEntryIndex } =\n    determineWinnerFromRandomness(\n      event.resultHash,\n      event.totalAmountLamports,\n      players\n    );\n\n  if (computedOffset !== event.winningOffset) {\n    errors.push(\n      `Winning offset mismatch: computed ${computedOffset}, event claims ${event.winningOffset}`\n    );\n  }\n\n  if (!computedWinner.equals(event.winner)) {\n    errors.push(\n      `Winner mismatch: computed ${computedWinner.toBase58()}, event claims ${event.winner.toBase58()}`\n    );\n  }\n\n  if (winningEntryIndex !== event.winningEntryIndex) {\n    errors.push(\n      `Winning entry index mismatch: computed ${winningEntryIndex}, event claims ${event.winningEntryIndex}`\n    );\n  }\n\n  const totalPool = event.payoutAmount + event.feeAmount;\n  if (totalPool !== event.totalAmountLamports) {\n    errors.push(\n      `Pool mismatch: payout + fee = ${totalPool}, totalAmountLamports = ${event.totalAmountLamports}`\n    );\n  }\n\n  const expectedFee = (totalPool * 3n) / 100n;\n  if (event.feeAmount !== expectedFee) {\n    errors.push(\n      `Fee mismatch: expected ${expectedFee} (3% of ${totalPool}), got ${event.feeAmount}`\n    );\n  }\n\n  return {\n    valid: errors.length === 0,\n    errors,\n    computedWinningOffset: computedOffset,\n    computedWinner,\n    computedWinningEntryIndex: winningEntryIndex,\n  };\n}\n\n/**\n * Calculate total jackpot payout from a lamport-denominated total pool.\n */\nexport function calculateJackpotPayout(\n  totalPoolLamports: bigint\n): number {\n  const fee = Number((totalPoolLamports * 3n) / 100n);\n  return Number(totalPoolLamports) - fee;\n}\n","numLines":192,"startLine":1,"totalLines":192}}}
