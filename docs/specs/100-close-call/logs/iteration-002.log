  },\n   931→          {\n   932→            \"name\": \"resolve_deadline\",\n   933→            \"docs\": [\n   934→              \"Unix timestamp after which timeout_refund is available.\"\n   935→            ],\n   936→            \"type\": \"i64\"\n   937→          },\n   938→          {\n   939→            \"name\": \"outcome\",\n   940→            \"docs\": [\n   941→              \"Settlement outcome.\"\n   942→            ],\n   943→            \"type\": {\n   944→              \"defined\": {\n   945→                \"name\": \"Outcome\"\n   946→              }\n   947→            }\n   948→          },\n   949→          {\n   950→            \"name\": \"total_fee\",\n   951→            \"docs\": [\n   952→              \"Fee collected (0 for refund rounds).\"\n   953→            ],\n   954→            \"type\": \"u64\"\n   955→          },\n   956→          {\n   957→            \"name\": \"bump\",\n   958→            \"docs\": [\n   959→              \"Bump seed for PDA derivation.\"\n   960→            ],\n   961→            \"type\": \"u8\"\n   962→          }\n   963→        ]\n   964→      }\n   965→    },\n   966→    {\n   967→      \"name\": \"Outcome\",\n   968→      \"docs\": [\n   969→        \"Settlement outcome.\"\n   970→      ],\n   971→      \"type\": {\n   972→        \"kind\": \"enum\",\n   973→        \"variants\": [\n   974→          {\n   975→            \"name\": \"Pending\"\n   976→          },\n   977→          {\n   978→            \"name\": \"Green\"\n   979→          },\n   980→          {\n   981→            \"name\": \"Red\"\n   982→          },\n   983→          {\n   984→            \"name\": \"Refund\"\n   985→          }\n   986→        ]\n   987→      }\n   988→    },\n   989→    {\n   990→      \"name\": \"RoundSettled\",\n   991→      \"docs\": [\n   992→        \"Event emitted when a round is settled.\"\n   993→      ],\n   994→      \"type\": {\n   995→        \"kind\": \"struct\",\n   996→        \"fields\": [\n   997→ 