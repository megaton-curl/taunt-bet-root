a as getLordConfigPda,\n    65→  determineWinnerFromRandomness as determineLordWinnerFromRandomness,\n    66→  mapOffsetToPlayer as mapSlotToPlayer,\n    67→  mapOffsetToPlayer,\n    68→  verifyLordRound,\n    69→  calculateJackpotPayout,\n    70→  type LordPlayerEntry,\n    71→  type RoundSettledEvent,\n    72→  type LordVerificationResult,\n    73→} from \"./lordofrngs\";\n    74→"}]},"parent_tool_use_id":null,"session_id":"ca44bf8e-b3d0-49be-94bb-b1cdc247762d","uuid":"0077cbde-a1f0-48b3-b3a0-94d7d6e6a4aa","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/index.ts","content":"// Round state machine\nexport { RoundStateMachine, type RoundState, type RoundPhase } from \"./RoundStateMachine\";\n\n// Payout calculations (UI-side, verification only - on-chain is authoritative)\nexport {\n  calculatePariMutuelPayout,\n  calculateWinnerPayout,\n  verifyPayoutInvariant,\n} from \"./payouts\";\n\n// Event emitter for UI updates\nexport { GameEventEmitter, type GameEvent, type GameEventType } from \"./GameEventEmitter\";\n\n// Legacy instruction builders (deprecated - use game-specific modules)\nexport { buildEntryInstruction, buildCashoutInstruction } from \"./instructions\";\n\n// Types\nexport type {\n  Pool,\n  PoolPhase,\n  PlayerEntry,\n  Side,\n  GameConfig,\n  GameId,\n  Tier,\n  // Coinflip types\n  CoinSide,\n  CoinflipPhase,\n  CoinflipState,\n  CoinflipMatch,\n  // Legacy types\n  PoolState,\n  LegacyPlayerEntry,\n} from \"./types\";\n\nexport {\n  MIN_WAGER_SOL,\n  MIN_WAGER_LAMPORTS,\n  TIER_AMOUNTS,\n  POOL_PHASE_VALUES,\n  SIDE_VALUES,\n  COIN_SIDE_VALUES,\n  COINFLIP_PHASE_VALUES,\n  GAME_IDS,\n  FEE_CONSTANTS,\n} from \"./types\";\n\n// Coinflip game client\nexport {\n  COINFLIP_PROGRAM_ID,\n  PROGRAM_IDS,\n  getMatchPda,\n  getConfigPda,\n  getEntryAmount,\n  calculatePotentialPayout,\n  getOppositeSide,\n  determineWinnerFromRandomness,\n} from \"./coinflip\";\n\n// Lord of the RNGs game client\nexport {\n  LORDOFRNGS_PROGRAM_ID,\n  getRoundPda,\n  getConfigPda as getLordConfigPda,\n  determineWinnerFromRandomness as determineLordWinnerFromRandomness,\n  mapOffsetToPlayer as mapSlotToPlayer,\n  mapOffsetToPlayer,\n  verifyLordRound,\n  calculateJackpotPayout,\n  type LordPlayerEntry,\n  type RoundSettledEvent,\n  type LordVerificationResult,\n} from \"./lordofrngs\";\n","numLines":74,"startLine":1,"totalLines":74}}}
