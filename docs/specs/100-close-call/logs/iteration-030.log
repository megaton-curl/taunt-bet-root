ool: PoolState): {\n  greenPercent: number;\n  redPercent: number;\n} {\n  if (pool.totalPool === 0) {\n    return { greenPercent: 50, redPercent: 50 };\n  }\n\n  return {\n    greenPercent: (pool.greenPool / pool.totalPool) * 100,\n    redPercent: (pool.redPool / pool.totalPool) * 100,\n  };\n}\n\n/**\n * Format amount for display\n */\nexport function formatAmount(amount: number, decimals: number = 4): string {\n  return amount.toFixed(decimals);\n}\n\n/**\n * Format USD amount for display\n */\nexport function formatUsd(amount: number): string {\n  return amount.toLocaleString(\"en-US\", {\n    style: \"currency\",\n    currency: \"USD\",\n    minimumFractionDigits: 2,\n    maximumFractionDigits: 2,\n  });\n}\n","structuredPatch":[{"oldStart":2,"oldLines":31,"newStart":2,"newLines":29,"lines":["  * Pari-Mutuel Payout Calculator for Close Call","  *","  * Formula:","- *   totalPool = greenPool + redPool + carryoverPool","+ *   totalPool = greenPool + redPool","  *   netPool = totalPool × 0.97 (3% fee)","  *   playerPayout = (playerBet / winningPool) × netPool","  */"," "," import type { BetSide, CandleOutcome, Candle, PoolState } from \"../types\";","-import { PLATFORM_FEE, DOJI_THRESHOLD_BPS } from \"../types\";","+import { PLATFORM_FEE } from \"../types\";"," "," export interface PayoutResult {","   winner: BetSide | null;","   payouts: Record<string, number>;","   totalPayout: number;","   platformFee: number;","-  carryoverToNext: number;"," }"," "," /**","- * Determine the outcome of a candle","+ * Determine the outcome of a candle (strict comparison, no threshold)","  */"," export function determineOutcome(candle: Candle): CandleOutcome {","   const diff = candle.close - candle.open;","-  const threshold = candle.open * (DOJI_THRESHOLD_BPS / 10000);"," ","-  if (Math.abs(diff) <= threshold) {","-    return \"doji\";","+  if (diff === 0) {","+    return \"refund\";","   }"," ","   return diff > 0 ? \"green\" : \"red\";"]},{"oldStart":37,"oldLines":20,"newStart":35,"newLines":17,"lines":["  */"," export function calculatePayouts(","   pool: PoolState,","-  outcome: CandleOutcome,","-  carryoverAmount: number = 0","+  outcome: CandleOutcome"," ): PayoutResult {","-  const totalPool = pool.totalPool + carryoverAmount;","+  const totalPool = pool.totalPool;"," ","-  // Handle DOJI - no winners, pool carries over","-  if (outcome === \"doji\") {","-    const fee = pool.totalPool * PLATFORM_FEE;","+  // Handle refund - no winners, full refund, no fee","+  if (outcome === \"refund\") {","     return {","       winner: null,","       payouts: {},","       totalPayout: 0,","-      platformFee: fee,","-      carryoverToNext: totalPool - fee,","+      platformFee: 0,","     };","   }"," "]},{"oldStart":58,"oldLines":22,"newStart":53,"newLines":20,"lines":["   const winner: BetSide = outcome;","   const winningBets = outcome === \"green\" ? pool.greenBets : pool.redBets;","   const winningPool = outcome === \"green\" ? pool.greenPool : pool.redPool;","+  const losingPool = outcome === \"green\" ? pool.redPool : pool.greenPool;"," ","-  // Handle edge case: no bets on winning side","-  if (winningPool === 0 || winningBets.length === 0) {","-    // All funds carry over (minus fee on current round bets)","-    const fee = pool.totalPool * PLATFORM_FEE;","+  // Handle one-sided pool: no losers means refund, no fee","+  if (losingPool === 0 || winningPool === 0 || winningBets.length === 0) {","     return {","       winner,","       payouts: {},","       totalPayout: 0,","-      platformFee: fee,","-      carryoverToNext: totalPool - fee,","+      platformFee: 0,","     };","   }"," ","-  // Calculate platform fee (only on current round's bets, not carryover)","-  const platformFee = pool.totalPool * PLATFORM_FEE;","+  // Calculate platform fee (3% of total pool on decisive rounds only)","+  const platformFee = totalPool * PLATFORM_FEE;","   const netPool = totalPool - platformFee;"," ","   // Calculate individual payouts"]},{"oldStart":92,"oldLines":7,"newStart":85,"newLines":6,"lines":["     payouts,","     totalPayout,","     platformFee,","-    carryoverToNext: 0,","   };"," }"," "]},{"oldStart":102,"oldLines":13,"newStart":94,"newLines":12,"lines":[" export function calculatePotentialPayout(","   betAmount: number,","   betSide: BetSide,","-  pool: PoolState,","-  carryoverAmount: number = 0","+  pool: PoolState"," ): number {","   // Calculate what the pool would look like with this bet","   const newWinningPool =","     betSide === \"green\" ? pool.greenPool + betAmount : pool.redPool + betAmount;","-  const newTotalPool = pool.totalPool + betAmount + carryoverAmount;","+  const newTotalPool = pool.totalPool + betAmount;","   const netPool = newTotalPool * (1 - PLATFORM_FEE);"," ","   // Player's share of winning pool"]},{"oldStart":123,"oldLines":11,"newStart":114,"newLines":10,"lines":["  */"," export function calculateOddsMultiplier(","   side: BetSide,","-  pool: PoolState,","-  carryoverAmount: number = 0","+  pool: PoolState"," ): number {","   const winningPool = side === \"green\" ? pool.greenPool : pool.redPool;","-  const totalPool = pool.totalPool + carryoverAmount;","+  const totalPool = pool.totalPool;"," ","   if (winningPool === 0 || totalPool === 0) {","     return 0;"]}],"originalFile":"/**\n * Pari-Mutuel Payout Calculator for Close Call\n *\n * Formula:\n *   totalPool = greenPool + redPool + carryoverPool\n *   netPool = totalPool × 0.97 (3% fee)\n *   playerPayout = (playerBet / winningPool) × netPool\n */\n\nimport type { BetSide, CandleOutcome, Candle, PoolState } from \"../types\";\nimport { PLATFORM_FEE, DOJI_THRESHOLD_BPS } from \"../types\";\n\nexport interface PayoutResult {\n  winner: BetSide | null;\n  payouts: Record<string, number>;\n  totalPayout: number;\n  platformFee: number;\n  carryoverToNext: number;\n}\n\n/**\n * Determine the outcome of a candle\n */\nexport function determineOutcome(candle: Candle): CandleOutcome {\n  const diff = candle.close - candle.open;\n  const threshold = candle.open * (DOJI_THRESHOLD_BPS / 10000);\n\n  if (Math.abs(diff) <= threshold) {\n    return \"doji\";\n  }\n\n  return diff > 0 ? \"green\" : \"red\";\n}\n\n/**\n * Calculate payouts for all winners\n */\nexport function calculatePayouts(\n  pool: PoolState,\n  outcome: CandleOutcome,\n  carryoverAmount: number = 0\n): PayoutResult {\n  const totalPool = pool.totalPool + carryoverAmount;\n\n  // Handle DOJI - no winners, pool carries over\n  if (outcome === \"doji\") {\n    const fee = pool.totalPool * PLATFORM_FEE;\n    return {\n      winner: null,\n      payouts: {},\n      totalPayout: 0,\n      platformFee: fee,\n      carryoverToNext: totalPool - fee,\n    };\n  }\n\n  // Determine winning side\n  const winner: BetSide = outcome;\n  const winningBets = outcome === \"green\" ? pool.greenBets : pool.redBets;\n  const winningPool = outcome === \"green\" ? pool.greenPool : pool.redPool;\n\n  // Handle edge case: no bets on winning side\n  if (winningPool === 0 || winningBets.length === 0) {\n    // All funds carry over (minus fee on current round bets)\n    const fee = pool.totalPool * PLATFORM_FEE;\n    return {\n      winner,\n      payouts: {},\n      totalPayout: 0,\n      platformFee: fee,\n      carryoverToNext: totalPool - fee,\n    };\n  }\n\n  // Calculate platform fee (only on current round's bets, not carryover)\n  const platformFee = pool.totalPool * PLATFORM_FEE;\n  const netPool = totalPool - platformFee;\n\n  // Calculate individual payouts\n  const payouts: Record<string, number> = {};\n  let totalPayout = 0;\n\n  for (const bet of winningBets) {\n    const share = bet.amount / winningPool;\n    const payout = netPool * share;\n    payouts[bet.address] = payout;\n    totalPayout += payout;\n  }\n\n  return {\n    winner,\n    payouts,\n    totalPayout,\n    platformFee,\n    carryoverToNext: 0,\n  };\n}\n\n/**\n * Calculate potential payout for a hypothetical bet\n */\nexport function calculatePotentialPayout(\n  betAmount: number,\n  betSide: BetSide,\n  pool: PoolState,\n  carryoverAmount: number = 0\n): number {\n  // Calculate what the pool would look like with this bet\n  const newWinningPool =\n    betSide === \"green\" ? pool.greenPool + betAmount : pool.redPool + betAmount;\n  const newTotalPool = pool.totalPool + betAmount + carryoverAmount;\n  const netPool = newTotalPool * (1 - PLATFORM_FEE);\n\n  // Player's share of winning pool\n  const share = betAmount / newWinningPool;\n\n  return netPool * share;\n}\n\n/**\n * Calculate odds multiplier for a side\n * Returns how much $1 would win (e.g., 2.0 means double your money)\n */\nexport function calculateOddsMultiplier(\n  side: BetSide,\n  pool: PoolState,\n  carryoverAmount: number = 0\n): number {\n  const winningPool = side === \"green\" ? pool.greenPool : pool.redPool;\n  const totalPool = pool.totalPool + carryoverAmount;\n\n  if (winningPool === 0 || totalPool === 0) {\n    return 0;\n  }\n\n  const netPool = totalPool * (1 - PLATFORM_FEE);\n  return netPool / winningPool;\n}\n\n/**\n * Calculate percentage of pool on each side\n */\nexport function calculatePoolDistribution(pool: PoolState): {\n  greenPercent: number;\n  redPercent: number;\n} {\n  if (pool.totalPool === 0) {\n    return { greenPercent: 50, redPercent: 50 };\n  }\n\n  return {\n    greenPercent: (pool.greenPool / pool.totalPool) * 100,\n    redPercent: (pool.redPool / pool.totalPool) * 100,\n  };\n}\n\n/**\n * Format amount for display\n */\nexport function formatAmount(amount: number, decimals: number = 4): string {\n  return amount.toFixed(decimals);\n}\n\n/**\n * Format USD amount for display\n */\nexport function formatUsd(amount: number): string {\n  return amount.toLocaleString(\"en-US\", {\n    style: \"currency\",\n    currency: \"USD\",\n    minimumFractionDigits: 2,\n    maximumFractionDigits: 2,\n  });\n}\n"}}
