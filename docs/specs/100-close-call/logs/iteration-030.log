{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_012vUAfJ7L6173E8ZFtPzR3n","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Ge4xK7vRkFs4EA4rpvqkMu","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/components/ActiveBetView.tsx","content":"import type { Round, PlayerBet } from \"../types\";\nimport { SIDE_COLORS, PLATFORM_FEE, BETTING_WINDOW_MS } from \"../types\";\n\ninterface ActiveBetViewProps {\n  round: Round;\n  userBet: PlayerBet;\n}\n\nexport function ActiveBetView({ round, userBet }: ActiveBetViewProps) {\n  // Calculate potential payout\n  const winningPool = userBet.side === \"green\" ? round.pool.greenPool : round.pool.redPool;\n  const totalPool = round.pool.totalPool;\n  const netPool = totalPool * (1 - PLATFORM_FEE);\n\n  const potentialPayout = winningPool > 0 ? (userBet.amount / winningPool) * netPool : 0;\n  const potentialProfit = potentialPayout - userBet.amount;\n  const multiplier = userBet.amount > 0 ? potentialPayout / userBet.amount : 0;\n\n  // Get side color\n  const sideColor = SIDE_COLORS[userBet.side];\n\n  // Determine if still in betting window (round is open and betting time hasn't elapsed)\n  const isBettingOpen = round.phase === \"open\" && Date.now() < round.bettingEndsAt;\n  const isLocked = round.phase === \"open\" && Date.now() >= round.bettingEndsAt;\n\n  // Phase display text\n  const getPhaseText = () => {\n    if (round.phase === \"settled\") return \"Round complete\";\n    if (round.phase === \"refunded\") return \"Round refunded\";\n    if (isBettingOpen) return \"Waiting for candle...\";\n    if (isLocked) return \"Bets locked - watching candle...\";\n    return \"\";\n  };\n\n  // Time remaining in betting window\n  const bettingTimeLeft = Math.max(0, round.bettingEndsAt - Date.now());\n  const bettingProgress = 1 - bettingTimeLeft / BETTING_WINDOW_MS;\n\n  return (\n    <div className=\"close-call-active-bet\">\n      <div className=\"close-call-active-bet__header\">\n        <h3 className=\"close-call-active-bet__title\">Your Active Bet</h3>\n        <span\n          className=\"close-call-active-bet__phase\"\n          data-phase={round.phase}\n          data-betting={isBettingOpen ? \"true\" : undefined}\n          data-locked={isLocked ? \"true\" : undefined}\n        >\n          {getPhaseText()}\n        </span>\n      </div>\n\n      <div className=\"close-call-active-bet__card\">\n        <div className=\"close-call-active-bet__side\" style={{ color: sideColor }}>\n          <span className=\"close-call-active-bet__side-icon\">\n            {userBet.side === \"green\" ? \"▲\" : \"▼\"}\n          </span>\n          <span className=\"close-call-active-bet__side-label\">\n            {userBet.side.toUpperCase()}\n          </span>\n        </div>\n\n        <div className=\"close-call-active-bet__details\">\n          <div className=\"close-call-active-bet__row\">\n            <span>Your Stake</span>\n            <span>{userBet.amount.toFixed(4)} SOL</span>\n          </div>\n          <div className=\"close-call-active-bet__row\">\n            <span>Your Share</span>\n            <span>\n              {winningPool > 0\n                ? ((userBet.amount / winningPool) * 100).toFixed(1)\n                : 0}%\n            </span>\n          </div>\n          <div className=\"close-call-active-bet__row close-call-active-bet__row--highlight\">\n            <span>Potential Win</span>\n            <span className=\"close-call-active-bet__payout\">\n              {potentialPayout.toFixed(4)} SOL\n              <span className=\"close-call-active-bet__profit\">\n                (+{potentialProfit.toFixed(4)})\n              </span>\n            </span>\n          </div>\n          <div className=\"close-call-active-bet__row\">\n            <span>Multiplier</span>\n            <span style={{ color: sideColor }}>{multiplier.toFixed(2)}x</span>\n          </div>\n        </div>\n      </div>\n\n      {isBettingOpen && (\n        <div className=\"close-call-active-bet__note\">\n          Your odds may change as more bets come in ({Math.ceil(bettingTimeLeft / 1000)}s left)\n          <div className=\"close-call-active-bet__progress\" style={{ width: `${bettingProgress * 100}%` }} />\n        </div>\n      )}\n\n      {isLocked && (\n        <div className=\"close-call-active-bet__note close-call-active-bet__note--locked\">\n          Odds are now locked. Good luck!\n        </div>\n      )}\n    </div>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3234,"cache_read_input_tokens":81351,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3234},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"5c05ee71-c547-4de4-8c73-cae9383060b9"}
