_COLORS.green : \"#d45d5d\";\n    53→\n    54→    return {\n    55→      roundId: entry.round.id.slice(-8),\n    56→      result: (\n    57→        <span className=\"close-call-history-result\">\n    58→          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n    59→            {entry.userBet.side.toUpperCase()}\n    60→          </span>\n    61→          <span className=\"close-call-history-result__separator\">|</span>\n    62→          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n    63→            {entry.won ? \"WON\" : \"LOST\"}\n    64→          </span>\n    65→        </span>\n    66→      ),\n    67→      payout: entry.won ? entry.payout : -entry.userBet.amount,\n    68→      timestamp: new Date(entry.round.resolvedAt ?? entry.round.createdAt),\n    69→      verified: true,\n    70→      won: entry.won,\n    71→      onClick: () => setSelectedHistory(entry),\n    72→    };\n    73→  });\n    74→\n    75→  // Handle placing bet with side selection\n    76→  const handlePlaceBetWithSide = async (side: BetSide) => {\n    77→    setPendingSide(side);\n    78→    try {\n    79→      await placeBet(side);\n    80→    } catch (error) {\n    81→      console.error(\"Failed to place bet:\", error);\n    82→    }\n    83→  };\n    84→\n    85→  // Sidebar content\n    86→  const sidebar = (\n    87→    <div className=\"close-call-sidebar\">\n    88→      {/* Carryover jackpot banner */}\n    89→      {carryoverJackpot > 0 && (\n    90→        <div className=\"close-call-sidebar__jackpot\">\n    91→          <span className=\"close-call-sidebar__jackpot-label\">JACKPOT</span>\n    92→          <span className=\"close-call-sidebar__jackpot-amount\">\n    93→            {`$${carryoverJackpot.toFixed(2)}`}\n    94→          </span>\n    95→        </div>\n    96→      )}\n    97→\n    98→      {/* Bet amount input */}\n    99→      <div className=\"close-call-sidebar__section\">\n   100→        <BetAmountInput\n   101→          value={pendingAmount}\n   102→          onChange={setPendingAmount}\n   103→          onAdjust={adjustBetAmount}\n   104→          disabled={placingBet || !!userBet}\n   105→          maxAmount={getBalance?.() ?? 10}\n   106→        />\n   107→      </div>\n   108→\n   109→      {/* Side selector - buttons place bets directly */}\n   110→      <div className=\"close-call-sidebar__section\">\n   111→        {!connected ? (\n   112→          <button\n   113→            type=\"button\"\n   114→            className=\"close-call-action-btn\"\n   115→            onClick={connect}\n   116→          >\n   117→            Connect Wallet\n   118→          </button>\n   119→        ) : (\n   120→          <SideSelector\n   121→            selectedSide={userBet?.side ?? pendingSide}\n   122→            onSelect={handlePlaceBetWithSide}\n   123→            disabled={currentRound?.phase !== \"betting\" || placingBet || pendingAmount <= 0 || !!userBet}\n   124→            placingBet={placingBet}\n   125→          />\n   126→        )}\n   127→      </div>\n   128→\n   129→      {/* Pool distribution - under the buttons */}\n   130→      {currentRound && (\n   131→        <div className=\"close-call-sidebar__section\">\n   132→          <PoolDistribution\n   133→            pool={currentRound.pool}\n   134→            carryoverAmount={currentRound.carryoverAmount}\n   135→            userBet={userBet}\n   136→            potentialPayout={potentialPayout}\n   137→            roundOutcome={currentRound.outcome}\n   138→            isRoundComplete={currentRound.phase === \"complete\"}\n   139→          />\n   140→        </div>\n   141→      )}\n   142→\n   143→      {/* Auto-payout message for winners - shown under prize pool */}\n   144→      {completedRound && (() => {\n   145→        const completedUserBet = address\n   146→          ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n   147→              (b) => b.address === address\n   148→            ) ?? null\n   149→          : null;\n   150→        const isWinner = completedUserBet && completedRound.winners?.includes(completedUserBet.address);\n   151→        const payout = completedUserBet && completedRound.payouts?.[completedUserBet.address];\n   152→\n   153→        if (isWinner && payout) {\n   154→          return (\n   155→            <div className=\"close-call-payout-received\">\n   156→              <span className=\"close-call-payout-received__label\">Payout Received!</span>\n   157→              <span className=\"close-call-payout-received__amount\">{`+$${payout.toFixed(2)}`}</span>\n   158→            </div>\n   159→          );\n   160→        }\n   161→        return null;\n   162→      })()}\n   163→\n   164→      {/* Round fairness info */}\n   165→      {currentRound && (\n   166→        <div className=\"close-call-sidebar__fairness\">\n   167→          <h4 className=\"close-call-sidebar__fairness-title\">Round Fairness</h4>\n   168→          <div className=\"close-call-sidebar__fairness-row\">\n   169→            <span>Round ID</span>\n   170→            <span className=\"close-call-sidebar__hash\" title={currentRound.id}>\n   171→              {currentRound.id.slice(-12)}\n   172→            </span>\n   173→          </div>\n   174→          <div className=\"close-call-sidebar__fairness-row\">\n   175→            <span>Seed Hash</span>\n   176→            <span className=\"close-call-sidebar__hash\" title={currentRound.seedHash}>\n   177→              {currentRound.seedHash.slice(0, 8)}...{currentRound.seedHash.slice(-4)}\n   178→            </span>\n   179→          </div>\n   180→        </div>\n   181→      )}\n   182→    </div>\n   183→  );\n   184→\n   185→  return (\n   186→    <>\n   187→      <GameLayout\n   188→        gameName=\"Close Call\"\n   189→        gameDescription=\"A pari-mutuel prediction market game\"\n   190→        sidebar={sidebar}\n   191→        historyEntries={historyEntries}\n   192→        showHistory={true}\n   193→      >\n   194→        <div className=\"close-call-main\">\n   195→          {/* Result banner - positioned above the chart */}\n   196→          {completedRound && (() => {\n   197→            const outcome = completedRound.outcome;\n   198→            const isUserWinner = completedRoundUserBet && completedRound.winners?.includes(completedRoundUserBet.address);\n   199→            const userPayout = completedRoundUserBet && completedRound.payouts?.[completedRoundUserBet.address];\n   200→            const outcomeColor = outcome === \"green\"\n   201→              ? SIDE_COLORS.green\n   202→              : outcome === \"red\"\n   203→              ? SIDE_COLORS.red\n   204→              : SIDE_COLORS.doji;\n   205→\n   206→            return (\n   207→              <RoundResultBanner\n   208→                outcomeText={outcome === \"doji\" ? \"DOJI\" : `${outcome?.toUpperCase()} WINS`}\n   209→                outcomeColor={outcomeColor}\n   210→                userWon={!!isUserWinner}\n   211→                userLost={!!completedRoundUserBet && !isUserWinner && outcome !== \"doji\"}\n   212→                statusText={\n   213→                  !completedRoundUserBet\n   214→                    ? undefined\n   215→                    : isUserWinner\n   216→                    ? \"You Won!\"\n   217→                    : outcome === \"doji\"\n   218→                    ? \"Pool carries over\"\n   219→                    : \"You Lost\"\n   220→                }\n   221→                payoutAmount={\n   222→                  completedRoundUserBet\n   223→                    ? isUserWinner\n   224→                      ? userPayout ?? undefined\n   225→                      : outcome === \"doji\"\n   226→                      ? undefined\n   227→                      : -completedRoundUserBet.amount\n   228→                    : undefined\n   229→                }\n   230→                onDismiss={clearCompletedRound}\n   231→              />\n   232→            );\n   233→          })()}\n   234→\n   235→          {/* Banner: betting on current candle */}\n   236→          <div className=\"close-call-main__banner\">\n   237→            <span>\n   238→              Will the current candle close{\" \"}\n   239→              <span style={{ color: SIDE_COLORS.green }}>GREEN</span> or{\" \"}\n   240→              <span style={{ color: SIDE_COLORS.red }}>RED</span>?\n   241→            </span>\n   242→          </div>\n   243→\n   244→          {/* Candlestick chart */}\n   245→          {!loading && recentCandles.length > 0 ? (\n   246→            <CandlestickChart\n   247→              candles={recentCandles}\n   248→              currentPrice={currentPrice}\n   249→              progress={candleProgress}\n   250→            />\n   251→          ) : (\n   252→            <div className=\"close-call-main__loading\">\n   253→              <div className=\"close-call-main__spinner\" />\n   254→              <span>Loading chart...</span>\n   255→            </div>\n   256→          )}\n   257→        </div>\n   258→      </GameLayout>\n   259→\n   260→      {/* History detail modal */}\n   261→      <Modal\n   262→        isOpen={selectedHistory !== null}\n   263→        onClose={() => setSelectedHistory(null)}\n   264→        title=\"Round Details\"\n   265→      >\n   266→        {selectedHistory && (() => {\n   267→          const { round, userBet: bet, payout, won } = selectedHistory;\n   268→          const sideColor = SIDE_COLORS[bet.side];\n   269→\n   270→          return (\n   271→            <div className=\"close-call-history-modal\">\n   272→              {/* Round stats */}\n   273→              <div className=\"close-call-history-modal__section\">\n   274→                <h4 className=\"close-call-history-modal__section-title\">Round Stats</h4>\n   275→                <div className=\"close-call-history-modal__row\">\n   276→                  <span>Your Side</span>\n   277→                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n   278→                    {bet.side.toUpperCase()}\n   279→                  </span>\n   280→                </div>\n   281→                <div className=\"close-call-history-modal__row\">\n   282→                  <span>Your Stake</span>\n   283→                  <span>{`$${bet.amount.toFixed(2)}`}</span>\n   284→                </div>\n   285→                <div className=\"close-call-history-modal__row\">\n   286→                  <span>Outcome</span>\n   287→                  <span\n   288→                    style={{\n   289→                      color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   290→                      textShadow: round.outcome ? `0 0 4px ${SIDE_COLORS[round.outcome]}` : undefined,\n   291→                    }}\n   292→                  >\n   293→                    {round.outcome?.toUpperCase() ?? \"?\"}\n   294→                  </span>\n   295→                </div>\n   296→                <div className=\"close-call-history-modal__row\">\n   297→                  <span>Result</span>\n   298→                  <span style={{ color: won ? SIDE_COLORS.green : \"#d45d5d\" }}>\n   299→                    {won ? \"WON!\" : \"LOST\"}\n   300→                  </span>\n   301→                </div>\n   302→                <div className=\"close-call-history-modal__row close-call-history-modal__row--highlight\">\n   303→                  <span>Payout</span>\n   304→                  <span className={won ? \"close-call-history-modal__highlight\" : \"\"}>\n   305→                    {won ? `+$${payout.toFixed(2)}` : `-$${bet.amount.toFixed(2)}`}\n   306→                  </span>\n   307→                </div>\n   308→              </div>\n   309→\n   310→              {/* Candle data */}\n   311→              {round.resultCandle && (\n   312→                <div className=\"close-call-history-modal__section\">\n   313→                  <h4 className=\"close-call-history-modal__section-title\">Candle Data</h4>\n   314→                  <div className=\"close-call-history-modal__row\">\n   315→                    <span>Open</span>\n   316→                    <span>${round.resultCandle.open.toFixed(2)}</span>\n   317→                  </div>\n   318→                  <div className=\"close-call-history-modal__row\">\n   319→                    <span>Close</span>\n   320→                    <span>${round.resultCandle.close.toFixed(2)}</span>\n   321→                  </div>\n   322→                  <div className=\"close-call-history-modal__row\">\n   323→                    <span>Change</span>\n   324→                    <span\n   325→                      style={{\n   326→                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n   327→                      }}\n   328→                    >\n   329→                      {round.outcome === \"green\" ? \"+\" : \"\"}\n   330→                      {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n   331→                    </span>\n   332→                  </div>\n   333→                </div>\n   334→              )}\n   335→\n   336→              {/* Round fairness */}\n   337→              <div className=\"close-call-history-modal__section\">\n   338→                <h4 className=\"close-call-history-modal__section-title\">\n   339→                  <span className=\"close-call-history-modal__lock\">🔒</span>\n   340→                  Round Fairness\n   341→                </h4>\n   342→                <div className=\"close-call-history-modal__row\">\n   343→                  <span>Round ID</span>\n   344→                  <span className=\"close-call-history-modal__hash\" title={round.id}>\n   345→                    {round.id}\n   346→                  </span>\n   347→                </div>\n   348→                <div className=\"close-call-history-modal__row\">\n   349→                  <span>Seed Hash</span>\n   350→                  <span className=\"close-call-history-modal__hash\" title={round.seedHash}>\n   351→                    {round.seedHash}\n   352→                  </span>\n   353→                </div>\n   354→                {round.serverSeed && (\n   355→                  <div className=\"close-call-history-modal__row\">\n   356→                    <span>Server Seed</span>\n   357→                    <span\n   358→                      className=\"close-call-history-modal__hash close-call-history-modal__hash--revealed\"\n   359→                      title={round.serverSeed}\n   360→                    >\n   361→                      {round.serverSeed}\n   362→                    </span>\n   363→                  </div>\n   364→                )}\n   365→              </div>\n   366→\n   367→              {/* Verify link */}\n   368→              <a href=\"/fairness\" className=\"close-call-history-modal__verify-link\">\n   369→                Verify on Fairness Page →\n   370→              </a>\n   371→            </div>\n   372→          );\n   373→        })()}\n   374→      </Modal>\n   375→    </>\n   376→  );\n   377→}\n   378→\n   379→export function CloseCallPage() {\n   380→  return (\n   381→    <CloseCallProvider>\n   382→      <CloseCallPageContent />\n   383→    </CloseCallProvider>\n   384→  );\n   385→}\n   386→"}]},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"1ee0c638-1dfb-4d96-ac71-83223730d050","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/pages/CloseCallPage.tsx","content":"import { useState } from \"react\";\nimport { GameLayout, Modal, RoundResultBanner, type HistoryEntry } from \"@rng-utopia/ui\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport {\n  CloseCallProvider,\n  useCloseCall,\n  CandlestickChart,\n  BetAmountInput,\n  SideSelector,\n  PoolDistribution,\n  SIDE_COLORS,\n  type UserRoundHistory,\n  type BetSide,\n} from \"../features/close-call\";\n\nfunction CloseCallPageContent() {\n  const { connected, connect, getBalance, address } = useWallet();\n  const {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    carryoverJackpot,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    potentialPayout,\n    clearCompletedRound,\n  } = useCloseCall();\n\n  // State for history modal\n  const [selectedHistory, setSelectedHistory] = useState<UserRoundHistory | null>(null);\n\n  // Get user's bet in the completed round (if any)\n  const completedRoundUserBet = completedRound && address\n    ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n        (b) => b.address === address\n      ) ?? null\n    : null;\n\n  // Convert user history to HistoryEntry format\n  const historyEntries: HistoryEntry[] = userHistory.map((entry) => {\n    const sideColor = SIDE_COLORS[entry.userBet.side];\n    const outcomeColor = entry.won ? SIDE_COLORS.green : \"#d45d5d\";\n\n    return {\n      roundId: entry.round.id.slice(-8),\n      result: (\n        <span className=\"close-call-history-result\">\n          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n            {entry.userBet.side.toUpperCase()}\n          </span>\n          <span className=\"close-call-history-result__separator\">|</span>\n          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {entry.won ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: entry.won ? entry.payout : -entry.userBet.amount,\n      timestamp: new Date(entry.round.resolvedAt ?? entry.round.createdAt),\n      verified: true,\n      won: entry.won,\n      onClick: () => setSelectedHistory(entry),\n    };\n  });\n\n  // Handle placing bet with side selection\n  const handlePlaceBetWithSide = async (side: BetSide) => {\n    setPendingSide(side);\n    try {\n      await placeBet(side);\n    } catch (error) {\n      console.error(\"Failed to place bet:\", error);\n    }\n  };\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"close-call-sidebar\">\n      {/* Carryover jackpot banner */}\n      {carryoverJackpot > 0 && (\n        <div className=\"close-call-sidebar__jackpot\">\n          <span className=\"close-call-sidebar__jackpot-label\">JACKPOT</span>\n          <span className=\"close-call-sidebar__jackpot-amount\">\n            {`$${carryoverJackpot.toFixed(2)}`}\n          </span>\n        </div>\n      )}\n\n      {/* Bet amount input */}\n      <div className=\"close-call-sidebar__section\">\n        <BetAmountInput\n          value={pendingAmount}\n          onChange={setPendingAmount}\n          onAdjust={adjustBetAmount}\n          disabled={placingBet || !!userBet}\n          maxAmount={getBalance?.() ?? 10}\n        />\n      </div>\n\n      {/* Side selector - buttons place bets directly */}\n      <div className=\"close-call-sidebar__section\">\n        {!connected ? (\n          <button\n            type=\"button\"\n            className=\"close-call-action-btn\"\n            onClick={connect}\n          >\n            Connect Wallet\n          </button>\n        ) : (\n          <SideSelector\n            selectedSide={userBet?.side ?? pendingSide}\n            onSelect={handlePlaceBetWithSide}\n            disabled={currentRound?.phase !== \"betting\" || placingBet || pendingAmount <= 0 || !!userBet}\n            placingBet={placingBet}\n          />\n        )}\n      </div>\n\n      {/* Pool distribution - under the buttons */}\n      {currentRound && (\n        <div className=\"close-call-sidebar__section\">\n          <PoolDistribution\n            pool={currentRound.pool}\n            carryoverAmount={currentRound.carryoverAmount}\n            userBet={userBet}\n            potentialPayout={potentialPayout}\n            roundOutcome={currentRound.outcome}\n            isRoundComplete={currentRound.phase === \"complete\"}\n          />\n        </div>\n      )}\n\n      {/* Auto-payout message for winners - shown under prize pool */}\n      {completedRound && (() => {\n        const completedUserBet = address\n          ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n              (b) => b.address === address\n            ) ?? null\n          : null;\n        const isWinner = completedUserBet && completedRound.winners?.includes(completedUserBet.address);\n        const payout = completedUserBet && completedRound.payouts?.[completedUserBet.address];\n\n        if (isWinner && payout) {\n          return (\n            <div className=\"close-call-payout-received\">\n              <span className=\"close-call-payout-received__label\">Payout Received!</span>\n              <span className=\"close-call-payout-received__amount\">{`+$${payout.toFixed(2)}`}</span>\n            </div>\n          );\n        }\n        return null;\n      })()}\n\n      {/* Round fairness info */}\n      {currentRound && (\n        <div className=\"close-call-sidebar__fairness\">\n          <h4 className=\"close-call-sidebar__fairness-title\">Round Fairness</h4>\n          <div className=\"close-call-sidebar__fairness-row\">\n            <span>Round ID</span>\n            <span className=\"close-call-sidebar__hash\" title={currentRound.id}>\n              {currentRound.id.slice(-12)}\n            </span>\n          </div>\n          <div className=\"close-call-sidebar__fairness-row\">\n            <span>Seed Hash</span>\n            <span className=\"close-call-sidebar__hash\" title={currentRound.seedHash}>\n              {currentRound.seedHash.slice(0, 8)}...{currentRound.seedHash.slice(-4)}\n            </span>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Close Call\"\n        gameDescription=\"A pari-mutuel prediction market game\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"close-call-main\">\n          {/* Result banner - positioned above the chart */}\n          {completedRound && (() => {\n            const outcome = completedRound.outcome;\n            const isUserWinner = completedRoundUserBet && completedRound.winners?.includes(completedRoundUserBet.address);\n            const userPayout = completedRoundUserBet && completedRound.payouts?.[completedRoundUserBet.address];\n            const outcomeColor = outcome === \"green\"\n              ? SIDE_COLORS.green\n              : outcome === \"red\"\n              ? SIDE_COLORS.red\n              : SIDE_COLORS.doji;\n\n            return (\n              <RoundResultBanner\n                outcomeText={outcome === \"doji\" ? \"DOJI\" : `${outcome?.toUpperCase()} WINS`}\n                outcomeColor={outcomeColor}\n                userWon={!!isUserWinner}\n                userLost={!!completedRoundUserBet && !isUserWinner && outcome !== \"doji\"}\n                statusText={\n                  !completedRoundUserBet\n                    ? undefined\n                    : isUserWinner\n                    ? \"You Won!\"\n                    : outcome === \"doji\"\n                    ? \"Pool carries over\"\n                    : \"You Lost\"\n                }\n                payoutAmount={\n                  completedRoundUserBet\n                    ? isUserWinner\n                      ? userPayout ?? undefined\n                      : outcome === \"doji\"\n                      ? undefined\n                      : -completedRoundUserBet.amount\n                    : undefined\n                }\n                onDismiss={clearCompletedRound}\n              />\n            );\n          })()}\n\n          {/* Banner: betting on current candle */}\n          <div className=\"close-call-main__banner\">\n            <span>\n              Will the current candle close{\" \"}\n              <span style={{ color: SIDE_COLORS.green }}>GREEN</span> or{\" \"}\n              <span style={{ color: SIDE_COLORS.red }}>RED</span>?\n            </span>\n          </div>\n\n          {/* Candlestick chart */}\n          {!loading && recentCandles.length > 0 ? (\n            <CandlestickChart\n              candles={recentCandles}\n              currentPrice={currentPrice}\n              progress={candleProgress}\n            />\n          ) : (\n            <div className=\"close-call-main__loading\">\n              <div className=\"close-call-main__spinner\" />\n              <span>Loading chart...</span>\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* History detail modal */}\n      <Modal\n        isOpen={selectedHistory !== null}\n        onClose={() => setSelectedHistory(null)}\n        title=\"Round Details\"\n      >\n        {selectedHistory && (() => {\n          const { round, userBet: bet, payout, won } = selectedHistory;\n          const sideColor = SIDE_COLORS[bet.side];\n\n          return (\n            <div className=\"close-call-history-modal\">\n              {/* Round stats */}\n              <div className=\"close-call-history-modal__section\">\n                <h4 className=\"close-call-history-modal__section-title\">Round Stats</h4>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {bet.side.toUpperCase()}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Your Stake</span>\n                  <span>{`$${bet.amount.toFixed(2)}`}</span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    style={{\n                      color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n                      textShadow: round.outcome ? `0 0 4px ${SIDE_COLORS[round.outcome]}` : undefined,\n                    }}\n                  >\n                    {round.outcome?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Result</span>\n                  <span style={{ color: won ? SIDE_COLORS.green : \"#d45d5d\" }}>\n                    {won ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row close-call-history-modal__row--highlight\">\n                  <span>Payout</span>\n                  <span className={won ? \"close-call-history-modal__highlight\" : \"\"}>\n                    {won ? `+$${payout.toFixed(2)}` : `-$${bet.amount.toFixed(2)}`}\n                  </span>\n                </div>\n              </div>\n\n              {/* Candle data */}\n              {round.resultCandle && (\n                <div className=\"close-call-history-modal__section\">\n                  <h4 className=\"close-call-history-modal__section-title\">Candle Data</h4>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Open</span>\n                    <span>${round.resultCandle.open.toFixed(2)}</span>\n                  </div>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Close</span>\n                    <span>${round.resultCandle.close.toFixed(2)}</span>\n                  </div>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Change</span>\n                    <span\n                      style={{\n                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\"