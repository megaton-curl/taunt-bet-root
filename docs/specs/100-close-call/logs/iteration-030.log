   }, []);"," ","-  // Claim payout for winning round","-  const claimPayout = useCallback(async () => {","-    if (!completedRound || !address) {","-      throw new Error(\"No completed round to claim\");","-    }","-","-    const isWinner = completedRound.winners?.includes(address);","-    if (!isWinner) {","-      throw new Error(\"You are not a winner\");","-    }","-","-    setClaiming(true);","-    try {","-      // Simulate transaction delay","-      await new Promise((resolve) => setTimeout(resolve, 1000));","-","-      // After claiming, clear the completed round","-      setCompletedRound(null);","-      mockClearCompletedRound();","-    } finally {","-      setClaiming(false);","-    }","-  }, [completedRound, address]);","-","   // Clear completed round (after user dismisses result overlay)","   const clearCompletedRound = useCallback(() => {","     setCompletedRound(null);"]},{"oldStart":351,"oldLines":18,"newStart":316,"newLines":15,"lines":["     currentPrice,","     candleProgress,","     userHistory,","-    carryoverJackpot,","     pendingAmount,","     pendingSide,","     userBet,","     loading,","     placingBet,","-    claiming,","     setPendingAmount,","     setPendingSide,","     placeBet,","     adjustBetAmount,","-    claimPayout,","     clearCompletedRound,","     potentialPayout,","     userOdds,"]}],"originalFile":"import {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  UserRoundHistory,\n  CloseCallContextValue,\n} from \"../types\";\nimport {\n  DEFAULT_BET_AMOUNT,\n  MIN_BET_AMOUNT,\n  MAX_BET_AMOUNT,\n} from \"../types\";\nimport {\n  initializeGame,\n  subscribeToRound,\n  subscribeToCompletedRound,\n  placeBet as mockPlaceBet,\n  getCurrentRound,\n  getUserHistory,\n  getCarryoverAmount,\n  getRecentCandles,\n  getCurrentCandle,\n  getCandleProgress,\n  isGameInitialized,\n  clearCompletedRound as mockClearCompletedRound,\n} from \"../utils/mock-simulation\";\nimport { calculatePotentialPayout } from \"../utils/payout-calculator\";\n\n// Default context value\nconst defaultContextValue: CloseCallContextValue = {\n  currentRound: null,\n  completedRound: null,\n  recentCandles: [],\n  currentPrice: 0,\n  candleProgress: 0,\n  userHistory: [],\n  carryoverJackpot: 0,\n  pendingAmount: DEFAULT_BET_AMOUNT,\n  pendingSide: null,\n  userBet: null,\n  loading: true,\n  placingBet: false,\n  claiming: false,\n  setPendingAmount: () => {},\n  setPendingSide: () => {},\n  placeBet: async () => {},\n  adjustBetAmount: () => {},\n  claimPayout: async () => {},\n  clearCompletedRound: () => {},\n  potentialPayout: 0,\n  userOdds: 0,\n  refreshRound: () => {},\n};\n\nconst CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n\nexport function CloseCallProvider({ children }: { children: ReactNode }) {\n  const { address, getBalance } = useWallet();\n\n  // Round state\n  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n  const [currentPrice, setCurrentPrice] = useState(0);\n  const [candleProgress, setCandleProgress] = useState(0);\n  const [carryoverJackpot, setCarryoverJackpot] = useState(0);\n\n  // User state\n  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [placingBet, setPlacingBet] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n\n  // Get user's bet in current round\n  const userBet = useMemo(() => {\n    if (!currentRound || !address) return null;\n\n    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    return allBets.find((b) => b.address === address) ?? null;\n  }, [currentRound, address]);\n\n  // Calculate potential payout\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    // If user has an active bet, calculate payout based on their bet\n    if (userBet) {\n      return calculatePotentialPayout(\n        userBet.amount,\n        userBet.side,\n        currentRound.pool,\n        currentRound.carryoverAmount\n      );\n    }\n\n    // Otherwise show preview based on pending selection\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(\n      pendingAmount,\n      pendingSide,\n      currentRound.pool,\n      currentRound.carryoverAmount\n    );\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // Calculate user's odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n\n    if (winningPool === 0) return 0;\n\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // Initialize game on mount\n  useEffect(() => {\n    if (!isGameInitialized()) {\n      initializeGame();\n    }\n\n    // Set initial state\n    const round = getCurrentRound();\n    if (round) {\n      setCurrentRound(round);\n    }\n\n    // Build candles array: completed candles + current forming candle\n    const completedCandles = getRecentCandles(15);\n    const currentCandle = getCurrentCandle();\n    if (currentCandle) {\n      setRecentCandles([...completedCandles, currentCandle]);\n    } else {\n      setRecentCandles(completedCandles);\n    }\n    setCarryoverJackpot(getCarryoverAmount());\n    setLoading(false);\n\n    // Subscribe to round updates\n    const unsubscribeRound = subscribeToRound((round) => {\n      setCurrentRound(round);\n      setCarryoverJackpot(getCarryoverAmount());\n\n      // Update candles: completed + current forming\n      const completed = getRecentCandles(15);\n      const current = getCurrentCandle();\n      if (current) {\n        setRecentCandles([...completed, current]);\n      } else {\n        setRecentCandles(completed);\n      }\n    });\n\n    // Subscribe to completed round updates\n    const unsubscribeCompleted = subscribeToCompletedRound((round) => {\n      setCompletedRound(round);\n    });\n\n    // Poll for price/progress updates\n    const pollInterval = setInterval(() => {\n      const candle = getCurrentCandle();\n      if (candle) {\n        const progress = getCandleProgress();\n        setCandleProgress(progress);\n\n        // Interpolate current price\n        const { open, high, low, close } = candle;\n        const isBullish = close > open;\n\n        let price: number;\n        if (isBullish) {\n          if (progress < 0.2) {\n            price = open + (low - open) * (progress / 0.2) * 0.7;\n          } else if (progress < 0.7) {\n            const lowPoint = open + (low - open) * 0.7;\n            price = lowPoint + (high - lowPoint) * ((progress - 0.2) / 0.5);\n          } else {\n            price = high + (close - high) * ((progress - 0.7) / 0.3);\n          }\n        } else {\n          if (progress < 0.2) {\n            price = open + (high - open) * (progress / 0.2) * 0.7;\n          } else if (progress < 0.7) {\n            const highPoint = open + (high - open) * 0.7;\n            price = highPoint + (low - highPoint) * ((progress - 0.2) / 0.5);\n          } else {\n            price = low + (close - low) * ((progress - 0.7) / 0.3);\n          }\n        }\n\n        setCurrentPrice(price);\n\n        // Update candles: completed + current forming\n        const completed = getRecentCandles(15);\n        setRecentCandles([...completed, candle]);\n      }\n    }, 100);\n\n    return () => {\n      unsubscribeRound();\n      unsubscribeCompleted();\n      clearInterval(pollInterval);\n    };\n  }, []);\n\n  // Update user history when address changes\n  useEffect(() => {\n    if (address) {\n      const history = getUserHistory(address).sort(\n        (a, b) => (b.round.resolvedAt ?? b.round.createdAt) - (a.round.resolvedAt ?? a.round.createdAt)\n      );\n      setUserHistory(history);\n    } else {\n      setUserHistory([]);\n    }\n  }, [address, currentRound?.phase]);\n\n  // Place bet action - accepts optional side override for direct button clicks\n  const placeBet = useCallback(async (sideOverride?: BetSide) => {\n    if (!address) {\n      throw new Error(\"Wallet not connected\");\n    }\n\n    const side = sideOverride ?? pendingSide;\n    if (!side) {\n      throw new Error(\"Select GREEN or RED\");\n    }\n\n    if (pendingAmount < MIN_BET_AMOUNT) {\n      throw new Error(`Minimum bet is $${MIN_BET_AMOUNT}`);\n    }\n\n    if (pendingAmount > MAX_BET_AMOUNT) {\n      throw new Error(`Maximum bet is $${MAX_BET_AMOUNT}`);\n    }\n\n    const currentBalance = getBalance?.();\n    if (currentBalance !== undefined && pendingAmount > currentBalance) {\n      throw new Error(\"Insufficient balance\");\n    }\n\n    setPlacingBet(true);\n\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      mockPlaceBet(address, side, pendingAmount);\n\n      // Reset selection after bet\n      setPendingSide(null);\n    } finally {\n      setPlacingBet(false);\n    }\n  }, [address, pendingSide, pendingAmount, getBalance]);\n\n  // Adjust bet amount\n  const adjustBetAmount = useCallback(\n    (adjustment: \"half\" | \"double\" | \"max\") => {\n      let newAmount: number;\n      const currentBalance = getBalance?.();\n\n      switch (adjustment) {\n        case \"half\":\n          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n          break;\n        case \"double\":\n          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n          break;\n        case \"max\":\n          newAmount = currentBalance !== undefined ? Math.min(currentBalance, MAX_BET_AMOUNT) : MAX_BET_AMOUNT;\n          break;\n      }\n\n      // Round to 4 decimal places\n      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n    },\n    [pendingAmount, getBalance]\n  );\n\n  // Refresh round data\n  const refreshRound = useCallback(() => {\n    const round = getCurrentRound();\n    if (round) {\n      setCurrentRound(round);\n    }\n    // Build candles: completed + current forming\n    const completed = getRecentCandles(15);\n    const current = getCurrentCandle();\n    if (current) {\n      setRecentCandles([...completed, current]);\n    } else {\n      setRecentCandles(completed);\n    }\n    setCarryoverJackpot(getCarryoverAmount());\n  }, []);\n\n  // Claim payout for winning round\n  const claimPayout = useCallback(async () => {\n    if (!completedRound || !address) {\n      throw new Error(\"No completed round to claim\");\n    }\n\n    const isWinner = completedRound.winners?.includes(address);\n    if (!isWinner) {\n      throw new Error(\"You are not a winner\");\n    }\n\n    setClaiming(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 1000));\n\n      // After claiming, clear the completed round\n      setCompletedRound(null);\n      mockClearCompletedRound();\n    } finally {\n      setClaiming(false);\n    }\n  }, [completedRound, address]);\n\n  // Clear completed round (after user dismisses result overlay)\n  const clearCompletedRound = useCallback(() => {\n    setCompletedRound(null);\n    mockClearCompletedRound();\n  }, []);\n\n  const contextValue: CloseCallContextValue = {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    carryoverJackpot,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    claiming,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    claimPayout,\n    clearCompletedRound,\n    potentialPayout,\n    userOdds,\n    refreshRound,\n  };\n\n  return (\n    <CloseCallContext.Provider value={contextValue}>\n      {children}\n    </CloseCallContext.Provider>\n  );\n}\n\nexport function useCloseCall(): CloseCallContextValue {\n  const context = useContext(CloseCallContext);\n  if (!context) {\n    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n  }\n  return context;\n}\n"}}
