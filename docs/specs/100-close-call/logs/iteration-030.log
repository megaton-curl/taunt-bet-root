{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0187YdLAzXv863ShXXXKHaMj","type":"tool_result","content":"     1→import { useEffect, useState } from \"react\";\n     2→import type { Round, PlayerBet } from \"../types\";\n     3→import { SIDE_COLORS } from \"../types\";\n     4→\n     5→interface RoundResultOverlayProps {\n     6→  round: Round;\n     7→  userBet: PlayerBet | null;\n     8→  onClose: () => void;\n     9→}\n    10→\n    11→export function RoundResultOverlay({\n    12→  round,\n    13→  userBet,\n    14→  onClose,\n    15→}: RoundResultOverlayProps) {\n    16→  const [isVisible, setIsVisible] = useState(false);\n    17→\n    18→  // Animate in\n    19→  useEffect(() => {\n    20→    const timer = setTimeout(() => setIsVisible(true), 50);\n    21→    return () => clearTimeout(timer);\n    22→  }, []);\n    23→\n    24→  // Auto-close after delay\n    25→  useEffect(() => {\n    26→    const timer = setTimeout(() => {\n    27→      setIsVisible(false);\n    28→      setTimeout(onClose, 300);\n    29→    }, 5000);\n    30→\n    31→    return () => clearTimeout(timer);\n    32→  }, [onClose]);\n    33→\n    34→  // Determine result\n    35→  const outcome = round.outcome;\n    36→  const isUserWinner = userBet && round.winners?.includes(userBet.address);\n    37→  const userPayout = userBet && round.payouts?.[userBet.address];\n    38→\n    39→  // Get outcome color\n    40→  const outcomeColor = outcome === \"green\"\n    41→    ? SIDE_COLORS.green\n    42→    : outcome === \"red\"\n    43→    ? SIDE_COLORS.red\n    44→    : SIDE_COLORS.doji;\n    45→\n    46→  // Get result text\n    47→  const getResultText = () => {\n    48→    if (!userBet) {\n    49→      if (outcome === \"doji\") return \"DOJI - Pool Carries Over!\";\n    50→      return `${outcome?.toUpperCase()} WINS!`;\n    51→    }\n    52→\n    53→    if (outcome === \"doji\") {\n    54→      return \"DOJI - No Winner!\";\n    55→    }\n    56→\n    57→    if (isUserWinner) {\n    58→      return \"YOU WON!\";\n    59→    }\n    60→\n    61→    return \"YOU LOST\";\n    62→  };\n    63→\n    64→  // Get payout text\n    65→  const getPayoutText = () => {\n    66→    if (!userBet) return null;\n    67→\n    68→    if (outcome === \"doji\") {\n    69→      return \"Pool carries over to next round\";\n    70→    }\n    71→\n    72→    if (isUserWinner && userPayout != null) {\n    73→      const profit = userPayout - userBet.amount;\n    74→      return `+$${userPayout.toFixed(4)} (+$${profit.toFixed(4)} profit)`;\n    75→    }\n    76→\n    77→    return `-$${userBet.amount.toFixed(4)}`;\n    78→  };\n    79→\n    80→  return (\n    81→    <div\n    82→      className={`close-call-result-overlay ${isVisible ? \"close-call-result-overlay--visible\" : \"\"}`}\n    83→      onClick={onClose}\n    84→    >\n    85→      <div\n    86→        className={`close-call-result-overlay__content ${\n    87→          outcome === \"doji\"\n    88→            ? \"close-call-result-overlay__content--doji\"\n    89→            : isUserWinner\n    90→            ? \"close-call-result-overlay__content--win\"\n    91→            : \"close-call-result-overlay__content--loss\"\n    92→        }`}\n    93→        onClick={(e) => e.stopPropagation()}\n    94→      >\n    95→        {/* Win Animation - Coin fountain */}\n    96→        {isUserWinner && (\n    97→          <div className=\"close-call-win-animation\">\n    98→            <div className=\"close-call-win-animation__stars\">\n    99→              {[...Array(8)].map((_, i) => (\n   100→                <span key={i} className=\"close-call-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n   101→              ))}\n   102→            </div>\n   103→            <div className=\"close-call-win-animation__coins\">\n   104→              {[...Array(6)].map((_, i) => (\n   105→                <span key={i} className=\"close-call-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n   106→              ))}\n   107→            </div>\n   108→          </div>\n   109→        )}\n   110→\n   111→        {/* Candle result visualization */}\n   112→        <div className=\"close-call-result-overlay__candle\">\n   113→          <div\n   114→            className={`close-call-result-overlay__candle-body close-call-result-overlay__candle-body--${outcome}`}\n   115→            style={{ backgroundColor: outcomeColor }}\n   116→          />\n   117→        </div>\n   118→\n   119→        {/* Result text */}\n   120→        <div\n   121→          className=\"close-call-result-overlay__result\"\n   122→          style={{ color: outcomeColor }}\n   123→        >\n   124→          {getResultText()}\n   125→        </div>\n   126→\n   127→        {/* Payout */}\n   128→        {userBet && (\n   129→          <div\n   130→            className={`close-call-result-overlay__payout ${\n   131→              isUserWinner ? \"close-call-result-overlay__payout--win\" : \"\"\n   132→            }`}\n   133→          >\n   134→            {getPayoutText()}\n   135→          </div>\n   136→        )}\n   137→\n   138→        {/* Candle details */}\n   139→        {round.resultCandle && (\n   140→          <div className=\"close-call-result-overlay__details\">\n   141→            <div className=\"close-call-result-overlay__price\">\n   142→              Open: ${round.resultCandle.open.toFixed(2)}\n   143→            </div>\n   144→            <div className=\"close-call-result-overlay__price\">\n   145→              Close: ${round.resultCandle.close.toFixed(2)}\n   146→            </div>\n   147→            <div\n   148→              className=\"close-call-result-overlay__change\"\n   149→              style={{ color: outcomeColor }}\n   150→            >\n   151→              {outcome === \"green\" ? \"+\" : outcome === \"red\" ? \"\" : \"~\"}\n   152→              {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n   153→            </div>\n   154→          </div>\n   155→        )}\n   156→\n   157→        {/* Fairness data */}\n   158→        <div className=\"close-call-result-overlay__fairness\">\n   159→          <div className=\"close-call-result-overlay__fairness-row\">\n   160→            <span>Round ID</span>\n   161→            <span className=\"close-call-result-overlay__hash\">\n   162→              {round.id.slice(-12)}\n   163→            </span>\n   164→          </div>\n   165→          {round.serverSeed && (\n   166→            <div className=\"close-call-result-overlay__fairness-row\">\n   167→              <span>Server Seed</span>\n   168→              <span className=\"close-call-result-overlay__hash close-call-result-overlay__hash--revealed\">\n   169→                {round.serverSeed.slice(0, 8)}...{round.serverSeed.slice(-4)}\n   170→              </span>\n   171→            </div>\n   172→          )}\n   173→        </div>\n   174→\n   175→        {/* Close button */}\n   176→        <button\n   177→          type=\"button\"\n   178→          className=\"close-call-result-overlay__close\"\n   179→          onClick={onClose}\n   180→        >\n   181→          Continue\n   182→        </button>\n   183→      </div>\n   184→    </div>\n   185→  );\n   186→}\n   187→"}]},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"71340cf0-2ea0-4c04-a799-4155e91d1dca","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/components/RoundResultOverlay.tsx","content":"import { useEffect, useState } from \"react\";\nimport type { Round, PlayerBet } from \"../types\";\nimport { SIDE_COLORS } from \"../types\";\n\ninterface RoundResultOverlayProps {\n  round: Round;\n  userBet: PlayerBet | null;\n  onClose: () => void;\n}\n\nexport function RoundResultOverlay({\n  round,\n  userBet,\n  onClose,\n}: RoundResultOverlayProps) {\n  const [isVisible, setIsVisible] = useState(false);\n\n  // Animate in\n  useEffect(() => {\n    const timer = setTimeout(() => setIsVisible(true), 50);\n    return () => clearTimeout(timer);\n  }, []);\n\n  // Auto-close after delay\n  useEffect(() => {\n    const timer = setTimeout(() => {\n      setIsVisible(false);\n      setTimeout(onClose, 300);\n    }, 5000);\n\n    return () => clearTimeout(timer);\n  }, [onClose]);\n\n  // Determine result\n  const outcome = round.outcome;\n  const isUserWinner = userBet && round.winners?.includes(userBet.address);\n  const userPayout = userBet && round.payouts?.[userBet.address];\n\n  // Get outcome color\n  const outcomeColor = outcome === \"green\"\n    ? SIDE_COLORS.green\n    : outcome === \"red\"\n    ? SIDE_COLORS.red\n    : SIDE_COLORS.doji;\n\n  // Get result text\n  const getResultText = () => {\n    if (!userBet) {\n      if (outcome === \"doji\") return \"DOJI - Pool Carries Over!\";\n      return `${outcome?.toUpperCase()} WINS!`;\n    }\n\n    if (outcome === \"doji\") {\n      return \"DOJI - No Winner!\";\n    }\n\n    if (isUserWinner) {\n      return \"YOU WON!\";\n    }\n\n    return \"YOU LOST\";\n  };\n\n  // Get payout text\n  const getPayoutText = () => {\n    if (!userBet) return null;\n\n    if (outcome === \"doji\") {\n      return \"Pool carries over to next round\";\n    }\n\n    if (isUserWinner && userPayout != null) {\n      const profit = userPayout - userBet.amount;\n      return `+$${userPayout.toFixed(4)} (+$${profit.toFixed(4)} profit)`;\n    }\n\n    return `-$${userBet.amount.toFixed(4)}`;\n  };\n\n  return (\n    <div\n      className={`close-call-result-overlay ${isVisible ? \"close-call-result-overlay--visible\" : \"\"}`}\n      onClick={onClose}\n    >\n      <div\n        className={`close-call-result-overlay__content ${\n          outcome === \"doji\"\n            ? \"close-call-result-overlay__content--doji\"\n            : isUserWinner\n            ? \"close-call-result-overlay__content--win\"\n            : \"close-call-result-overlay__content--loss\"\n        }`}\n        onClick={(e) => e.stopPropagation()}\n      >\n        {/* Win Animation - Coin fountain */}\n        {isUserWinner && (\n          <div className=\"close-call-win-animation\">\n            <div className=\"close-call-win-animation__stars\">\n              {[...Array(8)].map((_, i) => (\n                <span key={i} className=\"close-call-win-animation__star\" style={{ '--star-index': i } as React.CSSProperties}>★</span>\n              ))}\n            </div>\n            <div className=\"close-call-win-animation__coins\">\n              {[...Array(6)].map((_, i) => (\n                <span key={i} className=\"close-call-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n              ))}\n            </div>\n          </div>\n        )}\n\n        {/* Candle result visualization */}\n        <div className=\"close-call-result-overlay__candle\">\n          <div\n            className={`close-call-result-overlay__candle-body close-call-result-overlay__candle-body--${outcome}`}\n            style={{ backgroundColor: outcomeColor }}\n          />\n        </div>\n\n        {/* Result text */}\n        <div\n          className=\"close-call-result-overlay__result\"\n          style={{ color: outcomeColor }}\n        >\n          {getResultText()}\n        </div>\n\n        {/* Payout */}\n        {userBet && (\n          <div\n            className={`close-call-result-overlay__payout ${\n              isUserWinner ? \"close-call-result-overlay__payout--win\" : \"\"\n            }`}\n          >\n            {getPayoutText()}\n          </div>\n        )}\n\n        {/* Candle details */}\n        {round.resultCandle && (\n          <div className=\"close-call-result-overlay__details\">\n            <div className=\"close-call-result-overlay__price\">\n              Open: ${round.resultCandle.open.toFixed(2)}\n            </div>\n            <div className=\"close-call-result-overlay__price\">\n              Close: ${round.resultCandle.close.toFixed(2)}\n            </div>\n            <div\n              className=\"close-call-result-overlay__change\"\n              style={{ color: outcomeColor }}\n            >\n              {outcome === \"green\" ? \"+\" : outcome === \"red\" ? \"\" : \"~\"}\n              {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n            </div>\n          </div>\n        )}\n\n        {/* Fairness data */}\n        <div className=\"close-call-result-overlay__fairness\">\n          <div className=\"close-call-result-overlay__fairness-row\">\n            <span>Round ID</span>\n            <span className=\"close-call-result-overlay__hash\">\n              {round.id.slice(-12)}\n            </span>\n          </div>\n          {round.serverSeed && (\n            <div className=\"close-call-result-overlay__fairness-row\">\n              <span>Server Seed</span>\n              <span className=\"close-call-result-overlay__hash close-call-result-overlay__hash--revealed\">\n                {round.serverSeed.slice(0, 8)}...{round.serverSeed.slice(-4)}\n              </span>\n            </div>\n          )}\n        </div>\n\n        {/* Close button */}\n        <button\n          type=\"button\"\n          className=\"close-call-result-overlay__close\"\n          onClick={onClose}\n        >\n          Continue\n        </button>\n      </div>\n    </div>\n  );\n}\n","numLines":187,"startLine":1,"totalLines":187}}}
