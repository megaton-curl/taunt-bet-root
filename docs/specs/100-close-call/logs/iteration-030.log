n ? SIDE_COLORS.green : \"#d45d5d\";\n\n    return {\n      roundId: entry.round.id.slice(-8),\n      result: (\n        <span className=\"close-call-history-result\">\n          <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n            {entry.userBet.side.toUpperCase()}\n          </span>\n          <span className=\"close-call-history-result__separator\">|</span>\n          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {entry.won ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: entry.won ? entry.payout : -entry.userBet.amount,\n      timestamp: new Date(entry.round.resolvedAt ?? entry.round.createdAt),\n      verified: true,\n      won: entry.won,\n      onClick: () => setSelectedHistory(entry),\n    };\n  });\n\n  // Handle placing bet with side selection\n  const handlePlaceBetWithSide = async (side: BetSide) => {\n    setPendingSide(side);\n    try {\n      await placeBet(side);\n    } catch (error) {\n      console.error(\"Failed to place bet:\", error);\n    }\n  };\n\n  // Determine if betting window is open (round is open and within betting time)\n  const isBettingOpen = currentRound?.phase === \"open\" && Date.now() < (currentRound?.bettingEndsAt ?? 0);\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"close-call-sidebar\">\n      {/* Bet amount input */}\n      <div className=\"close-call-sidebar__section\">\n        <BetAmountInput\n          value={pendingAmount}\n          onChange={setPendingAmount}\n          onAdjust={adjustBetAmount}\n          disabled={placingBet || !!userBet}\n          maxAmount={getBalance?.() ?? 10}\n        />\n      </div>\n\n      {/* Side selector - buttons place bets directly */}\n      <div className=\"close-call-sidebar__section\">\n        {!connected ? (\n          <button\n            type=\"button\"\n            className=\"close-call-action-btn\"\n            onClick={connect}\n          >\n            Connect Wallet\n          </button>\n        ) : (\n          <SideSelector\n            selectedSide={userBet?.side ?? pendingSide}\n            onSelect={handlePlaceBetWithSide}\n            disabled={!isBettingOpen || placingBet || pendingAmount <= 0 || !!userBet}\n            placingBet={placingBet}\n          />\n        )}\n      </div>\n\n      {/* Pool distribution - under the buttons */}\n      {currentRound && (\n        <div className=\"close-call-sidebar__section\">\n          <PoolDistribution\n            pool={currentRound.pool}\n            userBet={userBet}\n            potentialPayout={potentialPayout}\n            roundOutcome={currentRound.outcome}\n            isRoundComplete={currentRound.phase === \"settled\" || currentRound.phase === \"refunded\"}\n          />\n        </div>\n      )}\n\n      {/* Auto-payout message for winners - shown under prize pool */}\n      {completedRound && (() => {\n        const completedUserBet = address\n          ? [...completedRound.pool.greenBets, ...completedRound.pool.redBets].find(\n              (b) => b.address === address\n            ) ?? null\n          : null;\n        const isWinner = completedUserBet && completedRound.winners?.includes(completedUserBet.address);\n        const payout = completedUserBet && completedRound.payouts?.[completedUserBet.address];\n\n        if (isWinner && payout) {\n          return (\n            <div className=\"close-call-payout-received\">\n              <span className=\"close-call-payout-received__label\">Payout Received!</span>\n              <span className=\"close-call-payout-received__amount\">{`+${payout.toFixed(4)} SOL`}</span>\n            </div>\n          );\n        }\n        return null;\n      })()}\n\n      {/* Round info */}\n      {currentRound && (\n        <div className=\"close-call-sidebar__fairness\">\n          <h4 className=\"close-call-sidebar__fairness-title\">Round Info</h4>\n          <div className=\"close-call-sidebar__fairness-row\">\n            <span>Round ID</span>\n            <span className=\"close-call-sidebar__hash\" title={currentRound.id}>\n              {currentRound.id.slice(-12)}\n            </span>\n          </div>\n          <div className=\"close-call-sidebar__fairness-row\">\n            <span>Oracle</span>\n            <span className=\"close-call-sidebar__hash\">Pyth BTC/USD</span>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Close Call\"\n        gameDescription=\"A pari-mutuel prediction market game\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"close-call-main\">\n          {/* Result banner - positioned above the chart */}\n          {completedRound && (() => {\n            const outcome = completedRound.outcome;\n            const isUserWinner = completedRoundUserBet && completedRound.winners?.includes(completedRoundUserBet.address);\n            const userPayout = completedRoundUserBet && completedRound.payouts?.[completedRoundUserBet.address];\n            const outcomeColor = outcome === \"green\"\n              ? SIDE_COLORS.green\n              : outcome === \"red\"\n              ? SIDE_COLORS.red\n              : SIDE_COLORS.refund;\n\n            return (\n              <RoundResultBanner\n                outcomeText={outcome === \"refund\" ? \"REFUND\" : `${outcome?.toUpperCase()} WINS`}\n                outcomeColor={outcomeColor}\n                userWon={!!isUserWinner}\n                userLost={!!completedRoundUserBet && !isUserWinner && outcome !== \"refund\"}\n                statusText={\n                  !completedRoundUserBet\n                    ? undefined\n                    : isUserWinner\n                    ? \"You Won!\"\n                    : outcome === \"refund\"\n                    ? \"Bet refunded\"\n                    : \"You Lost\"\n                }\n                payoutAmount={\n                  completedRoundUserBet\n                    ? isUserWinner\n                      ? userPayout ?? undefined\n                      : outcome === \"refund\"\n                      ? undefined\n                      : -completedRoundUserBet.amount\n                    : undefined\n                }\n                onDismiss={clearCompletedRound}\n              />\n            );\n          })()}\n\n          {/* Banner: betting on current candle */}\n          <div className=\"close-call-main__banner\">\n            <span>\n              Will the current candle close{\" \"}\n              <span style={{ color: SIDE_COLORS.green }}>GREEN</span> or{\" \"}\n              <span style={{ color: SIDE_COLORS.red }}>RED</span>?\n            </span>\n          </div>\n\n          {/* Candlestick chart */}\n          {!loading && recentCandles.length > 0 ? (\n            <CandlestickChart\n              candles={recentCandles}\n              currentPrice={currentPrice}\n              progress={candleProgress}\n            />\n          ) : (\n            <div className=\"close-call-main__loading\">\n              <div className=\"close-call-main__spinner\" />\n              <span>Loading chart...</span>\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* History detail modal */}\n      <Modal\n        isOpen={selectedHistory !== null}\n        onClose={() => setSelectedHistory(null)}\n        title=\"Round Details\"\n      >\n        {selectedHistory && (() => {\n          const { round, userBet: bet, payout, won } = selectedHistory;\n          const sideColor = SIDE_COLORS[bet.side];\n\n          return (\n            <div className=\"close-call-history-modal\">\n              {/* Round stats */}\n              <div className=\"close-call-history-modal__section\">\n                <h4 className=\"close-call-history-modal__section-title\">Round Stats</h4>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {bet.side.toUpperCase()}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Your Stake</span>\n                  <span>{`${bet.amount.toFixed(4)} SOL`}</span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    style={{\n                      color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n                      textShadow: round.outcome ? `0 0 4px ${SIDE_COLORS[round.outcome]}` : undefined,\n                    }}\n                  >\n                    {round.outcome?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Result</span>\n                  <span style={{ color: won ? SIDE_COLORS.green : \"#d45d5d\" }}>\n                    {won ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row close-call-history-modal__row--highlight\">\n                  <span>Payout</span>\n                  <span className={won ? \"close-call-history-modal__highlight\" : \"\"}>\n                    {won ? `+${payout.toFixed(4)} SOL` : `-${bet.amount.toFixed(4)} SOL`}\n                  </span>\n                </div>\n              </div>\n\n              {/* Candle data */}\n              {round.resultCandle && (\n                <div className=\"close-call-history-modal__section\">\n                  <h4 className=\"close-call-history-modal__section-title\">Candle Data</h4>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Open</span>\n                    <span>${round.resultCandle.open.toFixed(2)}</span>\n                  </div>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Close</span>\n                    <span>${round.resultCandle.close.toFixed(2)}</span>\n                  </div>\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Change</span>\n                    <span\n                      style={{\n                        color: round.outcome ? SIDE_COLORS[round.outcome] : \"#888\",\n                      }}\n                    >\n                      {round.outcome === \"green\" ? \"+\" : \"\"}\n                      {(round.resultCandle.close - round.resultCandle.open).toFixed(2)}\n                    </span>\n                  </div>\n                </div>\n              )}\n\n              {/* Round info (oracle-resolved, no commit-reveal) */}\n              <div className=\"close-call-history-modal__section\">\n                <h4 className=\"close-call-history-modal__section-title\">\n                  <span className=\"close-call-history-modal__lock\">🔒</span>\n                  Oracle Verification\n                </h4>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Round ID</span>\n                  <span className=\"close-call-history-modal__hash\" title={round.id}>\n                    {round.id}\n                  </span>\n                </div>\n                <div className=\"close-call-history-modal__row\">\n                  <span>Oracle</span>\n                  <span className=\"close-call-history-modal__hash\">Pyth BTC/USD</span>\n                </div>\n                {round.settleTx && (\n                  <div className=\"close-call-history-modal__row\">\n                    <span>Settlement Tx</span>\n                    <span className=\"close-call-history-modal__hash close-call-history-modal__hash--revealed\" title={round.settleTx}>\n                      {round.settleTx}\n                    </span>\n                  </div>\n                )}\n              </div>\n\n              {/* Verify link */}\n              <a href=\"/fairness\" className=\"close-call-history-modal__verify-link\">\n                Verify on Fairness Page →\n              </a>\n            </div>\n          );\n        })()}\n      </Modal>\n    </>\n  );\n}\n\nexport function CloseCallPage() {\n  return (\n    <CloseCallProvider>\n      <CloseCallPageContent />\n    </CloseCallProvider>\n  );\n}\n","structuredPatch":[{"oldStart":22,"oldLines":7,"newStart":22,"newLines":6,"lines":["     currentPrice,","     candleProgress,","     userHistory,","-    carryoverJackpot,","     pendingAmount,","     pendingSide,","     userBet,"]},{"oldStart":82,"oldLines":19,"newStart":81,"newLines":12,"lines":["     }","   };"," ","+  // Determine if betting window is open (round is open and within betting time)","+  const isBettingOpen = currentRound?.phase === \"open\" && Date.now() < (currentRound?.bettingEndsAt ?? 0);","+","   // Sidebar content","   const sidebar = (","     <div className=\"close-call-sidebar\">","-      {/* Carryover jackpot banner */}","-      {carryoverJackpot > 0 && (","-        <div className=\"close-call-sidebar__jackpot\">","-          <span className=\"close-call-sidebar__jackpot-label\">JACKPOT</span>","-          <span className=\"close-call-sidebar__jackpot-amount\">","-            {`$${carryoverJackpot.toFixed(2)}`}","-          </span>","-        </div>","-      )}","-","       {/* Bet amount input */}","       <div className=\"close-call-sidebar__section\">","         <BetAmountInput"]},{"oldStart":120,"oldLines":7,"newStart":112,"newLines":7,"lines":["           <SideSelector","             selectedSide={userBet?.side ?? pendingSide}","             onSelect={handlePlaceBetWithSide}","-            disabled={currentRound?.phase !== \"betting\" || placingBet || pendingAmount <= 0 || !!userBet}","+