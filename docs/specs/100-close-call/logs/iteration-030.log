nd: () => {},\n    63→};\n    64→\n    65→const CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n    66→\n    67→export function CloseCallProvider({ children }: { children: ReactNode }) {\n    68→  const { address, getBalance } = useWallet();\n    69→\n    70→  // Round state\n    71→  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n    72→  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n    73→  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n    74→  const [currentPrice, setCurrentPrice] = useState(0);\n    75→  const [candleProgress, setCandleProgress] = useState(0);\n    76→  const [carryoverJackpot, setCarryoverJackpot] = useState(0);\n    77→\n    78→  // User state\n    79→  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n    80→  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n    81→  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n    82→\n    83→  // Loading states\n    84→  const [loading, setLoading] = useState(true);\n    85→  const [placingBet, setPlacingBet] = useState(false);\n    86→  const [claiming, setClaiming] = useState(false);\n    87→\n    88→  // Get user's bet in current round\n    89→  const userBet = useMemo(() => {\n    90→    if (!currentRound || !address) return null;\n    91→\n    92→    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    93→    return allBets.find((b) => b.address === address) ?? null;\n    94→  }, [currentRound, address]);\n    95→\n    96→  // Calculate potential payout\n    97→  const potentialPayout = useMemo(() => {\n    98→    if (!currentRound) return 0;\n    99→\n   100→    // If user has an active bet, calculate payout based on their bet\n   101→    if (userBet) {\n   102→      return calculatePotentialPayout(\n   103→        userBet.amount,\n   104→        userBet.side,\n   105→        currentRound.pool,\n   106→        currentRound.carryoverAmount\n   107→      );\n   108→    }\n   109→\n   110→    // Otherwise show preview based on pending selection\n   111→    if (!pendingSide || pendingAmount <= 0) return 0;\n   112→\n   113→    return calculatePotentialPayout(\n   114→      pendingAmount,\n   115→      pendingSide,\n   116→      currentRound.pool,\n   117→      currentRound.carryoverAmount\n   118→    );\n   119→  }, [pendingAmount, pendingSide, currentRound, userBet]);\n   120→\n   121→  // Calculate user's odds (share of winning pool)\n   122→  const userOdds = useMemo(() => {\n   123→    if (!userBet || !currentRound) return 0;\n   124→\n   125→    const winningPool =\n   126→      userBet.side === \"green\"\n   127→        ? currentRound.pool.greenPool\n   128→        : currentRound.pool.redPool;\n   129→\n   130→    if (winningPool === 0) return 0;\n   131→\n   132→    return (userBet.amount / winningPool) * 100;\n   133→  }, [userBet, currentRound]);\n   134→\n   135→  // Initialize game on mount\n   136→  useEffect(() => {\n   137→    if (!isGameInitialized()) {\n   138→      initializeGame();\n   139→    }\n   140→\n   141→    // Set initial state\n   142→    const round = getCurrentRound();\n   143→    if (round) {\n   144→      setCurrentRound(round);\n   145→    }\n   146→\n   147→    // Build candles array: completed candles + current forming candle\n   148→    const completedCandles = getRecentCandles(15);\n   149→    const currentCandle = getCurrentCandle();\n   150→    if (currentCandle) {\n   151→      setRecentCandles([...completedCandles, currentCandle]);\n   152→    } else {\n   153→      setRecentCandles(completedCandles);\n   154→    }\n   155→    setCarryoverJackpot(getCarryoverAmount());\n   156→    setLoading(false);\n   157→\n   158→    // Subscribe to round updates\n   159→    const unsubscribeRound = subscribeToRound((round) => {\n   160→      setCurrentRound(round);\n   161→      setCarryoverJackpot(getCarryoverAmount());\n   162→\n   163→      // Update candles: completed + current forming\n   164→      const completed = getRecentCandles(15);\n   165→      const current = getCurrentCandle();\n   166→      if (current) {\n   167→        setRecentCandles([...completed, current]);\n   168→      } else {\n   169→        setRecentCandles(completed);\n   170→      }\n   171→    });\n   172→\n   173→    // Subscribe to completed round updates\n   174→    const unsubscribeCompleted = subscribeToCompletedRound((round) => {\n   175→      setCompletedRound(round);\n   176→    });\n   177→\n   178→    // Poll for price/progress updates\n   179→    const pollInterval = setInterval(() => {\n   180→      const candle = getCurrentCandle();\n   181→      if (candle) {\n   182→        const progress = getCandleProgress();\n   183→        setCandleProgress(progress);\n   184→\n   185→        // Interpolate current price\n   186→        const { open, high, low, close } = candle;\n   187→        const isBullish = close > open;\n   188→\n   189→        let price: number;\n   190→        if (isBullish) {\n   191→          if (progress < 0.2) {\n   192→            price = open + (low - open) * (progress / 0.2) * 0.7;\n   193→          } else if (progress < 0.7) {\n   194→            const lowPoint = open + (low - open) * 0.7;\n   195→            price = lowPoint + (high - lowPoint) * ((progress - 0.2) / 0.5);\n   196→          } else {\n   197→            price = high + (close - high) * ((progress - 0.7) / 0.3);\n   198→          }\n   199→        } else {\n   200→          if (progress < 0.2) {\n   201→            price = open + (high - open) * (progress / 0.2) * 0.7;\n   202→          } else if (progress < 0.7) {\n   203→            const highPoint = open + (high - open) * 0.7;\n   204→            price = highPoint + (low - highPoint) * ((progress - 0.2) / 0.5);\n   205→          } else {\n   206→            price = low + (close - low) * ((progress - 0.7) / 0.3);\n   207→          }\n   208→        }\n   209→\n   210→        setCurrentPrice(price);\n   211→\n   212→        // Update candles: completed + current forming\n   213→        const completed = getRecentCandles(15);\n   214→        setRecentCandles([...completed, candle]);\n   215→      }\n   216→    }, 100);\n   217→\n   218→    return () => {\n   219→      unsubscribeRound();\n   220→      unsubscribeCompleted();\n   221→      clearInterval(pollInterval);\n   222→    };\n   223→  }, []);\n   224→\n   225→  // Update user history when address changes\n   226→  useEffect(() => {\n   227→    if (address) {\n   228→      const history = getUserHistory(address).sort(\n   229→        (a, b) => (b.round.resolvedAt ?? b.round.createdAt) - (a.round.resolvedAt ?? a.round.createdAt)\n   230→      );\n   231→      setUserHistory(history);\n   232→    } else {\n   233→      setUserHistory([]);\n   234→    }\n   235→  }, [address, currentRound?.phase]);\n   236→\n   237→  // Place bet action - accepts optional side override for direct button clicks\n   238→  const placeBet = useCallback(async (sideOverride?: BetSide) => {\n   239→    if (!address) {\n   240→      throw new Error(\"Wallet not connected\");\n   241→    }\n   242→\n   243→    const side = sideOverride ?? pendingSide;\n   244→    if (!side) {\n   245→      throw new Error(\"Select GREEN or RED\");\n   246→    }\n   247→\n   248→    if (pendingAmount < MIN_BET_AMOUNT) {\n   249→      throw new Error(`Minimum bet is $${MIN_BET_AMOUNT}`);\n   250→    }\n   251→\n   252→    if (pendingAmount > MAX_BET_AMOUNT) {\n   253→      throw new Error(`Maximum bet is $${MAX_BET_AMOUNT}`);\n   254→    }\n   255→\n   256→    const currentBalance = getBalance?.();\n   257→    if (currentBalance !== undefined && pendingAmount > currentBalance) {\n   258→      throw new Error(\"Insufficient balance\");\n   259→    }\n   260→\n   261→    setPlacingBet(true);\n   262→\n   263→    try {\n   264→      // Simulate transaction delay\n   265→      await new Promise((resolve) => setTimeout(resolve, 500));\n   266→\n   267→      mockPlaceBet(address, side, pendingAmount);\n   268→\n   269→      // Reset selection after bet\n   270→      setPendingSide(null);\n   271→    } finally {\n   272→      setPlacingBet(false);\n   273→    }\n   274→  }, [address, pendingSide, pendingAmount, getBalance]);\n   275→\n   276→  // Adjust bet amount\n   277→  const adjustBetAmount = useCallback(\n   278→    (adjustment: \"half\" | \"double\" | \"max\") => {\n   279→      let newAmount: number;\n   280→      const currentBalance = getBalance?.();\n   281→\n   282→      switch (adjustment) {\n   283→        case \"half\":\n   284→          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n   285→          break;\n   286→        case \"double\":\n   287→          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n   288→          break;\n   289→        case \"max\":\n   290→          newAmount = currentBalance !== undefined ? Math.min(currentBalance, MAX_BET_AMOUNT) : MAX_BET_AMOUNT;\n   291→          break;\n   292→      }\n   293→\n   294→      // Round to 4 decimal places\n   295→      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n   296→    },\n   297→    [pendingAmount, getBalance]\n   298→  );\n   299→\n   300→  // Refresh round data\n   301→  const refreshRound = useCallback(() => {\n   302→    const round = getCurrentRound();\n   303→    if (round) {\n   304→      setCurrentRound(round);\n   305→    }\n   306→    // Build candles: completed + current forming\n   307→    const completed = getRecentCandles(15);\n   308→    const current = getCurrentCandle();\n   309→    if (current) {\n   310→      setRecentCandles([...completed, current]);\n   311→    } else {\n   312→      setRecentCandles(completed);\n   313→    }\n   314→    setCarryoverJackpot(getCarryoverAmount());\n   315→  }, []);\n   316→\n   317→  // Claim payout for winning round\n   318→  const claimPayout = useCallback(async () => {\n   319→    if (!completedRound || !address) {\n   320→      throw new Error(\"No completed round to claim\");\n   321→    }\n   322→\n   323→    const isWinner = completedRound.winners?.includes(address);\n   324→    if (!isWinner) {\n   325→      throw new Error(\"You are not a winner\");\n   326→    }\n   327→\n   328→    setClaiming(true);\n   329→    try {\n   330→      // Simulate transaction delay\n   331→      await new Promise((resolve) => setTimeout(resolve, 1000));\n   332→\n   333→      // After claiming, clear the completed round\n   334→      setCompletedRound(null);\n   335→      mockClearCompletedRound();\n   336→    } finally {\n   337→      setClaiming(false);\n   338→    }\n   339→  }, [completedRound, address]);\n   340→\n   341→  // Clear completed round (after user dismisses result overlay)\n   342→  const clearCompletedRound = useCallback(() => {\n   343→    setCompletedRound(null);\n   344→    mockClearCompletedRound();\n   345→  }, []);\n   346→\n   347→  const contextValue: CloseCallContextValue = {\n   348→    currentRound,\n   349→    completedRound,\n   350→    recentCandles,\n   351→    currentPrice,\n   352→    candleProgress,\n   353→    userHistory,\n   354→    carryoverJackpot,\n   355→    pendingAmount,\n   356→    pendingSide,\n   357→    userBet,\n   358→    loading,\n   359→    placingBet,\n   360→    claiming,\n   361→    setPendingAmount,\n   362→    setPendingSide,\n   363→    placeBet,\n   364→    adjustBetAmount,\n   365→    claimPayout,\n   366→    clearCompletedRound,\n   367→    potentialPayout,\n   368→    userOdds,\n   369→    refreshRound,\n   370→  };\n   371→\n   372→  return (\n   373→    <CloseCallContext.Provider value={contextValue}>\n   374→      {children}\n   375→    </CloseCallContext.Provider>\n   376→  );\n   377→}\n   378→\n   379→export function useCloseCall(): CloseCallContextValue {\n   380→  const context = useContext(CloseCallContext);\n   381→  if (!context) {\n   382→    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n   383→  }\n   384→  return context;\n   385→}\n   386→"}]},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"95d02954-a378-4452-8787-73ea7d7b2a13","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/context/CloseCallContext.tsx","content":"import {\n  createContext,\n  useContext,\n  useState,\n  useEffect,\n  useCallback,\n  useMemo,\n  type ReactNode,\n} from \"react\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  UserRoundHistory,\n  CloseCallContextValue,\n} from \"../types\";\nimport {\n  DEFAULT_BET_AMOUNT,\n  MIN_BET_AMOUNT,\n  MAX_BET_AMOUNT,\n} from \"../types\";\nimport {\n  initializeGame,\n  subscribeToRound,\n  subscribeToCompletedRound,\n  placeBet as mockPlaceBet,\n  getCurrentRound,\n  getUserHistory,\n  getCarryoverAmount,\n  getRecentCandles,\n  getCurrentCandle,\n  getCandleProgress,\n  isGameInitialized,\n  clearCompletedRound as mockClearCompletedRound,\n} from \"../utils/mock-simulation\";\nimport { calculatePotentialPayout } from \"../utils/payout-calculator\";\n\n// Default context value\nconst defaultContextValue: CloseCallContextValue = {\n  currentRound: null,\n  completedRound: null,\n  recentCandles: [],\n  currentPrice: 0,\n  candleProgress: 0,\n  userHistory: [],\n  carryoverJackpot: 0,\n  pendingAmount: DEFAULT_BET_AMOUNT,\n  pendingSide: null,\n  userBet: null,\n  loading: true,\n  placingBet: false,\n  claiming: false,\n  setPendingAmount: () => {},\n  setPendingSide: () => {},\n  placeBet: async () => {},\n  adjustBetAmount: () => {},\n  claimPayout: async () => {},\n  clearCompletedRound: () => {},\n  potentialPayout: 0,\n  userOdds: 0,\n  refreshRound: () => {},\n};\n\nconst CloseCallContext = createContext<CloseCallContextValue>(defaultContextValue);\n\nexport function CloseCallProvider({ children }: { children: ReactNode }) {\n  const { address, getBalance } = useWallet();\n\n  // Round state\n  const [currentRound, setCurrentRound] = useState<Round | null>(null);\n  const [completedRound, setCompletedRound] = useState<Round | null>(null);\n  const [recentCandles, setRecentCandles] = useState<Candle[]>([]);\n  const [currentPrice, setCurrentPrice] = useState(0);\n  const [candleProgress, setCandleProgress] = useState(0);\n  const [carryoverJackpot, setCarryoverJackpot] = useState(0);\n\n  // User state\n  const [userHistory, setUserHistory] = useState<UserRoundHistory[]>([]);\n  const [pendingAmount, setPendingAmount] = useState(DEFAULT_BET_AMOUNT);\n  const [pendingSide, setPendingSide] = useState<BetSide | null>(null);\n\n  // Loading states\n  const [loading, setLoading] = useState(true);\n  const [placingBet, setPlacingBet] = useState(false);\n  const [claiming, setClaiming] = useState(false);\n\n  // Get user's bet in current round\n  const userBet = useMemo(() => {\n    if (!currentRound || !address) return null;\n\n    const allBets = [...currentRound.pool.greenBets, ...currentRound.pool.redBets];\n    return allBets.find((b) => b.address === address) ?? null;\n  }, [currentRound, address]);\n\n  // Calculate potential payout\n  const potentialPayout = useMemo(() => {\n    if (!currentRound) return 0;\n\n    // If user has an active bet, calculate payout based on their bet\n    if (userBet) {\n      return calculatePotentialPayout(\n        userBet.amount,\n        userBet.side,\n        currentRound.pool,\n        currentRound.carryoverAmount\n      );\n    }\n\n    // Otherwise show preview based on pending selection\n    if (!pendingSide || pendingAmount <= 0) return 0;\n\n    return calculatePotentialPayout(\n      pendingAmount,\n      pendingSide,\n      currentRound.pool,\n      currentRound.carryoverAmount\n    );\n  }, [pendingAmount, pendingSide, currentRound, userBet]);\n\n  // Calculate user's odds (share of winning pool)\n  const userOdds = useMemo(() => {\n    if (!userBet || !currentRound) return 0;\n\n    const winningPool =\n      userBet.side === \"green\"\n        ? currentRound.pool.greenPool\n        : currentRound.pool.redPool;\n\n    if (winningPool === 0) return 0;\n\n    return (userBet.amount / winningPool) * 100;\n  }, [userBet, currentRound]);\n\n  // Initialize game on mount\n  useEffect(() => {\n    if (!isGameInitialized()) {\n      initializeGame();\n    }\n\n    // Set initial state\n    const round = getCurrentRound();\n    if (round) {\n      setCurrentRound(round);\n    }\n\n    // Build candles array: completed candles + current forming candle\n    const completedCandles = getRecentCandles(15);\n    const currentCandle = getCurrentCandle();\n    if (currentCandle) {\n      setRecentCandles([...completedCandles, currentCandle]);\n    } else {\n      setRecentCandles(completedCandles);\n    }\n    setCarryoverJackpot(getCarryoverAmount());\n    setLoading(false);\n\n    // Subscribe to round updates\n    const unsubscribeRound = subscribeToRound((round) => {\n      setCurrentRound(round);\n      setCarryoverJackpot(getCarryoverAmount());\n\n      // Update candles: completed + current forming\n      const completed = getRecentCandles(15);\n      const current = getCurrentCandle();\n      if (current) {\n        setRecentCandles([...completed, current]);\n      } else {\n        setRecentCandles(completed);\n      }\n    });\n\n    // Subscribe to completed round updates\n    const unsubscribeCompleted = subscribeToCompletedRound((round) => {\n      setCompletedRound(round);\n    });\n\n    // Poll for price/progress updates\n    const pollInterval = setInterval(() => {\n      const candle = getCurrentCandle();\n      if (candle) {\n        const progress = getCandleProgress();\n        setCandleProgress(progress);\n\n        // Interpolate current price\n        const { open, high, low, close } = candle;\n        const isBullish = close > open;\n\n        let price: number;\n        if (isBullish) {\n          if (progress < 0.2) {\n            price = open + (low - open) * (progress / 0.2) * 0.7;\n          } else if (progress < 0.7) {\n            const lowPoint = open + (low - open) * 0.7;\n            price = lowPoint + (high - lowPoint) * ((progress - 0.2) / 0.5);\n          } else {\n            price = high + (close - high) * ((progress - 0.7) / 0.3);\n          }\n        } else {\n          if (progress < 0.2) {\n            price = open + (high - open) * (progress / 0.2) * 0.7;\n          } else if (progress < 0.7) {\n            const highPoint = open + (high - open) * 0.7;\n            price = highPoint + (low - highPoint) * ((progress - 0.2) / 0.5);\n          } else {\n            price = low + (close - low) * ((progress - 0.7) / 0.3);\n          }\n        }\n\n        setCurrentPrice(price);\n\n        // Update candles: completed + current forming\n        const completed = getRecentCandles(15);\n        setRecentCandles([...completed, candle]);\n      }\n    }, 100);\n\n    return () => {\n      unsubscribeRound();\n      unsubscribeCompleted();\n      clearInterval(pollInterval);\n    };\n  }, []);\n\n  // Update user history when address changes\n  useEffect(() => {\n    if (address) {\n      const history = getUserHistory(address).sort(\n        (a, b) => (b.round.resolvedAt ?? b.round.createdAt) - (a.round.resolvedAt ?? a.round.createdAt)\n      );\n      setUserHistory(history);\n    } else {\n      setUserHistory([]);\n    }\n  }, [address, currentRound?.phase]);\n\n  // Place bet action - accepts optional side override for direct button clicks\n  const placeBet = useCallback(async (sideOverride?: BetSide) => {\n    if (!address) {\n      throw new Error(\"Wallet not connected\");\n    }\n\n    const side = sideOverride ?? pendingSide;\n    if (!side) {\n      throw new Error(\"Select GREEN or RED\");\n    }\n\n    if (pendingAmount < MIN_BET_AMOUNT) {\n      throw new Error(`Minimum bet is $${MIN_BET_AMOUNT}`);\n    }\n\n    if (pendingAmount > MAX_BET_AMOUNT) {\n      throw new Error(`Maximum bet is $${MAX_BET_AMOUNT}`);\n    }\n\n    const currentBalance = getBalance?.();\n    if (currentBalance !== undefined && pendingAmount > currentBalance) {\n      throw new Error(\"Insufficient balance\");\n    }\n\n    setPlacingBet(true);\n\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 500));\n\n      mockPlaceBet(address, side, pendingAmount);\n\n      // Reset selection after bet\n      setPendingSide(null);\n    } finally {\n      setPlacingBet(false);\n    }\n  }, [address, pendingSide, pendingAmount, getBalance]);\n\n  // Adjust bet amount\n  const adjustBetAmount = useCallback(\n    (adjustment: \"half\" | \"double\" | \"max\") => {\n      let newAmount: number;\n      const currentBalance = getBalance?.();\n\n      switch (adjustment) {\n        case \"half\":\n          newAmount = Math.max(MIN_BET_AMOUNT, pendingAmount / 2);\n          break;\n        case \"double\":\n          newAmount = Math.min(MAX_BET_AMOUNT, pendingAmount * 2);\n          break;\n        case \"max\":\n          newAmount = currentBalance !== undefined ? Math.min(currentBalance, MAX_BET_AMOUNT) : MAX_BET_AMOUNT;\n          break;\n      }\n\n      // Round to 4 decimal places\n      setPendingAmount(Math.round(newAmount * 10000) / 10000);\n    },\n    [pendingAmount, getBalance]\n  );\n\n  // Refresh round data\n  const refreshRound = useCallback(() => {\n    const round = getCurrentRound();\n    if (round) {\n      setCurrentRound(round);\n    }\n    // Build candles: completed + current forming\n    const completed = getRecentCandles(15);\n    const current = getCurrentCandle();\n    if (current) {\n      setRecentCandles([...completed, current]);\n    } else {\n      setRecentCandles(completed);\n    }\n    setCarryoverJackpot(getCarryoverAmount());\n  }, []);\n\n  // Claim payout for winning round\n  const claimPayout = useCallback(async () => {\n    if (!completedRound || !address) {\n      throw new Error(\"No completed round to claim\");\n    }\n\n    const isWinner = completedRound.winners?.includes(address);\n    if (!isWinner) {\n      throw new Error(\"You are not a winner\");\n    }\n\n    setClaiming(true);\n    try {\n      // Simulate transaction delay\n      await new Promise((resolve) => setTimeout(resolve, 1000));\n\n      // After claiming, clear the completed round\n      setCompletedRound(null);\n      mockClearCompletedRound();\n    } finally {\n      setClaiming(false);\n    }\n  }, [completedRound, address]);\n\n  // Clear completed round (after user dismisses result overlay)\n  const clearCompletedRound = useCallback(() => {\n    setCompletedRound(null);\n    mockClearCompletedRound();\n  }, []);\n\n  const contextValue: CloseCallContextValue = {\n    currentRound,\n    completedRound,\n    recentCandles,\n    currentPrice,\n    candleProgress,\n    userHistory,\n    carryoverJackpot,\n    pendingAmount,\n    pendingSide,\n    userBet,\n    loading,\n    placingBet,\n    claiming,\n    setPendingAmount,\n    setPendingSide,\n    placeBet,\n    adjustBetAmount,\n    claimPayout,\n    clearCompletedRound,\n    potentialPayout,\n    userOdds,\n    refreshRound,\n  };\n\n  return (\n    <CloseCallContext.Provider value={contextValue}>\n      {children}\n    </CloseCallContext.Provider>\n  );\n}\n\nexport function useCloseCall(): CloseCallContextValue {\n  const context = useContext(CloseCallContext);\n  if (!context) {\n    throw new Error(\"useCloseCall must be used within a CloseCallProvider\");\n  }\n  return context;\n}\n","numLines":386,"startLine":1,"totalLines":386}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_016MP8qzyUodWCG5e7PW7Gas","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Jv5BtK7znYQSkvsbhcTQDZ","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/utils/payout-calculator.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4927,"cache_read_input_tokens":46476,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4927},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"260d1a11-33a0-4c73-a626-31edc7e89b8e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jv5BtK7znYQSkvsbhcTQDZ","type":"tool_result","content":"     1→/**\n     2→ * Pari-Mutuel Payout Calculator for Close Call\n     3→ *\n     4→ * Formula:\n     5→ *   totalPool = greenPool + redPool + carryoverPool\n     6→ *   netPool = totalPool × 0.97 (3% fee)\n     7→ *   playerPayout = (playerBet / winningPool) × netPool\n     8→ */\n     9→\n    10→import type { BetSide, CandleOutcome, Candle, PoolState } from \"../types\";\n    11→import { PLATFORM_FEE, DOJI_THRESHOLD_BPS } from \"../types\";\n    12→\n    13→export interface PayoutResult {\n    14→  winner: BetSide | null;\n    15→  payouts: Record<string, number>;\n    16→  totalPayout: number;\n    17→  platformFee: number;\n    18→  carryoverToNext: number;\n    19→}\n    20→\n    21→/**\n    22→ * Determine the outcome of a candle\n    23→ */\n    24→export function determineOutcome(candle: Candle): CandleOutcome {\n    25→  const diff = candle.close - candle.open;\n    26→  const threshold = candle.open * (DOJI_THRESHOLD_BPS / 10000);\n    27→\n    28→  if (Math.abs(diff) <= threshold) {\n    29→    return \"doji\";\n    30→  }\n    31→\n    32→  return diff > 0 ? \"green\" : \"red\";\n    33→}\n    34→\n    35→/**\n    36→ * Calculate payouts for all winners\n    37→ */\n    38→export function calculatePayouts(\n    39→  pool: PoolState,\n    40→  outcome: CandleOutcome,\n    41→  carryoverAmount: number = 0\n    42→): PayoutResult {\n    43→  const totalPool = pool.totalPool + carryoverAmount;\n    44→\n    45→  // Handle DOJI - no winners, pool carries over\n    46→  if (outcome === \"doji\") {\n    47→    const fee = pool.totalPool * PLATFORM_FEE;\n    48→    return {\n    49→      winner: null,\n    50→      payouts: {},\n    51→      totalPayout: 0,\n    52→      platformFee: fee,\n    53→      carryoverToNext: totalPool - fee,\n    54→    };\n    55→  }\n    56→\n    57→  // Determine winning side\n    58→  const winner: BetSide = outcome;\n    59→  const winningBets = outcome === \"green\" ? pool.greenBets : pool.redBets;\n    60→  const winningPool = outcome === \"green\" ? pool.greenPool : pool.redPool;\n    61→\n    62→  // Handle edge case: no bets on winning side\n    63→  if (winningPool === 0 || winningBets.length === 0) {\n    64→    // All funds carry over (minus fee on current round bets)\n    65→    const fee = pool.totalPool * PLATFORM_FEE;\n    66→    return {\n    67→      winner,\n    68→      payouts: {},\n    69→      totalPayout: 0,\n    70→      platformFee: fee,\n    71→      carryoverToNext: totalPool - fee,\n    72→    };\n    73→  }\n    74→\n    75→  // Calculate platform fee (only on current round's bets, not carryover)\n    76→  const platformFee = pool.totalPool * PLATFORM_FEE;\n    77→  const netPool = totalPool - platformFee;\n    78→\n    79→  // Calculate individual payouts\n    80→  const payouts: Record<string, number> = {};\n    81→  let totalPayout = 0;\n    82→\n    83→  for (const bet of winningBets) {\n    84→    const share = bet.amount / winningPool;\n    85→    const payout = netPool * share;\n    86→    payouts[bet.address] = payout;\n    87→    totalPayout += payout;\n    88→  }\n    89→\n    90→  return {\n    91→    winner,\n    92→    payouts,\n    93→    totalPayout,\n    94→    platformFee,\n    95→    carryoverToNext: 0,\n    96→  };\n    97→}\n    98→\n    99→/**\n   100→ * Calculate potential payout for a hypothetical bet\n   101→ */\n   102→export function calculatePotentialPayout(\n   103→  betAmount: number,\n   104→  betSide: BetSide,\n   105→  pool: PoolState,\n   106→  carryoverAmount: number = 0\n   107→): number {\n   108→  // Calculate what the pool would look like with this bet\n   109→  const newWinningPool =\n   110→    betSide === \"green\" ? pool.greenPool + betAmount : pool.redPool + betAmount;\n   111→  const newTotalPool = pool.totalPool + betAmount + carryoverAmount;\n   112→  const netPool = newTotalPool * (1 - PLATFORM_FEE);\n   113→\n   114→  // Player's share of winning pool\n   115→  const share = betAmount / newWinningPool;\n   116→\n   117→  return netPool * share;\n   118→}\n   119→\n   120→/**\n   121→ * Calculate odds multiplier for a side\n   122→ * Returns how much $1 would win (e.g., 2.0 means double your money)\n   123→ */\n   124→export function calculateOddsMultiplier(\n   125→  side: BetSide,\n   126→  pool: PoolState,\n   127→  carryoverAmount: number = 0\n   128→): number {\n   129→  const winningPool = side === \"green\" ? pool.greenPool : pool.redPool;\n   130→  const totalPool = pool.totalPool + carryoverAmount;\n   131→\n   132→  if (winningPool === 0 || totalPool === 0) {\n   133→    return 0;\n   134→  }\n   135→\n   136→  const netPool = totalPool * (1 - PLATFORM_FEE);\n   137→  return netPool / winningPool;\n   138→}\n   139→\n   140→/**\n   141→ * Calculate percentage of pool on each side\n   142→ */\n   143→export function calculatePoolDistribution(pool: PoolState): {\n   144→  greenPercent: number;\n   145→  redPercent: number;\n   146→} {\n   147→  if (pool.totalPool === 0) {\n   148→    return { greenPercent: 50, redPercent: 50 };\n   149→  }\n   150→\n   151→  return {\n   152→    greenPercent: (pool.greenPool / pool.totalPool) * 100,\n   153→    redPercent: (pool.redPool / pool.totalPool) * 100,\n   154→  };\n   155→}\n   156→\n   157→/**\n   158→ * Format amount for display\n   159→ */\n   160→export function formatAmount(amount: number, decimals: number = 4): string {\n   161→  return amount.toFixed(decimals);\n   162→}\n   163→\n   164→/**\n   165→ * Format USD amount for display\n   166→ */\n   167→export function formatUsd(amount: number): string {\n   168→  return amount.toLocaleString(\"en-US\", {\n   169→    style: \"currency\",\n   170→    currency: \"USD\",\n   171→    minimumFractionDigits: 2,\n   172→    maximumFractionDigits: 2,\n   173→  });\n   174→}\n   175→"}]},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"24def2b5-3599-47ac-b335-b586c0fb6235","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/utils/payout-calculator.ts","content":"/**\n * Pari-Mutuel Payout Calculator for Close Call\n *\n * Formula:\n *   totalPool = greenPool + redPool + carryoverPool\n *   netPool = totalPool × 0.97 (3% fee)\n *   playerPayout = (playerBet / winningPool) × netPool\n */\n\nimport type { BetSide, CandleOutcome, Candle, PoolState } from \"../types\";\nimport { PLATFORM_FEE, DOJI_THRESHOLD_BPS } from \"../types\";\n\nexport interface PayoutResult {\n  winner: BetSide | null;\n  payouts: Record<string, number>;\n  totalPayout: number;\n  platformFee: number;\n  carryoverToNext: number;\n}\n\n/**\n * Determine the outcome of a candle\n */\nexport function determineOutcome(candle: Candle): CandleOutcome {\n  const diff = candle.close - candle.open;\n  const threshold = candle.open * (DOJI_THRESHOLD_BPS / 10000);\n\n  if (Math.abs(diff) <= threshold) {\n    return \"doji\";\n  }\n\n  return diff > 0 ? \"green\" : \"red\";\n}\n\n/**\n * Calculate payouts for all winners\n */\nexport function calculatePayouts(\n  pool: PoolState,\n  outcome: CandleOutcome,\n  carryoverAmount: number = 0\n): PayoutResult {\n  const totalPool = pool.totalPool + carryoverAmount;\n\n  // Handle DOJI - no winners, pool carries over\n  if (outcome === \"doji\") {\n    const fee = pool.totalPool * PLATFORM_FEE;\n    return {\n      winner: null,\n      payouts: {},\n      totalPayout: 0,\n      platformFee: fee,\n      carryoverToNext: totalPool - fee,\n    };\n  }\n\n  // Determine winning side\n  const winner: BetSide = outcome;\n  const winningBets = outcome === \"green\" ? pool.greenBets : pool.redBets;\n  const winningPool = outcome === \"green\" ? pool.greenPool : pool.redPool;\n\n  // Handle edge case: no bets on winning side\n  if (winningPool === 0 || winningBets.length === 0) {\n    // All funds carry over (minus fee on current round bets)\n    const fee = pool.totalPool * PLATFORM_FEE;\n    return {\n      winner,\n      payouts: {},\n      totalPayout: 0,\n      platformFee: fee,\n      carryoverToNext: totalPool - fee,\n    };\n  }\n\n  // Calculate platform fee (only on current round's bets, not carryover)\n  const platformFee = pool.totalPool * PLATFORM_FEE;\n  const netPool = totalPool - platformFee;\n\n  // Calculate individual payouts\n  const payouts: Record<string, number> = {};\n  let totalPayout = 0;\n\n  for (const bet of winningBets) {\n    const share = bet.amount / winningPool;\n    const payout = netPool * share;\n    payouts[bet.address] = payout;\n    totalPayout += payout;\n  }\n\n  return {\n    winner,\n    payouts,\n    totalPayout,\n    platformFee,\n    carryoverToNext: 0,\n  };\n}\n\n/**\n * Calculate potential payout for a hypothetical bet\n */\nexport function calculatePotentialPayout(\n  betAmount: number,\n  betSide: BetSide,\n  pool: PoolState,\n  carryoverAmount: number = 0\n): number {\n  // Calculate what the pool would look like with this bet\n  const newWinningPool =\n    betSide === \"green\" ? pool.greenPool + betAmount : pool.redPool + betAmount;\n  const newTotalPool = pool.totalPool + betAmount + carryoverAmount;\n  const netPool = newTotalPool * (1 - PLATFORM_FEE);\n\n  // Player's share of winning pool\n  const share = betAmount / newWinningPool;\n\n  return netPool * share;\n}\n\n/**\n * Calculate odds multiplier for a side\n * Returns how much $1 would win (e.g., 2.0 means double your money)\n */\nexport function calculateOddsMultiplier(\n  side: BetSide,\n  pool: PoolState,\n  carryoverAmount: number = 0\n): number {\n  const winningPool = side === \"green\" ? pool.greenPool : pool.redPool;\n  const totalPool = pool.totalPool + carryoverAmount;\n\n  if (winningPool === 0 || totalPool === 0) {\n    return 0;\n  }\n\n  const netPool = totalPool * (1 - PLATFORM_FEE);\n  return netPool / winningPool;\n}\n\n/**\n * Calculate percentage of pool on each side\n */\nexport function calculatePoolDistribution(pool: PoolState): {\n  greenPercent: number;\n  redPercent: number;\n} {\n  if (pool.totalPool === 0) {\n    return { greenPercent: 50, redPercent: 50 };\n  }\n\n  return {\n    greenPercent: (pool.greenPool / pool.totalPool) * 100,\n    redPercent: (pool.redPool / pool.totalPool) * 100,\n  };\n}\n\n/**\n * Format amount for display\n */\nexport function formatAmount(amount: number, decimals: number = 4): string {\n  return amount.toFixed(decimals);\n}\n\n/**\n * Format USD amount for display\n */\nexport function formatUsd(amount: number): string {\n  return amount.toLocaleString(\"en-US\", {\n    style: \"currency\",\n    currency: \"USD\",\n    minimumFractionDigits: 2,\n    maximumFractionDigits: 2,\n  });\n}\n","numLines":175,"startLine":1,"totalLines":175}}}
