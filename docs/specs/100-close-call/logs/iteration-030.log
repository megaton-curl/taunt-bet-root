{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X1y6ZNSy48StanYDmNj2fX","type":"tool_result","content":"     1→/**\n     2→ * Mock Simulation for Close Call\n     3→ *\n     4→ * Manages round lifecycle, betting, and settlement in mock mode.\n     5→ */\n     6→\n     7→import type {\n     8→  Round,\n     9→  BetSide,\n    10→  Candle,\n    11→  PlayerBet,\n    12→  PoolState,\n    13→  UserRoundHistory,\n    14→} from \"../types\";\n    15→import { BETTING_WINDOW_MS, MIN_BET_AMOUNT, MAX_BET_AMOUNT } from \"../types\";\n    16→import { getReplayEngine, type CandleReplayEngine } from \"./candle-replay\";\n    17→import { calculatePayouts, determineOutcome } from \"./payout-calculator\";\n    18→import { emitCloseCallComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\n    19→import { emitCloseCallResults } from \"../../player-profile/utils/profile-event-bus\";\n    20→\n    21→// ============ Store ============\n    22→\n    23→interface MockStore {\n    24→  currentRound: Round | null;\n    25→  completedRound: Round | null; // Most recently completed round (for result display)\n    26→  roundHistory: Round[];\n    27→  userHistory: Map<string, UserRoundHistory[]>;\n    28→  listeners: Set<(round: Round) => void>;\n    29→  completedListeners: Set<(round: Round) => void>;\n    30→  carryoverAmount: number;\n    31→  replayEngine: CandleReplayEngine | null;\n    32→  serverSeeds: Map<string, { serverSeed: string; blockHash: string }>;\n    33→  mockBetTimers: ReturnType<typeof setTimeout>[];\n    34→  isInitialized: boolean;\n    35→}\n    36→\n    37→const store: MockStore = {\n    38→  currentRound: null,\n    39→  completedRound: null,\n    40→  roundHistory: [],\n    41→  userHistory: new Map(),\n    42→  listeners: new Set(),\n    43→  completedListeners: new Set(),\n    44→  carryoverAmount: 0,\n    45→  replayEngine: null,\n    46→  serverSeeds: new Map(),\n    47→  mockBetTimers: [],\n    48→  isInitialized: false,\n    49→};\n    50→\n    51→// ============ Fairness Data ============\n    52→\n    53→// Generate a mock hex string (simulates SHA-256 hash or seed)\n    54→function generateMockHexString(length: number = 64): string {\n    55→  const chars = \"0123456789abcdef\";\n    56→  let result = \"\";\n    57→  for (let i = 0; i < length; i++) {\n    58→    result += chars[Math.floor(Math.random() * chars.length)];\n    59→  }\n    60→  return result;\n    61→}\n    62→\n    63→function generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string } {\n    64→  const serverSeed = generateMockHexString(64); // 256-bit seed\n    65→  const seedHash = generateMockHexString(64);   // SHA-256 hash of server seed\n    66→  const blockHash = generateMockHexString(64);  // Block hash\n    67→\n    68→  return { seedHash, serverSeed, blockHash };\n    69→}\n    70→\n    71→function generateRoundId(): string {\n    72→  return `cc-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n    73→}\n    74→\n    75→// ============ Mock Address Generation ============\n    76→\n    77→const MOCK_ADDRESSES = [\n    78→  \"7xKQ...nM4p\", \"3vBr...8sYq\", \"9aZm...kL2x\", \"5hTn...jR7w\",\n    79→  \"2cVp...9fGd\", \"8kLm...4nHs\", \"1qWe...6bYt\", \"4rTy...0mXz\",\n    80→  \"6uIo...2pAw\", \"0oKj...5nBv\", \"Ax7K...mN3p\", \"Bv8L...nO4q\",\n    81→  \"Cw9M...oP5r\", \"Dx0N...pQ6s\", \"Ey1O...qR7t\", \"Fz2P...rS8u\",\n    82→];\n    83→\n    84→function generateMockAddress(): string {\n    85→  const index = Math.floor(Math.random() * MOCK_ADDRESSES.length);\n    86→  return MOCK_ADDRESSES[index]!;\n    87→}\n    88→\n    89→// ============ Round Management ============\n    90→\n    91→function createEmptyPool(): PoolState {\n    92→  return {\n    93→    greenPool: 0,\n    94→    redPool: 0,\n    95→    totalPool: 0,\n    96→    playerCount: 0,\n    97→    greenBets: [],\n    98→    redBets: [],\n    99→  };\n   100→}\n   101→\n   102→function createNewRound(targetCandleTime: number): Round {\n   103→  const fairnessData = generateFairnessData();\n   104→  const roundId = generateRoundId();\n   105→\n   106→  store.serverSeeds.set(roundId, {\n   107→    serverSeed: fairnessData.serverSeed,\n   108→    blockHash: fairnessData.blockHash,\n   109→  });\n   110→\n   111→  const round: Round = {\n   112→    id: roundId,\n   113→    phase: \"betting\",\n   114→    pool: createEmptyPool(),\n   115→    createdAt: Date.now(),\n   116→    bettingEndsAt: Date.now() + BETTING_WINDOW_MS, // Betting window is first 10 seconds\n   117→    targetCandleTime,\n   118→    carryoverAmount: store.carryoverAmount,\n   119→    seedHash: fairnessData.seedHash,\n   120→  };\n   121→\n   122→  store.currentRound = round;\n   123→  notifyListeners(round);\n   124→\n   125→  // Schedule mock bets\n   126→  scheduleMockBets(round.id);\n   127→\n   128→  return round;\n   129→}\n   130→\n   131→function lockRound(): void {\n   132→  if (!store.currentRound) return;\n   133→  if (store.currentRound.phase !== \"betting\") return;\n   134→\n   135→  store.currentRound.phase = \"locked\";\n   136→  notifyListeners(store.currentRound);\n   137→\n   138→  // Clear any pending mock bet timers\n   139→  clearMockBetTimers();\n   140→}\n   141→\n   142→function resolveRound(resultCandle: Candle): void {\n   143→  if (!store.currentRound) return;\n   144→  if (store.currentRound.phase !== \"locked\") return;\n   145→\n   146→  const round = store.currentRound;\n   147→  round.phase = \"resolving\";\n   148→  round.resultCandle = resultCandle;\n   149→  notifyListeners(round);\n   150→\n   151→  // Determine outcome\n   152→  const outcome = determineOutcome(resultCandle);\n   153→  round.outcome = outcome;\n   154→\n   155→  // Reveal server seed\n   156→  const secrets = store.serverSeeds.get(round.id);\n   157→  if (secrets) {\n   158→    round.serverSeed = secrets.serverSeed;\n   159→    round.blockHash = secrets.blockHash;\n   160→  }\n   161→\n   162→  // Calculate payouts\n   163→  const payoutResult = calculatePayouts(round.pool, outcome, round.carryoverAmount);\n   164→  round.winners = Object.keys(payoutResult.payouts);\n   165→  round.payouts = payoutResult.payouts;\n   166→  round.payoutAmount = payoutResult.totalPayout;\n   167→\n   168→  // Update carryover for next round\n   169→  store.carryoverAmount = payoutResult.carryoverToNext;\n   170→\n   171→  // Complete the round immediately (don't wait - new round may have started)\n   172→  round.phase = \"complete\";\n   173→  round.resolvedAt = Date.now();\n   174→\n   175→  // Store as completed round for result display\n   176→  store.completedRound = { ...round, pool: { ...round.pool } };\n   177→\n   178→  // Archive round\n   179→  store.roundHistory.unshift(round);\n   180→\n   181→  // Update user histories\n   182→  updateUserHistories(round);\n   183→\n   184→  // Clean up server seed\n   185→  store.serverSeeds.delete(round.id);\n   186→\n   187→  // Notify completed round listeners\n   188→  notifyCompletedListeners(store.completedRound);\n   189→\n   190→  // Emit event for Boss Raid\n   191→  const allBets = [...round.pool.greenBets, ...round.pool.redBets].map((b) => ({\n   192→    address: b.address,\n   193→    amount: b.amount,\n   194→  }));\n   195→  if (allBets.length > 0) {\n   196→    emitCloseCallComplete(round.id, allBets);\n   197→  }\n   198→\n   199→  // Emit event for Player Profile (XP and stats tracking)\n   200→  const profileResults = [...round.pool.greenBets, ...round.pool.redBets].map((bet) => {\n   201→    const payout = round.payouts?.[bet.address] ?? 0;\n   202→    const won = payout > 0;\n   203→    return {\n   204→      address: bet.address,\n   205→      wager: bet.amount,\n   206→      outcome: (won ? \"win\" : \"loss\") as \"win\" | \"loss\",\n   207→      payout,\n   208→    };\n   209→  });\n   210→  if (profileResults.length > 0) {\n   211→    emitCloseCallResults(round.id, profileResults);\n   212→  }\n   213→}\n   214→\n   215→function updateUserHistories(round: Round): void {\n   216→  const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n   217→\n   218→  for (const bet of allBets) {\n   219→    const payout = round.payouts?.[bet.address] ?? 0;\n   220→    const won = payout > 0;\n   221→\n   222→    const historyEntry: UserRoundHistory = {\n   223→      round,\n   224→      userBet: bet,\n   225→      payout,\n   226→      won,\n   227→    };\n   228→\n   229→    const userHistory = store.userHistory.get(bet.address) ?? [];\n   230→    userHistory.unshift(historyEntry);\n   231→    store.userHistory.set(bet.address, userHistory);\n   232→  }\n   233→}\n   234→\n   235→// ============ Betting ============\n   236→\n   237→export function placeBet(playerAddress: string, side: BetSide, amount: number): Round {\n   238→  const round = store.currentRound;\n   239→\n   240→  if (!round) {\n   241→    throw new Error(\"No active round\");\n   242→  }\n   243→\n   244→  if (round.phase !== \"betting\") {\n   245→    throw new Error(\"Betting is closed for this round\");\n   246→  }\n   247→\n   248→  if (amount < MIN_BET_AMOUNT) {\n   249→    throw new Error(`Minimum bet is $${MIN_BET_AMOUNT}`);\n   250→  }\n   251→\n   252→  if (amount > MAX_BET_AMOUNT) {\n   253→    throw new Error(`Maximum bet is $${MAX_BET_AMOUNT}`);\n   254→  }\n   255→\n   256→  // Check for existing bet\n   257→  const existingBet = [...round.pool.greenBets, ...round.pool.redBets].find(\n   258→    (b) => b.address === playerAddress\n   259→  );\n   260→\n   261→  if (existingBet) {\n   262→    throw new Error(\"You have already bet on this round\");\n   263→  }\n   264→\n   265→  // Create bet\n   266→  const bet: PlayerBet = {\n   267→    address: playerAddress,\n   268→    side,\n   269→    amount,\n   270→    timestamp: Date.now(),\n   271→  };\n   272→\n   273→  // Add to pool\n   274→  if (side === \"green\") {\n   275→    round.pool.greenBets.push(bet);\n   276→    round.pool.greenPool += amount;\n   277→  } else {\n   278→    round.pool.redBets.push(bet);\n   279→    round.pool.redPool += amount;\n   280→  }\n   281→\n   282→  round.pool.totalPool += amount;\n   283→  round.pool.playerCount++;\n   284→\n   285→  // Emit wager placed event (triggers RNG buff chest drop check)\n   286→  emitWagerPlaced(\"close-call\", round.id, playerAddress, amount);\n   287→\n   288→  notifyListeners(round);\n   289→  return round;\n   290→}\n   291→\n   292→// ============ Mock Bets ============\n   293→\n   294→function scheduleMockBets(roundId: string): void {\n   295→  clearMockBetTimers();\n   296→\n   297→  // Schedule 3-7 mock bets within the 10 second betting window\n   298→  const betCount = 3 + Math.floor(Math.random() * 5);\n   299→  const bettingDuration = BETTING_WINDOW_MS - 1000; // Leave 1s buffer before lock\n   300→\n   301→  for (let i = 0; i < betCount; i++) {\n   302→    const delay = Math.random() * bettingDuration;\n   303→    const timer = setTimeout(() => {\n   304→      if (store.currentRound?.id !== roundId) return;\n   305→      if (store.currentRound?.phase !== \"betting\") return;\n   306→\n   307→      addMockBet();\n   308→    }, delay);\n   309→\n   310→    store.mockBetTimers.push(timer);\n   311→  }\n   312→}\n   313→\n   314→function addMockBet(): void {\n   315→  if (!store.currentRound || store.currentRound.phase !== \"betting\") return;\n   316→\n   317→  const address = generateMockAddress();\n   318→\n   319→  // Check if this mock address already bet\n   320→  const existingBet = [\n   321→    ...store.currentRound.pool.greenBets,\n   322→    ...store.currentRound.pool.redBets,\n   323→  ].find((b) => b.address === address);\n   324→\n   325→  if (existingBet) return;\n   326→\n   327→  // Random side (slightly biased toward current minority for balance)\n   328→  const greenRatio =\n   329→    store.currentRound.pool.totalPool > 0\n   330→      ? store.currentRound.pool.greenPool / store.currentRound.pool.totalPool\n   331→      : 0.5;\n   332→\n   333→  // Bias toward minority side for more balanced pools\n   334→  const greenProbability = greenRatio < 0.5 ? 0.6 : 0.4;\n   335→  const side: BetSide = Math.random() < greenProbability ? \"green\" : \"red\";\n   336→\n   337→  // Random amount (weighted toward smaller bets)\n   338→  const amount = Math.round((0.05 + Math.random() * Math.random() * 2) * 1000) / 1000;\n   339→\n   340→  try {\n   341→    placeBet(address, side, Math.max(MIN_BET_AMOUNT, amount));\n   342→  } catch {\n   343→    // Ignore bet errors for mock bets\n   344→  }\n   345→}\n   346→\n   347→function clearMockBetTimers(): void {\n   348→  for (const timer of store.mockBetTimers) {\n   349→    clearTimeout(timer);\n   350→  }\n   351→  store.mockBetTimers = [];\n   352→}\n   353→\n   354→// ============ Subscription ============\n   355→\n   356→function notifyListeners(round: Round): void {\n   357→  const roundCopy = { ...round, pool: { ...round.pool } };\n   358→  for (const listener of store.listeners) {\n   359→    try {\n   360→      listener(roundCopy);\n   361→    } catch (error) {\n   362→      console.error(\"Listener error:\", error);\n   363→    }\n   364→  }\n   365→}\n   366→\n   367→function notifyCompletedListeners(round: Round): void {\n   368→  const roundCopy = { ...round, pool: { ...round.pool } };\n   369→  for (const listener of store.completedListeners) {\n   370→    try {\n   371→      listener(roundCopy);\n   372→    } catch (error) {\n   373→      console.error(\"Completed listener error:\", error);\n   374→    }\n   375→  }\n   376→}\n   377→\n   378→export function subscribeToRound(callback: (round: Round) => void): () => void {\n   379→  store.listeners.add(callback);\n   380→\n   381→  // Immediately emit current round if exists\n   382→  if (store.currentRound) {\n   383→    callback({ ...store.currentRound, pool: { ...store.currentRound.pool } });\n   384→  }\n   385→\n   386→  return () => {\n   387→    store.listeners.delete(callback);\n   388→  };\n   389→}\n   390→\n   391→export function subscribeToCompletedRound(callback: (round: Round) => void): () => void {\n   392→  store.completedListeners.add(callback);\n   393→\n   394→  return () => {\n   395→    store.completedListeners.delete(callback);\n   396→  };\n   397→}\n   398→\n   399→// ============ Game Initialization ============\n   400→\n   401→export function initializeGame(): void {\n   402→  if (store.isInitialized) return;\n   403→\n   404→  store.replayEngine = getReplayEngine();\n   405→\n   406→  store.replayEngine.start({\n   407→    onCandleStart: (candle) => {\n   408→      // Resolve any pending round from previous candle\n   409→      if (store.currentRound?.phase === \"locked\" && store.currentRound.resultCandle) {\n   410→        // Already resolved via onCandleComplete\n   411→      }\n   412→\n   413→      // Create new round - users bet on THIS candle's outcome\n   414→      createNewRound(candle.openTime);\n   415→    },\n   416→\n   417→    onCandleComplete: (candle) => {\n   418→      // Resolve current round when candle closes\n   419→      if (store.currentRound?.phase === \"locked\") {\n   420→        resolveRound(candle);\n   421→      } else if (store.currentRound?.phase === \"betting\") {\n   422→        // If still in betting (shouldn't happen), lock first then resolve\n   423→        lockRound();\n   424→        resolveRound(candle);\n   425→      }\n   426→    },\n   427→\n   428→    onPriceTick: () => {\n   429→      // Auto-lock after 10 second betting window\n   430→      if (store.currentRound?.phase === \"betting\") {\n   431→        if (Date.now() >= store.currentRound.bettingEndsAt) {\n   432→          lockRound();\n   433→        }\n   434→      }\n   435→    },\n   436→  });\n   437→\n   438→  store.isInitialized = true;\n   439→}\n   440→\n   441→export function stopGame(): void {\n   442→  if (store.replayEngine) {\n   443→    store.replayEngine.stop();\n   444→  }\n   445→  clearMockBetTimers();\n   446→  store.isInitialized = false;\n   447→}\n   448→\n   449→// ============ Getters ============\n   450→\n   451→export function getCurrentRound(): Round | null {\n   452→  return store.currentRound;\n   453→}\n   454→\n   455→export function getCompletedRound(): Round | null {\n   456→  return store.completedRound;\n   457→}\n   458→\n   459→export function clearCompletedRound(): void {\n   460→  store.completedRound = null;\n   461→}\n   462→\n   463→export function getRoundHistory(): Round[] {\n   464→  return store.roundHistory;\n   465→}\n   466→\n   467→export function getUserHistory(address: string): UserRoundHistory[] {\n   468→  return store.userHistory.get(address) ?? [];\n   469→}\n   470→\n   471→export function getCarryoverAmount(): number {\n   472→  return store.carryoverAmount;\n   473→}\n   474→\n   475→export function getRecentCandles(count: number = 15): Candle[] {\n   476→  if (!store.replayEngine) return [];\n   477→  return store.replayEngine.getCandlesUpToCurrent(count);\n   478→}\n   479→\n   480→export function getCurrentCandle(): Candle | null {\n   481→  if (!store.replayEngine) return null;\n   482→  return store.replayEngine.getCurrentCandle();\n   483→}\n   484→\n   485→export function getCandleProgress(): number {\n   486→  if (!store.replayEngine) return 0;\n   487→  return store.replayEngine.getProgress();\n   488→}\n   489→\n   490→export function getTimeRemaining(): number {\n   491→  if (!store.replayEngine) return 0;\n   492→  return store.replayEngine.getTimeRemaining();\n   493→}\n   494→\n   495→export function isGameInitialized(): boolean {\n   496→  return store.isInitialized;\n   497→}\n   498→\n   499→// ============ Utility ============\n   500→\n   501→export function truncateAddress(address: string): string {\n   502→  if (address.length <= 10) return address;\n   503→  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n   504→}\n   505→"}]},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"ff42b440-0f76-4984-936c-ae5319989398","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/utils/mock-simulation.ts","content":"/**\n * Mock Simulation for Close Call\n *\n * Manages round lifecycle, betting, and settlement in mock mode.\n */\n\nimport type {\n  Round,\n  BetSide,\n  Candle,\n  PlayerBet,\n  PoolState,\n  UserRoundHistory,\n} from \"../types\";\nimport { BETTING_WINDOW_MS, MIN_BET_AMOUNT, MAX_BET_AMOUNT } from \"../types\";\nimport { getReplayEngine, type CandleReplayEngine } from \"./candle-replay\";\nimport { calculatePayouts, determineOutcome } from \"./payout-calculator\";\nimport { emitCloseCallComplete, emitWagerPlaced } from \"../../boss-raid/utils/raid-event-bus\";\nimport { emitCloseCallResults } from \"../../player-profile/utils/profile-event-bus\";\n\n// ============ Store ============\n\ninterface MockStore {\n  currentRound: Round | null;\n  completedRound: Round | null; // Most recently completed round (for result display)\n  roundHistory: Round[];\n  userHistory: Map<string, UserRoundHistory[]>;\n  listeners: Set<(round: Round) => void>;\n  completedListeners: Set<(round: Round) => void>;\n  carryoverAmount: number;\n  replayEngine: CandleReplayEngine | null;\n  serverSeeds: Map<string, { serverSeed: string; blockHash: string }>;\n  mockBetTimers: ReturnType<typeof setTimeout>[];\n  isInitialized: boolean;\n}\n\nconst store: MockStore = {\n  currentRound: null,\n  completedRound: null,\n  roundHistory: [],\n  userHistory: new Map(),\n  listeners: new Set(),\n  completedListeners: new Set(),\n  carryoverAmount: 0,\n  replayEngine: null,\n  serverSeeds: new Map(),\n  mockBetTimers: [],\n  isInitialized: false,\n};\n\n// ============ Fairness Data ============\n\n// Generate a mock hex string (simulates SHA-256 hash or seed)\nfunction generateMockHexString(length: number = 64): string {\n  const chars = \"0123456789abcdef\";\n  let result = \"\";\n  for (let i = 0; i < length; i++) {\n    result += chars[Math.floor(Math.random() * chars.length)];\n  }\n  return result;\n}\n\nfunction generateFairnessData(): { seedHash: string; serverSeed: string; blockHash: string } {\n  const serverSeed = generateMockHexString(64); // 256-bit seed\n  const seedHash = generateMockHexString(64);   // SHA-256 hash of server seed\n  const blockHash = generateMockHexString(64);  // Block hash\n\n  return { seedHash, serverSeed, blockHash };\n}\n\nfunction generateRoundId(): string {\n  return `cc-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n}\n\n// ============ Mock Address Generation ============\n\nconst MOCK_ADDRESSES = [\n  \"7xKQ...nM4p\", \"3vBr...8sYq\", \"9aZm...kL2x\", \"5hTn...jR7w\",\n  \"2cVp...9fGd\", \"8kLm...4nHs\", \"1qWe...6bYt\", \"4rTy...0mXz\",\n  \"6uIo...2pAw\", \"0oKj...5nBv\", \"Ax7K...mN3p\", \"Bv8L...nO4q\",\n  \"Cw9M...oP5r\", \"Dx0N...pQ6s\", \"Ey1O...qR7t\", \"Fz2P...rS8u\",\n];\n\nfunction generateMockAddress(): string {\n  const index = Math.floor(Math.random() * MOCK_ADDRESSES.length);\n  return MOCK_ADDRESSES[index]!;\n}\n\n// ============ Round Management ============\n\nfunction createEmptyPool(): PoolState {\n  return {\n    greenPool: 0,\n    redPool: 0,\n    totalPool: 0,\n    playerCount: 0,\n    greenBets: [],\n    redBets: [],\n  };\n}\n\nfunction createNewRound(targetCandleTime: number): Round {\n  const fairnessData = generateFairnessData();\n  const roundId = generateRoundId();\n\n  store.serverSeeds.set(roundId, {\n    serverSeed: fairnessData.serverSeed,\n    blockHash: fairnessData.blockHash,\n  });\n\n  const round: Round = {\n    id: roundId,\n    phase: \"betting\",\n    pool: createEmptyPool(),\n    createdAt: Date.now(),\n    bettingEndsAt: Date.now() + BETTING_WINDOW_MS, // Betting window is first 10 seconds\n    targetCandleTime,\n    carryoverAmount: store.carryoverAmount,\n    seedHash: fairnessData.seedHash,\n  };\n\n  store.currentRound = round;\n  notifyListeners(round);\n\n  // Schedule mock bets\n  scheduleMockBets(round.id);\n\n  return round;\n}\n\nfunction lockRound(): void {\n  if (!store.currentRound) return;\n  if (store.currentRound.phase !== \"betting\") return;\n\n  store.currentRound.phase = \"locked\";\n  notifyListeners(store.currentRound);\n\n  // Clear any pending mock bet timers\n  clearMockBetTimers();\n}\n\nfunction resolveRound(resultCandle: Candle): void {\n  if (!store.currentRound) return;\n  if (store.currentRound.phase !== \"locked\") return;\n\n  const round = store.currentRound;\n  round.phase = \"resolving\";\n  round.resultCandle = resultCandle;\n  notifyListeners(round);\n\n  // Determine outcome\n  const outcome = determineOutcome(resultCandle);\n  round.outcome = outcome;\n\n  // Reveal server seed\n  const secrets = store.serverSeeds.get(round.id);\n  if (secrets) {\n    round.serverSeed = secrets.serverSeed;\n    round.blockHash = secrets.blockHash;\n  }\n\n  // Calculate payouts\n  const payoutResult = calculatePayouts(round.pool, outcome, round.carryoverAmount);\n  round.winners = Object.keys(payoutResult.payouts);\n  round.payouts = payoutResult.payouts;\n  round.payoutAmount = payoutResult.totalPayout;\n\n  // Update carryover for next round\n  store.carryoverAmount = payoutResult.carryoverToNext;\n\n  // Complete the round immediately (don't wait - new round may have started)\n  round.phase = \"complete\";\n  round.resolvedAt = Date.now();\n\n  // Store as completed round for result display\n  store.completedRound = { ...round, pool: { ...round.pool } };\n\n  // Archive round\n  store.roundHistory.unshift(round);\n\n  // Update user histories\n  updateUserHistories(round);\n\n  // Clean up server seed\n  store.serverSeeds.delete(round.id);\n\n  // Notify completed round listeners\n  notifyCompletedListeners(store.completedRound);\n\n  // Emit event for Boss Raid\n  const allBets = [...round.pool.greenBets, ...round.pool.redBets].map((b) => ({\n    address: b.address,\n    amount: b.amount,\n  }));\n  if (allBets.length > 0) {\n    emitCloseCallComplete(round.id, allBets);\n  }\n\n  // Emit event for Player Profile (XP and stats tracking)\n  const profileResults = [...round.pool.greenBets, ...round.pool.redBets].map((bet) => {\n    const payout = round.payouts?.[bet.address] ?? 0;\n    const won = payout > 0;\n    return {\n      address: bet.address,\n      wager: bet.amount,\n      outcome: (won ? \"win\" : \"loss\") as \"win\" | \"loss\",\n      payout,\n    };\n  });\n  if (profileResults.length > 0) {\n    emitCloseCallResults(round.id, profileResults);\n  }\n}\n\nfunction updateUserHistories(round: Round): void {\n  const allBets = [...round.pool.greenBets, ...round.pool.redBets];\n\n  for (const bet of allBets) {\n    const payout = round.payouts?.[bet.address] ?? 0;\n    const won = payout > 0;\n\n    const historyEntry: UserRoundHistory = {\n      round,\n      userBet: bet,\n      payout,\n      won,\n    };\n\n    const userHistory = store.userHistory.get(bet.address) ?? [];\n    userHistory.unshift(historyEntry);\n    store.userHistory.set(bet.address, userHistory);\n  }\n}\n\n// ============ Betting ============\n\nexport function placeBet(playerAddress: string, side: BetSide, amount: number): Round {\n  const round = store.currentRound;\n\n  if (!round) {\n    throw new Error(\"No active round\");\n  }\n\n  if (round.phase !== \"betting\") {\n    throw new Error(\"Betting is closed for this round\");\n  }\n\n  if (amount < MIN_BET_AMOUNT) {\n    throw new Error(`Minimum bet is $${MIN_BET_AMOUNT}`);\n  }\n\n  if (amount > MAX_BET_AMOUNT) {\n    throw new Error(`Maximum bet is $${MAX_BET_AMOUNT}`);\n  }\n\n  // Check for existing bet\n  const existingBet = [...round.pool.greenBets, ...round.pool.redBets].find(\n    (b) => b.address === playerAddress\n  );\n\n  if (existingBet) {\n    throw new Error(\"You have already bet on this round\");\n  }\n\n  // Create bet\n  const bet: PlayerBet = {\n    address: playerAddress,\n    side,\n    amount,\n    timestamp: Date.now(),\n  };\n\n  // Add to pool\n  if (side === \"green\") {\n    round.pool.greenBets.push(bet);\n    round.pool.greenPool += amount;\n  } else {\n    round.pool.redBets.push(bet);\n    round.pool.redPool += amount;\n  }\n\n  round.pool.totalPool += amount;\n  round.pool.playerCount++;\n\n  // Emit wager placed event (triggers RNG buff chest drop check)\n  emitWagerPlaced(\"close-call\", round.id, playerAddress, amount);\n\n  notifyListeners(round);\n  return round;\n}\n\n// ============ Mock Bets ============\n\nfunction scheduleMockBets(roundId: string): void {\n  clearMockBetTimers();\n\n  // Schedule 3-7 mock bets within the 10 second betting window\n  const betCount = 3 + Math.floor(Math.random() * 5);\n  const bettingDuration = BETTING_WINDOW_MS - 1000; // Leave 1s buffer before lock\n\n  for (let i = 0; i < betCount; i++) {\n    const delay = Math.random() * bettingDuration;\n    const timer = setTimeout(() => {\n      if (store.currentRound?.id !== roundId) return;\n      if (store.currentRound?.phase !== \"betting\") return;\n\n      addMockBet();\n    }, delay);\n\n    store.mockBetTimers.push(timer);\n  }\n}\n\nfunction addMockBet(): void {\n  if (!store.currentRound || store.currentRound.phase !== \"betting\") return;\n\n  const address = generateMockAddress();\n\n  // Check if this mock address already bet\n  const existingBet = [\n    ...store.currentRound.pool.greenBets,\n    ...store.currentRound.pool.redBets,\n  ].find((b) => b.address === address);\n\n  if (existingBet) return;\n\n  // Random side (slightly biased toward current minority for balance)\n  const greenRatio =\n    store.currentRound.pool.totalPool > 0\n      ? store.currentRound.pool.greenPool / store.currentRound.pool.totalPool\n      : 0.5;\n\n  // Bias toward minority side for more balanced pools\n  const greenProbability = greenRatio < 0.5 ? 0.6 : 0.4;\n  const side: BetSide = Math.random() < greenProbability ? \"green\" : \"red\";\n\n  // Random amount (weighted toward smaller bets)\n  const amount = Math.round((0.05 + Math.random() * Math.random() * 2) * 1000) / 1000;\n\n  try {\n    placeBet(address, side, Math.max(MIN_BET_AMOUNT, amount));\n  } catch {\n    // Ignore bet errors for mock bets\n  }\n}\n\nfunction clearMockBetTimers(): void {\n  for (const timer of store.mockBetTimers) {\n    clearTimeout(timer);\n  }\n  store.mockBetTimers = [];\n}\n\n// ============ Subscription ============\n\nfunction notifyListeners(round: Round): void {\n  const roundCopy = { ...round, pool: { ...round.pool } };\n  for (const listener of store.listeners) {\n    try {\n      listener(roundCopy);\n    } catch (error) {\n      console.error(\"Listener error:\", error);\n    }\n  }\n}\n\nfunction notifyCompletedListeners(round: Round): void {\n  const roundCopy = { ...round, pool: { ...round.pool } };\n  for (const listener of store.completedListeners) {\n    try {\n      listener(roundCopy);\n    } catch (error) {\n      console.error(\"Completed listener error:\", error);\n    }\n  }\n}\n\nexport function subscribeToRound(callback: (round: Round) => void): () => void {\n  store.listeners.add(callback);\n\n  // Immediately emit current round if exists\n  if (store.currentRound) {\n    callback({ ...store.currentRound, pool: { ...store.currentRound.pool } });\n  }\n\n  return () => {\n    store.listeners.delete(callback);\n  };\n}\n\nexport function subscribeToCompletedRound(callback: (round: Round) => void): () => void {\n  store.completedListeners.add(callback);\n\n  return () => {\n    store.completedListeners.delete(callback);\n  };\n}\n\n// ============ Game Initialization ============\n\nexport function initializeGame(): void {\n  if (store.isInitialized) return;\n\n  store.replayEngine = getReplayEngine();\n\n  store.replayEngine.start({\n    onCandleStart: (candle) => {\n      // Resolve any pending round from previous candle\n      if (store.currentRound?.phase === \"locked\" && store.currentRound.resultCandle) {\n        // Already resolved via onCandleComplete\n      }\n\n      // Create new round - users bet on THIS candle's outcome\n      createNewRound(candle.openTime);\n    },\n\n    onCandleComplete: (candle) => {\n      // Resolve current round when candle closes\n      if (store.currentRound?.phase === \"locked\") {\n        resolveRound(candle);\n      } else if (store.currentRound?.phase === \"betting\") {\n        // If still in betting (shouldn't happen), lock first then resolve\n        lockRound();\n        resolveRound(candle);\n      }\n    },\n\n    onPriceTick: () => {\n      // Auto-lock after 10 second betting window\n      if (store.currentRound?.phase === \"betting\") {\n        if (Date.now() >= store.currentRound.bettingEndsAt) {\n          lockRound();\n        }\n      }\n    },\n  });\n\n  store.isInitialized = true;\n}\n\nexport function stopGame(): void {\n  if (store.replayEngine) {\n    store.replayEngine.stop();\n  }\n  clearMockBetTimers();\n  store.isInitialized = false;\n}\n\n// ============ Getters ============\n\nexport function getCurrentRound(): Round | null {\n  return store.currentRound;\n}\n\nexport function getCompletedRound(): Round | null {\n  return store.completedRound;\n}\n\nexport function clearCompletedRound(): void {\n  store.completedRound = null;\n}\n\nexport function getRoundHistory(): Round[] {\n  return store.roundHistory;\n}\n\nexport function getUserHistory(address: string): UserRoundHistory[] {\n  return store.userHistory.get(address) ?? [];\n}\n\nexport function getCarryoverAmount(): number {\n  return store.carryoverAmount;\n}\n\nexport function getRecentCandles(count: number = 15): Candle[] {\n  if (!store.replayEngine) return [];\n  return store.replayEngine.getCandlesUpToCurrent(count);\n}\n\nexport function getCurrentCandle(): Candle | null {\n  if (!store.replayEngine) return null;\n  return store.replayEngine.getCurrentCandle();\n}\n\nexport function getCandleProgress(): number {\n  if (!store.replayEngine) return 0;\n  return store.replayEngine.getProgress();\n}\n\nexport function getTimeRemaining(): number {\n  if (!store.replayEngine) return 0;\n  return store.replayEngine.getTimeRemaining();\n}\n\nexport function isGameInitialized(): boolean {\n  return store.isInitialized;\n}\n\n// ============ Utility ============\n\nexport function truncateAddress(address: string): string {\n  if (address.length <= 10) return address;\n  return `${address.slice(0, 4)}...${address.slice(-4)}`;\n}\n","numLines":505,"startLine":1,"totalLines":505}}}
