  doji: \"#f0b820\",\n};\n","structuredPatch":[{"oldStart":132,"oldLines":5,"newStart":132,"newLines":5,"lines":[" export const SIDE_COLORS = {","   green: \"#45b058\",","   red: \"#dc3545\",","-  doji: \"#f0b820\",","+  refund: \"#f0b820\","," };"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RBcX9ndtvc1TdZqke3zn8W","type":"message","role":"assistant","content":[{"type":"text","text":"Now update **payout-calculator.ts** — remove DOJI_THRESHOLD_BPS, carryover, and align with refund:"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":281,"cache_read_input_tokens":75353,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":281},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"aec7f744-d929-46a7-bbe7-570e4f2f1705"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RBcX9ndtvc1TdZqke3zn8W","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NK6tKJtdMyw5BeZrb1hyK1","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/close-call/utils/payout-calculator.ts","content":"/**\n * Pari-Mutuel Payout Calculator for Close Call\n *\n * Formula:\n *   totalPool = greenPool + redPool\n *   netPool = totalPool × 0.97 (3% fee)\n *   playerPayout = (playerBet / winningPool) × netPool\n */\n\nimport type { BetSide, CandleOutcome, Candle, PoolState } from \"../types\";\nimport { PLATFORM_FEE } from \"../types\";\n\nexport interface PayoutResult {\n  winner: BetSide | null;\n  payouts: Record<string, number>;\n  totalPayout: number;\n  platformFee: number;\n}\n\n/**\n * Determine the outcome of a candle (strict comparison, no threshold)\n */\nexport function determineOutcome(candle: Candle): CandleOutcome {\n  const diff = candle.close - candle.open;\n\n  if (diff === 0) {\n    return \"refund\";\n  }\n\n  return diff > 0 ? \"green\" : \"red\";\n}\n\n/**\n * Calculate payouts for all winners\n */\nexport function calculatePayouts(\n  pool: PoolState,\n  outcome: CandleOutcome\n): PayoutResult {\n  const totalPool = pool.totalPool;\n\n  // Handle refund - no winners, full refund, no fee\n  if (outcome === \"refund\") {\n    return {\n      winner: null,\n      payouts: {},\n      totalPayout: 0,\n      platformFee: 0,\n    };\n  }\n\n  // Determine winning side\n  const winner: BetSide = outcome;\n  const winningBets = outcome === \"green\" ? pool.greenBets : pool.redBets;\n  const winningPool = outcome === \"green\" ? pool.greenPool : pool.redPool;\n  const losingPool = outcome === \"green\" ? pool.redPool : pool.greenPool;\n\n  // Handle one-sided pool: no losers means refund, no fee\n  if (losingPool === 0 || winningPool === 0 || winningBets.length === 0) {\n    return {\n      winner,\n      payouts: {},\n      totalPayout: 0,\n      platformFee: 0,\n    };\n  }\n\n  // Calculate platform fee (3% of total pool on decisive rounds only)\n  const platformFee = totalPool * PLATFORM_FEE;\n  const netPool = totalPool - platformFee;\n\n  // Calculate individual payouts\n  const payouts: Record<string, number> = {};\n  let totalPayout = 0;\n\n  for (const bet of winningBets) {\n    const share = bet.amount / winningPool;\n    const payout = netPool * share;\n    payouts[bet.address] = payout;\n    totalPayout += payout;\n  }\n\n  return {\n    winner,\n    payouts,\n    totalPayout,\n    platformFee,\n  };\n}\n\n/**\n * Calculate potential payout for a hypothetical bet\n */\nexport function calculatePotentialPayout(\n  betAmount: number,\n  betSide: BetSide,\n  pool: PoolState\n): number {\n  // Calculate what the pool would look like with this bet\n  const newWinningPool =\n    betSide === \"green\" ? pool.greenPool + betAmount : pool.redPool + betAmount;\n  const newTotalPool = pool.totalPool + betAmount;\n  const netPool = newTotalPool * (1 - PLATFORM_FEE);\n\n  // Player's share of winning pool\n  const share = betAmount / newWinningPool;\n\n  return netPool * share;\n}\n\n/**\n * Calculate odds multiplier for a side\n * Returns how much $1 would win (e.g., 2.0 means double your money)\n */\nexport function calculateOddsMultiplier(\n  side: BetSide,\n  pool: PoolState\n): number {\n  const winningPool = side === \"green\" ? pool.greenPool : pool.redPool;\n  const totalPool = pool.totalPool;\n\n  if (winningPool === 0 || totalPool === 0) {\n    return 0;\n  }\n\n  const netPool = totalPool * (1 - PLATFORM_FEE);\n  return netPool / winningPool;\n}\n\n/**\n * Calculate percentage of pool on each side\n */\nexport function calculatePoolDistribution(pool: PoolState): {\n  greenPercent: number;\n  redPercent: number;\n} {\n  if (pool.totalPool === 0) {\n    return { greenPercent: 50, redPercent: 50 };\n  }\n\n  return {\n    greenPercent: (pool.greenPool / pool.totalPool) * 100,\n    redPercent: (pool.redPool / pool.totalPool) * 100,\n  };\n}\n\n/**\n * Format amount for display\n */\nexport function formatAmount(amount: number, decimals: number = 4): string {\n  return amount.toFixed(decimals);\n}\n\n/**\n * Format USD amount for display\n */\nexport function formatUsd(amount: number): string {\n  return amount.toLocaleString(\"en-US\", {\n    style: \"currency\",\n    currency: \"USD\",\n    minimumFractionDigits: 2,\n    maximumFractionDigits: 2,\n  });\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":281,"cache_read_input_tokens":75353,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":281},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d3481bfc-609c-41f4-8bb8-2d2167df8050","uuid":"664aa6a5-8189-4807-8646-970c8b495105"}
