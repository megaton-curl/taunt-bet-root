{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0195niD5fZfVhVkSZD1uLGaj","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# Copies Anchor-generated IDL JSON + TypeScript type files into packages/anchor-client/src/\n     3→# Run from the monorepo root: ./scripts/sync-idl\n     4→\n     5→set -euo pipefail\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     8→ROOT_DIR=\"$(dirname \"$SCRIPT_DIR\")\"\n     9→IDL_SRC=\"$ROOT_DIR/solana/target/idl\"\n    10→TYPES_SRC=\"$ROOT_DIR/solana/target/types\"\n    11→DEST=\"$ROOT_DIR/packages/anchor-client/src\"\n    12→\n    13→if [ ! -d \"$IDL_SRC\" ]; then\n    14→  echo \"Error: IDL directory not found at $IDL_SRC\"\n    15→  echo \"Run 'anchor build' in solana/ first.\"\n    16→  exit 1\n    17→fi\n    18→\n    19→mkdir -p \"$DEST\"\n    20→\n    21→# Copy IDL JSON files\n    22→for f in \"$IDL_SRC\"/*.json; do\n    23→  [ -f \"$f\" ] || continue\n    24→  cp \"$f\" \"$DEST/\"\n    25→  echo \"Copied $(basename \"$f\")\"\n    26→done\n    27→\n    28→# Copy TypeScript type files\n    29→for f in \"$TYPES_SRC\"/*.ts; do\n    30→  [ -f \"$f\" ] || continue\n    31→  cp \"$f\" \"$DEST/\"\n    32→  echo \"Copied $(basename \"$f\")\"\n    33→done\n    34→\n    35→echo \"IDL sync complete.\"\n    36→"}]},"parent_tool_use_id":"toolu_01BzbAanzyNPDn92dUGsDsMS","session_id":"ed8c7c2b-8171-4a42-9e8a-cd2ad9b0248c","uuid":"de39960b-c6ae-4530-9d0c-16556f59633e"}
