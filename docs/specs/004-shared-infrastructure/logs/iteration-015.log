{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014r4iaViTYjZTxUFmJqnED8","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  SYSVAR_SLOT_HASHES_PUBKEY,\n     7→  Transaction,\n     8→  type TransactionInstruction,\n     9→} from \"@solana/web3.js\";\n    10→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n    11→import {\n    12→  TIER_VALUES,\n    13→  COIN_SIDE_VALUES,\n    14→  TIER_AMOUNTS,\n    15→  type Tier,\n    16→  type CoinSide,\n    17→} from \"@rng-utopia/game-engine/browser\";\n    18→import type { UIMatch } from \"../types\";\n    19→\n    20→// ============ Constants ============\n    21→\n    22→const COINFLIP_PROGRAM_ID = new PublicKey(\n    23→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    24→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    25→);\n    26→\n    27→// MagicBlock Ephemeral VRF constants\n    28→const VRF_DEFAULT_QUEUE = new PublicKey(\"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\");\n    29→const VRF_PROGRAM_ID = new PublicKey(\"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\");\n    30→// program_identity is a PDA derived from [\"identity\"] under our program ID (set by #[vrf] macro)\n    31→const [VRF_PROGRAM_IDENTITY] = PublicKey.findProgramAddressSync(\n    32→  [Buffer.from(\"identity\")],\n    33→  COINFLIP_PROGRAM_ID,\n    34→);\n    35→\n    36→// On-chain phase constants\n    37→const PHASE_WAITING = 0;\n    38→const PHASE_LOCKED = 1;\n    39→const PHASE_SETTLED = 2;\n    40→\n    41→// ============ PDA Derivation ============\n    42→\n    43→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    44→  return PublicKey.findProgramAddressSync(\n    45→    [Buffer.from(\"match\"), creator.toBuffer()],\n    46→    COINFLIP_PROGRAM_ID\n    47→  );\n    48→}\n    49→\n    50→export function getConfigPda(): [PublicKey, number] {\n    51→  return PublicKey.findProgramAddressSync(\n    52→    [Buffer.from(\"coinflip_config\")],\n    53→    COINFLIP_PROGRAM_ID\n    54→  );\n    55→}\n    56→\n    57→// ============ Program Instance ============\n    58→\n    59→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    60→  // Read-only provider (no wallet needed for queries)\n    61→  const provider = new AnchorProvider(\n    62→    connection,\n    63→    {} as AnchorProvider[\"wallet\"],\n    64→    { commitment: \"confirmed\" }\n    65→  );\n    66→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    67→}\n    68→\n    69→// ============ On-Chain Account Types ============\n    70→\n    71→interface OnChainMatch {\n    72→  creator: PublicKey;\n    73→  opponent: PublicKey;\n    74→  tier: number;\n    75→  entryAmount: { toNumber(): number };\n    76→  creatorSide: number;\n    77→  phase: number;\n    78→  result: number;\n    79→  winner: PublicKey;\n    80→  claimed: boolean;\n    81→  lockedAt: { toNumber(): number };\n    82→  bump: number;\n    83→}\n    84→\n    85→// ============ Converters ============\n    86→\n    87→function tierFromIndex(index: number): Tier {\n    88→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"emerald\", \"diamond\"];\n    89→  return tiers[index] ?? \"iron\";\n    90→}\n    91→\n    92→function sideFromIndex(index: number): CoinSide {\n    93→  return index === 0 ? \"heads\" : \"tails\";\n    94→}\n    95→\n    96→function phaseToUI(phase: number): UIMatch[\"phase\"] {\n    97→  switch (phase) {\n    98→    case PHASE_WAITING:\n    99→      return \"created\";\n   100→    case PHASE_LOCKED:\n   101→      return \"ready\";\n   102→    case PHASE_SETTLED:\n   103→      return \"complete\";\n   104→    default:\n   105→      return \"created\";\n   106→  }\n   107→}\n   108→\n   109→const DEFAULT_PUBKEY = PublicKey.default;\n   110→\n   111→function isDefaultPubkey(key: PublicKey): boolean {\n   112→  return key.equals(DEFAULT_PUBKEY);\n   113→}\n   114→\n   115→export function onChainMatchToUI(\n   116→  matchPda: PublicKey,\n   117→  data: OnChainMatch\n   118→): UIMatch {\n   119→  const tier = tierFromIndex(data.tier);\n   120→  const creatorSide = sideFromIndex(data.creatorSide);\n   121→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   122→  const phase = phaseToUI(data.phase);\n   123→  const isSettled = data.phase === PHASE_SETTLED;\n   124→\n   125→  const entryAmountSol = TIER_AMOUNTS[tier];\n   126→  const totalPool = entryAmountSol * 2;\n   127→  const payoutAmount = totalPool * 0.97;\n   128→\n   129→  const lockedAt = data.lockedAt.toNumber();\n   130→\n   131→  return {\n   132→    id: matchPda.toBase58(),\n   133→    tier,\n   134→    entryAmount: entryAmountSol,\n   135→    player1: data.creator.toBase58(),\n   136→    player1Side: creatorSide,\n   137→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   138→    player2Side: hasOpponent\n   139→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   140→      : null,\n   141→    phase,\n   142→    createdAt: Date.now(),\n   143→    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n   144→    result: isSettled ? sideFromIndex(data.result) : null,\n   145→    winner: isSettled && !isDefaultPubkey(data.winner)\n   146→      ? data.winner.toBase58()\n   147→      : null,\n   148→    claimed: data.claimed,\n   149→    payoutAmount,\n   150→    seedHash: \"\","}]},"parent_tool_use_id":"toolu_01BzbAanzyNPDn92dUGsDsMS","session_id":"ed8c7c2b-8171-4a42-9e8a-cd2ad9b0248c","uuid":"5a90b566-96b1-4258-8279-b8a4772bbc5f"}
