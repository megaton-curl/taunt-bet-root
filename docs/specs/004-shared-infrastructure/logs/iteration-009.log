{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bj1GPMFwqBWbaVmWFCTdyZ","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::{LOCK_TIMEOUT_SECONDS, PHASE_LOCKED};\n     3→\n     4→use crate::error::CoinflipError;\n     5→use crate::state::CoinflipMatch;\n     6→\n     7→#[derive(Accounts)]\n     8→pub struct TimeoutCancel<'info> {\n     9→    /// Either the creator or opponent can trigger a timeout cancel.\n    10→    #[account(mut)]\n    11→    pub caller: Signer<'info>,\n    12→\n    13→    /// The creator's account — receives rent refund.\n    14→    /// CHECK: Validated against coinflip_match.creator.\n    15→    #[account(mut)]\n    16→    pub creator: AccountInfo<'info>,\n    17→\n    18→    /// The opponent's account — receives entry refund.\n    19→    /// CHECK: Validated against coinflip_match.opponent.\n    20→    #[account(mut)]\n    21→    pub opponent: AccountInfo<'info>,\n    22→\n    23→    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    24→    #[account(\n    25→        mut,\n    26→        close = creator,\n    27→        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    28→        bump = coinflip_match.bump,\n    29→    )]\n    30→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    31→}\n    32→\n    33→pub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    34→    let coinflip_match = &ctx.accounts.coinflip_match;\n    35→\n    36→    // Must be in LOCKED phase\n    37→    require!(\n    38→        coinflip_match.phase == PHASE_LOCKED,\n    39→        CoinflipError::InvalidPhase\n    40→    );\n    41→\n    42→    // Caller must be either creator or opponent\n    43→    let caller = ctx.accounts.caller.key();\n    44→    require!(\n    45→        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n    46→        CoinflipError::UnauthorizedCaller\n    47→    );\n    48→\n    49→    // Validate passed accounts match stored keys\n    50→    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    51→    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n    52→\n    53→    // Check timeout has elapsed\n    54→    let now = Clock::get()?.unix_timestamp;\n    55→    require!(\n    56→        now - coinflip_match.locked_at >= LOCK_TIMEOUT_SECONDS,\n    57→        CoinflipError::LockTimeoutNotElapsed\n    58→    );\n    59→\n    60→    let entry_amount = coinflip_match.entry_amount;\n    61→\n    62→    // Refund both players their entry amounts from escrow\n    63→    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    64→    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    65→    **ctx.accounts.creator.try_borrow_mut_lamports()? += entry_amount;\n    66→\n    67→    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    68→    **ctx.accounts.opponent.try_borrow_mut_lamports()? += entry_amount;\n    69→\n    70→    // Account is closed by Anchor's `close = creator` constraint —\n    71→    // remaining lamports (rent) are returned to creator.\n    72→\n    73→    Ok(())\n    74→}\n    75→"}]},"parent_tool_use_id":"toolu_01FWUBgoZ92sfBvqpoEvkFzT","session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"110c623e-3ccf-4c74-b03a-534be6e0c768"}
