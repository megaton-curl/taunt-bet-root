{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GJd8TV4Bwz5PvAfPLuEL3i","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::system_program;\n     3→use rng_shared::constants::{is_valid_side, PHASE_WAITING};\n     4→use rng_shared::tiers::get_tier_amount;\n     5→\n     6→use crate::error::CoinflipError;\n     7→use crate::state::CoinflipMatch;\n     8→\n     9→#[derive(Accounts)]\n    10→pub struct CreateMatch<'info> {\n    11→    /// The player creating the match. Must sign and fund the escrow.\n    12→    #[account(mut)]\n    13→    pub creator: Signer<'info>,\n    14→\n    15→    /// The match PDA. Seeds enforce one active match per creator.\n    16→    #[account(\n    17→        init,\n    18→        payer = creator,\n    19→        space = 8 + CoinflipMatch::INIT_SPACE,\n    20→        seeds = [b\"match\", creator.key().as_ref()],\n    21→        bump,\n    22→    )]\n    23→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    24→\n    25→    pub system_program: Program<'info, System>,\n    26→}\n    27→\n    28→pub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    29→    require!(is_valid_side(side), CoinflipError::InvalidSide);\n    30→\n    31→    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n    32→\n    33→    // Transfer entry_amount from creator to match PDA (escrow)\n    34→    system_program::transfer(\n    35→        CpiContext::new(\n    36→            ctx.accounts.system_program.to_account_info(),\n    37→            system_program::Transfer {\n    38→                from: ctx.accounts.creator.to_account_info(),\n    39→                to: ctx.accounts.coinflip_match.to_account_info(),\n    40→            },\n    41→        ),\n    42→        entry_amount,\n    43→    )?;\n    44→\n    45→    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    46→    coinflip_match.creator = ctx.accounts.creator.key();\n    47→    coinflip_match.opponent = Pubkey::default();\n    48→    coinflip_match.tier = tier;\n    49→    coinflip_match.entry_amount = entry_amount;\n    50→    coinflip_match.creator_side = side;\n    51→    coinflip_match.phase = PHASE_WAITING;\n    52→    coinflip_match.result = 0;\n    53→    coinflip_match.winner = Pubkey::default();\n    54→    coinflip_match.claimed = false;\n    55→    coinflip_match.bump = ctx.bumps.coinflip_match;\n    56→\n    57→    Ok(())\n    58→}\n    59→"}]},"parent_tool_use_id":null,"session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"e5813886-647b-43ea-a0a0-7bf2bd227234","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/create_match.rs","content":"use anchor_lang::prelude::*;\nuse anchor_lang::system_program;\nuse rng_shared::constants::{is_valid_side, PHASE_WAITING};\nuse rng_shared::tiers::get_tier_amount;\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct CreateMatch<'info> {\n    /// The player creating the match. Must sign and fund the escrow.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA. Seeds enforce one active match per creator.\n    #[account(\n        init,\n        payer = creator,\n        space = 8 + CoinflipMatch::INIT_SPACE,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    require!(is_valid_side(side), CoinflipError::InvalidSide);\n\n    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n\n    // Transfer entry_amount from creator to match PDA (escrow)\n    system_program::transfer(\n        CpiContext::new(\n            ctx.accounts.system_program.to_account_info(),\n            system_program::Transfer {\n                from: ctx.accounts.creator.to_account_info(),\n                to: ctx.accounts.coinflip_match.to_account_info(),\n            },\n        ),\n        entry_amount,\n    )?;\n\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.creator = ctx.accounts.creator.key();\n    coinflip_match.opponent = Pubkey::default();\n    coinflip_match.tier = tier;\n    coinflip_match.entry_amount = entry_amount;\n    coinflip_match.creator_side = side;\n    coinflip_match.phase = PHASE_WAITING;\n    coinflip_match.result = 0;\n    coinflip_match.winner = Pubkey::default();\n    coinflip_match.claimed = false;\n    coinflip_match.bump = ctx.bumps.coinflip_match;\n\n    Ok(())\n}\n","numLines":59,"startLine":1,"totalLines":59}}}
