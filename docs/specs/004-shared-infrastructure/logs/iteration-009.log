{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019fdhXibhuC8f7K8nkBQBUS","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::state::CoinflipConfig;\n     4→\n     5→#[derive(Accounts)]\n     6→pub struct InitializeConfig<'info> {\n     7→    /// Admin authority who initializes the config.\n     8→    #[account(mut)]\n     9→    pub authority: Signer<'info>,\n    10→\n    11→    /// The config PDA (singleton).\n    12→    #[account(\n    13→        init,\n    14→        payer = authority,\n    15→        space = 8 + CoinflipConfig::INIT_SPACE,\n    16→        seeds = [b\"coinflip_config\"],\n    17→        bump,\n    18→    )]\n    19→    pub config: Account<'info, CoinflipConfig>,\n    20→\n    21→    pub system_program: Program<'info, System>,\n    22→}\n    23→\n    24→pub fn handler(\n    25→    ctx: Context<InitializeConfig>,\n    26→    oracle_authority: Pubkey,\n    27→    treasury: Pubkey,\n    28→) -> Result<()> {\n    29→    let config = &mut ctx.accounts.config;\n    30→    config.authority = ctx.accounts.authority.key();\n    31→    config.oracle_authority = oracle_authority;\n    32→    config.treasury = treasury;\n    33→    config.bump = ctx.bumps.config;\n    34→\n    35→    Ok(())\n    36→}\n    37→"}]},"parent_tool_use_id":"toolu_01FWUBgoZ92sfBvqpoEvkFzT","session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"e28b5e07-4afb-4bed-a8ee-845b7db7372a"}
