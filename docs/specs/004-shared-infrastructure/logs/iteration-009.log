{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H3L6bRq88FgyX3se2v5Jni","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::{from_randomness, PHASE_LOCKED, PHASE_SETTLED};\n     3→\n     4→use crate::error::CoinflipError;\n     5→use crate::state::{CoinflipConfig, CoinflipMatch};\n     6→\n     7→#[derive(Accounts)]\n     8→pub struct ResolveMatch<'info> {\n     9→    /// Oracle authority: VRF_PROGRAM_IDENTITY in real mode, config keypair in mock mode.\n    10→    pub oracle: Signer<'info>,\n    11→\n    12→    /// The config PDA with oracle authority.\n    13→    #[account(\n    14→        seeds = [b\"coinflip_config\"],\n    15→        bump = config.bump,\n    16→    )]\n    17→    pub config: Account<'info, CoinflipConfig>,\n    18→\n    19→    /// The match PDA to resolve.\n    20→    #[account(\n    21→        mut,\n    22→        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    23→        bump = coinflip_match.bump,\n    24→    )]\n    25→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    26→}\n    27→\n    28→pub fn handler(ctx: Context<ResolveMatch>, randomness: [u8; 32]) -> Result<()> {\n    29→    let coinflip_match = &ctx.accounts.coinflip_match;\n    30→\n    31→    // Must be in LOCKED phase\n    32→    require!(\n    33→        coinflip_match.phase == PHASE_LOCKED,\n    34→        CoinflipError::InvalidPhase\n    35→    );\n    36→\n    37→    // Oracle must match config.oracle_authority.\n    38→    // On devnet this is VRF_PROGRAM_IDENTITY; in bankrun tests it's a test keypair.\n    39→    require!(\n    40→        ctx.accounts.oracle.key() == ctx.accounts.config.oracle_authority,\n    41→        CoinflipError::UnauthorizedOracle\n    42→    );\n    43→\n    44→    // Derive result from randomness\n    45→    let result = from_randomness(randomness[0]);\n    46→\n    47→    // Determine winner: if result matches creator_side, creator wins; otherwise opponent\n    48→    let winner = if result == coinflip_match.creator_side {\n    49→        coinflip_match.creator\n    50→    } else {\n    51→        coinflip_match.opponent\n    52→    };\n    53→\n    54→    // Update match state\n    55→    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    56→    coinflip_match.result = result;\n    57→    coinflip_match.winner = winner;\n    58→    coinflip_match.phase = PHASE_SETTLED;\n    59→\n    60→    Ok(())\n    61→}\n    62→"}]},"parent_tool_use_id":null,"session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"10b064cd-4bb1-46e4-b579-d74571b2d407","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/resolve_match.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::constants::{from_randomness, PHASE_LOCKED, PHASE_SETTLED};\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n#[derive(Accounts)]\npub struct ResolveMatch<'info> {\n    /// Oracle authority: VRF_PROGRAM_IDENTITY in real mode, config keypair in mock mode.\n    pub oracle: Signer<'info>,\n\n    /// The config PDA with oracle authority.\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// The match PDA to resolve.\n    #[account(\n        mut,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n}\n\npub fn handler(ctx: Context<ResolveMatch>, randomness: [u8; 32]) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in LOCKED phase\n    require!(\n        coinflip_match.phase == PHASE_LOCKED,\n        CoinflipError::InvalidPhase\n    );\n\n    // Oracle must match config.oracle_authority.\n    // On devnet this is VRF_PROGRAM_IDENTITY; in bankrun tests it's a test keypair.\n    require!(\n        ctx.accounts.oracle.key() == ctx.accounts.config.oracle_authority,\n        CoinflipError::UnauthorizedOracle\n    );\n\n    // Derive result from randomness\n    let result = from_randomness(randomness[0]);\n\n    // Determine winner: if result matches creator_side, creator wins; otherwise opponent\n    let winner = if result == coinflip_match.creator_side {\n        coinflip_match.creator\n    } else {\n        coinflip_match.opponent\n    };\n\n    // Update match state\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.result = result;\n    coinflip_match.winner = winner;\n    coinflip_match.phase = PHASE_SETTLED;\n\n    Ok(())\n}\n","numLines":62,"startLine":1,"totalLines":62}}}
