{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SuWSzPtmAs2GJ9yDRpGEdU","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::state::CoinflipConfig;\n     4→\n     5→/// Admin-only instruction to close a match account that can't be deserialized\n     6→/// (e.g., after an account layout migration). Drains all lamports to the\n     7→/// original creator and zeroes the account data.\n     8→#[derive(Accounts)]\n     9→pub struct ForceClose<'info> {\n    10→    /// Config authority (admin).\n    11→    pub authority: Signer<'info>,\n    12→\n    13→    /// The config PDA — validates authority.\n    14→    #[account(\n    15→        seeds = [b\"coinflip_config\"],\n    16→        bump = config.bump,\n    17→        has_one = authority,\n    18→    )]\n    19→    pub config: Account<'info, CoinflipConfig>,\n    20→\n    21→    /// CHECK: The match account to close. Not deserialized — may have old layout.\n    22→    #[account(mut)]\n    23→    pub match_account: AccountInfo<'info>,\n    24→\n    25→    /// CHECK: Receives the lamports. Should be the match creator or admin.\n    26→    #[account(mut)]\n    27→    pub recipient: AccountInfo<'info>,\n    28→}\n    29→\n    30→pub fn handler(ctx: Context<ForceClose>) -> Result<()> {\n    31→    let match_info = &ctx.accounts.match_account;\n    32→\n    33→    // Verify it's owned by this program\n    34→    require_keys_eq!(*match_info.owner, crate::ID);\n    35→\n    36→    // Drain all lamports to recipient\n    37→    let lamports = match_info.lamports();\n    38→    **match_info.try_borrow_mut_lamports()? -= lamports;\n    39→    **ctx.accounts.recipient.try_borrow_mut_lamports()? += lamports;\n    40→\n    41→    // Zero the data so the account is effectively closed\n    42→    match_info.try_borrow_mut_data()?.fill(0);\n    43→\n    44→    Ok(())\n    45→}\n    46→"}]},"parent_tool_use_id":null,"session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"0b5a53c7-1e2d-44e8-852d-d4dbf15368b0","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/force_close.rs","content":"use anchor_lang::prelude::*;\n\nuse crate::state::CoinflipConfig;\n\n/// Admin-only instruction to close a match account that can't be deserialized\n/// (e.g., after an account layout migration). Drains all lamports to the\n/// original creator and zeroes the account data.\n#[derive(Accounts)]\npub struct ForceClose<'info> {\n    /// Config authority (admin).\n    pub authority: Signer<'info>,\n\n    /// The config PDA — validates authority.\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n        has_one = authority,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// CHECK: The match account to close. Not deserialized — may have old layout.\n    #[account(mut)]\n    pub match_account: AccountInfo<'info>,\n\n    /// CHECK: Receives the lamports. Should be the match creator or admin.\n    #[account(mut)]\n    pub recipient: AccountInfo<'info>,\n}\n\npub fn handler(ctx: Context<ForceClose>) -> Result<()> {\n    let match_info = &ctx.accounts.match_account;\n\n    // Verify it's owned by this program\n    require_keys_eq!(*match_info.owner, crate::ID);\n\n    // Drain all lamports to recipient\n    let lamports = match_info.lamports();\n    **match_info.try_borrow_mut_lamports()? -= lamports;\n    **ctx.accounts.recipient.try_borrow_mut_lamports()? += lamports;\n\n    // Zero the data so the account is effectively closed\n    match_info.try_borrow_mut_data()?.fill(0);\n\n    Ok(())\n}\n","numLines":46,"startLine":1,"totalLines":46}}}
