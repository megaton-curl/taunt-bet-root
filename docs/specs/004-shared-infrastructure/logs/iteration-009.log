nflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n\n    // Oracle authority check removed — Orao uses account constraints.\n    // This instruction is being replaced by read-at-claim in a later iteration.\n\n    // Derive result from randomness\n    let result = from_randomness(randomness[0]);\n\n    // Determine winner\n    let winner = if result == coinflip_match.creator_side {\n        coinflip_match.creator\n    } else {\n        coinflip_match.opponent\n    };\n\n    // Update match state — use Resolving→Settled path for legacy compat\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.result = result;\n    coinflip_match.winner = winner;\n    // Transition via Resolving (allowed: Locked→Resolving→Settled)\n    coinflip_match.phase = RoundPhase::Resolving;\n    coinflip_match.phase = RoundPhase::Settled;\n    coinflip_match.settled_at_ts = Clock::get()?.unix_timestamp;\n\n    Ok(())\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
