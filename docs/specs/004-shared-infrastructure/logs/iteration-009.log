       const RESOLVE_MATCH_DISC: [u8; 8] = [73, 0, 15, 197, 178, 47, 21, 193];\n    94→        let discriminator = RESOLVE_MATCH_DISC.to_vec();\n    95→\n    96→        // Use match PDA pubkey bytes as unique caller seed\n    97→        let caller_seed = match_key.to_bytes();\n    98→\n    99→        let ix = create_request_randomness_ix(RequestRandomnessParams {\n   100→            payer: ctx.accounts.opponent.key(),\n   101→            oracle_queue: ctx.accounts.oracle_queue.key(),\n   102→            callback_program_id: crate::ID,\n   103→            callback_discriminator: discriminator,\n   104→            caller_seed,\n   105→            accounts_metas: Some(vec![\n   106→                // resolve_match needs: oracle (auto-added by VRF), config, coinflip_match\n   107→                SerializableAccountMeta {\n   108→                    pubkey: config_key,\n   109→                    is_signer: false,\n   110→                    is_writable: false,\n   111→                },\n   112→                SerializableAccountMeta {\n   113→                    pubkey: match_key,\n   114→                    is_signer: false,\n   115→                    is_writable: true,\n   116→                },\n   117→            ]),\n   118→            callback_args: None,\n   119→        });\n   120→\n   121→        ctx.accounts\n   122→            .invoke_signed_vrf(&ctx.accounts.opponent.to_account_info(), &ix)\n   123→            .map_err(|_| error!(CoinflipError::VrfRequestFailed))?;\n   124→    }\n   125→\n   126→    Ok(())\n   127→}\n   128→"}]},"parent_tool_use_id":null,"session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"4702c791-d4e5-4aed-bc85-c76cb7dc071b","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/join_match.rs","content":"use anchor_lang::prelude::*;\nuse anchor_lang::system_program;\nuse rng_shared::constants::{PHASE_LOCKED, PHASE_WAITING};\n\nuse ephemeral_vrf_sdk::anchor::vrf;\n#[cfg(not(feature = \"mock-oracle\"))]\nuse ephemeral_vrf_sdk::instructions::{create_request_randomness_ix, RequestRandomnessParams};\n#[cfg(not(feature = \"mock-oracle\"))]\nuse ephemeral_vrf_sdk::types::SerializableAccountMeta;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n/// Unified struct — `#[vrf]` macro adds program_identity, vrf_program,\n/// slot_hashes, and system_program. Same IDL in both build modes.\n/// In mock-oracle mode the VRF accounts are present but the CPI is skipped.\n#[vrf]\n#[derive(Accounts)]\npub struct JoinMatch<'info> {\n    /// The opponent joining the match. Must sign and fund their escrow.\n    #[account(mut)]\n    pub opponent: Signer<'info>,\n\n    /// The match PDA to join.\n    #[account(\n        mut,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (needed for VRF callback account metas).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// CHECK: Oracle queue for VRF randomness requests.\n    #[account(mut)]\n    pub oracle_queue: AccountInfo<'info>,\n    // #[vrf] auto-adds: program_identity, vrf_program, slot_hashes, system_program\n}\n\npub fn handler(ctx: Context<JoinMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in WAITING phase\n    require!(\n        coinflip_match.phase == PHASE_WAITING,\n        CoinflipError::InvalidPhase\n    );\n\n    // Opponent cannot be the creator\n    require!(\n        ctx.accounts.opponent.key() != coinflip_match.creator,\n        CoinflipError::CannotJoinOwnMatch\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n    let opponent_key = ctx.accounts.opponent.key();\n\n    // Cache keys for VRF callback before mutable borrow\n    #[cfg(not(feature = \"mock-oracle\"))]\n    let config_key = ctx.accounts.config.key();\n    #[cfg(not(feature = \"mock-oracle\"))]\n    let match_key = ctx.accounts.coinflip_match.key();\n\n    // Transfer entry_amount from opponent to match PDA (escrow)\n    system_program::transfer(\n        CpiContext::new(\n            ctx.accounts.system_program.to_account_info(),\n            system_program::Transfer {\n                from: ctx.accounts.opponent.to_account_info(),\n                to: ctx.accounts.coinflip_match.to_account_info(),\n            },\n        ),\n        entry_amount,\n    )?;\n\n    // Update match state\n    {\n        let coinflip_match = &mut ctx.accounts.coinflip_match;\n        coinflip_match.opponent = opponent_key;\n        coinflip_match.phase = PHASE_LOCKED;\n        coinflip_match.locked_at = Clock::get()?.unix_timestamp;\n    }\n\n    // Request VRF randomness (real mode only — skipped in bankrun tests)\n    #[cfg(not(feature = \"mock-oracle\"))]\n    {\n        // Anchor discriminator: sha256(\"global:resolve_match\")[..8]\n        const RESOLVE_MATCH_DISC: [u8; 8] = [73, 0, 15, 197, 178, 47, 21, 193];\n        let discriminator = RESOLVE_MATCH_DISC.to_vec();\n\n        // Use match PDA pubkey bytes as unique caller seed\n        let caller_seed = match_key.to_bytes();\n\n        let ix = create_request_randomness_ix(RequestRandomnessParams {\n            payer: ctx.accounts.opponent.key(),\n            oracle_queue: ctx.accounts.oracle_queue.key(),\n            callback_program_id: crate::ID,\n            callback_discriminator: discriminator,\n            caller_seed,\n            accounts_metas: Some(vec![\n                // resolve_match needs: oracle (auto-added by VRF), config, coinflip_match\n                SerializableAccountMeta {\n                    pubkey: config_key,\n                    is_signer: false,\n                    is_writable: false,\n                },\n                SerializableAccountMeta {\n                    pubkey: match_key,\n                    is_signer: false,\n                    is_writable: true,\n                },\n            ]),\n            callback_args: None,\n        });\n\n        ctx.accounts\n            .invoke_signed_vrf(&ctx.accounts.opponent.to_account_info(), &ix)\n            .map_err(|_| error!(CoinflipError::VrfRequestFailed))?;\n    }\n\n    Ok(())\n}\n","numLines":128,"startLine":1,"totalLines":128}}}
