{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D7zXtkjW1PR1mzYrmidgk9","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/timeout_cancel.rs has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"284d3293-ab87-4d3c-a158-6244d603eb0e","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/timeout_cancel.rs","oldString":"use rng_shared::constants::{LOCK_TIMEOUT_SECONDS, PHASE_LOCKED};","newString":"use rng_shared::constants::LOCK_TIMEOUT_SECONDS;\nuse rng_shared::lifecycle::RoundPhase;","originalFile":"use anchor_lang::prelude::*;\nuse rng_shared::constants::{LOCK_TIMEOUT_SECONDS, PHASE_LOCKED};\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct TimeoutCancel<'info> {\n    /// Either the creator or opponent can trigger a timeout cancel.\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The creator's account — receives rent refund.\n    /// CHECK: Validated against coinflip_match.creator.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent's account — receives entry refund.\n    /// CHECK: Validated against coinflip_match.opponent.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n}\n\npub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in LOCKED phase\n    require!(\n        coinflip_match.phase == PHASE_LOCKED,\n        CoinflipError::InvalidPhase\n    );\n\n    // Caller must be either creator or opponent\n    let caller = ctx.accounts.caller.key();\n    require!(\n        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n        CoinflipError::UnauthorizedCaller\n    );\n\n    // Validate passed accounts match stored keys\n    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n\n    // Check timeout has elapsed\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        now - coinflip_match.locked_at >= LOCK_TIMEOUT_SECONDS,\n        CoinflipError::LockTimeoutNotElapsed\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n\n    // Refund both players their entry amounts from escrow\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    **ctx.accounts.creator.try_borrow_mut_lamports()? += entry_amount;\n\n    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    **ctx.accounts.opponent.try_borrow_mut_lamports()? += entry_amount;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // remaining lamports (rent) are returned to creator.\n\n    Ok(())\n}\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":6,"lines":[" use anchor_lang::prelude::*;","-use rng_shared::constants::{LOCK_TIMEOUT_SECONDS, PHASE_LOCKED};","+use rng_shared::constants::LOCK_TIMEOUT_SECONDS;","+use rng_shared::lifecycle::RoundPhase;"," "," use crate::error::CoinflipError;"," use crate::state::CoinflipMatch;"]}],"userModified":false,"replaceAll":false}}
