{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019m6Y13SFjmLeGgzLSjkq4q","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::system_program;\n     3→use rng_shared::constants::{PHASE_LOCKED, PHASE_WAITING};\n     4→\n     5→use ephemeral_vrf_sdk::anchor::vrf;\n     6→#[cfg(not(feature = \"mock-oracle\"))]\n     7→use ephemeral_vrf_sdk::instructions::{create_request_randomness_ix, RequestRandomnessParams};\n     8→#[cfg(not(feature = \"mock-oracle\"))]\n     9→use ephemeral_vrf_sdk::types::SerializableAccountMeta;\n    10→\n    11→use crate::error::CoinflipError;\n    12→use crate::state::{CoinflipConfig, CoinflipMatch};\n    13→\n    14→/// Unified struct — `#[vrf]` macro adds program_identity, vrf_program,\n    15→/// slot_hashes, and system_program. Same IDL in both build modes.\n    16→/// In mock-oracle mode the VRF accounts are present but the CPI is skipped.\n    17→#[vrf]\n    18→#[derive(Accounts)]\n    19→pub struct JoinMatch<'info> {\n    20→    /// The opponent joining the match. Must sign and fund their escrow.\n    21→    #[account(mut)]\n    22→    pub opponent: Signer<'info>,\n    23→\n    24→    /// The match PDA to join.\n    25→    #[account(\n    26→        mut,\n    27→        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    28→        bump = coinflip_match.bump,\n    29→    )]\n    30→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    31→\n    32→    /// The config PDA (needed for VRF callback account metas).\n    33→    #[account(\n    34→        seeds = [b\"coinflip_config\"],\n    35→        bump = config.bump,\n    36→    )]\n    37→    pub config: Account<'info, CoinflipConfig>,\n    38→\n    39→    /// CHECK: Oracle queue for VRF randomness requests.\n    40→    #[account(mut)]\n    41→    pub oracle_queue: AccountInfo<'info>,\n    42→    // #[vrf] auto-adds: program_identity, vrf_program, slot_hashes, system_program\n    43→}\n    44→\n    45→pub fn handler(ctx: Context<JoinMatch>) -> Result<()> {\n    46→    let coinflip_match = &ctx.accounts.coinflip_match;\n    47→\n    48→    // Must be in WAITING phase\n    49→    require!(\n    50→        coinflip_match.phase == PHASE_WAITING,\n    51→        CoinflipError::InvalidPhase\n    52→    );\n    53→\n    54→    // Opponent cannot be the creator\n    55→    require!(\n    56→        ctx.accounts.opponent.key() != coinflip_match.creator,\n    57→        CoinflipError::CannotJoinOwnMatch\n    58→    );\n    59→\n    60→    let entry_amount = coinflip_match.entry_amount;\n    61→    let opponent_key = ctx.accounts.opponent.key();\n    62→\n    63→    // Cache keys for VRF callback before mutable borrow\n    64→    #[cfg(not(feature = \"mock-oracle\"))]\n    65→    let config_key = ctx.accounts.config.key();\n    66→    #[cfg(not(feature = \"mock-oracle\"))]\n    67→    let match_key = ctx.accounts.coinflip_match.key();\n    68→\n    69→    // Transfer entry_amount from opponent to match PDA (escrow)\n    70→    system_program::transfer(\n    71→        CpiContext::new(\n    72→            ctx.accounts.system_program.to_account_info(),\n    73→            system_program::Transfer {\n    74→                from: ctx.accounts.opponent.to_account_info(),\n    75→                to: ctx.accounts.coinflip_match.to_account_info(),\n    76→            },\n    77→        ),\n    78→        entry_amount,\n    79→    )?;\n    80→\n    81→    // Update match state\n    82→    {\n    83→        let coinflip_match = &mut ctx.accounts.coinflip_match;\n    84→        coinflip_match.opponent = opponent_key;\n    85→        coinflip_match.phase = PHASE_LOCKED;\n    86→        coinflip_match.locked_at = Clock::get()?.unix_timestamp;\n    87→    }\n    88→\n    89→    // Request VRF randomness (real mode only — skipped in bankrun tests)\n    90→    #[cfg(not(feature = \"mock-oracle\"))]\n    91→    {\n    92→        // Anchor discriminator: sha256(\"global:resolve_match\")[..8]\n    93→        const RESOLVE_MATCH_DISC: [u8; 8] = [73, 0, 15, 197, 178, 47, 21, 193];\n    94→        let discriminator = RESOLVE_MATCH_DISC.to_vec();\n    95→\n    96→        // Use match PDA pubkey bytes as unique caller seed\n    97→        let caller_seed = match_key.to_bytes();\n    98→\n    99→        let ix = create_request_randomness_ix(RequestRandomnessParams {\n   100→            payer: ctx.accounts.opponent.key(),\n   101→            oracle_queue: ctx.accounts.oracle_queue.key(),\n   102→            callback_program_id: crate::ID,\n   103→            callback_discriminator: discriminator,\n   104→            caller_seed,\n   105→            accounts_metas: Some(vec![\n   106→                // resolve_match needs: oracle (auto-added by VRF), config, coinflip_match\n   107→                SerializableAccountMeta {\n   108→                    pubkey: config_key,\n   109→                    is_signer: false,\n   110→                    is_writable: false,\n   111→                },\n   112→                SerializableAccountMeta {\n   113→                    pubkey: match_key,\n   114→                    is_signer: false,\n   115→                    is_writable: true,\n   116→                },\n   117→            ]),\n   118→            callback_args: None,\n   119→        });\n   120→\n   121→        ctx.accounts\n   122→            .invoke_signed_vrf(&ctx.accounts.opponent.to_account_info(), &ix)\n   123→            .map_err(|_| error!(CoinflipError::VrfRequestFailed))?;\n   124→    }\n   125→\n   126→    Ok(())\n   127→}\n   128→"}]},"parent_tool_use_id":null,"session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"b54d4c0f-4977-4052-b348-9e22775d5034","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/join_match.rs","content":"use anchor_lang::prelude::*;\nuse anchor_lang::system_program;\nuse rng_shared::constants::{PHASE_LOCKED, PHASE_WAITING};\n\nuse ephemeral_vrf_sdk::anchor::vrf;\n#[cfg(not(feature = \"mock-oracle\"))]\nuse ephemeral_vrf_sdk::instructions::{create_request_randomness_ix, RequestRandomnessParams};\n#[cfg(not(feature = \"mock-oracle\"))]\nuse ephemeral_vrf_sdk::types::SerializableAccountMeta;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n/// Unified struct — `#[vrf]` macro adds program_identity, vrf_program,\n/// slot_hashes, and system_program. Same IDL in both build modes.\n/// In mock-oracle mode the VRF accounts are present but the CPI is skipped.\n#[vrf]\n#[derive(Accounts)]\npub struct JoinMatch<'info> {\n    /// The opponent joining the match. Must sign and fund their escrow.\n    #[account(mut)]\n    pub opponent: Signer<'info>,\n\n    /// The match PDA to join.\n    #[account(\n        mut,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (needed for VRF callback account metas).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// CHECK: Oracle queue for VRF randomness requests.\n    #[account(mut)]\n    pub oracle_queue: AccountInfo<'info>,\n    // #[vrf] auto-adds: program_identity, vrf_program, slot_hashes, system_program\n}\n\npub fn handler(ctx: Context<JoinMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in WAITING phase\n    require!(\n        coinflip_match.phase == PHASE_WAITING,\n        CoinflipError::InvalidPhase\n    );\n\n    // Opponent cannot be the creator\n    require!(\n        ctx.accounts.opponent.key() != coinflip_match.creator,\n        CoinflipError::CannotJoinOwnMatch\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n    let opponent_key = ctx.accounts.opponent.key();\n\n    // Cache keys for VRF callback before mutable borrow\n    #[cfg(not(feature = \"mock-oracle\"))]\n    let config_key = ctx.accounts.config.key();\n    #[cfg(not(feature = \"mock-oracle\"))]\n    let match_key = ctx.accounts.coinflip_match.key();\n\n    // Transfer entry_amount from opponent to match PDA (escrow)\n    system_program::transfer(\n        CpiContext::new(\n            ctx.accounts.system_program.to_account_info(),\n            system_program::Transfer {\n                from: ctx.accounts.opponent.to_account_info(),\n                to: ctx.accounts.coinflip_match.to_account_info(),\n            },\n        ),\n        entry_amount,\n    )?;\n\n    // Update match state\n    {\n        let coinflip_match = &mut ctx.accounts.coinflip_match;\n        coinflip_match.opponent = opponent_key;\n        coinflip_match.phase = PHASE_LOCKED;\n        coinflip_match.locked_at = Clock::get()?.unix_timestamp;\n    }\n\n    // Request VRF randomness (real mode only — skipped in bankrun tests)\n    #[cfg(not(feature = \"mock-oracle\"))]\n    {\n        // Anchor discriminator: sha256(\"global:resolve_match\")[..8]\n        const RESOLVE_MATCH_DISC: [u8; 8] = [73, 0, 15, 197, 178, 47, 21, 193];\n        let discriminator = RESOLVE_MATCH_DISC.to_vec();\n\n        // Use match PDA pubkey bytes as unique caller seed\n        let caller_seed = match_key.to_bytes();\n\n        let ix = create_request_randomness_ix(RequestRandomnessParams {\n            payer: ctx.accounts.opponent.key(),\n            oracle_queue: ctx.accounts.oracle_queue.key(),\n            callback_program_id: crate::ID,\n            callback_discriminator: discriminator,\n            caller_seed,\n            accounts_metas: Some(vec![\n                // resolve_match needs: oracle (auto-added by VRF), config, coinflip_match\n                SerializableAccountMeta {\n                    pubkey: config_key,\n                    is_signer: false,\n                    is_writable: false,\n                },\n                SerializableAccountMeta {\n                    pubkey: match_key,\n                    is_signer: false,\n                    is_writable: true,\n                },\n            ]),\n            callback_args: None,\n        });\n\n        ctx.accounts\n            .invoke_signed_vrf(&ctx.accounts.opponent.to_account_info(), &ix)\n            .map_err(|_| error!(CoinflipError::VrfRequestFailed))?;\n    }\n\n    Ok(())\n}\n","numLines":128,"startLine":1,"totalLines":128}}}
