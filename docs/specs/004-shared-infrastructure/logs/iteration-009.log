{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DmJJB5qrMnB5DiVEADJkxw","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Fixed tier entry amounts in lamports.\n     4→/// Index 0 = Iron, 1 = Bronze, 2 = Silver, 3 = Gold, 4 = Platinum, 5 = Diamond\n     5→pub const TIER_AMOUNTS: [u64; 6] = [\n     6→    5_000_000,       // 0.005 SOL — Iron\n     7→    10_000_000,      // 0.01  SOL — Bronze\n     8→    100_000_000,     // 0.1   SOL — Silver\n     9→    250_000_000,     // 0.25  SOL — Gold\n    10→    500_000_000,     // 0.5   SOL — Platinum\n    11→    1_000_000_000,   // 1.0   SOL — Diamond\n    12→];\n    13→\n    14→pub const TIER_COUNT: usize = TIER_AMOUNTS.len();\n    15→\n    16→/// Returns the entry amount for the given tier index, or an error if out of range.\n    17→pub fn get_tier_amount(tier: u8) -> Result<u64> {\n    18→    TIER_AMOUNTS\n    19→        .get(tier as usize)\n    20→        .copied()\n    21→        .ok_or_else(|| error!(TierError::InvalidTier))\n    22→}\n    23→\n    24→#[error_code]\n    25→pub enum TierError {\n    26→    #[msg(\"Invalid tier index\")]\n    27→    InvalidTier,\n    28→}\n    29→"}]},"parent_tool_use_id":"toolu_01FWUBgoZ92sfBvqpoEvkFzT","session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"e7704319-660b-4608-abf0-33121dab30f3"}
