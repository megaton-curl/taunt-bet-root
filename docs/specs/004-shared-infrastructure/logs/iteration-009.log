{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WmY381DZPQHcdm1RZiqC1T","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::PHASE_WAITING;\n     3→\n     4→use crate::error::CoinflipError;\n     5→use crate::state::CoinflipMatch;\n     6→\n     7→#[derive(Accounts)]\n     8→pub struct CancelMatch<'info> {\n     9→    /// The creator cancelling their match.\n    10→    #[account(mut)]\n    11→    pub creator: Signer<'info>,\n    12→\n    13→    /// The match PDA (closed on cancel — escrow + rent refunded to creator).\n    14→    #[account(\n    15→        mut,\n    16→        close = creator,\n    17→        seeds = [b\"match\", creator.key().as_ref()],\n    18→        bump = coinflip_match.bump,\n    19→    )]\n    20→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    21→\n    22→    pub system_program: Program<'info, System>,\n    23→}\n    24→\n    25→pub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    26→    let coinflip_match = &ctx.accounts.coinflip_match;\n    27→\n    28→    // Only WAITING matches can be cancelled\n    29→    require!(\n    30→        coinflip_match.phase == PHASE_WAITING,\n    31→        CoinflipError::CannotCancel\n    32→    );\n    33→\n    34→    // Account is closed by Anchor's `close = creator` constraint —\n    35→    // all lamports (escrow + rent) are returned to creator.\n    36→\n    37→    Ok(())\n    38→}\n    39→"}]},"parent_tool_use_id":null,"session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"f2fe1a3f-0f92-4a9b-a6e8-b34b84bbcc0e","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/cancel_match.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::constants::PHASE_WAITING;\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct CancelMatch<'info> {\n    /// The creator cancelling their match.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA (closed on cancel — escrow + rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Only WAITING matches can be cancelled\n    require!(\n        coinflip_match.phase == PHASE_WAITING,\n        CoinflipError::CannotCancel\n    );\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // all lamports (escrow + rent) are returned to creator.\n\n    Ok(())\n}\n","numLines":39,"startLine":1,"totalLines":39}}}
