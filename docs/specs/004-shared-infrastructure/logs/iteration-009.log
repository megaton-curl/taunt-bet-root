\n    47→    #[account(mut)]\n    48→    pub creator_profile: AccountInfo<'info>,\n    49→\n    50→    /// Opponent's player profile PDA on the platform program.\n    51→    /// CHECK: Validated by platform program via CPI (if account exists).\n    52→    #[account(mut)]\n    53→    pub opponent_profile: AccountInfo<'info>,\n    54→\n    55→    /// The platform program for CPI calls.\n    56→    pub platform_program: Program<'info, platform::program::Platform>,\n    57→\n    58→    pub system_program: Program<'info, System>,\n    59→}\n    60→\n    61→pub fn handler(ctx: Context<ClaimPayout>) -> Result<()> {\n    62→    let coinflip_match = &ctx.accounts.coinflip_match;\n    63→\n    64→    // Must be in SETTLED phase\n    65→    require!(\n    66→        coinflip_match.phase == PHASE_SETTLED,\n    67→        CoinflipError::InvalidPhase\n    68→    );\n    69→\n    70→    // Caller must be either creator or opponent\n    71→    let caller = ctx.accounts.caller.key();\n    72→    require!(\n    73→        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n    74→        CoinflipError::UnauthorizedCaller\n    75→    );\n    76→\n    77→    // Validate winner account matches on-chain winner\n    78→    require!(\n    79→        ctx.accounts.winner.key() == coinflip_match.winner,\n    80→        CoinflipError::NotWinner\n    81→    );\n    82→\n    83→    // Prevent double claim\n    84→    require!(!coinflip_match.claimed, CoinflipError::AlreadyClaimed);\n    85→\n    86→    // Validate treasury matches config\n    87→    require!(\n    88→        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n    89→        CoinflipError::InvalidPhase\n    90→    );\n    91→\n    92→    // Validate creator matches match.creator\n    93→    require!(\n    94→        ctx.accounts.creator.key() == coinflip_match.creator,\n    95→        CoinflipError::InvalidPhase\n    96→    );\n    97→\n    98→    // Compute payout amounts\n    99→    let pool = coinflip_match.entry_amount.checked_mul(2).unwrap();\n   100→    let fee = calculate_fee(pool);\n   101→    let payout = pool - fee;\n   102→\n   103→    // Transfer payout to winner\n   104→    let match_info = ctx.accounts.coinflip_match.to_account_info();\n   105→    **match_info.try_borrow_mut_lamports()? -= payout;\n   106→    **ctx.accounts.winner.try_borrow_mut_lamports()? += payout;\n   107→\n   108→    // Transfer fee to treasury\n   109→    **match_info.try_borrow_mut_lamports()? -= fee;\n   110→    **ctx.accounts.treasury.try_borrow_mut_lamports()? += fee;\n   111→\n   112→    // CPI: update player profiles (only if they exist on-chain)\n   113→    let config_bump = ctx.accounts.config.bump;\n   114→    let signer_seeds: &[&[&[u8]]] = &[&[b\"coinflip_config\", &[config_bump]]];\n   115→\n   116→    let cpi_program = ctx.accounts.platform_program.to_account_info();\n   117→\n   118→    // Creator profile update — skip if profile hasn't been created yet\n   119→    if !ctx.accounts.creator_profile.data_is_empty() {\n   120→        let creator_is_winner = ctx.accounts.creator.key() == coinflip_match.winner;\n   121→        let creator_won_amount = if creator_is_winner { payout } else { 0 };\n   122→        let cpi_accounts_creator = platform::cpi::accounts::UpdatePlayerProfile {\n   123→            caller: ctx.accounts.config.to_account_info(),\n   124→            profile: ctx.accounts.creator_profile.to_account_info(),\n   125→        };\n   126→        let cpi_ctx_creator =\n   127→            CpiContext::new_with_signer(cpi_program.clone(), cpi_accounts_creator, signer_seeds);\n   128→        platform::cpi::update_player_profile(\n   129→            cpi_ctx_creator,\n   130→            coinflip_match.entry_amount,\n   131→            creator_won_amount,\n   132→            creator_is_winner,\n   133→        )?;\n   134→    }\n   135→\n   136→    // Opponent profile update — skip if profile hasn't been created yet\n   137→    if !ctx.accounts.opponent_profile.data_is_empty() {\n   138→        let opponent_is_winner = coinflip_match.opponent == coinflip_match.winner;\n   139→        let opponent_won_amount = if opponent_is_winner { payout } else { 0 };\n   140→        let cpi_accounts_opponent = platform::cpi::accounts::UpdatePlayerProfile {\n   141→            caller: ctx.accounts.config.to_account_info(),\n   142→            profile: ctx.accounts.opponent_profile.to_account_info(),\n   143→        };\n   144→        let cpi_ctx_opponent =\n   145→            CpiContext::new_with_signer(cpi_program, cpi_accounts_opponent, signer_seeds);\n   146→        platform::cpi::update_player_profile(\n   147→            cpi_ctx_opponent,\n   148→            coinflip_match.entry_amount,\n   149→            opponent_won_amount,\n   150→            opponent_is_winner,\n   151→        )?;\n   152→    }\n   153→\n   154→    // Account is closed by Anchor's `close = creator` constraint —\n   155→    // remaining lamports (rent) are sent to creator, data is zeroed,\n   156→    // and owner is set back to system program. This ensures the PDA\n   157→    // is fully cleaned up so the creator can start a new match.\n   158→\n   159→    Ok(())\n   160→}\n   161→"}]},"parent_tool_use_id":null,"session_id":"9c12a0c3-e927-48e5-aad8-631d6cf2e564","uuid":"e3f8e3f9-f80a-423a-8363-7004c7ae524a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/claim_payout.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::constants::PHASE_SETTLED;\nuse rng_shared::fees::calculate_fee;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n#[derive(Accounts)]\npub struct ClaimPayout<'info> {\n    /// Either the creator or opponent can trigger the claim.\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The winner who receives the payout.\n    /// CHECK: Validated against coinflip_match.winner in handler.\n    #[account(mut)]\n    pub winner: AccountInfo<'info>,\n\n    /// The match PDA (closed after claim — rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (for treasury address + CPI signing).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// The treasury account to receive fees.\n    /// CHECK: Validated against config.treasury in handler.\n    #[account(mut)]\n    pub treasury: AccountInfo<'info>,\n\n    /// The creator account (receives rent refund on close).\n    /// CHECK: Validated against coinflip_match.creator in handler.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// Creator's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub creator_profile: AccountInfo<'info>,\n\n    /// Opponent's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub opponent_profile: AccountInfo<'info>,\n\n    /// The platform program for CPI calls.\n    pub platform_program: Program<'info, platform::program::Platform>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<ClaimPayout>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in SETTLED phase\n    require!(\n        coinflip_match.phase == PHASE_SETTLED,\n        CoinflipError::InvalidPhase\n    );\n\n    // Caller must be either creator or opponent\n    let caller = ctx.accounts.caller.key();\n    require!(\n        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n        CoinflipError::UnauthorizedCaller\n    );\n\n    // Validate winner account matches on-chain winner\n    require!(\n        ctx.accounts.winner.key() == coinflip_match.winner,\n        CoinflipError::NotWinner\n    );\n\n    // Prevent double claim\n    require!(!coinflip_match.claimed, CoinflipError::AlreadyClaimed);\n\n    // Validate treasury matches config\n    require!(\n        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n        CoinflipError::InvalidPhase\n    );\n\n    // Validate creator matches match.creator\n    require!(\n        ctx.accounts.creator.key() == coinflip_match.creator,\n        CoinflipError::InvalidPhase\n    );\n\n    // Compute payout amounts\n    let pool = coinflip_match.entry_amount.checked_mul(2).unwrap();\n    let fee = calculate_fee(pool);\n    let payout = pool - fee;\n\n    // Transfer payout to winner\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    **match_info.try_borrow_mut_lamports()? -= payout;\n    **ctx.accounts.winner.try_borrow_mut_lamports()? += payout;\n\n    // Transfer fee to treasury\n    **match_info.try_borrow_mut_lamports()? -= fee;\n    **ctx.accounts.treasury.try_borrow_mut_lamports()? += fee;\n\n    // CPI: update player profiles (only if they exist on-chain)\n    let config_bump = ctx.accounts.config.bump;\n    let signer_seeds: &[&[&[u8]]] = &[&[b\"coinflip_config\", &[config_bump]]];\n\n    let cpi_program = ctx.accounts.platform_program.to_account_info();\n\n    // Creator profile update — skip if profile hasn't been created yet\n    if !ctx.accounts.creator_profile.data_is_empty() {\n        let creator_is_winner = ctx.accounts.creator.key() == coinflip_match.winner;\n        let creator_won_amount = if creator_is_winner { payout } else { 0 };\n        let cpi_accounts_creator = platform::cpi::accounts::UpdatePlayerProfile {\n            caller: ctx.accounts.config.to_account_info(),\n            profile: ctx.accounts.creator_profile.to_account_info(),\n        };\n        let cpi_ctx_creator =\n            CpiContext::new_with_signer(cpi_program.clone(), cpi_accounts_creator, signer_seeds);\n        platform::cpi::update_player_profile(\n            cpi_ctx_creator,\n            coinflip_match.entry_amount,\n            creator_won_amount,\n            creator_is_winner,\n        )?;\n    }\n\n    // Opponent profile update — skip if profile hasn't been created yet\n    if !ctx.accounts.opponent_profile.data_is_empty() {\n        let opponent_is_winner = coinflip_match.opponent == coinflip_match.winner;\n        let opponent_won_amount = if opponent_is_winner { payout } else { 0 };\n        let cpi_accounts_opponent = platform::cpi::accounts::UpdatePlayerProfile {\n            caller: ctx.accounts.config.to_account_info(),\n            profile: ctx.accounts.opponent_profile.to_account_info(),\n        };\n        let cpi_ctx_opponent =\n            CpiContext::new_with_signer(cpi_program, cpi_accounts_opponent, signer_seeds);\n        platform::cpi::update_player_profile(\n            cpi_ctx_opponent,\n            coinflip_match.entry_amount,\n            opponent_won_amount,\n            opponent_is_winner,\n        )?;\n    }\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // remaining lamports (rent) are sent to creator, data is zeroed,\n    // and owner is set back to system program. This ensures the PDA\n    // is fully cleaned up so the creator can start a new match.\n\n    Ok(())\n}\n","numLines":161,"startLine":1,"totalLines":161}}}
