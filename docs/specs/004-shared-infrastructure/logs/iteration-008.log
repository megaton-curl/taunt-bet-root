{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CbmGELTm1jzweX6n6EDRTr","type":"tool_result","content":"     1→//! # ORAO VRF\n     2→//!\n     3→//! Crate to interact with `orao-vrf` smart contract on Solana network.\n     4→//!\n     5→//! Provides an interface to request verifiable randomness (Ed25519 Signature)\n     6→//! on the Solana network.\n     7→//!\n     8→//! ## Documentation\n     9→//!\n    10→//! Please look into the following functions and structures:\n    11→//!\n    12→//! * [`RequestBuilder`] – convenient builder for randomness requests\n    13→//! * [`get_network_state`] – helper to fetch the VRF configuration\n    14→//! * [`get_randomness`] – helper to fetch the randomness request state\n    15→//! * [`randomness_account_address`] – helper to derive randomness request state address\n    16→//! * [`network_state_account_address`] – helper to derive VRF on-chain configuration address\n    17→//!\n    18→//! ## Cross Program Invocation\n    19→//!\n    20→//! For CPI please look into the `cpi` example and account requirements for the [`Request`]\n    21→//! instruction.\n    22→//!\n    23→//! **Note:** requires `cpi` feature to be enabled and `sdk` feature to be disabled.\n    24→//!\n    25→//! ```ignore\n    26→//! // assuming ctx to be a context of an instruction that performs CPI\n    27→//! let vrf_program = ctx.accounts.vrf.to_account_info();\n    28→//! let request_accounts = orao_solana_vrf::cpi::accounts::Request {\n    29→//!     payer: ctx.accounts.player.to_account_info(),\n    30→//!     network_state: ctx.accounts.config.to_account_info(),\n    31→//!     treasury: ctx.accounts.treasury.to_account_info(),\n    32→//!     request: ctx.accounts.request.to_account_info(),\n    33→//!     system_program: ctx.accounts.system_program.to_account_info(),\n    34→//! };\n    35→//! let cpi_ctx = CpiContext::new(vrf_program, request_accounts);\n    36→//! orao_solana_vrf::cpi::request(cpi_ctx, seed)?;\n    37→//! ```\n    38→#![cfg_attr(docsrs, feature(doc_cfg))]\n    39→#![allow(deprecated)]\n    40→\n    41→use anchor_lang::prelude::*;\n    42→use state::{NetworkState, OraoTokenFeeConfig, Randomness, RandomnessV2};\n    43→\n    44→pub use crate::error::Error;\n    45→\n    46→pub mod error;\n    47→\n    48→pub mod events;\n    49→pub mod state;\n    50→\n    51→mod sdk;\n    52→#[cfg(all(feature = \"sdk\", not(feature = \"idl-build\")))]\n    53→pub use crate::sdk::*;\n    54→\n    55→pub const VERSION: &str = env!(\"CARGO_PKG_VERSION\");\n    56→\n    57→declare_id!(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n    58→\n    59→/// This is the seed used for creating request/fulfillment accounts.\n    60→pub const RANDOMNESS_ACCOUNT_SEED: &[u8] = b\"orao-vrf-randomness-request\";\n    61→\n    62→/// This is the seed used to create network-wide configuration PDA\n    63→/// account, that sets things like fulfillment authorities, costs, etc.\n    64→pub const CONFIG_ACCOUNT_SEED: &[u8] = b\"orao-vrf-network-configuration\";\n    65→\n    66→// this is the number of public keys that are allowed to generate randomness\n    67→pub const MAX_FULFILLMENT_AUTHORITIES_COUNT: usize = 10;\n    68→\n    69→/// Returns network state account address for the given VRF address.\n    70→///\n    71→/// * `vrf_id` — use [`crate::id`] to get the proper address\n    72→pub fn network_state_account_address(vrf_id: &Pubkey) -> Pubkey {\n    73→    Pubkey::find_program_address(&[CONFIG_ACCOUNT_SEED], vrf_id).0\n    74→}\n    75→\n    76→/// Returns randomness account address for the given seed and VRF address.\n    77→///\n    78→/// * `vrf_id` — use [`crate::id`] to get the proper address\n    79→pub fn randomness_account_address(vrf_id: &Pubkey, seed: &[u8; 32]) -> Pubkey {\n    80→    Pubkey::find_program_address(&[RANDOMNESS_ACCOUNT_SEED, &seed[..]], vrf_id).0\n    81→}\n    82→\n    83→/// Helper that XORes `r` into `l`.\n    84→pub fn xor_array<const N: usize>(l: &mut [u8; N], r: &[u8; N]) {\n    85→    for i in 0..N {\n    86→        l[i] ^= r[i];\n    87→    }\n    88→}\n    89→\n    90→/// Helper that checks for Byzantine quorum.\n    91→pub const fn quorum(count: usize, total: usize) -> bool {\n    92→    count >= majority(total)\n    93→}\n    94→\n    95→/// Helper that returns the majority for the given total value.\n    96→pub const fn majority(total: usize) -> usize {\n    97→    total * 2 / 3 + 1\n    98→}\n    99→\n   100→#[allow(unused_variables)]\n   101→#[program]\n   102→pub mod orao_vrf {\n   103→    use super::*;\n   104→\n   105→    /// Performs VRF initialization (for required accounts see [`crate::InitNetwork`]).\n   106→    ///\n   107→    /// *  fee – request fee (in lamports)\n   108→    /// *  config_authority – VRF config update authority\n   109→    /// *  fulfillment_authorities – randomness fulfillment authorities\n   110→    /// *  token_fee_config – token fee configuration\n   111→    ///\n   112→    /// Treasury is given via instruction accounts.\n   113→    pub fn init_network(\n   114→        ctx: Context<InitNetwork>,\n   115→        fee: u64,\n   116→        config_authority: Pubkey,\n   117→        fulfillment_authorities: Vec<Pubkey>,\n   118→        token_fee_config: Option<OraoTokenFeeConfig>,\n   119→    ) -> Result<()> {\n   120→        Ok(())\n   121→    }\n   122→\n   123→    /// Performs VRF configuration update (for required accounts see [`crate::UpdateNetwork`]).\n   124→    ///\n   125→    /// *  fee – request fee (in lamports)\n   126→    /// *  config_authority – VRF config update authority\n   127→    /// *  fulfillment_authorities – randomness fulfillment authorities\n   128→    /// *  token_fee_config – token fee configuration\n   129→    ///\n   130→    /// Treasury is given via instruction accounts.\n   131→    pub fn update_network(\n   132→        ctx: Context<UpdateNetwork>,\n   133→        fee: u64,\n   134→        config_authority: Pubkey,\n   135→        fulfillment_authorities: Vec<Pubkey>,\n   136→        token_fee_config: Option<OraoTokenFeeConfig>,\n   137→    ) -> Result<()> {\n   138→        Ok(())\n   139→    }\n   140→\n   141→    /// (**deprecated: see [`crate::Request`]**) Performs a randomness request\n   142→    /// (for required accounts see [`crate::Request`]).\n   143→    ///\n   144→    /// *  seed – unique request seed\n   145→    pub fn request<'info>(\n   146→        ctx: Context<'_, '_, '_, 'info, Request<'info>>,\n   147→        seed: [u8; 32],\n   148→    ) -> Result<()> {\n   149→        Ok(())\n   150→    }\n   151→\n   152→    /// (**deprecated: see [`crate::FulfillV2`]**) Fulfills a randomness request\n   153→    /// (for required accounts see [`crate::Fulfill`]).\n   154→    pub fn fulfill(ctx: Context<Fulfill>) -> Result<()> {\n   155→        Ok(())\n   156→    }\n   157→\n   158→    /// Performs a randomness request (for required accounts see [`crate::RequestV2`]).\n   159→    ///\n   160→    /// *  seed – unique request seed\n   161→    pub fn request_v2<'info>(\n   162→        ctx: Context<'_, '_, '_, 'info, RequestV2<'info>>,\n   163→        seed: [u8; 32],\n   164→    ) -> Result<()> {\n   165→        Ok(())\n   166→    }\n   167→\n   168→    /// Fulfills a randomness request (for required accounts see [`crate::FulfillV2`]).\n   169→    pub fn fulfill_v2(ctx: Context<FulfillV2>) -> Result<()> {\n   170→        Ok(())\n   171→    }\n   172→}\n   173→\n   174→/// Initialize network configuration.\n   175→///\n   176→/// ### Required accounts\n   177→///\n   178→/// *  (signer) payer – fee payer\n   179→/// *  (writable) network_state – VRF network state PDA\n   180→///    (see [`network_state_account_address`])\n   181→/// *  treasury – SOL treasury account\n   182→/// *  system_program - system program account\n   183→///\n   184→/// ### Remaining accounts\n   185→///\n   186→/// Following accounts are necessary if `token_fee_config` is given:\n   187→///\n   188→/// *  mint_account – SPL token mint account (should match the token fee config)\n   189→/// *  token_treasury_account – should match SPL token and token fee config\n   190→#[derive(Accounts)]\n   191→pub struct InitNetwork<'info> {\n   192→    #[account(mut)]\n   193→    pub payer: Signer<'info>,\n   194→    #[account(\n   195→        init,\n   196→        payer = payer,\n   197→        space = 8 + 464,\n   198→        seeds = [CONFIG_ACCOUNT_SEED],\n   199→        bump,\n   200→    )]\n   201→    pub network_state: Account<'info, NetworkState>,\n   202→    /// CHECK:\n   203→    pub treasury: AccountInfo<'info>,\n   204→    pub system_program: Program<'info, System>,\n   205→}\n   206→\n   207→/// Update network configuration.\n   208→///\n   209→/// ### Required accounts\n   210→///\n   211→/// *  (signer) authority – should match configured VRF authority\n   212→/// *  (writable) network_state – VRF network state PDA\n   213→///    (see [`network_state_account_address`])\n   214→/// *  treasury – SOL treasury account\n   215→///\n   216→/// ### Remaining accounts\n   217→///\n   218→/// Following accounts are necessary if `token_fee_config` is given:\n   219→///\n   220→/// *  mint_account – SPL token mint account (should match the token fee config)\n   221→/// *  token_treasury_account – should match SPL token and token fee config\n   222→#[derive(Accounts)]\n   223→pub struct UpdateNetwork<'info> {\n   224→    #[account(mut)]\n   225→    pub authority: Signer<'info>,\n   226→    #[account(\n   227→        mut,\n   228→        seeds = [CONFIG_ACCOUNT_SEED],\n   229→        bump,\n   230→        constraint = network_state.config.authority == authority.key(),\n   231→    )]\n   232→    pub network_state: Account<'info, NetworkState>,\n   233→    /// CHECK:\n   234→    pub treasury: AccountInfo<'info>,\n   235→}\n   236→\n   237→/// (**deprecated: see [`crate::RequestV2`]**) Request randomness.\n   238→///\n   239→/// ### Required accounts\n   240→///\n   241→/// *  (signer) payer – request and transaction fee payer\n   242→/// *  (writable) network_state – VRF on-chain config PDA\n   243→///    (see [`network_state_account_address`])\n   244→/// *  (writable) (from VRF on-chain config) treasury – either SOL treasury or token treasury\n   245→///    (see remaining accounts)\n   246→/// *  (writable) request – randomness request PDA\n   247→///    (see [`randomness_account_address`])\n   248→/// *  system_program - system program account\n   249→///\n   250→/// ### Remaining accounts\n   251→///\n   252→/// If token fee configuration exists and given treasury equals token treasury,\n   253→/// then remaining accounts are required:\n   254→///\n   255→/// *  (writable) token_payer – payer token wallet\n   256→/// *  token_program_account – necessary to execute the transfer\n   257→///\n   258→/// ### Space calculation for account creation (request)\n   259→///\n   260→/// * 8 (anchor tag) + 32 (seed) + 64 (combined randomness) + 4 (response array length) + (32 (fulfiller pubkey) + 64 (fulfiller randomness))  * 7 (maximum number of responses)\n   261→///\n   262→#[derive(Accounts)]\n   263→#[instruction(seed: [u8; 32])]\n   264→#[deprecated(since = \"0.4.0\", note = \"See RequestV2\")]\n   265→pub struct Request<'info> {\n   266→    #[account(mut)]\n   267→    pub payer: Signer<'info>,\n   268→    #[account(\n   269→        mut,\n   270→        seeds = [CONFIG_ACCOUNT_SEED],\n   271→        bump,\n   272→    )]\n   273→    pub network_state: Account<'info, NetworkState>,\n   274→    /// CHECK:\n   275→    #[account(\n   276→        mut,\n   277→        constraint = network_state.config.treasury == treasury.key() ||\n   278→        network_state.config.token_fee_config.as_ref().map(|x| x.treasury) == Some(treasury.key())\n   279→        @ Error::UnknownTreasuryGiven)]\n   280→    pub treasury: AccountInfo<'info>,\n   281→    #[account(\n   282→        init,\n   283→        payer = payer,\n   284→        space = 8 + Randomness::SIZE,\n   285→        seeds = [RANDOMNESS_ACCOUNT_SEED, &seed],\n   286→        bump,\n   287→    )]\n   288→    pub request: Account<'info, Randomness>,\n   289→    pub system_program: Program<'info, System>,\n   290→}\n   291→\n   292→/// (**deprecated: see [`crate::FulfillV2`]**) Fulfill randomness.\n   293→///\n   294→/// ### Required accounts\n   295→///\n   296→/// *  (signer) payer – transaction fee payer\n   297→/// *  instruction_acc – sysvar instruction account\n   298→/// *  (writable) network_state – VRF on-chain config PDA\n   299→///    (see [`network_state_account_address`])\n   300→/// *  (writable) request – randomness request PDA\n   301→///    (see [`randomness_account_address`])\n   302→#[derive(Accounts)]\n   303→#[deprecated(since = \"0.4.0\", note = \"See FulfillV2\")]\n   304→pub struct Fulfill<'info> {\n   305→    #[account(mut)]\n   306→    pub payer: Signer<'info>,\n   307→    /// CHECK:\n   308→    pub instruction_acc: AccountInfo<'info>,\n   309→    #[account(\n   310→        mut,\n   311→        seeds = [CONFIG_ACCOUNT_SEED],\n   312→        bump,\n   313→    )]\n   314→    pub network_state: Account<'info, NetworkState>,\n   315→    #[account(\n   316→        mut,\n   317→        seeds = [RANDOMNESS_ACCOUNT_SEED, &request.seed],\n   318→        bump,\n   319→    )]\n   320→    pub request: Account<'info, Randomness>,\n   321→}\n   322→\n   323→/// Request randomness.\n   324→///\n   325→/// ### Required accounts\n   326→///\n   327→/// *  (signer) payer – request and transaction fee payer\n   328→/// *  (writable) network_state – VRF on-chain config PDA\n   329→///    (see [`network_state_account_address`])\n   330→/// *  (writable) (from VRF on-chain config) treasury – either SOL treasury or token treasury\n   331→///    (see remaining accounts)\n   332→/// *  (writable) request – randomness request PDA\n   333→///    (see [`randomness_account_address`])\n   334→/// *  system_program - system program account\n   335→///\n   336→/// ### Remaining accounts\n   337→///\n   338→/// If token fee configuration exists and given treasury equals token treasury,\n   339→/// then remaining accounts are required:\n   340→///\n   341→/// *  (writable) token_payer – payer token wallet\n   342→/// *  token_program_account – necessary to execute the transfer\n   343→///\n   344→/// ### Space calculation for account creation (request)\n   345→///\n   346→/// * 8 (anchor tag) + 32 (client) + 32 (seed) + 4 (response array length) + (32 (fulfiller pubkey) + 64 (fulfiller randomness))  * 7 (maximum number of responses)\n   347→///\n   348→#[derive(Accounts)]\n   349→#[instruction(seed: [u8; 32])]\n   350→pub struct RequestV2<'info> {\n   351→    #[account(mut)]\n   352→    pub payer: Signer<'info>,\n   353→    #[account(\n   354→        mut,\n   355→        seeds = [CONFIG_ACCOUNT_SEED],\n   356→        bump,\n   357→    )]\n   358→    pub network_state: Account<'info, NetworkState>,\n   359→    /// CHECK:\n   360→    #[account(\n   361→        mut,\n   362→        constraint = network_state.config.treasury == treasury.key() ||\n   363→        network_state.config.token_fee_config.as_ref().map(|x| x.treasury) == Some(treasury.key())\n   364→        @ Error::UnknownTreasuryGiven)]\n   365→    pub treasury: AccountInfo<'info>,\n   366→    #[account(\n   367→        init,\n   368→        payer = payer,\n   369→        space = 8 + RandomnessV2::PENDING_SIZE,\n   370→        seeds = [RANDOMNESS_ACCOUNT_SEED, &seed],\n   371→        bump,\n   372→    )]\n   373→    pub request: Account<'info, RandomnessV2>,\n   374→    pub system_program: Program<'info, System>,\n   375→}\n   376→\n   377→/// Fulfill randomness (v2).\n   378→///\n   379→/// ### Required accounts\n   380→///\n   381→/// *  (signer) payer – transaction fee payer\n   382→/// *  instruction_acc – sysvar instruction account\n   383→/// *  (writable) network_state – VRF on-chain config PDA\n   384→///    (see [`network_state_account_address`])\n   385→/// *  (writable) request – randomness request PDA\n   386→///    (see [`randomness_account_address`])\n   387→/// *  (writable) client - client account (see [`Randomness::client`])\n   388→#[derive(Accounts)]\n   389→pub struct FulfillV2<'info> {\n   390→    #[account(mut)]\n   391→    pub payer: Signer<'info>,\n   392→    /// CHECK:\n   393→    pub instruction_acc: AccountInfo<'info>,\n   394→    #[account(\n   395→        mut,\n   396→        seeds = [CONFIG_ACCOUNT_SEED],\n   397→        bump,\n   398→    )]\n   399→    pub network_state: Account<'info, NetworkState>,\n   400→    #[account(\n   401→        mut,\n   402→        seeds = [RANDOMNESS_ACCOUNT_SEED, request.seed()],\n   403→        bump,\n   404→    )]\n   405→    pub request: Account<'info, RandomnessV2>,\n   406→    /// CHECK: An address of this account is validated via anchor constraint\n   407→    #[account(mut, constraint = *request.client() == client.key())]\n   408→    pub client: AccountInfo<'info>,\n   409→    pub system_program: Program<'info, System>,\n   410→}\n   411→"}]},"parent_tool_use_id":null,"session_id":"34433cb1-6ee0-432f-833f-aec143a4b7e1","uuid":"9408b897-5f29-41f9-849d-e5397fe58d1b","tool_use_result":{"type":"text","file":{"filePath":"/home/vscode/.cargo/registry/src/index.crates.io-1949cf8c6b5b557f/orao-solana-vrf-0.7.0/src/lib.rs","content":"//! # ORAO VRF\n//!\n//! Crate to interact with `orao-vrf` smart contract on Solana network.\n//!\n//! Provides an interface to request verifiable randomness (Ed25519 Signature)\n//! on the Solana network.\n//!\n//! ## Documentation\n//!\n//! Please look into the following functions and structures:\n//!\n//! * [`RequestBuilder`] – convenient builder for randomness requests\n//! * [`get_network_state`] – helper to fetch the VRF configuration\n//! * [`get_randomness`] – helper to fetch the randomness request state\n//! * [`randomness_account_address`] – helper to derive randomness request state address\n//! * [`network_state_account_address`] – helper to derive VRF on-chain configuration address\n//!\n//! ## Cross Program Invocation\n//!\n//! For CPI please look into the `cpi` example and account requirements for the [`Request`]\n//! instruction.\n//!\n//! **Note:** requires `cpi` feature to be enabled and `sdk` feature to be disabled.\n//!\n//! ```ignore\n//! // assuming ctx to be a context of an instruction that performs CPI\n//! let vrf_program = ctx.accounts.vrf.to_account_info();\n//! let request_accounts = orao_solana_vrf::cpi::accounts::Request {\n//!     payer: ctx.accounts.player.to_account_info(),\n//!     network_state: ctx.accounts.config.to_account_info(),\n//!     treasury: ctx.accounts.treasury.to_account_info(),\n//!     request: ctx.accounts.request.to_account_info(),\n//!     system_program: ctx.accounts.system_program.to_account_info(),\n//! };\n//! let cpi_ctx = CpiContext::new(vrf_program, request_accounts);\n//! orao_solana_vrf::cpi::request(cpi_ctx, seed)?;\n//! ```\n#![cfg_attr(docsrs, feature(doc_cfg))]\n#![allow(deprecated)]\n\nuse anchor_lang::prelude::*;\nuse state::{NetworkState, OraoTokenFeeConfig, Randomness, RandomnessV2};\n\npub use crate::error::Error;\n\npub mod error;\n\npub mod events;\npub mod state;\n\nmod sdk;\n#[cfg(all(feature = \"sdk\", not(feature = \"idl-build\")))]\npub use crate::sdk::*;\n\npub const VERSION: &str = env!(\"CARGO_PKG_VERSION\");\n\ndeclare_id!(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n\n/// This is the seed used for creating request/fulfillment accounts.\npub const RANDOMNESS_ACCOUNT_SEED: &[u8] = b\"orao-vrf-randomness-request\";\n\n/// This is the seed used to create network-wide configuration PDA\n/// account, that sets things like fulfillment authorities, costs, etc.\npub const CONFIG_ACCOUNT_SEED: &[u8] = b\"orao-vrf-network-configuration\";\n\n// this is the number of public keys that are allowed to generate randomness\npub const MAX_FULFILLMENT_AUTHORITIES_COUNT: usize = 10;\n\n/// Returns network state account address for the given VRF address.\n///\n/// * `vrf_id` — use [`crate::id`] to get the proper address\npub fn network_state_account_address(vrf_id: &Pubkey) -> Pubkey {\n    Pubkey::find_program_address(&[CONFIG_ACCOUNT_SEED], vrf_id).0\n}\n\n/// Returns randomness account address for the given seed and VRF address.\n///\n/// * `vrf_id` — use [`crate::id`] to get the proper address\npub fn randomness_account_address(vrf_id: &Pubkey, seed: &[u8; 32]) -> Pubkey {\n    Pubkey::find_program_address(&[RANDOMNESS_ACCOUNT_SEED, &seed[..]], vrf_id).0\n}\n\n/// Helper that XORes `r` into `l`.\npub fn xor_array<const N: usize>(l: &mut [u8; N], r: &[u8; N]) {\n    for i in 0..N {\n        l[i] ^= r[i];\n    }\n}\n\n/// Helper that checks for Byzantine quorum.\npub const fn quorum(count: usize, total: usize) -> bool {\n    count >= majority(total)\n}\n\n/// Helper that returns the majority for the given total value.\npub const fn majority(total: usize) -> usize {\n    total * 2 / 3 + 1\n}\n\n#[allow(unused_variables)]\n#[program]\npub mod orao_vrf {\n    use super::*;\n\n    /// Performs VRF initialization (for required accounts see [`crate::InitNetwork`]).\n    ///\n    /// *  fee – request fee (in lamports)\n    /// *  config_authority – VRF config update authority\n    /// *  fulfillment_authorities – randomness fulfillment authorities\n    /// *  token_fee_config – token fee configuration\n    ///\n    /// Treasury is given via instruction accounts.\n    pub fn init_network(\n        ctx: Context<InitNetwork>,\n        fee: u64,\n        config_authority: Pubkey,\n        fulfillment_authorities: Vec<Pubkey>,\n        token_fee_config: Option<OraoTokenFeeConfig>,\n    ) -> Result<()> {\n        Ok(())\n    }\n\n    /// Performs VRF configuration update (for required accounts see [`crate::UpdateNetwork`]).\n    ///\n    /// *  fee – request fee (in lamports)\n    /// *  config_authority – VRF config update authority\n    /// *  fulfillment_authorities – randomness fulfillment authorities\n    /// *  token_fee_config – token fee configuration\n    ///\n    /// Treasury is given via instruction accounts.\n    pub fn update_network(\n        ctx: Context<UpdateNetwork>,\n        fee: u64,\n        config_authority: Pubkey,\n        fulfillment_authorities: Vec<Pubkey>,\n        token_fee_config: Option<OraoTokenFeeConfig>,\n    ) -> Result<()> {\n        Ok(())\n    }\n\n    /// (**deprecated: see [`crate::Request`]**) Performs a randomness request\n    /// (for required accounts see [`crate::Request`]).\n    ///\n    /// *  seed – unique request seed\n    pub fn request<'info>(\n        ctx: Context<'_, '_, '_, 'info, Request<'info>>,\n        seed: [u8; 32],\n    ) -> Result<()> {\n        Ok(())\n    }\n\n    /// (**deprecated: see [`crate::FulfillV2`]**) Fulfills a randomness request\n    /// (for required accounts see [`crate::Fulfill`]).\n    pub fn fulfill(ctx: Context<Fulfill>) -> Result<()> {\n        Ok(())\n    }\n\n    /// Performs a randomness request (for required accounts see [`crate::RequestV2`]).\n    ///\n    /// *  seed – unique request seed\n    pub fn request_v2<'info>(\n        ctx: Context<'_, '_, '_, 'info, RequestV2<'info>>,\n        seed: [u8; 32],\n    ) -> Result<()> {\n        Ok(())\n    }\n\n    /// Fulfills a randomness request (for required accounts see [`crate::FulfillV2`]).\n    pub fn fulfill_v2(ctx: Context<FulfillV2>) -> Result<()> {\n        Ok(())\n    }\n}\n\n/// Initialize network configuration.\n///\n/// ### Required accounts\n///\n/// *  (signer) payer – fee payer\n/// *  (writable) network_state – VRF network state PDA\n///    (see [`network_state_account_address`])\n/// *  treasury – SOL treasury account\n/// *  system_program - system program account\n///\n/// ### Remaining accounts\n///\n/// Following accounts are necessary if `token_fee_config` is given:\n///\n/// *  mint_account – SPL token mint account (should match the token fee config)\n/// *  token_treasury_account – should match SPL token and token fee config\n#[derive(Accounts)]\npub struct InitNetwork<'info> {\n    #[account(mut)]\n    pub payer: Signer<'info>,\n    #[account(\n        init,\n        payer = payer,\n        space = 8 + 464,\n        seeds = [CONFIG_ACCOUNT_SEED],\n        bump,\n    )]\n    pub network_state: Account<'info, NetworkState>,\n    /// CHECK:\n    pub treasury: AccountInfo<'info>,\n    pub system_program: Program<'info, System>,\n}\n\n/// Update network configuration.\n///\n/// ### Required accounts\n///\n/// *  (signer) authority – should match configured VRF authority\n/// *  (writable) network_state – VRF network state PDA\n///    (see [`network_state_account_address`])\n/// *  treasury – SOL treasury account\n///\n/// ### Remaining accounts\n///\n/// Following accounts are necessary if `token_fee_config` is given:\n///\n/// *  mint_account – SPL token mint account (should match the token fee config)\n/// *  token_treasury_account – should match SPL token and token fee config\n#[derive(Accounts)]\npub struct UpdateNetwork<'info> {\n    #[account(mut)]\n    pub authority: Signer<'info>,\n    #[account(\n        mut,\n        seeds = [CONFIG_ACCOUNT_SEED],\n        bump,\n        constraint = network_state.config.authority == authority.key(),\n    )]\n    pub network_state: Account<'info, NetworkState>,\n    /// CHECK:\n    pub treasury: AccountInfo<'info>,\n}\n\n/// (**deprecated: see [`crate::RequestV2`]**) Request randomness.\n///\n/// ### Required accounts\n///\n/// *  (signer) payer – request and transaction fee payer\n/// *  (writable) network_state – VRF on-chain config PDA\n///    (see [`network_state_account_address`])\n/// *  (writable) (from VRF on-chain config) treasury – either SOL treasury or token treasury\n///    (see remaining accounts)\n/// *  (writable) request – randomness request PDA\n///    (see [`randomness_account_address`])\n/// *  system_program - system program account\n///\n/// ### Remaining accounts\n///\n/// If token fee configuration exists and given treasury equals token treasury,\n/// then remaining accounts are required:\n///\n/// *  (writable) token_payer – payer token wallet\n/// *  token_program_account – necessary to execute the transfer\n///\n/// ### Space calculation for account creation (request)\n///\n/// * 8 (anchor tag) + 32 (seed) + 64 (combined randomness) + 4 (response array length) + (32 (fulfiller pubkey) + 64 (fulfiller randomness))  * 7 (maximum number of responses)\n///\n#[derive(Accounts)]\n#[instruction(seed: [u8; 32])]\n#[deprecated(since = \"0.4.0\", note = \"See RequestV2\")]\npub struct Request<'info> {\n    #[account(mut)]\n    pub payer: Signer<'info>,\n    #[account(\n        mut,\n        seeds = [CONFIG_ACCOUNT_SEED],\n        bump,\n    )]\n    pub network_state: Account<'info, NetworkState>,\n    /// CHECK:\n    #[account(\n        mut,\n        constraint = network_state.config.treasury == treasury.key() ||\n        network_state.config.token_fee_config.as_ref().map(|x| x.treasury) == Some(treasury.key())\n        @ Error::UnknownTreasuryGiven)]\n    pub treasury: AccountInfo<'info>,\n    #[account(\n        init,\n        payer = payer,\n        space = 8 + Randomness::SIZE,\n        seeds = [RANDOMNESS_ACCOUNT_SEED, &seed],\n        bump,\n    )]\n    pub request: Account<'info, Randomness>,\n    pub system_program: Program<'info, System>,\n}\n\n/// (**deprecated: see [`crate::FulfillV2`]**) Fulfill randomness.\n///\n/// ### Required accounts\n///\n/// *  (signer) payer – transaction fee payer\n/// *  instruction_acc – sysvar instruction account\n/// *  (writable) network_state – VRF on-chain config PDA\n///    (see [`network_state_account_address`])\n/// *  (writable) request – randomness request PDA\n///    (see [`randomness_account_address`])\n#[derive(Accounts)]\n#[deprecated(since = \"0.4.0\", note = \"See FulfillV2\")]\npub struct Fulfill<'info> {\n    #[account(mut)]\n    pub payer: Signer<'info>,\n    /// CHECK:\n    pub instruction_acc: AccountInfo<'info>,\n    #[account(\n        mut,\n        seeds = [CONFIG_ACCOUNT_SEED],\n        bump,\n    )]\n    pub network_state: Account<'info, NetworkState>,\n    #[account(\n        mut,\n        seeds = [RANDOMNESS_ACCOUNT_SEED, &request.seed],\n        bump,\n    )]\n    pub request: Account<'info, Randomness>,\n}\n\n/// Request randomness.\n///\n/// ### Required accounts\n///\n/// *  (signer) payer – request and transaction fee payer\n/// *  (writable) network_state – VRF on-chain config PDA\n///    (see [`network_state_account_address`])\n/// *  (writable) (from VRF on-chain config) treasury – either SOL treasury or token treasury\n///    (see remaining accounts)\n/// *  (writable) request – randomness request PDA\n///    (see [`randomness_account_address`])\n/// *  system_program - system program account\n///\n/// ### Remaining accounts\n///\n/// If token fee configuration exists and given treasury equals token treasury,\n/// then remaining accounts are required:\n///\n/// *  (writable) token_payer – payer token wallet\n/// *  token_program_account – necessary to execute the transfer\n///\n/// ### Space calculation for account creation (request)\n///\n/// * 8 (anchor tag) + 32 (client) + 32 (seed) + 4 (response array length) + (32 (fulfiller pubkey) + 64 (fulfiller randomness))  * 7 (maximum number of responses)\n///\n#[derive(Accounts)]\n#[instruction(seed: [u8; 32])]\npub struct RequestV2<'info> {\n    #[account(mut)]\n    pub payer: Signer<'info>,\n    #[account(\n        mut,\n        seeds = [CONFIG_ACCOUNT_SEED],\n        bump,\n    )]\n    pub network_state: Account<'info, NetworkState>,\n    /// CHECK:\n    #[account(\n        mut,\n        constraint = network_state.config.treasury == treasury.key() ||\n        network_state.config.token_fee_config.as_ref().map(|x| x.treasury) == Some(treasury.key())\n        @ Error::UnknownTreasuryGiven)]\n    pub treasury: AccountInfo<'info>,\n    #[account(\n        init,\n        payer = payer,\n        space = 8 + RandomnessV2::PENDING_SIZE,\n        seeds = [RANDOMNESS_ACCOUNT_SEED, &seed],\n        bump,\n    )]\n    pub request: Account<'info, RandomnessV2>,\n    pub system_program: Program<'info, System>,\n}\n\n/// Fulfill randomness (v2).\n///\n/// ### Required accounts\n///\n/// *  (signer) payer – transaction fee payer\n/// *  instruction_acc – sysvar instruction account\n/// *  (writable) network_state – VRF on-chain config PDA\n///    (see [`network_state_account_address`])\n/// *  (writable) request – randomness request PDA\n///    (see [`randomness_account_address`])\n/// *  (writable) client - client account (see [`Randomness::client`])\n#[derive(Accounts)]\npub struct FulfillV2<'info> {\n    #[account(mut)]\n    pub payer: Signer<'info>,\n    /// CHECK:\n    pub instruction_acc: AccountInfo<'info>,\n    #[account(\n        mut,\n        seeds = [CONFIG_ACCOUNT_SEED],\n        bump,\n    )]\n    pub network_state: Account<'info, NetworkState>,\n    #[account(\n        mut,\n        seeds = [RANDOMNESS_ACCOUNT_SEED, request.seed()],\n        bump,\n    )]\n    pub request: Account<'info, RandomnessV2>,\n    /// CHECK: An address of this account is validated via anchor constraint\n    #[account(mut, constraint = *request.client() == client.key())]\n    pub client: AccountInfo<'info>,\n    pub system_program: Program<'info, System>,\n}\n","numLines":411,"startLine":1,"totalLines":411}}}
