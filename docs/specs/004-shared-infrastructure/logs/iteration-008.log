{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MZZ85Xo72u3cd6XLf3TuZa","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→pub mod error;\n     4→pub mod instructions;\n     5→pub mod state;\n     6→\n     7→use instructions::*;\n     8→\n     9→declare_id!(\"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\");\n    10→\n    11→#[program]\n    12→pub mod coinflip {\n    13→    use super::*;\n    14→\n    15→    pub fn initialize_config(\n    16→        ctx: Context<InitializeConfig>,\n    17→        oracle_authority: Pubkey,\n    18→        treasury: Pubkey,\n    19→    ) -> Result<()> {\n    20→        instructions::initialize_config::handler(ctx, oracle_authority, treasury)\n    21→    }\n    22→\n    23→    pub fn create_match(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    24→        instructions::create_match::handler(ctx, tier, side)\n    25→    }\n    26→\n    27→    pub fn join_match(ctx: Context<JoinMatch>) -> Result<()> {\n    28→        instructions::join_match::handler(ctx)\n    29→    }\n    30→\n    31→    pub fn resolve_match(ctx: Context<ResolveMatch>, randomness: [u8; 32]) -> Result<()> {\n    32→        instructions::resolve_match::handler(ctx, randomness)\n    33→    }\n    34→\n    35→    pub fn claim_payout(ctx: Context<ClaimPayout>) -> Result<()> {\n    36→        instructions::claim_payout::handler(ctx)\n    37→    }\n    38→\n    39→    pub fn cancel_match(ctx: Context<CancelMatch>) -> Result<()> {\n    40→        instructions::cancel_match::handler(ctx)\n    41→    }\n    42→\n    43→    pub fn timeout_cancel(ctx: Context<TimeoutCancel>) -> Result<()> {\n    44→        instructions::timeout_cancel::handler(ctx)\n    45→    }\n    46→\n    47→    pub fn force_close(ctx: Context<ForceClose>) -> Result<()> {\n    48→        instructions::force_close::handler(ctx)\n    49→    }\n    50→}\n    51→"}]},"parent_tool_use_id":"toolu_01RX2FV8ZQ3Cd91kTDeVny6B","session_id":"34