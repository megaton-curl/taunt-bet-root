8→    tokenFeeConfig?: OraoTokenFeeConfig | null;\n   199→    computeBudgetConfig: ComputeBudgetConfig;\n   200→    /**\n   201→     * Creates a new update_network instruction builder that updates nothing.\n   202→     *\n   203→     * @param vrf ORAO VRF program instance.\n   204→     */\n   205→    constructor(vrf: Orao);\n   206→    /** Change configuration authority. */\n   207→    with_authority(authority: web3.PublicKey): UpdateBuilder;\n   208→    /** Change treasury account address. */\n   209→    with_treasury(treasury: web3.PublicKey): UpdateBuilder;\n   210→    /** Change fee (in lamports). */\n   211→    with_fee(requestFee: BN): UpdateBuilder;\n   212→    /** Change fulfillment authorities. */\n   213→    with_fulfillment_authorities(fulfillmentAuthorities: web3.PublicKey[]): UpdateBuilder;\n   214→    /** Change token fee configuration. */\n   215→    with_token_fee_config(tokenFeeConfig: OraoTokenFeeConfig): UpdateBuilder;\n   216→    /**\n   217→     * Adds a prioritization fee in micro-lamports (applied per compute unit).\n   218→     *\n   219→     * Adds `ComputeBudgetInstruction::SetComputeUnitPrice` to the request builder.\n   220→     *\n   221→     * *   if not specified, then median fee of the last 150 confirmed\n   222→     *     slots is used (this is by default)\n   223→     * *   if zero, then compute unit price is not applied at all.\n   224→     */\n   225→    withComputeUnitPrice(computeUnitPrice: bigint): UpdateBuilder;\n   226→    /**\n   227→     * Defines a multiplier that is applied to a median compute unit price.\n   228→     *\n   229→     * This is only applied if no compute_unit_price specified, i.e. if compute unit price\n   230→     * is measured as a median fee of the last 150 confirmed slots.\n   231→     *\n   232→     * *   if not specified, then no multiplier is applied (this is by default)\n   233→     * *   if specified, then applied as follows: `compute_unit_price = median * multiplier`\n   234→     */\n   235→    withComputeUnitPriceMultiplier(multiplier: number): UpdateBuilder;\n   236→    /** Defines a specific compute unit limit that the transaction is allowed to consume.\n   237→     *\n   238→     * Adds `ComputeBudgetInstruction::SetComputeUnitLimit` to the request builder.\n   239→     *\n   240→     * *   if not specified, then compute unit limit is not applied at all\n   241→     *     (this is by default)\n   242→     * *   if specified, then applied as is\n   243→     */\n   244→    withComputeUnitLimit(computeUnitLimit: number): UpdateBuilder;\n   245→    /**\n   246→     * Returns a {@link MethodsBuilder} instance for the `UpdateNetwork` instruction.\n   247→     *\n   248→     * Note, that compute budget instructions will be prepended to the returned\n   249→     * instance (use {@link UpdateBuilder.withComputeUnitPrice} and\n   250→     * {@link UpdateBuilder.withComputeUnitLimit} to opt-out).\n   251→     */\n   252→    build(): Promise<MethodsBuilder<OraoVrf, AllInstructionsMap<OraoVrf>[\"updateNetwork\"]>>;\n   253→    /**\n   254→     * Performs an RPC call.\n   255→     *\n   256→     * @returns a transaction signature.\n   257→     */\n   258→    rpc(): Promise<string>;\n   259→}\n   260→/**\n   261→ * A convenient builder for the `Request` instruction.\n   262→ *\n   263→ * Note that by default it will guess and apply a prioritization fee (see\n   264→ * {@link RequestBuilder.withComputeUnitPrice} and {@link RequestBuilder.withComputeUnitLimit}\n   265→ * to opt-out)\n   266→ */\n   267→export declare class RequestBuilder {\n   268→    vrf: Orao;\n   269→    seed: Uint8Array;\n   270→    tokenWallet: web3.PublicKey | null;\n   271→    computeBudgetConfig: ComputeBudgetConfig;\n   272→    /**\n   273→     * Creates a randomness request builder (defaults to pay fees with SOL).\n   274→     *\n   275→     * @param vrf ORAO VRF program instance.\n   276→     * @param seed seed value (32 bytes).\n   277→     */\n   278→    constructor(vrf: Orao, seed: Uint8Array);\n   279→    /**\n   280→     * Pay fees with SPL token using given token wallet address.\n   281→     *\n   282→     * Instruction could fail if token fee is not configured for the contract\n   283→     * or given wallet is not a proper SPL wallet.\n   284→     *\n   285→     * @param tokenWallet SPL token wallet (belongs to a payer)\n   286→     */\n   287→    payWithToken(tokenWallet: web3.PublicKey): RequestBuilder;\n   288→    /**\n   289→     * Adds a prioritization fee in micro-lamports (applied per compute unit).\n   290→     *\n   291→     * Adds `ComputeBudgetInstruction::SetComputeUnitPrice` to the request builder.\n   292→     *\n   293→     * *   if not specified, then median fee of the last 150 confirmed\n   294→     *     slots is used (this is by default)\n   295→     * *   if zero, then compute unit price is not applied at all.\n   296→     */\n   297→    withComputeUnitPrice(computeUnitPrice: bigint): RequestBuilder;\n   298→    /**\n   299→     * Defines a multiplier that is applied to a median compute unit price.\n   300→     *\n   301→     * This is only applied if no compute_unit_price specified, i.e. if compute unit price\n   302→     * is measured as a median fee of the last 150 confirmed slots.\n   303→     *\n   304→     * *   if not specified, then no multiplier is applied (this is by default)\n   305→     * *   if specified, then applied as follows: `compute_unit_price = median * multiplier`\n   306→     */\n   307→    withComputeUnitPriceMultiplier(multiplier: number): RequestBuilder;\n   308→    /** Defines a specific compute unit limit that the transaction is allowed to consume.\n   309→     *\n   310→     * Adds `ComputeBudgetInstruction::SetComputeUnitLimit` to the request builder.\n   311→     *\n   312→     * *   if not specified, then compute unit limit is not applied at all\n   313→     *     (this is by default)\n   314→     * *   if specified, then applied as is\n   315→     */\n   316→    withComputeUnitLimit(computeUnitLi