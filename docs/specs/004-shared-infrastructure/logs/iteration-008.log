{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VFehWg3kFwH7kgBdutVTgm","type":"tool_result","content":"     1→use crate::consts;\n     2→use crate::solana::{system_program, Pubkey};\n     3→use crate::types::{RequestRandomness, SerializableAccountMeta};\n     4→\n     5→/// Parameters for creating a request randomness instruction\n     6→#[derive(Default)]\n     7→pub struct RequestRandomnessParams {\n     8→    pub payer: Pubkey,\n     9→    pub oracle_queue: Pubkey,\n    10→    pub callback_program_id: Pubkey,\n    11→    pub callback_discriminator: Vec<u8>,\n    12→    pub accounts_metas: Option<Vec<SerializableAccountMeta>>,\n    13→    pub caller_seed: [u8; 32],\n    14→    pub callback_args: Option<Vec<u8>>,\n    15→}\n    16→\n    17→pub fn create_request_randomness_ix(\n    18→    params: RequestRandomnessParams,\n    19→) -> solana_program::instruction::Instruction {\n    20→    solana_program::instruction::Instruction {\n    21→        program_id: consts::VRF_PROGRAM_ID,\n    22→        accounts: vec![\n    23→            solana_program::instruction::AccountMeta::new(params.payer, true),\n    24→            solana_program::instruction::AccountMeta::new_readonly(\n    25→                Pubkey::find_program_address(&[consts::IDENTITY], &params.callback_program_id).0,\n    26→                true,\n    27→            ),\n    28→            solana_program::instruction::AccountMeta::new(params.oracle_queue, false),\n    29→            solana_program::instruction::AccountMeta::new_readonly(system_program::ID, false),\n    30→            solana_program::instruction::AccountMeta::new_readonly(\n    31→                solana_program::sysvar::slot_hashes::ID,\n    32→                false,\n    33→            ),\n    34→        ],\n    35→        data: RequestRandomness {\n    36→            caller_seed: params.caller_seed,\n    37→            callback_program_id: params.callback_program_id,\n    38→            callback_discriminator: params.callback_discriminator,\n    39→            callback_accounts_metas: params.accounts_metas.unwrap_or_default(),\n    40→            callback_args: params.callback_args.unwrap_or_default(),\n    41→        }\n    42→        .to_bytes(),\n    43→    }\n    44→}\n    45→\n    46→pub fn create_request_regular_randomness_ix(\n    47→    params: RequestRandomnessParams,\n    48→) -> solana_program::instruction::Instruction {\n    49→    let mut ix = create_request_randomness_ix(params);\n    50→    ix.data[0] = 8;\n    51→    ix\n    52→}\n    53→"}]},"parent_tool_use_id":"toolu_01HEdZY3XjPm2YnBHKESmsur","session_id":"34433cb1-6ee0-432f-833f-aec143a4b7e1","uuid":"2b904487-7458-4580-a709-197dbe0cf5a8"}
