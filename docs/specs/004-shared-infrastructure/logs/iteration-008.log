{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QfUnkqeQevbGW1gPReyUPJ","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::{from_randomness, PHASE_LOCKED, PHASE_SETTLED};\n     3→\n     4→use crate::error::CoinflipError;\n     5→use crate::state::{CoinflipConfig, CoinflipMatch};\n     6→\n     7→#[derive(Accounts)]\n     8→pub struct ResolveMatch<'info> {\n     9→    /// Oracle authority: VRF_PROGRAM_IDENTITY in real mode, config keypair in mock mode.\n    10→    pub oracle: Signer<'info>,\n    11→\n    12→    /// The config PDA with oracle authority.\n    13→    #[account(\n    14→        seeds = [b\"coinflip_config\"],\n    15→        bump = config.bump,\n    16→    )]\n    17→    pub config: Account<'info, CoinflipConfig>,\n    18→\n    19→    /// The match PDA to resolve.\n    20→    #[account(\n    21→        mut,\n    22→        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    23→        bump = coinflip_match.bump,\n    24→    )]\n    25→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    26→}\n    27→\n    28→pub fn handler(ctx: Context<ResolveMatch>, randomness: [u8; 32]) -> Result<()> {\n    29→    let coinflip_match = &ctx.accounts.coinflip_match;\n    30→\n    31→    // Must be in LOCKED phase\n    32→    require!(\n    33→        coinflip_match.phase == PHASE_LOCKED,\n    34→        CoinflipError::InvalidPhase\n    35→    );\n    36→\n    37→    // Oracle must match config.oracle_authority.\n    38→    // On devnet this is VRF_PROGRAM_IDENTITY; in bankrun tests it's a test keypair.\n    39→    require!(\n    40→        ctx.accounts.oracle.key() == ctx.accounts.config.oracle_authority,\n    41→        CoinflipError::UnauthorizedOracle\n    42→    );\n    43→\n    44→    // Derive result from randomness\n    45→    let result = from_randomness(randomness[0]);\n    46→\n    47→    // Determine winner: if result matches creator_side, creator wins; otherwise opponent\n    48→    let winner = if result == coinflip_match.creator_side {\n    49→        coinflip_match.creator\n    50→    } else {\n    51→        coinflip_match.opponent\n    52→    };\n    53→\n    54→    // Update match state\n    55→    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    56→    coinflip_match.result = result;\n    57→    coinflip_match.winner = winner;\n    58→    coinflip_match.phase = PHASE_SETTLED;\n    59→\n    60→    Ok(())\n    61→}\n    62→"}]},"parent_tool_use_id":"toolu_01HEdZY3XjPm2YnBHKESmsur","session_id":"34433cb1-6ee0-432f-833f-aec143a4b7e1","uuid":"affa03ff-4193-4f53-8c0c-32d58a11e5de"}
