/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/lib.rs","content":"use anchor_lang::prelude::*;\n\npub mod error;\npub mod instructions;\npub mod state;\n\nuse instructions::*;\n\ndeclare_id!(\"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\");\n\n#[program]\npub mod coinflip {\n    use super::*;\n\n    pub fn initialize_config(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n        instructions::initialize_config::handler(ctx, treasury)\n    }\n\n    pub fn create_match(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n        instructions::create_match::handler(ctx, tier, side)\n    }\n\n    pub fn join_match(ctx: Context<JoinMatch>) -> Result<()> {\n        instructions::join_match::handler(ctx)\n    }\n\n    pub fn resolve_match(ctx: Context<ResolveMatch>, randomness: [u8; 32]) -> Result<()> {\n        instructions::resolve_match::handler(ctx, randomness)\n    }\n\n    pub fn claim_payout(ctx: Context<ClaimPayout>) -> Result<()> {\n        instructions::claim_payout::handler(ctx)\n    }\n\n    pub fn cancel_match(ctx: Context<CancelMatch>) -> Result<()> {\n        instructions::cancel_match::handler(ctx)\n    }\n\n    pub fn timeout_cancel(ctx: Context<TimeoutCancel>) -> Result<()> {\n        instructions::timeout_cancel::handler(ctx)\n    }\n\n    pub fn force_close(ctx: Context<ForceClose>) -> Result<()> {\n        instructions::force_close::handler(ctx)\n    }\n}\n","numLines":47,"startLine":1,"totalLines":47}}}
