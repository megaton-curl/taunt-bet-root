{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PM2AtCWQ4vK3bcJZ4TW2Vf","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::lifecycle::RoundPhase;\n     3→\n     4→/// Global configuration for the coinflip program.\n     5→/// PDA seeds: [b\"coinflip_config\"]\n     6→#[account]\n     7→#[derive(InitSpace)]\n     8→pub struct CoinflipConfig {\n     9→    /// Admin authority (can update config).\n    10→    pub authority: Pubkey,\n    11→    /// Fee destination wallet.\n    12→    pub treasury: Pubkey,\n    13→    /// Whether the game is paused (rejects new matches).\n    14→    pub paused: bool,\n    15→    /// Bump seed for PDA derivation.\n    16→    pub bump: u8,\n    17→}\n    18→\n    19→/// A coinflip match between two players.\n    20→/// PDA seeds: [b\"match\", creator.key().as_ref()]\n    21→#[account]\n    22→#[derive(InitSpace)]\n    23→pub struct CoinflipMatch {\n    24→    /// The player who created the match.\n    25→    pub creator: Pubkey,\n    26→    /// The player who joined (Pubkey::default() if empty).\n    27→    pub opponent: Pubkey,\n    28→    /// Tier index (0-5).\n    29→    pub tier: u8,\n    30→    /// Entry amount in lamports (derived from tier).\n    31→    pub entry_amount: u64,\n    32→    /// Side chosen by creator (0 = Heads, 1 = Tails).\n    33→    pub creator_side: u8,\n    34→    /// Current phase of the match (shared lifecycle enum).\n    35→    pub phase: RoundPhase,\n    36→    /// The winning side after VRF resolution (0 or 1, only valid when settled).\n    37→    pub result: u8,\n    38→    /// The winner's pubkey (Pubkey::default() until settled).\n    39→    pub winner: Pubkey,\n    40→    /// Whether the payout has been claimed.\n    41→    pub claimed: bool,\n    42→    /// Unix timestamp when the match entered LOCKED phase (0 if still WAITING).\n    43→    pub locked_at: i64,\n    44→    /// Deadline for VRF resolution; after this, timeout refund is available.\n    45→    pub resolve_deadline: i64,\n    46→    /// Address of the Orao randomness PDA for VRF lookup at claim time.\n    47→    pub vrf_request_key: Pubkey,\n    48→    /// Bump seed for PDA derivation.\n    49→    pub bump: u8,\n    50→}\n    51→\n    52→/// Event emitted when a match is settled via claim_payout.\n    53→#[event]\n    54→pub struct MatchSettled {\n    55→    pub creator: Pubkey,\n    56→    pub opponent: Pubkey,\n    57→    pub winner: Pubkey,\n    58→    pub randomness: [u8; 32],\n    59→    pub payout_amount: u64,\n    60→    pub fee_amount: u64,\n    61→}\n    62→"}]},"parent_tool_use_id":null,"session_id":"1cdc65df-3102-470b-b95b-aac0191639cb","uuid":"aae9b8f5-3039-4779-8371-80cccc1a986c","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/state.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::lifecycle::RoundPhase;\n\n/// Global configuration for the coinflip program.\n/// PDA seeds: [b\"coinflip_config\"]\n#[account]\n#[derive(InitSpace)]\npub struct CoinflipConfig {\n    /// Admin authority (can update config).\n    pub authority: Pubkey,\n    /// Fee destination wallet.\n    pub treasury: Pubkey,\n    /// Whether the game is paused (rejects new matches).\n    pub paused: bool,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// A coinflip match between two players.\n/// PDA seeds: [b\"match\", creator.key().as_ref()]\n#[account]\n#[derive(InitSpace)]\npub struct CoinflipMatch {\n    /// The player who created the match.\n    pub creator: Pubkey,\n    /// The player who joined (Pubkey::default() if empty).\n    pub opponent: Pubkey,\n    /// Tier index (0-5).\n    pub tier: u8,\n    /// Entry amount in lamports (derived from tier).\n    pub entry_amount: u64,\n    /// Side chosen by creator (0 = Heads, 1 = Tails).\n    pub creator_side: u8,\n    /// Current phase of the match (shared lifecycle enum).\n    pub phase: RoundPhase,\n    /// The winning side after VRF resolution (0 or 1, only valid when settled).\n    pub result: u8,\n    /// The winner's pubkey (Pubkey::default() until settled).\n    pub winner: Pubkey,\n    /// Whether the payout has been claimed.\n    pub claimed: bool,\n    /// Unix timestamp when the match entered LOCKED phase (0 if still WAITING).\n    pub locked_at: i64,\n    /// Deadline for VRF resolution; after this, timeout refund is available.\n    pub resolve_deadline: i64,\n    /// Address of the Orao randomness PDA for VRF lookup at claim time.\n    pub vrf_request_key: Pubkey,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// Event emitted when a match is settled via claim_payout.\n#[event]\npub struct MatchSettled {\n    pub creator: Pubkey,\n    pub opponent: Pubkey,\n    pub winner: Pubkey,\n    pub randomness: [u8; 32],\n    pub payout_amount: u64,\n    pub fee_amount: u64,\n}\n","numLines":62,"startLine":1,"totalLines":62}}}
