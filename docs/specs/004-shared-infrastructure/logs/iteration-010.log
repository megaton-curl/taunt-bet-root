{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UA8qNxYdubtvkfNQdGGS6B","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::system_program;\n     3→use rng_shared::constants::is_valid_side;\n     4→use rng_shared::lifecycle::RoundPhase;\n     5→use rng_shared::tiers::get_tier_amount;\n     6→\n     7→use crate::error::CoinflipError;\n     8→use crate::state::CoinflipMatch;\n     9→\n    10→#[derive(Accounts)]\n    11→pub struct CreateMatch<'info> {\n    12→    /// The player creating the match. Must sign and fund the escrow.\n    13→    #[account(mut)]\n    14→    pub creator: Signer<'info>,\n    15→\n    16→    /// The match PDA. Seeds enforce one active match per creator.\n    17→    #[account(\n    18→        init,\n    19→        payer = creator,\n    20→        space = 8 + CoinflipMatch::INIT_SPACE,\n    21→        seeds = [b\"match\", creator.key().as_ref()],\n    22→        bump,\n    23→    )]\n    24→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    25→\n    26→    pub system_program: Program<'info, System>,\n    27→}\n    28→\n    29→pub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    30→    require!(is_valid_side(side), CoinflipError::InvalidSide);\n    31→\n    32→    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n    33→\n    34→    // Transfer entry_amount from creator to match PDA (escrow)\n    35→    system_program::transfer(\n    36→        CpiContext::new(\n    37→            ctx.accounts.system_program.to_account_info(),\n    38→            system_program::Transfer {\n    39→                from: ctx.accounts.creator.to_account_info(),\n    40→                to: ctx.accounts.coinflip_match.to_account_info(),\n    41→            },\n    42→        ),\n    43→        entry_amount,\n    44→    )?;\n    45→\n    46→    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    47→    coinflip_match.creator = ctx.accounts.creator.key();\n    48→    coinflip_match.opponent = Pubkey::default();\n    49→    coinflip_match.tier = tier;\n    50→    coinflip_match.entry_amount = entry_amount;\n    51→    coinflip_match.creator_side = side;\n    52→    coinflip_match.phase = RoundPhase::Waiting;\n    53→    coinflip_match.result = 0;\n    54→    coinflip_match.winner = Pubkey::default();\n    55→    coinflip_match.claimed = false;\n    56→    coinflip_match.resolve_deadline = 0;\n    57→    coinflip_match.vrf_request_key = Pubkey::default();\n    58→    coinflip_match.bump = ctx.bumps.coinflip_match;\n    59→\n    60→    Ok(())\n    61→}\n    62→"}]},"parent_tool_use_id":null,"session_id":"1cdc65df-3102-470b-b95b-aac0191639cb","uuid":"8cc89e97-91fb-47c7-ada8-024b90eab226","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/create_match.rs","content":"use anchor_lang::prelude::*;\nuse anchor_lang::system_program;\nuse rng_shared::constants::is_valid_side;\nuse rng_shared::lifecycle::RoundPhase;\nuse rng_shared::tiers::get_tier_amount;\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct CreateMatch<'info> {\n    /// The player creating the match. Must sign and fund the escrow.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA. Seeds enforce one active match per creator.\n    #[account(\n        init,\n        payer = creator,\n        space = 8 + CoinflipMatch::INIT_SPACE,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    require!(is_valid_side(side), CoinflipError::InvalidSide);\n\n    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n\n    // Transfer entry_amount from creator to match PDA (escrow)\n    system_program::transfer(\n        CpiContext::new(\n            ctx.accounts.system_program.to_account_info(),\n            system_program::Transfer {\n                from: ctx.accounts.creator.to_account_info(),\n                to: ctx.accounts.coinflip_match.to_account_info(),\n            },\n        ),\n        entry_amount,\n    )?;\n\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.creator = ctx.accounts.creator.key();\n    coinflip_match.opponent = Pubkey::default();\n    coinflip_match.tier = tier;\n    coinflip_match.entry_amount = entry_amount;\n    coinflip_match.creator_side = side;\n    coinflip_match.phase = RoundPhase::Waiting;\n    coinflip_match.result = 0;\n    coinflip_match.winner = Pubkey::default();\n    coinflip_match.claimed = false;\n    coinflip_match.resolve_deadline = 0;\n    coinflip_match.vrf_request_key = Pubkey::default();\n    coinflip_match.bump = ctx.bumps.coinflip_match;\n\n    Ok(())\n}\n","numLines":62,"startLine":1,"totalLines":62}}}
