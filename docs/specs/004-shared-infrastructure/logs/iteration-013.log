{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gw9cZwnZZbXzRjgHQVc6Bv","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Default timeout (seconds) after which a LOCKED/RESOLVING round can be refunded.\n     4→pub const DEFAULT_RESOLVE_TIMEOUT_SECONDS: i64 = 120;\n     5→\n     6→#[error_code]\n     7→pub enum TimeoutError {\n     8→    #[msg(\"Resolve deadline has been exceeded\")]\n     9→    ResolveDeadlineExceeded,\n    10→}\n    11→\n    12→/// Returns `true` when the current time is at or past the resolve deadline.\n    13→pub fn is_expired(resolve_deadline: i64, now: i64) -> bool {\n    14→    now >= resolve_deadline\n    15→}\n    16→\n    17→/// Returns `Ok(())` if the deadline has NOT been exceeded, or an error if it has.\n    18→pub fn enforce_not_expired(resolve_deadline: i64, now: i64) -> Result<()> {\n    19→    if is_expired(resolve_deadline, now) {\n    20→        Err(TimeoutError::ResolveDeadlineExceeded.into())\n    21→    } else {\n    22→        Ok(())\n    23→    }\n    24→}\n    25→\n    26→#[cfg(test)]\n    27→mod tests {\n    28→    use super::*;\n    29→\n    30→    #[test]\n    31→    fn expired_exactly_at_deadline() {\n    32→        assert!(is_expired(1000, 1000));\n    33→    }\n    34→\n    35→    #[test]\n    36→    fn not_expired_one_second_before() {\n    37→        assert!(!is_expired(1000, 999));\n    38→    }\n    39→\n    40→    #[test]\n    41→    fn expired_one_second_after() {\n    42→        assert!(is_expired(1000, 1001));\n    43→    }\n    44→\n    45→    #[test]\n    46→    fn enforce_not_expired_ok_before_deadline() {\n    47→        assert!(enforce_not_expired(1000, 999).is_ok());\n    48→    }\n    49→\n    50→    #[test]\n    51→    fn enforce_not_expired_fails_at_deadline() {\n    52→        assert!(enforce_not_expired(1000, 1000).is_err());\n    53→    }\n    54→\n    55→    #[test]\n    56→    fn enforce_not_expired_fails_after_deadline() {\n    57→        assert!(enforce_not_expired(1000, 1001).is_err());\n    58→    }\n    59→}\n    60→"}]},"parent_tool_use_id":null,"session_id":"cc42e584-26b8-4b3e-985d-452c2ef4242f","uuid":"15b52e05-5fcb-4df9-8355-81be72e53fc0","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/timeout.rs","content":"use anchor_lang::prelude::*;\n\n/// Default timeout (seconds) after which a LOCKED/RESOLVING round can be refunded.\npub const DEFAULT_RESOLVE_TIMEOUT_SECONDS: i64 = 120;\n\n#[error_code]\npub enum TimeoutError {\n    #[msg(\"Resolve deadline has been exceeded\")]\n    ResolveDeadlineExceeded,\n}\n\n/// Returns `true` when the current time is at or past the resolve deadline.\npub fn is_expired(resolve_deadline: i64, now: i64) -> bool {\n    now >= resolve_deadline\n}\n\n/// Returns `Ok(())` if the deadline has NOT been exceeded, or an error if it has.\npub fn enforce_not_expired(resolve_deadline: i64, now: i64) -> Result<()> {\n    if is_expired(resolve_deadline, now) {\n        Err(TimeoutError::ResolveDeadlineExceeded.into())\n    } else {\n        Ok(())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn expired_exactly_at_deadline() {\n        assert!(is_expired(1000, 1000));\n    }\n\n    #[test]\n    fn not_expired_one_second_before() {\n        assert!(!is_expired(1000, 999));\n    }\n\n    #[test]\n    fn expired_one_second_after() {\n        assert!(is_expired(1000, 1001));\n    }\n\n    #[test]\n    fn enforce_not_expired_ok_before_deadline() {\n        assert!(enforce_not_expired(1000, 999).is_ok());\n    }\n\n    #[test]\n    fn enforce_not_expired_fails_at_deadline() {\n        assert!(enforce_not_expired(1000, 1000).is_err());\n    }\n\n    #[test]\n    fn enforce_not_expired_fails_after_deadline() {\n        assert!(enforce_not_expired(1000, 1001).is_err());\n    }\n}\n","numLines":60,"startLine":1,"totalLines":60}}}
