," ","     // Account is closed by Anchor's `close = creator` constraint —","     // remaining lamports (rent) are returned to creator."]}],"originalFile":"use anchor_lang::prelude::*;\nuse rng_shared::constants::LOCK_TIMEOUT_SECONDS;\nuse rng_shared::lifecycle::RoundPhase;\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct TimeoutCancel<'info> {\n    /// Either the creator or opponent can trigger a timeout cancel.\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The creator's account — receives rent refund.\n    /// CHECK: Validated against coinflip_match.creator.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent's account — receives entry refund.\n    /// CHECK: Validated against coinflip_match.opponent.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n}\n\npub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in LOCKED phase\n    require!(\n        coinflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n\n    // Caller must be either creator or opponent\n    let caller = ctx.accounts.caller.key();\n    require!(\n        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n        CoinflipError::UnauthorizedCaller\n    );\n\n    // Validate passed accounts match stored keys\n    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n\n    // Check timeout has elapsed\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        now - coinflip_match.locked_at >= LOCK_TIMEOUT_SECONDS,\n        CoinflipError::LockTimeoutNotElapsed\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n\n    // Refund both players their entry amounts from escrow\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    **ctx.accounts.creator.try_borrow_mut_lamports()? += entry_amount;\n\n    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    **ctx.accounts.opponent.try_borrow_mut_lamports()? += entry_amount;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // remaining lamports (rent) are returned to creator.\n\n    Ok(())\n}\n"}}
