{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01J7VA8vz3c6cxFLADci9ryM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XHt9zy6CBKeai1WkA16Enf","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/timeout_cancel.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_from_pda;\nuse rng_shared::lifecycle::{self, RoundPhase};\nuse rng_shared::timeout::is_expired;\nuse rng_shared::vrf_orao::{is_fulfilled, read_orao_randomness};\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct TimeoutCancel<'info> {\n    /// Any signer can trigger a timeout cancel (permissionless after deadline).\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The creator's account — receives entry refund + rent.\n    /// CHECK: Validated against coinflip_match.creator.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent's account — receives entry refund.\n    /// CHECK: Validated against coinflip_match.opponent.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The Orao randomness PDA — used to check VRF is NOT fulfilled.\n    /// CHECK: Key validated against coinflip_match.vrf_request_key; data read by shared VRF helper.\n    pub randomness_account: AccountInfo<'info>,\n}\n\npub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in LOCKED phase\n    require!(\n        coinflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n\n    // Validate passed accounts match stored keys\n    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n    require_keys_eq!(\n        ctx.accounts.randomness_account.key(),\n        coinflip_match.vrf_request_key\n    );\n\n    // Check timeout has elapsed using shared helper\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        is_expired(coinflip_match.resolve_deadline, now),\n        CoinflipError::LockTimeoutNotElapsed\n    );\n\n    // Check that VRF randomness is NOT fulfilled — if it is, must use claim_payout instead.\n    // read_orao_randomness returns Ok([u8;32]) if fulfilled, Err if not.\n    // We try to read; if it succeeds and is fulfilled, reject the timeout cancel.\n    let vrf_is_fulfilled = read_orao_randomness(&ctx.accounts.randomness_account)\n        .map(|r| is_fulfilled(&r))\n        .unwrap_or(false);\n    require!(!vrf_is_fulfilled, CoinflipError::InvalidPhase);\n\n    let entry_amount = coinflip_match.entry_amount;\n\n    // Refund both players their entry amounts using shared escrow helper\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.creator, entry_amount)?;\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.opponent, entry_amount)?;\n\n    // Transition to Refunded via shared lifecycle\n    lifecycle::transition(coinflip_match.phase, RoundPhase::Refunded)?;\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.phase = RoundPhase::Refunded;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // remaining lamports (rent) are returned to creator.\n\n    Ok(())\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3769,"cache_read_input_tokens":56244,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3769},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cc42e584-26b8-4b3e-985d-452c2ef4242f","uuid":"9b525923-b33a-4a17-8aed-b72f97ba6df0"}
