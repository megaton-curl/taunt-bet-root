{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wr5Abe8eqq6AsA7aa7Jmbi","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Audit fields stored on match/round accounts for VRF traceability.\n     4→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, InitSpace)]\n     5→pub struct VrfAuditFields {\n     6→    /// Address of the Orao randomness PDA for this match/round.\n     7→    pub vrf_request_key: Pubkey,\n     8→    /// Unix timestamp when VRF was requested.\n     9→    pub vrf_requested_at: i64,\n    10→}\n    11→\n    12→/// Error codes for VRF operations.\n    13→#[error_code]\n    14→pub enum VrfError {\n    15→    /// Randomness has not been fulfilled by the VRF oracle.\n    16→    #[msg(\"VRF randomness not yet fulfilled\")]\n    17→    RandomnessNotFulfilled,\n    18→}\n    19→\n    20→/// Returns true if the 32-byte randomness is non-zero (i.e., fulfilled).\n    21→pub fn is_fulfilled(randomness: &[u8; 32]) -> bool {\n    22→    randomness.iter().any(|&b| b != 0)\n    23→}\n    24→\n    25→// ---------------------------------------------------------------------------\n    26→// Real Orao mode — CPI into Orao VRF program\n    27→// ---------------------------------------------------------------------------\n    28→\n    29→/// CPI into Orao VRF to request randomness.\n    30→#[cfg(not(feature = \"mock-vrf\"))]\n    31→pub fn request_orao_randomness<'info>(\n    32→    orao_program: &AccountInfo<'info>,\n    33→    network_state: &AccountInfo<'info>,\n    34→    treasury: &AccountInfo<'info>,\n    35→    random: &AccountInfo<'info>,\n    36→    payer: &AccountInfo<'info>,\n    37→    system_program: &AccountInfo<'info>,\n    38→    seed: [u8; 32],\n    39→) -> Result<()> {\n    40→    let cpi_accounts = orao_solana_vrf::cpi::accounts::RequestV2 {\n    41→        payer: payer.clone(),\n    42→        network_state: network_state.clone(),\n    43→        treasury: treasury.clone(),\n    44→        request: random.clone(),\n    45→        system_program: system_program.clone(),\n    46→    };\n    47→    let cpi_ctx = CpiContext::new(orao_program.clone(), cpi_accounts);\n    48→    orao_solana_vrf::cpi::request_v2(cpi_ctx, seed)\n    49→}\n    50→\n    51→/// Read fulfilled randomness from an Orao randomness account.\n    52→///\n    53→/// Deserializes the Orao `RandomnessAccountData` (supports both V1 and V2\n    54→/// accounts) and returns the first 32 bytes of the 64-byte randomness.\n    55→/// Returns an error if randomness has not been fulfilled yet.\n    56→#[cfg(not(feature = \"mock-vrf\"))]\n    57→pub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    58→    use anchor_lang::AccountDeserialize;\n    59→\n    60→    let data = randomness_account.try_borrow_data()?;\n    61→    let mut buf: &[u8] = &data;\n    62→    let account_data =\n    63→        orao_solana_vrf::state::RandomnessAccountData::try_deserialize_unchecked(&mut buf)?;\n    64→\n    65→    match account_data.fulfilled_randomness() {\n    66→        Some(randomness_64) => {\n    67→            let mut result = [0u8; 32];\n    68→            result.copy_from_slice(&randomness_64[..32]);\n    69→            Ok(result)\n    70→        }\n    71→        None => Err(error!(VrfError::RandomnessNotFulfilled)),\n    72→    }\n    73→}\n    74→\n    75→// ---------------------------------------------------------------------------\n    76→// Mock VRF mode — no Orao CPI, reads raw bytes from test account\n    77→// ---------------------------------------------------------------------------\n    78→\n    79→/// No-op in mock mode. Test authority writes mock randomness directly.\n    80→#[cfg(feature = \"mock-vrf\")]\n    81→pub fn request_orao_randomness<'info>(\n    82→    _orao_program: &AccountInfo<'info>,\n    83→    _network_state: &AccountInfo<'info>,\n    84→    _treasury: &AccountInfo<'info>,\n    85→    _random: &AccountInfo<'info>,\n    86→    _payer: &AccountInfo<'info>,\n    87→    _system_program: &AccountInfo<'info>,\n    88→    _seed: [u8; 32],\n    89→) -> Result<()> {\n    90→    Ok(())\n    91→}\n    92→\n    93→/// In mock mode, reads raw 32 bytes from account data as randomness.\n    94→/// All-zeros = unfulfilled (returns error).\n    95→#[cfg(feature = \"mock-vrf\")]\n    96→pub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    97→    let data = randomness_account.try_borrow_data()?;\n    98→    require!(data.len() >= 32, VrfError::RandomnessNotFulfilled);\n    99→\n   100→    let mut randomness = [0u8; 32];\n   101→    randomness.copy_from_slice(&data[..32]);\n   102→\n   103→    require!(is_fulfilled(&randomness), VrfError::RandomnessNotFulfilled);\n   104→    Ok(randomness)\n   105→}\n   106→\n   107→#[cfg(test)]\n   108→mod tests {\n   109→    use super::*;\n   110→\n   111→    #[test]\n   112→    fn test_is_fulfilled_all_zeros() {\n   113→        let zeros = [0u8; 32];\n   114→        assert!(!is_fulfilled(&zeros));\n   115→    }\n   116→\n   117→    #[test]\n   118→    fn test_is_fulfilled_non_zero() {\n   119→        let mut data = [0u8; 32];\n   120→        data[0] = 1;\n   121→        assert!(is_fulfilled(&data));\n   122→    }\n   123→\n   124→    #[test]\n   125→    fn test_is_fulfilled_all_ones() {\n   126→        let ones = [0xFF; 32];\n   127→        assert!(is_fulfilled(&ones));\n   128→    }\n   129→\n   130→    #[test]\n   131→    fn test_is_fulfilled_single_byte_set() {\n   132→        let mut data = [0u8; 32];\n   133→        data[31] = 42;\n   134→        assert!(is_fulfilled(&data));\n   135→    }\n   136→\n   137→    #[test]\n   138→    fn test_vrf_audit_fields_size() {\n   139→        // Pubkey (32) + i64 (8) = 40 bytes\n   140→        assert_eq!(<VrfAuditFields as anchor_lang::Space>::INIT_SPACE, 40);\n   141→    }\n   142→}\n   143→"}]},"parent_tool_use_id":null,"session_id":"cc42e584-26b8-4b3e-985d-452c2ef4242f","uuid":"425187ea-2c01-4b04-8b86-549c06628911","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/vrf_orao.rs","content":"use anchor_lang::prelude::*;\n\n/// Audit fields stored on match/round accounts for VRF traceability.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, InitSpace)]\npub struct VrfAuditFields {\n    /// Address of the Orao randomness PDA for this match/round.\n    pub vrf_request_key: Pubkey,\n    /// Unix timestamp when VRF was requested.\n    pub vrf_requested_at: i64,\n}\n\n/// Error codes for VRF operations.\n#[error_code]\npub enum VrfError {\n    /// Randomness has not been fulfilled by the VRF oracle.\n    #[msg(\"VRF randomness not yet fulfilled\")]\n    RandomnessNotFulfilled,\n}\n\n/// Returns true if the 32-byte randomness is non-zero (i.e., fulfilled).\npub fn is_fulfilled(randomness: &[u8; 32]) -> bool {\n    randomness.iter().any(|&b| b != 0)\n}\n\n// ---------------------------------------------------------------------------\n// Real Orao mode — CPI into Orao VRF program\n// ---------------------------------------------------------------------------\n\n/// CPI into Orao VRF to request randomness.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn request_orao_randomness<'info>(\n    orao_program: &AccountInfo<'info>,\n    network_state: &AccountInfo<'info>,\n    treasury: &AccountInfo<'info>,\n    random: &AccountInfo<'info>,\n    payer: &AccountInfo<'info>,\n    system_program: &AccountInfo<'info>,\n    seed: [u8; 32],\n) -> Result<()> {\n    let cpi_accounts = orao_solana_vrf::cpi::accounts::RequestV2 {\n        payer: payer.clone(),\n        network_state: network_state.clone(),\n        treasury: treasury.clone(),\n        request: random.clone(),\n        system_program: system_program.clone(),\n    };\n    let cpi_ctx = CpiContext::new(orao_program.clone(), cpi_accounts);\n    orao_solana_vrf::cpi::request_v2(cpi_ctx, seed)\n}\n\n/// Read fulfilled randomness from an Orao randomness account.\n///\n/// Deserializes the Orao `RandomnessAccountData` (supports both V1 and V2\n/// accounts) and returns the first 32 bytes of the 64-byte randomness.\n/// Returns an error if randomness has not been fulfilled yet.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    use anchor_lang::AccountDeserialize;\n\n    let data = randomness_account.try_borrow_data()?;\n    let mut buf: &[u8] = &data;\n    let account_data =\n        orao_solana_vrf::state::RandomnessAccountData::try_deserialize_unchecked(&mut buf)?;\n\n    match account_data.fulfilled_randomness() {\n        Some(randomness_64) => {\n            let mut result = [0u8; 32];\n            result.copy_from_slice(&randomness_64[..32]);\n            Ok(result)\n        }\n        None => Err(error!(VrfError::RandomnessNotFulfilled)),\n    }\n}\n\n// ---------------------------------------------------------------------------\n// Mock VRF mode — no Orao CPI, reads raw bytes from test account\n// ---------------------------------------------------------------------------\n\n/// No-op in mock mode. Test authority writes mock randomness directly.\n#[cfg(feature = \"mock-vrf\")]\npub fn request_orao_randomness<'info>(\n    _orao_program: &AccountInfo<'info>,\n    _network_state: &AccountInfo<'info>,\n    _treasury: &AccountInfo<'info>,\n    _random: &AccountInfo<'info>,\n    _payer: &AccountInfo<'info>,\n    _system_program: &AccountInfo<'info>,\n    _seed: [u8; 32],\n) -> Result<()> {\n    Ok(())\n}\n\n/// In mock mode, reads raw 32 bytes from account data as randomness.\n/// All-zeros = unfulfilled (returns error).\n#[cfg(feature = \"mock-vrf\")]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    let data = randomness_account.try_borrow_data()?;\n    require!(data.len() >= 32, VrfError::RandomnessNotFulfilled);\n\n    let mut randomness = [0u8; 32];\n    randomness.copy_from_slice(&data[..32]);\n\n    require!(is_fulfilled(&randomness), VrfError::RandomnessNotFulfilled);\n    Ok(randomness)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_is_fulfilled_all_zeros() {\n        let zeros = [0u8; 32];\n        assert!(!is_fulfilled(&zeros));\n    }\n\n    #[test]\n    fn test_is_fulfilled_non_zero() {\n        let mut data = [0u8; 32];\n        data[0] = 1;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_is_fulfilled_all_ones() {\n        let ones = [0xFF; 32];\n        assert!(is_fulfilled(&ones));\n    }\n\n    #[test]\n    fn test_is_fulfilled_single_byte_set() {\n        let mut data = [0u8; 32];\n        data[31] = 42;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_vrf_audit_fields_size() {\n        // Pubkey (32) + i64 (8) = 40 bytes\n        assert_eq!(<VrfAuditFields as anchor_lang::Space>::INIT_SPACE, 40);\n    }\n}\n","numLines":143,"startLine":1,"totalLines":143}}}
