{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YGZmeFppVQnCBBT6vUG6uE","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::LOCK_TIMEOUT_SECONDS;\n     3→use rng_shared::lifecycle::RoundPhase;\n     4→\n     5→use crate::error::CoinflipError;\n     6→use crate::state::CoinflipMatch;\n     7→\n     8→#[derive(Accounts)]\n     9→pub struct TimeoutCancel<'info> {\n    10→    /// Either the creator or opponent can trigger a timeout cancel.\n    11→    #[account(mut)]\n    12→    pub caller: Signer<'info>,\n    13→\n    14→    /// The creator's account — receives rent refund.\n    15→    /// CHECK: Validated against coinflip_match.creator.\n    16→    #[account(mut)]\n    17→    pub creator: AccountInfo<'info>,\n    18→\n    19→    /// The opponent's account — receives entry refund.\n    20→    /// CHECK: Validated against coinflip_match.opponent.\n    21→    #[account(mut)]\n    22→    pub opponent: AccountInfo<'info>,\n    23→\n    24→    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    25→    #[account(\n    26→        mut,\n    27→        close = creator,\n    28→        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    29→        bump = coinflip_match.bump,\n    30→    )]\n    31→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    32→}\n    33→\n    34→pub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    35→    let coinflip_match = &ctx.accounts.coinflip_match;\n    36→\n    37→    // Must be in LOCKED phase\n    38→    require!(\n    39→        coinflip_match.phase == RoundPhase::Locked,\n    40→        CoinflipError::InvalidPhase\n    41→    );\n    42→\n    43→    // Caller must be either creator or opponent\n    44→    let caller = ctx.accounts.caller.key();\n    45→    require!(\n    46→        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n    47→        CoinflipError::UnauthorizedCaller\n    48→    );\n    49→\n    50→    // Validate passed accounts match stored keys\n    51→    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    52→    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n    53→\n    54→    // Check timeout has elapsed\n    55→    let now = Clock::get()?.unix_timestamp;\n    56→    require!(\n    57→        now - coinflip_match.locked_at >= LOCK_TIMEOUT_SECONDS,\n    58→        CoinflipError::LockTimeoutNotElapsed\n    59→    );\n    60→\n    61→    let entry_amount = coinflip_match.entry_amount;\n    62→\n    63→    // Refund both players their entry amounts from escrow\n    64→    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    65→    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    66→    **ctx.accounts.creator.try_borrow_mut_lamports()? += entry_amount;\n    67→\n    68→    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    69→    **ctx.accounts.opponent.try_borrow_mut_lamports()? += entry_amount;\n    70→\n    71→    // Account is closed by Anchor's `close = creator` constraint —\n    72→    // remaining lamports (rent) are returned to creator.\n    73→\n    74→    Ok(())\n    75→}\n    76→"}]},"parent_tool_use_id":null,"session_id":"cc42e584-26b8-4b3e-985d-452c2ef4242f","uuid":"29a39d90-a42c-4e89-ad92-0eb8ee60f2e3","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/timeout_cancel.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::constants::LOCK_TIMEOUT_SECONDS;\nuse rng_shared::lifecycle::RoundPhase;\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct TimeoutCancel<'info> {\n    /// Either the creator or opponent can trigger a timeout cancel.\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The creator's account — receives rent refund.\n    /// CHECK: Validated against coinflip_match.creator.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent's account — receives entry refund.\n    /// CHECK: Validated against coinflip_match.opponent.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n}\n\npub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in LOCKED phase\n    require!(\n        coinflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n\n    // Caller must be either creator or opponent\n    let caller = ctx.accounts.caller.key();\n    require!(\n        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n        CoinflipError::UnauthorizedCaller\n    );\n\n    // Validate passed accounts match stored keys\n    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n\n    // Check timeout has elapsed\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        now - coinflip_match.locked_at >= LOCK_TIMEOUT_SECONDS,\n        CoinflipError::LockTimeoutNotElapsed\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n\n    // Refund both players their entry amounts from escrow\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    **ctx.accounts.creator.try_borrow_mut_lamports()? += entry_amount;\n\n    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    **ctx.accounts.opponent.try_borrow_mut_lamports()? += entry_amount;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // remaining lamports (rent) are returned to creator.\n\n    Ok(())\n}\n","numLines":76,"startLine":1,"totalLines":76}}}
