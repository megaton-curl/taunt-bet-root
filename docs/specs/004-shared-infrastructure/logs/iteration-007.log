{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JDv6k1PNCBsr8qokBjrWtR","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/cpi.rs has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"c02d31dc-7289-45e7-92f4-faacb953998d","uuid":"cec7cd59-934f-46f5-ba22-654e8e94e6da","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/cpi.rs","oldString":"use anchor_lang::prelude::*;\nuse anchor_lang::solana_program::{\n    instruction::{AccountMeta, Instruction},\n    program::invoke_signed,\n};","newString":"use anchor_lang::prelude::*;\nuse anchor_lang::solana_program::{\n    instruction::{AccountMeta, Instruction},\n    program::invoke_signed,\n};\nuse solana_sha256_hasher::hashv;","originalFile":"use anchor_lang::prelude::*;\nuse anchor_lang::solana_program::{\n    instruction::{AccountMeta, Instruction},\n    program::invoke_signed,\n};\n\n/// Calls the platform program's `update_player_profile` instruction via CPI.\n///\n/// If the profile account has no data (player hasn't created a profile), the call\n/// is silently skipped — returns `Ok(())` without emitting a CPI.\n///\n/// This helper constructs the CPI instruction manually (discriminator + borsh args)\n/// to avoid a circular dependency between `rng-shared` and `platform`.\n///\n/// # Arguments\n///\n/// * `platform_program` — The platform program account.\n/// * `profile` — The player's profile PDA (mutable). Skipped if empty.\n/// * `authority` — The game config PDA that signs the CPI.\n/// * `signer_seeds` — Seeds for PDA signing (e.g., `&[b\"coinflip_config\", &[bump]]`).\n/// * `total_games_delta` — Reserved; platform always increments by 1 per call.\n/// * `wins_delta` — If > 0, player is marked as winner.\n/// * `total_wagered_delta` — Lamports wagered in this game (maps to `wager_amount`).\n/// * `total_won_delta` — Lamports won in this game (maps to `won_amount`, 0 if lost).\n///\n/// # Example\n///\n/// ```ignore\n/// update_player_profile_cpi(\n///     &ctx.accounts.platform_program,\n///     &ctx.accounts.creator_profile,\n///     &ctx.accounts.config.to_account_info(),\n///     &[b\"coinflip_config\", &[config_bump]],\n///     1,                    // total_games_delta\n///     if is_winner { 1 } else { 0 }, // wins_delta\n///     entry_amount,         // total_wagered_delta\n///     if is_winner { payout } else { 0 }, // total_won_delta\n/// )?;\n/// ```\npub fn update_player_profile_cpi<'a>(\n    platform_program: &AccountInfo<'a>,\n    profile: &AccountInfo<'a>,\n    authority: &AccountInfo<'a>,\n    signer_seeds: &[&[u8]],\n    _total_games_delta: u64,\n    wins_delta: u64,\n    total_wagered_delta: u64,\n    total_won_delta: u64,\n) -> Result<()> {\n    // Guard: skip if profile hasn't been created yet\n    if profile.data_is_empty() {\n        return Ok(());\n    }\n\n    // Map to platform program's actual parameters\n    let wager_amount = total_wagered_delta;\n    let won_amount = total_won_delta;\n    let is_winner = wins_delta > 0;\n\n    // Discriminator = sha256(\"global:update_player_profile\")[0..8]\n    let disc = anchor_lang::solana_program::hash::hash(b\"global:update_player_profile\");\n\n    // Instruction data: 8-byte discriminator + wager_amount(u64) + won_amount(u64) + is_winner(bool)\n    let mut data = [0u8; 25];\n    data[..8].copy_from_slice(&disc.to_bytes()[..8]);\n    data[8..16].copy_from_slice(&wager_amount.to_le_bytes());\n    data[16..24].copy_from_slice(&won_amount.to_le_bytes());\n    data[24] = u8::from(is_winner);\n\n    let accounts = vec![\n        AccountMeta::new_readonly(*authority.key, true), // caller (signer)\n        AccountMeta::new(*profile.key, false),           // profile (mutable)\n    ];\n\n    let ix = Instruction {\n        program_id: *platform_program.key,\n        accounts,\n        data: data.to_vec(),\n    };\n\n    invoke_signed(\n        &ix,\n        &[authority.clone(), profile.clone(), platform_program.clone()],\n        &[signer_seeds],\n    )?;\n\n    Ok(())\n}\n","structuredPatch":[{"oldStart":3,"oldLines":6,"newStart":3,"newLines":7,"lines":["     instruction::{AccountMeta, Instruction},","     program::invoke_signed,"," };","+use solana_sha256_hasher::hashv;"," "," /// Calls the platform program's `update_player_profile` instruction via CPI."," ///"]}],"userModified":false,"replaceAll":false}}
