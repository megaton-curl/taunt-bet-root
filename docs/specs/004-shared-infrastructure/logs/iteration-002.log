{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019TDmVFAVv3p6JBCpmo4Mde","type":"tool_result","content":"     1→/// Coin sides\n     2→pub const SIDE_HEADS: u8 = 0;\n     3→pub const SIDE_TAILS: u8 = 1;\n     4→\n     5→/// Match phases\n     6→pub const PHASE_WAITING: u8 = 0;   // Creator placed bet, waiting for opponent\n     7→pub const PHASE_LOCKED: u8 = 1;    // Both players in, requesting VRF\n     8→pub const PHASE_SETTLED: u8 = 2;   // VRF resolved, winner determined\n     9→pub const PHASE_CANCELLED: u8 = 3; // Creator cancelled before opponent joined\n    10→\n    11→/// Timeout (in seconds) after which a LOCKED match can be cancelled.\n    12→pub const LOCK_TIMEOUT_SECONDS: i64 = 120; // 2 minutes\n    13→\n    14→/// Derive a coin side (0 or 1) from a randomness byte.\n    15→pub fn from_randomness(byte: u8) -> u8 {\n    16→    byte % 2\n    17→}\n    18→\n    19→/// Returns true if the given value is a valid side (HEADS or TAILS).\n    20→pub fn is_valid_side(side: u8) -> bool {\n    21→    side == SIDE_HEADS || side == SIDE_TAILS\n    22→}\n    23→\n    24→#[cfg(test)]\n    25→mod tests {\n    26→    use super::*;\n    27→\n    28→    #[test]\n    29→    fn test_from_randomness() {\n    30→        assert_eq!(from_randomness(0), SIDE_HEADS);\n    31→        assert_eq!(from_randomness(1), SIDE_TAILS);\n    32→        assert_eq!(from_randomness(2), SIDE_HEADS);\n    33→        assert_eq!(from_randomness(255), SIDE_TAILS);\n    34→    }\n    35→\n    36→    #[test]\n    37→    fn test_is_valid_side() {\n    38→        assert!(is_valid_side(SIDE_HEADS));\n    39→        assert!(is_valid_side(SIDE_TAILS));\n    40→        assert!(!is_valid_side(2));\n    41→        assert!(!is_valid_side(255));\n    42→    }\n    43→}\n    44→"}]},"parent_tool_use_id":null,"session_id":"bd1b82af-c9c8-48e7-8c3d-b4ca3e7d8bc8","uuid":"96726c0d-8c85-4ee2-a320-e11071938a60","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/constants.rs","content":"/// Coin sides\npub const SIDE_HEADS: u8 = 0;\npub const SIDE_TAILS: u8 = 1;\n\n/// Match phases\npub const PHASE_WAITING: u8 = 0;   // Creator placed bet, waiting for opponent\npub const PHASE_LOCKED: u8 = 1;    // Both players in, requesting VRF\npub const PHASE_SETTLED: u8 = 2;   // VRF resolved, winner determined\npub const PHASE_CANCELLED: u8 = 3; // Creator cancelled before opponent joined\n\n/// Timeout (in seconds) after which a LOCKED match can be cancelled.\npub const LOCK_TIMEOUT_SECONDS: i64 = 120; // 2 minutes\n\n/// Derive a coin side (0 or 1) from a randomness byte.\npub fn from_randomness(byte: u8) -> u8 {\n    byte % 2\n}\n\n/// Returns true if the given value is a valid side (HEADS or TAILS).\npub fn is_valid_side(side: u8) -> bool {\n    side == SIDE_HEADS || side == SIDE_TAILS\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_from_randomness() {\n        assert_eq!(from_randomness(0), SIDE_HEADS);\n        assert_eq!(from_randomness(1), SIDE_TAILS);\n        assert_eq!(from_randomness(2), SIDE_HEADS);\n        assert_eq!(from_randomness(255), SIDE_TAILS);\n    }\n\n    #[test]\n    fn test_is_valid_side() {\n        assert!(is_valid_side(SIDE_HEADS));\n        assert!(is_valid_side(SIDE_TAILS));\n        assert!(!is_valid_side(2));\n        assert!(!is_valid_side(255));\n    }\n}\n","numLines":44,"startLine":1,"totalLines":44}}}
