s u128) as u64;\n    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    (revenue, rakeback, chest)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_calculate_fee() {\n        assert_eq!(calculate_fee(10_000), 300);\n        assert_eq!(calculate_fee(1_000_000), 30_000);\n        assert_eq!(calculate_fee(0), 0);\n    }\n\n    #[test]\n    fn test_split_fee() {\n        let (rev, rake, chest) = split_fee(300);\n        assert_eq!(rev, 200);\n        assert_eq!(rake, 70);\n        assert_eq!(chest, 30);\n        assert_eq!(rev + rake + chest, 300);\n    }\n}\n","structuredPatch":[{"oldStart":1,"oldLines":3,"newStart":1,"newLines":6,"lines":["+/// Compile-time safety cap: no fee can ever exceed 10% (1000 bps).","+pub const MAX_FEE_BPS: u16 = 1000;","+"," /// Total platform fee: 3% (300 basis points)"," /// - 200 bps: platform revenue"," /// - 70 bps: rakeback pool (raid boss rewards)"]},{"oldStart":7,"oldLines":6,"newStart":10,"newLines":9,"lines":[" pub const RAKEBACK_BPS: u16 = 70;"," pub const CHEST_BPS: u16 = 30;"," ","+// Compile-time assertion: fee must never exceed safety cap.","+const _: () = assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);","+"," /// Calculate the total fee for a given amount."," /// Returns the fee in lamports."," pub fn calculate_fee(amount: u64) -> u64 {"]}],"userModified":false,"replaceAll":false}}
