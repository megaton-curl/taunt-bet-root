{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V57jt2GtS8beg39LHZd8DW","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/fees.rs has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"d8cf6fa3-64fe-48ab-93d9-47cc1917b9fc","uuid":"b4f957d9-085b-4f56-ac95-8b79b7233fd8","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/fees.rs","oldString":"/// Split a fee amount into (revenue, rakeback, chest).","newString":"/// Calculate fee and net payout for a given pool amount.\n/// Returns `(fee, net_payout)` where `net_payout = pool - fee`.\n/// Fee rounds down (integer division truncates), favoring the player.\npub fn calculate_net_payout(pool: u64) -> (u64, u64) {\n    let fee = calculate_fee(pool);\n    (fee, pool - fee)\n}\n\n/// Split a fee amount into (revenue, rakeback, chest).","originalFile":"/// Compile-time safety cap: no fee can ever exceed 10% (1000 bps).\npub const MAX_FEE_BPS: u16 = 1000;\n\n/// Total platform fee: 3% (300 basis points)\n/// - 200 bps: platform revenue\n/// - 70 bps: rakeback pool (raid boss rewards)\n/// - 30 bps: chest treasury\npub const TOTAL_FEE_BPS: u16 = 300;\npub const REVENUE_BPS: u16 = 200;\npub const RAKEBACK_BPS: u16 = 70;\npub const CHEST_BPS: u16 = 30;\n\n// Compile-time assertion: fee must never exceed safety cap.\nconst _: () = assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n\n/// Calculate the total fee for a given amount.\n/// Returns the fee in lamports.\npub fn calculate_fee(amount: u64) -> u64 {\n    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n}\n\n/// Split a fee amount into (revenue, rakeback, chest).\npub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    (revenue, rakeback, chest)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_calculate_fee() {\n        assert_eq!(calculate_fee(10_000), 300);\n        assert_eq!(calculate_fee(1_000_000), 30_000);\n        assert_eq!(calculate_fee(0), 0);\n    }\n\n    #[test]\n    fn test_split_fee() {\n        let (rev, rake, chest) = split_fee(300);\n        assert_eq!(rev, 200);\n        assert_eq!(rake, 70);\n        assert_eq!(chest, 30);\n        assert_eq!(rev + rake + chest, 300);\n    }\n}\n","structuredPatch":[{"oldStart":19,"oldLines":6,"newStart":19,"newLines":14,"lines":["     (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64"," }"," ","+/// Calculate fee and net payout for a given pool amount.","+/// Returns `(fee, net_payout)` where `net_payout = pool - fee`.","+/// Fee rounds down (integer division truncates), favoring the player.","+pub fn calculate_net_payout(pool: u64) -> (u64, u64) {","+    let fee = calculate_fee(pool);","+    (fee, pool - fee)","+}","+"," /// Split a fee amount into (revenue, rakeback, chest)."," pub fn split_fee(fee: u64) -> (u64, u64, u64) {","     let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;"]}],"userModified":false,"replaceAll":false}}
