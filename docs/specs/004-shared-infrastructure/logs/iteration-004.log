{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NqdShPXkXWoVFpxHRV3DoK","type":"tool_result","content":"     1→/// Total platform fee: 3% (300 basis points)\n     2→/// - 200 bps: platform revenue\n     3→/// - 70 bps: rakeback pool (raid boss rewards)\n     4→/// - 30 bps: chest treasury\n     5→pub const TOTAL_FEE_BPS: u16 = 300;\n     6→pub const REVENUE_BPS: u16 = 200;\n     7→pub const RAKEBACK_BPS: u16 = 70;\n     8→pub const CHEST_BPS: u16 = 30;\n     9→\n    10→/// Calculate the total fee for a given amount.\n    11→/// Returns the fee in lamports.\n    12→pub fn calculate_fee(amount: u64) -> u64 {\n    13→    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n    14→}\n    15→\n    16→/// Split a fee amount into (revenue, rakeback, chest).\n    17→pub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    18→    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    19→    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    20→    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    21→    (revenue, rakeback, chest)\n    22→}\n    23→\n    24→#[cfg(test)]\n    25→mod tests {\n    26→    use super::*;\n    27→\n    28→    #[test]\n    29→    fn test_calculate_fee() {\n    30→        assert_eq!(calculate_fee(10_000), 300);\n    31→        assert_eq!(calculate_fee(1_000_000), 30_000);\n    32→        assert_eq!(calculate_fee(0), 0);\n    33→    }\n    34→\n    35→    #[test]\n    36→    fn test_split_fee() {\n    37→        let (rev, rake, chest) = split_fee(300);\n    38→        assert_eq!(rev, 200);\n    39→        assert_eq!(rake, 70);\n    40→        assert_eq!(chest, 30);\n    41→        assert_eq!(rev + rake + chest, 300);\n    42→    }\n    43→}\n    44→"}]},"parent_tool_use_id":null,"session_id":"d8cf6fa3-64fe-48ab-93d9-47cc1917b9fc","uuid":"632c23ce-901c-44ce-a415-ad3aa87d6a6c","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/fees.rs","content":"/// Total platform fee: 3% (300 basis points)\n/// - 200 bps: platform revenue\n/// - 70 bps: rakeback pool (raid boss rewards)\n/// - 30 bps: chest treasury\npub const TOTAL_FEE_BPS: u16 = 300;\npub const REVENUE_BPS: u16 = 200;\npub const RAKEBACK_BPS: u16 = 70;\npub const CHEST_BPS: u16 = 30;\n\n/// Calculate the total fee for a given amount.\n/// Returns the fee in lamports.\npub fn calculate_fee(amount: u64) -> u64 {\n    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n}\n\n/// Split a fee amount into (revenue, rakeback, chest).\npub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    (revenue, rakeback, chest)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_calculate_fee() {\n        assert_eq!(calculate_fee(10_000), 300);\n        assert_eq!(calculate_fee(1_000_000), 30_000);\n        assert_eq!(calculate_fee(0), 0);\n    }\n\n    #[test]\n    fn test_split_fee() {\n        let (rev, rake, chest) = split_fee(300);\n        assert_eq!(rev, 200);\n        assert_eq!(rake, 70);\n        assert_eq!(chest, 30);\n        assert_eq!(rev + rake + chest, 300);\n    }\n}\n","numLines":44,"startLine":1,"totalLines":44}}}
