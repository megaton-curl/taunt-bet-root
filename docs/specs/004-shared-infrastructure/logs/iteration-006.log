///     entry_amount,\n///     &ctx.accounts.system_program.to_account_info(),\n/// )?;\n/// ```\npub fn transfer_lamports_to_pda(\n    from: &AccountInfo,\n    pda: &AccountInfo,\n    amount: u64,\n    system_program_info: &AccountInfo,\n) -> Result<()> {\n    system_program::transfer(\n        CpiContext::new(\n            system_program_info.clone(),\n            system_program::Transfer {\n                from: from.clone(),\n                to: pda.clone(),\n            },\n        ),\n        amount,\n    )\n}\n","structuredPatch":[],"originalFile":null}}
