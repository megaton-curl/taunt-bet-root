fers lamports from a signer to a PDA using system program CPI.\n///\n/// This is the standard pattern for depositing funds into an escrow PDA\n/// (e.g., a player funding a match entry).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_to_pda(\n///     &ctx.accounts.creator.to_account_info(),\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     entry_amount,\n///     &ctx.accounts.system_program.to_account_info(),\n/// )?;\n/// ```\npub fn transfer_lamports_to_pda(\n    from: &AccountInfo,\n    pda: &AccountInfo,\n    amount: u64,\n    system_program_info: &AccountInfo,\n) -> Result<()> {\n    system_program::transfer(\n        CpiContext::new(\n            system_program_info.clone(),\n            system_program::Transfer {\n                from: from.clone(),\n                to: pda.clone(),\n            },\n        ),\n        amount,\n    )\n}\n","structuredPatch":[{"oldStart":50,"oldLines":11,"newStart":50,"newLines":11,"lines":[" ///     &ctx.accounts.system_program.to_account_info(),"," /// )?;"," /// ```","-pub fn transfer_lamports_to_pda(","-    from: &AccountInfo,","-    pda: &AccountInfo,","+pub fn transfer_lamports_to_pda<'a>(","+    from: &AccountInfo<'a>,","+    pda: &AccountInfo<'a>,","     amount: u64,","-    system_program_info: &AccountInfo,","+    system_program_info: &AccountInfo<'a>,"," ) -> Result<()> {","     system_program::transfer(","         CpiContext::new("]}],"userModified":false,"replaceAll":false}}
