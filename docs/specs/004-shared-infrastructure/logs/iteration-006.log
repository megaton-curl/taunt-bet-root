{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K5HbpvkWEm7uVCeinHjSL3","type":"tool_result","content":"     1â†’/// Compile-time safety cap: no fee can ever exceed 10% (1000 bps).\n     2â†’pub const MAX_FEE_BPS: u16 = 1000;\n     3â†’\n     4â†’/// Total platform fee: 3% (300 basis points)\n     5â†’/// - 200 bps: platform revenue\n     6â†’/// - 70 bps: rakeback pool (raid boss rewards)\n     7â†’/// - 30 bps: chest treasury\n     8â†’pub const TOTAL_FEE_BPS: u16 = 300;\n     9â†’pub const REVENUE_BPS: u16 = 200;\n    10â†’pub const RAKEBACK_BPS: u16 = 70;\n    11â†’pub const CHEST_BPS: u16 = 30;\n    12â†’\n    13â†’// Compile-time assertion: fee must never exceed safety cap.\n    14â†’const _: () = assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n    15â†’\n    16â†’/// Calculate the total fee for a given amount.\n    17â†’/// Returns the fee in lamports.\n    18â†’pub fn calculate_fee(amount: u64) -> u64 {\n    19â†’    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n    20â†’}\n    21â†’\n    22â†’/// Calculate fee and net payout for a given pool amount.\n    23â†’/// Returns `(fee, net_payout)` where `net_payout = pool - fee`.\n    24â†’/// Fee rounds down (integer division truncates), favoring the player.\n    25â†’pub fn calculate_net_payout(pool: u64) -> (u64, u64) {\n    26â†’    let fee = calculate_fee(pool);\n    27â†’    (fee, pool - fee)\n    28â†’}\n    29â†’\n    30â†’/// Split a fee amount into (revenue, rakeback, chest).\n    31â†’pub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    32â†’    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    33â†’    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    34â†’    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    35â†’    (revenue, rakeback, chest)\n    36â†’}\n    37â†’\n    38â†’#[cfg(test)]\n    39â†’mod tests {\n    40â†’    use super::*;\n    41â†’\n    42â†’    #[test]\n    43â†’    fn test_calculate_fee() {\n    44â†’        assert_eq!(calculate_fee(10_000), 300);\n    45â†’        assert_eq!(calculate_fee(1_000_000), 30_000);\n    46â†’        assert_eq!(calculate_fee(0), 0);\n    47â†’    }\n    48â†’\n    49â†’    #[test]\n    50â†’    fn test_calculate_net_payout() {\n    51â†’        let (fee, net) = calculate_net_payout(1_000_000);\n    52â†’        assert_eq!(fee, 30_000);\n    53â†’        assert_eq!(net, 970_000);\n    54â†’        assert_eq!(fee + net, 1_000_000);\n    55â†’\n    56â†’        // Zero pool\n    57â†’        let (fee, net) = calculate_net_payout(0);\n    58â†’        assert_eq!(fee, 0);\n    59â†’        assert_eq!(net, 0);\n    60â†’\n    61â†’        // Small amount where rounding truncates (favors player)\n    62â†’        // 100 lamports * 300 / 10000 = 3.0 exactly\n    63â†’        let (fee, net) = calculate_net_payout(100);\n    64â†’        assert_eq!(fee, 3);\n    65â†’        assert_eq!(net, 97);\n    66â†’\n    67â†’        // Non-round amount: 1 lamport â†’ fee rounds to 0\n    68â†’        let (fee, net) = calculate_net_payout(1);\n    69â†’        assert_eq!(fee, 0);\n    70â†’        assert_eq!(net, 1);\n    71â†’    }\n    72â†’\n    73â†’    #[test]\n    74â†’    fn test_max_fee_bps_cap() {\n    75â†’        assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n    76â†’    }\n    77â†’\n    78â†’    #[test]\n    79â†’    fn test_split_fee() {\n    80â†’        let (rev, rake, chest) = split_fee(300);\n    81â†’        assert_eq!(rev, 200);\n    82â†’        assert_eq!(rake, 70);\n    83â†’        assert_eq!(chest, 30);\n    84â†’        assert_eq!(rev + rake + chest, 300);\n    85â†’    }\n    86â†’}\n    87â†’"}]},"parent_tool_use_id":"toolu_01Ls6eE1rz4QYaFd3aFc4AJz","session_id":"3ef31b5a-f057-490b-97be-2b7d8a2c562f","uuid":"8391f3b8-54fa-4433-ae40-674775b15adb"}
