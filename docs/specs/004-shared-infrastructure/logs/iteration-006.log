{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0156qHigRwGBRS8bP2fDYPbC","type":"tool_result","content":"     1â†’use anchor_lang::prelude::*;\n     2â†’use rng_shared::constants::{LOCK_TIMEOUT_SECONDS, PHASE_LOCKED};\n     3â†’\n     4â†’use crate::error::CoinflipError;\n     5â†’use crate::state::CoinflipMatch;\n     6â†’\n     7â†’#[derive(Accounts)]\n     8â†’pub struct TimeoutCancel<'info> {\n     9â†’    /// Either the creator or opponent can trigger a timeout cancel.\n    10â†’    #[account(mut)]\n    11â†’    pub caller: Signer<'info>,\n    12â†’\n    13â†’    /// The creator's account â€” receives rent refund.\n    14â†’    /// CHECK: Validated against coinflip_match.creator.\n    15â†’    #[account(mut)]\n    16â†’    pub creator: AccountInfo<'info>,\n    17â†’\n    18â†’    /// The opponent's account â€” receives entry refund.\n    19â†’    /// CHECK: Validated against coinflip_match.opponent.\n    20â†’    #[account(mut)]\n    21â†’    pub opponent: AccountInfo<'info>,\n    22â†’\n    23â†’    /// The match PDA to cancel (closed after refunds â€” rent goes to creator).\n    24â†’    #[account(\n    25â†’        mut,\n    26â†’        close = creator,\n    27â†’        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    28â†’        bump = coinflip_match.bump,\n    29â†’    )]\n    30â†’    pub coinflip_match: Account<'info, CoinflipMatch>,\n    31â†’}\n    32â†’\n    33â†’pub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    34â†’    let coinflip_match = &ctx.accounts.coinflip_match;\n    35â†’\n    36â†’    // Must be in LOCKED phase\n    37â†’    require!(\n    38â†’        coinflip_match.phase == PHASE_LOCKED,\n    39â†’        CoinflipError::InvalidPhase\n    40â†’    );\n    41â†’\n    42â†’    // Caller must be either creator or opponent\n    43â†’    let caller = ctx.accounts.caller.key();\n    44â†’    require!(\n    45â†’        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n    46â†’        CoinflipError::UnauthorizedCaller\n    47â†’    );\n    48â†’\n    49â†’    // Validate passed accounts match stored keys\n    50â†’    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    51â†’    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n    52â†’\n    53â†’    // Check timeout has elapsed\n    54â†’    let now = Clock::get()?.unix_timestamp;\n    55â†’    require!(\n    56â†’        now - coinflip_match.locked_at >= LOCK_TIMEOUT_SECONDS,\n    57â†’        CoinflipError::LockTimeoutNotElapsed\n    58â†’    );\n    59â†’\n    60â†’    let entry_amount = coinflip_match.entry_amount;\n    61â†’\n    62â†’    // Refund both players their entry amounts from escrow\n    63â†’    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    64â†’    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    65â†’    **ctx.accounts.creator.try_borrow_mut_lamports()? += entry_amount;\n    66â†’\n    67â†’    **match_info.try_borrow_mut_lamports()? -= entry_amount;\n    68â†’    **ctx.accounts.opponent.try_borrow_mut_lamports()? += entry_amount;\n    69â†’\n    70â†’    // Account is closed by Anchor's `close = creator` constraint â€”\n    71â†’    // remaining lamports (rent) are returned to creator.\n    72â†’\n    73â†’    Ok(())\n    74â†’}\n    75â†’"}]},"parent_tool_use_id":"toolu_01Ls6eE1rz4QYaFd3aFc4AJz","session_id":"3ef31b5a-f057-490b-97be-2b7d8a2c562f","uuid":"226ae348-819b-4eaf-88a7-123312d5ec80"}
