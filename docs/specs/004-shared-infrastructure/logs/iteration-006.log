{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018RpsWGuxFL6RAddrWhQQPR","type":"tool_result","content":"     1â†’use anchor_lang::prelude::*;\n     2â†’use rng_shared::constants::PHASE_SETTLED;\n     3â†’use rng_shared::fees::calculate_fee;\n     4â†’\n     5â†’use crate::error::CoinflipError;\n     6â†’use crate::state::{CoinflipConfig, CoinflipMatch};\n     7â†’\n     8â†’#[derive(Accounts)]\n     9â†’pub struct ClaimPayout<'info> {\n    10â†’    /// Either the creator or opponent can trigger the claim.\n    11â†’    #[account(mut)]\n    12â†’    pub caller: Signer<'info>,\n    13â†’\n    14â†’    /// The winner who receives the payout.\n    15â†’    /// CHECK: Validated against coinflip_match.winner in handler.\n    16â†’    #[account(mut)]\n    17â†’    pub winner: AccountInfo<'info>,\n    18â†’\n    19â†’    /// The match PDA (closed after claim â€” rent refunded to creator).\n    20â†’    #[account(\n    21â†’        mut,\n    22â†’        close = creator,\n    23â†’        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    24â†’        bump = coinflip_match.bump,\n    25â†’    )]\n    26â†’    pub coinflip_match: Account<'info, CoinflipMatch>,\n    27â†’\n    28â†’    /// The config PDA (for treasury address + CPI signing).\n    29â†’    #[account(\n    30â†’        seeds = [b\"coinflip_config\"],\n    31â†’        bump = config.bump,\n    32â†’    )]\n    33â†’    pub config: Account<'info, CoinflipConfig>,\n    34â†’\n    35â†’    /// The treasury account to receive fees.\n    36â†’    /// CHECK: Validated against config.treasury in handler.\n    37â†’    #[account(mut)]\n    38â†’    pub treasury: AccountInfo<'info>,\n    39â†’\n    40â†’    /// The creator account (receives rent refund on close).\n    41â†’    /// CHECK: Validated against coinflip_match.creator in handler.\n    42â†’    #[account(mut)]\n    43â†’    pub creator: AccountInfo<'info>,\n    44â†’\n    45â†’    /// Creator's player profile PDA on the platform program.\n    46â†’    /// CHECK: Validated by platform program via CPI (if account exists).\n    47â†’    #[account(mut)]\n    48â†’    pub creator_profile: AccountInfo<'info>,\n    49â†’\n    50â†’    /// Opponent's player profile PDA on the platform program.\n    51â†’    /// CHECK: Validated by platform program via CPI (if account exists).\n    52â†’    #[account(mut)]\n    53â†’    pub opponent_profile: AccountInfo<'info>,\n    54â†’\n    55â†’    /// The platform program for CPI calls.\n    56â†’    pub platform_program: Program<'info, platform::program::Platform>,\n    57â†’\n    58â†’    pub system_program: Program<'info, System>,\n    59â†’}\n    60â†’\n    61â†’pub fn handler(ctx: Context<ClaimPayout>) -> Result<()> {\n    62â†’    let coinflip_match = &ctx.accounts.coinflip_match;\n    63â†’\n    64â†’    // Must be in SETTLED phase\n    65â†’    require!(\n    66â†’        coinflip_match.phase == PHASE_SETTLED,\n    67â†’        CoinflipError::InvalidPhase\n    68â†’    );\n    69â†’\n    70â†’    // Caller must be either creator or opponent\n    71â†’    let caller = ctx.accounts.caller.key();\n    72â†’    require!(\n    73â†’        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n    74â†’        CoinflipError::UnauthorizedCaller\n    75â†’    );\n    76â†’\n    77â†’    // Validate winner account matches on-chain winner\n    78â†’    require!(\n    79â†’        ctx.accounts.winner.key() == coinflip_match.winner,\n    80â†’        CoinflipError::NotWinner\n    81â†’    );\n    82â†’\n    83â†’    // Prevent double claim\n    84â†’    require!(!coinflip_match.claimed, CoinflipError::AlreadyClaimed);\n    85â†’\n    86â†’    // Validate treasury matches config\n    87â†’    require!(\n    88â†’        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n    89â†’        CoinflipError::InvalidPhase\n    90â†’    );\n    91â†’\n    92â†’    // Validate creator matches match.creator\n    93â†’    require!(\n    94â†’        ctx.accounts.creator.key() == coinflip_match.creator,\n    95â†’        CoinflipError::InvalidPhase\n    96â†’    );\n    97â†’\n    98â†’    // Compute payout amounts\n    99â†’    let pool = coinflip_match.entry_amount.checked_mul(2).unwrap();\n   100â†’    let fee = calculate_fee(pool);\n   101â†’    let payout = pool - fee;\n   102â†’\n   103â†’    // Transfer payout to winner\n   104â†’    let match_info = ctx.accounts.coinflip_match.to_account_info();\n   105â†’    **match_info.try_borrow_mut_lamports()? -= payout;\n   106â†’    **ctx.accounts.winner.try_borrow_mut_lamports()? += payout;\n   107â†’\n   108â†’    // Transfer fee to treasury\n   109â†’    **match_info.try_borrow_mut_lamports()? -= fee;\n   110â†’    **ctx.accounts.treasury.try_borrow_mut_lamports()? += fee;\n   111â†’\n   112â†’    // CPI: update player profiles (only if they exist on-chain)\n   113â†’    let config_bump = ctx.accounts.config.bump;\n   114â†’    let signer_seeds: &[&[&[u8]]] = &[&[b\"coinflip_config\", &[config_bump]]];\n   115â†’\n   116â†’    let cpi_program = ctx.accounts.platform_program.to_account_info();\n   117â†’\n   118â†’    // Creator profile update â€” skip if profile hasn't been created yet\n   119â†’    if !ctx.accounts.creator_profile.data_is_empty() {\n   120â†’        let creator_is_winner = ctx.accounts.creator.key() == coinflip_match.winner;\n   121â†’        let creator_won_amount = if creator_is_winner { payout } else { 0 };\n   122â†’        let cpi_accounts_creator = platform::cpi::accounts::UpdatePlayerProfile {\n   123â†’            caller: ctx.accounts.config.to_account_info(),\n   124â†’            profile: ctx.accounts.creator_profile.to_account_info(),\n   125â†’        };\n   126â†’        let cpi_ctx_creator =\n   127â†’            CpiContext::new_with_signer(cpi_program.clone(), cpi_accounts_creator, signer_seeds);\n   128â†’        platform::cpi::update_player_profile(\n   129â†’            cpi_ctx_creator,\n   130â†’            coinflip_match.entry_amount,\n   131â†’            creator_won_amount,\n   132â†’            creator_is_winner,\n   133â†’        )?;\n   134â†’    }\n   135â†’\n   136â†’    // Opponent profile update â€” skip if profile hasn't been created yet\n   137â†’    if !ctx.accounts.opponent_profile.data_is_empty() {\n   138â†’        let opponent_is_winner = coinflip_match.opponent == coinflip_match.winner;\n   139â†’        let opponent_won_amount = if opponent_is_winner { payout } else { 0 };\n   140â†’        let cpi_accounts_opponent = platform::cpi::accounts::UpdatePlayerProfile {\n   141â†’            caller: ctx.accounts.config.to_account_info(),\n   142â†’            profile: ctx.accounts.opponent_profile.to_account_info(),\n   143â†’        };\n   144â†’        let cpi_ctx_opponent =\n   145â†’            CpiContext::new_with_signer(cpi_program, cpi_accounts_opponent, signer_seeds);\n   146â†’        platform::cpi::update_player_profile(\n   147â†’            cpi_ctx_opponent,\n   148â†’            coinflip_match.entry_amount,\n   149â†’            opponent_won_amount,\n   150â†’            opponent_is_winner,\n   151â†’        )?;\n   152â†’    }\n   153â†’\n   154â†’    // Account is closed by Anchor's `close = creator` constraint â€”\n   155â†’    // remaining lamports (rent) are sent to creator, data is zeroed,\n   156â†’    // and owner is set back to system program. This ensures the PDA\n   157â†’    // is fully cleaned up so the creator can start a new match.\n   158â†’\n   159â†’    Ok(())\n   160â†’}\n   161â†’"}]},"parent_tool_use_id":null,"session_id":"3ef31b5a-f057-490b-97be-2b7d8a2c562f","uuid":"6218dff3-5595-441b-945a-5ed889a65367","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/claim_payout.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::constants::PHASE_SETTLED;\nuse rng_shared::fees::calculate_fee;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n#[derive(Accounts)]\npub struct ClaimPayout<'info> {\n    /// Either the creator or opponent can trigger the claim.\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The winner who receives the payout.\n    /// CHECK: Validated against coinflip_match.winner in handler.\n    #[account(mut)]\n    pub winner: AccountInfo<'info>,\n\n    /// The match PDA (closed after claim â€” rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (for treasury address + CPI signing).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// The treasury account to receive fees.\n    /// CHECK: Validated against config.treasury in handler.\n    #[account(mut)]\n    pub treasury: AccountInfo<'info>,\n\n    /// The creator account (receives rent refund on close).\n    /// CHECK: Validated against coinflip_match.creator in handler.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// Creator's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub creator_profile: AccountInfo<'info>,\n\n    /// Opponent's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub opponent_profile: AccountInfo<'info>,\n\n    /// The platform program for CPI calls.\n    pub platform_program: Program<'info, platform::program::Platform>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<ClaimPayout>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in SETTLED phase\n    require!(\n        coinflip_match.phase == PHASE_SETTLED,\n        CoinflipError::InvalidPhase\n    );\n\n    // Caller must be either creator or opponent\n    let caller = ctx.accounts.caller.key();\n    require!(\n        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n        CoinflipError::UnauthorizedCaller\n    );\n\n    // Validate winner account matches on-chain winner\n    require!(\n        ctx.accounts.winner.key() == coinflip_match.winner,\n        CoinflipError::NotWinner\n    );\n\n    // Prevent double claim\n    require!(!coinflip_match.claimed, CoinflipError::AlreadyClaimed);\n\n    // Validate treasury matches config\n    require!(\n        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n        CoinflipError::InvalidPhase\n    );\n\n    // Validate creator matches match.creator\n    require!(\n        ctx.accounts.creator.key() == coinflip_match.creator,\n        CoinflipError::InvalidPhase\n    );\n\n    // Compute payout amounts\n    let pool = coinflip_match.entry_amount.checked_mul(2).unwrap();\n    let fee = calculate_fee(pool);\n    let payout = pool - fee;\n\n    // Transfer payout to winner\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    **match_info.try_borrow_mut_lamports()? -= payout;\n    **ctx.accounts.winner.try_borrow_mut_lamports()? += payout;\n\n    // Transfer fee to treasury\n    **match_info.try_borrow_mut_lamports()? -= fee;\n    **ctx.accounts.treasury.try_borrow_mut_lamports()? += fee;\n\n    // CPI: update player profiles (only if they exist on-chain)\n    let config_bump = ctx.accounts.config.bump;\n    let signer_seeds: &[&[&[u8]]] = &[&[b\"coinflip_config\", &[config_bump]]];\n\n    let cpi_program = ctx.accounts.platform_program.to_account_info();\n\n    // Creator profile update â€” skip if profile hasn't been created yet\n    if !ctx.accounts.creator_profile.data_is_empty() {\n        let creator_is_winner = ctx.accounts.creator.key() == coinflip_match.winner;\n        let creator_won_amount = if creator_is_winner { payout } else { 0 };\n        let cpi_accounts_creator = platform::cpi::accounts::UpdatePlayerProfile {\n            caller: ctx.accounts.config.to_account_info(),\n            profile: ctx.accounts.creator_profile.to_account_info(),\n        };\n        let cpi_ctx_creator =\n            CpiContext::new_with_signer(cpi_program.clone(), cpi_accounts_creator, signer_seeds);\n        platform::cpi::update_player_profile(\n            cpi_ctx_creator,\n            coinflip_match.entry_amount,\n            creator_won_amount,\n            creator_is_winner,\n        )?;\n    }\n\n    // Opponent profile update â€” skip if profile hasn't been created yet\n    if !ctx.accounts.opponent_profile.data_is_empty() {\n        let opponent_is_winner = coinflip_match.opponent == coinflip_match.winner;\n        let opponent_won_amount = if opponent_is_winner { payout } else { 0 };\n        let cpi_accounts_opponent = platform::cpi::accounts::UpdatePlayerProfile {\n            caller: ctx.accounts.config.to_account_info(),\n            profile: ctx.accounts.opponent_profile.to_account_info(),\n        };\n        let cpi_ctx_opponent =\n            CpiContext::new_with_signer(cpi_program, cpi_accounts_opponent, signer_seeds);\n        platform::cpi::update_player_profile(\n            cpi_ctx_opponent,\n            coinflip_match.entry_amount,\n            opponent_won_amount,\n            opponent_is_winner,\n        )?;\n    }\n\n    // Account is closed by Anchor's `close = creator` constraint â€”\n    // remaining lamports (rent) are sent to creator, data is zeroed,\n    // and owner is set back to system program. This ensures the PDA\n    // is fully cleaned up so the creator can start a new match.\n\n    Ok(())\n}\n","numLines":161,"startLine":1,"totalLines":161}}}
