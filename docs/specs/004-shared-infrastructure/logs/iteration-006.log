{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018Q9s8a8GeR5cSF3Y69tfFf","type":"tool_result","content":"     1â†’use anchor_lang::prelude::*;\n     2â†’use rng_shared::constants::{from_randomness, PHASE_LOCKED, PHASE_SETTLED};\n     3â†’\n     4â†’use crate::error::CoinflipError;\n     5â†’use crate::state::{CoinflipConfig, CoinflipMatch};\n     6â†’\n     7â†’#[derive(Accounts)]\n     8â†’pub struct ResolveMatch<'info> {\n     9â†’    /// Oracle authority: VRF_PROGRAM_IDENTITY in real mode, config keypair in mock mode.\n    10â†’    pub oracle: Signer<'info>,\n    11â†’\n    12â†’    /// The config PDA with oracle authority.\n    13â†’    #[account(\n    14â†’        seeds = [b\"coinflip_config\"],\n    15â†’        bump = config.bump,\n    16â†’    )]\n    17â†’    pub config: Account<'info, CoinflipConfig>,\n    18â†’\n    19â†’    /// The match PDA to resolve.\n    20â†’    #[account(\n    21â†’        mut,\n    22â†’        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    23â†’        bump = coinflip_match.bump,\n    24â†’    )]\n    25â†’    pub coinflip_match: Account<'info, CoinflipMatch>,\n    26â†’}\n    27â†’\n    28â†’pub fn handler(ctx: Context<ResolveMatch>, randomness: [u8; 32]) -> Result<()> {\n    29â†’    let coinflip_match = &ctx.accounts.coinflip_match;\n    30â†’\n    31â†’    // Must be in LOCKED phase\n    32â†’    require!(\n    33â†’        coinflip_match.phase == PHASE_LOCKED,\n    34â†’        CoinflipError::InvalidPhase\n    35â†’    );\n    36â†’\n    37â†’    // Oracle must match config.oracle_authority.\n    38â†’    // On devnet this is VRF_PROGRAM_IDENTITY; in bankrun tests it's a test keypair.\n    39â†’    require!(\n    40â†’        ctx.accounts.oracle.key() == ctx.accounts.config.oracle_authority,\n    41â†’        CoinflipError::UnauthorizedOracle\n    42â†’    );\n    43â†’\n    44â†’    // Derive result from randomness\n    45â†’    let result = from_randomness(randomness[0]);\n    46â†’\n    47â†’    // Determine winner: if result matches creator_side, creator wins; otherwise opponent\n    48â†’    let winner = if result == coinflip_match.creator_side {\n    49â†’        coinflip_match.creator\n    50â†’    } else {\n    51â†’        coinflip_match.opponent\n    52â†’    };\n    53â†’\n    54â†’    // Update match state\n    55â†’    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    56â†’    coinflip_match.result = result;\n    57â†’    coinflip_match.winner = winner;\n    58â†’    coinflip_match.phase = PHASE_SETTLED;\n    59â†’\n    60â†’    Ok(())\n    61â†’}\n    62â†’"}]},"parent_tool_use_id":"toolu_01Ls6eE1rz4QYaFd3aFc4AJz","session_id":"3ef31b5a-f057-490b-97be-2b7d8a2c562f","uuid":"fd509b4f-01cc-4286-8b8f-8486049e05da"}
