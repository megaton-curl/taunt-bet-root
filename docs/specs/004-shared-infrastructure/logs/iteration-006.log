{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017idsq44pGsYAVDGgJ24Shg","type":"tool_result","content":"     1â†’use anchor_lang::prelude::*;\n     2â†’use rng_shared::constants::PHASE_WAITING;\n     3â†’\n     4â†’use crate::error::CoinflipError;\n     5â†’use crate::state::CoinflipMatch;\n     6â†’\n     7â†’#[derive(Accounts)]\n     8â†’pub struct CancelMatch<'info> {\n     9â†’    /// The creator cancelling their match.\n    10â†’    #[account(mut)]\n    11â†’    pub creator: Signer<'info>,\n    12â†’\n    13â†’    /// The match PDA (closed on cancel â€” escrow + rent refunded to creator).\n    14â†’    #[account(\n    15â†’        mut,\n    16â†’        close = creator,\n    17â†’        seeds = [b\"match\", creator.key().as_ref()],\n    18â†’        bump = coinflip_match.bump,\n    19â†’    )]\n    20â†’    pub coinflip_match: Account<'info, CoinflipMatch>,\n    21â†’\n    22â†’    pub system_program: Program<'info, System>,\n    23â†’}\n    24â†’\n    25â†’pub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    26â†’    let coinflip_match = &ctx.accounts.coinflip_match;\n    27â†’\n    28â†’    // Only WAITING matches can be cancelled\n    29â†’    require!(\n    30â†’        coinflip_match.phase == PHASE_WAITING,\n    31â†’        CoinflipError::CannotCancel\n    32â†’    );\n    33â†’\n    34â†’    // Account is closed by Anchor's `close = creator` constraint â€”\n    35â†’    // all lamports (escrow + rent) are returned to creator.\n    36â†’\n    37â†’    Ok(())\n    38â†’}\n    39â†’"}]},"parent_tool_use_id":"toolu_01Ls6eE1rz4QYaFd3aFc4AJz","session_id":"3ef31b5a-f057-490b-97be-2b7d8a2c562f","uuid":"af7d7ddb-231a-4637-9364-d7108d982692"}
