{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JYLSQYVQ6u6mgM6Zb3bQGv","type":"tool_result","content":"     1â†’use anchor_lang::prelude::*;\n     2â†’\n     3â†’use crate::state::CoinflipConfig;\n     4â†’\n     5â†’/// Admin-only instruction to close a match account that can't be deserialized\n     6â†’/// (e.g., after an account layout migration). Drains all lamports to the\n     7â†’/// original creator and zeroes the account data.\n     8â†’#[derive(Accounts)]\n     9â†’pub struct ForceClose<'info> {\n    10â†’    /// Config authority (admin).\n    11â†’    pub authority: Signer<'info>,\n    12â†’\n    13â†’    /// The config PDA â€” validates authority.\n    14â†’    #[account(\n    15â†’        seeds = [b\"coinflip_config\"],\n    16â†’        bump = config.bump,\n    17â†’        has_one = authority,\n    18â†’    )]\n    19â†’    pub config: Account<'info, CoinflipConfig>,\n    20â†’\n    21â†’    /// CHECK: The match account to close. Not deserialized â€” may have old layout.\n    22â†’    #[account(mut)]\n    23â†’    pub match_account: AccountInfo<'info>,\n    24â†’\n    25â†’    /// CHECK: Receives the lamports. Should be the match creator or admin.\n    26â†’    #[account(mut)]\n    27â†’    pub recipient: AccountInfo<'info>,\n    28â†’}\n    29â†’\n    30â†’pub fn handler(ctx: Context<ForceClose>) -> Result<()> {\n    31â†’    let match_info = &ctx.accounts.match_account;\n    32â†’\n    33â†’    // Verify it's owned by this program\n    34â†’    require_keys_eq!(*match_info.owner, crate::ID);\n    35â†’\n    36â†’    // Drain all lamports to recipient\n    37â†’    let lamports = match_info.lamports();\n    38â†’    **match_info.try_borrow_mut_lamports()? -= lamports;\n    39â†’    **ctx.accounts.recipient.try_borrow_mut_lamports()? += lamports;\n    40â†’\n    41â†’    // Zero the data so the account is effectively closed\n    42â†’    match_info.try_borrow_mut_data()?.fill(0);\n    43â†’\n    44â†’    Ok(())\n    45â†’}\n    46â†’"}]},"parent_tool_use_id":"toolu_01Ls6eE1rz4QYaFd3aFc4AJz","session_id":"3ef31b5a-f057-490b-97be-2b7d8a2c562f","uuid":"d3b89385-3a99-4760-9044-433f6982d1cf"}
