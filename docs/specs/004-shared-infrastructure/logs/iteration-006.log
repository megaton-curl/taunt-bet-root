{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VNRkCB2aQdh5uzPh7rNNhq","type":"tool_result","content":"     1â†’use anchor_lang::prelude::*;\n     2â†’use anchor_lang::system_program;\n     3â†’use rng_shared::constants::{is_valid_side, PHASE_WAITING};\n     4â†’use rng_shared::tiers::get_tier_amount;\n     5â†’\n     6â†’use crate::error::CoinflipError;\n     7â†’use crate::state::CoinflipMatch;\n     8â†’\n     9â†’#[derive(Accounts)]\n    10â†’pub struct CreateMatch<'info> {\n    11â†’    /// The player creating the match. Must sign and fund the escrow.\n    12â†’    #[account(mut)]\n    13â†’    pub creator: Signer<'info>,\n    14â†’\n    15â†’    /// The match PDA. Seeds enforce one active match per creator.\n    16â†’    #[account(\n    17â†’        init,\n    18â†’        payer = creator,\n    19â†’        space = 8 + CoinflipMatch::INIT_SPACE,\n    20â†’        seeds = [b\"match\", creator.key().as_ref()],\n    21â†’        bump,\n    22â†’    )]\n    23â†’    pub coinflip_match: Account<'info, CoinflipMatch>,\n    24â†’\n    25â†’    pub system_program: Program<'info, System>,\n    26â†’}\n    27â†’\n    28â†’pub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    29â†’    require!(is_valid_side(side), CoinflipError::InvalidSide);\n    30â†’\n    31â†’    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n    32â†’\n    33â†’    // Transfer entry_amount from creator to match PDA (escrow)\n    34â†’    system_program::transfer(\n    35â†’        CpiContext::new(\n    36â†’            ctx.accounts.system_program.to_account_info(),\n    37â†’            system_program::Transfer {\n    38â†’                from: ctx.accounts.creator.to_account_info(),\n    39â†’                to: ctx.accounts.coinflip_match.to_account_info(),\n    40â†’            },\n    41â†’        ),\n    42â†’        entry_amount,\n    43â†’    )?;\n    44â†’\n    45â†’    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    46â†’    coinflip_match.creator = ctx.accounts.creator.key();\n    47â†’    coinflip_match.opponent = Pubkey::default();\n    48â†’    coinflip_match.tier = tier;\n    49â†’    coinflip_match.entry_amount = entry_amount;\n    50â†’    coinflip_match.creator_side = side;\n    51â†’    coinflip_match.phase = PHASE_WAITING;\n    52â†’    coinflip_match.result = 0;\n    53â†’    coinflip_match.winner = Pubkey::default();\n    54â†’    coinflip_match.claimed = false;\n    55â†’    coinflip_match.bump = ctx.bumps.coinflip_match;\n    56â†’\n    57â†’    Ok(())\n    58â†’}\n    59â†’"}]},"parent_tool_use_id":null,"session_id":"3ef31b5a-f057-490b-97be-2b7d8a2c562f","uuid":"39bec2f7-c138-4d24-9a19-d951a475a56c","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/create_match.rs","content":"use anchor_lang::prelude::*;\nuse anchor_lang::system_program;\nuse rng_shared::constants::{is_valid_side, PHASE_WAITING};\nuse rng_shared::tiers::get_tier_amount;\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct CreateMatch<'info> {\n    /// The player creating the match. Must sign and fund the escrow.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA. Seeds enforce one active match per creator.\n    #[account(\n        init,\n        payer = creator,\n        space = 8 + CoinflipMatch::INIT_SPACE,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    require!(is_valid_side(side), CoinflipError::InvalidSide);\n\n    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n\n    // Transfer entry_amount from creator to match PDA (escrow)\n    system_program::transfer(\n        CpiContext::new(\n            ctx.accounts.system_program.to_account_info(),\n            system_program::Transfer {\n                from: ctx.accounts.creator.to_account_info(),\n                to: ctx.accounts.coinflip_match.to_account_info(),\n            },\n        ),\n        entry_amount,\n    )?;\n\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.creator = ctx.accounts.creator.key();\n    coinflip_match.opponent = Pubkey::default();\n    coinflip_match.tier = tier;\n    coinflip_match.entry_amount = entry_amount;\n    coinflip_match.creator_side = side;\n    coinflip_match.phase = PHASE_WAITING;\n    coinflip_match.result = 0;\n    coinflip_match.winner = Pubkey::default();\n    coinflip_match.claimed = false;\n    coinflip_match.bump = ctx.bumps.coinflip_match;\n\n    Ok(())\n}\n","numLines":59,"startLine":1,"totalLines":59}}}
