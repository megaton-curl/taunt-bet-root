{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YJs5Q2PBfoPfS1XPiAjaez","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use solana_sha256_hasher::hashv;\n     3→\n     4→#[error_code]\n     5→pub enum CommitRevealError {\n     6→    #[msg(\"Commitment mismatch: SHA256(server_seed) does not match stored commitment\")]\n     7→    CommitmentMismatch,\n     8→}\n     9→\n    10→/// Writes a commitment hash into the provided storage slot.\n    11→pub fn store_commitment(commitment: &mut [u8; 32], hash: [u8; 32]) {\n    12→    *commitment = hash;\n    13→}\n    14→\n    15→/// Verifies that `SHA256(server_seed)` matches the stored commitment.\n    16→pub fn verify_reveal(commitment: &[u8; 32], server_seed: &[u8]) -> Result<()> {\n    17→    let computed = hashv(&[server_seed]);\n    18→    if computed.to_bytes() == *commitment {\n    19→        Ok(())\n    20→    } else {\n    21→        Err(CommitRevealError::CommitmentMismatch.into())\n    22→    }\n    23→}\n    24→\n    25→#[cfg(test)]\n    26→mod tests {\n    27→    use super::*;\n    28→    use solana_sha256_hasher::hashv as sha256;\n    29→\n    30→    #[test]\n    31→    fn known_pair_passes() {\n    32→        let seed = b\"known_server_seed_1234\";\n    33→        let hash = sha256(&[seed]);\n    34→        let mut commitment = [0u8; 32];\n    35→        store_commitment(&mut commitment, hash.to_bytes());\n    36→        assert!(verify_reveal(&commitment, seed).is_ok());\n    37→    }\n    38→\n    39→    #[test]\n    40→    fn tampered_seed_fails() {\n    41→        let seed = b\"original_seed\";\n    42→        let hash = sha256(&[seed]);\n    43→        let mut commitment = [0u8; 32];\n    44→        store_commitment(&mut commitment, hash.to_bytes());\n    45→        assert!(verify_reveal(&commitment, b\"tampered_seed\").is_err());\n    46→    }\n    47→\n    48→    #[test]\n    49→    fn empty_seed_fails() {\n    50→        let seed = b\"non_empty_seed\";\n    51→        let hash = sha256(&[seed]);\n    52→        let mut commitment = [0u8; 32];\n    53→        store_commitment(&mut commitment, hash.to_bytes());\n    54→        assert!(verify_reveal(&commitment, b\"\").is_err());\n    55→    }\n    56→}\n    57→"}]},"parent_tool_use_id":null,"session_id":"71f3d66f-916b-4438-95fb-e3b573af6aa8","uuid":"5d6b880f-5eee-45b3-a6ed-db75606b31ef","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/commit_reveal.rs","content":"use anchor_lang::prelude::*;\nuse solana_sha256_hasher::hashv;\n\n#[error_code]\npub enum CommitRevealError {\n    #[msg(\"Commitment mismatch: SHA256(server_seed) does not match stored commitment\")]\n    CommitmentMismatch,\n}\n\n/// Writes a commitment hash into the provided storage slot.\npub fn store_commitment(commitment: &mut [u8; 32], hash: [u8; 32]) {\n    *commitment = hash;\n}\n\n/// Verifies that `SHA256(server_seed)` matches the stored commitment.\npub fn verify_reveal(commitment: &[u8; 32], server_seed: &[u8]) -> Result<()> {\n    let computed = hashv(&[server_seed]);\n    if computed.to_bytes() == *commitment {\n        Ok(())\n    } else {\n        Err(CommitRevealError::CommitmentMismatch.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use solana_sha256_hasher::hashv as sha256;\n\n    #[test]\n    fn known_pair_passes() {\n        let seed = b\"known_server_seed_1234\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, seed).is_ok());\n    }\n\n    #[test]\n    fn tampered_seed_fails() {\n        let seed = b\"original_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"tampered_seed\").is_err());\n    }\n\n    #[test]\n    fn empty_seed_fails() {\n        let seed = b\"non_empty_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"\").is_err());\n    }\n}\n","numLines":57,"startLine":1,"totalLines":57}}}
