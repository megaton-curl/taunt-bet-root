{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lh3jhx4cFEd2KMeUHK7Ekf","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→pub mod error;\n     4→pub mod instructions;\n     5→pub mod state;\n     6→\n     7→use instructions::*;\n     8→\n     9→declare_id!(\"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\");\n    10→\n    11→#[program]\n    12→pub mod platform {\n    13→    use super::*;\n    14→\n    15→    pub fn initialize_platform(ctx: Context<InitializePlatform>, treasury: Pubkey) -> Result<()> {\n    16→        instructions::initialize_platform::handler(ctx, treasury)\n    17→    }\n    18→\n    19→    pub fn create_player_profile(ctx: Context<CreatePlayerProfile>) -> Result<()> {\n    20→        instructions::create_player_profile::handler(ctx)\n    21→    }\n    22→\n    23→    pub fn update_player_profile(\n    24→        ctx: Context<UpdatePlayerProfile>,\n    25→        wager_amount: u64,\n    26→        won_amount: u64,\n    27→        is_winner: bool,\n    28→    ) -> Result<()> {\n    29→        instructions::update_player_profile::handler(ctx, wager_amount, won_amount, is_winner)\n    30→    }\n    31→}\n    32→"}]},"parent_tool_use_id":"toolu_01QcyL5tdRikF3ustsTirKmN","session_id":"71f3d66f-916b-4438-95fb-e3b573af6aa8","uuid":"c5836424-c52f-4ea6-9140-2884426aabcc"}
