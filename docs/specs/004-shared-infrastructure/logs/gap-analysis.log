{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DJqCNhxusC3minXkw5rkUc","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→  type TransactionInstruction,\n     8→} from \"@solana/web3.js\";\n     9→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n    10→import {\n    11→  TIER_VALUES,\n    12→  COIN_SIDE_VALUES,\n    13→  TIER_AMOUNTS,\n    14→  type Tier,\n    15→  type CoinSide,\n    16→} from \"@rng-utopia/game-engine/browser\";\n    17→import type { UIMatch } from \"../types\";\n    18→\n    19→// ============ Constants ============\n    20→\n    21→const COINFLIP_PROGRAM_ID = new PublicKey(\n    22→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    23→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    24→);\n    25→\n    26→// Orao VRF program (on-chain VRF provider)\n    27→const ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n    28→\n    29→// ============ PDA Derivation ============\n    30→\n    31→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    32→  return PublicKey.findProgramAddressSync(\n    33→    [Buffer.from(\"match\"), creator.toBuffer()],\n    34→    COINFLIP_PROGRAM_ID\n    35→  );\n    36→}\n    37→\n    38→export function getConfigPda(): [PublicKey, number] {\n    39→  return PublicKey.findProgramAddressSync(\n    40→    [Buffer.from(\"coinflip_config\")],\n    41→    COINFLIP_PROGRAM_ID\n    42→  );\n    43→}\n    44→\n    45→/** Orao VRF network state PDA (stores config + treasury). */\n    46→function getOraoNetworkStatePda(): PublicKey {\n    47→  const [pda] = PublicKey.findProgramAddressSync(\n    48→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    49→    ORAO_VRF_PROGRAM_ID\n    50→  );\n    51→  return pda;\n    52→}\n    53→\n    54→/** Orao VRF randomness PDA derived from a 32-byte seed. */\n    55→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    56→  const [pda] = PublicKey.findProgramAddressSync(\n    57→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    58→    ORAO_VRF_PROGRAM_ID\n    59→  );\n    60→  return pda;\n    61→}\n    62→\n    63→// ============ Program Instance ============\n    64→\n    65→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    66→  // Read-only provider (no wallet needed for queries)\n    67→  const provider = new AnchorProvider(\n    68→    connection,\n    69→    {} as AnchorProvider[\"wallet\"],\n    70→    { commitment: \"confirmed\" }\n    71→  );\n    72→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    73→}\n    74→\n    75→// ============ On-Chain Account Types ============\n    76→\n    77→/** Anchor enum variant representation — one key with empty object value. */\n    78→type RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n    79→  | { resolving: object } | { settled: object } | { refunded: object };\n    80→\n    81→interface OnChainMatch {\n    82→  creator: PublicKey;\n    83→  opponent: PublicKey;\n    84→  tier: number;\n    85→  entryAmount: { toNumber(): number };\n    86→  creatorSide: number;\n    87→  phase: RoundPhaseVariant;\n    88→  result: number;\n    89→  winner: PublicKey;\n    90→  claimed: boolean;\n    91→  createdAt: { toNumber(): number };\n    92→  lockedAt: { toNumber(): number };\n    93→  resolveDeadline: { toNumber(): number };\n    94→  vrfRequestKey: PublicKey;\n    95→  bump: number;\n    96→}\n    97→\n    98→// ============ Converters ============\n    99→\n   100→function tierFromIndex(index: number): Tier {\n   101→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"emerald\", \"diamond\"];\n   102→  return tiers[index] ?? \"iron\";\n   103→}\n   104→\n   105→function sideFromIndex(index: number): CoinSide {\n   106→  return index === 0 ? \"heads\" : \"tails\";\n   107→}\n   108→\n   109→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   110→  return name in phase;\n   111→}\n   112→\n   113→function phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n   114→  if (isPhase(phase, \"waiting\")) return \"created\";\n   115→  if (isPhase(phase, \"locked\")) return \"ready\";\n   116→  if (isPhase(phase, \"settled\")) return \"complete\";\n   117→  return \"created\";\n   118→}\n   119→\n   120→const DEFAULT_PUBKEY = PublicKey.default;\n   121→\n   122→function isDefaultPubkey(key: PublicKey): boolean {\n   123→  return key.equals(DEFAULT_PUBKEY);\n   124→}\n   125→\n   126→export function onChainMatchToUI(\n   127→  matchPda: PublicKey,\n   128→  data: OnChainMatch\n   129→): UIMatch {\n   130→  const tier = tierFromIndex(data.tier);\n   131→  const creatorSide = sideFromIndex(data.creatorSide);\n   132→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   133→  const phase = phaseToUI(data.phase);\n   134→  const isSettled = isPhase(data.phase, \"settled\");\n   135→\n   136→  const entryAmountSol = TIER_AMOUNTS[tier];\n   137→  const totalPool = entryAmountSol * 2;\n   138→  const payoutAmount = totalPool * 0.97;\n   139→\n   140→  const lockedAt = data.lockedAt.toNumber();\n   141→\n   142→  return {\n   143→    id: matchPda.toBase58(),\n   144→    tier,\n   145→    entryAmount: entryAmountSol,\n   146→    player1: data.creator.toBase58(),\n   147→    player1Side: creatorSide,\n   148→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   149→    player2Side: hasOpponent\n   150→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   151→      : null,\n   152→    phase,\n   153→    createdAt: Date.now(),\n   154→    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n   155→    result: isSettled ? sideFromIndex(data.result) : null,\n   156→    winner: isSettled && !isDefaultPubkey(data.winner)\n   157→      ? data.winner.toBase58()\n   158→      : null,\n   159→    claimed: data.claimed,\n   160→    payoutAmount,\n   161→    seedHash: \"\",\n   162→  };\n   163→}\n   164→\n   165→// ============ Account Queries ============\n   166→\n   167→export async function fetchAllOpenMatches(\n   168→  connection: Connection\n   169→): Promise<UIMatch[]> {\n   170→  const program = getCoinflipProgram(connection);\n   171→  const accounts = await program.account.coinflipMatch.all();\n   172→\n   173→  return accounts\n   174→    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n   175→    .map((acc) =>\n   176→      onChainMatchToUI(\n   177→        acc.publicKey,\n   178→        acc.account as unknown as OnChainMatch\n   179→      )\n   180→    );\n   181→}\n   182→\n   183→export async function fetchMatchByCreator(\n   184→  connection: Connection,\n   185→  creator: PublicKey\n   186→): Promise<UIMatch | null> {\n   187→  const program = getCoinflipProgram(connection);\n   188→  const [matchPda] = getMatchPda(creator);\n   189→\n   190→  try {\n   191→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   192→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   193→  } catch {\n   194→    // Account doesn't exist\n   195→    return null;\n   196→  }\n   197→}\n   198→\n   199→export async function fetchMatch(\n   200→  connection: Connection,\n   201→  matchPda: PublicKey\n   202→): Promise<UIMatch | null> {\n   203→  const program = getCoinflipProgram(connection);\n   204→\n   205→  try {\n   206→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   207→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   208→  } catch {\n   209→    return null;\n   210→  }\n   211→}\n   212→\n   213→// ============ Instruction Builders ============\n   214→\n   215→export function buildCreateMatchInstruction(\n   216→  creator: PublicKey,\n   217→  tier: Tier,\n   218→  side: CoinSide\n   219→): { instruction: TransactionInstruction; matchPda: PublicKey } {\n   220→  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n   221→  const [matchPda] = getMatchPda(creator);\n   222→  const [configPda] = getConfigPda();\n   223→\n   224→  const tierIndex = TIER_VALUES[tier];\n   225→  const sideIndex = COIN_SIDE_VALUES[side];\n   226→\n   227→  const instruction = program.methods\n   228→    .createMatch(tierIndex, sideIndex)\n   229→    .accountsStrict({\n   230→      creator,\n   231→      coinflipMatch: matchPda,\n   232→      config: configPda,\n   233→      systemProgram: SystemProgram.programId,\n   234→    })\n   235→    .instruction();\n   236→\n   237→  // instruction() returns a Promise<TransactionInstruction>, but we return\n   238→  // it synchronously wrapped — callers must await the instruction.\n   239→  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n   240→}\n   241→\n   242→export async function buildCreateMatchTx(\n   243→  connection: Connection,\n   244→  creator: PublicKey,\n   245→  tier: Tier,\n   246→  side: CoinSide\n   247→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   248→  const program = getCoinflipProgram(connection);\n   249→  const [matchPda] = getMatchPda(creator);\n   250→  const [configPda] = getConfigPda();\n   251→\n   252→  const tierIndex = TIER_VALUES[tier];\n   253→  const sideIndex = COIN_SIDE_VALUES[side];\n   254→\n   255→  const ix = await program.methods\n   256→    .createMatch(tierIndex, sideIndex)\n   257→    .accountsStrict({\n   258→      creator,\n   259→      coinflipMatch: matchPda,\n   260→      config: configPda,\n   261→      systemProgram: SystemProgram.programId,\n   262→    })\n   263→    .instruction();\n   264→\n   265→  const tx = new Transaction().add(ix);\n   266→  tx.feePayer = creator;\n   267→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   268→\n   269→  return { transaction: tx, matchPda };\n   270→}\n   271→\n   272→export async function buildJoinMatchTx(\n   273→  connection: Connection,\n   274→  opponent: PublicKey,\n   275→  matchCreator: PublicKey\n   276→): Promise<Transaction> {\n   277→  const program = getCoinflipProgram(connection);\n   278→  const [matchPda] = getMatchPda(matchCreator);\n   279→  const [configPda] = getConfigPda();\n   280→\n   281→  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n   282→  const oraoNetworkState = getOraoNetworkStatePda();\n   283→  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n   284→  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n   285→  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n   286→  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n   287→  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n   288→\n   289→  const ix = await program.methods\n   290→    .joinMatch()\n   291→    .accountsStrict({\n   292→      opponent,\n   293→      coinflipMatch: matchPda,\n   294→      config: configPda,\n   295→      oraoProgram: ORAO_VRF_PROGRAM_ID,\n   296→      oraoNetworkState,\n   297→      oraoTreasury,\n   298→      oraoRandom,\n   299→      systemProgram: SystemProgram.programId,\n   300→    })\n   301→    .instruction();\n   302→\n   303→  const tx = new Transaction().add(ix);\n   304→  tx.feePayer = opponent;\n   305→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   306→\n   307→  return tx;\n   308→}\n   309→\n   310→export async function buildCancelMatchTx(\n   311→  connection: Connection,\n   312→  creator: PublicKey\n   313→): Promise<Transaction> {\n   314→  const program = getCoinflipProgram(connection);\n   315→  const [matchPda] = getMatchPda(creator);\n   316→\n   317→  const ix = await program.methods\n   318→    .cancelMatch()\n   319→    .accountsStrict({\n   320→      creator,\n   321→      coinflipMatch: matchPda,\n   322→      systemProgram: SystemProgram.programId,\n   323→    })\n   324→    .instruction();\n   325→\n   326→  const tx = new Transaction().add(ix);\n   327→  tx.feePayer = creator;\n   328→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   329→\n   330→  return tx;\n   331→}\n   332→\n   333→export async function buildTimeoutCancelTx(\n   334→  connection: Connection,\n   335→  caller: PublicKey,\n   336→  matchCreator: PublicKey,\n   337→  opponent: PublicKey\n   338→): Promise<Transaction> {\n   339→  const program = getCoinflipProgram(connection);\n   340→  const [matchPda] = getMatchPda(matchCreator);\n   341→\n   342→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   343→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   344→\n   345→  const ix = await program.methods\n   346→    .timeoutCancel()\n   347→    .accountsStrict({\n   348→      caller,\n   349→      creator: matchCreator,\n   350→      opponent,\n   351→      coinflipMatch: matchPda,\n   352→      randomnessAccount,\n   353→    })\n   354→    .instruction();\n   355→\n   356→  const tx = new Transaction().add(ix);\n   357→  tx.feePayer = caller;\n   358→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   359→\n   360→  return tx;\n   361→}\n   362→\n   363→export async function buildClaimPayoutTx(\n   364→  connection: Connection,\n   365→  caller: PublicKey,\n   366→  matchCreator: PublicKey,\n   367→  opponent: PublicKey\n   368→): Promise<Transaction> {\n   369→  const program = getCoinflipProgram(connection);\n   370→  const [matchPda] = getMatchPda(matchCreator);\n   371→  const [configPda] = getConfigPda();\n   372→\n   373→  // Fetch config to get treasury address\n   374→  const config = await program.account.coinflipConfig.fetch(configPda);\n   375→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   376→\n   377→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   378→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   379→\n   380→  // Derive player profile PDAs for CPI\n   381→  const PLATFORM_PROGRAM_ID = new PublicKey(\n   382→    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n   383→      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n   384→  );\n   385→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   386→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   387→    PLATFORM_PROGRAM_ID\n   388→  );\n   389→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   390→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   391→    PLATFORM_PROGRAM_ID\n   392→  );\n   393→\n   394→  const ix = await program.methods\n   395→    .claimPayout()\n   396→    .accountsStrict({\n   397→      caller,\n   398→      coinflipMatch: matchPda,\n   399→      config: configPda,\n   400→      treasury,\n   401→      creator: matchCreator,\n   402→      opponent,\n   403→      randomnessAccount,\n   404→      creatorProfile,\n   405→      opponentProfile,\n   406→      platformProgram: PLATFORM_PROGRAM_ID,\n   407→      systemProgram: SystemProgram.programId,\n   408→    })\n   409→    .instruction();\n   410→\n   411→  const tx = new Transaction().add(ix);\n   412→  tx.feePayer = caller;\n   413→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   414→\n   415→  return tx;\n   416→}\n   417→"}]},"parent_tool_use_id":"toolu_01RkEJGU3bRAB1iyEqZLGEmf","session_id":"71f3d66f-916b-4438-95fb-e3b573af6aa8","uuid":"71a9d4ce-65f6-4d40-bd89-856a3934445e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EeXoqGnyWgNzHVYpnsyCSK","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\n     5→import {\n     6→  Keypair,\n     7→  PublicKey,\n     8→  SystemProgram,\n     9→  LAMPORTS_PER_SOL,\n    10→} from \"@solana/web3.js\";\n    11→import { Clock } from \"solana-bankrun\";\n    12→import type { Coinflip } from \"../target/types/coinflip\";\n    13→import type { Platform } from \"../target/types/platform\";\n    14→import { readFileSync } from \"fs\";\n    15→import { dirname, join } from \"path\";\n    16→import { fileURLToPath } from \"url\";\n    17→\n    18→const __filename = fileURLToPath(import.meta.url);\n    19→const __dirname = dirname(__filename);\n    20→\n    21→const IDL = JSON.parse(\n    22→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n    23→);\n    24→const PROGRAM_ID = new PublicKey(IDL.address);\n    25→\n    26→const PLATFORM_IDL = JSON.parse(\n    27→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    28→);\n    29→const PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Constants matching shared crate\n    33→// ---------------------------------------------------------------------------\n    34→const SIDE_HEADS = 0;\n    35→const SIDE_TAILS = 1;\n    36→const TIER_IRON = 0;\n    37→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n    38→const TOTAL_FEE_BPS = 300;\n    39→const DEFAULT_RESOLVE_TIMEOUT = 120; // seconds\n    40→\n    41→// Mock VRF randomness buffers (32 bytes each)\n    42→// HEADS: byte[0]=2 → 2%2=0=HEADS, non-zero so is_fulfilled=true\n    43→const RANDOMNESS_HEADS = (() => {\n    44→  const buf = Buffer.alloc(32);\n    45→  buf[0] = 2;\n    46→  return buf;\n    47→})();\n    48→// TAILS: byte[0]=1 → 1%2=1=TAILS, non-zero so is_fulfilled=true\n    49→const RANDOMNESS_TAILS = (() => {\n    50→  const buf = Buffer.alloc(32);\n    51→  buf[0] = 1;\n    52→  return buf;\n    53→})();\n    54→// Unfulfilled: all zeros → is_fulfilled=false\n    55→const RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n    56→\n    57→// ---------------------------------------------------------------------------\n    58→// PDA helpers\n    59→// ---------------------------------------------------------------------------\n    60→function getMatchPda(creator: PublicKey): PublicKey {\n    61→  const [pda] = PublicKey.findProgramAddressSync(\n    62→    [Buffer.from(\"match\"), creator.toBuffer()],\n    63→    PROGRAM_ID\n    64→  );\n    65→  return pda;\n    66→}\n    67→\n    68→function getConfigPda(): PublicKey {\n    69→  const [pda] = PublicKey.findProgramAddressSync(\n    70→    [Buffer.from(\"coinflip_config\")],\n    71→    PROGRAM_ID\n    72→  );\n    73→  return pda;\n    74→}\n    75→\n    76→function getPlatformConfigPda(): PublicKey {\n    77→  const [pda] = PublicKey.findProgramAddressSync(\n    78→    [Buffer.from(\"platform_config\")],\n    79→    PLATFORM_PROGRAM_ID\n    80→  );\n    81→  return pda;\n    82→}\n    83→\n    84→function getPlayerProfilePda(wallet: PublicKey): PublicKey {\n    85→  const [pda] = PublicKey.findProgramAddressSync(\n    86→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    87→    PLATFORM_PROGRAM_ID\n    88→  );\n    89→  return pda;\n    90→}\n    91→\n    92→// ---------------------------------------------------------------------------\n    93→// Test context factory\n    94→// ---------------------------------------------------------------------------\n    95→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n    96→  return {\n    97→    lamports,\n    98→    data: Buffer.alloc(0),\n    99→    owner: SystemProgram.programId,\n   100→    executable: false,\n   101→  };\n   102→}\n   103→\n   104→interface TestContext {\n   105→  context: Awaited<ReturnType<typeof startAnchor>>;\n   106→  creator: PublicKey;\n   107→  opponent: Keypair;\n   108→  treasury: Keypair;\n   109→  mockRandomness: Keypair;\n   110→  mockOraoProgram: Keypair;\n   111→  mockOraoNetworkState: Keypair;\n   112→  mockOraoTreasury: Keypair;\n   113→  creatorProgram: Program<Coinflip>;\n   114→  opponentProgram: Program<Coinflip>;\n   115→  platformProgram: Program<Platform>;\n   116→  opponentPlatformProgram: Program<Platform>;\n   117→  configPda: PublicKey;\n   118→  matchPda: PublicKey;\n   119→  platformConfigPda: PublicKey;\n   120→  creatorProfilePda: PublicKey;\n   121→  opponentProfilePda: PublicKey;\n   122→}\n   123→\n   124→async function createTestContext(): Promise<TestContext> {\n   125→  const opponent = Keypair.generate();\n   126→  const treasury = Keypair.generate();\n   127→  const mockRandomness = Keypair.generate();\n   128→  const mockOraoProgram = Keypair.generate();\n   129→  const mockOraoNetworkState = Keypair.generate();\n   130→  const mockOraoTreasury = Keypair.generate();\n   131→\n   132→  const context = await startAnchor(\"./\", [], [\n   133→    { address: opponent.publicKey, info: fundedAccountData() },\n   134→    { address: treasury.publicKey, info: fundedAccountData() },\n   135→    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n   136→    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n   137→    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n   138→    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n   139→    // Mock randomness account — starts unfulfilled (32 zero bytes)\n   140→    {\n   141→      address: mockRandomness.publicKey,\n   142→      info: {\n   143→        lamports: LAMPORTS_PER_SOL,\n   144→        data: RANDOMNESS_UNFULFILLED,\n   145→        owner: SystemProgram.programId,\n   146→        executable: false,\n   147→      },\n   148→    },\n   149→  ]);\n   150→\n   151→  const creatorProvider = new BankrunProvider(context);\n   152→  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n   153→\n   154→  const opponentProvider = new BankrunProvider(context, new Wallet(opponent));\n   155→  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n   156→\n   157→  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n   158→  const opponentPlatformProgram = new Program<Platform>(\n   159→    PLATFORM_IDL,\n   160→    opponentProvider\n   161→  );\n   162→\n   163→  const creator = creatorProvider.wallet.publicKey;\n   164→  const configPda = getConfigPda();\n   165→  const matchPda = getMatchPda(creator);\n   166→  const platformConfigPda = getPlatformConfigPda();\n   167→  const creatorProfilePda = getPlayerProfilePda(creator);\n   168→  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n   169→\n   170→  return {\n   171→    context,\n   172→    creator,\n   173→    opponent,\n   174→    treasury,\n   175→    mockRandomness,\n   176→    mockOraoProgram,\n   177→    mockOraoNetworkState,\n   178→    mockOraoTreasury,\n   179→    creatorProgram,\n   180→    opponentProgram,\n   181→    platformProgram,\n   182→    opponentPlatformProgram,\n   183→    configPda,\n   184→    matchPda,\n   185→    platformConfigPda,\n   186→    creatorProfilePda,\n   187→    opponentProfilePda,\n   188→  };\n   189→}\n   190→\n   191→// ---------------------------------------------------------------------------\n   192→// Instruction helpers\n   193→// ---------------------------------------------------------------------------\n   194→async function initConfig(t: TestContext) {\n   195→  await t.creatorProgram.methods\n   196→    .initializeConfig(t.treasury.publicKey)\n   197→    .accounts({\n   198→      authority: t.creator,\n   199→      config: t.configPda,\n   200→      systemProgram: SystemProgram.programId,\n   201→    })\n   202→    .rpc();\n   203→}\n   204→\n   205→async function initPlatform(t: TestContext) {\n   206→  await t.platformProgram.methods\n   207→    .initializePlatform(t.treasury.publicKey)\n   208→    .accounts({\n   209→      authority: t.creator,\n   210→      config: t.platformConfigPda,\n   211→      systemProgram: SystemProgram.programId,\n   212→    })\n   213→    .rpc();\n   214→}\n   215→\n   216→async function createPlayerProfile(\n   217→  t: TestContext,\n   218→  program: Program<Platform>,\n   219→  player: PublicKey\n   220→) {\n   221→  const profilePda = getPlayerProfilePda(player);\n   222→  await program.methods\n   223→    .createPlayerProfile()\n   224→    .accounts({\n   225→      player,\n   226→      profile: profilePda,\n   227→      systemProgram: SystemProgram.programId,\n   228→    })\n   229→    .rpc();\n   230→}\n   231→\n   232→async function setupPlatform(t: TestContext) {\n   233→  await initPlatform(t);\n   234→  await createPlayerProfile(t, t.platformProgram, t.creator);\n   235→  await createPlayerProfile(\n   236→    t,\n   237→    t.opponentPlatformProgram,\n   238→    t.opponent.publicKey\n   239→  );\n   240→}\n   241→\n   242→async function createMatch(\n   243→  t: TestContext,\n   244→  tier = TIER_IRON,\n   245→  side = SIDE_HEADS\n   246→) {\n   247→  await t.creatorProgram.methods\n   248→    .createMatch(tier, side)\n   249→    .accounts({\n   250→      creator: t.creator,\n   251→      coinflipMatch: t.matchPda,\n   252→      config: t.configPda,\n   253→      systemProgram: SystemProgram.programId,\n   254→    })\n   255→    .rpc();\n   256→}\n   257→\n   258→async function joinMatch(t: TestContext) {\n   259→  await t.opponentProgram.methods\n   260→    .joinMatch()\n   261→    .accounts({\n   262→      opponent: t.opponent.publicKey,\n   263→      coinflipMatch: t.matchPda,\n   264→      config: t.configPda,\n   265→      oraoProgram: t.mockOraoProgram.publicKey,\n   266→      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   267→      oraoTreasury: t.mockOraoTreasury.publicKey,\n   268→      oraoRandom: t.mockRandomness.publicKey,\n   269→      systemProgram: SystemProgram.programId,\n   270→    })\n   271→    .rpc();\n   272→}\n   273→\n   274→async function claimPayout(\n   275→  t: TestContext,\n   276→  callerProgram: Program<Coinflip>,\n   277→  callerPubkey: PublicKey\n   278→) {\n   279→  await callerProgram.methods\n   280→    .claimPayout()\n   281→    .accounts({\n   282→      caller: callerPubkey,\n   283→      coinflipMatch: t.matchPda,\n   284→      config: t.configPda,\n   285→      treasury: t.treasury.publicKey,\n   286→      creator: t.creator,\n   287→      opponent: t.opponent.publicKey,\n   288→      randomnessAccount: t.mockRandomness.publicKey,\n   289→      creatorProfile: t.creatorProfilePda,\n   290→      opponentProfile: t.opponentProfilePda,\n   291→      platformProgram: PLATFORM_PROGRAM_ID,\n   292→      systemProgram: SystemProgram.programId,\n   293→    })\n   294→    .rpc();\n   295→}\n   296→\n   297→async function cancelMatch(t: TestContext) {\n   298→  await t.creatorProgram.methods\n   299→    .cancelMatch()\n   300→    .accounts({\n   301→      creator: t.creator,\n   302→      coinflipMatch: t.matchPda,\n   303→      systemProgram: SystemProgram.programId,\n   304→    })\n   305→    .rpc();\n   306→}\n   307→\n   308→async function timeoutCancel(\n   309→  t: TestContext,\n   310→  callerProgram: Program<Coinflip>,\n   311→  callerPubkey: PublicKey\n   312→) {\n   313→  await callerProgram.methods\n   314→    .timeoutCancel()\n   315→    .accounts({\n   316→      caller: callerPubkey,\n   317→      creator: t.creator,\n   318→      opponent: t.opponent.publicKey,\n   319→      coinflipMatch: t.matchPda,\n   320→      randomnessAccount: t.mockRandomness.publicKey,\n   321→    })\n   322→    .rpc();\n   323→}\n   324→\n   325→function setMockRandomness(t: TestContext, data: Buffer) {\n   326→  t.context.setAccount(t.mockRandomness.publicKey, {\n   327→    lamports: LAMPORTS_PER_SOL,\n   328→    data,\n   329→    owner: SystemProgram.programId,\n   330→    executable: false,\n   331→  });\n   332→}\n   333→\n   334→async function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n   335→  const account = await t.context.banksClient.getAccount(pubkey);\n   336→  return account ? Number(account.lamports) : 0;\n   337→}\n   338→\n   339→async function warpPastDeadline(t: TestContext) {\n   340→  const clock = await t.context.banksClient.getClock();\n   341→  t.context.setClock(\n   342→    new Clock(\n   343→      clock.slot + BigInt(300),\n   344→      clock.epochStartTimestamp,\n   345→      clock.epoch,\n   346→      clock.leaderScheduleEpoch,\n   347→      clock.unixTimestamp + BigInt(DEFAULT_RESOLVE_TIMEOUT + 10)\n   348→    )\n   349→  );\n   350→}\n   351→\n   352→// ===========================================================================\n   353→// Tests\n   354→// ===========================================================================\n   355→describe(\"coinflip\", () => {\n   356→  // -----------------------------------------------------------------------\n   357→  // initialize_config\n   358→  // -----------------------------------------------------------------------\n   359→  describe(\"initialize_config\", () => {\n   360→    it(\"creates config with treasury and paused=false\", async () => {\n   361→      const t = await createTestContext();\n   362→      await initConfig(t);\n   363→\n   364→      const config = await t.creatorProgram.account.coinflipConfig.fetch(\n   365→        t.configPda\n   366→      );\n   367→      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n   368→      expect(config.treasury.toBase58()).to.equal(\n   369→        t.treasury.publicKey.toBase58()\n   370→      );\n   371→      expect(config.paused).to.equal(false);\n   372→    });\n   373→  });\n   374→\n   375→  // -----------------------------------------------------------------------\n   376→  // create_match\n   377→  // -----------------------------------------------------------------------\n   378→  describe(\"create_match\", () => {\n   379→    it(\"creates match in Waiting phase with correct escrow\", async () => {\n   380→      const t = await createTestContext();\n   381→      await initConfig(t);\n   382→      await createMatch(t);\n   383→\n   384→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   385→      expect(m.creator.toBase58()).to.equal(t.creator.toBase58());\n   386→      expect(m.opponent.toBase58()).to.equal(PublicKey.default.toBase58());\n   387→      expect(m.tier).to.equal(TIER_IRON);\n   388→      expect(m.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   389→      expect(m.creatorSide).to.equal(SIDE_HEADS);\n   390→      expect(JSON.stringify(m.phase)).to.equal(JSON.stringify({ waiting: {} }));\n   391→      expect(m.claimed).to.equal(false);\n   392→      expect(m.createdAt.toNumber()).to.be.greaterThan(0);\n   393→    });\n   394→\n   395→    it(\"escrows correct lamport amount\", async () => {\n   396→      const t = await createTestContext();\n   397→      await initConfig(t);\n   398→      const balanceBefore = await getBalance(t, t.creator);\n   399→\n   400→      await createMatch(t);\n   401→\n   402→      const matchBalance = await getBalance(t, t.matchPda);\n   403→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   404→      const rentLamports = matchBalance - m.entryAmount.toNumber();\n   405→      expect(rentLamports).to.be.greaterThan(0);\n   406→      expect(m.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   407→\n   408→      const balanceAfter = await getBalance(t, t.creator);\n   409→      const spent = balanceBefore - balanceAfter;\n   410→      // Creator paid entry_amount + rent + tx fee (5000)\n   411→      expect(spent - matchBalance).to.equal(5000);\n   412→    });\n   413→\n   414→    it(\"rejects invalid side\", async () => {\n   415→      const t = await createTestContext();\n   416→      await initConfig(t);\n   417→      try {\n   418→        await t.creatorProgram.methods\n   419→          .createMatch(TIER_IRON, 3)\n   420→          .accounts({\n   421→            creator: t.creator,\n   422→            coinflipMatch: t.matchPda,\n   423→            config: t.configPda,\n   424→            systemProgram: SystemProgram.programId,\n   425→          })\n   426→          .rpc();\n   427→        expect.fail(\"Expected InvalidSide error\");\n   428→      } catch (err) {\n   429→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   430→          \"InvalidSide\"\n   431→        );\n   432→      }\n   433→    });\n   434→\n   435→    it(\"rejects invalid tier\", async () => {\n   436→      const t = await createTestContext();\n   437→      await initConfig(t);\n   438→      try {\n   439→        await t.creatorProgram.methods\n   440→          .createMatch(99, SIDE_HEADS)\n   441→          .accounts({\n   442→            creator: t.creator,\n   443→            coinflipMatch: t.matchPda,\n   444→            config: t.configPda,\n   445→            systemProgram: SystemProgram.programId,\n   446→          })\n   447→          .rpc();\n   448→        expect.fail(\"Expected InvalidTier error\");\n   449→      } catch (err) {\n   450→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   451→          \"InvalidTier\"\n   452→        );\n   453→      }\n   454→    });\n   455→  });\n   456→\n   457→  // -----------------------------------------------------------------------\n   458→  // join_match\n   459→  // -----------------------------------------------------------------------\n   460→  describe(\"join_match\", () => {\n   461→    it(\"transitions to Locked, doubles escrow, sets VRF fields\", async () => {\n   462→      const t = await createTestContext();\n   463→      await initConfig(t);\n   464→      await createMatch(t);\n   465→\n   466→      const escrowBefore = await getBalance(t, t.matchPda);\n   467→      await joinMatch(t);\n   468→\n   469→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   470→      expect(m.opponent.toBase58()).to.equal(\n   471→        t.opponent.publicKey.toBase58()\n   472→      );\n   473→      expect(JSON.stringify(m.phase)).to.equal(\n   474→        JSON.stringify({ locked: {} })\n   475→      );\n   476→      expect(m.vrfRequestKey.toBase58()).to.equal(\n   477→        t.mockRandomness.publicKey.toBase58()\n   478→      );\n   479→      expect(m.resolveDeadline.toNumber()).to.be.greaterThan(0);\n   480→      expect(m.lockedAt.toNumber()).to.be.greaterThan(0);\n   481→\n   482→      const escrowAfter = await getBalance(t, t.matchPda);\n   483→      expect(escrowAfter - escrowBefore).to.equal(TIER_IRON_AMOUNT);\n   484→    });\n   485→\n   486→    it(\"rejects self-join\", async () => {\n   487→      const t = await createTestContext();\n   488→      await initConfig(t);\n   489→      await createMatch(t);\n   490→\n   491→      try {\n   492→        await t.creatorProgram.methods\n   493→          .joinMatch()\n   494→          .accounts({\n   495→            opponent: t.creator,\n   496→            coinflipMatch: t.matchPda,\n   497→            config: t.configPda,\n   498→            oraoProgram: t.mockOraoProgram.publicKey,\n   499→            oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   500→            oraoTreasury: t.mockOraoTreasury.publicKey,\n   501→            oraoRandom: t.mockRandomness.publicKey,\n   502→            systemProgram: SystemProgram.programId,\n   503→          })\n   504→          .rpc();\n   505→        expect.fail(\"Expected CannotJoinOwnMatch error\");\n   506→      } catch (err) {\n   507→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   508→          \"CannotJoinOwnMatch\"\n   509→        );\n   510→      }\n   511→    });\n   512→\n   513→    it(\"rejects join when already Locked\", async () => {\n   514→      const t = await createTestContext();\n   515→      await initConfig(t);\n   516→      await createMatch(t);\n   517→      await joinMatch(t);\n   518→\n   519→      const secondOpponent = Keypair.generate();\n   520→      t.context.setAccount(secondOpponent.publicKey, fundedAccountData());\n   521→      const secondProvider = new BankrunProvider(\n   522→        t.context,\n   523→        new Wallet(secondOpponent)\n   524→      );\n   525→      const secondProgram = new Program<Coinflip>(IDL, secondProvider);\n   526→\n   527→      try {\n   528→        await secondProgram.methods\n   529→          .joinMatch()\n   530→          .accounts({\n   531→            opponent: secondOpponent.publicKey,\n   532→            coinflipMatch: t.matchPda,\n   533→            config: t.configPda,\n   534→            oraoProgram: t.mockOraoProgram.publicKey,\n   535→            oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   536→            oraoTreasury: t.mockOraoTreasury.publicKey,\n   537→            oraoRandom: t.mockRandomness.publicKey,\n   538→            systemProgram: SystemProgram.programId,\n   539→          })\n   540→          .rpc();\n   541→        expect.fail(\"Expected InvalidTransition error\");\n   542→      } catch (err) {\n   543→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   544→          \"InvalidTransition\"\n   545→        );\n   546→      }\n   547→    });\n   548→  });\n   549→\n   550→  // -----------------------------------------------------------------------\n   551→  // claim_payout\n   552→  // -----------------------------------------------------------------------\n   553→  describe(\"claim_payout\", () => {\n   554→    it(\"creator wins with HEADS, fee to treasury\", async () => {\n   555→      const t = await createTestContext();\n   556→      await initConfig(t);\n   557→      await setupPlatform(t);\n   558→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   559→      await joinMatch(t);\n   560→\n   561→      // Write fulfilled randomness: byte[0]=2 → HEADS\n   562→      setMockRandomness(t, RANDOMNESS_HEADS);\n   563→\n   564→      const pool = TIER_IRON_AMOUNT * 2;\n   565→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   566→      const payout = pool - fee;\n   567→\n   568→      const winnerBefore = await getBalance(t, t.creator);\n   569→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   570→\n   571→      await claimPayout(t, t.creatorProgram, t.creator);\n   572→\n   573→      const winnerAfter = await getBalance(t, t.creator);\n   574→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   575→\n   576→      // Creator receives payout + rent refund from closed PDA (minus tx fee)\n   577→      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n   578→      // Treasury receives exact fee\n   579→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   580→    });\n   581→\n   582→    it(\"opponent wins with TAILS\", async () => {\n   583→      const t = await createTestContext();\n   584→      await initConfig(t);\n   585→      await setupPlatform(t);\n   586→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   587→      await joinMatch(t);\n   588→\n   589→      setMockRandomness(t, RANDOMNESS_TAILS);\n   590→\n   591→      const pool = TIER_IRON_AMOUNT * 2;\n   592→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   593→      const payout = pool - fee;\n   594→\n   595→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   596→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   597→\n   598→      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n   599→\n   600→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n   601→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   602→\n   603→      // Opponent receives payout (minus tx fee of 5000)\n   604→      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(\n   605→        payout - 5000\n   606→      );\n   607→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   608→    });\n   609→\n   610→    it(\"either player can trigger claim — payout goes to derived winner\", async () => {\n   611→      const t = await createTestContext();\n   612→      await initConfig(t);\n   613→      await setupPlatform(t);\n   614→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   615→      await joinMatch(t);\n   616→\n   617→      // TAILS → opponent wins, but creator triggers claim\n   618→      setMockRandomness(t, RANDOMNESS_TAILS);\n   619→\n   620→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   621→\n   622→      // Creator calls claim, but payout goes to opponent (derived winner)\n   623→      await claimPayout(t, t.creatorProgram, t.creator);\n   624→\n   625→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n   626→      const pool = TIER_IRON_AMOUNT * 2;\n   627→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   628→      const payout = pool - fee;\n   629→\n   630→      // Opponent didn't call any tx, so exact payout (no tx fee deduction)\n   631→      expect(opponentAfter - opponentBefore).to.equal(payout);\n   632→    });\n   633→\n   634→    it(\"match PDA closed after claim\", async () => {\n   635→      const t = await createTestContext();\n   636→      await initConfig(t);\n   637→      await setupPlatform(t);\n   638→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   639→      await joinMatch(t);\n   640→      setMockRandomness(t, RANDOMNESS_HEADS);\n   641→\n   642→      await claimPayout(t, t.creatorProgram, t.creator);\n   643→\n   644→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   645→      expect(matchAccount).to.be.null;\n   646→    });\n   647→\n   648→    it(\"rejects claim with unfulfilled randomness\", async () => {\n   649→      const t = await createTestContext();\n   650→      await initConfig(t);\n   651→      await setupPlatform(t);\n   652→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   653→      await joinMatch(t);\n   654→      // Randomness stays all zeros (unfulfilled)\n   655→\n   656→      try {\n   657→        await claimPayout(t, t.creatorProgram, t.creator);\n   658→        expect.fail(\"Expected RandomnessNotFulfilled error\");\n   659→      } catch (err) {\n   660→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   661→          \"RandomnessNotFulfilled\"\n   662→        );\n   663→      }\n   664→    });\n   665→\n   666→    it(\"rejects double claim (account closed)\", async () => {\n   667→      const t = await createTestContext();\n   668→      await initConfig(t);\n   669→      await setupPlatform(t);\n   670→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   671→      await joinMatch(t);\n   672→      setMockRandomness(t, RANDOMNESS_HEADS);\n   673→\n   674→      await claimPayout(t, t.creatorProgram, t.creator);\n   675→\n   676→      try {\n   677→        await claimPayout(t, t.creatorProgram, t.creator);\n   678→        expect.fail(\"Expected error on double claim\");\n   679→      } catch (err) {\n   680→        // Account is closed — second claim fails\n   681→        expect(err).to.exist;\n   682→      }\n   683→    });\n   684→\n   685→    it(\"rejects unauthorized caller (not creator or opponent)\", async () => {\n   686→      const t = await createTestContext();\n   687→      await initConfig(t);\n   688→      await setupPlatform(t);\n   689→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   690→      await joinMatch(t);\n   691→      setMockRandomness(t, RANDOMNESS_HEADS);\n   692→\n   693→      const thirdParty = Keypair.generate();\n   694→      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n   695→      const thirdProvider = new BankrunProvider(\n   696→        t.context,\n   697→        new Wallet(thirdParty)\n   698→      );\n   699→      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n   700→\n   701→      try {\n   702→        await thirdProgram.methods\n   703→          .claimPayout()\n   704→          .accounts({\n   705→            caller: thirdParty.publicKey,\n   706→            coinflipMatch: t.matchPda,\n   707→            config: t.configPda,\n   708→            treasury: t.treasury.publicKey,\n   709→            creator: t.creator,\n   710→            opponent: t.opponent.publicKey,\n   711→            randomnessAccount: t.mockRandomness.publicKey,\n   712→            creatorProfile: t.creatorProfilePda,\n   713→            opponentProfile: t.opponentProfilePda,\n   714→            platformProgram: PLATFORM_PROGRAM_ID,\n   715→            systemProgram: SystemProgram.programId,\n   716→          })\n   717→          .rpc();\n   718→        expect.fail(\"Expected UnauthorizedCaller error\");\n   719→      } catch (err) {\n   720→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   721→          \"UnauthorizedCaller\"\n   722→        );\n   723→      }\n   724→    });\n   725→\n   726→    it(\"updates player profiles via CPI — creator wins\", async () => {\n   727→      const t = await createTestContext();\n   728→      await initConfig(t);\n   729→      await setupPlatform(t);\n   730→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   731→      await joinMatch(t);\n   732→      setMockRandomness(t, RANDOMNESS_HEADS);\n   733→\n   734→      await claimPayout(t, t.creatorProgram, t.creator);\n   735→\n   736→      const pool = TIER_IRON_AMOUNT * 2;\n   737→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   738→      const payout = pool - fee;\n   739→\n   740→      const cp = await t.platformProgram.account.playerProfile.fetch(\n   741→        t.creatorProfilePda\n   742→      );\n   743→      expect(cp.totalGames.toNumber()).to.equal(1);\n   744→      expect(cp.wins.toNumber()).to.equal(1);\n   745→      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   746→      expect(cp.totalWon.toNumber()).to.equal(payout);\n   747→\n   748→      const op = await t.platformProgram.account.playerProfile.fetch(\n   749→        t.opponentProfilePda\n   750→      );\n   751→      expect(op.totalGames.toNumber()).to.equal(1);\n   752→      expect(op.wins.toNumber()).to.equal(0);\n   753→      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   754→      expect(op.totalWon.toNumber()).to.equal(0);\n   755→    });\n   756→\n   757→    it(\"updates player profiles via CPI — opponent wins\", async () => {\n   758→      const t = await createTestContext();\n   759→      await initConfig(t);\n   760→      await setupPlatform(t);\n   761→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   762→      await joinMatch(t);\n   763→      setMockRandomness(t, RANDOMNESS_TAILS);\n   764→\n   765→      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n   766→\n   767→      const pool = TIER_IRON_AMOUNT * 2;\n   768→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   769→      const payout = pool - fee;\n   770→\n   771→      const cp = await t.platformProgram.account.playerProfile.fetch(\n   772→        t.creatorProfilePda\n   773→      );\n   774→      expect(cp.totalGames.toNumber()).to.equal(1);\n   775→      expect(cp.wins.toNumber()).to.equal(0);\n   776→      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   777→      expect(cp.totalWon.toNumber()).to.equal(0);\n   778→\n   779→      const op = await t.platformProgram.account.playerProfile.fetch(\n   780→        t.opponentProfilePda\n   781→      );\n   782→      expect(op.totalGames.toNumber()).to.equal(1);\n   783→      expect(op.wins.toNumber()).to.equal(1);\n   784→      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   785→      expect(op.totalWon.toNumber()).to.equal(payout);\n   786→    });\n   787→  });\n   788→\n   789→  // -----------------------------------------------------------------------\n   790→  // cancel_match\n   791→  // -----------------------------------------------------------------------\n   792→  describe(\"cancel_match\", () => {\n   793→    it(\"creator cancels Waiting match, full refund\", async () => {\n   794→      const t = await createTestContext();\n   795→      await initConfig(t);\n   796→      await createMatch(t);\n   797→\n   798→      const balanceBefore = await getBalance(t, t.creator);\n   799→      await cancelMatch(t);\n   800→      const balanceAfter = await getBalance(t, t.creator);\n   801→\n   802→      // Creator gets escrow + rent back (minus tx fee)\n   803→      expect(balanceAfter - balanceBefore).to.be.greaterThanOrEqual(\n   804→        TIER_IRON_AMOUNT\n   805→      );\n   806→\n   807→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   808→      expect(matchAccount).to.be.null;\n   809→    });\n   810→\n   811→    it(\"rejects cancel after Locked (CannotCancel)\", async () => {\n   812→      const t = await createTestContext();\n   813→      await initConfig(t);\n   814→      await createMatch(t);\n   815→      await joinMatch(t);\n   816→\n   817→      try {\n   818→        await cancelMatch(t);\n   819→        expect.fail(\"Expected CannotCancel error\");\n   820→      } catch (err) {\n   821→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   822→          \"CannotCancel\"\n   823→        );\n   824→      }\n   825→    });\n   826→\n   827→    it(\"rejects cancel by non-creator\", async () => {\n   828→      const t = await createTestContext();\n   829→      await initConfig(t);\n   830→      await createMatch(t);\n   831→\n   832→      // Opponent tries to cancel creator's match — PDA mismatch\n   833→      const opponentMatchPda = getMatchPda(t.opponent.publicKey);\n   834→      try {\n   835→        await t.opponentProgram.methods\n   836→          .cancelMatch()\n   837→          .accounts({\n   838→            creator: t.opponent.publicKey,\n   839→            coinflipMatch: opponentMatchPda,\n   840→            systemProgram: SystemProgram.programId,\n   841→          })\n   842→          .rpc();\n   843→        expect.fail(\"Expected error\");\n   844→      } catch (err) {\n   845→        // PDA doesn't exist → AccountNotInitialized\n   846→        expect(err).to.exist;\n   847→      }\n   848→    });\n   849→  });\n   850→\n   851→  // -----------------------------------------------------------------------\n   852→  // timeout_cancel\n   853→  // -----------------------------------------------------------------------\n   854→  describe(\"timeout_cancel\", () => {\n   855→    it(\"permissionless refund after deadline when VRF unfulfilled\", async () => {\n   856→      const t = await createTestContext();\n   857→      await initConfig(t);\n   858→      await createMatch(t);\n   859→      await joinMatch(t);\n   860→      // Randomness stays unfulfilled (all zeros)\n   861→\n   862→      await warpPastDeadline(t);\n   863→\n   864→      const creatorBefore = await getBalance(t, t.creator);\n   865→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   866→\n   867→      // Third party triggers timeout (permissionless)\n   868→      const thirdParty = Keypair.generate();\n   869→      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n   870→      const thirdProvider = new BankrunProvider(\n   871→        t.context,\n   872→        new Wallet(thirdParty)\n   873→      );\n   874→      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n   875→\n   876→      await timeoutCancel(t, thirdProgram, thirdParty.publicKey);\n   877→\n   878→      const creatorAfter = await getBalance(t, t.creator);\n   879→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n   880→\n   881→      // Both players refunded entry amounts\n   882→      // Creator also gets rent refund from closed PDA\n   883→      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n   884→        TIER_IRON_AMOUNT\n   885→      );\n   886→      expect(opponentAfter - opponentBefore).to.equal(TIER_IRON_AMOUNT);\n   887→\n   888→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   889→      expect(matchAccount).to.be.null;\n   890→    });\n   891→\n   892→    it(\"rejects timeout before deadline\", async () => {\n   893→      const t = await createTestContext();\n   894→      await initConfig(t);\n   895→      await createMatch(t);\n   896→      await joinMatch(t);\n   897→      // Don't warp clock\n   898→\n   899→      try {\n   900→        await timeoutCancel(t, t.creatorProgram, t.creator);\n   901→        expect.fail(\"Expected LockTimeoutNotElapsed error\");\n   902→      } catch (err) {\n   903→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   904→          \"LockTimeoutNotElapsed\"\n   905→        );\n   906→      }\n   907→    });\n   908→\n   909→    it(\"rejects timeout when VRF IS fulfilled — must claim instead\", async () => {\n   910→      const t = await createTestContext();\n   911→      await initConfig(t);\n   912→      await createMatch(t);\n   913→      await joinMatch(t);\n   914→\n   915→      // Set fulfilled randomness\n   916→      setMockRandomness(t, RANDOMNESS_HEADS);\n   917→      await warpPastDeadline(t);\n   918→\n   919→      try {\n   920→        await timeoutCancel(t, t.creatorProgram, t.creator);\n   921→        expect.fail(\"Expected error — VRF fulfilled, must claim\");\n   922→      } catch (err) {\n   923→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   924→          \"InvalidPhase\"\n   925→        );\n   926→      }\n   927→    });\n   928→  });\n   929→\n   930→  // -----------------------------------------------------------------------\n   931→  // full lifecycle\n   932→  // -----------------------------------------------------------------------\n   933→  describe(\"full lifecycle\", () => {\n   934→    it(\"create → join → claim(HEADS) → PDA closed\", async () => {\n   935→      const t = await createTestContext();\n   936→      await initConfig(t);\n   937→      await setupPlatform(t);\n   938→\n   939→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   940→      let m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   941→      expect(JSON.stringify(m.phase)).to.equal(\n   942→        JSON.stringify({ waiting: {} })\n   943→      );\n   944→\n   945→      await joinMatch(t);\n   946→      m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   947→      expect(JSON.stringify(m.phase)).to.equal(\n   948→        JSON.stringify({ locked: {} })\n   949→      );\n   950→\n   951→      setMockRandomness(t, RANDOMNESS_HEADS);\n   952→\n   953→      const pool = TIER_IRON_AMOUNT * 2;\n   954→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   955→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   956→\n   957→      await claimPayout(t, t.creatorProgram, t.creator);\n   958→\n   959→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   960→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   961→\n   962→      const closed = await t.context.banksClient.getAccount(t.matchPda);\n   963→      expect(closed).to.be.null;\n   964→    });\n   965→\n   966→    it(\"create → cancel → create again\", async () => {\n   967→      const t = await createTestContext();\n   968→      await initConfig(t);\n   969→\n   970→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   971→      await cancelMatch(t);\n   972→\n   973→      const closed = await t.context.banksClient.getAccount(t.matchPda);\n   974→      expect(closed).to.be.null;\n   975→\n   976→      // Create again (same PDA slot is free)\n   977→      await createMatch(t, TIER_IRON, SIDE_TAILS);\n   978→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   979→      expect(m.creatorSide).to.equal(SIDE_TAILS);\n   980→      expect(JSON.stringify(m.phase)).to.equal(\n   981→        JSON.stringify({ waiting: {} })\n   982→      );\n   983→    });\n   984→\n   985→    it(\"create → join → timeout (VRF unfulfilled) → both refunded\", async () => {\n   986→      const t = await createTestContext();\n   987→      await initConfig(t);\n   988→\n   989→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   990→      await joinMatch(t);\n   991→\n   992→      await warpPastDeadline(t);\n   993→\n   994→      const creatorBefore = await getBalance(t, t.creator);\n   995→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   996→\n   997→      await timeoutCancel(t, t.opponentProgram, t.opponent.publicKey);\n   998→\n   999→      const creatorAfter = await getBalance(t, t.creator);\n  1000→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n  1001→\n  1002→      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n  1003→        TIER_IRON_AMOUNT\n  1004→      );\n  1005→      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(\n  1006→        TIER_IRON_AMOUNT - 5000\n  1007→      ); // minus tx fee\n  1008→    });\n  1009→  });\n  1010→});\n  1011→"}]},"parent_tool_use_id":"toolu_01RkEJGU3bRAB1iyEqZLGEmf","session_id":"71f3d66f-916b-4438-95fb-e3b573af6aa8","uuid":"cc517130-531a-45c4-9990-969d6c5f6042"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01TWxrdfqFCtec8BczC3VyuQ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NDQdfLK1zWYUw8Dy3ipdKe","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":3201,"cache_read_input_tokens":21539,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3201},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01RkEJGU3bRAB1iyEqZLGEmf","session_id":"71f3d66f-916b-4438-95fb-e3b573af6aa8","uuid":"88f66509-65db-4e41-aa13-907a6cfebc36"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NDQdfLK1zWYUw8Dy3ipdKe","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey, type Transaction } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchMatchByCreator,\n    16→  fetchMatch,\n    17→  getMatchPda,\n    18→  buildCreateMatchTx,\n    19→  buildJoinMatchTx,\n    20→  buildCancelMatchTx,\n    21→  buildTimeoutCancelTx,\n    22→  buildClaimPayoutTx,\n    23→} from \"../utils/chain\";\n    24→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    25→\n    26→/** Parse Solana/wallet errors into user-friendly messages */\n    27→function parseTransactionError(err: unknown): string {\n    28→  const msg = err instanceof Error ? err.message : String(err);\n    29→\n    30→  // Wallet not connected\n    31→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    32→    return \"Wallet not connected. Please connect your wallet first.\";\n    33→  }\n    34→\n    35→  // User rejected\n    36→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    37→    return \"Transaction cancelled by user.\";\n    38→  }\n    39→\n    40→  // Insufficient funds (Solana runtime error)\n    41→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    42→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    43→  }\n    44→\n    45→  // Account already in use (match already exists)\n    46→  if (msg.includes(\"already in use\")) {\n    47→    return \"You already have an active match. Cancel it before creating a new one.\";\n    48→  }\n    49→\n    50→  // Network / RPC errors\n    51→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    52→    return \"Network error. Please check your connection and try again.\";\n    53→  }\n    54→\n    55→  // Anchor program errors\n    56→  if (msg.includes(\"InvalidPhase\")) {\n    57→    return \"This match is no longer available.\";\n    58→  }\n    59→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    60→    return \"You cannot join your own match.\";\n    61→  }\n    62→\n    63→  // Simulation / preflight failures\n    64→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    65→    return \"Transaction simulation failed. The match may no longer be available.\";\n    66→  }\n    67→\n    68→  // Blockhash expiry\n    69→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    70→    return \"Transaction expired. Please try again.\";\n    71→  }\n    72→\n    73→  // Generic fallback — log full error for debugging\n    74→  console.error(\"[coinflip] unhandled transaction error:\", err);\n    75→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    76→}\n    77→\n    78→interface CoinflipContextValue {\n    79→  // State\n    80→  activeMatch: UIMatch | null;\n    81→  openMatches: UIMatch[];\n    82→  userHistory: UIMatch[];\n    83→  selectedTier: Tier | null;\n    84→  selectedSide: CoinSide | null;\n    85→\n    86→  // Loading states\n    87→  loading: boolean;\n    88→  creating: boolean;\n    89→  joining: boolean;\n    90→  claiming: boolean;\n    91→  joiningMatchId: string | null;\n    92→\n    93→  // Error state\n    94→  error: string | null;\n    95→  clearError: () => void;\n    96→\n    97→  // Actions\n    98→  setSelectedTier: (tier: Tier | null) => void;\n    99→  setSelectedSide: (side: CoinSide | null) => void;\n   100→  createMatch: () => Promise<void>;\n   101→  joinMatch: (matchId: string) => Promise<void>;\n   102→  cancelMatch: () => Promise<void>;\n   103→  timeoutCancel: () => Promise<void>;\n   104→  claimPayout: () => Promise<void>;\n   105→  clearActiveMatch: () => void;\n   106→  refreshMatches: () => void;\n   107→}\n   108→\n   109→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n   110→\n   111→export function CoinflipProvider({ children }: { children: ReactNode }) {\n   112→  const { connected, publicKey, sendTransaction } = useWallet();\n   113→  const { connection } = useConnection();\n   114→  const { refresh: refreshBalance } = useBalance();\n   115→\n   116→  // Selection state\n   117→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   118→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   119→\n   120→  // Match state\n   121→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   122→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   123→  const [userHistory] = useState<UIMatch[]>([]);\n   124→\n   125→  // Loading states\n   126→  const [loading, setLoading] = useState(true);\n   127→  const [creating, setCreating] = useState(false);\n   128→  const [joining, setJoining] = useState(false);\n   129→  const [claiming, setClaiming] = useState(false);\n   130→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   131→\n   132→  // Error state\n   133→  const [error, setError] = useState<string | null>(null);\n   134→  const clearError = useCallback(() => setError(null), []);\n   135→\n   136→  // Timer ref for flip animation delay (ready→flipping→complete)\n   137→  const flipTimerRef = useRef<number | null>(null);\n   138→\n   139→  // Ref to prevent polling races from restoring a dismissed match.\n   140→  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n   141→  // from the previous poll interval may resolve and call setActiveMatch,\n   142→  // putting them back on the match view. This ref blocks that.\n   143→  const dismissedMatchRef = useRef<string | null>(null);\n   144→\n   145→  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n   146→  const sendAndConfirm = useCallback(\n   147→    async (transaction: Transaction): Promise<string> => {\n   148→      const { blockhash, lastValidBlockHeight } =\n   149→        await connection.getLatestBlockhash(\"confirmed\");\n   150→      const signature = await sendTransaction(transaction);\n   151→      await connection.confirmTransaction(\n   152→        { signature, blockhash, lastValidBlockHeight },\n   153→        \"confirmed\",\n   154→      );\n   155→      await refreshBalance();\n   156→      return signature;\n   157→    },\n   158→    [connection, sendTransaction, refreshBalance],\n   159→  );\n   160→\n   161→  // Fetch open matches from on-chain\n   162→  const refreshMatches = useCallback(() => {\n   163→    fetchAllOpenMatches(connection)\n   164→      .then((matches) => {\n   165→        setOpenMatches(matches);\n   166→        setLoading(false);\n   167→      })\n   168→      .catch(() => {\n   169→        setLoading(false);\n   170→      });\n   171→  }, [connection]);\n   172→\n   173→  // Initial load\n   174→  useEffect(() => {\n   175→    setLoading(true);\n   176→    refreshMatches();\n   177→  }, [refreshMatches]);\n   178→\n   179→  // Poll for match updates — faster when waiting for VRF callback (LOCKED→SETTLED)\n   180→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   181→  const pollInterval = isAwaitingVrf ? 2000 : 5000;\n   182→\n   183→  useEffect(() => {\n   184→    const interval = setInterval(() => {\n   185→      refreshMatches();\n   186→\n   187→      // If there's an active match, refresh it too (skip during flip animation)\n   188→      if (activeMatch && activeMatch.phase !== \"flipping\") {\n   189→        const matchPda = new PublicKey(activeMatch.id);\n   190→        fetchMatch(connection, matchPda)\n   191→          .then((updated) => {\n   192→            // If user dismissed this match while fetch was in flight, ignore\n   193→            if (dismissedMatchRef.current === matchPda.toBase58()) return;\n   194→\n   195→            if (updated) {\n   196→              // Intercept ready→complete: insert 3s flip animation first\n   197→              if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n   198→                setActiveMatch({ ...updated, phase: \"flipping\" });\n   199→                flipTimerRef.current = window.setTimeout(() => {\n   200→                  flipTimerRef.current = null;\n   201→                  // Only reveal result if still in flipping phase (user hasn't navigated away)\n   202→                  setActiveMatch((current) =>\n   203→                    current?.phase === \"flipping\" ? updated : current\n   204→                  );\n   205→                }, 3000);\n   206→              } else {\n   207→                setActiveMatch(updated);\n   208→              }\n   209→            } else {\n   210→              // Match account closed (claimed or cancelled)\n   211→              setActiveMatch(null);\n   212→            }\n   213→          })\n   214→          .catch(() => {\n   215→            // Ignore polling errors\n   216→          });\n   217→      }\n   218→    }, pollInterval);\n   219→    return () => clearInterval(interval);\n   220→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   221→\n   222→  // Cleanup flip timer on unmount\n   223→  useEffect(() => {\n   224→    return () => {\n   225→      if (flipTimerRef.current !== null) {\n   226→        clearTimeout(flipTimerRef.current);\n   227→      }\n   228→    };\n   229→  }, []);\n   230→\n   231→  const createMatch = useCallback(async () => {\n   232→    if (!connected || !publicKey) {\n   233→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   234→      return;\n   235→    }\n   236→    if (!selectedTier || !selectedSide) {\n   237→      setError(\"Select tier and side first.\");\n   238→      return;\n   239→    }\n   240→\n   241→    setCreating(true);\n   242→    setError(null);\n   243→    try {\n   244→      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n   245→      const [matchPda] = getMatchPda(publicKey);\n   246→      const existing = await fetchMatch(connection, matchPda);\n   247→      if (existing) {\n   248→        if (existing.phase === \"complete\") {\n   249→          // Match is settled — show it so user can settle (winner claims, loser closes)\n   250→          setActiveMatch(existing);\n   251→          dismissedMatchRef.current = null;\n   252→          setError(\"Settle your previous match first.\");\n   253→        } else {\n   254→          // Match still in progress\n   255→          setActiveMatch(existing);\n   256→          dismissedMatchRef.current = null;\n   257→          setError(\"You already have an active match.\");\n   258→        }\n   259→        return;\n   260→      }\n   261→\n   262→      const { transaction } = await buildCreateMatchTx(\n   263→        connection,\n   264→        publicKey,\n   265→        selectedTier,\n   266→        selectedSide\n   267→      );\n   268→\n   269→      await sendAndConfirm(transaction);\n   270→\n   271→      // Clear dismissed ref — this is a new intentional match\n   272→      dismissedMatchRef.current = null;\n   273→\n   274→      // Fetch the created match from on-chain\n   275→      const match = await fetchMatch(connection, matchPda);\n   276→      if (match) {\n   277→        setActiveMatch(match);\n   278→      }\n   279→\n   280→      setSelectedSide(null);\n   281→      refreshMatches();\n   282→    } catch (err) {\n   283→      setError(parseTransactionError(err));\n   284→    } finally {\n   285→      setCreating(false);\n   286→    }\n   287→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n   288→\n   289→  const joinMatch = useCallback(\n   290→    async (matchId: string) => {\n   291→      if (!connected || !publicKey) {\n   292→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   293→        return;\n   294→      }\n   295→\n   296→      setJoining(true);\n   297→      setJoiningMatchId(matchId);\n   298→      setError(null);\n   299→      try {\n   300→        // matchId is the match PDA base58 — fetch to get the creator\n   301→        const matchPda = new PublicKey(matchId);\n   302→        const existingMatch = await fetchMatch(connection, matchPda);\n   303→        if (!existingMatch) {\n   304→          setError(\"Match not found. It may have been cancelled.\");\n   305→          return;\n   306→        }\n   307→\n   308→        const matchCreator = new PublicKey(existingMatch.player1);\n   309→        const transaction = await buildJoinMatchTx(\n   310→          connection,\n   311→          publicKey,\n   312→          matchCreator\n   313→        );\n   314→\n   315→        await sendAndConfirm(transaction);\n   316→\n   317→        // Clear dismissed ref — this is a new intentional match\n   318→        dismissedMatchRef.current = null;\n   319→\n   320→        // Fetch updated match\n   321→        const updated = await fetchMatch(connection, matchPda);\n   322→        if (updated) {\n   323→          setActiveMatch(updated);\n   324→        }\n   325→\n   326→        refreshMatches();\n   327→      } catch (err) {\n   328→        setError(parseTransactionError(err));\n   329→      } finally {\n   330→        setJoining(false);\n   331→        setJoiningMatchId(null);\n   332→      }\n   333→    },\n   334→    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n   335→  );\n   336→\n   337→  const cancelMatch = useCallback(async () => {\n   338→    if (!connected || !publicKey || !activeMatch) {\n   339→      setError(\"No active match to cancel.\");\n   340→      return;\n   341→    }\n   342→\n   343→    setError(null);\n   344→    try {\n   345→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   346→      await sendAndConfirm(transaction);\n   347→      setActiveMatch(null);\n   348→      refreshMatches();\n   349→    } catch (err) {\n   350→      setError(parseTransactionError(err));\n   351→    }\n   352→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   353→\n   354→  const timeoutCancel = useCallback(async () => {\n   355→    if (!connected || !publicKey || !activeMatch) {\n   356→      setError(\"No active match to cancel.\");\n   357→      return;\n   358→    }\n   359→    if (!activeMatch.player2) {\n   360→      setError(\"Match has no opponent.\");\n   361→      return;\n   362→    }\n   363→\n   364→    setError(null);\n   365→    try {\n   366→      const matchCreator = new PublicKey(activeMatch.player1);\n   367→      const opponent = new PublicKey(activeMatch.player2);\n   368→\n   369→      const transaction = await buildTimeoutCancelTx(\n   370→        connection,\n   371→        publicKey,\n   372→        matchCreator,\n   373→        opponent\n   374→      );\n   375→      await sendAndConfirm(transaction);\n   376→      setActiveMatch(null);\n   377→      refreshMatches();\n   378→    } catch (err) {\n   379→      setError(parseTransactionError(err));\n   380→    }\n   381→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   382→\n   383→  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   384→   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n   385→  const claimPayout = useCallback(async () => {\n   386→    if (!connected || !publicKey || !activeMatch) {\n   387→      setError(\"No active match to claim.\");\n   388→      return;\n   389→    }\n   390→    if (!activeMatch.player2) {\n   391→      setError(\"Match has no opponent yet.\");\n   392→      return;\n   393→    }\n   394→\n   395→    setClaiming(true);\n   396→    setError(null);\n   397→    try {\n   398→      const matchCreator = new PublicKey(activeMatch.player1);\n   399→      const opponent = new PublicKey(activeMatch.player2);\n   400→\n   401→      const transaction = await buildClaimPayoutTx(\n   402→        connection,\n   403→        publicKey,   // caller (either player — winner derived on-chain from VRF)\n   404→        matchCreator,\n   405→        opponent\n   406→      );\n   407→\n   408→      await sendAndConfirm(transaction);\n   409→\n   410→      // Match PDA is now closed — clear local state\n   411→      dismissedMatchRef.current = activeMatch.id;\n   412→      setActiveMatch(null);\n   413→      refreshMatches();\n   414→    } catch (err) {\n   415→      setError(parseTransactionError(err));\n   416→    } finally {\n   417→      setClaiming(false);\n   418→    }\n   419→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   420→\n   421→  // Track if user explicitly cleared the match\n   422→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   423→\n   424→  const clearActiveMatch = useCallback(() => {\n   425→    // Record the dismissed match ID so in-flight polls don't restore it\n   426→    dismissedMatchRef.current = activeMatch?.id ?? null;\n   427→    setActiveMatch(null);\n   428→    setUserClearedMatch(true);\n   429→    setError(null);\n   430→    refreshMatches();\n   431→  }, [activeMatch, refreshMatches]);\n   432→\n   433→  // Check for existing active match on wallet connect\n   434→  useEffect(() => {\n   435→    if (publicKey && !activeMatch && !userClearedMatch) {\n   436→      fetchMatchByCreator(connection, publicKey)\n   437→        .then((match) => {\n   438→          if (match) {\n   439→            // Don't restore a match the user explicitly dismissed\n   440→            if (dismissedMatchRef.current === match.id) return;\n   441→            setActiveMatch(match);\n   442→          }\n   443→        })\n   444→        .catch(() => {\n   445→          // No active match found\n   446→        });\n   447→    }\n   448→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   449→\n   450→  // Reset userClearedMatch when creating or joining a new match\n   451→  useEffect(() => {\n   452→    if (activeMatch) {\n   453→      setUserClearedMatch(false);\n   454→    }\n   455→  }, [activeMatch]);\n   456→\n   457→  const value: CoinflipContextValue = {\n   458→    activeMatch,\n   459→    openMatches,\n   460→    userHistory,\n   461→    selectedTier,\n   462→    selectedSide,\n   463→    loading,\n   464→    creating,\n   465→    joining,\n   466→    claiming,\n   467→    joiningMatchId,\n   468→    error,\n   469→    clearError,\n   470→    setSelectedTier,\n   471→    setSelectedSide,\n   472→    createMatch,\n   473→    joinMatch,\n   474→    cancelMatch,\n   475→    timeoutCancel,\n   476→    claimPayout,\n   477→    clearActiveMatch,\n   478→    refreshMatches,\n   479→  };\n   480→\n   481→  return (\n   482→    <CoinflipContext.Provider value={value}>\n   483→      {children}\n   484→    </CoinflipContext.Provider>\n   485→  );\n   486→}\n   487→\n   488→export function useCoinflip(): CoinflipContextValue {\n   489→  const context = useContext(CoinflipContext);\n   490→  if (!context) {\n   491→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   492→  }\n   493→  return context;\n   494→}\n   495→"}]},"parent_tool_use_id":"toolu_01RkEJGU3bRAB1iyEqZLGEmf","session_id":"71f3d66f-916b-4438-95fb-e3b573af6aa8","uuid":"40acb037-a765-4b31-8eaa-9b55f34be86c"}
