{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SaxNh2cWSt4bDsnEZJT1ZK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JUgeAGRsgo3dZiC1CEc4LW","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/lifecycle.rs","content":"use anchor_lang::prelude::*;\n\n/// Lifecycle phase for every round/match in any game.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug)]\npub enum RoundPhase {\n    Waiting,\n    Active,\n    Locked,\n    Resolving,\n    Settled,\n    Refunded,\n}\n\n/// Timestamps tracking round progression.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug)]\npub struct RoundTimestamps {\n    pub created_at: i64,\n    pub locked_at: Option<i64>,\n    pub resolve_deadline: Option<i64>,\n    pub settled_at: Option<i64>,\n}\n\n#[error_code]\npub enum LifecycleError {\n    #[msg(\"Invalid phase transition\")]\n    InvalidTransition,\n}\n\n/// Validates that the transition from `current` to `target` is allowed.\n///\n/// Allowed transitions:\n/// - Waiting → Active, Locked, Refunded\n/// - Active → Locked, Refunded\n/// - Locked → Resolving, Refunded\n/// - Resolving → Settled, Refunded\n///\n/// LOCKED → SETTLED is explicitly disallowed; VRF games read the result\n/// at claim time and set the phase directly.\npub fn transition(current: RoundPhase, target: RoundPhase) -> Result<()> {\n    let valid = matches!(\n        (current, target),\n        (RoundPhase::Waiting, RoundPhase::Active)\n            | (RoundPhase::Waiting, RoundPhase::Locked)\n            | (RoundPhase::Active, RoundPhase::Locked)\n            | (RoundPhase::Locked, RoundPhase::Resolving)\n            | (RoundPhase::Resolving, RoundPhase::Settled)\n            | (RoundPhase::Resolving, RoundPhase::Refunded)\n            | (RoundPhase::Waiting, RoundPhase::Refunded)\n            | (RoundPhase::Active, RoundPhase::Refunded)\n            | (RoundPhase::Locked, RoundPhase::Refunded)\n    );\n\n    if valid {\n        Ok(())\n    } else {\n        Err(LifecycleError::InvalidTransition.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn valid_transitions() {\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Active).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Resolving).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Settled).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Refunded).is_ok());\n    }\n\n    #[test]\n    fn invalid_transitions() {\n        // Self-transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Locked).is_err());\n\n        // Backward transitions\n        assert!(transition(RoundPhase::Active, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Settled, RoundPhase::Waiting).is_err());\n\n        // LOCKED → SETTLED explicitly invalid (VRF games use claim, not transition)\n        assert!(transition(RoundPhase::Locked, RoundPhase::Settled).is_err());\n\n        // Terminal states cannot transition\n        assert!(transition(RoundPhase::Settled, RoundPhase::Refunded).is_err());\n        assert!(transition(RoundPhase::Refunded, RoundPhase::Settled).is_err());\n\n        // Skip transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Settled).is_err());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Resolving).is_err());\n    }\n\n    #[test]\n    fn enum_serialization_roundtrip() {\n        let phases = [\n            RoundPhase::Waiting,\n            RoundPhase::Active,\n            RoundPhase::Locked,\n            RoundPhase::Resolving,\n            RoundPhase::Settled,\n            RoundPhase::Refunded,\n        ];\n\n        for phase in phases {\n            let mut buf = Vec::new();\n            AnchorSerialize::serialize(&phase, &mut buf).unwrap();\n            let deserialized = RoundPhase::deserialize(&mut buf.as_slice()).unwrap();\n            assert_eq!(phase, deserialized);\n        }\n    }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2804,"cache_read_input_tokens":48079,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2804},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bfad57a9-e771-4d1d-b145-aa285d009d3a","uuid":"b0d157f7-3e8d-4e51-8a0b-21149651f5a0"}
