{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MkT1xuxUApmqfFjpQioVFb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015zJSVmr5KAXgJoavUftmkH","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/pause.rs","content":"use anchor_lang::prelude::*;\n\n#[error_code]\npub enum PauseError {\n    #[msg(\"Platform is paused\")]\n    PlatformPaused,\n    #[msg(\"Game is paused\")]\n    GamePaused,\n}\n\n/// Checks that neither the global platform nor the specific game is paused.\n/// Global pause takes precedence over game pause.\npub fn check_not_paused(global_paused: bool, game_paused: bool) -> Result<()> {\n    if global_paused {\n        return Err(PauseError::PlatformPaused.into());\n    }\n    if game_paused {\n        return Err(PauseError::GamePaused.into());\n    }\n    Ok(())\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn both_unpaused_ok() {\n        assert!(check_not_paused(false, false).is_ok());\n    }\n\n    #[test]\n    fn global_paused_returns_platform_paused() {\n        let err = check_not_paused(true, false).unwrap_err();\n        assert_eq!(\n            err.to_string(),\n            format!(\"custom program error: 0x{:x}\", PauseError::PlatformPaused as u32 + 6000)\n        );\n    }\n\n    #[test]\n    fn game_paused_returns_game_paused() {\n        let err = check_not_paused(false, true).unwrap_err();\n        assert_eq!(\n            err.to_string(),\n            format!(\"custom program error: 0x{:x}\", PauseError::GamePaused as u32 + 6000)\n        );\n    }\n\n    #[test]\n    fn both_paused_returns_platform_paused_precedence() {\n        let err = check_not_paused(true, true).unwrap_err();\n        assert_eq!(\n            err.to_string(),\n            format!(\"custom program error: 0x{:x}\", PauseError::PlatformPaused as u32 + 6000)\n        );\n    }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1211,"cache_read_input_tokens":47304,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1211},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"103a3746-9536-4342-984d-74fe039c1199","uuid":"ffe82337-b630-4a36-ad8a-a2681eb20711"}
