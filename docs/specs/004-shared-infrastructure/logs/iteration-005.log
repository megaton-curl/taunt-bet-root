::prelude::*;\n\n#[error_code]\npub enum PauseError {\n    #[msg(\"Platform is paused\")]\n    PlatformPaused,\n    #[msg(\"Game is paused\")]\n    GamePaused,\n}\n\n/// Checks that neither the global platform nor the specific game is paused.\n/// Global pause takes precedence over game pause.\npub fn check_not_paused(global_paused: bool, game_paused: bool) -> Result<()> {\n    if global_paused {\n        return Err(PauseError::PlatformPaused.into());\n    }\n    if game_paused {\n        return Err(PauseError::GamePaused.into());\n    }\n    Ok(())\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn both_unpaused_ok() {\n        assert!(check_not_paused(false, false).is_ok());\n    }\n\n    #[test]\n    fn global_paused_returns_platform_paused() {\n        let err = check_not_paused(true, false).unwrap_err();\n        assert_eq!(\n            err.to_string(),\n            format!(\"custom program error: 0x{:x}\", PauseError::PlatformPaused as u32 + 6000)\n        );\n    }\n\n    #[test]\n    fn game_paused_returns_game_paused() {\n        let err = check_not_paused(false, true).unwrap_err();\n        assert_eq!(\n            err.to_string(),\n            format!(\"custom program error: 0x{:x}\", PauseError::GamePaused as u32 + 6000)\n        );\n    }\n\n    #[test]\n    fn both_paused_returns_platform_paused_precedence() {\n        let err = check_not_paused(true, true).unwrap_err();\n        assert_eq!(\n            err.to_string(),\n            format!(\"custom program error: 0x{:x}\", PauseError::PlatformPaused as u32 + 6000)\n        );\n    }\n}\n","structuredPatch":[{"oldStart":32,"oldLines":27,"newStart":32,"newLines":18,"lines":["     #[test]","     fn global_paused_returns_platform_paused() {","         let err = check_not_paused(true, false).unwrap_err();","-        assert_eq!(","-            err.to_string(),","-            format!(\"custom program error: 0x{:x}\", PauseError::PlatformPaused as u32 + 6000)","-        );","+        assert!(err.to_string().contains(\"PlatformPaused\"));","     }"," ","     #[test]","     fn game_paused_returns_game_paused() {","         let err = check_not_paused(false, true).unwrap_err();","-        assert_eq!(","-            err.to_string(),","-            format!(\"custom program error: 0x{:x}\", PauseError::GamePaused as u32 + 6000)","-        );","+        assert!(err.to_string().contains(\"GamePaused\"));","     }"," ","     #[test]","     fn both_paused_returns_platform_paused_precedence() {","         let err = check_not_paused(true, true).unwrap_err();","-        assert_eq!(","-            err.to_string(),","-            format!(\"custom program error: 0x{:x}\", PauseError::PlatformPaused as u32 + 6000)","-        );","+        assert!(err.to_string().contains(\"PlatformPaused\"));","     }"," }"]}],"userModified":false,"replaceAll":false}}
