  93→    coinflip_match.phase = RoundPhase::Locked;\n    94→    coinflip_match.locked_at = now;\n    95→    coinflip_match.resolve_deadline = now + DEFAULT_RESOLVE_TIMEOUT_SECONDS;\n    96→    coinflip_match.vrf_request_key = ctx.accounts.orao_random.key();\n    97→\n    98→    Ok(())\n    99→}\n   100→"}]},"parent_tool_use_id":null,"session_id":"d7619d26-977f-447b-8d13-946b8a80fc7d","uuid":"ff97f614-62a2-489b-8933-31bc3eb8c572","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/join_match.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_to_pda;\nuse rng_shared::lifecycle::{self, RoundPhase};\nuse rng_shared::timeout::DEFAULT_RESOLVE_TIMEOUT_SECONDS;\nuse rng_shared::vrf_orao;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n/// Opponent joins a match, deposits SOL, and requests Orao VRF.\n#[derive(Accounts)]\npub struct JoinMatch<'info> {\n    /// The opponent joining the match. Must sign and fund their escrow.\n    #[account(mut)]\n    pub opponent: Signer<'info>,\n\n    /// The match PDA to join.\n    #[account(\n        mut,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA.\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// Orao VRF program.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    pub orao_program: UncheckedAccount<'info>,\n\n    /// Orao network state PDA.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_network_state: UncheckedAccount<'info>,\n\n    /// Orao treasury for VRF fee payment.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_treasury: UncheckedAccount<'info>,\n\n    /// Orao randomness account (created by Orao CPI).\n    /// CHECK: Orao VRF CPI validates and initializes this account.\n    #[account(mut)]\n    pub orao_random: UncheckedAccount<'info>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<JoinMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Validate Waiting → Locked transition via shared lifecycle\n    lifecycle::transition(coinflip_match.phase, RoundPhase::Locked)?;\n\n    // Opponent cannot be the creator\n    require!(\n        ctx.accounts.opponent.key() != coinflip_match.creator,\n        CoinflipError::CannotJoinOwnMatch\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n    let opponent_key = ctx.accounts.opponent.key();\n\n    // Transfer entry_amount from opponent to match PDA (escrow) via shared helper\n    transfer_lamports_to_pda(\n        &ctx.accounts.opponent.to_account_info(),\n        &ctx.accounts.coinflip_match.to_account_info(),\n        entry_amount,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    // Request Orao VRF — use match PDA key as unique seed\n    let seed: [u8; 32] = ctx.accounts.coinflip_match.key().to_bytes();\n    vrf_orao::request_orao_randomness(\n        &ctx.accounts.orao_program.to_account_info(),\n        &ctx.accounts.orao_network_state.to_account_info(),\n        &ctx.accounts.orao_treasury.to_account_info(),\n        &ctx.accounts.orao_random.to_account_info(),\n        &ctx.accounts.opponent.to_account_info(),\n        &ctx.accounts.system_program.to_account_info(),\n        seed,\n    )?;\n\n    // Update match state\n    let now = Clock::get()?.unix_timestamp;\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.opponent = opponent_key;\n    coinflip_match.phase = RoundPhase::Locked;\n    coinflip_match.locked_at = now;\n    coinflip_match.resolve_deadline = now + DEFAULT_RESOLVE_TIMEOUT_SECONDS;\n    coinflip_match.vrf_request_key = ctx.accounts.orao_random.key();\n\n    Ok(())\n}\n","numLines":100,"startLine":1,"totalLines":100}}}
