{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YVc2fXntmnmfReXuUHhvfa","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  SYSVAR_SLOT_HASHES_PUBKEY,\n     7→  Transaction,\n     8→  type TransactionInstruction,\n     9→} from \"@solana/web3.js\";\n    10→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n    11→import {\n    12→  TIER_VALUES,\n    13→  COIN_SIDE_VALUES,\n    14→  TIER_AMOUNTS,\n    15→  type Tier,\n    16→  type CoinSide,\n    17→} from \"@rng-utopia/game-engine/browser\";\n    18→import type { UIMatch } from \"../types\";\n    19→\n    20→// ============ Constants ============\n    21→\n    22→const COINFLIP_PROGRAM_ID = new PublicKey(\n    23→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    24→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    25→);\n    26→\n    27→// Legacy VRF constants (to be replaced with Orao accounts)\n    28→const VRF_DEFAULT_QUEUE = new PublicKey(\"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\");\n    29→const VRF_PROGRAM_ID = new PublicKey(\"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\");\n    30→// program_identity is a PDA derived from [\"identity\"] under our program ID\n    31→const [VRF_PROGRAM_IDENTITY] = PublicKey.findProgramAddressSync(\n    32→  [Buffer.from(\"identity\")],\n    33→  COINFLIP_PROGRAM_ID,\n    34→);\n    35→\n    36→// On-chain phase constants\n    37→const PHASE_WAITING = 0;\n    38→const PHASE_LOCKED = 1;\n    39→const PHASE_SETTLED = 2;\n    40→\n    41→// ============ PDA Derivation ============\n    42→\n    43→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    44→  return PublicKey.findProgramAddressSync(\n    45→    [Buffer.from(\"match\"), creator.toBuffer()],\n    46→    COINFLIP_PROGRAM_ID\n    47→  );\n    48→}\n    49→\n    50→export function getConfigPda(): [PublicKey, number] {\n    51→  return PublicKey.findProgramAddressSync(\n    52→    [Buffer.from(\"coinflip_config\")],\n    53→    COINFLIP_PROGRAM_ID\n    54→  );\n    55→}\n    56→\n    57→// ============ Program Instance ============\n    58→\n    59→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    60→  // Read-only provider (no wallet needed for queries)\n    61→  const provider = new AnchorProvider(\n    62→    connection,\n    63→    {} as AnchorProvider[\"wallet\"],\n    64→    { commitment: \"confirmed\" }\n    65→  );\n    66→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    67→}\n    68→\n    69→// ============ On-Chain Account Types ============\n    70→\n    71→interface OnChainMatch {\n    72→  creator: PublicKey;\n    73→  opponent: PublicKey;\n    74→  tier: number;\n    75→  entryAmount: { toNumber(): number };\n    76→  creatorSide: number;\n    77→  phase: number;\n    78→  result: number;\n    79→  winner: PublicKey;\n    80→  claimed: boolean;\n    81→  lockedAt: { toNumber(): number };\n    82→  bump: number;\n    83→}\n    84→\n    85→// ============ Converters ============\n    86→\n    87→function tierFromIndex(index: number): Tier {\n    88→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"emerald\", \"diamond\"];\n    89→  return tiers[index] ?? \"iron\";\n    90→}\n    91→\n    92→function sideFromIndex(index: number): CoinSide {\n    93→  return index === 0 ? \"heads\" : \"tails\";\n    94→}\n    95→\n    96→function phaseToUI(phase: number): UIMatch[\"phase\"] {\n    97→  switch (phase) {\n    98→    case PHASE_WAITING:\n    99→      return \"created\";\n   100→    case PHASE_LOCKED:\n   101→      return \"ready\";\n   102→    case PHASE_SETTLED:\n   103→      return \"complete\";\n   104→    default:\n   105→      return \"created\";\n   106→  }\n   107→}\n   108→\n   109→const DEFAULT_PUBKEY = PublicKey.default;\n   110→\n   111→function isDefaultPubkey(key: PublicKey): boolean {\n   112→  return key.equals(DEFAULT_PUBKEY);\n   113→}\n   114→\n   115→export function onChainMatchToUI(\n   116→  matchPda: PublicKey,\n   117→  data: OnChainMatch\n   118→): UIMatch {\n   119→  const tier = tierFromIndex(data.tier);\n   120→  const creatorSide = sideFromIndex(data.creatorSide);\n   121→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   122→  const phase = phaseToUI(data.phase);\n   123→  const isSettled = data.phase === PHASE_SETTLED;\n   124→\n   125→  const entryAmountSol = TIER_AMOUNTS[tier];\n   126→  const totalPool = entryAmountSol * 2;\n   127→  const payoutAmount = totalPool * 0.97;\n   128→\n   129→  const lockedAt = data.lockedAt.toNumber();\n   130→\n   131→  return {\n   132→    id: matchPda.toBase58(),\n   133→    tier,\n   134→    entryAmount: entryAmountSol,\n   135→    player1: data.creator.toBase58(),\n   136→    player1Side: creatorSide,\n   137→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   138→    player2Side: hasOpponent\n   139→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   140→      : null,\n   141→    phase,\n   142→    createdAt: Date.now(),\n   143→    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n   144→    result: isSettled ? sideFromIndex(data.result) : null,\n   145→    winner: isSettled && !isDefaultPubkey(data.winner)\n   146→      ? data.winner.toBase58()\n   147→      : null,\n   148→    claimed: data.claimed,\n   149→    payoutAmount,\n   150→    seedHash: \"\",\n   151→  };\n   152→}\n   153→\n   154→// ============ Account Queries ============\n   155→\n   156→export async function fetchAllOpenMatches(\n   157→  connection: Connection\n   158→): Promise<UIMatch[]> {\n   159→  const program = getCoinflipProgram(connection);\n   160→  const accounts = await program.account.coinflipMatch.all();\n   161→\n   162→  return accounts\n   163→    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n   164→    .map((acc) =>\n   165→      onChainMatchToUI(\n   166→        acc.publicKey,\n   167→        acc.account as unknown as OnChainMatch\n   168→      )\n   169→    );\n   170→}\n   171→\n   172→export async function fetchMatchByCreator(\n   173→  connection: Connection,\n   174→  creator: PublicKey\n   175→): Promise<UIMatch | null> {\n   176→  const program = getCoinflipProgram(connection);\n   177→  const [matchPda] = getMatchPda(creator);\n   178→\n   179→  try {\n   180→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   181→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   182→  } catch {\n   183→    // Account doesn't exist\n   184→    return null;\n   185→  }\n   186→}\n   187→\n   188→export async function fetchMatch(\n   189→  connection: Connection,\n   190→  matchPda: PublicKey\n   191→): Promise<UIMatch | null> {\n   192→  const program = getCoinflipProgram(connection);\n   193→\n   194→  try {\n   195→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   196→    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n   197→  } catch {\n   198→    return null;\n   199→  }\n   200→}\n   201→\n   202→// ============ Instruction Builders ============\n   203→\n   204→export function buildCreateMatchInstruction(\n   205→  creator: PublicKey,\n   206→  tier: Tier,\n   207→  side: CoinSide\n   208→): { instruction: TransactionInstruction; matchPda: PublicKey } {\n   209→  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n   210→  const [matchPda] = getMatchPda(creator);\n   211→\n   212→  const tierIndex = TIER_VALUES[tier];\n   213→  const sideIndex = COIN_SIDE_VALUES[side];\n   214→\n   215→  const instruction = program.methods\n   216→    .createMatch(tierIndex, sideIndex)\n   217→    .accountsStrict({\n   218→      creator,\n   219→      coinflipMatch: matchPda,\n   220→      systemProgram: SystemProgram.programId,\n   221→    })\n   222→    .instruction();\n   223→\n   224→  // instruction() returns a Promise<TransactionInstruction>, but we return\n   225→  // it synchronously wrapped — callers must await the instruction.\n   226→  // For now, build the transaction inline.\n   227→  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n   228→}\n   229→\n   230→export async function buildCreateMatchTx(\n   231→  connection: Connection,\n   232→  creator: PublicKey,\n   233→  tier: Tier,\n   234→  side: CoinSide\n   235→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   236→  const program = getCoinflipProgram(connection);\n   237→  const [matchPda] = getMatchPda(creator);\n   238→\n   239→  const tierIndex = TIER_VALUES[tier];\n   240→  const sideIndex = COIN_SIDE_VALUES[side];\n   241→\n   242→  const ix = await program.methods\n   243→    .createMatch(tierIndex, sideIndex)\n   244→    .accountsStrict({\n   245→      creator,\n   246→      coinflipMatch: matchPda,\n   247→      systemProgram: SystemProgram.programId,\n   248→    })\n   249→    .instruction();\n   250→\n   251→  const tx = new Transaction().add(ix);\n   252→  tx.feePayer = creator;\n   253→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   254→\n   255→  return { transaction: tx, matchPda };\n   256→}\n   257→\n   258→export async function buildJoinMatchTx(\n   259→  connection: Connection,\n   260→  opponent: PublicKey,\n   261→  matchCreator: PublicKey\n   262→): Promise<Transaction> {\n   263→  const program = getCoinflipProgram(connection);\n   264→  const [matchPda] = getMatchPda(matchCreator);\n   265→  const [configPda] = getConfigPda();\n   266→\n   267→  const ix = await program.methods\n   268→    .joinMatch()\n   269→    .accountsStrict({\n   270→      opponent,\n   271→      coinflipMatch: matchPda,\n   272→      config: configPda,\n   273→      oracleQueue: VRF_DEFAULT_QUEUE,\n   274→      programIdentity: VRF_PROGRAM_IDENTITY,\n   275→      vrfProgram: VRF_PROGRAM_ID,\n   276→      slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n   277→      systemProgram: SystemProgram.programId,\n   278→    })\n   279→    .instruction();\n   280→\n   281→  const tx = new Transaction().add(ix);\n   282→  tx.feePayer = opponent;\n   283→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   284→\n   285→  return tx;\n   286→}\n   287→\n   288→export async function buildCancelMatchTx(\n   289→  connection: Connection,\n   290→  creator: PublicKey\n   291→): Promise<Transaction> {\n   292→  const program = getCoinflipProgram(connection);\n   293→  const [matchPda] = getMatchPda(creator);\n   294→\n   295→  const ix = await program.methods\n   296→    .cancelMatch()\n   297→    .accountsStrict({\n   298→      creator,\n   299→      coinflipMatch: matchPda,\n   300→      systemProgram: SystemProgram.programId,\n   301→    })\n   302→    .instruction();\n   303→\n   304→  const tx = new Transaction().add(ix);\n   305→  tx.feePayer = creator;\n   306→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   307→\n   308→  return tx;\n   309→}\n   310→\n   311→export async function buildTimeoutCancelTx(\n   312→  connection: Connection,\n   313→  caller: PublicKey,\n   314→  matchCreator: PublicKey,\n   315→  opponent: PublicKey\n   316→): Promise<Transaction> {\n   317→  const program = getCoinflipProgram(connection);\n   318→  const [matchPda] = getMatchPda(matchCreator);\n   319→\n   320→  const ix = await program.methods\n   321→    .timeoutCancel()\n   322→    .accountsStrict({\n   323→      caller,\n   324→      creator: matchCreator,\n   325→      opponent,\n   326→      coinflipMatch: matchPda,\n   327→    })\n   328→    .instruction();\n   329→\n   330→  const tx = new Transaction().add(ix);\n   331→  tx.feePayer = caller;\n   332→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   333→\n   334→  return tx;\n   335→}\n   336→\n   337→export async function buildClaimPayoutTx(\n   338→  connection: Connection,\n   339→  caller: PublicKey,\n   340→  winner: PublicKey,\n   341→  matchCreator: PublicKey,\n   342→  opponent: PublicKey\n   343→): Promise<Transaction> {\n   344→  const program = getCoinflipProgram(connection);\n   345→  const [matchPda] = getMatchPda(matchCreator);\n   346→  const [configPda] = getConfigPda();\n   347→\n   348→  // Fetch config to get treasury address\n   349→  const config = await program.account.coinflipConfig.fetch(configPda);\n   350→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   351→\n   352→  // Derive player profile PDAs for CPI\n   353→  const PLATFORM_PROGRAM_ID = new PublicKey(\n   354→    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n   355→      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n   356→  );\n   357→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   358→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   359→    PLATFORM_PROGRAM_ID\n   360→  );\n   361→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   362→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   363→    PLATFORM_PROGRAM_ID\n   364→  );\n   365→\n   366→  const ix = await program.methods\n   367→    .claimPayout()\n   368→    .accountsStrict({\n   369→      caller,\n   370→      winner,\n   371→      coinflipMatch: matchPda,\n   372→      config: configPda,\n   373→      treasury,\n   374→      creator: matchCreator,\n   375→      creatorProfile,\n   376→      opponentProfile,\n   377→      platformProgram: PLATFORM_PROGRAM_ID,\n   378→      systemProgram: SystemProgram.programId,\n   379→    })\n   380→    .instruction();\n   381→\n   382→  const tx = new Transaction().add(ix);\n   383→  tx.feePayer = caller;\n   384→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   385→\n   386→  return tx;\n   387→}\n   388→"}]},"parent_tool_use_id":null,"session_id":"d7619d26-977f-447b-8d13-946b8a80fc7d","uuid":"3a01cc1e-21ba-48f6-afac-07a5b196f05f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts","content":"import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  Connection,\n  PublicKey,\n  SystemProgram,\n  SYSVAR_SLOT_HASHES_PUBKEY,\n  Transaction,\n  type TransactionInstruction,\n} from \"@solana/web3.js\";\nimport { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\nimport {\n  TIER_VALUES,\n  COIN_SIDE_VALUES,\n  TIER_AMOUNTS,\n  type Tier,\n  type CoinSide,\n} from \"@rng-utopia/game-engine/browser\";\nimport type { UIMatch } from \"../types\";\n\n// ============ Constants ============\n\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n);\n\n// Legacy VRF constants (to be replaced with Orao accounts)\nconst VRF_DEFAULT_QUEUE = new PublicKey(\"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\");\nconst VRF_PROGRAM_ID = new PublicKey(\"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\");\n// program_identity is a PDA derived from [\"identity\"] under our program ID\nconst [VRF_PROGRAM_IDENTITY] = PublicKey.findProgramAddressSync(\n  [Buffer.from(\"identity\")],\n  COINFLIP_PROGRAM_ID,\n);\n\n// On-chain phase constants\nconst PHASE_WAITING = 0;\nconst PHASE_LOCKED = 1;\nconst PHASE_SETTLED = 2;\n\n// ============ PDA Derivation ============\n\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n// ============ Program Instance ============\n\nfunction getCoinflipProgram(connection: Connection): Program<Coinflip> {\n  // Read-only provider (no wallet needed for queries)\n  const provider = new AnchorProvider(\n    connection,\n    {} as AnchorProvider[\"wallet\"],\n    { commitment: \"confirmed\" }\n  );\n  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n}\n\n// ============ On-Chain Account Types ============\n\ninterface OnChainMatch {\n  creator: PublicKey;\n  opponent: PublicKey;\n  tier: number;\n  entryAmount: { toNumber(): number };\n  creatorSide: number;\n  phase: number;\n  result: number;\n  winner: PublicKey;\n  claimed: boolean;\n  lockedAt: { toNumber(): number };\n  bump: number;\n}\n\n// ============ Converters ============\n\nfunction tierFromIndex(index: number): Tier {\n  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"emerald\", \"diamond\"];\n  return tiers[index] ?? \"iron\";\n}\n\nfunction sideFromIndex(index: number): CoinSide {\n  return index === 0 ? \"heads\" : \"tails\";\n}\n\nfunction phaseToUI(phase: number): UIMatch[\"phase\"] {\n  switch (phase) {\n    case PHASE_WAITING:\n      return \"created\";\n    case PHASE_LOCKED:\n      return \"ready\";\n    case PHASE_SETTLED:\n      return \"complete\";\n    default:\n      return \"created\";\n  }\n}\n\nconst DEFAULT_PUBKEY = PublicKey.default;\n\nfunction isDefaultPubkey(key: PublicKey): boolean {\n  return key.equals(DEFAULT_PUBKEY);\n}\n\nexport function onChainMatchToUI(\n  matchPda: PublicKey,\n  data: OnChainMatch\n): UIMatch {\n  const tier = tierFromIndex(data.tier);\n  const creatorSide = sideFromIndex(data.creatorSide);\n  const hasOpponent = !isDefaultPubkey(data.opponent);\n  const phase = phaseToUI(data.phase);\n  const isSettled = data.phase === PHASE_SETTLED;\n\n  const entryAmountSol = TIER_AMOUNTS[tier];\n  const totalPool = entryAmountSol * 2;\n  const payoutAmount = totalPool * 0.97;\n\n  const lockedAt = data.lockedAt.toNumber();\n\n  return {\n    id: matchPda.toBase58(),\n    tier,\n    entryAmount: entryAmountSol,\n    player1: data.creator.toBase58(),\n    player1Side: creatorSide,\n    player2: hasOpponent ? data.opponent.toBase58() : null,\n    player2Side: hasOpponent\n      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n      : null,\n    phase,\n    createdAt: Date.now(),\n    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n    result: isSettled ? sideFromIndex(data.result) : null,\n    winner: isSettled && !isDefaultPubkey(data.winner)\n      ? data.winner.toBase58()\n      : null,\n    claimed: data.claimed,\n    payoutAmount,\n    seedHash: \"\",\n  };\n}\n\n// ============ Account Queries ============\n\nexport async function fetchAllOpenMatches(\n  connection: Connection\n): Promise<UIMatch[]> {\n  const program = getCoinflipProgram(connection);\n  const accounts = await program.account.coinflipMatch.all();\n\n  return accounts\n    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n    .map((acc) =>\n      onChainMatchToUI(\n        acc.publicKey,\n        acc.account as unknown as OnChainMatch\n      )\n    );\n}\n\nexport async function fetchMatchByCreator(\n  connection: Connection,\n  creator: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    // Account doesn't exist\n    return null;\n  }\n}\n\nexport async function fetchMatch(\n  connection: Connection,\n  matchPda: PublicKey\n): Promise<UIMatch | null> {\n  const program = getCoinflipProgram(connection);\n\n  try {\n    const account = await program.account.coinflipMatch.fetch(matchPda);\n    return onChainMatchToUI(matchPda, account as unknown as OnChainMatch);\n  } catch {\n    return null;\n  }\n}\n\n// ============ Instruction Builders ============\n\nexport function buildCreateMatchInstruction(\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): { instruction: TransactionInstruction; matchPda: PublicKey } {\n  const program = getCoinflipProgram(new Connection(\"http://127.0.0.1:8899\"));\n  const [matchPda] = getMatchPda(creator);\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const instruction = program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  // instruction() returns a Promise<TransactionInstruction>, but we return\n  // it synchronously wrapped — callers must await the instruction.\n  // For now, build the transaction inline.\n  return { instruction: instruction as unknown as TransactionInstruction, matchPda };\n}\n\nexport async function buildCreateMatchTx(\n  connection: Connection,\n  creator: PublicKey,\n  tier: Tier,\n  side: CoinSide\n): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const tierIndex = TIER_VALUES[tier];\n  const sideIndex = COIN_SIDE_VALUES[side];\n\n  const ix = await program.methods\n    .createMatch(tierIndex, sideIndex)\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return { transaction: tx, matchPda };\n}\n\nexport async function buildJoinMatchTx(\n  connection: Connection,\n  opponent: PublicKey,\n  matchCreator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  const ix = await program.methods\n    .joinMatch()\n    .accountsStrict({\n      opponent,\n      coinflipMatch: matchPda,\n      config: configPda,\n      oracleQueue: VRF_DEFAULT_QUEUE,\n      programIdentity: VRF_PROGRAM_IDENTITY,\n      vrfProgram: VRF_PROGRAM_ID,\n      slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = opponent;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildCancelMatchTx(\n  connection: Connection,\n  creator: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(creator);\n\n  const ix = await program.methods\n    .cancelMatch()\n    .accountsStrict({\n      creator,\n      coinflipMatch: matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = creator;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildTimeoutCancelTx(\n  connection: Connection,\n  caller: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n\n  const ix = await program.methods\n    .timeoutCancel()\n    .accountsStrict({\n      caller,\n      creator: matchCreator,\n      opponent,\n      coinflipMatch: matchPda,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n\nexport async function buildClaimPayoutTx(\n  connection: Connection,\n  caller: PublicKey,\n  winner: PublicKey,\n  matchCreator: PublicKey,\n  opponent: PublicKey\n): Promise<Transaction> {\n  const program = getCoinflipProgram(connection);\n  const [matchPda] = getMatchPda(matchCreator);\n  const [configPda] = getConfigPda();\n\n  // Fetch config to get treasury address\n  const config = await program.account.coinflipConfig.fetch(configPda);\n  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n\n  // Derive player profile PDAs for CPI\n  const PLATFORM_PROGRAM_ID = new PublicKey(\n    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n      .VITE_PLATFORM_PROGRAM_ID ?? \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n  );\n  const [creatorProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  const [opponentProfile] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n\n  const ix = await program.methods\n    .claimPayout()\n    .accountsStrict({\n      caller,\n      winner,\n      coinflipMatch: matchPda,\n      config: configPda,\n      treasury,\n      creator: matchCreator,\n      creatorProfile,\n      opponentProfile,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .instruction();\n\n  const tx = new Transaction().add(ix);\n  tx.feePayer = caller;\n  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n\n  return tx;\n}\n","numLines":388,"startLine":1,"totalLines":388}}}
