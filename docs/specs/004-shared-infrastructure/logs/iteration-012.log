{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DqQZfSTCPkLRCeMGv9sAdg","type":"tool_result","content":[{"type":"text","text":"Here are the FULL contents of all six shared crate files:\n\n## 1. escrow.rs\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::system_program;\n\n/// Error codes for escrow operations.\n#[error_code]\npub enum EscrowError {\n    /// The escrow PDA does not hold enough lamports for the requested transfer.\n    #[msg(\"Insufficient escrow balance\")]\n    InsufficientEscrowBalance,\n}\n\n/// Transfers lamports from a PDA to a recipient using direct lamport manipulation.\n///\n/// This is the standard pattern for moving funds out of a program-owned PDA\n/// (e.g., paying out a winner, refunding a player, sending fees to treasury).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_from_pda(\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     &ctx.accounts.winner.to_account_info(),\n///     payout_amount,\n/// )?;\n/// ```\npub fn transfer_lamports_from_pda(\n    pda: &AccountInfo,\n    recipient: &AccountInfo,\n    amount: u64,\n) -> Result<()> {\n    let pda_balance = pda.lamports();\n    require!(pda_balance >= amount, EscrowError::InsufficientEscrowBalance);\n\n    **pda.try_borrow_mut_lamports()? -= amount;\n    **recipient.try_borrow_mut_lamports()? += amount;\n\n    Ok(())\n}\n\n/// Transfers lamports from a signer to a PDA using system program CPI.\n///\n/// This is the standard pattern for depositing funds into an escrow PDA\n/// (e.g., a player funding a match entry).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_to_pda(\n///     &ctx.accounts.creator.to_account_info(),\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     entry_amount,\n///     &ctx.accounts.system_program.to_account_info(),\n/// )?;\n/// ```\npub fn transfer_lamports_to_pda<'a>(\n    from: &AccountInfo<'a>,\n    pda: &AccountInfo<'a>,\n    amount: u64,\n    system_program_info: &AccountInfo<'a>,\n) -> Result<()> {\n    system_program::transfer(\n        CpiContext::new(\n            system_program_info.clone(),\n            system_program::Transfer {\n                from: from.clone(),\n                to: pda.clone(),\n            },\n        ),\n        amount,\n    )\n}\n```\n\n## 2. fees.rs\n```rust\n/// Compile-time safety cap: no fee can ever exceed 10% (1000 bps).\npub const MAX_FEE_BPS: u16 = 1000;\n\n/// Total platform fee: 3% (300 basis points)\n/// - 200 bps: platform revenue\n/// - 70 bps: rakeback pool (raid boss rewards)\n/// - 30 bps: chest treasury\npub const TOTAL_FEE_BPS: u16 = 300;\npub const REVENUE_BPS: u16 = 200;\npub const RAKEBACK_BPS: u16 = 70;\npub const CHEST_BPS: u16 = 30;\n\n// Compile-time assertion: fee must never exceed safety cap.\nconst _: () = assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n\n/// Calculate the total fee for a given amount.\n/// Returns the fee in lamports.\npub fn calculate_fee(amount: u64) -> u64 {\n    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n}\n\n/// Calculate fee and net payout for a given pool amount.\n/// Returns `(fee, net_payout)` where `net_payout = pool - fee`.\n/// Fee rounds down (integer division truncates), favoring the player.\npub fn calculate_net_payout(pool: u64) -> (u64, u64) {\n    let fee = calculate_fee(pool);\n    (fee, pool - fee)\n}\n\n/// Split a fee amount into (revenue, rakeback, chest).\npub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    (revenue, rakeback, chest)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_calculate_fee() {\n        assert_eq!(calculate_fee(10_000), 300);\n        assert_eq!(calculate_fee(1_000_000), 30_000);\n        assert_eq!(calculate_fee(0), 0);\n    }\n\n    #[test]\n    fn test_calculate_net_payout() {\n        let (fee, net) = calculate_net_payout(1_000_000);\n        assert_eq!(fee, 30_000);\n        assert_eq!(net, 970_000);\n        assert_eq!(fee + net, 1_000_000);\n\n        // Zero pool\n        let (fee, net) = calculate_net_payout(0);\n        assert_eq!(fee, 0);\n        assert_eq!(net, 0);\n\n        // Small amount where rounding truncates (favors player)\n        // 100 lamports * 300 / 10000 = 3.0 exactly\n        let (fee, net) = calculate_net_payout(100);\n        assert_eq!(fee, 3);\n        assert_eq!(net, 97);\n\n        // Non-round amount: 1 lamport → fee rounds to 0\n        let (fee, net) = calculate_net_payout(1);\n        assert_eq!(fee, 0);\n        assert_eq!(net, 1);\n    }\n\n    #[test]\n    fn test_max_fee_bps_cap() {\n        assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n    }\n\n    #[test]\n    fn test_split_fee() {\n        let (rev, rake, chest) = split_fee(300);\n        assert_eq!(rev, 200);\n        assert_eq!(rake, 70);\n        assert_eq!(chest, 30);\n        assert_eq!(rev + rake + chest, 300);\n    }\n}\n```\n\n## 3. vrf_orao.rs\n```rust\nuse anchor_lang::prelude::*;\n\n/// Audit fields stored on match/round accounts for VRF traceability.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, InitSpace)]\npub struct VrfAuditFields {\n    /// Address of the Orao randomness PDA for this match/round.\n    pub vrf_request_key: Pubkey,\n    /// Unix timestamp when VRF was requested.\n    pub vrf_requested_at: i64,\n}\n\n/// Error codes for VRF operations.\n#[error_code]\npub enum VrfError {\n    /// Randomness has not been fulfilled by the VRF oracle.\n    #[msg(\"VRF randomness not yet fulfilled\")]\n    RandomnessNotFulfilled,\n}\n\n/// Returns true if the 32-byte randomness is non-zero (i.e., fulfilled).\npub fn is_fulfilled(randomness: &[u8; 32]) -> bool {\n    randomness.iter().any(|&b| b != 0)\n}\n\n// ---------------------------------------------------------------------------\n// Real Orao mode — CPI into Orao VRF program\n// ---------------------------------------------------------------------------\n\n/// CPI into Orao VRF to request randomness.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn request_orao_randomness<'info>(\n    orao_program: &AccountInfo<'info>,\n    network_state: &AccountInfo<'info>,\n    treasury: &AccountInfo<'info>,\n    random: &AccountInfo<'info>,\n    payer: &AccountInfo<'info>,\n    system_program: &AccountInfo<'info>,\n    seed: [u8; 32],\n) -> Result<()> {\n    let cpi_accounts = orao_solana_vrf::cpi::accounts::RequestV2 {\n        payer: payer.clone(),\n        network_state: network_state.clone(),\n        treasury: treasury.clone(),\n        request: random.clone(),\n        system_program: system_program.clone(),\n    };\n    let cpi_ctx = CpiContext::new(orao_program.clone(), cpi_accounts);\n    orao_solana_vrf::cpi::request_v2(cpi_ctx, seed)\n}\n\n/// Read fulfilled randomness from an Orao randomness account.\n///\n/// Deserializes the Orao `RandomnessAccountData` (supports both V1 and V2\n/// accounts) and returns the first 32 bytes of the 64-byte randomness.\n/// Returns an error if randomness has not been fulfilled yet.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    use anchor_lang::AccountDeserialize;\n\n    let data = randomness_account.try_borrow_data()?;\n    let mut buf: &[u8] = &data;\n    let account_data =\n        orao_solana_vrf::state::RandomnessAccountData::try_deserialize_unchecked(&mut buf)?;\n\n    match account_data.fulfilled_randomness() {\n        Some(randomness_64) => {\n            let mut result = [0u8; 32];\n            result.copy_from_slice(&randomness_64[..32]);\n            Ok(result)\n        }\n        None => Err(error!(VrfError::RandomnessNotFulfilled)),\n    }\n}\n\n// ---------------------------------------------------------------------------\n// Mock VRF mode — no Orao CPI, reads raw bytes from test account\n// ---------------------------------------------------------------------------\n\n/// No-op in mock mode. Test authority writes mock randomness directly.\n#[cfg(feature = \"mock-vrf\")]\npub fn request_orao_randomness<'info>(\n    _orao_program: &AccountInfo<'info>,\n    _network_state: &AccountInfo<'info>,\n    _treasury: &AccountInfo<'info>,\n    _random: &AccountInfo<'info>,\n    _payer: &AccountInfo<'info>,\n    _system_program: &AccountInfo<'info>,\n    _seed: [u8; 32],\n) -> Result<()> {\n    Ok(())\n}\n\n/// In mock mode, reads raw 32 bytes from account data as randomness.\n/// All-zeros = unfulfilled (returns error).\n#[cfg(feature = \"mock-vrf\")]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    let data = randomness_account.try_borrow_data()?;\n    require!(data.len() >= 32, VrfError::RandomnessNotFulfilled);\n\n    let mut randomness = [0u8; 32];\n    randomness.copy_from_slice(&data[..32]);\n\n    require!(is_fulfilled(&randomness), VrfError::RandomnessNotFulfilled);\n    Ok(randomness)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_is_fulfilled_all_zeros() {\n        let zeros = [0u8; 32];\n        assert!(!is_fulfilled(&zeros));\n    }\n\n    #[test]\n    fn test_is_fulfilled_non_zero() {\n        let mut data = [0u8; 32];\n        data[0] = 1;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_is_fulfilled_all_ones() {\n        let ones = [0xFF; 32];\n        assert!(is_fulfilled(&ones));\n    }\n\n    #[test]\n    fn test_is_fulfilled_single_byte_set() {\n        let mut data = [0u8; 32];\n        data[31] = 42;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_vrf_audit_fields_size() {\n        // Pubkey (32) + i64 (8) = 40 bytes\n        assert_eq!(<VrfAuditFields as anchor_lang::Space>::INIT_SPACE, 40);\n    }\n}\n```\n\n## 4. cpi.rs\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::solana_program::{\n    instruction::{AccountMeta, Instruction},\n    program::invoke_signed,\n};\nuse solana_sha256_hasher::hashv;\n\n/// Calls the platform program's `update_player_profile` instruction via CPI.\n///\n/// If the profile account has no data (player hasn't created a profile), the call\n/// is silently skipped — returns `Ok(())` without emitting a CPI.\n///\n/// This helper constructs the CPI instruction manually (discriminator + borsh args)\n/// to avoid a circular dependency between `rng-shared` and `platform`.\n///\n/// # Arguments\n///\n/// * `platform_program` — The platform program account.\n/// * `profile` — The player's profile PDA (mutable). Skipped if empty.\n/// * `authority` — The game config PDA that signs the CPI.\n/// * `signer_seeds` — Seeds for PDA signing (e.g., `&[b\"coinflip_config\", &[bump]]`).\n/// * `total_games_delta` — Reserved; platform always increments by 1 per call.\n/// * `wins_delta` — If > 0, player is marked as winner.\n/// * `total_wagered_delta` — Lamports wagered in this game (maps to `wager_amount`).\n/// * `total_won_delta` — Lamports won in this game (maps to `won_amount`, 0 if lost).\n///\n/// # Example\n///\n/// ```ignore\n/// update_player_profile_cpi(\n///     &ctx.accounts.platform_program,\n///     &ctx.accounts.creator_profile,\n///     &ctx.accounts.config.to_account_info(),\n///     &[b\"coinflip_config\", &[config_bump]],\n///     1,                    // total_games_delta\n///     if is_winner { 1 } else { 0 }, // wins_delta\n///     entry_amount,         // total_wagered_delta\n///     if is_winner { payout } else { 0 }, // total_won_delta\n/// )?;\n/// ```\npub fn update_player_profile_cpi<'a>(\n    platform_program: &AccountInfo<'a>,\n    profile: &AccountInfo<'a>,\n    authority: &AccountInfo<'a>,\n    signer_seeds: &[&[u8]],\n    _total_games_delta: u64,\n    wins_delta: u64,\n    total_wagered_delta: u64,\n    total_won_delta: u64,\n) -> Result<()> {\n    // Guard: skip if profile hasn't been created yet\n    if profile.data_is_empty() {\n        return Ok(());\n    }\n\n    // Map to platform program's actual parameters\n    let wager_amount = total_wagered_delta;\n    let won_amount = total_won_delta;\n    let is_winner = wins_delta > 0;\n\n    // Discriminator = sha256(\"global:update_player_profile\")[0..8]\n    let disc = hashv(&[b\"global:update_player_profile\"]);\n\n    // Instruction data: 8-byte discriminator + wager_amount(u64) + won_amount(u64) + is_winner(bool)\n    let mut data = [0u8; 25];\n    data[..8].copy_from_slice(&disc.to_bytes()[..8]);\n    data[8..16].copy_from_slice(&wager_amount.to_le_bytes());\n    data[16..24].copy_from_slice(&won_amount.to_le_bytes());\n    data[24] = u8::from(is_winner);\n\n    let accounts = vec![\n        AccountMeta::new_readonly(*authority.key, true), // caller (signer)\n        AccountMeta::new(*profile.key, false),           // profile (mutable)\n    ];\n\n    let ix = Instruction {\n        program_id: *platform_program.key,\n        accounts,\n        data: data.to_vec(),\n    };\n\n    invoke_signed(\n        &ix,\n        &[authority.clone(), profile.clone(), platform_program.clone()],\n        &[signer_seeds],\n    )?;\n\n    Ok(())\n}\n```\n\n## 5. constants.rs\n```rust\n/// Coin sides\npub const SIDE_HEADS: u8 = 0;\npub const SIDE_TAILS: u8 = 1;\n\n/// Match phases\npub const PHASE_WAITING: u8 = 0;   // Creator placed bet, waiting for opponent\npub const PHASE_LOCKED: u8 = 1;    // Both players in, requesting VRF\npub const PHASE_SETTLED: u8 = 2;   // VRF resolved, winner determined\npub const PHASE_CANCELLED: u8 = 3; // Creator cancelled before opponent joined\n\n/// Timeout (in seconds) after which a LOCKED match can be cancelled.\npub const LOCK_TIMEOUT_SECONDS: i64 = 120; // 2 minutes\n\n/// Derive a coin side (0 or 1) from a randomness byte.\npub fn from_randomness(byte: u8) -> u8 {\n    byte % 2\n}\n\n/// Returns true if the given value is a valid side (HEADS or TAILS).\npub fn is_valid_side(side: u8) -> bool {\n    side == SIDE_HEADS || side == SIDE_TAILS\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_from_randomness() {\n        assert_eq!(from_randomness(0), SIDE_HEADS);\n        assert_eq!(from_randomness(1), SIDE_TAILS);\n        assert_eq!(from_randomness(2), SIDE_HEADS);\n        assert_eq!(from_randomness(255), SIDE_TAILS);\n    }\n\n    #[test]\n    fn test_is_valid_side() {\n        assert!(is_valid_side(SIDE_HEADS));\n        assert!(is_valid_side(SIDE_TAILS));\n        assert!(!is_valid_side(2));\n        assert!(!is_valid_side(255));\n    }\n}\n```\n\n## 6. lifecycle.rs\n```rust\nuse anchor_lang::prelude::*;\n\n/// Lifecycle phase for every round/match in any game.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\npub enum RoundPhase {\n    Waiting,\n    Active,\n    Locked,\n    Resolving,\n    Settled,\n    Refunded,\n}\n\n/// Timestamps tracking round progression.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug)]\npub struct RoundTimestamps {\n    pub created_at: i64,\n    pub locked_at: Option<i64>,\n    pub resolve_deadline: Option<i64>,\n    pub settled_at: Option<i64>,\n}\n\n#[error_code]\npub enum LifecycleError {\n    #[msg(\"Invalid phase transition\")]\n    InvalidTransition,\n}\n\n/// Validates that the transition from `current` to `target` is allowed.\n///\n/// Allowed transitions:\n/// - Waiting → Active, Locked, Refunded\n/// - Active → Locked, Refunded\n/// - Locked → Resolving, Refunded\n/// - Resolving → Settled, Refunded\n///\n/// LOCKED → SETTLED is explicitly disallowed; VRF games read the result\n/// at claim time and set the phase directly.\npub fn transition(current: RoundPhase, target: RoundPhase) -> Result<()> {\n    let valid = matches!(\n        (current, target),\n        (RoundPhase::Waiting, RoundPhase::Active)\n            | (RoundPhase::Waiting, RoundPhase::Locked)\n            | (RoundPhase::Active, RoundPhase::Locked)\n            | (RoundPhase::Locked, RoundPhase::Resolving)\n            | (RoundPhase::Resolving, RoundPhase::Settled)\n            | (RoundPhase::Resolving, RoundPhase::Refunded)\n            | (RoundPhase::Waiting, RoundPhase::Refunded)\n            | (RoundPhase::Active, RoundPhase::Refunded)\n            | (RoundPhase::Locked, RoundPhase::Refunded)\n    );\n\n    if valid {\n        Ok(())\n    } else {\n        Err(LifecycleError::InvalidTransition.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn valid_transitions() {\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Active).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Resolving).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Settled).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Refunded).is_ok());\n    }\n\n    #[test]\n    fn invalid_transitions() {\n        // Self-transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Locked).is_err());\n\n        // Backward transitions\n        assert!(transition(RoundPhase::Active, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Settled, RoundPhase::Waiting).is_err());\n\n        // LOCKED → SETTLED explicitly invalid (VRF games use claim, not transition)\n        assert!(transition(RoundPhase::Locked, RoundPhase::Settled).is_err());\n\n        // Terminal states cannot transition\n        assert!(transition(RoundPhase::Settled, RoundPhase::Refunded).is_err());\n        assert!(transition(RoundPhase::Refunded, RoundPhase::Settled).is_err());\n\n        // Skip transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Settled).is_err());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Resolving).is_err());\n    }\n\n    #[test]\n    fn enum_serialization_roundtrip() {\n        let phases = [\n            RoundPhase::Waiting,\n            RoundPhase::Active,\n            RoundPhase::Locked,\n            RoundPhase::Resolving,\n            RoundPhase::Settled,\n            RoundPhase::Refunded,\n        ];\n\n        for phase in phases {\n            let mut buf = Vec::new();\n            AnchorSerialize::serialize(&phase, &mut buf).unwrap();\n            let deserialized = RoundPhase::deserialize(&mut buf.as_slice()).unwrap();\n            assert_eq!(phase, deserialized);\n        }\n    }\n}\n```\n\nAll six files have been returned with complete contents."},{"type":"text","text":"agentId: a5c39a9f898c62cc4 (for resuming to continue this agent's work if needed)\n<usage>total_tokens: 41306\ntool_uses: 6\nduration_ms: 42906</usage>"}]}]},"parent_tool_use_id":null,"session_id":"ab4e0643-d5a1-4100-b87f-b1dbf0a5ddae","uuid":"af334ada-7e13-4f29-943e-30e285c7100d","tool_use_result":{"status":"completed","prompt":"Read and return the FULL contents of these files from the shared crate:\n\n1. /workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/escrow.rs\n2. /workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/fees.rs\n3. /workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/vrf_orao.rs\n4. /workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/cpi.rs\n5. /workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/constants.rs\n6. /workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/lifecycle.rs\n\nReturn ALL file contents completely.","agentId":"a5c39a9f898c62cc4","content":[{"type":"text","text":"Here are the FULL contents of all six shared crate files:\n\n## 1. escrow.rs\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::system_program;\n\n/// Error codes for escrow operations.\n#[error_code]\npub enum EscrowError {\n    /// The escrow PDA does not hold enough lamports for the requested transfer.\n    #[msg(\"Insufficient escrow balance\")]\n    InsufficientEscrowBalance,\n}\n\n/// Transfers lamports from a PDA to a recipient using direct lamport manipulation.\n///\n/// This is the standard pattern for moving funds out of a program-owned PDA\n/// (e.g., paying out a winner, refunding a player, sending fees to treasury).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_from_pda(\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     &ctx.accounts.winner.to_account_info(),\n///     payout_amount,\n/// )?;\n/// ```\npub fn transfer_lamports_from_pda(\n    pda: &AccountInfo,\n    recipient: &AccountInfo,\n    amount: u64,\n) -> Result<()> {\n    let pda_balance = pda.lamports();\n    require!(pda_balance >= amount, EscrowError::InsufficientEscrowBalance);\n\n    **pda.try_borrow_mut_lamports()? -= amount;\n    **recipient.try_borrow_mut_lamports()? += amount;\n\n    Ok(())\n}\n\n/// Transfers lamports from a signer to a PDA using system program CPI.\n///\n/// This is the standard pattern for depositing funds into an escrow PDA\n/// (e.g., a player funding a match entry).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_to_pda(\n///     &ctx.accounts.creator.to_account_info(),\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     entry_amount,\n///     &ctx.accounts.system_program.to_account_info(),\n/// )?;\n/// ```\npub fn transfer_lamports_to_pda<'a>(\n    from: &AccountInfo<'a>,\n    pda: &AccountInfo<'a>,\n    amount: u64,\n    system_program_info: &AccountInfo<'a>,\n) -> Result<()> {\n    system_program::transfer(\n        CpiContext::new(\n            system_program_info.clone(),\n            system_program::Transfer {\n                from: from.clone(),\n                to: pda.clone(),\n            },\n        ),\n        amount,\n    )\n}\n```\n\n## 2. fees.rs\n```rust\n/// Compile-time safety cap: no fee can ever exceed 10% (1000 bps).\npub const MAX_FEE_BPS: u16 = 1000;\n\n/// Total platform fee: 3% (300 basis points)\n/// - 200 bps: platform revenue\n/// - 70 bps: rakeback pool (raid boss rewards)\n/// - 30 bps: chest treasury\npub const TOTAL_FEE_BPS: u16 = 300;\npub const REVENUE_BPS: u16 = 200;\npub const RAKEBACK_BPS: u16 = 70;\npub const CHEST_BPS: u16 = 30;\n\n// Compile-time assertion: fee must never exceed safety cap.\nconst _: () = assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n\n/// Calculate the total fee for a given amount.\n/// Returns the fee in lamports.\npub fn calculate_fee(amount: u64) -> u64 {\n    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n}\n\n/// Calculate fee and net payout for a given pool amount.\n/// Returns `(fee, net_payout)` where `net_payout = pool - fee`.\n/// Fee rounds down (integer division truncates), favoring the player.\npub fn calculate_net_payout(pool: u64) -> (u64, u64) {\n    let fee = calculate_fee(pool);\n    (fee, pool - fee)\n}\n\n/// Split a fee amount into (revenue, rakeback, chest).\npub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    (revenue, rakeback, chest)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_calculate_fee() {\n        assert_eq!(calculate_fee(10_000), 300);\n        assert_eq!(calculate_fee(1_000_000), 30_000);\n        assert_eq!(calculate_fee(0), 0);\n    }\n\n    #[test]\n    fn test_calculate_net_payout() {\n        let (fee, net) = calculate_net_payout(1_000_000);\n        assert_eq!(fee, 30_000);\n        assert_eq!(net, 970_000);\n        assert_eq!(fee + net, 1_000_000);\n\n        // Zero pool\n        let (fee, net) = calculate_net_payout(0);\n        assert_eq!(fee, 0);\n        assert_eq!(net, 0);\n\n        // Small amount where rounding truncates (favors player)\n        // 100 lamports * 300 / 10000 = 3.0 exactly\n        let (fee, net) = calculate_net_payout(100);\n        assert_eq!(fee, 3);\n        assert_eq!(net, 97);\n\n        // Non-round amount: 1 lamport → fee rounds to 0\n        let (fee, net) = calculate_net_payout(1);\n        assert_eq!(fee, 0);\n        assert_eq!(net, 1);\n    }\n\n    #[test]\n    fn test_max_fee_bps_cap() {\n        assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n    }\n\n    #[test]\n    fn test_split_fee() {\n        let (rev, rake, chest) = split_fee(300);\n        assert_eq!(rev, 200);\n        assert_eq!(rake, 70);\n        assert_eq!(chest, 30);\n        assert_eq!(rev + rake + chest, 300);\n    }\n}\n```\n\n## 3. vrf_orao.rs\n```rust\nuse anchor_lang::prelude::*;\n\n/// Audit fields stored on match/round accounts for VRF traceability.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, InitSpace)]\npub struct VrfAuditFields {\n    /// Address of the Orao randomness PDA for this match/round.\n    pub vrf_request_key: Pubkey,\n    /// Unix timestamp when VRF was requested.\n    pub vrf_requested_at: i64,\n}\n\n/// Error codes for VRF operations.\n#[error_code]\npub enum VrfError {\n    /// Randomness has not been fulfilled by the VRF oracle.\n    #[msg(\"VRF randomness not yet fulfilled\")]\n    RandomnessNotFulfilled,\n}\n\n/// Returns true if the 32-byte randomness is non-zero (i.e., fulfilled).\npub fn is_fulfilled(randomness: &[u8; 32]) -> bool {\n    randomness.iter().any(|&b| b != 0)\n}\n\n// ---------------------------------------------------------------------------\n// Real Orao mode — CPI into Orao VRF program\n// ---------------------------------------------------------------------------\n\n/// CPI into Orao VRF to request randomness.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn request_orao_randomness<'info>(\n    orao_program: &AccountInfo<'info>,\n    network_state: &AccountInfo<'info>,\n    treasury: &AccountInfo<'info>,\n    random: &AccountInfo<'info>,\n    payer: &AccountInfo<'info>,\n    system_program: &AccountInfo<'info>,\n    seed: [u8; 32],\n) -> Result<()> {\n    let cpi_accounts = orao_solana_vrf::cpi::accounts::RequestV2 {\n        payer: payer.clone(),\n        network_state: network_state.clone(),\n        treasury: treasury.clone(),\n        request: random.clone(),\n        system_program: system_program.clone(),\n    };\n    let cpi_ctx = CpiContext::new(orao_program.clone(), cpi_accounts);\n    orao_solana_vrf::cpi::request_v2(cpi_ctx, seed)\n}\n\n/// Read fulfilled randomness from an Orao randomness account.\n///\n/// Deserializes the Orao `RandomnessAccountData` (supports both V1 and V2\n/// accounts) and returns the first 32 bytes of the 64-byte randomness.\n/// Returns an error if randomness has not been fulfilled yet.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    use anchor_lang::AccountDeserialize;\n\n    let data = randomness_account.try_borrow_data()?;\n    let mut buf: &[u8] = &data;\n    let account_data =\n        orao_solana_vrf::state::RandomnessAccountData::try_deserialize_unchecked(&mut buf)?;\n\n    match account_data.fulfilled_randomness() {\n        Some(randomness_64) => {\n            let mut result = [0u8; 32];\n            result.copy_from_slice(&randomness_64[..32]);\n            Ok(result)\n        }\n        None => Err(error!(VrfError::RandomnessNotFulfilled)),\n    }\n}\n\n// ---------------------------------------------------------------------------\n// Mock VRF mode — no Orao CPI, reads raw bytes from test account\n// ---------------------------------------------------------------------------\n\n/// No-op in mock mode. Test authority writes mock randomness directly.\n#[cfg(feature = \"mock-vrf\")]\npub fn request_orao_randomness<'info>(\n    _orao_program: &AccountInfo<'info>,\n    _network_state: &AccountInfo<'info>,\n    _treasury: &AccountInfo<'info>,\n    _random: &AccountInfo<'info>,\n    _payer: &AccountInfo<'info>,\n    _system_program: &AccountInfo<'info>,\n    _seed: [u8; 32],\n) -> Result<()> {\n    Ok(())\n}\n\n/// In mock mode, reads raw 32 bytes from account data as randomness.\n/// All-zeros = unfulfilled (returns error).\n#[cfg(feature = \"mock-vrf\")]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    let data = randomness_account.try_borrow_data()?;\n    require!(data.len() >= 32, VrfError::RandomnessNotFulfilled);\n\n    let mut randomness = [0u8; 32];\n    randomness.copy_from_slice(&data[..32]);\n\n    require!(is_fulfilled(&randomness), VrfError::RandomnessNotFulfilled);\n    Ok(randomness)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_is_fulfilled_all_zeros() {\n        let zeros = [0u8; 32];\n        assert!(!is_fulfilled(&zeros));\n    }\n\n    #[test]\n    fn test_is_fulfilled_non_zero() {\n        let mut data = [0u8; 32];\n        data[0] = 1;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_is_fulfilled_all_ones() {\n        let ones = [0xFF; 32];\n        assert!(is_fulfilled(&ones));\n    }\n\n    #[test]\n    fn test_is_fulfilled_single_byte_set() {\n        let mut data = [0u8; 32];\n        data[31] = 42;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_vrf_audit_fields_size() {\n        // Pubkey (32) + i64 (8) = 40 bytes\n        assert_eq!(<VrfAuditFields as anchor_lang::Space>::INIT_SPACE, 40);\n    }\n}\n```\n\n## 4. cpi.rs\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::solana_program::{\n    instruction::{AccountMeta, Instruction},\n    program::invoke_signed,\n};\nuse solana_sha256_hasher::hashv;\n\n/// Calls the platform program's `update_player_profile` instruction via CPI.\n///\n/// If the profile account has no data (player hasn't created a profile), the call\n/// is silently skipped — returns `Ok(())` without emitting a CPI.\n///\n/// This helper constructs the CPI instruction manually (discriminator + borsh args)\n/// to avoid a circular dependency between `rng-shared` and `platform`.\n///\n/// # Arguments\n///\n/// * `platform_program` — The platform program account.\n/// * `profile` — The player's profile PDA (mutable). Skipped if empty.\n/// * `authority` — The game config PDA that signs the CPI.\n/// * `signer_seeds` — Seeds for PDA signing (e.g., `&[b\"coinflip_config\", &[bump]]`).\n/// * `total_games_delta` — Reserved; platform always increments by 1 per call.\n/// * `wins_delta` — If > 0, player is marked as winner.\n/// * `total_wagered_delta` — Lamports wagered in this game (maps to `wager_amount`).\n/// * `total_won_delta` — Lamports won in this game (maps to `won_amount`, 0 if lost).\n///\n/// # Example\n///\n/// ```ignore\n/// update_player_profile_cpi(\n///     &ctx.accounts.platform_program,\n///     &ctx.accounts.creator_profile,\n///     &ctx.accounts.config.to_account_info(),\n///     &[b\"coinflip_config\", &[config_bump]],\n///     1,                    // total_games_delta\n///     if is_winner { 1 } else { 0 }, // wins_delta\n///     entry_amount,         // total_wagered_delta\n///     if is_winner { payout } else { 0 }, // total_won_delta\n/// )?;\n/// ```\npub fn update_player_profile_cpi<'a>(\n    platform_program: &AccountInfo<'a>,\n    profile: &AccountInfo<'a>,\n    authority: &AccountInfo<'a>,\n    signer_seeds: &[&[u8]],\n    _total_games_delta: u64,\n    wins_delta: u64,\n    total_wagered_delta: u64,\n    total_won_delta: u64,\n) -> Result<()> {\n    // Guard: skip if profile hasn't been created yet\n    if profile.data_is_empty() {\n        return Ok(());\n    }\n\n    // Map to platform program's actual parameters\n    let wager_amount = total_wagered_delta;\n    let won_amount = total_won_delta;\n    let is_winner = wins_delta > 0;\n\n    // Discriminator = sha256(\"global:update_player_profile\")[0..8]\n    let disc = hashv(&[b\"global:update_player_profile\"]);\n\n    // Instruction data: 8-byte discriminator + wager_amount(u64) + won_amount(u64) + is_winner(bool)\n    let mut data = [0u8; 25];\n    data[..8].copy_from_slice(&disc.to_bytes()[..8]);\n    data[8..16].copy_from_slice(&wager_amount.to_le_bytes());\n    data[16..24].copy_from_slice(&won_amount.to_le_bytes());\n    data[24] = u8::from(is_winner);\n\n    let accounts = vec![\n        AccountMeta::new_readonly(*authority.key, true), // caller (signer)\n        AccountMeta::new(*profile.key, false),           // profile (mutable)\n    ];\n\n    let ix = Instruction {\n        program_id: *platform_program.key,\n        accounts,\n        data: data.to_vec(),\n    };\n\n    invoke_signed(\n        &ix,\n        &[authority.clone(), profile.clone(), platform_program.clone()],\n        &[signer_seeds],\n    )?;\n\n    Ok(())\n}\n```\n\n## 5. constants.rs\n```rust\n/// Coin sides\npub const SIDE_HEADS: u8 = 0;\npub const SIDE_TAILS: u8 = 1;\n\n/// Match phases\npub const PHASE_WAITING: u8 = 0;   // Creator placed bet, waiting for opponent\npub const PHASE_LOCKED: u8 = 1;    // Both players in, requesting VRF\npub const PHASE_SETTLED: u8 = 2;   // VRF resolved, winner determined\npub const PHASE_CANCELLED: u8 = 3; // Creator cancelled before opponent joined\n\n/// Timeout (in seconds) after which a LOCKED match can be cancelled.\npub const LOCK_TIMEOUT_SECONDS: i64 = 120; // 2 minutes\n\n/// Derive a coin side (0 or 1) from a randomness byte.\npub fn from_randomness(byte: u8) -> u8 {\n    byte % 2\n}\n\n/// Returns true if the given value is a valid side (HEADS or TAILS).\npub fn is_valid_side(side: u8) -> bool {\n    side == SIDE_HEADS || side == SIDE_TAILS\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_from_randomness() {\n        assert_eq!(from_randomness(0), SIDE_HEADS);\n        assert_eq!(from_randomness(1), SIDE_TAILS);\n        assert_eq!(from_randomness(2), SIDE_HEADS);\n        assert_eq!(from_randomness(255), SIDE_TAILS);\n    }\n\n    #[test]\n    fn test_is_valid_side() {\n        assert!(is_valid_side(SIDE_HEADS));\n        assert!(is_valid_side(SIDE_TAILS));\n        assert!(!is_valid_side(2));\n        assert!(!is_valid_side(255));\n    }\n}\n```\n\n## 6. lifecycle.rs\n```rust\nuse anchor_lang::prelude::*;\n\n/// Lifecycle phase for every round/match in any game.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\npub enum RoundPhase {\n    Waiting,\n    Active,\n    Locked,\n    Resolving,\n    Settled,\n    Refunded,\n}\n\n/// Timestamps tracking round progression.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug)]\npub struct RoundTimestamps {\n    pub created_at: i64,\n    pub locked_at: Option<i64>,\n    pub resolve_deadline: Option<i64>,\n    pub settled_at: Option<i64>,\n}\n\n#[error_code]\npub enum LifecycleError {\n    #[msg(\"Invalid phase transition\")]\n    InvalidTransition,\n}\n\n/// Validates that the transition from `current` to `target` is allowed.\n///\n/// Allowed transitions:\n/// - Waiting → Active, Locked, Refunded\n/// - Active → Locked, Refunded\n/// - Locked → Resolving, Refunded\n/// - Resolving → Settled, Refunded\n///\n/// LOCKED → SETTLED is explicitly disallowed; VRF games read the result\n/// at claim time and set the phase directly.\npub fn transition(current: RoundPhase, target: RoundPhase) -> Result<()> {\n    let valid = matches!(\n        (current, target),\n        (RoundPhase::Waiting, RoundPhase::Active)\n            | (RoundPhase::Waiting, RoundPhase::Locked)\n            | (RoundPhase::Active, RoundPhase::Locked)\n            | (RoundPhase::Locked, RoundPhase::Resolving)\n            | (RoundPhase::Resolving, RoundPhase::Settled)\n            | (RoundPhase::Resolving, RoundPhase::Refunded)\n            | (RoundPhase::Waiting, RoundPhase::Refunded)\n            | (RoundPhase::Active, RoundPhase::Refunded)\n            | (RoundPhase::Locked, RoundPhase::Refunded)\n    );\n\n    if valid {\n        Ok(())\n    } else {\n        Err(LifecycleError::InvalidTransition.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn valid_transitions() {\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Active).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Resolving).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Settled).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Refunded).is_ok());\n    }\n\n    #[test]\n    fn invalid_transitions() {\n        // Self-transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Locked).is_err());\n\n        // Backward transitions\n        assert!(transition(RoundPhase::Active, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Settled, RoundPhase::Waiting).is_err());\n\n        // LOCKED → SETTLED explicitly invalid (VRF games use claim, not transition)\n        assert!(transition(RoundPhase::Locked, RoundPhase::Settled).is_err());\n\n        // Terminal states cannot transition\n        assert!(transition(RoundPhase::Settled, RoundPhase::Refunded).is_err());\n        assert!(transition(RoundPhase::Refunded, RoundPhase::Settled).is_err());\n\n        // Skip transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Settled).is_err());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Resolving).is_err());\n    }\n\n    #[test]\n    fn enum_serialization_roundtrip() {\n        let phases = [\n            RoundPhase::Waiting,\n            RoundPhase::Active,\n            RoundPhase::Locked,\n            RoundPhase::Resolving,\n            RoundPhase::Settled,\n            RoundPhase::Refunded,\n        ];\n\n        for phase in phases {\n            let mut buf = Vec::new();\n            AnchorSerialize::serialize(&phase, &mut buf).unwrap();\n            let deserialized = RoundPhase::deserialize(&mut buf.as_slice()).unwrap();\n            assert_eq!(phase, deserialized);\n        }\n    }\n}\n```\n\nAll six files have been returned with complete contents."}],"totalDurationMs":42906,"totalTokens":41306,"totalToolUseCount":6,"usage":{"input_tokens":7,"cache_creation_input_tokens":10439,"cache_read_input_tokens":24651,"output_tokens":6209,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":10439,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}}}
