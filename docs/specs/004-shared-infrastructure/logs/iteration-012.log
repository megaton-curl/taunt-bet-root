{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LZZy2PU2vxHm4DL8XN7Jbv","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::from_randomness;\n     3→use rng_shared::lifecycle::RoundPhase;\n     4→\n     5→use crate::error::CoinflipError;\n     6→use crate::state::{CoinflipConfig, CoinflipMatch};\n     7→\n     8→/// Legacy resolve instruction — will be removed when claim_payout is\n     9→/// rewritten to read VRF at claim time. Kept temporarily for compilation.\n    10→#[derive(Accounts)]\n    11→pub struct ResolveMatch<'info> {\n    12→    /// Oracle authority signer.\n    13→    pub oracle: Signer<'info>,\n    14→\n    15→    /// The config PDA.\n    16→    #[account(\n    17→        seeds = [b\"coinflip_config\"],\n    18→        bump = config.bump,\n    19→    )]\n    20→    pub config: Account<'info, CoinflipConfig>,\n    21→\n    22→    /// The match PDA to resolve.\n    23→    #[account(\n    24→        mut,\n    25→        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n    26→        bump = coinflip_match.bump,\n    27→    )]\n    28→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    29→}\n    30→\n    31→pub fn handler(ctx: Context<ResolveMatch>, randomness: [u8; 32]) -> Result<()> {\n    32→    let coinflip_match = &ctx.accounts.coinflip_match;\n    33→\n    34→    // Must be in LOCKED phase\n    35→    require!(\n    36→        coinflip_match.phase == RoundPhase::Locked,\n    37→        CoinflipError::InvalidPhase\n    38→    );\n    39→\n    40→    // Oracle authority check removed — Orao uses account constraints.\n    41→    // This instruction is being replaced by read-at-claim in a later iteration.\n    42→\n    43→    // Derive result from randomness\n    44→    let result = from_randomness(randomness[0]);\n    45→\n    46→    // Determine winner\n    47→    let winner = if result == coinflip_match.creator_side {\n    48→        coinflip_match.creator\n    49→    } else {\n    50→        coinflip_match.opponent\n    51→    };\n    52→\n    53→    // Update match state\n    54→    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    55→    coinflip_match.result = result;\n    56→    coinflip_match.winner = winner;\n    57→    coinflip_match.phase = RoundPhase::Settled;\n    58→\n    59→    Ok(())\n    60→}\n    61→"}]},"parent_tool_use_id":"toolu_01Kdq1ZEidfTwB5ArJVT8Vv8","session_id":"ab4e0643-d5a1-4100-b87f-b1dbf0a5ddae","uuid":"765ebabc-9420-404f-a45b-e08db9164951"}
