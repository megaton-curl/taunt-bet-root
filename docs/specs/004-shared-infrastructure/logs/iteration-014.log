{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PFrHcczrpoNbgNgdXKbGg7","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::lifecycle::{transition, RoundPhase};\n     3→\n     4→use crate::state::CoinflipMatch;\n     5→\n     6→#[derive(Accounts)]\n     7→pub struct CancelMatch<'info> {\n     8→    /// The creator cancelling their match.\n     9→    #[account(mut)]\n    10→    pub creator: Signer<'info>,\n    11→\n    12→    /// The match PDA (closed on cancel — escrow + rent refunded to creator).\n    13→    #[account(\n    14→        mut,\n    15→        close = creator,\n    16→        seeds = [b\"match\", creator.key().as_ref()],\n    17→        bump = coinflip_match.bump,\n    18→    )]\n    19→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    20→\n    21→    pub system_program: Program<'info, System>,\n    22→}\n    23→\n    24→pub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    25→    let coinflip_match = &ctx.accounts.coinflip_match;\n    26→\n    27→    // Validate phase transition: Waiting → Refunded\n    28→    transition(coinflip_match.phase, RoundPhase::Refunded)?;\n    29→\n    30→    // Account is closed by Anchor's `close = creator` constraint —\n    31→    // all lamports (escrow + rent) are returned to creator.\n    32→\n    33→    Ok(())\n    34→}\n    35→"}]},"parent_tool_use_id":null,"session_id":"26c7f4cc-b2b2-41aa-85e9-beee2a3d95f1","uuid":"75def3e0-ea89-4257-ab51-94e372c049b7","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/cancel_match.rs","content":"use anchor_lang::prelude::*;\nuse rng_shared::lifecycle::{transition, RoundPhase};\n\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct CancelMatch<'info> {\n    /// The creator cancelling their match.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA (closed on cancel — escrow + rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Validate phase transition: Waiting → Refunded\n    transition(coinflip_match.phase, RoundPhase::Refunded)?;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // all lamports (escrow + rent) are returned to creator.\n\n    Ok(())\n}\n","numLines":35,"startLine":1,"totalLines":35}}}
