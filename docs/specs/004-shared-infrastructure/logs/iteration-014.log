{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X8Eoqd6K2dxvaHAPH9w6TC","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/solana/tests/coinflip.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"26c7f4cc-b2b2-41aa-85e9-beee2a3d95f1","uuid":"e4eaac38-0c57-486c-8713-6b373118bbc7","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/coinflip.ts","oldString":"    it(\"rejects cancel after Locked (InvalidTransition)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t);\n\n      try {\n        await cancelMatch(t);\n        expect.fail(\"Expected InvalidTransition error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"InvalidTransition\"\n        );\n      }\n    });","newString":"    it(\"rejects cancel after Locked (CannotCancel)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t);\n\n      try {\n        await cancelMatch(t);\n        expect.fail(\"Expected CannotCancel error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"CannotCancel\"\n        );\n      }\n    });","originalFile":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport { Clock } from \"solana-bankrun\";\nimport type { Coinflip } from \"../target/types/coinflip\";\nimport type { Platform } from \"../target/types/platform\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\nconst PLATFORM_IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n);\nconst PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n\n// ---------------------------------------------------------------------------\n// Constants matching shared crate\n// ---------------------------------------------------------------------------\nconst SIDE_HEADS = 0;\nconst SIDE_TAILS = 1;\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL in lamports\nconst TOTAL_FEE_BPS = 300;\nconst DEFAULT_RESOLVE_TIMEOUT = 120; // seconds\n\n// Mock VRF randomness buffers (32 bytes each)\n// HEADS: byte[0]=2 → 2%2=0=HEADS, non-zero so is_fulfilled=true\nconst RANDOMNESS_HEADS = (() => {\n  const buf = Buffer.alloc(32);\n  buf[0] = 2;\n  return buf;\n})();\n// TAILS: byte[0]=1 → 1%2=1=TAILS, non-zero so is_fulfilled=true\nconst RANDOMNESS_TAILS = (() => {\n  const buf = Buffer.alloc(32);\n  buf[0] = 1;\n  return buf;\n})();\n// Unfulfilled: all zeros → is_fulfilled=false\nconst RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getMatchPda(creator: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlatformConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlayerProfilePda(wallet: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Test context factory\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  opponent: Keypair;\n  treasury: Keypair;\n  mockRandomness: Keypair;\n  mockOraoProgram: Keypair;\n  mockOraoNetworkState: Keypair;\n  mockOraoTreasury: Keypair;\n  creatorProgram: Program<Coinflip>;\n  opponentProgram: Program<Coinflip>;\n  platformProgram: Program<Platform>;\n  opponentPlatformProgram: Program<Platform>;\n  configPda: PublicKey;\n  matchPda: PublicKey;\n  platformConfigPda: PublicKey;\n  creatorProfilePda: PublicKey;\n  opponentProfilePda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const opponent = Keypair.generate();\n  const treasury = Keypair.generate();\n  const mockRandomness = Keypair.generate();\n  const mockOraoProgram = Keypair.generate();\n  const mockOraoNetworkState = Keypair.generate();\n  const mockOraoTreasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: opponent.publicKey, info: fundedAccountData() },\n    { address: treasury.publicKey, info: fundedAccountData() },\n    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n    // Mock randomness account — starts unfulfilled (32 zero bytes)\n    {\n      address: mockRandomness.publicKey,\n      info: {\n        lamports: LAMPORTS_PER_SOL,\n        data: RANDOMNESS_UNFULFILLED,\n        owner: SystemProgram.programId,\n        executable: false,\n      },\n    },\n  ]);\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n\n  const opponentProvider = new BankrunProvider(context, new Wallet(opponent));\n  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n\n  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n  const opponentPlatformProgram = new Program<Platform>(\n    PLATFORM_IDL,\n    opponentProvider\n  );\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n  const matchPda = getMatchPda(creator);\n  const platformConfigPda = getPlatformConfigPda();\n  const creatorProfilePda = getPlayerProfilePda(creator);\n  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n\n  return {\n    context,\n    creator,\n    opponent,\n    treasury,\n    mockRandomness,\n    mockOraoProgram,\n    mockOraoNetworkState,\n    mockOraoTreasury,\n    creatorProgram,\n    opponentProgram,\n    platformProgram,\n    opponentPlatformProgram,\n    configPda,\n    matchPda,\n    platformConfigPda,\n    creatorProfilePda,\n    opponentProfilePda,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Instruction helpers\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function initPlatform(t: TestContext) {\n  await t.platformProgram.methods\n    .initializePlatform(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.platformConfigPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createPlayerProfile(\n  t: TestContext,\n  program: Program<Platform>,\n  player: PublicKey\n) {\n  const profilePda = getPlayerProfilePda(player);\n  await program.methods\n    .createPlayerProfile()\n    .accounts({\n      player,\n      profile: profilePda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function setupPlatform(t: TestContext) {\n  await initPlatform(t);\n  await createPlayerProfile(t, t.platformProgram, t.creator);\n  await createPlayerProfile(\n    t,\n    t.opponentPlatformProgram,\n    t.opponent.publicKey\n  );\n}\n\nasync function createMatch(\n  t: TestContext,\n  tier = TIER_IRON,\n  side = SIDE_HEADS\n) {\n  await t.creatorProgram.methods\n    .createMatch(tier, side)\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function joinMatch(t: TestContext) {\n  await t.opponentProgram.methods\n    .joinMatch()\n    .accounts({\n      opponent: t.opponent.publicKey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      oraoProgram: t.mockOraoProgram.publicKey,\n      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n      oraoTreasury: t.mockOraoTreasury.publicKey,\n      oraoRandom: t.mockRandomness.publicKey,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function claimPayout(\n  t: TestContext,\n  callerProgram: Program<Coinflip>,\n  callerPubkey: PublicKey\n) {\n  await callerProgram.methods\n    .claimPayout()\n    .accounts({\n      caller: callerPubkey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      treasury: t.treasury.publicKey,\n      creator: t.creator,\n      opponent: t.opponent.publicKey,\n      randomnessAccount: t.mockRandomness.publicKey,\n      creatorProfile: t.creatorProfilePda,\n      opponentProfile: t.opponentProfilePda,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function cancelMatch(t: TestContext) {\n  await t.creatorProgram.methods\n    .cancelMatch()\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function timeoutCancel(\n  t: TestContext,\n  callerProgram: Program<Coinflip>,\n  callerPubkey: PublicKey\n) {\n  await callerProgram.methods\n    .timeoutCancel()\n    .accounts({\n      caller: callerPubkey,\n      creator: t.creator,\n      opponent: t.opponent.publicKey,\n      coinflipMatch: t.matchPda,\n      randomnessAccount: t.mockRandomness.publicKey,\n    })\n    .rpc();\n}\n\nfunction setMockRandomness(t: TestContext, data: Buffer) {\n  t.context.setAccount(t.mockRandomness.publicKey, {\n    lamports: LAMPORTS_PER_SOL,\n    data,\n    owner: SystemProgram.programId,\n    executable: false,\n  });\n}\n\nasync function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n  const account = await t.context.banksClient.getAccount(pubkey);\n  return account ? Number(account.lamports) : 0;\n}\n\nasync function warpPastDeadline(t: TestContext) {\n  const clock = await t.context.banksClient.getClock();\n  t.context.setClock(\n    new Clock(\n      clock.slot + BigInt(300),\n      clock.epochStartTimestamp,\n      clock.epoch,\n      clock.leaderScheduleEpoch,\n      clock.unixTimestamp + BigInt(DEFAULT_RESOLVE_TIMEOUT + 10)\n    )\n  );\n}\n\n// ===========================================================================\n// Tests\n// ===========================================================================\ndescribe(\"coinflip\", () => {\n  // -----------------------------------------------------------------------\n  // initialize_config\n  // -----------------------------------------------------------------------\n  describe(\"initialize_config\", () => {\n    it(\"creates config with treasury and paused=false\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.coinflipConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n      expect(config.paused).to.equal(false);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // create_match\n  // -----------------------------------------------------------------------\n  describe(\"create_match\", () => {\n    it(\"creates match in Waiting phase with correct escrow\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(m.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(m.opponent.toBase58()).to.equal(PublicKey.default.toBase58());\n      expect(m.tier).to.equal(TIER_IRON);\n      expect(m.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(m.creatorSide).to.equal(SIDE_HEADS);\n      expect(JSON.stringify(m.phase)).to.equal(JSON.stringify({ waiting: {} }));\n      expect(m.claimed).to.equal(false);\n      expect(m.createdAt.toNumber()).to.be.greaterThan(0);\n    });\n\n    it(\"escrows correct lamport amount\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      const balanceBefore = await getBalance(t, t.creator);\n\n      await createMatch(t);\n\n      const matchBalance = await getBalance(t, t.matchPda);\n      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      const rentLamports = matchBalance - m.entryAmount.toNumber();\n      expect(rentLamports).to.be.greaterThan(0);\n      expect(m.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n\n      const balanceAfter = await getBalance(t, t.creator);\n      const spent = balanceBefore - balanceAfter;\n      // Creator paid entry_amount + rent + tx fee (5000)\n      expect(spent - matchBalance).to.equal(5000);\n    });\n\n    it(\"rejects invalid side\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      try {\n        await t.creatorProgram.methods\n          .createMatch(TIER_IRON, 3)\n          .accounts({\n            creator: t.creator,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidSide error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"InvalidSide\"\n        );\n      }\n    });\n\n    it(\"rejects invalid tier\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      try {\n        await t.creatorProgram.methods\n          .createMatch(99, SIDE_HEADS)\n          .accounts({\n            creator: t.creator,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"InvalidTier\"\n        );\n      }\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // join_match\n  // -----------------------------------------------------------------------\n  describe(\"join_match\", () => {\n    it(\"transitions to Locked, doubles escrow, sets VRF fields\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      const escrowBefore = await getBalance(t, t.matchPda);\n      await joinMatch(t);\n\n      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(m.opponent.toBase58()).to.equal(\n        t.opponent.publicKey.toBase58()\n      );\n      expect(JSON.stringify(m.phase)).to.equal(\n        JSON.stringify({ locked: {} })\n      );\n      expect(m.vrfRequestKey.toBase58()).to.equal(\n        t.mockRandomness.publicKey.toBase58()\n      );\n      expect(m.resolveDeadline.toNumber()).to.be.greaterThan(0);\n      expect(m.lockedAt.toNumber()).to.be.greaterThan(0);\n\n      const escrowAfter = await getBalance(t, t.matchPda);\n      expect(escrowAfter - escrowBefore).to.equal(TIER_IRON_AMOUNT);\n    });\n\n    it(\"rejects self-join\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      try {\n        await t.creatorProgram.methods\n          .joinMatch()\n          .accounts({\n            opponent: t.creator,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            oraoProgram: t.mockOraoProgram.publicKey,\n            oraoNetworkState: t.mockOraoNetworkState.publicKey,\n            oraoTreasury: t.mockOraoTreasury.publicKey,\n            oraoRandom: t.mockRandomness.publicKey,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected CannotJoinOwnMatch error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"CannotJoinOwnMatch\"\n        );\n      }\n    });\n\n    it(\"rejects join when already Locked\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t);\n\n      const secondOpponent = Keypair.generate();\n      t.context.setAccount(secondOpponent.publicKey, fundedAccountData());\n      const secondProvider = new BankrunProvider(\n        t.context,\n        new Wallet(secondOpponent)\n      );\n      const secondProgram = new Program<Coinflip>(IDL, secondProvider);\n\n      try {\n        await secondProgram.methods\n          .joinMatch()\n          .accounts({\n            opponent: secondOpponent.publicKey,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            oraoProgram: t.mockOraoProgram.publicKey,\n            oraoNetworkState: t.mockOraoNetworkState.publicKey,\n            oraoTreasury: t.mockOraoTreasury.publicKey,\n            oraoRandom: t.mockRandomness.publicKey,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTransition error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"InvalidTransition\"\n        );\n      }\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // claim_payout\n  // -----------------------------------------------------------------------\n  describe(\"claim_payout\", () => {\n    it(\"creator wins with HEADS, fee to treasury\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      // Write fulfilled randomness: byte[0]=2 → HEADS\n      setMockRandomness(t, RANDOMNESS_HEADS);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const winnerBefore = await getBalance(t, t.creator);\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const winnerAfter = await getBalance(t, t.creator);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      // Creator receives payout + rent refund from closed PDA (minus tx fee)\n      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n      // Treasury receives exact fee\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n    });\n\n    it(\"opponent wins with TAILS\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      setMockRandomness(t, RANDOMNESS_TAILS);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n\n      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n\n      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      // Opponent receives payout (minus tx fee of 5000)\n      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(\n        payout - 5000\n      );\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n    });\n\n    it(\"either player can trigger claim — payout goes to derived winner\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      // TAILS → opponent wins, but creator triggers claim\n      setMockRandomness(t, RANDOMNESS_TAILS);\n\n      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n\n      // Creator calls claim, but payout goes to opponent (derived winner)\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Opponent didn't call any tx, so exact payout (no tx fee deduction)\n      expect(opponentAfter - opponentBefore).to.equal(payout);\n    });\n\n    it(\"match PDA closed after claim\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      setMockRandomness(t, RANDOMNESS_HEADS);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects claim with unfulfilled randomness\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      // Randomness stays all zeros (unfulfilled)\n\n      try {\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected RandomnessNotFulfilled error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"RandomnessNotFulfilled\"\n        );\n      }\n    });\n\n    it(\"rejects double claim (account closed)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      setMockRandomness(t, RANDOMNESS_HEADS);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      try {\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected error on double claim\");\n      } catch (err) {\n        // Account is closed — second claim fails\n        expect(err).to.exist;\n      }\n    });\n\n    it(\"rejects unauthorized caller (not creator or opponent)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      setMockRandomness(t, RANDOMNESS_HEADS);\n\n      const thirdParty = Keypair.generate();\n      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n      const thirdProvider = new BankrunProvider(\n        t.context,\n        new Wallet(thirdParty)\n      );\n      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n\n      try {\n        await thirdProgram.methods\n          .claimPayout()\n          .accounts({\n            caller: thirdParty.publicKey,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            treasury: t.treasury.publicKey,\n            creator: t.creator,\n            opponent: t.opponent.publicKey,\n            randomnessAccount: t.mockRandomness.publicKey,\n            creatorProfile: t.creatorProfilePda,\n            opponentProfile: t.opponentProfilePda,\n            platformProgram: PLATFORM_PROGRAM_ID,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected UnauthorizedCaller error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"UnauthorizedCaller\"\n        );\n      }\n    });\n\n    it(\"updates player profiles via CPI — creator wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      setMockRandomness(t, RANDOMNESS_HEADS);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const cp = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(cp.totalGames.toNumber()).to.equal(1);\n      expect(cp.wins.toNumber()).to.equal(1);\n      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(cp.totalWon.toNumber()).to.equal(payout);\n\n      const op = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(op.totalGames.toNumber()).to.equal(1);\n      expect(op.wins.toNumber()).to.equal(0);\n      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(op.totalWon.toNumber()).to.equal(0);\n    });\n\n    it(\"updates player profiles via CPI — opponent wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      setMockRandomness(t, RANDOMNESS_TAILS);\n\n      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const cp = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(cp.totalGames.toNumber()).to.equal(1);\n      expect(cp.wins.toNumber()).to.equal(0);\n      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(cp.totalWon.toNumber()).to.equal(0);\n\n      const op = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(op.totalGames.toNumber()).to.equal(1);\n      expect(op.wins.toNumber()).to.equal(1);\n      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(op.totalWon.toNumber()).to.equal(payout);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // cancel_match\n  // -----------------------------------------------------------------------\n  describe(\"cancel_match\", () => {\n    it(\"creator cancels Waiting match, full refund\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      const balanceBefore = await getBalance(t, t.creator);\n      await cancelMatch(t);\n      const balanceAfter = await getBalance(t, t.creator);\n\n      // Creator gets escrow + rent back (minus tx fee)\n      expect(balanceAfter - balanceBefore).to.be.greaterThanOrEqual(\n        TIER_IRON_AMOUNT\n      );\n\n      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects cancel after Locked (InvalidTransition)\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t);\n\n      try {\n        await cancelMatch(t);\n        expect.fail(\"Expected InvalidTransition error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"InvalidTransition\"\n        );\n      }\n    });\n\n    it(\"rejects cancel by non-creator\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      // Opponent tries to cancel creator's match — PDA mismatch\n      const opponentMatchPda = getMatchPda(t.opponent.publicKey);\n      try {\n        await t.opponentProgram.methods\n          .cancelMatch()\n          .accounts({\n            creator: t.opponent.publicKey,\n            coinflipMatch: opponentMatchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected error\");\n      } catch (err) {\n        // PDA doesn't exist → AccountNotInitialized\n        expect(err).to.exist;\n      }\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // timeout_cancel\n  // -----------------------------------------------------------------------\n  describe(\"timeout_cancel\", () => {\n    it(\"permissionless refund after deadline when VRF unfulfilled\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t);\n      // Randomness stays unfulfilled (all zeros)\n\n      await warpPastDeadline(t);\n\n      const creatorBefore = await getBalance(t, t.creator);\n      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n\n      // Third party triggers timeout (permissionless)\n      const thirdParty = Keypair.generate();\n      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n      const thirdProvider = new BankrunProvider(\n        t.context,\n        new Wallet(thirdParty)\n      );\n      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n\n      await timeoutCancel(t, thirdProgram, thirdParty.publicKey);\n\n      const creatorAfter = await getBalance(t, t.creator);\n      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n\n      // Both players refunded entry amounts\n      // Creator also gets rent refund from closed PDA\n      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n        TIER_IRON_AMOUNT\n      );\n      expect(opponentAfter - opponentBefore).to.equal(TIER_IRON_AMOUNT);\n\n      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects timeout before deadline\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t);\n      // Don't warp clock\n\n      try {\n        await timeoutCancel(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected LockTimeoutNotElapsed error\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"LockTimeoutNotElapsed\"\n        );\n      }\n    });\n\n    it(\"rejects timeout when VRF IS fulfilled — must claim instead\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t);\n\n      // Set fulfilled randomness\n      setMockRandomness(t, RANDOMNESS_HEADS);\n      await warpPastDeadline(t);\n\n      try {\n        await timeoutCancel(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected error — VRF fulfilled, must claim\");\n      } catch (err) {\n        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"InvalidPhase\"\n        );\n      }\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // full lifecycle\n  // -----------------------------------------------------------------------\n  describe(\"full lifecycle\", () => {\n    it(\"create → join → claim(HEADS) → PDA closed\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      let m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(JSON.stringify(m.phase)).to.equal(\n        JSON.stringify({ waiting: {} })\n      );\n\n      await joinMatch(t);\n      m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(JSON.stringify(m.phase)).to.equal(\n        JSON.stringify({ locked: {} })\n      );\n\n      setMockRandomness(t, RANDOMNESS_HEADS);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n\n      const closed = await t.context.banksClient.getAccount(t.matchPda);\n      expect(closed).to.be.null;\n    });\n\n    it(\"create → cancel → create again\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await cancelMatch(t);\n\n      const closed = await t.context.banksClient.getAccount(t.matchPda);\n      expect(closed).to.be.null;\n\n      // Create again (same PDA slot is free)\n      await createMatch(t, TIER_IRON, SIDE_TAILS);\n      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(m.creatorSide).to.equal(SIDE_TAILS);\n      expect(JSON.stringify(m.phase)).to.equal(\n        JSON.stringify({ waiting: {} })\n      );\n    });\n\n    it(\"create → join → timeout (VRF unfulfilled) → both refunded\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await warpPastDeadline(t);\n\n      const creatorBefore = await getBalance(t, t.creator);\n      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n\n      await timeoutCancel(t, t.opponentProgram, t.opponent.publicKey);\n\n      const creatorAfter = await getBalance(t, t.creator);\n      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n\n      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n        TIER_IRON_AMOUNT\n      );\n      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(\n        TIER_IRON_AMOUNT - 5000\n      ); // minus tx fee\n    });\n  });\n});\n","structuredPatch":[{"oldStart":808,"oldLines":7,"newStart":808,"newLines":7,"lines":["       expect(matchAccount).to.be.null;","     });"," ","-    it(\"rejects cancel after Locked (InvalidTransition)\", async () => {","+    it(\"rejects cancel after Locked (CannotCancel)\", async () => {","       const t = await cr