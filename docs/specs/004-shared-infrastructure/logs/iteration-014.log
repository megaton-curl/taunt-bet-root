:error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n#[derive(Accounts)]\npub struct CreateMatch<'info> {\n    /// The player creating the match. Must sign and fund the escrow.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA. Seeds enforce one active match per creator.\n    #[account(\n        init,\n        payer = creator,\n        space = 8 + CoinflipMatch::INIT_SPACE,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (read-only, for pause check).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    // Pause check: reject new matches when game is paused\n    check_not_paused(false, ctx.accounts.config.paused)?;\n\n    require!(is_valid_side(side), CoinflipError::InvalidSide);\n\n    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n\n    // Transfer entry_amount from creator to match PDA (escrow)\n    transfer_lamports_to_pda(\n        &ctx.accounts.creator.to_account_info(),\n        &ctx.accounts.coinflip_match.to_account_info(),\n        entry_amount,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    let now = Clock::get()?.unix_timestamp;\n\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.creator = ctx.accounts.creator.key();\n    coinflip_match.opponent = Pubkey::default();\n    coinflip_match.tier = tier;\n    coinflip_match.entry_amount = entry_amount;\n    coinflip_match.creator_side = side;\n    coinflip_match.phase = RoundPhase::Waiting;\n    coinflip_match.result = 0;\n    coinflip_match.winner = Pubkey::default();\n    coinflip_match.claimed = false;\n    coinflip_match.created_at = now;\n    coinflip_match.locked_at = 0;\n    coinflip_match.resolve_deadline = 0;\n    coinflip_match.vrf_request_key = Pubkey::default();\n    coinflip_match.bump = ctx.bumps.coinflip_match;\n\n    Ok(())\n}\n```\n\n---\n\n### 6. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/join_match.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_to_pda;\nuse rng_shared::lifecycle::{self, RoundPhase};\nuse rng_shared::timeout::DEFAULT_RESOLVE_TIMEOUT_SECONDS;\nuse rng_shared::vrf_orao;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n/// Opponent joins a match, deposits SOL, and requests Orao VRF.\n#[derive(Accounts)]\npub struct JoinMatch<'info> {\n    /// The opponent joining the match. Must sign and fund their escrow.\n    #[account(mut)]\n    pub opponent: Signer<'info>,\n\n    /// The match PDA to join.\n    #[account(\n        mut,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA.\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// Orao VRF program.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    pub orao_program: UncheckedAccount<'info>,\n\n    /// Orao network state PDA.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_network_state: UncheckedAccount<'info>,\n\n    /// Orao treasury for VRF fee payment.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_treasury: UncheckedAccount<'info>,\n\n    /// Orao randomness account (created by Orao CPI).\n    /// CHECK: Orao VRF CPI validates and initializes this account.\n    #[account(mut)]\n    pub orao_random: UncheckedAccount<'info>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<JoinMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Validate Waiting → Locked transition via shared lifecycle\n    lifecycle::transition(coinflip_match.phase, RoundPhase::Locked)?;\n\n    // Opponent cannot be the creator\n    require!(\n        ctx.accounts.opponent.key() != coinflip_match.creator,\n        CoinflipError::CannotJoinOwnMatch\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n    let opponent_key = ctx.accounts.opponent.key();\n\n    // Transfer entry_amount from opponent to match PDA (escrow) via shared helper\n    transfer_lamports_to_pda(\n        &ctx.accounts.opponent.to_account_info(),\n        &ctx.accounts.coinflip_match.to_account_info(),\n        entry_amount,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    // Request Orao VRF — use match PDA key as unique seed\n    let seed: [u8; 32] = ctx.accounts.coinflip_match.key().to_bytes();\n    vrf_orao::request_orao_randomness(\n        &ctx.accounts.orao_program.to_account_info(),\n        &ctx.accounts.orao_network_state.to_account_info(),\n        &ctx.accounts.orao_treasury.to_account_info(),\n        &ctx.accounts.orao_random.to_account_info(),\n        &ctx.accounts.opponent.to_account_info(),\n        &ctx.accounts.system_program.to_account_info(),\n        seed,\n    )?;\n\n    // Update match state\n    let now = Clock::get()?.unix_timestamp;\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.opponent = opponent_key;\n    coinflip_match.phase = RoundPhase::Locked;\n    coinflip_match.locked_at = now;\n    coinflip_match.resolve_deadline = now + DEFAULT_RESOLVE_TIMEOUT_SECONDS;\n    coinflip_match.vrf_request_key = ctx.accounts.orao_random.key();\n\n    Ok(())\n}\n```\n\n---\n\n### 7. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/claim_payout.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::constants::from_randomness;\nuse rng_shared::escrow::transfer_lamports_from_pda;\nuse rng_shared::fees::calculate_net_payout;\nuse rng_shared::lifecycle::RoundPhase;\nuse rng_shared::vrf_orao::read_orao_randomness;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch, MatchSettled};\n\n#[derive(Accounts)]\npub struct ClaimPayout<'info> {\n    /// Either the creator or opponent can trigger the claim.\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The match PDA (closed after claim — rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (for treasury address + CPI signing).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// The treasury account to receive fees.\n    /// CHECK: Validated against config.treasury in handler.\n    #[account(mut)]\n    pub treasury: AccountInfo<'info>,\n\n    /// The creator account (receives rent refund on close).\n    /// CHECK: Validated against coinflip_match.creator in handler.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent account.\n    /// CHECK: Validated against coinflip_match.opponent in handler.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The Orao randomness PDA — must match vrf_request_key stored on match.\n    /// CHECK: Key validated against coinflip_match.vrf_request_key; data read by shared VRF helper.\n    pub randomness_account: AccountInfo<'info>,\n\n    /// Creator's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub creator_profile: AccountInfo<'info>,\n\n    /// Opponent's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub opponent_profile: AccountInfo<'info>,\n\n    /// The platform program for CPI calls.\n    pub platform_program: Program<'info, platform::program::Platform>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<ClaimPayout>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // (1) Must be in LOCKED phase and not already claimed\n    require!(\n        coinflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n    require!(!coinflip_match.claimed, CoinflipError::AlreadyClaimed);\n\n    // Caller must be either creator or opponent\n    let caller = ctx.accounts.caller.key();\n    require!(\n        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n        CoinflipError::UnauthorizedCaller\n    );\n\n    // Validate accounts match stored state\n    require!(\n        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.creator.key() == coinflip_match.creator,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.opponent.key() == coinflip_match.opponent,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.randomness_account.key() == coinflip_match.vrf_request_key,\n        CoinflipError::InvalidPhase\n    );\n\n    // (2) Read Orao randomness — rejects if not fulfilled\n    let randomness = read_orao_randomness(&ctx.accounts.randomness_account)?;\n\n    // (3) Derive winner from randomness\n    let result = from_randomness(randomness[0]);\n    let winner = if result == coinflip_match.creator_side {\n        coinflip_match.creator\n    } else {\n        coinflip_match.opponent\n    };\n\n    // (4) Compute fee/payout\n    let pool = coinflip_match.entry_amount.checked_mul(2).unwrap();\n    let (fee, payout) = calculate_net_payout(pool);\n\n    // (5) Transfer payout to winner + fee to treasury\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    let winner_account = if winner == coinflip_match.creator {\n        ctx.accounts.creator.to_account_info()\n    } else {\n        ctx.accounts.opponent.to_account_info()\n    };\n    transfer_lamports_from_pda(&match_info, &winner_account, payout)?;\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.treasury, fee)?;\n\n    // (6) CPI update both player profiles via shared helper\n    let config_bump = ctx.accounts.config.bump;\n    let signer_seeds: &[&[u8]] = &[b\"coinflip_config\", &[config_bump]];\n\n    let creator_is_winner = winner == coinflip_match.creator;\n    rng_shared::cpi::update_player_profile_cpi(\n        &ctx.accounts.platform_program.to_account_info(),\n        &ctx.accounts.creator_profile,\n        &ctx.accounts.config.to_account_info(),\n        signer_seeds,\n        1,\n        if creator_is_winner { 1 } else { 0 },\n        coinflip_match.entry_amount,\n        if creator_is_winner { payout } else { 0 },\n    )?;\n\n    rng_shared::cpi::update_player_profile_cpi(\n        &ctx.accounts.platform_program.to_account_info(),\n        &ctx.accounts.opponent_profile,\n        &ctx.accounts.config.to_account_info(),\n        signer_seeds,\n        1,\n        if creator_is_winner { 0 } else { 1 },\n        coinflip_match.entry_amount,\n        if creator_is_winner { 0 } else { payout },\n    )?;\n\n    // (7) Emit MatchSettled event (audit trail persists in tx logs after PDA closed)\n    emit!(MatchSettled {\n        creator: coinflip_match.creator,\n        opponent: coinflip_match.opponent,\n        winner,\n        randomness,\n        payout_amount: payout,\n        fee_amount: fee,\n    });\n\n    // (8) Set phase = Settled, claimed = true, store result + winner\n    // Note: LOCKED → SETTLED is intentionally not in the transition() function;\n    // VRF games handle this phase change directly after reading randomness.\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.phase = RoundPhase::Settled;\n    coinflip_match.claimed = true;\n    coinflip_match.result = result;\n    coinflip_match.winner = winner;\n\n    // Account is closed by Anchor's `close = creator` constraint after handler returns.\n    // Remaining lamports (rent) are sent to creator.\n\n    Ok(())\n}\n```\n\n---\n\n### 8. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/cancel_match.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::lifecycle::{transition, RoundPhase};\n\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct CancelMatch<'info> {\n    /// The creator cancelling their match.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA (closed on cancel — escrow + rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Validate phase transition: Waiting → Refunded\n    transition(coinflip_match.phase, RoundPhase::Refunded)?;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // all lamports (escrow + rent) are returned to creator.\n\n    Ok(())\n}\n```\n\n---\n\n### 9. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/timeout_cancel.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_from_pda;\nuse rng_shared::lifecycle::{self, RoundPhase};\nuse rng_shared::timeout::is_expired;\nuse rng_shared::vrf_orao::{is_fulfilled, read_orao_randomness};\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct TimeoutCancel<'info> {\n    /// Any signer can trigger a timeout cancel (permissionless after deadline).\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The creator's account — receives entry refund + rent.\n    /// CHECK: Validated against coinflip_match.creator.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent's account — receives entry refund.\n    /// CHECK: Validated against coinflip_match.opponent.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The Orao randomness PDA — used to check VRF is NOT fulfilled.\n    /// CHECK: Key validated against coinflip_match.vrf_request_key; data read by shared VRF helper.\n    pub randomness_account: AccountInfo<'info>,\n}\n\npub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in LOCKED phase\n    require!(\n        coinflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n\n    // Validate passed accounts match stored keys\n    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n    require_keys_eq!(\n        ctx.accounts.randomness_account.key(),\n        coinflip_match.vrf_request_key\n    );\n\n    // Check timeout has elapsed using shared helper\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        is_expired(coinflip_match.resolve_deadline, now),\n        CoinflipError::LockTimeoutNotElapsed\n    );\n\n    // Check that VRF randomness is NOT fulfilled — if it is, must use claim_payout instead.\n    // read_orao_randomness returns Ok([u8;32]) if fulfilled, Err if not.\n    // We try to read; if it succeeds and is fulfilled, reject the timeout cancel.\n    let vrf_is_fulfilled = read_orao_randomness(&ctx.accounts.randomness_account)\n        .map(|r| is_fulfilled(&r))\n        .unwrap_or(false);\n    require!(!vrf_is_fulfilled, CoinflipError::InvalidPhase);\n\n    let entry_amount = coinflip_match.entry_amount;\n\n    // Refund both players their entry amounts using shared escrow helper\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.creator, entry_amount)?;\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.opponent, entry_amount)?;\n\n    // Transition to Refunded via shared lifecycle\n    lifecycle::transition(coinflip_match.phase, RoundPhase::Refunded)?;\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.phase = RoundPhase::Refunded;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // remaining lamports (rent) are returned to creator.\n\n    Ok(())\n}\n```\n\n---\n\n### 10. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/initialize_config.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\nuse crate::state::CoinflipConfig;\n\n#[derive(Accounts)]\npub struct InitializeConfig<'info> {\n    /// Admin authority who initializes the config.\n    #[account(mut)]\n    pub authority: Signer<'info>,\n\n    /// The config PDA (singleton).\n    #[account(\n        init,\n        payer = authority,\n        space = 8 + CoinflipConfig::INIT_SPACE,\n        seeds = [b\"coinflip_config\"],\n        bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n    let config = &mut ctx.accounts.config;\n    config.authority = ctx.accounts.authority.key();\n    config.treasury = treasury;\n    config.paused = false;\n    config.bump = ctx.bumps.config;\n\n    Ok(())\n}\n```\n\n---\n\nAll 10 files have been provided with their complete source code. The coinflip program is an Anchor-based smart contract that implements a two-player coin flip game using Orao VRF for randomization."},{"type":"text","text":"agentId: ab54b0fbcfe59211a (for resuming to continue this agent's work if needed)\n<usage>total_tokens: 44819\ntool_uses: 10\nduration_ms: 51125</usage>"}]}]},"parent_tool_use_id":null,"session_id":"26c7f4cc-b2b2-41aa-85e9-beee2a3d95f1","uuid":"b1f49649-9713-4782-b375-b3696accd19c","tool_use_result":{"status":"completed","prompt":"Read the following files and report their complete contents back to me. I need ALL the code, not summaries:\n\n1. `sources/rng-utopia/solana/programs/coinflip/src/state.rs`\n2. `sources/rng-utopia/solana/programs/coinflip/src/lib.rs`\n3. `sources/rng-utopia/solana/programs/coinflip/src/instructions/mod.rs`\n4. `sources/rng-utopia/solana/programs/coinflip/src/error.rs`\n5. `sources/rng-utopia/solana/programs/coinflip/src/instructions/create_match.rs`\n6. `sources/rng-utopia/solana/programs/coinflip/src/instructions/join_match.rs`\n7. `sources/rng-utopia/solana/programs/coinflip/src/instructions/claim_payout.rs`\n8. `sources/rng-utopia/solana/programs/coinflip/src/instructions/cancel_match.rs`\n9. `sources/rng-utopia/solana/programs/coinflip/src/instructions/timeout_cancel.rs`\n10. `sources/rng-utopia/solana/programs/coinflip/src/instructions/initialize_config.rs`\n\nRead each file and provide the COMPLETE content.","agentId":"ab54b0fbcfe59211a","content":[{"type":"text","text":"## Complete Coinflip Program Source Code\n\nHere are all 10 files you requested, with complete contents:\n\n---\n\n### 1. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/state.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::lifecycle::RoundPhase;\n\n/// Global configuration for the coinflip program.\n/// PDA seeds: [b\"coinflip_config\"]\n#[account]\n#[derive(InitSpace)]\npub struct CoinflipConfig {\n    /// Admin authority (can update config).\n    pub authority: Pubkey,\n    /// Fee destination wallet.\n    pub treasury: Pubkey,\n    /// Whether the game is paused (rejects new matches).\n    pub paused: bool,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// A coinflip match between two players.\n/// PDA seeds: [b\"match\", creator.key().as_ref()]\n#[account]\n#[derive(InitSpace)]\npub struct CoinflipMatch {\n    /// The player who created the match.\n    pub creator: Pubkey,\n    /// The player who joined (Pubkey::default() if empty).\n    pub opponent: Pubkey,\n    /// Tier index (0-5).\n    pub tier: u8,\n    /// Entry amount in lamports (derived from tier).\n    pub entry_amount: u64,\n    /// Side chosen by creator (0 = Heads, 1 = Tails).\n    pub creator_side: u8,\n    /// Current phase of the match (shared lifecycle enum).\n    pub phase: RoundPhase,\n    /// The winning side after VRF resolution (0 or 1, only valid when settled).\n    pub result: u8,\n    /// The winner's pubkey (Pubkey::default() until settled).\n    pub winner: Pubkey,\n    /// Whether the payout has been claimed.\n    pub claimed: bool,\n    /// Unix timestamp when the match was created.\n    pub created_at: i64,\n    /// Unix timestamp when the match entered LOCKED phase (0 if still WAITING).\n    pub locked_at: i64,\n    /// Deadline for VRF resolution; after this, timeout refund is available.\n    pub resolve_deadline: i64,\n    /// Address of the Orao randomness PDA for VRF lookup at claim time.\n    pub vrf_request_key: Pubkey,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// Event emitted when a match is settled via claim_payout.\n#[event]\npub struct MatchSettled {\n    pub creator: Pubkey,\n    pub opponent: Pubkey,\n    pub winner: Pubkey,\n    pub randomness: [u8; 32],\n    pub payout_amount: u64,\n    pub fee_amount: u64,\n}\n```\n\n---\n\n### 2. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/lib.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\npub mod error;\npub mod instructions;\npub mod state;\n\nuse instructions::*;\n\ndeclare_id!(\"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\");\n\n#[program]\npub mod coinflip {\n    use super::*;\n\n    pub fn initialize_config(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n        instructions::initialize_config::handler(ctx, treasury)\n    }\n\n    pub fn create_match(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n        instructions::create_match::handler(ctx, tier, side)\n    }\n\n    pub fn join_match(ctx: Context<JoinMatch>) -> Result<()> {\n        instructions::join_match::handler(ctx)\n    }\n\n    pub fn claim_payout(ctx: Context<ClaimPayout>) -> Result<()> {\n        instructions::claim_payout::handler(ctx)\n    }\n\n    pub fn cancel_match(ctx: Context<CancelMatch>) -> Result<()> {\n        instructions::cancel_match::handler(ctx)\n    }\n\n    pub fn timeout_cancel(ctx: Context<TimeoutCancel>) -> Result<()> {\n        instructions::timeout_cancel::handler(ctx)\n    }\n\n    pub fn force_close(ctx: Context<ForceClose>) -> Result<()> {\n        instructions::force_close::handler(ctx)\n    }\n}\n```\n\n---\n\n### 3. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/mod.rs`\n\n```rust\npub mod cancel_match;\npub mod claim_payout;\npub mod create_match;\npub mod force_close;\npub mod initialize_config;\npub mod join_match;\npub mod timeout_cancel;\n\npub use cancel_match::*;\npub use claim_payout::*;\npub use create_match::*;\npub use force_close::*;\npub use initialize_config::*;\npub use join_match::*;\npub use timeout_cancel::*;\n```\n\n---\n\n### 4. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/error.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\n#[error_code]\npub enum CoinflipError {\n    /// 6100 (Anchor adds 6000 base offset)\n    #[msg(\"Invalid side: must be 0 (Heads) or 1 (Tails)\")]\n    InvalidSide = 100,\n\n    /// 6101\n    #[msg(\"Invalid tier index\")]\n    InvalidTier,\n\n    /// 6102\n    #[msg(\"Match is not in the expected phase\")]\n    InvalidPhase,\n\n    /// 6103\n    #[msg(\"Insufficient funds for entry amount\")]\n    InsufficientFunds,\n\n    /// 6104\n    #[msg(\"Creator cannot join their own match\")]\n    CannotJoinOwnMatch,\n\n    /// 6105\n    #[msg(\"Only the oracle authority can resolve matches\")]\n    UnauthorizedOracle,\n\n    /// 6106\n    #[msg(\"Payout has already been claimed\")]\n    AlreadyClaimed,\n\n    /// 6107\n    #[msg(\"Only the winner can claim the payout\")]\n    NotWinner,\n\n    /// 6108\n    #[msg(\"Match can only be cancelled in WAITING phase\")]\n    CannotCancel,\n\n    /// 6109\n    #[msg(\"VRF randomness request failed\")]\n    VrfRequestFailed,\n\n    /// 6110\n    #[msg(\"Lock timeout has not elapsed yet\")]\n    LockTimeoutNotElapsed,\n\n    /// 6111\n    #[msg(\"Only the creator or opponent can cancel a timed-out match\")]\n    UnauthorizedCaller,\n}\n```\n\n---\n\n### 5. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/create_match.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::constants::is_valid_side;\nuse rng_shared::escrow::transfer_lamports_to_pda;\nuse rng_shared::lifecycle::RoundPhase;\nuse rng_shared::pause::check_not_paused;\nuse rng_shared::tiers::get_tier_amount;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n#[derive(Accounts)]\npub struct CreateMatch<'info> {\n    /// The player creating the match. Must sign and fund the escrow.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA. Seeds enforce one active match per creator.\n    #[account(\n        init,\n        payer = creator,\n        space = 8 + CoinflipMatch::INIT_SPACE,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (read-only, for pause check).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CreateMatch>, tier: u8, side: u8) -> Result<()> {\n    // Pause check: reject new matches when game is paused\n    check_not_paused(false, ctx.accounts.config.paused)?;\n\n    require!(is_valid_side(side), CoinflipError::InvalidSide);\n\n    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n\n    // Transfer entry_amount from creator to match PDA (escrow)\n    transfer_lamports_to_pda(\n        &ctx.accounts.creator.to_account_info(),\n        &ctx.accounts.coinflip_match.to_account_info(),\n        entry_amount,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    let now = Clock::get()?.unix_timestamp;\n\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.creator = ctx.accounts.creator.key();\n    coinflip_match.opponent = Pubkey::default();\n    coinflip_match.tier = tier;\n    coinflip_match.entry_amount = entry_amount;\n    coinflip_match.creator_side = side;\n    coinflip_match.phase = RoundPhase::Waiting;\n    coinflip_match.result = 0;\n    coinflip_match.winner = Pubkey::default();\n    coinflip_match.claimed = false;\n    coinflip_match.created_at = now;\n    coinflip_match.locked_at = 0;\n    coinflip_match.resolve_deadline = 0;\n    coinflip_match.vrf_request_key = Pubkey::default();\n    coinflip_match.bump = ctx.bumps.coinflip_match;\n\n    Ok(())\n}\n```\n\n---\n\n### 6. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/join_match.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_to_pda;\nuse rng_shared::lifecycle::{self, RoundPhase};\nuse rng_shared::timeout::DEFAULT_RESOLVE_TIMEOUT_SECONDS;\nuse rng_shared::vrf_orao;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch};\n\n/// Opponent joins a match, deposits SOL, and requests Orao VRF.\n#[derive(Accounts)]\npub struct JoinMatch<'info> {\n    /// The opponent joining the match. Must sign and fund their escrow.\n    #[account(mut)]\n    pub opponent: Signer<'info>,\n\n    /// The match PDA to join.\n    #[account(\n        mut,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA.\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// Orao VRF program.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    pub orao_program: UncheckedAccount<'info>,\n\n    /// Orao network state PDA.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_network_state: UncheckedAccount<'info>,\n\n    /// Orao treasury for VRF fee payment.\n    /// CHECK: Validated by Orao VRF CPI internally.\n    #[account(mut)]\n    pub orao_treasury: UncheckedAccount<'info>,\n\n    /// Orao randomness account (created by Orao CPI).\n    /// CHECK: Orao VRF CPI validates and initializes this account.\n    #[account(mut)]\n    pub orao_random: UncheckedAccount<'info>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<JoinMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Validate Waiting → Locked transition via shared lifecycle\n    lifecycle::transition(coinflip_match.phase, RoundPhase::Locked)?;\n\n    // Opponent cannot be the creator\n    require!(\n        ctx.accounts.opponent.key() != coinflip_match.creator,\n        CoinflipError::CannotJoinOwnMatch\n    );\n\n    let entry_amount = coinflip_match.entry_amount;\n    let opponent_key = ctx.accounts.opponent.key();\n\n    // Transfer entry_amount from opponent to match PDA (escrow) via shared helper\n    transfer_lamports_to_pda(\n        &ctx.accounts.opponent.to_account_info(),\n        &ctx.accounts.coinflip_match.to_account_info(),\n        entry_amount,\n        &ctx.accounts.system_program.to_account_info(),\n    )?;\n\n    // Request Orao VRF — use match PDA key as unique seed\n    let seed: [u8; 32] = ctx.accounts.coinflip_match.key().to_bytes();\n    vrf_orao::request_orao_randomness(\n        &ctx.accounts.orao_program.to_account_info(),\n        &ctx.accounts.orao_network_state.to_account_info(),\n        &ctx.accounts.orao_treasury.to_account_info(),\n        &ctx.accounts.orao_random.to_account_info(),\n        &ctx.accounts.opponent.to_account_info(),\n        &ctx.accounts.system_program.to_account_info(),\n        seed,\n    )?;\n\n    // Update match state\n    let now = Clock::get()?.unix_timestamp;\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.opponent = opponent_key;\n    coinflip_match.phase = RoundPhase::Locked;\n    coinflip_match.locked_at = now;\n    coinflip_match.resolve_deadline = now + DEFAULT_RESOLVE_TIMEOUT_SECONDS;\n    coinflip_match.vrf_request_key = ctx.accounts.orao_random.key();\n\n    Ok(())\n}\n```\n\n---\n\n### 7. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/claim_payout.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::constants::from_randomness;\nuse rng_shared::escrow::transfer_lamports_from_pda;\nuse rng_shared::fees::calculate_net_payout;\nuse rng_shared::lifecycle::RoundPhase;\nuse rng_shared::vrf_orao::read_orao_randomness;\n\nuse crate::error::CoinflipError;\nuse crate::state::{CoinflipConfig, CoinflipMatch, MatchSettled};\n\n#[derive(Accounts)]\npub struct ClaimPayout<'info> {\n    /// Either the creator or opponent can trigger the claim.\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The match PDA (closed after claim — rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The config PDA (for treasury address + CPI signing).\n    #[account(\n        seeds = [b\"coinflip_config\"],\n        bump = config.bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    /// The treasury account to receive fees.\n    /// CHECK: Validated against config.treasury in handler.\n    #[account(mut)]\n    pub treasury: AccountInfo<'info>,\n\n    /// The creator account (receives rent refund on close).\n    /// CHECK: Validated against coinflip_match.creator in handler.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent account.\n    /// CHECK: Validated against coinflip_match.opponent in handler.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The Orao randomness PDA — must match vrf_request_key stored on match.\n    /// CHECK: Key validated against coinflip_match.vrf_request_key; data read by shared VRF helper.\n    pub randomness_account: AccountInfo<'info>,\n\n    /// Creator's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub creator_profile: AccountInfo<'info>,\n\n    /// Opponent's player profile PDA on the platform program.\n    /// CHECK: Validated by platform program via CPI (if account exists).\n    #[account(mut)]\n    pub opponent_profile: AccountInfo<'info>,\n\n    /// The platform program for CPI calls.\n    pub platform_program: Program<'info, platform::program::Platform>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<ClaimPayout>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // (1) Must be in LOCKED phase and not already claimed\n    require!(\n        coinflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n    require!(!coinflip_match.claimed, CoinflipError::AlreadyClaimed);\n\n    // Caller must be either creator or opponent\n    let caller = ctx.accounts.caller.key();\n    require!(\n        caller == coinflip_match.creator || caller == coinflip_match.opponent,\n        CoinflipError::UnauthorizedCaller\n    );\n\n    // Validate accounts match stored state\n    require!(\n        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.creator.key() == coinflip_match.creator,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.opponent.key() == coinflip_match.opponent,\n        CoinflipError::InvalidPhase\n    );\n    require!(\n        ctx.accounts.randomness_account.key() == coinflip_match.vrf_request_key,\n        CoinflipError::InvalidPhase\n    );\n\n    // (2) Read Orao randomness — rejects if not fulfilled\n    let randomness = read_orao_randomness(&ctx.accounts.randomness_account)?;\n\n    // (3) Derive winner from randomness\n    let result = from_randomness(randomness[0]);\n    let winner = if result == coinflip_match.creator_side {\n        coinflip_match.creator\n    } else {\n        coinflip_match.opponent\n    };\n\n    // (4) Compute fee/payout\n    let pool = coinflip_match.entry_amount.checked_mul(2).unwrap();\n    let (fee, payout) = calculate_net_payout(pool);\n\n    // (5) Transfer payout to winner + fee to treasury\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    let winner_account = if winner == coinflip_match.creator {\n        ctx.accounts.creator.to_account_info()\n    } else {\n        ctx.accounts.opponent.to_account_info()\n    };\n    transfer_lamports_from_pda(&match_info, &winner_account, payout)?;\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.treasury, fee)?;\n\n    // (6) CPI update both player profiles via shared helper\n    let config_bump = ctx.accounts.config.bump;\n    let signer_seeds: &[&[u8]] = &[b\"coinflip_config\", &[config_bump]];\n\n    let creator_is_winner = winner == coinflip_match.creator;\n    rng_shared::cpi::update_player_profile_cpi(\n        &ctx.accounts.platform_program.to_account_info(),\n        &ctx.accounts.creator_profile,\n        &ctx.accounts.config.to_account_info(),\n        signer_seeds,\n        1,\n        if creator_is_winner { 1 } else { 0 },\n        coinflip_match.entry_amount,\n        if creator_is_winner { payout } else { 0 },\n    )?;\n\n    rng_shared::cpi::update_player_profile_cpi(\n        &ctx.accounts.platform_program.to_account_info(),\n        &ctx.accounts.opponent_profile,\n        &ctx.accounts.config.to_account_info(),\n        signer_seeds,\n        1,\n        if creator_is_winner { 0 } else { 1 },\n        coinflip_match.entry_amount,\n        if creator_is_winner { 0 } else { payout },\n    )?;\n\n    // (7) Emit MatchSettled event (audit trail persists in tx logs after PDA closed)\n    emit!(MatchSettled {\n        creator: coinflip_match.creator,\n        opponent: coinflip_match.opponent,\n        winner,\n        randomness,\n        payout_amount: payout,\n        fee_amount: fee,\n    });\n\n    // (8) Set phase = Settled, claimed = true, store result + winner\n    // Note: LOCKED → SETTLED is intentionally not in the transition() function;\n    // VRF games handle this phase change directly after reading randomness.\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.phase = RoundPhase::Settled;\n    coinflip_match.claimed = true;\n    coinflip_match.result = result;\n    coinflip_match.winner = winner;\n\n    // Account is closed by Anchor's `close = creator` constraint after handler returns.\n    // Remaining lamports (rent) are sent to creator.\n\n    Ok(())\n}\n```\n\n---\n\n### 8. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/cancel_match.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::lifecycle::{transition, RoundPhase};\n\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct CancelMatch<'info> {\n    /// The creator cancelling their match.\n    #[account(mut)]\n    pub creator: Signer<'info>,\n\n    /// The match PDA (closed on cancel — escrow + rent refunded to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", creator.key().as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Validate phase transition: Waiting → Refunded\n    transition(coinflip_match.phase, RoundPhase::Refunded)?;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // all lamports (escrow + rent) are returned to creator.\n\n    Ok(())\n}\n```\n\n---\n\n### 9. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/timeout_cancel.rs`\n\n```rust\nuse anchor_lang::prelude::*;\nuse rng_shared::escrow::transfer_lamports_from_pda;\nuse rng_shared::lifecycle::{self, RoundPhase};\nuse rng_shared::timeout::is_expired;\nuse rng_shared::vrf_orao::{is_fulfilled, read_orao_randomness};\n\nuse crate::error::CoinflipError;\nuse crate::state::CoinflipMatch;\n\n#[derive(Accounts)]\npub struct TimeoutCancel<'info> {\n    /// Any signer can trigger a timeout cancel (permissionless after deadline).\n    #[account(mut)]\n    pub caller: Signer<'info>,\n\n    /// The creator's account — receives entry refund + rent.\n    /// CHECK: Validated against coinflip_match.creator.\n    #[account(mut)]\n    pub creator: AccountInfo<'info>,\n\n    /// The opponent's account — receives entry refund.\n    /// CHECK: Validated against coinflip_match.opponent.\n    #[account(mut)]\n    pub opponent: AccountInfo<'info>,\n\n    /// The match PDA to cancel (closed after refunds — rent goes to creator).\n    #[account(\n        mut,\n        close = creator,\n        seeds = [b\"match\", coinflip_match.creator.as_ref()],\n        bump = coinflip_match.bump,\n    )]\n    pub coinflip_match: Account<'info, CoinflipMatch>,\n\n    /// The Orao randomness PDA — used to check VRF is NOT fulfilled.\n    /// CHECK: Key validated against coinflip_match.vrf_request_key; data read by shared VRF helper.\n    pub randomness_account: AccountInfo<'info>,\n}\n\npub fn handler(ctx: Context<TimeoutCancel>) -> Result<()> {\n    let coinflip_match = &ctx.accounts.coinflip_match;\n\n    // Must be in LOCKED phase\n    require!(\n        coinflip_match.phase == RoundPhase::Locked,\n        CoinflipError::InvalidPhase\n    );\n\n    // Validate passed accounts match stored keys\n    require_keys_eq!(ctx.accounts.creator.key(), coinflip_match.creator);\n    require_keys_eq!(ctx.accounts.opponent.key(), coinflip_match.opponent);\n    require_keys_eq!(\n        ctx.accounts.randomness_account.key(),\n        coinflip_match.vrf_request_key\n    );\n\n    // Check timeout has elapsed using shared helper\n    let now = Clock::get()?.unix_timestamp;\n    require!(\n        is_expired(coinflip_match.resolve_deadline, now),\n        CoinflipError::LockTimeoutNotElapsed\n    );\n\n    // Check that VRF randomness is NOT fulfilled — if it is, must use claim_payout instead.\n    // read_orao_randomness returns Ok([u8;32]) if fulfilled, Err if not.\n    // We try to read; if it succeeds and is fulfilled, reject the timeout cancel.\n    let vrf_is_fulfilled = read_orao_randomness(&ctx.accounts.randomness_account)\n        .map(|r| is_fulfilled(&r))\n        .unwrap_or(false);\n    require!(!vrf_is_fulfilled, CoinflipError::InvalidPhase);\n\n    let entry_amount = coinflip_match.entry_amount;\n\n    // Refund both players their entry amounts using shared escrow helper\n    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.creator, entry_amount)?;\n    transfer_lamports_from_pda(&match_info, &ctx.accounts.opponent, entry_amount)?;\n\n    // Transition to Refunded via shared lifecycle\n    lifecycle::transition(coinflip_match.phase, RoundPhase::Refunded)?;\n    let coinflip_match = &mut ctx.accounts.coinflip_match;\n    coinflip_match.phase = RoundPhase::Refunded;\n\n    // Account is closed by Anchor's `close = creator` constraint —\n    // remaining lamports (rent) are returned to creator.\n\n    Ok(())\n}\n```\n\n---\n\n### 10. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/instructions/initialize_config.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\nuse crate::state::CoinflipConfig;\n\n#[derive(Accounts)]\npub struct InitializeConfig<'info> {\n    /// Admin authority who initializes the config.\n    #[account(mut)]\n    pub authority: Signer<'info>,\n\n    /// The config PDA (singleton).\n    #[account(\n        init,\n        payer = authority,\n        space = 8 + CoinflipConfig::INIT_SPACE,\n        seeds = [b\"coinflip_config\"],\n        bump,\n    )]\n    pub config: Account<'info, CoinflipConfig>,\n\n    pub system_program: Program<'info, System>,\n}\n\npub fn handler(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n    let config = &mut ctx.accounts.config;\n    config.authority = ctx.accounts.authority.key();\n    config.treasury = treasury;\n    config.paused = false;\n    config.bump = ctx.bumps.config;\n\n    Ok(())\n}\n```\n\n---\n\nAll 10 files have been provided with their complete source code. The coinflip program is an Anchor-based smart contract that implements a two-player coin flip game using Orao VRF for randomization."}],"totalDurationMs":51125,"totalTokens":44819,"totalToolUseCount":10,"usage":{"input_tokens":