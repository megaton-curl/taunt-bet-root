(t, RANDOMNESS_HEADS);"," ","-      // 4. Claim","       const pool = TIER_IRON_AMOUNT * 2;","       const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);","-","       const treasuryBefore = await getBalance(t, t.treasury.publicKey);","+","       await claimPayout(t, t.creatorProgram, t.creator);","-      const treasuryAfter = await getBalance(t, t.treasury.publicKey);"," ","+      const treasuryAfter = await getBalance(t, t.treasury.publicKey);","       expect(treasuryAfter - treasuryBefore).to.equal(fee);"," ","-      // Match account closed","       const closed = await t.context.banksClient.getAccount(t.matchPda);","       expect(closed).to.be.null;","     });"," ","     it(\"create → cancel → create again\", async () => {","       const t = await createTestContext();","+      await initConfig(t);"," ","-      // 1. Create","       await createMatch(t, TIER_IRON, SIDE_HEADS);","-      let match = await t.creatorProgram.account.coinflipMatch.fetch(","-        t.matchPda","-      );","-      expect(match.phase).to.equal(PHASE_WAITING);","-","-      // 2. Cancel","       await cancelMatch(t);","+","       const closed = await t.context.banksClient.getAccount(t.matchPda);","       expect(closed).to.be.null;"," ","-      // 3. Create again (same PDA slot is free)","+      // Create again (same PDA slot is free)","       await createMatch(t, TIER_IRON, SIDE_TAILS);","-      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);","-      expect(match.creatorSide).to.equal(SIDE_TAILS);","-      expect(match.phase).to.equal(PHASE_WAITING);","+      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);","+      expect(m.creatorSide).to.equal(SIDE_TAILS);","+      expect(JSON.stringify(m.phase)).to.equal(","+        JSON.stringify({ waiting: {} })","+      );","     });","+","+    it(\"create → join → timeout (VRF unfulfilled) → both refunded\", async () => {","+      const t = await createTestContext();","+      await initConfig(t);","+","+      await createMatch(t, TIER_IRON, SIDE_HEADS);","+      await joinMatch(t);","+","+      await warpPastDeadline(t);","+","+      const creatorBefore = await getBalance(t, t.creator);","+      const opponentBefore = await getBalance(t, t.opponent.publicKey);","+","+      await timeoutCancel(t, t.opponentProgram, t.opponent.publicKey);","+","+      const creatorAfter = await getBalance(t, t.creator);","+      const opponentAfter = await getBalance(t, t.opponent.publicKey);","+","+      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(","+        TIER_IRON_AMOUNT","+      );","+      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(","+        TIER_IRON_AMOUNT - 5000","+      ); // minus tx fee","+    });","   });"," });"]}],"originalFile":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  SYSVAR_SLOT_HASHES_PUBKEY,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Coinflip } from \"../target/types/coinflip\";\nimport type { Platform } from \"../target/types/platform\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\nconst PLATFORM_IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n);\nconst PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n\n// ---------------------------------------------------------------------------\n// Constants matching shared crate\n// ---------------------------------------------------------------------------\nconst SIDE_HEADS = 0;\nconst SIDE_TAILS = 1;\nconst PHASE_WAITING = 0;\nconst PHASE_LOCKED = 1;\nconst PHASE_SETTLED = 2;\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL in lamports\nconst TOTAL_FEE_BPS = 300;\n\n// VRF mock constants\nconst RANDOMNESS_HEADS = new Array(32).fill(0); // byte[0]=0 (even) → HEADS\nconst RANDOMNESS_TAILS = (() => {\n  const arr = new Array(32).fill(0);\n  arr[0] = 1; // byte[0]=1 (odd) → TAILS\n  return arr;\n})();\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getMatchPda(creator: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlatformConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlayerProfilePda(wallet: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Bankrun context factory — fresh state per test\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\n// Real VRF constants — match ephemeral-vrf-sdk consts.rs\nconst VRF_PROGRAM_ADDRESS = new PublicKey(\"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\");\nconst VRF_DEFAULT_QUEUE = new PublicKey(\"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\");\n\n// Derive program_identity PDA: seeds=[b\"identity\"], program=coinflip\nconst [PROGRAM_IDENTITY_PDA] = PublicKey.findProgramAddressSync(\n  [Buffer.from(\"identity\")],\n  PROGRAM_ID\n);\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  opponent: Keypair;\n  oracle: Keypair;\n  treasury: Keypair;\n  creatorProgram: Program<Coinflip>;\n  opponentProgram: Program<Coinflip>;\n  oracleProgram: Program<Coinflip>;\n  platformProgram: Program<Platform>;\n  opponentPlatformProgram: Program<Platform>;\n  configPda: PublicKey;\n  matchPda: PublicKey;\n  platformConfigPda: PublicKey;\n  creatorProfilePda: PublicKey;\n  opponentProfilePda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const opponent = Keypair.generate();\n  const oracle = Keypair.generate();\n  const treasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: opponent.publicKey, info: fundedAccountData() },\n    { address: oracle.publicKey, info: fundedAccountData() },\n    { address: treasury.publicKey, info: fundedAccountData() },\n    // Mock VRF accounts at real addresses so #[vrf] macro constraints pass\n    { address: VRF_DEFAULT_QUEUE, info: fundedAccountData(LAMPORTS_PER_SOL) },\n    { address: PROGRAM_IDENTITY_PDA, info: fundedAccountData(LAMPORTS_PER_SOL) },\n  ]);\n\n  // Load a dummy program at the VRF program address.\n  // Anchor's Program<> type checks executable=true + matching address.\n  // Reuse the coinflip .so as a no-op stand-in (we never CPI into it in mock mode).\n  context.setAccount(VRF_PROGRAM_ADDRESS, {\n    lamports: LAMPORTS_PER_SOL,\n    data: readFileSync(join(__dirname, \"..\", \"target\", \"deploy\", \"coinflip.so\")),\n    owner: new PublicKey(\"BPFLoader2111111111111111111111111111111111\"),\n    executable: true,\n  });\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n\n  const opponentProvider = new BankrunProvider(\n    context,\n    new Wallet(opponent)\n  );\n  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n\n  const oracleProvider = new BankrunProvider(context, new Wallet(oracle));\n  const oracleProgram = new Program<Coinflip>(IDL, oracleProvider);\n\n  // Platform program instances\n  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n  const opponentPlatformProgram = new Program<Platform>(PLATFORM_IDL, opponentProvider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n  const matchPda = getMatchPda(creator);\n  const platformConfigPda = getPlatformConfigPda();\n  const creatorProfilePda = getPlayerProfilePda(creator);\n  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n\n  return {\n    context,\n    creator,\n    opponent,\n    oracle,\n    treasury,\n    creatorProgram,\n    opponentProgram,\n    oracleProgram,\n    platformProgram,\n    opponentPlatformProgram,\n    configPda,\n    matchPda,\n    platformConfigPda,\n    creatorProfilePda,\n    opponentProfilePda,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Helpers — call instructions\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.oracle.publicKey, t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function initPlatform(t: TestContext) {\n  await t.platformProgram.methods\n    .initializePlatform(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.platformConfigPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createPlayerProfile(t: TestContext, program: Program<Platform>, player: PublicKey) {\n  const profilePda = getPlayerProfilePda(player);\n  await program.methods\n    .createPlayerProfile()\n    .accounts({\n      player,\n      profile: profilePda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function setupPlatform(t: TestContext) {\n  await initPlatform(t);\n  await createPlayerProfile(t, t.platformProgram, t.creator);\n  await createPlayerProfile(t, t.opponentPlatformProgram, t.opponent.publicKey);\n}\n\nasync function createMatch(\n  t: TestContext,\n  tier = TIER_IRON,\n  side = SIDE_HEADS\n) {\n  await t.creatorProgram.methods\n    .createMatch(tier, side)\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function joinMatch(t: TestContext) {\n  await t.opponentProgram.methods\n    .joinMatch()\n    .accounts({\n      opponent: t.opponent.publicKey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      oracleQueue: VRF_DEFAULT_QUEUE,\n      programIdentity: PROGRAM_IDENTITY_PDA,\n      vrfProgram: VRF_PROGRAM_ADDRESS,\n      slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function resolveMatch(t: TestContext, randomness: number[]) {\n  await t.oracleProgram.methods\n    .resolveMatch(randomness)\n    .accounts({\n      oracle: t.oracle.publicKey,\n      config: t.configPda,\n      coinflipMatch: t.matchPda,\n    })\n    .rpc();\n}\n\nasync function claimPayout(t: TestContext, winnerProgram: Program<Coinflip>, winnerPubkey: PublicKey) {\n  await winnerProgram.methods\n    .claimPayout()\n    .accounts({\n      winner: winnerPubkey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      treasury: t.treasury.publicKey,\n      creator: t.creator,\n      creatorProfile: t.creatorProfilePda,\n      opponentProfile: t.opponentProfilePda,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function cancelMatch(t: TestContext) {\n  await t.creatorProgram.methods\n    .cancelMatch()\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n  const account = await t.context.banksClient.getAccount(pubkey);\n  return account ? Number(account.lamports) : 0;\n}\n\n// ===========================================================================\n// Tests\n// ===========================================================================\ndescribe(\"coinflip\", () => {\n  // -------------------------------------------------------------------------\n  // initialize_config\n  // -------------------------------------------------------------------------\n  describe(\"initialize_config\", () => {\n    it(\"creates config with oracle and treasury\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.coinflipConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.oracleAuthority.toBase58()).to.equal(\n        t.oracle.publicKey.toBase58()\n      );\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // create_match\n  // -------------------------------------------------------------------------\n  describe(\"create_match\", () => {\n    it(\"creates a coinflip match\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(match.opponent.toBase58()).to.equal(\n        PublicKey.default.toBase58()\n      );\n      expect(match.tier).to.equal(TIER_IRON);\n      expect(match.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(match.creatorSide).to.equal(SIDE_HEADS);\n      expect(match.phase).to.equal(PHASE_WAITING);\n      expect(match.result).to.equal(0);\n      expect(match.winner.toBase58()).to.equal(PublicKey.default.toBase58());\n      expect(match.claimed).to.equal(false);\n    });\n\n    it(\"rejects invalid side\", async () => {\n      const t = await createTestContext();\n\n      try {\n        await t.creatorProgram.methods\n          .createMatch(TIER_IRON, 3)\n          .accounts({\n            creator: t.creator,\n            coinflipMatch: t.matchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidSide error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidSide\");\n        expect(anchorErr.error.errorCode.number).to.equal(6100);\n      }\n    });\n\n    it(\"rejects invalid tier\", async () => {\n      const t = await createTestContext();\n\n      try {\n        await t.creatorProgram.methods\n          .createMatch(99, SIDE_HEADS)\n          .accounts({\n            creator: t.creator,\n            coinflipMatch: t.matchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidTier\");\n        expect(anchorErr.error.errorCode.number).to.equal(6101);\n      }\n    });\n\n    it(\"escrows correct lamport amount\", async () => {\n      const t = await createTestContext();\n      const balanceBefore = await getBalance(t, t.creator);\n\n      await createMatch(t);\n\n      const matchBalance = await getBalance(t, t.matchPda);\n      // Match PDA holds escrow + rent-exempt minimum\n      const matchAccount = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      const rentLamports =\n        matchBalance - matchAccount.entryAmount.toNumber();\n      expect(rentLamports).to.be.greaterThan(0);\n      expect(matchAccount.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n\n      const balanceAfter = await getBalance(t, t.creator);\n      // Creator paid entry_amount + rent + transaction fee\n      const spent = balanceBefore - balanceAfter;\n      expect(spent).to.be.greaterThanOrEqual(matchBalance);\n      // Transaction fee is 5000 lamports\n      expect(spent - matchBalance).to.equal(5000);\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // join_match\n  // -------------------------------------------------------------------------\n  describe(\"join_match\", () => {\n    it(\"opponent joins, phase transitions to LOCKED, escrow doubled\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      const balanceBefore = await getBalance(t, t.matchPda);\n      await joinMatch(t);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.opponent.toBase58()).to.equal(\n        t.opponent.publicKey.toBase58()\n      );\n      expect(match.phase).to.equal(PHASE_LOCKED);\n\n      const balanceAfter = await getBalance(t, t.matchPda);\n      // Escrow should have doubled (both players deposited entry_amount)\n      expect(balanceAfter - balanceBefore).to.equal(TIER_IRON_AMOUNT);\n    });\n\n    it(\"rejects creator joining own match\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      try {\n        // Creator tries to join as opponent\n        await t.creatorProgram.methods\n          .joinMatch()\n          .accounts({\n            opponent: t.creator,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            oracleQueue: VRF_DEFAULT_QUEUE,\n            programIdentity: PROGRAM_IDENTITY_PDA,\n            vrfProgram: VRF_PROGRAM_ADDRESS,\n            slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected CannotJoinOwnMatch error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"CannotJoinOwnMatch\");\n        expect(anchorErr.error.errorCode.number).to.equal(6104);\n      }\n    });\n\n    it(\"rejects if not in WAITING phase\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t); // phase → LOCKED (once implemented)\n\n      try {\n        // Second opponent tries to join — fund them so tx doesn't fail pre-program\n        const secondOpponent = Keypair.generate();\n        t.context.setAccount(secondOpponent.publicKey, fundedAccountData());\n        const secondProvider = new BankrunProvider(\n          t.context,\n          new Wallet(secondOpponent)\n        );\n        const secondProgram = new Program<Coinflip>(IDL, secondProvider);\n\n        await secondProgram.methods\n          .joinMatch()\n          .accounts({\n            opponent: secondOpponent.publicKey,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            oracleQueue: VRF_DEFAULT_QUEUE,\n            programIdentity: PROGRAM_IDENTITY_PDA,\n            vrfProgram: VRF_PROGRAM_ADDRESS,\n            slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // resolve_match\n  // -------------------------------------------------------------------------\n  describe(\"resolve_match\", () => {\n    it(\"HEADS when randomness[0] is even — creator wins if chose HEADS\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.result).to.equal(SIDE_HEADS);\n      expect(match.winner.toBase58()).to.equal(t.creator.toBase58());\n    });\n\n    it(\"TAILS when randomness[0] is odd — opponent wins if creator chose HEADS\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_TAILS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.result).to.equal(SIDE_TAILS);\n      expect(match.winner.toBase58()).to.equal(\n        t.opponent.publicKey.toBase58()\n      );\n    });\n\n    it(\"phase transitions to SETTLED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_SETTLED);\n    });\n\n    it(\"rejects unauthorized oracle\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      try {\n        // Creator (not oracle) tries to resolve\n        await t.creatorProgram.methods\n          .resolveMatch(RANDOMNESS_HEADS)\n          .accounts({\n            oracle: t.creator,\n            config: t.configPda,\n            coinflipMatch: t.matchPda,\n          })\n          .rpc();\n        expect.fail(\"Expected UnauthorizedOracle error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"UnauthorizedOracle\");\n        expect(anchorErr.error.errorCode.number).to.equal(6105);\n      }\n    });\n\n    it(\"rejects if not in LOCKED phase\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      // Skip join — match is still WAITING\n\n      try {\n        await resolveMatch(t, RANDOMNESS_HEADS);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // claim_payout\n  // -------------------------------------------------------------------------\n  describe(\"claim_payout\", () => {\n    it(\"winner gets pool minus fee, treasury gets fee\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS); // creator wins\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const winnerBefore = await getBalance(t, t.creator);\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const winnerAfter = await getBalance(t, t.creator);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      // Winner receives payout (plus rent refund from closed account)\n      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n      // Treasury receives fee\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n    });\n\n    it(\"match account closed, rent refunded to creator\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      // Match account should no longer exist\n      const matchAccount =\n        await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects double claim\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS);\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      try {\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected AlreadyClaimed error\");\n      } catch (err) {\n        // Account is closed so this should fail (either AlreadyClaimed or account not found)\n        expect(err).to.exist;\n      }\n    });\n\n    it(\"rejects claim by loser\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_TAILS); // opponent wins\n\n      try {\n        // Creator (loser) tries to claim\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected NotWinner error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"NotWinner\");\n        expect(anchorErr.error.errorCode.number).to.equal(6107);\n      }\n    });\n\n    it(\"rejects if not SETTLED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      // Skip join + resolve — match is WAITING\n\n      try {\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n\n    it(\"updates player profiles via CPI — creator wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS); // creator wins\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Creator (winner) profile\n      const creatorProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(creatorProfile.totalGames.toNumber()).to.equal(1);\n      expect(creatorProfile.wins.toNumber()).to.equal(1);\n      expect(creatorProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(creatorProfile.totalWon.toNumber()).to.equal(payout);\n\n      // Opponent (loser) profile\n      const opponentProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(opponentProfile.totalGames.toNumber()).to.equal(1);\n      expect(opponentProfile.wins.toNumber()).to.equal(0);\n      expect(opponentProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(opponentProfile.totalWon.toNumber()).to.equal(0);\n    });\n\n    it(\"updates player profiles via CPI — opponent wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_TAILS); // opponent wins\n\n      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Creator (loser) profile\n      const creatorProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(creatorProfile.totalGames.toNumber()).to.equal(1);\n      expect(creatorProfile.wins.toNumber()).to.equal(0);\n      expect(creatorProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(creatorProfile.totalWon.toNumber()).to.equal(0);\n\n      // Opponent (winner) profile\n      const opponentProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(opponentProfile.totalGames.toNumber()).to.equal(1);\n      expect(opponentProfile.wins.toNumber()).to.equal(1);\n      expect(opponentProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(opponentProfile.totalWon.toNumber()).to.equal(payout);\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // cancel_match\n  // -------------------------------------------------------------------------\n  describe(\"cancel_match\", () => {\n    it(\"creator cancels WAITING match, full refund\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      const balanceBefore = await getBalance(t, t.creator);\n\n      await cancelMatch(t);\n\n      const balanceAfter = await getBalance(t, t.creator);\n      // Creator gets back entry_amount + rent\n      expect(balanceAfter - balanceBefore).to.be.greaterThanOrEqual(\n        TIER_IRON_AMOUNT\n      );\n\n      // Match account should be closed\n      const matchAccount =\n        await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects cancel after LOCKED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t); // phase → LOCKED (once implemented)\n\n      try {\n        await cancelMatch(t);\n        expect.fail(\"Expected CannotCancel error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"CannotCancel\");\n        expect(anchorErr.error.errorCode.number).to.equal(6108);\n      }\n    });\n\n    it(\"rejects cancel by non-creator\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      // Opponent tries to cancel creator's match\n      // The PDA seeds [b\"match\", creator.key()] won't match opponent's key\n      // so this should fail with a constraint error\n      const opponentMatchPda = getMatchPda(t.opponent.publicKey);\n\n      try {\n        await t.opponentProgram.methods\n          .cancelMatch()\n          .accounts({\n            creator: t.opponent.publicKey,\n            coinflipMatch: opponentMatchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected constraint error\");\n      } catch (err) {\n        // PDA [b\"match\", opponent_key] doesn't exist → AccountNotInitialized\n        expect(err).to.exist;\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // full lifecycle\n  // -------------------------------------------------------------------------\n  describe(\"full lifecycle\", () => {\n    it(\"create → join → resolve(HEADS) → claim\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n\n      // 1. Create\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      let match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_WAITING);\n\n      // 2. Join\n      await joinMatch(t);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.phase).to.equal(PHASE_LOCKED);\n\n      // 3. Resolve — HEADS → creator wins\n      await resolveMatch(t, RANDOMNESS_HEADS);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.phase).to.equal(PHASE_SETTLED);\n      expect(match.winner.toBase58()).to.equal(t.creator.toBase58());\n\n      // 4. Claim\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n      await claimPayout(t, t.creatorProgram, t.creator);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n\n      // Match account closed\n      const closed = await t.context.banksClient.getAccount(t.matchPda);\n      expect(closed).to.be.null;\n    });\n\n    it(\"create → cancel → create again\", async () => {\n      const t = await createTestContext();\n\n      // 1. Create\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      let match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_WAITING);\n\n      // 2. Cancel\n      await cancelMatch(t);\n      const closed = await t.context.banksClient.getAccount(t.matchPda);\n      expect(closed).to.be.null;\n\n      // 3. Create again (same PDA slot is free)\n      await createMatch(t, TIER_IRON, SIDE_TAILS);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.creatorSide).to.equal(SIDE_TAILS);\n      expect(match.phase).to.equal(PHASE_WAITING);\n    });\n  });\n});\n"}}
