{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LwYrqnggC7QF8vADmCdkjR","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Lifecycle phase for every round/match in any game.\n     4→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\n     5→pub enum RoundPhase {\n     6→    Waiting,\n     7→    Active,\n     8→    Locked,\n     9→    Resolving,\n    10→    Settled,\n    11→    Refunded,\n    12→}\n    13→\n    14→/// Timestamps tracking round progression.\n    15→#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug)]\n    16→pub struct RoundTimestamps {\n    17→    pub created_at: i64,\n    18→    pub locked_at: Option<i64>,\n    19→    pub resolve_deadline: Option<i64>,\n    20→    pub settled_at: Option<i64>,\n    21→}\n    22→\n    23→#[error_code]\n    24→pub enum LifecycleError {\n    25→    #[msg(\"Invalid phase transition\")]\n    26→    InvalidTransition,\n    27→}\n    28→\n    29→/// Validates that the transition from `current` to `target` is allowed.\n    30→///\n    31→/// Allowed transitions:\n    32→/// - Waiting → Active, Locked, Refunded\n    33→/// - Active → Locked, Refunded\n    34→/// - Locked → Resolving, Refunded\n    35→/// - Resolving → Settled, Refunded\n    36→///\n    37→/// LOCKED → SETTLED is explicitly disallowed; VRF games read the result\n    38→/// at claim time and set the phase directly.\n    39→pub fn transition(current: RoundPhase, target: RoundPhase) -> Result<()> {\n    40→    let valid = matches!(\n    41→        (current, target),\n    42→        (RoundPhase::Waiting, RoundPhase::Active)\n    43→            | (RoundPhase::Waiting, RoundPhase::Locked)\n    44→            | (RoundPhase::Active, RoundPhase::Locked)\n    45→            | (RoundPhase::Locked, RoundPhase::Resolving)\n    46→            | (RoundPhase::Resolving, RoundPhase::Settled)\n    47→            | (RoundPhase::Resolving, RoundPhase::Refunded)\n    48→            | (RoundPhase::Waiting, RoundPhase::Refunded)\n    49→            | (RoundPhase::Active, RoundPhase::Refunded)\n    50→            | (RoundPhase::Locked, RoundPhase::Refunded)\n    51→    );\n    52→\n    53→    if valid {\n    54→        Ok(())\n    55→    } else {\n    56→        Err(LifecycleError::InvalidTransition.into())\n    57→    }\n    58→}\n    59→\n    60→#[cfg(test)]\n    61→mod tests {\n    62→    use super::*;\n    63→\n    64→    #[test]\n    65→    fn valid_transitions() {\n    66→        assert!(transition(RoundPhase::Waiting, RoundPhase::Active).is_ok());\n    67→        assert!(transition(RoundPhase::Waiting, RoundPhase::Locked).is_ok());\n    68→        assert!(transition(RoundPhase::Active, RoundPhase::Locked).is_ok());\n    69→        assert!(transition(RoundPhase::Locked, RoundPhase::Resolving).is_ok());\n    70→        assert!(transition(RoundPhase::Resolving, RoundPhase::Settled).is_ok());\n    71→        assert!(transition(RoundPhase::Resolving, RoundPhase::Refunded).is_ok());\n    72→        assert!(transition(RoundPhase::Waiting, RoundPhase::Refunded).is_ok());\n    73→        assert!(transition(RoundPhase::Active, RoundPhase::Refunded).is_ok());\n    74→        assert!(transition(RoundPhase::Locked, RoundPhase::Refunded).is_ok());\n    75→    }\n    76→\n    77→    #[test]\n    78→    fn invalid_transitions() {\n    79→        // Self-transitions\n    80→        assert!(transition(RoundPhase::Waiting, RoundPhase::Waiting).is_err());\n    81→        assert!(transition(RoundPhase::Locked, RoundPhase::Locked).is_err());\n    82→\n    83→        // Backward transitions\n    84→        assert!(transition(RoundPhase::Active, RoundPhase::Waiting).is_err());\n    85→        assert!(transition(RoundPhase::Locked, RoundPhase::Waiting).is_err());\n    86→        assert!(transition(RoundPhase::Settled, RoundPhase::Waiting).is_err());\n    87→\n    88→        // LOCKED → SETTLED explicitly invalid (VRF games use claim, not transition)\n    89→        assert!(transition(RoundPhase::Locked, RoundPhase::Settled).is_err());\n    90→\n    91→        // Terminal states cannot transition\n    92→        assert!(transition(RoundPhase::Settled, RoundPhase::Refunded).is_err());\n    93→        assert!(transition(RoundPhase::Refunded, RoundPhase::Settled).is_err());\n    94→\n    95→        // Skip transitions\n    96→        assert!(transition(RoundPhase::Waiting, RoundPhase::Settled).is_err());\n    97→        assert!(transition(RoundPhase::Waiting, RoundPhase::Resolving).is_err());\n    98→    }\n    99→\n   100→    #[test]\n   101→    fn enum_serialization_roundtrip() {\n   102→        let phases = [\n   103→            RoundPhase::Waiting,\n   104→            RoundPhase::Active,\n   105→            RoundPhase::Locked,\n   106→            RoundPhase::Resolving,\n   107→            RoundPhase::Settled,\n   108→            RoundPhase::Refunded,\n   109→        ];\n   110→\n   111→        for phase in phases {\n   112→            let mut buf = Vec::new();\n   113→            AnchorSerialize::serialize(&phase, &mut buf).unwrap();\n   114→            let deserialized = RoundPhase::deserialize(&mut buf.as_slice()).unwrap();\n   115→            assert_eq!(phase, deserialized);\n   116→        }\n   117→    }\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_01PPSdpFi1tB1FR2YN46e36N","session_id":"26c7f4cc-b2b2-41aa-85e9-beee2a3d95f1","uuid":"bf3aa719-01de-473b-b09e-72e7a42ebee6"}
