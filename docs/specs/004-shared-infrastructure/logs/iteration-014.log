Program<Coinflip>(IDL, provider);\n    const creator = provider.wallet.publicKey;\n    const configPda = getConfigPda();\n    const matchPda = getMatchPda(creator);\n\n    // Initialize config\n    await program.methods\n      .initializeConfig(treasury.publicKey)\n      .accounts({\n        authority: creator,\n        config: configPda,\n        systemProgram: SystemProgram.programId,\n      })\n      .rpc();\n\n    const config = await program.account.coinflipConfig.fetch(configPda);\n    expect(config.paused).to.equal(false);\n    console.log(\"Config initialized OK\");\n\n    // Create match\n    await program.methods\n      .createMatch(0, 0) // tier 0, side HEADS\n      .accounts({\n        creator,\n        coinflipMatch: matchPda,\n        config: configPda,\n        systemProgram: SystemProgram.programId,\n      })\n      .rpc();\n\n    const m = await program.account.coinflipMatch.fetch(matchPda);\n    console.log(\"Match phase:\", JSON.stringify(m.phase));\n    expect(m.entryAmount.toNumber()).to.equal(5_000_000);\n  });\n});\nTESTEOF\ntimeout 60 npx mocha -t 60000 --bail tests/minimal.ts 2>&1 | head -30 || true\nrm tests/minimal.ts","description":"Test config + create_match","timeout":120000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":739,"cache_read_input_tokens":138434,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":739},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"26c7f4cc-b2b2-41aa-85e9-beee2a3d95f1","uuid":"c8ca5120-5edc-4ccd-a086-7d9a375ff778"}
