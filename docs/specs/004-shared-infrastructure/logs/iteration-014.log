{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PPSdpFi1tB1FR2YN46e36N","type":"tool_result","content":[{"type":"text","text":"## Complete Contents of Shared Library Files\n\nHere are all the requested files from `/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/`:\n\n### 1. **lib.rs**\n```rust\npub mod commit_reveal;\npub mod constants;\npub mod cpi;\npub mod escrow;\npub mod fees;\npub mod lifecycle;\npub mod pause;\npub mod tiers;\npub mod timeout;\npub mod vrf_orao;\n```\n\n### 2. **constants.rs**\n```rust\n/// Coin sides\npub const SIDE_HEADS: u8 = 0;\npub const SIDE_TAILS: u8 = 1;\n\n/// Match phases\npub const PHASE_WAITING: u8 = 0;   // Creator placed bet, waiting for opponent\npub const PHASE_LOCKED: u8 = 1;    // Both players in, requesting VRF\npub const PHASE_SETTLED: u8 = 2;   // VRF resolved, winner determined\npub const PHASE_CANCELLED: u8 = 3; // Creator cancelled before opponent joined\n\n/// Timeout (in seconds) after which a LOCKED match can be cancelled.\npub const LOCK_TIMEOUT_SECONDS: i64 = 120; // 2 minutes\n\n/// Derive a coin side (0 or 1) from a randomness byte.\npub fn from_randomness(byte: u8) -> u8 {\n    byte % 2\n}\n\n/// Returns true if the given value is a valid side (HEADS or TAILS).\npub fn is_valid_side(side: u8) -> bool {\n    side == SIDE_HEADS || side == SIDE_TAILS\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_from_randomness() {\n        assert_eq!(from_randomness(0), SIDE_HEADS);\n        assert_eq!(from_randomness(1), SIDE_TAILS);\n        assert_eq!(from_randomness(2), SIDE_HEADS);\n        assert_eq!(from_randomness(255), SIDE_TAILS);\n    }\n\n    #[test]\n    fn test_is_valid_side() {\n        assert!(is_valid_side(SIDE_HEADS));\n        assert!(is_valid_side(SIDE_TAILS));\n        assert!(!is_valid_side(2));\n        assert!(!is_valid_side(255));\n    }\n}\n```\n\n### 3. **fees.rs**\n```rust\n/// Compile-time safety cap: no fee can ever exceed 10% (1000 bps).\npub const MAX_FEE_BPS: u16 = 1000;\n\n/// Total platform fee: 3% (300 basis points)\n/// - 200 bps: platform revenue\n/// - 70 bps: rakeback pool (raid boss rewards)\n/// - 30 bps: chest treasury\npub const TOTAL_FEE_BPS: u16 = 300;\npub const REVENUE_BPS: u16 = 200;\npub const RAKEBACK_BPS: u16 = 70;\npub const CHEST_BPS: u16 = 30;\n\n// Compile-time assertion: fee must never exceed safety cap.\nconst _: () = assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n\n/// Calculate the total fee for a given amount.\n/// Returns the fee in lamports.\npub fn calculate_fee(amount: u64) -> u64 {\n    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n}\n\n/// Calculate fee and net payout for a given pool amount.\n/// Returns `(fee, net_payout)` where `net_payout = pool - fee`.\n/// Fee rounds down (integer division truncates), favoring the player.\npub fn calculate_net_payout(pool: u64) -> (u64, u64) {\n    let fee = calculate_fee(pool);\n    (fee, pool - fee)\n}\n\n/// Split a fee amount into (revenue, rakeback, chest).\npub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    (revenue, rakeback, chest)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_calculate_fee() {\n        assert_eq!(calculate_fee(10_000), 300);\n        assert_eq!(calculate_fee(1_000_000), 30_000);\n        assert_eq!(calculate_fee(0), 0);\n    }\n\n    #[test]\n    fn test_calculate_net_payout() {\n        let (fee, net) = calculate_net_payout(1_000_000);\n        assert_eq!(fee, 30_000);\n        assert_eq!(net, 970_000);\n        assert_eq!(fee + net, 1_000_000);\n\n        // Zero pool\n        let (fee, net) = calculate_net_payout(0);\n        assert_eq!(fee, 0);\n        assert_eq!(net, 0);\n\n        // Small amount where rounding truncates (favors player)\n        // 100 lamports * 300 / 10000 = 3.0 exactly\n        let (fee, net) = calculate_net_payout(100);\n        assert_eq!(fee, 3);\n        assert_eq!(net, 97);\n\n        // Non-round amount: 1 lamport → fee rounds to 0\n        let (fee, net) = calculate_net_payout(1);\n        assert_eq!(fee, 0);\n        assert_eq!(net, 1);\n    }\n\n    #[test]\n    fn test_max_fee_bps_cap() {\n        assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n    }\n\n    #[test]\n    fn test_split_fee() {\n        let (rev, rake, chest) = split_fee(300);\n        assert_eq!(rev, 200);\n        assert_eq!(rake, 70);\n        assert_eq!(chest, 30);\n        assert_eq!(rev + rake + chest, 300);\n    }\n}\n```\n\n### 4. **lifecycle.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n/// Lifecycle phase for every round/match in any game.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\npub enum RoundPhase {\n    Waiting,\n    Active,\n    Locked,\n    Resolving,\n    Settled,\n    Refunded,\n}\n\n/// Timestamps tracking round progression.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug)]\npub struct RoundTimestamps {\n    pub created_at: i64,\n    pub locked_at: Option<i64>,\n    pub resolve_deadline: Option<i64>,\n    pub settled_at: Option<i64>,\n}\n\n#[error_code]\npub enum LifecycleError {\n    #[msg(\"Invalid phase transition\")]\n    InvalidTransition,\n}\n\n/// Validates that the transition from `current` to `target` is allowed.\n///\n/// Allowed transitions:\n/// - Waiting → Active, Locked, Refunded\n/// - Active → Locked, Refunded\n/// - Locked → Resolving, Refunded\n/// - Resolving → Settled, Refunded\n///\n/// LOCKED → SETTLED is explicitly disallowed; VRF games read the result\n/// at claim time and set the phase directly.\npub fn transition(current: RoundPhase, target: RoundPhase) -> Result<()> {\n    let valid = matches!(\n        (current, target),\n        (RoundPhase::Waiting, RoundPhase::Active)\n            | (RoundPhase::Waiting, RoundPhase::Locked)\n            | (RoundPhase::Active, RoundPhase::Locked)\n            | (RoundPhase::Locked, RoundPhase::Resolving)\n            | (RoundPhase::Resolving, RoundPhase::Settled)\n            | (RoundPhase::Resolving, RoundPhase::Refunded)\n            | (RoundPhase::Waiting, RoundPhase::Refunded)\n            | (RoundPhase::Active, RoundPhase::Refunded)\n            | (RoundPhase::Locked, RoundPhase::Refunded)\n    );\n\n    if valid {\n        Ok(())\n    } else {\n        Err(LifecycleError::InvalidTransition.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn valid_transitions() {\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Active).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Resolving).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Settled).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Refunded).is_ok());\n    }\n\n    #[test]\n    fn invalid_transitions() {\n        // Self-transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Locked).is_err());\n\n        // Backward transitions\n        assert!(transition(RoundPhase::Active, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Settled, RoundPhase::Waiting).is_err());\n\n        // LOCKED → SETTLED explicitly invalid (VRF games use claim, not transition)\n        assert!(transition(RoundPhase::Locked, RoundPhase::Settled).is_err());\n\n        // Terminal states cannot transition\n        assert!(transition(RoundPhase::Settled, RoundPhase::Refunded).is_err());\n        assert!(transition(RoundPhase::Refunded, RoundPhase::Settled).is_err());\n\n        // Skip transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Settled).is_err());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Resolving).is_err());\n    }\n\n    #[test]\n    fn enum_serialization_roundtrip() {\n        let phases = [\n            RoundPhase::Waiting,\n            RoundPhase::Active,\n            RoundPhase::Locked,\n            RoundPhase::Resolving,\n            RoundPhase::Settled,\n            RoundPhase::Refunded,\n        ];\n\n        for phase in phases {\n            let mut buf = Vec::new();\n            AnchorSerialize::serialize(&phase, &mut buf).unwrap();\n            let deserialized = RoundPhase::deserialize(&mut buf.as_slice()).unwrap();\n            assert_eq!(phase, deserialized);\n        }\n    }\n}\n```\n\n### 5. **timeout.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n/// Default timeout (seconds) after which a LOCKED/RESOLVING round can be refunded.\npub const DEFAULT_RESOLVE_TIMEOUT_SECONDS: i64 = 120;\n\n#[error_code]\npub enum TimeoutError {\n    #[msg(\"Resolve deadline has been exceeded\")]\n    ResolveDeadlineExceeded,\n}\n\n/// Returns `true` when the current time is at or past the resolve deadline.\npub fn is_expired(resolve_deadline: i64, now: i64) -> bool {\n    now >= resolve_deadline\n}\n\n/// Returns `Ok(())` if the deadline has NOT been exceeded, or an error if it has.\npub fn enforce_not_expired(resolve_deadline: i64, now: i64) -> Result<()> {\n    if is_expired(resolve_deadline, now) {\n        Err(TimeoutError::ResolveDeadlineExceeded.into())\n    } else {\n        Ok(())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn expired_exactly_at_deadline() {\n        assert!(is_expired(1000, 1000));\n    }\n\n    #[test]\n    fn not_expired_one_second_before() {\n        assert!(!is_expired(1000, 999));\n    }\n\n    #[test]\n    fn expired_one_second_after() {\n        assert!(is_expired(1000, 1001));\n    }\n\n    #[test]\n    fn enforce_not_expired_ok_before_deadline() {\n        assert!(enforce_not_expired(1000, 999).is_ok());\n    }\n\n    #[test]\n    fn enforce_not_expired_fails_at_deadline() {\n        assert!(enforce_not_expired(1000, 1000).is_err());\n    }\n\n    #[test]\n    fn enforce_not_expired_fails_after_deadline() {\n        assert!(enforce_not_expired(1000, 1001).is_err());\n    }\n}\n```\n\n### 6. **vrf_orao.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n/// Audit fields stored on match/round accounts for VRF traceability.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, InitSpace)]\npub struct VrfAuditFields {\n    /// Address of the Orao randomness PDA for this match/round.\n    pub vrf_request_key: Pubkey,\n    /// Unix timestamp when VRF was requested.\n    pub vrf_requested_at: i64,\n}\n\n/// Error codes for VRF operations.\n#[error_code]\npub enum VrfError {\n    /// Randomness has not been fulfilled by the VRF oracle.\n    #[msg(\"VRF randomness not yet fulfilled\")]\n    RandomnessNotFulfilled,\n}\n\n/// Returns true if the 32-byte randomness is non-zero (i.e., fulfilled).\npub fn is_fulfilled(randomness: &[u8; 32]) -> bool {\n    randomness.iter().any(|&b| b != 0)\n}\n\n// ---------------------------------------------------------------------------\n// Real Orao mode — CPI into Orao VRF program\n// ---------------------------------------------------------------------------\n\n/// CPI into Orao VRF to request randomness.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn request_orao_randomness<'info>(\n    orao_program: &AccountInfo<'info>,\n    network_state: &AccountInfo<'info>,\n    treasury: &AccountInfo<'info>,\n    random: &AccountInfo<'info>,\n    payer: &AccountInfo<'info>,\n    system_program: &AccountInfo<'info>,\n    seed: [u8; 32],\n) -> Result<()> {\n    let cpi_accounts = orao_solana_vrf::cpi::accounts::RequestV2 {\n        payer: payer.clone(),\n        network_state: network_state.clone(),\n        treasury: treasury.clone(),\n        request: random.clone(),\n        system_program: system_program.clone(),\n    };\n    let cpi_ctx = CpiContext::new(orao_program.clone(), cpi_accounts);\n    orao_solana_vrf::cpi::request_v2(cpi_ctx, seed)\n}\n\n/// Read fulfilled randomness from an Orao randomness account.\n///\n/// Deserializes the Orao `RandomnessAccountData` (supports both V1 and V2\n/// accounts) and returns the first 32 bytes of the 64-byte randomness.\n/// Returns an error if randomness has not been fulfilled yet.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    use anchor_lang::AccountDeserialize;\n\n    let data = randomness_account.try_borrow_data()?;\n    let mut buf: &[u8] = &data;\n    let account_data =\n        orao_solana_vrf::state::RandomnessAccountData::try_deserialize_unchecked(&mut buf)?;\n\n    match account_data.fulfilled_randomness() {\n        Some(randomness_64) => {\n            let mut result = [0u8; 32];\n            result.copy_from_slice(&randomness_64[..32]);\n            Ok(result)\n        }\n        None => Err(error!(VrfError::RandomnessNotFulfilled)),\n    }\n}\n\n// ---------------------------------------------------------------------------\n// Mock VRF mode — no Orao CPI, reads raw bytes from test account\n// ---------------------------------------------------------------------------\n\n/// No-op in mock mode. Test authority writes mock randomness directly.\n#[cfg(feature = \"mock-vrf\")]\npub fn request_orao_randomness<'info>(\n    _orao_program: &AccountInfo<'info>,\n    _network_state: &AccountInfo<'info>,\n    _treasury: &AccountInfo<'info>,\n    _random: &AccountInfo<'info>,\n    _payer: &AccountInfo<'info>,\n    _system_program: &AccountInfo<'info>,\n    _seed: [u8; 32],\n) -> Result<()> {\n    Ok(())\n}\n\n/// In mock mode, reads raw 32 bytes from account data as randomness.\n/// All-zeros = unfulfilled (returns error).\n#[cfg(feature = \"mock-vrf\")]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    let data = randomness_account.try_borrow_data()?;\n    require!(data.len() >= 32, VrfError::RandomnessNotFulfilled);\n\n    let mut randomness = [0u8; 32];\n    randomness.copy_from_slice(&data[..32]);\n\n    require!(is_fulfilled(&randomness), VrfError::RandomnessNotFulfilled);\n    Ok(randomness)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_is_fulfilled_all_zeros() {\n        let zeros = [0u8; 32];\n        assert!(!is_fulfilled(&zeros));\n    }\n\n    #[test]\n    fn test_is_fulfilled_non_zero() {\n        let mut data = [0u8; 32];\n        data[0] = 1;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_is_fulfilled_all_ones() {\n        let ones = [0xFF; 32];\n        assert!(is_fulfilled(&ones));\n    }\n\n    #[test]\n    fn test_is_fulfilled_single_byte_set() {\n        let mut data = [0u8; 32];\n        data[31] = 42;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_vrf_audit_fields_size() {\n        // Pubkey (32) + i64 (8) = 40 bytes\n        assert_eq!(<VrfAuditFields as anchor_lang::Space>::INIT_SPACE, 40);\n    }\n}\n```\n\n### 7. **escrow.rs**\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::system_program;\n\n/// Error codes for escrow operations.\n#[error_code]\npub enum EscrowError {\n    /// The escrow PDA does not hold enough lamports for the requested transfer.\n    #[msg(\"Insufficient escrow balance\")]\n    InsufficientEscrowBalance,\n}\n\n/// Transfers lamports from a PDA to a recipient using direct lamport manipulation.\n///\n/// This is the standard pattern for moving funds out of a program-owned PDA\n/// (e.g., paying out a winner, refunding a player, sending fees to treasury).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_from_pda(\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     &ctx.accounts.winner.to_account_info(),\n///     payout_amount,\n/// )?;\n/// ```\npub fn transfer_lamports_from_pda(\n    pda: &AccountInfo,\n    recipient: &AccountInfo,\n    amount: u64,\n) -> Result<()> {\n    let pda_balance = pda.lamports();\n    require!(pda_balance >= amount, EscrowError::InsufficientEscrowBalance);\n\n    **pda.try_borrow_mut_lamports()? -= amount;\n    **recipient.try_borrow_mut_lamports()? += amount;\n\n    Ok(())\n}\n\n/// Transfers lamports from a signer to a PDA using system program CPI.\n///\n/// This is the standard pattern for depositing funds into an escrow PDA\n/// (e.g., a player funding a match entry).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_to_pda(\n///     &ctx.accounts.creator.to_account_info(),\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     entry_amount,\n///     &ctx.accounts.system_program.to_account_info(),\n/// )?;\n/// ```\npub fn transfer_lamports_to_pda<'a>(\n    from: &AccountInfo<'a>,\n    pda: &AccountInfo<'a>,\n    amount: u64,\n    system_program_info: &AccountInfo<'a>,\n) -> Result<()> {\n    system_program::transfer(\n        CpiContext::new(\n            system_program_info.clone(),\n            system_program::Transfer {\n                from: from.clone(),\n                to: pda.clone(),\n            },\n        ),\n        amount,\n    )\n}\n```\n\n### 8. **pause.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n#[error_code]\npub enum PauseError {\n    #[msg(\"Platform is paused\")]\n    PlatformPaused,\n    #[msg(\"Game is paused\")]\n    GamePaused,\n}\n\n/// Checks that neither the global platform nor the specific game is paused.\n/// Global pause takes precedence over game pause.\npub fn check_not_paused(global_paused: bool, game_paused: bool) -> Result<()> {\n    if global_paused {\n        return Err(PauseError::PlatformPaused.into());\n    }\n    if game_paused {\n        return Err(PauseError::GamePaused.into());\n    }\n    Ok(())\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn both_unpaused_ok() {\n        assert!(check_not_paused(false, false).is_ok());\n    }\n\n    #[test]\n    fn global_paused_returns_platform_paused() {\n        let err = check_not_paused(true, false).unwrap_err();\n        assert!(err.to_string().contains(\"PlatformPaused\"));\n    }\n\n    #[test]\n    fn game_paused_returns_game_paused() {\n        let err = check_not_paused(false, true).unwrap_err();\n        assert!(err.to_string().contains(\"GamePaused\"));\n    }\n\n    #[test]\n    fn both_paused_returns_platform_paused_precedence() {\n        let err = check_not_paused(true, true).unwrap_err();\n        assert!(err.to_string().contains(\"PlatformPaused\"));\n    }\n}\n```\n\n### 9. **cpi.rs**\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::solana_program::{\n    instruction::{AccountMeta, Instruction},\n    program::invoke_signed,\n};\nuse solana_sha256_hasher::hashv;\n\n/// Calls the platform program's `update_player_profile` instruction via CPI.\n///\n/// If the profile account has no data (player hasn't created a profile), the call\n/// is silently skipped — returns `Ok(())` without emitting a CPI.\n///\n/// This helper constructs the CPI instruction manually (discriminator + borsh args)\n/// to avoid a circular dependency between `rng-shared` and `platform`.\n///\n/// # Arguments\n///\n/// * `platform_program` — The platform program account.\n/// * `profile` — The player's profile PDA (mutable). Skipped if empty.\n/// * `authority` — The game config PDA that signs the CPI.\n/// * `signer_seeds` — Seeds for PDA signing (e.g., `&[b\"coinflip_config\", &[bump]]`).\n/// * `total_games_delta` — Reserved; platform always increments by 1 per call.\n/// * `wins_delta` — If > 0, player is marked as winner.\n/// * `total_wagered_delta` — Lamports wagered in this game (maps to `wager_amount`).\n/// * `total_won_delta` — Lamports won in this game (maps to `won_amount`, 0 if lost).\n///\n/// # Example\n///\n/// ```ignore\n/// update_player_profile_cpi(\n///     &ctx.accounts.platform_program,\n///     &ctx.accounts.creator_profile,\n///     &ctx.accounts.config.to_account_info(),\n///     &[b\"coinflip_config\", &[config_bump]],\n///     1,                    // total_games_delta\n///     if is_winner { 1 } else { 0 }, // wins_delta\n///     entry_amount,         // total_wagered_delta\n///     if is_winner { payout } else { 0 }, // total_won_delta\n/// )?;\n/// ```\npub fn update_player_profile_cpi<'a>(\n    platform_program: &AccountInfo<'a>,\n    profile: &AccountInfo<'a>,\n    authority: &AccountInfo<'a>,\n    signer_seeds: &[&[u8]],\n    _total_games_delta: u64,\n    wins_delta: u64,\n    total_wagered_delta: u64,\n    total_won_delta: u64,\n) -> Result<()> {\n    // Guard: skip if profile hasn't been created yet\n    if profile.data_is_empty() {\n        return Ok(());\n    }\n\n    // Map to platform program's actual parameters\n    let wager_amount = total_wagered_delta;\n    let won_amount = total_won_delta;\n    let is_winner = wins_delta > 0;\n\n    // Discriminator = sha256(\"global:update_player_profile\")[0..8]\n    let disc = hashv(&[b\"global:update_player_profile\"]);\n\n    // Instruction data: 8-byte discriminator + wager_amount(u64) + won_amount(u64) + is_winner(bool)\n    let mut data = [0u8; 25];\n    data[..8].copy_from_slice(&disc.to_bytes()[..8]);\n    data[8..16].copy_from_slice(&wager_amount.to_le_bytes());\n    data[16..24].copy_from_slice(&won_amount.to_le_bytes());\n    data[24] = u8::from(is_winner);\n\n    let accounts = vec![\n        AccountMeta::new_readonly(*authority.key, true), // caller (signer)\n        AccountMeta::new(*profile.key, false),           // profile (mutable)\n    ];\n\n    let ix = Instruction {\n        program_id: *platform_program.key,\n        accounts,\n        data: data.to_vec(),\n    };\n\n    invoke_signed(\n        &ix,\n        &[authority.clone(), profile.clone(), platform_program.clone()],\n        &[signer_seeds],\n    )?;\n\n    Ok(())\n}\n```\n\n### 10. **commit_reveal.rs**\n```rust\nuse anchor_lang::prelude::*;\nuse solana_sha256_hasher::hashv;\n\n#[error_code]\npub enum CommitRevealError {\n    #[msg(\"Commitment mismatch: SHA256(server_seed) does not match stored commitment\")]\n    CommitmentMismatch,\n}\n\n/// Writes a commitment hash into the provided storage slot.\npub fn store_commitment(commitment: &mut [u8; 32], hash: [u8; 32]) {\n    *commitment = hash;\n}\n\n/// Verifies that `SHA256(server_seed)` matches the stored commitment.\npub fn verify_reveal(commitment: &[u8; 32], server_seed: &[u8]) -> Result<()> {\n    let computed = hashv(&[server_seed]);\n    if computed.to_bytes() == *commitment {\n        Ok(())\n    } else {\n        Err(CommitRevealError::CommitmentMismatch.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use solana_sha256_hasher::hashv as sha256;\n\n    #[test]\n    fn known_pair_passes() {\n        let seed = b\"known_server_seed_1234\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, seed).is_ok());\n    }\n\n    #[test]\n    fn tampered_seed_fails() {\n        let seed = b\"original_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"tampered_seed\").is_err());\n    }\n\n    #[test]\n    fn empty_seed_fails() {\n        let seed = b\"non_empty_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"\").is_err());\n    }\n}\n```\n\n### 11. **tiers.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n/// Fixed tier entry amounts in lamports.\n/// Index 0 = Iron, 1 = Bronze, 2 = Silver, 3 = Gold, 4 = Platinum, 5 = Diamond\npub const TIER_AMOUNTS: [u64; 6] = [\n    5_000_000,       // 0.005 SOL — Iron\n    10_000_000,      // 0.01  SOL — Bronze\n    100_000_000,     // 0.1   SOL — Silver\n    250_000_000,     // 0.25  SOL — Gold\n    500_000_000,     // 0.5   SOL — Platinum\n    1_000_000_000,   // 1.0   SOL — Diamond\n];\n\npub const TIER_COUNT: usize = TIER_AMOUNTS.len();\n\n/// Returns the entry amount for the given tier index, or an error if out of range.\npub fn get_tier_amount(tier: u8) -> Result<u64> {\n    TIER_AMOUNTS\n        .get(tier as usize)\n        .copied()\n        .ok_or_else(|| error!(TierError::InvalidTier))\n}\n\n#[error_code]\npub enum TierError {\n    #[msg(\"Invalid tier index\")]\n    InvalidTier,\n}\n```\n\n---\n\nAll 11 files have been provided in their complete form above."},{"type":"text","text":"agentId: a512a4ca5ee0d4a20 (for resuming to continue this agent's work if needed)\n<usage>total_tokens: 46487\ntool_uses: 11\nduration_ms: 56394</usage>"}]}]},"parent_tool_use_id":null,"session_id":"26c7f4cc-b2b2-41aa-85e9-beee2a3d95f1","uuid":"eca8c70a-8fba-4253-8960-2d99c0b73c3e","tool_use_result":{"status":"completed","prompt":"Read the following files and report their complete contents back to me. I need ALL the code:\n\n1. `sources/rng-utopia/solana/shared/src/lib.rs`\n2. `sources/rng-utopia/solana/shared/src/constants.rs`\n3. `sources/rng-utopia/solana/shared/src/fees.rs`\n4. `sources/rng-utopia/solana/shared/src/lifecycle.rs`\n5. `sources/rng-utopia/solana/shared/src/timeout.rs`\n6. `sources/rng-utopia/solana/shared/src/vrf_orao.rs`\n7. `sources/rng-utopia/solana/shared/src/escrow.rs`\n8. `sources/rng-utopia/solana/shared/src/pause.rs`\n9. `sources/rng-utopia/solana/shared/src/cpi.rs`\n10. `sources/rng-utopia/solana/shared/src/commit_reveal.rs`\n11. `sources/rng-utopia/solana/shared/src/tiers.rs`","agentId":"a512a4ca5ee0d4a20","content":[{"type":"text","text":"## Complete Contents of Shared Library Files\n\nHere are all the requested files from `/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/`:\n\n### 1. **lib.rs**\n```rust\npub mod commit_reveal;\npub mod constants;\npub mod cpi;\npub mod escrow;\npub mod fees;\npub mod lifecycle;\npub mod pause;\npub mod tiers;\npub mod timeout;\npub mod vrf_orao;\n```\n\n### 2. **constants.rs**\n```rust\n/// Coin sides\npub const SIDE_HEADS: u8 = 0;\npub const SIDE_TAILS: u8 = 1;\n\n/// Match phases\npub const PHASE_WAITING: u8 = 0;   // Creator placed bet, waiting for opponent\npub const PHASE_LOCKED: u8 = 1;    // Both players in, requesting VRF\npub const PHASE_SETTLED: u8 = 2;   // VRF resolved, winner determined\npub const PHASE_CANCELLED: u8 = 3; // Creator cancelled before opponent joined\n\n/// Timeout (in seconds) after which a LOCKED match can be cancelled.\npub const LOCK_TIMEOUT_SECONDS: i64 = 120; // 2 minutes\n\n/// Derive a coin side (0 or 1) from a randomness byte.\npub fn from_randomness(byte: u8) -> u8 {\n    byte % 2\n}\n\n/// Returns true if the given value is a valid side (HEADS or TAILS).\npub fn is_valid_side(side: u8) -> bool {\n    side == SIDE_HEADS || side == SIDE_TAILS\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_from_randomness() {\n        assert_eq!(from_randomness(0), SIDE_HEADS);\n        assert_eq!(from_randomness(1), SIDE_TAILS);\n        assert_eq!(from_randomness(2), SIDE_HEADS);\n        assert_eq!(from_randomness(255), SIDE_TAILS);\n    }\n\n    #[test]\n    fn test_is_valid_side() {\n        assert!(is_valid_side(SIDE_HEADS));\n        assert!(is_valid_side(SIDE_TAILS));\n        assert!(!is_valid_side(2));\n        assert!(!is_valid_side(255));\n    }\n}\n```\n\n### 3. **fees.rs**\n```rust\n/// Compile-time safety cap: no fee can ever exceed 10% (1000 bps).\npub const MAX_FEE_BPS: u16 = 1000;\n\n/// Total platform fee: 3% (300 basis points)\n/// - 200 bps: platform revenue\n/// - 70 bps: rakeback pool (raid boss rewards)\n/// - 30 bps: chest treasury\npub const TOTAL_FEE_BPS: u16 = 300;\npub const REVENUE_BPS: u16 = 200;\npub const RAKEBACK_BPS: u16 = 70;\npub const CHEST_BPS: u16 = 30;\n\n// Compile-time assertion: fee must never exceed safety cap.\nconst _: () = assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n\n/// Calculate the total fee for a given amount.\n/// Returns the fee in lamports.\npub fn calculate_fee(amount: u64) -> u64 {\n    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n}\n\n/// Calculate fee and net payout for a given pool amount.\n/// Returns `(fee, net_payout)` where `net_payout = pool - fee`.\n/// Fee rounds down (integer division truncates), favoring the player.\npub fn calculate_net_payout(pool: u64) -> (u64, u64) {\n    let fee = calculate_fee(pool);\n    (fee, pool - fee)\n}\n\n/// Split a fee amount into (revenue, rakeback, chest).\npub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    (revenue, rakeback, chest)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_calculate_fee() {\n        assert_eq!(calculate_fee(10_000), 300);\n        assert_eq!(calculate_fee(1_000_000), 30_000);\n        assert_eq!(calculate_fee(0), 0);\n    }\n\n    #[test]\n    fn test_calculate_net_payout() {\n        let (fee, net) = calculate_net_payout(1_000_000);\n        assert_eq!(fee, 30_000);\n        assert_eq!(net, 970_000);\n        assert_eq!(fee + net, 1_000_000);\n\n        // Zero pool\n        let (fee, net) = calculate_net_payout(0);\n        assert_eq!(fee, 0);\n        assert_eq!(net, 0);\n\n        // Small amount where rounding truncates (favors player)\n        // 100 lamports * 300 / 10000 = 3.0 exactly\n        let (fee, net) = calculate_net_payout(100);\n        assert_eq!(fee, 3);\n        assert_eq!(net, 97);\n\n        // Non-round amount: 1 lamport → fee rounds to 0\n        let (fee, net) = calculate_net_payout(1);\n        assert_eq!(fee, 0);\n        assert_eq!(net, 1);\n    }\n\n    #[test]\n    fn test_max_fee_bps_cap() {\n        assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n    }\n\n    #[test]\n    fn test_split_fee() {\n        let (rev, rake, chest) = split_fee(300);\n        assert_eq!(rev, 200);\n        assert_eq!(rake, 70);\n        assert_eq!(chest, 30);\n        assert_eq!(rev + rake + chest, 300);\n    }\n}\n```\n\n### 4. **lifecycle.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n/// Lifecycle phase for every round/match in any game.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, Debug, InitSpace)]\npub enum RoundPhase {\n    Waiting,\n    Active,\n    Locked,\n    Resolving,\n    Settled,\n    Refunded,\n}\n\n/// Timestamps tracking round progression.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, Debug)]\npub struct RoundTimestamps {\n    pub created_at: i64,\n    pub locked_at: Option<i64>,\n    pub resolve_deadline: Option<i64>,\n    pub settled_at: Option<i64>,\n}\n\n#[error_code]\npub enum LifecycleError {\n    #[msg(\"Invalid phase transition\")]\n    InvalidTransition,\n}\n\n/// Validates that the transition from `current` to `target` is allowed.\n///\n/// Allowed transitions:\n/// - Waiting → Active, Locked, Refunded\n/// - Active → Locked, Refunded\n/// - Locked → Resolving, Refunded\n/// - Resolving → Settled, Refunded\n///\n/// LOCKED → SETTLED is explicitly disallowed; VRF games read the result\n/// at claim time and set the phase directly.\npub fn transition(current: RoundPhase, target: RoundPhase) -> Result<()> {\n    let valid = matches!(\n        (current, target),\n        (RoundPhase::Waiting, RoundPhase::Active)\n            | (RoundPhase::Waiting, RoundPhase::Locked)\n            | (RoundPhase::Active, RoundPhase::Locked)\n            | (RoundPhase::Locked, RoundPhase::Resolving)\n            | (RoundPhase::Resolving, RoundPhase::Settled)\n            | (RoundPhase::Resolving, RoundPhase::Refunded)\n            | (RoundPhase::Waiting, RoundPhase::Refunded)\n            | (RoundPhase::Active, RoundPhase::Refunded)\n            | (RoundPhase::Locked, RoundPhase::Refunded)\n    );\n\n    if valid {\n        Ok(())\n    } else {\n        Err(LifecycleError::InvalidTransition.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn valid_transitions() {\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Active).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Locked).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Resolving).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Settled).is_ok());\n        assert!(transition(RoundPhase::Resolving, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Active, RoundPhase::Refunded).is_ok());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Refunded).is_ok());\n    }\n\n    #[test]\n    fn invalid_transitions() {\n        // Self-transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Locked).is_err());\n\n        // Backward transitions\n        assert!(transition(RoundPhase::Active, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Locked, RoundPhase::Waiting).is_err());\n        assert!(transition(RoundPhase::Settled, RoundPhase::Waiting).is_err());\n\n        // LOCKED → SETTLED explicitly invalid (VRF games use claim, not transition)\n        assert!(transition(RoundPhase::Locked, RoundPhase::Settled).is_err());\n\n        // Terminal states cannot transition\n        assert!(transition(RoundPhase::Settled, RoundPhase::Refunded).is_err());\n        assert!(transition(RoundPhase::Refunded, RoundPhase::Settled).is_err());\n\n        // Skip transitions\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Settled).is_err());\n        assert!(transition(RoundPhase::Waiting, RoundPhase::Resolving).is_err());\n    }\n\n    #[test]\n    fn enum_serialization_roundtrip() {\n        let phases = [\n            RoundPhase::Waiting,\n            RoundPhase::Active,\n            RoundPhase::Locked,\n            RoundPhase::Resolving,\n            RoundPhase::Settled,\n            RoundPhase::Refunded,\n        ];\n\n        for phase in phases {\n            let mut buf = Vec::new();\n            AnchorSerialize::serialize(&phase, &mut buf).unwrap();\n            let deserialized = RoundPhase::deserialize(&mut buf.as_slice()).unwrap();\n            assert_eq!(phase, deserialized);\n        }\n    }\n}\n```\n\n### 5. **timeout.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n/// Default timeout (seconds) after which a LOCKED/RESOLVING round can be refunded.\npub const DEFAULT_RESOLVE_TIMEOUT_SECONDS: i64 = 120;\n\n#[error_code]\npub enum TimeoutError {\n    #[msg(\"Resolve deadline has been exceeded\")]\n    ResolveDeadlineExceeded,\n}\n\n/// Returns `true` when the current time is at or past the resolve deadline.\npub fn is_expired(resolve_deadline: i64, now: i64) -> bool {\n    now >= resolve_deadline\n}\n\n/// Returns `Ok(())` if the deadline has NOT been exceeded, or an error if it has.\npub fn enforce_not_expired(resolve_deadline: i64, now: i64) -> Result<()> {\n    if is_expired(resolve_deadline, now) {\n        Err(TimeoutError::ResolveDeadlineExceeded.into())\n    } else {\n        Ok(())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn expired_exactly_at_deadline() {\n        assert!(is_expired(1000, 1000));\n    }\n\n    #[test]\n    fn not_expired_one_second_before() {\n        assert!(!is_expired(1000, 999));\n    }\n\n    #[test]\n    fn expired_one_second_after() {\n        assert!(is_expired(1000, 1001));\n    }\n\n    #[test]\n    fn enforce_not_expired_ok_before_deadline() {\n        assert!(enforce_not_expired(1000, 999).is_ok());\n    }\n\n    #[test]\n    fn enforce_not_expired_fails_at_deadline() {\n        assert!(enforce_not_expired(1000, 1000).is_err());\n    }\n\n    #[test]\n    fn enforce_not_expired_fails_after_deadline() {\n        assert!(enforce_not_expired(1000, 1001).is_err());\n    }\n}\n```\n\n### 6. **vrf_orao.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n/// Audit fields stored on match/round accounts for VRF traceability.\n#[derive(AnchorSerialize, AnchorDeserialize, Clone, Copy, PartialEq, Eq, InitSpace)]\npub struct VrfAuditFields {\n    /// Address of the Orao randomness PDA for this match/round.\n    pub vrf_request_key: Pubkey,\n    /// Unix timestamp when VRF was requested.\n    pub vrf_requested_at: i64,\n}\n\n/// Error codes for VRF operations.\n#[error_code]\npub enum VrfError {\n    /// Randomness has not been fulfilled by the VRF oracle.\n    #[msg(\"VRF randomness not yet fulfilled\")]\n    RandomnessNotFulfilled,\n}\n\n/// Returns true if the 32-byte randomness is non-zero (i.e., fulfilled).\npub fn is_fulfilled(randomness: &[u8; 32]) -> bool {\n    randomness.iter().any(|&b| b != 0)\n}\n\n// ---------------------------------------------------------------------------\n// Real Orao mode — CPI into Orao VRF program\n// ---------------------------------------------------------------------------\n\n/// CPI into Orao VRF to request randomness.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn request_orao_randomness<'info>(\n    orao_program: &AccountInfo<'info>,\n    network_state: &AccountInfo<'info>,\n    treasury: &AccountInfo<'info>,\n    random: &AccountInfo<'info>,\n    payer: &AccountInfo<'info>,\n    system_program: &AccountInfo<'info>,\n    seed: [u8; 32],\n) -> Result<()> {\n    let cpi_accounts = orao_solana_vrf::cpi::accounts::RequestV2 {\n        payer: payer.clone(),\n        network_state: network_state.clone(),\n        treasury: treasury.clone(),\n        request: random.clone(),\n        system_program: system_program.clone(),\n    };\n    let cpi_ctx = CpiContext::new(orao_program.clone(), cpi_accounts);\n    orao_solana_vrf::cpi::request_v2(cpi_ctx, seed)\n}\n\n/// Read fulfilled randomness from an Orao randomness account.\n///\n/// Deserializes the Orao `RandomnessAccountData` (supports both V1 and V2\n/// accounts) and returns the first 32 bytes of the 64-byte randomness.\n/// Returns an error if randomness has not been fulfilled yet.\n#[cfg(not(feature = \"mock-vrf\"))]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    use anchor_lang::AccountDeserialize;\n\n    let data = randomness_account.try_borrow_data()?;\n    let mut buf: &[u8] = &data;\n    let account_data =\n        orao_solana_vrf::state::RandomnessAccountData::try_deserialize_unchecked(&mut buf)?;\n\n    match account_data.fulfilled_randomness() {\n        Some(randomness_64) => {\n            let mut result = [0u8; 32];\n            result.copy_from_slice(&randomness_64[..32]);\n            Ok(result)\n        }\n        None => Err(error!(VrfError::RandomnessNotFulfilled)),\n    }\n}\n\n// ---------------------------------------------------------------------------\n// Mock VRF mode — no Orao CPI, reads raw bytes from test account\n// ---------------------------------------------------------------------------\n\n/// No-op in mock mode. Test authority writes mock randomness directly.\n#[cfg(feature = \"mock-vrf\")]\npub fn request_orao_randomness<'info>(\n    _orao_program: &AccountInfo<'info>,\n    _network_state: &AccountInfo<'info>,\n    _treasury: &AccountInfo<'info>,\n    _random: &AccountInfo<'info>,\n    _payer: &AccountInfo<'info>,\n    _system_program: &AccountInfo<'info>,\n    _seed: [u8; 32],\n) -> Result<()> {\n    Ok(())\n}\n\n/// In mock mode, reads raw 32 bytes from account data as randomness.\n/// All-zeros = unfulfilled (returns error).\n#[cfg(feature = \"mock-vrf\")]\npub fn read_orao_randomness(randomness_account: &AccountInfo) -> Result<[u8; 32]> {\n    let data = randomness_account.try_borrow_data()?;\n    require!(data.len() >= 32, VrfError::RandomnessNotFulfilled);\n\n    let mut randomness = [0u8; 32];\n    randomness.copy_from_slice(&data[..32]);\n\n    require!(is_fulfilled(&randomness), VrfError::RandomnessNotFulfilled);\n    Ok(randomness)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn test_is_fulfilled_all_zeros() {\n        let zeros = [0u8; 32];\n        assert!(!is_fulfilled(&zeros));\n    }\n\n    #[test]\n    fn test_is_fulfilled_non_zero() {\n        let mut data = [0u8; 32];\n        data[0] = 1;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_is_fulfilled_all_ones() {\n        let ones = [0xFF; 32];\n        assert!(is_fulfilled(&ones));\n    }\n\n    #[test]\n    fn test_is_fulfilled_single_byte_set() {\n        let mut data = [0u8; 32];\n        data[31] = 42;\n        assert!(is_fulfilled(&data));\n    }\n\n    #[test]\n    fn test_vrf_audit_fields_size() {\n        // Pubkey (32) + i64 (8) = 40 bytes\n        assert_eq!(<VrfAuditFields as anchor_lang::Space>::INIT_SPACE, 40);\n    }\n}\n```\n\n### 7. **escrow.rs**\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::system_program;\n\n/// Error codes for escrow operations.\n#[error_code]\npub enum EscrowError {\n    /// The escrow PDA does not hold enough lamports for the requested transfer.\n    #[msg(\"Insufficient escrow balance\")]\n    InsufficientEscrowBalance,\n}\n\n/// Transfers lamports from a PDA to a recipient using direct lamport manipulation.\n///\n/// This is the standard pattern for moving funds out of a program-owned PDA\n/// (e.g., paying out a winner, refunding a player, sending fees to treasury).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_from_pda(\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     &ctx.accounts.winner.to_account_info(),\n///     payout_amount,\n/// )?;\n/// ```\npub fn transfer_lamports_from_pda(\n    pda: &AccountInfo,\n    recipient: &AccountInfo,\n    amount: u64,\n) -> Result<()> {\n    let pda_balance = pda.lamports();\n    require!(pda_balance >= amount, EscrowError::InsufficientEscrowBalance);\n\n    **pda.try_borrow_mut_lamports()? -= amount;\n    **recipient.try_borrow_mut_lamports()? += amount;\n\n    Ok(())\n}\n\n/// Transfers lamports from a signer to a PDA using system program CPI.\n///\n/// This is the standard pattern for depositing funds into an escrow PDA\n/// (e.g., a player funding a match entry).\n///\n/// # Example\n/// ```ignore\n/// transfer_lamports_to_pda(\n///     &ctx.accounts.creator.to_account_info(),\n///     &ctx.accounts.coinflip_match.to_account_info(),\n///     entry_amount,\n///     &ctx.accounts.system_program.to_account_info(),\n/// )?;\n/// ```\npub fn transfer_lamports_to_pda<'a>(\n    from: &AccountInfo<'a>,\n    pda: &AccountInfo<'a>,\n    amount: u64,\n    system_program_info: &AccountInfo<'a>,\n) -> Result<()> {\n    system_program::transfer(\n        CpiContext::new(\n            system_program_info.clone(),\n            system_program::Transfer {\n                from: from.clone(),\n                to: pda.clone(),\n            },\n        ),\n        amount,\n    )\n}\n```\n\n### 8. **pause.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n#[error_code]\npub enum PauseError {\n    #[msg(\"Platform is paused\")]\n    PlatformPaused,\n    #[msg(\"Game is paused\")]\n    GamePaused,\n}\n\n/// Checks that neither the global platform nor the specific game is paused.\n/// Global pause takes precedence over game pause.\npub fn check_not_paused(global_paused: bool, game_paused: bool) -> Result<()> {\n    if global_paused {\n        return Err(PauseError::PlatformPaused.into());\n    }\n    if game_paused {\n        return Err(PauseError::GamePaused.into());\n    }\n    Ok(())\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn both_unpaused_ok() {\n        assert!(check_not_paused(false, false).is_ok());\n    }\n\n    #[test]\n    fn global_paused_returns_platform_paused() {\n        let err = check_not_paused(true, false).unwrap_err();\n        assert!(err.to_string().contains(\"PlatformPaused\"));\n    }\n\n    #[test]\n    fn game_paused_returns_game_paused() {\n        let err = check_not_paused(false, true).unwrap_err();\n        assert!(err.to_string().contains(\"GamePaused\"));\n    }\n\n    #[test]\n    fn both_paused_returns_platform_paused_precedence() {\n        let err = check_not_paused(true, true).unwrap_err();\n        assert!(err.to_string().contains(\"PlatformPaused\"));\n    }\n}\n```\n\n### 9. **cpi.rs**\n```rust\nuse anchor_lang::prelude::*;\nuse anchor_lang::solana_program::{\n    instruction::{AccountMeta, Instruction},\n    program::invoke_signed,\n};\nuse solana_sha256_hasher::hashv;\n\n/// Calls the platform program's `update_player_profile` instruction via CPI.\n///\n/// If the profile account has no data (player hasn't created a profile), the call\n/// is silently skipped — returns `Ok(())` without emitting a CPI.\n///\n/// This helper constructs the CPI instruction manually (discriminator + borsh args)\n/// to avoid a circular dependency between `rng-shared` and `platform`.\n///\n/// # Arguments\n///\n/// * `platform_program` — The platform program account.\n/// * `profile` — The player's profile PDA (mutable). Skipped if empty.\n/// * `authority` — The game config PDA that signs the CPI.\n/// * `signer_seeds` — Seeds for PDA signing (e.g., `&[b\"coinflip_config\", &[bump]]`).\n/// * `total_games_delta` — Reserved; platform always increments by 1 per call.\n/// * `wins_delta` — If > 0, player is marked as winner.\n/// * `total_wagered_delta` — Lamports wagered in this game (maps to `wager_amount`).\n/// * `total_won_delta` — Lamports won in this game (maps to `won_amount`, 0 if lost).\n///\n/// # Example\n///\n/// ```ignore\n/// update_player_profile_cpi(\n///     &ctx.accounts.platform_program,\n///     &ctx.accounts.creator_profile,\n///     &ctx.accounts.config.to_account_info(),\n///     &[b\"coinflip_config\", &[config_bump]],\n///     1,                    // total_games_delta\n///     if is_winner { 1 } else { 0 }, // wins_delta\n///     entry_amount,         // total_wagered_delta\n///     if is_winner { payout } else { 0 }, // total_won_delta\n/// )?;\n/// ```\npub fn update_player_profile_cpi<'a>(\n    platform_program: &AccountInfo<'a>,\n    profile: &AccountInfo<'a>,\n    authority: &AccountInfo<'a>,\n    signer_seeds: &[&[u8]],\n    _total_games_delta: u64,\n    wins_delta: u64,\n    total_wagered_delta: u64,\n    total_won_delta: u64,\n) -> Result<()> {\n    // Guard: skip if profile hasn't been created yet\n    if profile.data_is_empty() {\n        return Ok(());\n    }\n\n    // Map to platform program's actual parameters\n    let wager_amount = total_wagered_delta;\n    let won_amount = total_won_delta;\n    let is_winner = wins_delta > 0;\n\n    // Discriminator = sha256(\"global:update_player_profile\")[0..8]\n    let disc = hashv(&[b\"global:update_player_profile\"]);\n\n    // Instruction data: 8-byte discriminator + wager_amount(u64) + won_amount(u64) + is_winner(bool)\n    let mut data = [0u8; 25];\n    data[..8].copy_from_slice(&disc.to_bytes()[..8]);\n    data[8..16].copy_from_slice(&wager_amount.to_le_bytes());\n    data[16..24].copy_from_slice(&won_amount.to_le_bytes());\n    data[24] = u8::from(is_winner);\n\n    let accounts = vec![\n        AccountMeta::new_readonly(*authority.key, true), // caller (signer)\n        AccountMeta::new(*profile.key, false),           // profile (mutable)\n    ];\n\n    let ix = Instruction {\n        program_id: *platform_program.key,\n        accounts,\n        data: data.to_vec(),\n    };\n\n    invoke_signed(\n        &ix,\n        &[authority.clone(), profile.clone(), platform_program.clone()],\n        &[signer_seeds],\n    )?;\n\n    Ok(())\n}\n```\n\n### 10. **commit_reveal.rs**\n```rust\nuse anchor_lang::prelude::*;\nuse solana_sha256_hasher::hashv;\n\n#[error_code]\npub enum CommitRevealError {\n    #[msg(\"Commitment mismatch: SHA256(server_seed) does not match stored commitment\")]\n    CommitmentMismatch,\n}\n\n/// Writes a commitment hash into the provided storage slot.\npub fn store_commitment(commitment: &mut [u8; 32], hash: [u8; 32]) {\n    *commitment = hash;\n}\n\n/// Verifies that `SHA256(server_seed)` matches the stored commitment.\npub fn verify_reveal(commitment: &[u8; 32], server_seed: &[u8]) -> Result<()> {\n    let computed = hashv(&[server_seed]);\n    if computed.to_bytes() == *commitment {\n        Ok(())\n    } else {\n        Err(CommitRevealError::CommitmentMismatch.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use solana_sha256_hasher::hashv as sha256;\n\n    #[test]\n    fn known_pair_passes() {\n        let seed = b\"known_server_seed_1234\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, seed).is_ok());\n    }\n\n    #[test]\n    fn tampered_seed_fails() {\n        let seed = b\"original_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"tampered_seed\").is_err());\n    }\n\n    #[test]\n    fn empty_seed_fails() {\n        let seed = b\"non_empty_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"\").is_err());\n    }\n}\n```\n\n### 11. **tiers.rs**\n```rust\nuse anchor_lang::prelude::*;\n\n/// Fixed tier entry amounts in lamports.\n/// Index 0 = Iron, 1 = Bronze, 2 = Silver, 3 = Gold, 4 = Platinum, 5 = Diamond\npub const TIER_AMOUNTS: [u64; 6] = [\n    5_000_000,       // 0.005 SOL — Iron\n    10_000_000,      // 0.01  SOL — Bronze\n    100_000_000,     // 0.1   SOL — Silver\n    250_000_000,     // 0.25  SOL — Gold\n    500_000_000,     // 0.5   SOL — Platinum\n    1_000_000_000,   // 1.0   SOL — Diamond\n];\n\npub const TIER_COUNT: usize = TIER_AMOUNTS.len();\n\n/// Returns the entry amount for the given tier index, or an error if out of range.\npub fn get_tier_amount(tier: u8) -> Result<u64> {\n    TIER_AMOUNTS\n        .get(tier as usize)\n        .copied()\n        .ok_or_else(|| error!(TierError::InvalidTier))\n}\n\n#[error_code]\npub enum TierError {\n    #[msg(\"Invalid tier index\")]\n    InvalidTier,\n}\n```\n\n---\n\nAll 11 files have been provided in their complete form above."}],"totalDurationMs":56394,"totalTokens":46487,"totalToolUseCount":11,"usage":{"input_tokens":7,"cache_creation_input_tokens":13535,"cache_read_input_tokens":24711,"output_tokens":8234,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":13535,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H3zLRrn2QAA1LotQHv2YFS","type":"tool_result","content":[{"type":"text","text":"Perfect! Here are all the files you requested:\n\n## 1. `/workspaces/rng-utopia/sources/rng-utopia/solana/tests/coinflip.ts`\n\n```typescript\nimport { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  SYSVAR_SLOT_HASHES_PUBKEY,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Coinflip } from \"../target/types/coinflip\";\nimport type { Platform } from \"../target/types/platform\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\nconst PLATFORM_IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n);\nconst PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n\n// ---------------------------------------------------------------------------\n// Constants matching shared crate\n// ---------------------------------------------------------------------------\nconst SIDE_HEADS = 0;\nconst SIDE_TAILS = 1;\nconst PHASE_WAITING = 0;\nconst PHASE_LOCKED = 1;\nconst PHASE_SETTLED = 2;\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL in lamports\nconst TOTAL_FEE_BPS = 300;\n\n// VRF mock constants\nconst RANDOMNESS_HEADS = new Array(32).fill(0); // byte[0]=0 (even) → HEADS\nconst RANDOMNESS_TAILS = (() => {\n  const arr = new Array(32).fill(0);\n  arr[0] = 1; // byte[0]=1 (odd) → TAILS\n  return arr;\n})();\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getMatchPda(creator: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlatformConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlayerProfilePda(wallet: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Bankrun context factory — fresh state per test\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\n// Real VRF constants — match ephemeral-vrf-sdk consts.rs\nconst VRF_PROGRAM_ADDRESS = new PublicKey(\"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\");\nconst VRF_DEFAULT_QUEUE = new PublicKey(\"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\");\n\n// Derive program_identity PDA: seeds=[b\"identity\"], program=coinflip\nconst [PROGRAM_IDENTITY_PDA] = PublicKey.findProgramAddressSync(\n  [Buffer.from(\"identity\")],\n  PROGRAM_ID\n);\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  opponent: Keypair;\n  oracle: Keypair;\n  treasury: Keypair;\n  creatorProgram: Program<Coinflip>;\n  opponentProgram: Program<Coinflip>;\n  oracleProgram: Program<Coinflip>;\n  platformProgram: Program<Platform>;\n  opponentPlatformProgram: Program<Platform>;\n  configPda: PublicKey;\n  matchPda: PublicKey;\n  platformConfigPda: PublicKey;\n  creatorProfilePda: PublicKey;\n  opponentProfilePda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const opponent = Keypair.generate();\n  const oracle = Keypair.generate();\n  const treasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: opponent.publicKey, info: fundedAccountData() },\n    { address: oracle.publicKey, info: fundedAccountData() },\n    { address: treasury.publicKey, info: fundedAccountData() },\n    // Mock VRF accounts at real addresses so #[vrf] macro constraints pass\n    { address: VRF_DEFAULT_QUEUE, info: fundedAccountData(LAMPORTS_PER_SOL) },\n    { address: PROGRAM_IDENTITY_PDA, info: fundedAccountData(LAMPORTS_PER_SOL) },\n  ]);\n\n  // Load a dummy program at the VRF program address.\n  // Anchor's Program<> type checks executable=true + matching address.\n  // Reuse the coinflip .so as a no-op stand-in (we never CPI into it in mock mode).\n  context.setAccount(VRF_PROGRAM_ADDRESS, {\n    lamports: LAMPORTS_PER_SOL,\n    data: readFileSync(join(__dirname, \"..\", \"target\", \"deploy\", \"coinflip.so\")),\n    owner: new PublicKey(\"BPFLoader2111111111111111111111111111111111\"),\n    executable: true,\n  });\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n\n  const opponentProvider = new BankrunProvider(\n    context,\n    new Wallet(opponent)\n  );\n  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n\n  const oracleProvider = new BankrunProvider(context, new Wallet(oracle));\n  const oracleProgram = new Program<Coinflip>(IDL, oracleProvider);\n\n  // Platform program instances\n  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n  const opponentPlatformProgram = new Program<Platform>(PLATFORM_IDL, opponentProvider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n  const matchPda = getMatchPda(creator);\n  const platformConfigPda = getPlatformConfigPda();\n  const creatorProfilePda = getPlayerProfilePda(creator);\n  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n\n  return {\n    context,\n    creator,\n    opponent,\n    oracle,\n    treasury,\n    creatorProgram,\n    opponentProgram,\n    oracleProgram,\n    platformProgram,\n    opponentPlatformProgram,\n    configPda,\n    matchPda,\n    platformConfigPda,\n    creatorProfilePda,\n    opponentProfilePda,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Helpers — call instructions\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.oracle.publicKey, t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function initPlatform(t: TestContext) {\n  await t.platformProgram.methods\n    .initializePlatform(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.platformConfigPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createPlayerProfile(t: TestContext, program: Program<Platform>, player: PublicKey) {\n  const profilePda = getPlayerProfilePda(player);\n  await program.methods\n    .createPlayerProfile()\n    .accounts({\n      player,\n      profile: profilePda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function setupPlatform(t: TestContext) {\n  await initPlatform(t);\n  await createPlayerProfile(t, t.platformProgram, t.creator);\n  await createPlayerProfile(t, t.opponentPlatformProgram, t.opponent.publicKey);\n}\n\nasync function createMatch(\n  t: TestContext,\n  tier = TIER_IRON,\n  side = SIDE_HEADS\n) {\n  await t.creatorProgram.methods\n    .createMatch(tier, side)\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function joinMatch(t: TestContext) {\n  await t.opponentProgram.methods\n    .joinMatch()\n    .accounts({\n      opponent: t.opponent.publicKey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      oracleQueue: VRF_DEFAULT_QUEUE,\n      programIdentity: PROGRAM_IDENTITY_PDA,\n      vrfProgram: VRF_PROGRAM_ADDRESS,\n      slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function resolveMatch(t: TestContext, randomness: number[]) {\n  await t.oracleProgram.methods\n    .resolveMatch(randomness)\n    .accounts({\n      oracle: t.oracle.publicKey,\n      config: t.configPda,\n      coinflipMatch: t.matchPda,\n    })\n    .rpc();\n}\n\nasync function claimPayout(t: TestContext, winnerProgram: Program<Coinflip>, winnerPubkey: PublicKey) {\n  await winnerProgram.methods\n    .claimPayout()\n    .accounts({\n      winner: winnerPubkey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      treasury: t.treasury.publicKey,\n      creator: t.creator,\n      creatorProfile: t.creatorProfilePda,\n      opponentProfile: t.opponentProfilePda,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function cancelMatch(t: TestContext) {\n  await t.creatorProgram.methods\n    .cancelMatch()\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n  const account = await t.context.banksClient.getAccount(pubkey);\n  return account ? Number(account.lamports) : 0;\n}\n\n// ===========================================================================\n// Tests\n// ===========================================================================\ndescribe(\"coinflip\", () => {\n  // -------------------------------------------------------------------------\n  // initialize_config\n  // -------------------------------------------------------------------------\n  describe(\"initialize_config\", () => {\n    it(\"creates config with oracle and treasury\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.coinflipConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.oracleAuthority.toBase58()).to.equal(\n        t.oracle.publicKey.toBase58()\n      );\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // create_match\n  // -------------------------------------------------------------------------\n  describe(\"create_match\", () => {\n    it(\"creates a coinflip match\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(match.opponent.toBase58()).to.equal(\n        PublicKey.default.toBase58()\n      );\n      expect(match.tier).to.equal(TIER_IRON);\n      expect(match.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(match.creatorSide).to.equal(SIDE_HEADS);\n      expect(match.phase).to.equal(PHASE_WAITING);\n      expect(match.result).to.equal(0);\n      expect(match.winner.toBase58()).to.equal(PublicKey.default.toBase58());\n      expect(match.claimed).to.equal(false);\n    });\n\n    it(\"rejects invalid side\", async () => {\n      const t = await createTestContext();\n\n      try {\n        await t.creatorProgram.methods\n          .createMatch(TIER_IRON, 3)\n          .accounts({\n            creator: t.creator,\n            coinflipMatch: t.matchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidSide error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidSide\");\n        expect(anchorErr.error.errorCode.number).to.equal(6100);\n      }\n    });\n\n    it(\"rejects invalid tier\", async () => {\n      const t = await createTestContext();\n\n      try {\n        await t.creatorProgram.methods\n          .createMatch(99, SIDE_HEADS)\n          .accounts({\n            creator: t.creator,\n            coinflipMatch: t.matchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidTier\");\n        expect(anchorErr.error.errorCode.number).to.equal(6101);\n      }\n    });\n\n    it(\"escrows correct lamport amount\", async () => {\n      const t = await createTestContext();\n      const balanceBefore = await getBalance(t, t.creator);\n\n      await createMatch(t);\n\n      const matchBalance = await getBalance(t, t.matchPda);\n      // Match PDA holds escrow + rent-exempt minimum\n      const matchAccount = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      const rentLamports =\n        matchBalance - matchAccount.entryAmount.toNumber();\n      expect(rentLamports).to.be.greaterThan(0);\n      expect(matchAccount.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n\n      const balanceAfter = await getBalance(t, t.creator);\n      // Creator paid entry_amount + rent + transaction fee\n      const spent = balanceBefore - balanceAfter;\n      expect(spent).to.be.greaterThanOrEqual(matchBalance);\n      // Transaction fee is 5000 lamports\n      expect(spent - matchBalance).to.equal(5000);\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // join_match\n  // -------------------------------------------------------------------------\n  describe(\"join_match\", () => {\n    it(\"opponent joins, phase transitions to LOCKED, escrow doubled\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      const balanceBefore = await getBalance(t, t.matchPda);\n      await joinMatch(t);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.opponent.toBase58()).to.equal(\n        t.opponent.publicKey.toBase58()\n      );\n      expect(match.phase).to.equal(PHASE_LOCKED);\n\n      const balanceAfter = await getBalance(t, t.matchPda);\n      // Escrow should have doubled (both players deposited entry_amount)\n      expect(balanceAfter - balanceBefore).to.equal(TIER_IRON_AMOUNT);\n    });\n\n    it(\"rejects creator joining own match\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      try {\n        // Creator tries to join as opponent\n        await t.creatorProgram.methods\n          .joinMatch()\n          .accounts({\n            opponent: t.creator,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            oracleQueue: VRF_DEFAULT_QUEUE,\n            programIdentity: PROGRAM_IDENTITY_PDA,\n            vrfProgram: VRF_PROGRAM_ADDRESS,\n            slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected CannotJoinOwnMatch error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"CannotJoinOwnMatch\");\n        expect(anchorErr.error.errorCode.number).to.equal(6104);\n      }\n    });\n\n    it(\"rejects if not in WAITING phase\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t); // phase → LOCKED (once implemented)\n\n      try {\n        // Second opponent tries to join — fund them so tx doesn't fail pre-program\n        const secondOpponent = Keypair.generate();\n        t.context.setAccount(secondOpponent.publicKey, fundedAccountData());\n        const secondProvider = new BankrunProvider(\n          t.context,\n          new Wallet(secondOpponent)\n        );\n        const secondProgram = new Program<Coinflip>(IDL, secondProvider);\n\n        await secondProgram.methods\n          .joinMatch()\n          .accounts({\n            opponent: secondOpponent.publicKey,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            oracleQueue: VRF_DEFAULT_QUEUE,\n            programIdentity: PROGRAM_IDENTITY_PDA,\n            vrfProgram: VRF_PROGRAM_ADDRESS,\n            slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // resolve_match\n  // -------------------------------------------------------------------------\n  describe(\"resolve_match\", () => {\n    it(\"HEADS when randomness[0] is even — creator wins if chose HEADS\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.result).to.equal(SIDE_HEADS);\n      expect(match.winner.toBase58()).to.equal(t.creator.toBase58());\n    });\n\n    it(\"TAILS when randomness[0] is odd — opponent wins if creator chose HEADS\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_TAILS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.result).to.equal(SIDE_TAILS);\n      expect(match.winner.toBase58()).to.equal(\n        t.opponent.publicKey.toBase58()\n      );\n    });\n\n    it(\"phase transitions to SETTLED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_SETTLED);\n    });\n\n    it(\"rejects unauthorized oracle\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      try {\n        // Creator (not oracle) tries to resolve\n        await t.creatorProgram.methods\n          .resolveMatch(RANDOMNESS_HEADS)\n          .accounts({\n            oracle: t.creator,\n            config: t.configPda,\n            coinflipMatch: t.matchPda,\n          })\n          .rpc();\n        expect.fail(\"Expected UnauthorizedOracle error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"UnauthorizedOracle\");\n        expect(anchorErr.error.errorCode.number).to.equal(6105);\n      }\n    });\n\n    it(\"rejects if not in LOCKED phase\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      // Skip join — match is still WAITING\n\n      try {\n        await resolveMatch(t, RANDOMNESS_HEADS);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // claim_payout\n  // -------------------------------------------------------------------------\n  describe(\"claim_payout\", () => {\n    it(\"winner gets pool minus fee, treasury gets fee\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS); // creator wins\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const winnerBefore = await getBalance(t, t.creator);\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const winnerAfter = await getBalance(t, t.creator);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      // Winner receives payout (plus rent refund from closed account)\n      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n      // Treasury receives fee\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n    });\n\n    it(\"match account closed, rent refunded to creator\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      // Match account should no longer exist\n      const matchAccount =\n        await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects double claim\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS);\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      try {\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected AlreadyClaimed error\");\n      } catch (err) {\n        // Account is closed so this should fail (either AlreadyClaimed or account not found)\n        expect(err).to.exist;\n      }\n    });\n\n    it(\"rejects claim by loser\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_TAILS); // opponent wins\n\n      try {\n        // Creator (loser) tries to claim\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected NotWinner error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"NotWinner\");\n        expect(anchorErr.error.errorCode.number).to.equal(6107);\n      }\n    });\n\n    it(\"rejects if not SETTLED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      // Skip join + resolve — match is WAITING\n\n      try {\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n\n    it(\"updates player profiles via CPI — creator wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS); // creator wins\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Creator (winner) profile\n      const creatorProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(creatorProfile.totalGames.toNumber()).to.equal(1);\n      expect(creatorProfile.wins.toNumber()).to.equal(1);\n      expect(creatorProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(creatorProfile.totalWon.toNumber()).to.equal(payout);\n\n      // Opponent (loser) profile\n      const opponentProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(opponentProfile.totalGames.toNumber()).to.equal(1);\n      expect(opponentProfile.wins.toNumber()).to.equal(0);\n      expect(opponentProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(opponentProfile.totalWon.toNumber()).to.equal(0);\n    });\n\n    it(\"updates player profiles via CPI — opponent wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_TAILS); // opponent wins\n\n      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Creator (loser) profile\n      const creatorProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(creatorProfile.totalGames.toNumber()).to.equal(1);\n      expect(creatorProfile.wins.toNumber()).to.equal(0);\n      expect(creatorProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(creatorProfile.totalWon.toNumber()).to.equal(0);\n\n      // Opponent (winner) profile\n      const opponentProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(opponentProfile.totalGames.toNumber()).to.equal(1);\n      expect(opponentProfile.wins.toNumber()).to.equal(1);\n      expect(opponentProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(opponentProfile.totalWon.toNumber()).to.equal(payout);\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // cancel_match\n  // -------------------------------------------------------------------------\n  describe(\"cancel_match\", () => {\n    it(\"creator cancels WAITING match, full refund\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      const balanceBefore = await getBalance(t, t.creator);\n\n      await cancelMatch(t);\n\n      const balanceAfter = await getBalance(t, t.creator);\n      // Creator gets back entry_amount + rent\n      expect(balanceAfter - balanceBefore).to.be.greaterThanOrEqual(\n        TIER_IRON_AMOUNT\n      );\n\n      // Match account should be closed\n      const matchAccount =\n        await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects cancel after LOCKED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t); // phase → LOCKED (once implemented)\n\n      try {\n        await cancelMatch(t);\n        expect.fail(\"Expected CannotCancel error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"CannotCancel\");\n        expect(anchorErr.error.errorCode.number).to.equal(6108);\n      }\n    });\n\n    it(\"rejects cancel by non-creator\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      // Opponent tries to cancel creator's match\n      // The PDA seeds [b\"match\", creator.key()] won't match opponent's key\n      // so this should fail with a constraint error\n      const opponentMatchPda = getMatchPda(t.opponent.publicKey);\n\n      try {\n        await t.opponentProgram.methods\n          .cancelMatch()\n          .accounts({\n            creator: t.opponent.publicKey,\n            coinflipMatch: opponentMatchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected constraint error\");\n      } catch (err) {\n        // PDA [b\"match\", opponent_key] doesn't exist → AccountNotInitialized\n        expect(err).to.exist;\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // full lifecycle\n  // -------------------------------------------------------------------------\n  describe(\"full lifecycle\", () => {\n    it(\"create → join → resolve(HEADS) → claim\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n\n      // 1. Create\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      let match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_WAITING);\n\n      // 2. Join\n      await joinMatch(t);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.phase).to.equal(PHASE_LOCKED);\n\n      // 3. Resolve — HEADS → creator wins\n      await resolveMatch(t, RANDOMNESS_HEADS);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.phase).to.equal(PHASE_SETTLED);\n      expect(match.winner.toBase58()).to.equal(t.creator.toBase58());\n\n      // 4. Claim\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n      await claimPayout(t, t.creatorProgram, t.creator);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n\n      // Match account closed\n      const closed = await t.context.banksClient.getAccount(t.matchPda);\n      expect(closed).to.be.null;\n    });\n\n    it(\"create → cancel → create again\", async () => {\n      const t = await createTestContext();\n\n      // 1. Create\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      let match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_WAITING);\n\n      // 2. Cancel\n      await cancelMatch(t);\n      const closed = await t.context.banksClient.getAccount(t.matchPda);\n      expect(closed).to.be.null;\n\n      // 3. Create again (same PDA slot is free)\n      await createMatch(t, TIER_IRON, SIDE_TAILS);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.creatorSide).to.equal(SIDE_TAILS);\n      expect(match.phase).to.equal(PHASE_WAITING);\n    });\n  });\n});\n```\n\n## 2. `/workspaces/rng-utopia/sources/rng-utopia/solana/Anchor.toml`\n\n```toml\n[toolchain]\nanchor_version = \"0.32.1\"\n\n[features]\nresolution = true\nskip-lint = false\n\n[programs.localnet]\ncoinflip = \"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\"\nplatform = \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n\n[programs.devnet]\ncoinflip = \"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\"\nplatform = \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n\n[registry]\nurl = \"https://api.apr.dev\"\n\n[provider]\ncluster = \"Localnet\"\nwallet = \"~/.config/solana/id.json\"\n\n[scripts]\ntest = \"pnpm exec ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts\"\n```\n\n## 3. `/workspaces/rng-utopia/sources/rng-utopia/solana/Cargo.toml`\n\n```toml\n[workspace]\nmembers = [\n    \"shared\",\n    \"programs/coinflip\",\n    \"programs/platform\",\n]\nresolver = \"2\"\n\n[workspace.dependencies]\nanchor-lang = \"0.32.1\"\norao-solana-vrf = { version = \"0.7.0\", default-features = false, features = [\"cpi\"] }\nrng-shared = { path = \"shared\" }\nsolana-sha256-hasher = \"2.3\"\n\n[profile.release]\noverflow-checks = true\nlto = \"fat\"\ncodegen-units = 1\n\n[profile.release.build-override]\nopt-level = 3\nincremental = false\ncodegen-units = 1\n```\n\n## 4. `/workspaces/rng-utopia/sources/rng-utopia/solana/package.json`\n\n```json\n{\n  \"name\": \"rng-utopia-programs\",\n  \"private\": true,\n  \"type\": \"module\",\n  \"scripts\": {\n    \"test\": \"anchor test --skip-local-validator --skip-deploy\"\n  },\n  \"dependencies\": {\n    \"@coral-xyz/anchor\": \"^0.32.1\",\n    \"@solana/web3.js\": \"^1.95.0\"\n  },\n  \"devDependencies\": {\n    \"@orao-network/solana-vrf\": \"^0.8.0\",\n    \"@switchboard-xyz/solana-randomness-service\": \"^1.0.0\",\n    \"@types/chai\": \"^4.3.0\",\n    \"@types/mocha\": \"^10.0.0\",\n    \"anchor-bankrun\": \"^0.5.0\",\n    \"chai\": \"^4.4.0\",\n    \"mocha\": \"^10.7.0\",\n    \"solana-bankrun\": \"^0.4.0\",\n    \"ts-mocha\": \"^10.0.0\",\n    \"typescript\": \"^5.0.0\"\n  }\n}\n```\n\n## 5. `/workspaces/rng-utopia/sources/rng-utopia/solana/tsconfig.json`\n\n```json\n{\n  \"compilerOptions\": {\n    \"types\": [\"mocha\", \"chai\"],\n    \"typeRoots\": [\"./node_modules/@types\"],\n    \"lib\": [\"es2020\"],\n    \"module\": \"commonjs\",\n    \"target\": \"es2020\",\n    \"esModuleInterop\": true,\n    \"resolveJsonModule\": true,\n    \"moduleResolution\": \"node\",\n    \"sourceMap\": true,\n    \"outDir\": \"./dist\",\n    \"baseUrl\": \".\"\n  },\n  \"include\": [\"tests/**/*.ts\"]\n}\n```\n\n## 6. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/Cargo.toml`\n\n```toml\n[package]\nname = \"coinflip\"\nversion = \"0.1.0\"\nedition = \"2021\"\n\n[lib]\ncrate-type = [\"cdylib\", \"lib\"]\nname = \"coinflip\"\n\n[dependencies]\nanchor-lang = { workspace = true }\nrng-shared = { workspace = true }\nplatform = { path = \"../platform\", features = [\"cpi\"] }\norao-solana-vrf = { workspace = true }\n\n[features]\nno-entrypoint = []\nno-idl = []\nno-log-ix-name = []\ncpi = [\"no-entrypoint\"]\ndefault = [\"mock-vrf\"]\nmock-vrf = [\"rng-shared/mock-vrf\"]\nidl-build = [\"anchor-lang/idl-build\"]\n```\n\n## 7. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/platform/src/lib.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\npub mod error;\npub mod instructions;\npub mod state;\n\nuse instructions::*;\n\ndeclare_id!(\"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\");\n\n#[program]\npub mod platform {\n    use super::*;\n\n    pub fn initialize_platform(ctx: Context<InitializePlatform>, treasury: Pubkey) -> Result<()> {\n        instructions::initialize_platform::handler(ctx, treasury)\n    }\n\n    pub fn create_player_profile(ctx: Context<CreatePlayerProfile>) -> Result<()> {\n        instructions::create_player_profile::handler(ctx)\n    }\n\n    pub fn update_player_profile(\n        ctx: Context<UpdatePlayerProfile>,\n        wager_amount: u64,\n        won_amount: u64,\n        is_winner: bool,\n    ) -> Result<()> {\n        instructions::update_player_profile::handler(ctx, wager_amount, won_amount, is_winner)\n    }\n}\n```\n\n## 8. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/platform/src/state.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\n/// Global platform configuration. Singleton PDA.\n/// Seeds: [b\"platform_config\"]\n#[account]\n#[derive(InitSpace)]\npub struct PlatformConfig {\n    /// The admin authority that can update config.\n    pub authority: Pubkey,\n    /// Treasury wallet that receives platform fees.\n    pub treasury: Pubkey,\n    /// Total fee in basis points (e.g., 300 = 3%).\n    pub fee_bps: u16,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n\n/// Player profile tracking game stats. One per wallet.\n/// Seeds: [b\"player_profile\", wallet.as_ref()]\n#[account]\n#[derive(InitSpace)]\npub struct PlayerProfile {\n    /// The wallet this profile belongs to.\n    pub authority: Pubkey,\n    /// Total number of games played.\n    pub total_games: u64,\n    /// Total wins.\n    pub wins: u64,\n    /// Total SOL wagered (in lamports).\n    pub total_wagered: u64,\n    /// Total SOL won (in lamports).\n    pub total_won: u64,\n    /// Bump seed for PDA derivation.\n    pub bump: u8,\n}\n```\n\n## Directory Listing: `/workspaces/rng-utopia/sources/rng-utopia/solana/tests/`\n\nThe tests directory contains:\n1. `/workspaces/rng-utopia/sources/rng-utopia/solana/tests/coinflip.ts` (provided above)\n2. `/workspaces/rng-utopia/sources/rng-utopia/solana/tests/devnet-integration.md`\n3. `/workspaces/rng-utopia/sources/rng-utopia/solana/tests/platform.ts`"},{"type":"text","text":"agentId: ab7301ea8a0052e5f (for resuming to continue this agent's work if needed)\n<usage>total_tokens: 54192\ntool_uses: 9\nduration_ms: 71151</usage>"}]}]},"parent_tool_use_id":null,"session_id":"26c7f4cc-b2b2-41aa-85e9-beee2a3d95f1","uuid":"c82c7a53-28c0-4617-90e2-64212537fa5e","tool_use_result":{"status":"completed","prompt":"Read the following files and report their complete contents back to me. I need ALL the code:\n\n1. `sources/rng-utopia/solana/tests/coinflip.ts`\n2. `sources/rng-utopia/solana/Anchor.toml`\n3. `sources/rng-utopia/solana/Cargo.toml`\n4. `sources/rng-utopia/solana/package.json`\n5. `sources/rng-utopia/solana/tsconfig.json`\n6. `sources/rng-utopia/solana/programs/coinflip/Cargo.toml`\n7. `sources/rng-utopia/solana/programs/platform/src/lib.rs`\n8. `sources/rng-utopia/solana/programs/platform/src/state.rs`\n\nAlso check if there's a `sources/rng-utopia/solana/tests/` directory and list all files in it.","agentId":"ab7301ea8a0052e5f","content":[{"type":"text","text":"Perfect! Here are all the files you requested:\n\n## 1. `/workspaces/rng-utopia/sources/rng-utopia/solana/tests/coinflip.ts`\n\n```typescript\nimport { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  SYSVAR_SLOT_HASHES_PUBKEY,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Coinflip } from \"../target/types/coinflip\";\nimport type { Platform } from \"../target/types/platform\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\nconst PLATFORM_IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n);\nconst PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n\n// ---------------------------------------------------------------------------\n// Constants matching shared crate\n// ---------------------------------------------------------------------------\nconst SIDE_HEADS = 0;\nconst SIDE_TAILS = 1;\nconst PHASE_WAITING = 0;\nconst PHASE_LOCKED = 1;\nconst PHASE_SETTLED = 2;\nconst TIER_IRON = 0;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL in lamports\nconst TOTAL_FEE_BPS = 300;\n\n// VRF mock constants\nconst RANDOMNESS_HEADS = new Array(32).fill(0); // byte[0]=0 (even) → HEADS\nconst RANDOMNESS_TAILS = (() => {\n  const arr = new Array(32).fill(0);\n  arr[0] = 1; // byte[0]=1 (odd) → TAILS\n  return arr;\n})();\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getMatchPda(creator: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlatformConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlayerProfilePda(wallet: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Bankrun context factory — fresh state per test\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\n// Real VRF constants — match ephemeral-vrf-sdk consts.rs\nconst VRF_PROGRAM_ADDRESS = new PublicKey(\"Vrf1RNUjXmQGjmQrQLvJHs9SNkvDJEsRVFPkfSQUwGz\");\nconst VRF_DEFAULT_QUEUE = new PublicKey(\"Cuj97ggrhhidhbu39TijNVqE74xvKJ69gDervRUXAxGh\");\n\n// Derive program_identity PDA: seeds=[b\"identity\"], program=coinflip\nconst [PROGRAM_IDENTITY_PDA] = PublicKey.findProgramAddressSync(\n  [Buffer.from(\"identity\")],\n  PROGRAM_ID\n);\n\ninterface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  opponent: Keypair;\n  oracle: Keypair;\n  treasury: Keypair;\n  creatorProgram: Program<Coinflip>;\n  opponentProgram: Program<Coinflip>;\n  oracleProgram: Program<Coinflip>;\n  platformProgram: Program<Platform>;\n  opponentPlatformProgram: Program<Platform>;\n  configPda: PublicKey;\n  matchPda: PublicKey;\n  platformConfigPda: PublicKey;\n  creatorProfilePda: PublicKey;\n  opponentProfilePda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const opponent = Keypair.generate();\n  const oracle = Keypair.generate();\n  const treasury = Keypair.generate();\n\n  const context = await startAnchor(\"./\", [], [\n    { address: opponent.publicKey, info: fundedAccountData() },\n    { address: oracle.publicKey, info: fundedAccountData() },\n    { address: treasury.publicKey, info: fundedAccountData() },\n    // Mock VRF accounts at real addresses so #[vrf] macro constraints pass\n    { address: VRF_DEFAULT_QUEUE, info: fundedAccountData(LAMPORTS_PER_SOL) },\n    { address: PROGRAM_IDENTITY_PDA, info: fundedAccountData(LAMPORTS_PER_SOL) },\n  ]);\n\n  // Load a dummy program at the VRF program address.\n  // Anchor's Program<> type checks executable=true + matching address.\n  // Reuse the coinflip .so as a no-op stand-in (we never CPI into it in mock mode).\n  context.setAccount(VRF_PROGRAM_ADDRESS, {\n    lamports: LAMPORTS_PER_SOL,\n    data: readFileSync(join(__dirname, \"..\", \"target\", \"deploy\", \"coinflip.so\")),\n    owner: new PublicKey(\"BPFLoader2111111111111111111111111111111111\"),\n    executable: true,\n  });\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n\n  const opponentProvider = new BankrunProvider(\n    context,\n    new Wallet(opponent)\n  );\n  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n\n  const oracleProvider = new BankrunProvider(context, new Wallet(oracle));\n  const oracleProgram = new Program<Coinflip>(IDL, oracleProvider);\n\n  // Platform program instances\n  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n  const opponentPlatformProgram = new Program<Platform>(PLATFORM_IDL, opponentProvider);\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n  const matchPda = getMatchPda(creator);\n  const platformConfigPda = getPlatformConfigPda();\n  const creatorProfilePda = getPlayerProfilePda(creator);\n  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n\n  return {\n    context,\n    creator,\n    opponent,\n    oracle,\n    treasury,\n    creatorProgram,\n    opponentProgram,\n    oracleProgram,\n    platformProgram,\n    opponentPlatformProgram,\n    configPda,\n    matchPda,\n    platformConfigPda,\n    creatorProfilePda,\n    opponentProfilePda,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Helpers — call instructions\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.oracle.publicKey, t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function initPlatform(t: TestContext) {\n  await t.platformProgram.methods\n    .initializePlatform(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.platformConfigPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createPlayerProfile(t: TestContext, program: Program<Platform>, player: PublicKey) {\n  const profilePda = getPlayerProfilePda(player);\n  await program.methods\n    .createPlayerProfile()\n    .accounts({\n      player,\n      profile: profilePda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function setupPlatform(t: TestContext) {\n  await initPlatform(t);\n  await createPlayerProfile(t, t.platformProgram, t.creator);\n  await createPlayerProfile(t, t.opponentPlatformProgram, t.opponent.publicKey);\n}\n\nasync function createMatch(\n  t: TestContext,\n  tier = TIER_IRON,\n  side = SIDE_HEADS\n) {\n  await t.creatorProgram.methods\n    .createMatch(tier, side)\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function joinMatch(t: TestContext) {\n  await t.opponentProgram.methods\n    .joinMatch()\n    .accounts({\n      opponent: t.opponent.publicKey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      oracleQueue: VRF_DEFAULT_QUEUE,\n      programIdentity: PROGRAM_IDENTITY_PDA,\n      vrfProgram: VRF_PROGRAM_ADDRESS,\n      slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function resolveMatch(t: TestContext, randomness: number[]) {\n  await t.oracleProgram.methods\n    .resolveMatch(randomness)\n    .accounts({\n      oracle: t.oracle.publicKey,\n      config: t.configPda,\n      coinflipMatch: t.matchPda,\n    })\n    .rpc();\n}\n\nasync function claimPayout(t: TestContext, winnerProgram: Program<Coinflip>, winnerPubkey: PublicKey) {\n  await winnerProgram.methods\n    .claimPayout()\n    .accounts({\n      winner: winnerPubkey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      treasury: t.treasury.publicKey,\n      creator: t.creator,\n      creatorProfile: t.creatorProfilePda,\n      opponentProfile: t.opponentProfilePda,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function cancelMatch(t: TestContext) {\n  await t.creatorProgram.methods\n    .cancelMatch()\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n  const account = await t.context.banksClient.getAccount(pubkey);\n  return account ? Number(account.lamports) : 0;\n}\n\n// ===========================================================================\n// Tests\n// ===========================================================================\ndescribe(\"coinflip\", () => {\n  // -------------------------------------------------------------------------\n  // initialize_config\n  // -------------------------------------------------------------------------\n  describe(\"initialize_config\", () => {\n    it(\"creates config with oracle and treasury\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n\n      const config = await t.creatorProgram.account.coinflipConfig.fetch(\n        t.configPda\n      );\n      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n      expect(config.oracleAuthority.toBase58()).to.equal(\n        t.oracle.publicKey.toBase58()\n      );\n      expect(config.treasury.toBase58()).to.equal(\n        t.treasury.publicKey.toBase58()\n      );\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // create_match\n  // -------------------------------------------------------------------------\n  describe(\"create_match\", () => {\n    it(\"creates a coinflip match\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.creator.toBase58()).to.equal(t.creator.toBase58());\n      expect(match.opponent.toBase58()).to.equal(\n        PublicKey.default.toBase58()\n      );\n      expect(match.tier).to.equal(TIER_IRON);\n      expect(match.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(match.creatorSide).to.equal(SIDE_HEADS);\n      expect(match.phase).to.equal(PHASE_WAITING);\n      expect(match.result).to.equal(0);\n      expect(match.winner.toBase58()).to.equal(PublicKey.default.toBase58());\n      expect(match.claimed).to.equal(false);\n    });\n\n    it(\"rejects invalid side\", async () => {\n      const t = await createTestContext();\n\n      try {\n        await t.creatorProgram.methods\n          .createMatch(TIER_IRON, 3)\n          .accounts({\n            creator: t.creator,\n            coinflipMatch: t.matchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidSide error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidSide\");\n        expect(anchorErr.error.errorCode.number).to.equal(6100);\n      }\n    });\n\n    it(\"rejects invalid tier\", async () => {\n      const t = await createTestContext();\n\n      try {\n        await t.creatorProgram.methods\n          .createMatch(99, SIDE_HEADS)\n          .accounts({\n            creator: t.creator,\n            coinflipMatch: t.matchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidTier error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidTier\");\n        expect(anchorErr.error.errorCode.number).to.equal(6101);\n      }\n    });\n\n    it(\"escrows correct lamport amount\", async () => {\n      const t = await createTestContext();\n      const balanceBefore = await getBalance(t, t.creator);\n\n      await createMatch(t);\n\n      const matchBalance = await getBalance(t, t.matchPda);\n      // Match PDA holds escrow + rent-exempt minimum\n      const matchAccount = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      const rentLamports =\n        matchBalance - matchAccount.entryAmount.toNumber();\n      expect(rentLamports).to.be.greaterThan(0);\n      expect(matchAccount.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n\n      const balanceAfter = await getBalance(t, t.creator);\n      // Creator paid entry_amount + rent + transaction fee\n      const spent = balanceBefore - balanceAfter;\n      expect(spent).to.be.greaterThanOrEqual(matchBalance);\n      // Transaction fee is 5000 lamports\n      expect(spent - matchBalance).to.equal(5000);\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // join_match\n  // -------------------------------------------------------------------------\n  describe(\"join_match\", () => {\n    it(\"opponent joins, phase transitions to LOCKED, escrow doubled\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      const balanceBefore = await getBalance(t, t.matchPda);\n      await joinMatch(t);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.opponent.toBase58()).to.equal(\n        t.opponent.publicKey.toBase58()\n      );\n      expect(match.phase).to.equal(PHASE_LOCKED);\n\n      const balanceAfter = await getBalance(t, t.matchPda);\n      // Escrow should have doubled (both players deposited entry_amount)\n      expect(balanceAfter - balanceBefore).to.equal(TIER_IRON_AMOUNT);\n    });\n\n    it(\"rejects creator joining own match\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      try {\n        // Creator tries to join as opponent\n        await t.creatorProgram.methods\n          .joinMatch()\n          .accounts({\n            opponent: t.creator,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            oracleQueue: VRF_DEFAULT_QUEUE,\n            programIdentity: PROGRAM_IDENTITY_PDA,\n            vrfProgram: VRF_PROGRAM_ADDRESS,\n            slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected CannotJoinOwnMatch error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"CannotJoinOwnMatch\");\n        expect(anchorErr.error.errorCode.number).to.equal(6104);\n      }\n    });\n\n    it(\"rejects if not in WAITING phase\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t); // phase → LOCKED (once implemented)\n\n      try {\n        // Second opponent tries to join — fund them so tx doesn't fail pre-program\n        const secondOpponent = Keypair.generate();\n        t.context.setAccount(secondOpponent.publicKey, fundedAccountData());\n        const secondProvider = new BankrunProvider(\n          t.context,\n          new Wallet(secondOpponent)\n        );\n        const secondProgram = new Program<Coinflip>(IDL, secondProvider);\n\n        await secondProgram.methods\n          .joinMatch()\n          .accounts({\n            opponent: secondOpponent.publicKey,\n            coinflipMatch: t.matchPda,\n            config: t.configPda,\n            oracleQueue: VRF_DEFAULT_QUEUE,\n            programIdentity: PROGRAM_IDENTITY_PDA,\n            vrfProgram: VRF_PROGRAM_ADDRESS,\n            slotHashes: SYSVAR_SLOT_HASHES_PUBKEY,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // resolve_match\n  // -------------------------------------------------------------------------\n  describe(\"resolve_match\", () => {\n    it(\"HEADS when randomness[0] is even — creator wins if chose HEADS\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.result).to.equal(SIDE_HEADS);\n      expect(match.winner.toBase58()).to.equal(t.creator.toBase58());\n    });\n\n    it(\"TAILS when randomness[0] is odd — opponent wins if creator chose HEADS\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_TAILS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.result).to.equal(SIDE_TAILS);\n      expect(match.winner.toBase58()).to.equal(\n        t.opponent.publicKey.toBase58()\n      );\n    });\n\n    it(\"phase transitions to SETTLED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      const match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_SETTLED);\n    });\n\n    it(\"rejects unauthorized oracle\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n\n      try {\n        // Creator (not oracle) tries to resolve\n        await t.creatorProgram.methods\n          .resolveMatch(RANDOMNESS_HEADS)\n          .accounts({\n            oracle: t.creator,\n            config: t.configPda,\n            coinflipMatch: t.matchPda,\n          })\n          .rpc();\n        expect.fail(\"Expected UnauthorizedOracle error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"UnauthorizedOracle\");\n        expect(anchorErr.error.errorCode.number).to.equal(6105);\n      }\n    });\n\n    it(\"rejects if not in LOCKED phase\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      // Skip join — match is still WAITING\n\n      try {\n        await resolveMatch(t, RANDOMNESS_HEADS);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // claim_payout\n  // -------------------------------------------------------------------------\n  describe(\"claim_payout\", () => {\n    it(\"winner gets pool minus fee, treasury gets fee\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS); // creator wins\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const winnerBefore = await getBalance(t, t.creator);\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const winnerAfter = await getBalance(t, t.creator);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      // Winner receives payout (plus rent refund from closed account)\n      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n      // Treasury receives fee\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n    });\n\n    it(\"match account closed, rent refunded to creator\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      // Match account should no longer exist\n      const matchAccount =\n        await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects double claim\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS);\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      try {\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected AlreadyClaimed error\");\n      } catch (err) {\n        // Account is closed so this should fail (either AlreadyClaimed or account not found)\n        expect(err).to.exist;\n      }\n    });\n\n    it(\"rejects claim by loser\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_TAILS); // opponent wins\n\n      try {\n        // Creator (loser) tries to claim\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected NotWinner error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"NotWinner\");\n        expect(anchorErr.error.errorCode.number).to.equal(6107);\n      }\n    });\n\n    it(\"rejects if not SETTLED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      // Skip join + resolve — match is WAITING\n\n      try {\n        await claimPayout(t, t.creatorProgram, t.creator);\n        expect.fail(\"Expected InvalidPhase error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"InvalidPhase\");\n        expect(anchorErr.error.errorCode.number).to.equal(6102);\n      }\n    });\n\n    it(\"updates player profiles via CPI — creator wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_HEADS); // creator wins\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Creator (winner) profile\n      const creatorProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(creatorProfile.totalGames.toNumber()).to.equal(1);\n      expect(creatorProfile.wins.toNumber()).to.equal(1);\n      expect(creatorProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(creatorProfile.totalWon.toNumber()).to.equal(payout);\n\n      // Opponent (loser) profile\n      const opponentProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(opponentProfile.totalGames.toNumber()).to.equal(1);\n      expect(opponentProfile.wins.toNumber()).to.equal(0);\n      expect(opponentProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(opponentProfile.totalWon.toNumber()).to.equal(0);\n    });\n\n    it(\"updates player profiles via CPI — opponent wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      await resolveMatch(t, RANDOMNESS_TAILS); // opponent wins\n\n      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      // Creator (loser) profile\n      const creatorProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(creatorProfile.totalGames.toNumber()).to.equal(1);\n      expect(creatorProfile.wins.toNumber()).to.equal(0);\n      expect(creatorProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(creatorProfile.totalWon.toNumber()).to.equal(0);\n\n      // Opponent (winner) profile\n      const opponentProfile = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(opponentProfile.totalGames.toNumber()).to.equal(1);\n      expect(opponentProfile.wins.toNumber()).to.equal(1);\n      expect(opponentProfile.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(opponentProfile.totalWon.toNumber()).to.equal(payout);\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // cancel_match\n  // -------------------------------------------------------------------------\n  describe(\"cancel_match\", () => {\n    it(\"creator cancels WAITING match, full refund\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      const balanceBefore = await getBalance(t, t.creator);\n\n      await cancelMatch(t);\n\n      const balanceAfter = await getBalance(t, t.creator);\n      // Creator gets back entry_amount + rent\n      expect(balanceAfter - balanceBefore).to.be.greaterThanOrEqual(\n        TIER_IRON_AMOUNT\n      );\n\n      // Match account should be closed\n      const matchAccount =\n        await t.context.banksClient.getAccount(t.matchPda);\n      expect(matchAccount).to.be.null;\n    });\n\n    it(\"rejects cancel after LOCKED\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n      await joinMatch(t); // phase → LOCKED (once implemented)\n\n      try {\n        await cancelMatch(t);\n        expect.fail(\"Expected CannotCancel error\");\n      } catch (err) {\n        expect(err).to.be.instanceOf(AnchorError);\n        const anchorErr = err as AnchorError;\n        expect(anchorErr.error.errorCode.code).to.equal(\"CannotCancel\");\n        expect(anchorErr.error.errorCode.number).to.equal(6108);\n      }\n    });\n\n    it(\"rejects cancel by non-creator\", async () => {\n      const t = await createTestContext();\n      await createMatch(t);\n\n      // Opponent tries to cancel creator's match\n      // The PDA seeds [b\"match\", creator.key()] won't match opponent's key\n      // so this should fail with a constraint error\n      const opponentMatchPda = getMatchPda(t.opponent.publicKey);\n\n      try {\n        await t.opponentProgram.methods\n          .cancelMatch()\n          .accounts({\n            creator: t.opponent.publicKey,\n            coinflipMatch: opponentMatchPda,\n            systemProgram: SystemProgram.programId,\n          })\n          .rpc();\n        expect.fail(\"Expected constraint error\");\n      } catch (err) {\n        // PDA [b\"match\", opponent_key] doesn't exist → AccountNotInitialized\n        expect(err).to.exist;\n      }\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // full lifecycle\n  // -------------------------------------------------------------------------\n  describe(\"full lifecycle\", () => {\n    it(\"create → join → resolve(HEADS) → claim\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n\n      // 1. Create\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      let match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_WAITING);\n\n      // 2. Join\n      await joinMatch(t);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.phase).to.equal(PHASE_LOCKED);\n\n      // 3. Resolve — HEADS → creator wins\n      await resolveMatch(t, RANDOMNESS_HEADS);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.phase).to.equal(PHASE_SETTLED);\n      expect(match.winner.toBase58()).to.equal(t.creator.toBase58());\n\n      // 4. Claim\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n\n      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n      await claimPayout(t, t.creatorProgram, t.creator);\n      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n\n      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n\n      // Match account closed\n      const closed = await t.context.banksClient.getAccount(t.matchPda);\n      expect(closed).to.be.null;\n    });\n\n    it(\"create → cancel → create again\", async () => {\n      const t = await createTestContext();\n\n      // 1. Create\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      let match = await t.creatorProgram.account.coinflipMatch.fetch(\n        t.matchPda\n      );\n      expect(match.phase).to.equal(PHASE_WAITING);\n\n      // 2. Cancel\n      await cancelMatch(t);\n      const closed = await t.context.banksClient.getAccount(t.matchPda);\n      expect(closed).to.be.null;\n\n      // 3. Create again (same PDA slot is free)\n      await createMatch(t, TIER_IRON, SIDE_TAILS);\n      match = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n      expect(match.creatorSide).to.equal(SIDE_TAILS);\n      expect(match.phase).to.equal(PHASE_WAITING);\n    });\n  });\n});\n```\n\n## 2. `/workspaces/rng-utopia/sources/rng-utopia/solana/Anchor.toml`\n\n```toml\n[toolchain]\nanchor_version = \"0.32.1\"\n\n[features]\nresolution = true\nskip-lint = false\n\n[programs.localnet]\ncoinflip = \"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\"\nplatform = \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n\n[programs.devnet]\ncoinflip = \"H8Q2R1bUxzfUkV6WRRiZxYWwGfCr794AcnskWpsRQJf3\"\nplatform = \"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\"\n\n[registry]\nurl = \"https://api.apr.dev\"\n\n[provider]\ncluster = \"Localnet\"\nwallet = \"~/.config/solana/id.json\"\n\n[scripts]\ntest = \"pnpm exec ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts\"\n```\n\n## 3. `/workspaces/rng-utopia/sources/rng-utopia/solana/Cargo.toml`\n\n```toml\n[workspace]\nmembers = [\n    \"shared\",\n    \"programs/coinflip\",\n    \"programs/platform\",\n]\nresolver = \"2\"\n\n[workspace.dependencies]\nanchor-lang = \"0.32.1\"\norao-solana-vrf = { version = \"0.7.0\", default-features = false, features = [\"cpi\"] }\nrng-shared = { path = \"shared\" }\nsolana-sha256-hasher = \"2.3\"\n\n[profile.release]\noverflow-checks = true\nlto = \"fat\"\ncodegen-units = 1\n\n[profile.release.build-override]\nopt-level = 3\nincremental = false\ncodegen-units = 1\n```\n\n## 4. `/workspaces/rng-utopia/sources/rng-utopia/solana/package.json`\n\n```json\n{\n  \"name\": \"rng-utopia-programs\",\n  \"private\": true,\n  \"type\": \"module\",\n  \"scripts\": {\n    \"test\": \"anchor test --skip-local-validator --skip-deploy\"\n  },\n  \"dependencies\": {\n    \"@coral-xyz/anchor\": \"^0.32.1\",\n    \"@solana/web3.js\": \"^1.95.0\"\n  },\n  \"devDependencies\": {\n    \"@orao-network/solana-vrf\": \"^0.8.0\",\n    \"@switchboard-xyz/solana-randomness-service\": \"^1.0.0\",\n    \"@types/chai\": \"^4.3.0\",\n    \"@types/mocha\": \"^10.0.0\",\n    \"anchor-bankrun\": \"^0.5.0\",\n    \"chai\": \"^4.4.0\",\n    \"mocha\": \"^10.7.0\",\n    \"solana-bankrun\": \"^0.4.0\",\n    \"ts-mocha\": \"^10.0.0\",\n    \"typescript\": \"^5.0.0\"\n  }\n}\n```\n\n## 5. `/workspaces/rng-utopia/sources/rng-utopia/solana/tsconfig.json`\n\n```json\n{\n  \"compilerOptions\": {\n    \"types\": [\"mocha\", \"chai\"],\n    \"typeRoots\": [\"./node_modules/@types\"],\n    \"lib\": [\"es2020\"],\n    \"module\": \"commonjs\",\n    \"target\": \"es2020\",\n    \"esModuleInterop\": true,\n    \"resolveJsonModule\": true,\n    \"moduleResolution\": \"node\",\n    \"sourceMap\": true,\n    \"outDir\": \"./dist\",\n    \"baseUrl\": \".\"\n  },\n  \"include\": [\"tests/**/*.ts\"]\n}\n```\n\n## 6. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/Cargo.toml`\n\n```toml\n[package]\nname = \"coinflip\"\nversion = \"0.1.0\"\nedition = \"2021\"\n\n[lib]\ncrate-type = [\"cdylib\", \"lib\"]\nname = \"coinflip\"\n\n[dependencies]\nanchor-lang = { workspace = true }\nrng-shared = { workspace = true }\nplatform = { path = \"../platform\", features = [\"cpi\"] }\norao-solana-vrf = { workspace = true }\n\n[features]\nno-entrypoint = []\nno-idl = []\nno-log-ix-name = []\ncpi = [\"no-entrypoint\"]\ndefault = [\"mock-vrf\"]\nmock-vrf = [\"rng-shared/mock-vrf\"]\nidl-build = [\"anchor-lang/idl-build\"]\n```\n\n## 7. `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/platform/src/lib.rs`\n\n```rust\nuse anchor_lang::prelude::*;\n\npub mod error;\npub mod instructions;\npub mod state;\n\nuse instructions::*;\n\ndeclare_id!(\"dYJcBccf1M7yDePcgmiytiEtwr7n4fAaLQAhVPNHgVM\");\n\n#[program]\npub mod platform {\n    use super::*;\n\n    pub fn initialize_platform(ctx: Context<InitializePlatform>, treasury: Pubkey) -> Result<()> {\n        instructions::initialize_platform::handler(ctx, treasury)\n    }\n\n    pub fn create_player_profile(ctx: Context<CreatePlayerProfile>) -> Result<()> {\n        instructions::create_player_profile::handler(ctx)\n    }\n\n    pub fn update_player_profile(\n        ctx: Context<UpdatePlayerProf