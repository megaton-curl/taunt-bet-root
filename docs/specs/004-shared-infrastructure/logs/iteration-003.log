ed\").is_err());\n    }\n\n    #[test]\n    fn empty_seed_fails() {\n        let seed = b\"non_empty_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"\").is_err());\n    }\n}\n","numLines":57,"startLine":1,"totalLines":57}}}
