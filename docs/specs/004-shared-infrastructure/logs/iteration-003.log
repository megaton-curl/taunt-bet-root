{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AUpN51LD2XnXtaxQjwK3RB","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::solana_program::hash::hashv;\n     3→\n     4→#[error_code]\n     5→pub enum CommitRevealError {\n     6→    #[msg(\"Commitment mismatch: SHA256(server_seed) does not match stored commitment\")]\n     7→    CommitmentMismatch,\n     8→}\n     9→\n    10→/// Writes a commitment hash into the provided storage slot.\n    11→pub fn store_commitment(commitment: &mut [u8; 32], hash: [u8; 32]) {\n    12→    *commitment = hash;\n    13→}\n    14→\n    15→/// Verifies that `SHA256(server_seed)` matches the stored commitment.\n    16→pub fn verify_reveal(commitment: &[u8; 32], server_seed: &[u8]) -> Result<()> {\n    17→    let computed = hashv(&[server_seed]);\n    18→    if computed.to_bytes() == *commitment {\n    19→        Ok(())\n    20→    } else {\n    21→        Err(CommitRevealError::CommitmentMismatch.into())\n    22→    }\n    23→}\n    24→\n    25→#[cfg(test)]\n    26→mod tests {\n    27→    use super::*;\n    28→    use anchor_lang::solana_program::hash::hashv as sha256;\n    29→\n    30→    #[test]\n    31→    fn known_pair_passes() {\n    32→        let seed = b\"known_server_seed_1234\";\n    33→        let hash = sha256(&[seed]);\n    34→        let mut commitment = [0u8; 32];\n    35→        store_commitment(&mut commitment, hash.to_bytes());\n    36→        assert!(verify_reveal(&commitment, seed).is_ok());\n    37→    }\n    38→\n    39→    #[test]\n    40→    fn tampered_seed_fails() {\n    41→        let seed = b\"original_seed\";\n    42→        let hash = sha256(&[seed]);\n    43→        let mut commitment = [0u8; 32];\n    44→        store_commitment(&mut commitment, hash.to_bytes());\n    45→        assert!(verify_reveal(&commitment, b\"tampered_seed\").is_err());\n    46→    }\n    47→\n    48→    #[test]\n    49→    fn empty_seed_fails() {\n    50→        let