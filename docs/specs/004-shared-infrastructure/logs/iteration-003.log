{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MGCTJiahZWjuzmrkmH2B2p","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BzQmxd2CSztmseDhZYgeoo","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/commit_reveal.rs","content":"use anchor_lang::prelude::*;\nuse solana_program::hash::hashv;\n\n#[error_code]\npub enum CommitRevealError {\n    #[msg(\"Commitment mismatch: SHA256(server_seed) does not match stored commitment\")]\n    CommitmentMismatch,\n}\n\n/// Writes a commitment hash into the provided storage slot.\npub fn store_commitment(commitment: &mut [u8; 32], hash: [u8; 32]) {\n    *commitment = hash;\n}\n\n/// Verifies that `SHA256(server_seed)` matches the stored commitment.\npub fn verify_reveal(commitment: &[u8; 32], server_seed: &[u8]) -> Result<()> {\n    let computed = hashv(&[server_seed]);\n    if computed.to_bytes() == *commitment {\n        Ok(())\n    } else {\n        Err(CommitRevealError::CommitmentMismatch.into())\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use solana_program::hash::hashv as sha256;\n\n    #[test]\n    fn known_pair_passes() {\n        let seed = b\"known_server_seed_1234\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, seed).is_ok());\n    }\n\n    #[test]\n    fn tampered_seed_fails() {\n        let seed = b\"original_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"tampered_seed\").is_err());\n    }\n\n    #[test]\n    fn empty_seed_fails() {\n        let seed = b\"non_empty_seed\";\n        let hash = sha256(&[seed]);\n        let mut commitment = [0u8; 32];\n        store_commitment(&mut commitment, hash.to_bytes());\n        assert!(verify_reveal(&commitment, b\"\").is_err());\n    }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3204,"cache_read_input_tokens":46556,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3204},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c8750bb3-0ef3-4d3a-84d0-49ed076a7a63","uuid":"b90964e7-aac4-47ec-953f-e2a39f48fa04"}
