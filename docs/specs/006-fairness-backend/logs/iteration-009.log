{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sa8eWBtN3MeQyQLGqEEvDt","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_to_pda;\n     3→use rng_shared::fairness::ENTROPY_SLOT_OFFSET;\n     4→use rng_shared::timeout::COINFLIP_RESOLVE_TIMEOUT_SECONDS;\n     5→\n     6→use crate::error::CoinflipError;\n     7→use crate::state::{CoinflipConfig, CoinflipMatch, PHASE_LOCKED, PHASE_WAITING};\n     8→\n     9→/// Opponent joins a match and deposits SOL. Sets target_slot for entropy.\n    10→#[derive(Accounts)]\n    11→pub struct JoinMatch<'info> {\n    12→    /// The opponent joining the match. Must sign and fund their escrow.\n    13→    #[account(mut)]\n    14→    pub opponent: Signer<'info>,\n    15→\n    16→    /// The match PDA to join.\n    17→    #[account(\n    18→        mut,\n    19→        seeds = [b\"match\", coinflip_match.creator.as_ref(), &coinflip_match.nonce.to_le_bytes()],\n    20→        bump = coinflip_match.bump,\n    21→    )]\n    22→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    23→\n    24→    /// The config PDA.\n    25→    #[account(\n    26→        seeds = [b\"coinflip_config\"],\n    27→        bump = config.bump,\n    28→    )]\n    29→    pub config: Account<'info, CoinflipConfig>,\n    30→\n    31→    pub system_program: Program<'info, System>,\n    32→}\n    33→\n    34→pub fn handler(ctx: Context<JoinMatch>) -> Result<()> {\n    35→    let coinflip_match = &ctx.accounts.coinflip_match;\n    36→\n    37→    require!(\n    38→        coinflip_match.phase == PHASE_WAITING,\n    39→        CoinflipError::InvalidPhase\n    40→    );\n    41→\n    42→    require!(\n    43→        ctx.accounts.opponent.key() != coinflip_match.creator,\n    44→        CoinflipError::CannotJoinOwnMatch\n    45→    );\n    46→\n    47→    let entry_amount = coinflip_match.entry_amount;\n    48→    let opponent_key = ctx.accounts.opponent.key();\n    49→\n    50→    transfer_lamports_to_pda(\n    51→        &ctx.accounts.opponent.to_account_info(),\n    52→        &ctx.accounts.coinflip_match.to_account_info(),\n    53→        entry_amount,\n    54→        &ctx.accounts.system_program.to_account_info(),\n    55→    )?;\n    56→\n    57→    let now = Clock::get()?;\n    58→    let m = &mut ctx.accounts.coinflip_match;\n    59→    m.opponent = opponent_key;\n    60→    m.target_slot = now.slot + ENTROPY_SLOT_OFFSET;\n    61→    m.resolve_deadline = now.unix_timestamp + COINFLIP_RESOLVE_TIMEOUT_SECONDS;\n    62→    m.phase = PHASE_LOCKED;\n    63→\n    64→    Ok(())\n    65→}\n    66→"}]},"parent_tool_use_id":"toolu_01MwXDoXYxA3esW1KxnPrP4n","session_id":"fa98a4f2-a7e5-449d-8951-5905b3595daa","uuid":"e4e9ffad-5262-4de1-8c4a-b4d17bc9fbce"}
