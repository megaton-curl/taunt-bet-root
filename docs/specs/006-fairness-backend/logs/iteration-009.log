{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JTjNQktoGRAz27N4md9xaK","type":"tool_result","content":"     1→import { randomBytes, createHash } from \"node:crypto\";\n     2→import { PublicKey } from \"@solana/web3.js\";\n     3→\n     4→export const COINFLIP_PROGRAM_ID = new PublicKey(\n     5→  \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n     6→);\n     7→\n     8→/** Generate a 32-byte cryptographically secure random secret. */\n     9→export function generateSecret(): Buffer {\n    10→  return randomBytes(32);\n    11→}\n    12→\n    13→/**\n    14→ * Compute commitment = sha256(secret).\n    15→ * Matches the algorithm in packages/fairness/src/commitment.ts.\n    16→ */\n    17→export function computeCommitment(secret: Buffer): Buffer {\n    18→  return createHash(\"sha256\").update(secret).digest();\n    19→}\n    20→\n    21→/**\n    22→ * Derive match PDA using seeds [\"match\", creator, nonce.to_le_bytes()].\n    23→ * Matches the on-chain program's PDA derivation.\n    24→ */\n    25→export function deriveMatchPda(\n    26→  creator: PublicKey,\n    27→  nonce: number | bigint,\n    28→): [PublicKey, number] {\n    29→  const nonceBuf = Buffer.alloc(8);\n    30→  nonceBuf.writeBigUInt64LE(BigInt(nonce));\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    33→    COINFLIP_PROGRAM_ID,\n    34→  );\n    35→}\n    36→"}]},"parent_tool_use_id":"toolu_01Te4TMBw6dEC45ufCWLtVjH","session_id":"fa98a4f2-a7e5-449d-8951-5905b3595daa","uuid":"b6af7f74-a062-4df8-b45f-d80c460f09bd"}
