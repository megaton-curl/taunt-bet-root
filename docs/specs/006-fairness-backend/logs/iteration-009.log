{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bj8sn4yxuqvU8rnRCX4YSV","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→\n     3→export interface Config {\n     4→  port: number;\n     5→  databaseUrl: string;\n     6→  rpcUrl: string;\n     7→  serverKeypair: Keypair;\n     8→  authClockSkewSeconds: number;\n     9→  rateLimitPerWallet: number;\n    10→  rateLimitGlobal: number;\n    11→}\n    12→\n    13→function requireEnv(name: string): string {\n    14→  const value = process.env[name];\n    15→  if (!value) {\n    16→    throw new Error(`Missing required environment variable: ${name}`);\n    17→  }\n    18→  return value;\n    19→}\n    20→\n    21→function parseKeypair(raw: string): Keypair {\n    22→  try {\n    23→    const bytes = JSON.parse(raw) as number[];\n    24→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    25→  } catch {\n    26→    throw new Error(\n    27→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    28→    );\n    29→  }\n    30→}\n    31→\n    32→export function loadConfig(): Config {\n    33→  return {\n    34→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    35→    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    36→    rpcUrl: requireEnv(\"RPC_URL\"),\n    37→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    38→    authClockSkewSeconds: parseInt(\n    39→      process.env.AUTH_CLOCK_SKEW_SECONDS ?? \"60\",\n    40→      10,\n    41→    ),\n    42→    rateLimitPerWallet: parseInt(\n    43→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    44→      10,\n    45→    ),\n    46→    rateLimitGlobal: parseInt(\n    47→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    48→      10,\n    49→    ),\n    50→  };\n    51→}\n    52→"}]},"parent_tool_use_id":"toolu_01Te4TMBw6dEC45ufCWLtVjH","session_id":"fa98a4f2-a7e5-449d-8951-5905b3595daa","uuid":"261d76e5-ff1b-42ee-bc84-85cc0e9f8d79"}
