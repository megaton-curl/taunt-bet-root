{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hoc87hjjQTXWNLy4tNHsuy","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Fixed tier entry amounts in lamports.\n     4→/// Index 0 = Copper, 1 = Iron, 2 = Bronze, 3 = Silver, 4 = Gold,\n     5→/// 5 = Platinum, 6 = Diamond, 7 = Emerald\n     6→pub const TIER_AMOUNTS: [u64; 8] = [\n     7→    2_500_000,       // 0.0025 SOL — Copper\n     8→    5_000_000,       // 0.005  SOL — Iron\n     9→    10_000_000,      // 0.01   SOL — Bronze\n    10→    50_000_000,      // 0.05   SOL — Silver\n    11→    100_000_000,     // 0.1    SOL — Gold\n    12→    250_000_000,     // 0.25   SOL — Platinum\n    13→    500_000_000,     // 0.5    SOL — Diamond\n    14→    1_000_000_000,   // 1.0    SOL — Emerald\n    15→];\n    16→\n    17→pub const TIER_COUNT: usize = TIER_AMOUNTS.len();\n    18→\n    19→/// Returns the entry amount for the given tier index, or an error if out of range.\n    20→pub fn get_tier_amount(tier: u8) -> Result<u64> {\n    21→    TIER_AMOUNTS\n    22→        .get(tier as usize)\n    23→        .copied()\n    24→        .ok_or_else(|| error!(TierError::InvalidTier))\n    25→}\n    26→\n    27→#[error_code]\n    28→pub enum TierError {\n    29→    #[msg(\"Invalid tier index\")]\n    30→    InvalidTier,\n    31→}\n    32→"}]},"parent_tool_use_id":"toolu_01MwXDoXYxA3esW1KxnPrP4n","session_id":"fa98a4f2-a7e5-449d-8951-5905b3595daa","uuid":"b268c967-e1a4-402c-a262-ae4890b1bdbf"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xi8q1rqd63EnWX1SYS7D4i","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Default timeout (seconds) for VRF-based games (lordofrngs). Server has 120s to fulfill.\n     4→pub const DEFAULT_RESOLVE_TIMEOUT_SECONDS: i64 = 120;\n     5→\n     6→/// Timeout (seconds) after which a coinflip match can be publicly refunded (24 hours).\n     7→/// Separate from VRF timeout because commit-reveal settlement can be done permissionlessly,\n     8→/// so only a long backstop is needed.\n     9→pub const COINFLIP_RESOLVE_TIMEOUT_SECONDS: i64 = 86_400;\n    10→\n    11→#[error_code]\n    12→pub enum TimeoutError {\n    13→    #[msg(\"Resolve deadline has been exceeded\")]\n    14→    ResolveDeadlineExceeded,\n    15→}\n    16→\n    17→/// Returns `true` when the current time is at or past the resolve deadline.\n    18→pub fn is_expired(resolve_deadline: i64, now: i64) -> bool {\n    19→    now >= resolve_deadline\n    20→}\n    21→\n    22→/// Returns `Ok(())` if the deadline has NOT been exceeded, or an error if it has.\n    23→pub fn enforce_not_expired(resolve_deadline: i64, now: i64) -> Result<()> {\n    24→    if is_expired(resolve_deadline, now) {\n    25→        Err(TimeoutError::ResolveDeadlineExceeded.into())\n    26→    } else {\n    27→        Ok(())\n    28→    }\n    29→}\n    30→\n    31→#[cfg(test)]\n    32→mod tests {\n    33→    use super::*;\n    34→\n    35→    #[test]\n    36→    fn expired_exactly_at_deadline() {\n    37→        assert!(is_expired(1000, 1000));\n    38→    }\n    39→\n    40→    #[test]\n    41→    fn not_expired_one_second_before() {\n    42→        assert!(!is_expired(1000, 999));\n    43→    }\n    44→\n    45→    #[test]\n    46→    fn expired_one_second_after() {\n    47→        assert!(is_expired(1000, 1001));\n    48→    }\n    49→\n    50→    #[test]\n    51→    fn enforce_not_expired_ok_before_deadline() {\n    52→        assert!(enforce_not_expired(1000, 999).is_ok());\n    53→    }\n    54→\n    55→    #[test]\n    56→    fn enforce_not_expired_fails_at_deadline() {\n    57→        assert!(enforce_not_expired(1000, 1000).is_err());\n    58→    }\n    59→\n    60→    #[test]\n    61→    fn enforce_not_expired_fails_after_deadline() {\n    62→        assert!(enforce_not_expired(1000, 1001).is_err());\n    63→    }\n    64→}\n    65→"}]},"parent_tool_use_id":"toolu_01MwXDoXYxA3esW1KxnPrP4n","session_id":"fa98a4f2-a7e5-449d-8951-5905b3595daa","uuid":"9a3c765c-f3a5-4f5b-954c-9fd43e25a5b4"}
