n    99→\n   100→function getPlayerProfilePda(wallet: PublicKey): PublicKey {\n   101→  const [pda] = PublicKey.findProgramAddressSync(\n   102→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n   103→    PLATFORM_PROGRAM_ID\n   104→  );\n   105→  return pda;\n   106→}\n   107→\n   108→// ---------------------------------------------------------------------------\n   109→// Test context factory\n   110→// ---------------------------------------------------------------------------\n   111→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n   112→  return {\n   113→    lamports,\n   114→    data: Buffer.alloc(0),\n   115→    owner: SystemProgram.programId,\n   116→    executable: false,\n   117→  };\n   118→}\n   119→\n   120→interface TestContext {"}]},"parent_tool_use_id":null,"session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"32fbdffa-fae3-4696-a63e-7d74f4141b6f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/coinflip.ts","content":"import { describe, it } from \"mocha\";\nimport { expect } from \"chai\";\nimport { startAnchor, BankrunProvider } from \"anchor-bankrun\";\nimport { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\nimport anchor from \"@coral-xyz/anchor\";\nconst { BN } = anchor;\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport { Clock } from \"solana-bankrun\";\nimport { createHash } from \"crypto\";\nimport type { Coinflip } from \"../target/types/coinflip\";\nimport type { Platform } from \"../target/types/platform\";\nimport { readFileSync } from \"fs\";\nimport { dirname, join } from \"path\";\nimport { fileURLToPath } from \"url\";\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = dirname(__filename);\n\nconst IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n);\nconst PROGRAM_ID = new PublicKey(IDL.address);\n\nconst PLATFORM_IDL = JSON.parse(\n  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n);\nconst PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n\n// ---------------------------------------------------------------------------\n// Constants matching shared crate\n// ---------------------------------------------------------------------------\nconst SIDE_HEADS = 0;\nconst SIDE_TAILS = 1;\nconst TIER_COPPER = 0;\nconst TIER_COPPER_AMOUNT = 2_500_000; // 0.0025 SOL\nconst TIER_IRON = 1;\nconst TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\nconst TOTAL_FEE_BPS = 300;\nconst DEFAULT_RESOLVE_TIMEOUT = 86_400; // 24 hours (seconds)\n\n// ---------------------------------------------------------------------------\n// Crypto helpers (commit-reveal)\n// ---------------------------------------------------------------------------\nfunction sha256(data: Buffer): Buffer {\n  return createHash(\"sha256\").update(data).digest();\n}\n\nfunction computeCommitment(secret: Buffer): Buffer {\n  return sha256(secret);\n}\n\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPda: PublicKey,\n  algorithmVer: number\n): Buffer {\n  const pdaBytes = matchPda.toBuffer();\n  const verBuf = Buffer.from([algorithmVer]);\n  return sha256(Buffer.concat([secret, entropy, pdaBytes, verBuf]));\n}\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\nfunction getMatchPda(\n  creator: PublicKey,\n  nonce: number | bigint = 0\n): PublicKey {\n  const nonceBuf = Buffer.alloc(8);\n  nonceBuf.writeBigUInt64LE(BigInt(nonce));\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlatformConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\nfunction getPlayerProfilePda(wallet: PublicKey): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PLATFORM_PROGRAM_ID\n  );\n  return pda;\n}\n\n// ---------------------------------------------------------------------------\n// Test context factory\n// ---------------------------------------------------------------------------\nfunction fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n  return {\n    lamports,\n    data: Buffer.alloc(0),\n    owner: SystemProgram.programId,\n    executable: false,\n  };\n}\n\ninterface TestContext {","numLines":120,"startLine":1,"totalLines":1233}}}
