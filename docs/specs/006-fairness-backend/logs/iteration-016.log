{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018qdr5Sc6Jx4GBZyHAWUJcZ","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\n     5→import anchor from \"@coral-xyz/anchor\";\n     6→const { BN } = anchor;\n     7→import {\n     8→  Keypair,\n     9→  PublicKey,\n    10→  SystemProgram,\n    11→  LAMPORTS_PER_SOL,\n    12→} from \"@solana/web3.js\";\n    13→import { Clock } from \"solana-bankrun\";\n    14→import { createHash } from \"crypto\";\n    15→import type { Coinflip } from \"../target/types/coinflip\";\n    16→import type { Platform } from \"../target/types/platform\";\n    17→import { readFileSync } from \"fs\";\n    18→import { dirname, join } from \"path\";\n    19→import { fileURLToPath } from \"url\";\n    20→\n    21→const __filename = fileURLToPath(import.meta.url);\n    22→const __dirname = dirname(__filename);\n    23→\n    24→const IDL = JSON.parse(\n    25→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n    26→);\n    27→const PROGRAM_ID = new PublicKey(IDL.address);\n    28→\n    29→const PLATFORM_IDL = JSON.parse(\n    30→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    31→);\n    32→const PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n    33→\n    34→// ---------------------------------------------------------------------------\n    35→// Constants matching shared crate\n    36→// ---------------------------------------------------------------------------\n    37→const SIDE_HEADS = 0;\n    38→const SIDE_TAILS = 1;\n    39→const TIER_COPPER = 0;\n    40→const TIER_COPPER_AMOUNT = 2_500_000; // 0.0025 SOL\n    41→const TIER_IRON = 1;\n    42→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n    43→const TOTAL_FEE_BPS = 300;\n    44→const DEFAULT_RESOLVE_TIMEOUT = 86_400; // 24 hours (seconds)\n    45→\n    46→// ---------------------------------------------------------------------------\n    47→// Crypto helpers (commit-reveal)\n    48→// ---------------------------------------------------------------------------\n    49→function sha256(data: Buffer): Buffer {\n    50→  return createHash(\"sha256\").update(data).digest();\n    51→}\n    52→\n    53→function computeCommitment(secret: Buffer): Buffer {\n    54→  return sha256(secret);\n    55→}\n    56→\n    57→function deriveResult(\n    58→  secret: Buffer,\n    59→  entropy: Buffer,\n    60→  matchPda: PublicKey,\n    61→  algorithmVer: number\n    62→): Buffer {\n    63→  const pdaBytes = matchPda.toBuffer();\n    64→  const verBuf = Buffer.from([algorithmVer]);\n    65→  return sha256(Buffer.concat([secret, entropy, pdaBytes, verBuf]));\n    66→}\n    67→\n    68→// ---------------------------------------------------------------------------\n    69→// PDA helpers\n    70→// ---------------------------------------------------------------------------\n    71→function getMatchPda(\n    72→  creator: PublicKey,\n    73→  nonce: number | bigint = 0\n    74→): PublicKey {\n    75→  const nonceBuf = Buffer.alloc(8);\n    76→  nonceBuf.writeBigUInt64LE(BigInt(nonce));\n    77→  const [pda] = PublicKey.findProgramAddressSync(\n    78→    [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    79→    PROGRAM_ID\n    80→  );\n    81→  return pda;\n    82→}\n    83→\n    84→function getConfigPda(): PublicKey {\n    85→  const [pda] = PublicKey.findProgramAddressSync(\n    86→    [Buffer.from(\"coinflip_config\")],\n    87→    PROGRAM_ID\n    88→  );\n    89→  return pda;\n    90→}\n    91→\n    92→function getPlatformConfigPda(): PublicKey {\n    93→  const [pda] = PublicKey.findProgramAddressSync(\n    94→    [Buffer.from(\"platform_config\")],\n    95→    PLATFORM_PROGRAM_ID\n    96→  );\n    97→  return pda;\n    98→}\n    99→\n   100→function getPlayerProfilePda(wallet: PublicKey): PublicKey {\n   101→  const [pda] = PublicKey.findProgramAddressSync(\n   102→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n   103→    PLATFORM_PROGRAM_ID\n   104→  );\n   105→  return pda;\n   106→}\n   107→\n   108→// ---------------------------------------------------------------------------\n   109→// Test context factory\n   110→// ---------------------------------------------------------------------------\n   111→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n   112→  return {\n   113→    lamports,\n   114→    data: Buffer.alloc(0),\n   115→    owner: SystemProgram.programId,\n   116→    executable: false,\n   117→  };\n   118→}\n   119→\n   120→interface TestContext {\n   121→  context: Awaited<ReturnType<typeof startAnchor>>;\n   122→  creator: PublicKey;\n   123→  opponent: Keypair;\n   124→  treasury: Keypair;\n   125→  server: Keypair;\n   126→  mockEntropy: Keypair;\n   127→  creatorProgram: Program<Coinflip>;\n   128→  opponentProgram: Program<Coinflip>;\n   129→  serverProgram: Program<Coinflip>;\n   130→  platformProgram: Program<Platform>;\n   131→  opponentPlatformProgram: Program<Platform>;\n   132→  configPda: PublicKey;\n   133→  matchPda: PublicKey;\n   134→  platformConfigPda: PublicKey;\n   135→  creatorProfilePda: PublicKey;\n   136→  opponentProfilePda: PublicKey;\n   137→}\n   138→\n   139→async function createTestContext(): Promise<TestContext> {\n   140→  const opponent = Keypair.generate();\n   141→  const treasury = Keypair.generate();\n   142→  const server = Keypair.generate();\n   143→  const mockEntropy = Keypair.generate();\n   144→\n   145→  // Entropy account: 32 bytes of non-zero data\n   146→  const entropyData = Buffer.alloc(32);\n   147→  entropyData[0] = 0xab;\n   148→  entropyData[1] = 0xcd;\n   149→  entropyData[15] = 0x42;\n   150→\n   151→  const context = await startAnchor(\"./\", [], [\n   152→    { address: opponent.publicKey, info: fundedAccountData() },\n   153→    { address: treasury.publicKey, info: fundedAccountData() },\n   154→    { address: server.publicKey, info: fundedAccountData() },\n   155→    {\n   156→      address: mockEntropy.publicKey,\n   157→      info: {\n   158→        lamports: LAMPORTS_PER_SOL,\n   159→        data: entropyData,\n   160→        owner: SystemProgram.programId,\n   161→        executable: false,\n   162→      },\n   163→    },\n   164→  ]);\n   165→\n   166→  const creatorProvider = new BankrunProvider(context);\n   167→  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n   168→\n   169→  const opponentProvider = new BankrunProvider(context, new Wallet(opponent));\n   170→  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n   171→\n   172→  const serverProvider = new BankrunProvider(context, new Wallet(server));\n   173→  const serverProgram = new Program<Coinflip>(IDL, serverProvider);\n   174→\n   175→  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n   176→  const opponentPlatformProgram = new Program<Platform>(\n   177→    PLATFORM_IDL,\n   178→    opponentProvider\n   179→  );\n   180→\n   181→  const creator = creatorProvider.wallet.publicKey;\n   182→  const configPda = getConfigPda();\n   183→  const matchPda = getMatchPda(creator);\n   184→  const platformConfigPda = getPlatformConfigPda();\n   185→  const creatorProfilePda = getPlayerProfilePda(creator);\n   186→  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n   187→\n   188→  return {\n   189→    context,\n   190→    creator,\n   191→    opponent,\n   192→    treasury,\n   193→    server,\n   194→    mockEntropy,\n   195→    creatorProgram,\n   196→    opponentProgram,\n   197→    serverProgram,\n   198→    platformProgram,\n   199→    opponentPlatformProgram,\n   200→    configPda,\n   201→    matchPda,\n   202→    platformConfigPda,\n   203→    creatorProfilePda,\n   204→    opponentProfilePda,\n   205→  };\n   206→}\n   207→\n   208→// ---------------------------------------------------------------------------\n   209→// Instruction helpers\n   210→// ---------------------------------------------------------------------------\n   211→async function initConfig(t: TestContext) {\n   212→  await t.creatorProgram.methods\n   213→    .initializeConfig(t.treasury.publicKey)\n   214→    .accounts({\n   215→      authority: t.creator,\n   216→      config: t.configPda,\n   217→      systemProgram: SystemProgram.programId,\n   218→    })\n   219→    .rpc();\n   220→}\n   221→\n   222→async function initPlatform(t: TestContext) {\n   223→  await t.platformProgram.methods\n   224→    .initializePlatform(t.treasury.publicKey)\n   225→    .accounts({\n   226→      authority: t.creator,\n   227→      config: t.platformConfigPda,\n   228→      systemProgram: SystemProgram.programId,\n   229→    })\n   230→    .rpc();\n   231→}\n   232→\n   233→async function createPlayerProfile(\n   234→  t: TestContext,\n   235→  program: Program<Platform>,\n   236→  player: PublicKey\n   237→) {\n   238→  const profilePda = getPlayerProfilePda(player);\n   239→  await program.methods\n   240→    .createPlayerProfile()\n   241→    .accounts({\n   242→      player,\n   243→      profile: profilePda,\n   244→      systemProgram: SystemProgram.programId,\n   245→    })\n   246→    .rpc();\n   247→}\n   248→\n   249→async function setupPlatform(t: TestContext) {\n   250→  await initPlatform(t);\n   251→  await createPlayerProfile(t, t.platformProgram, t.creator);\n   252→  await createPlayerProfile(\n   253→    t,\n   254→    t.opponentPlatformProgram,\n   255→    t.opponent.publicKey\n   256→  );\n   257→}\n   258→\n   259→function generateSecret(): Buffer {\n   260→  const buf = Buffer.alloc(32);\n   261→  for (let i = 0; i < 32; i++) {\n   262→    buf[i] = Math.floor(Math.random() * 256);\n   263→  }\n   264→  return buf;\n   265→}\n   266→\n   267→async function createMatch(\n   268→  t: TestContext,\n   269→  secret: Buffer,\n   270→  tier = TIER_IRON,\n   271→  side = SIDE_HEADS,\n   272→  nonce = 0\n   273→) {\n   274→  const commitment = computeCommitment(secret);\n   275→  const matchPda = nonce === 0 ? t.matchPda : getMatchPda(t.creator, nonce);\n   276→  await t.creatorProgram.methods\n   277→    .createMatch(\n   278→      Array.from(commitment) as unknown as number[],\n   279→      tier,\n   280→      side,\n   281→      new BN(nonce)\n   282→    )\n   283→    .accounts({\n   284→      creator: t.creator,\n   285→      server: t.server.publicKey,\n   286→      coinflipMatch: matchPda,\n   287→      config: t.configPda,\n   288→      systemProgram: SystemProgram.programId,\n   289→    })\n   290→    .signers([t.server])\n   291→    .rpc();\n   292→}\n   293→\n   294→async function joinMatch(t: TestContext) {\n   295→  await t.opponentProgram.methods\n   296→    .joinMatch()\n   297→    .accounts({\n   298→      opponent: t.opponent.publicKey,\n   299→      coinflipMatch: t.matchPda,\n   300→      config: t.configPda,\n   301→      systemProgram: SystemProgram.programId,\n   302→    })\n   303→    .rpc();\n   304→}\n   305→\n   306→async function settle(\n   307→  t: TestContext,\n   308→  secret: Buffer,\n   309→  callerProgram?: Program<Coinflip>,\n   310→  callerPubkey?: PublicKey\n   311→) {\n   312→  const program = callerProgram ?? t.serverProgram;\n   313→  const caller = callerPubkey ?? t.server.publicKey;\n   314→  await program.methods\n   315→    .settle(Array.from(secret) as unknown as number[])\n   316→    .accounts({\n   317→      caller,\n   318→      coinflipMatch: t.matchPda,\n   319→      config: t.configPda,\n   320→      entropy: t.mockEntropy.publicKey,\n   321→      treasury: t.treasury.publicKey,\n   322→      creator: t.creator,\n   323→      opponent: t.opponent.publicKey,\n   324→      creatorProfile: t.creatorProfilePda,\n   325→      opponentProfile: t.opponentProfilePda,\n   326→      platformProgram: PLATFORM_PROGRAM_ID,\n   327→      systemProgram: SystemProgram.programId,\n   328→    })\n   329→    .rpc();\n   330→}\n   331→\n   332→async function requestRefund(\n   333→  t: TestContext,\n   334→  callerProgram: Program<Coinflip>,\n   335→  callerPubkey: PublicKey\n   336→) {\n   337→  await callerProgram.methods\n   338→    .requestRefund()\n   339→    .accounts({\n   340→      caller: callerPubkey,\n   341→      creator: t.creator,\n   342→      opponent: t.opponent.publicKey,\n   343→      coinflipMatch: t.matchPda,\n   344→    })\n   345→    .rpc();\n   346→}\n   347→\n   348→async function cancelMatch(t: TestContext) {\n   349→  await t.creatorProgram.methods\n   350→    .cancelMatch()\n   351→    .accounts({\n   352→      creator: t.creator,\n   353→      coinflipMatch: t.matchPda,\n   354→      systemProgram: SystemProgram.programId,\n   355→    })\n   356→    .rpc();\n   357→}\n   358→\n   359→async function timeoutRefund(\n   360→  t: TestContext,\n   361→  callerProgram: Program<Coinflip>,\n   362→  callerPubkey: PublicKey\n   363→) {\n   364→  await callerProgram.methods\n   365→    .timeoutRefund()\n   366→    .accounts({\n   367→      caller: callerPubkey,\n   368→      creator: t.creator,\n   369→      opponent: t.opponent.publicKey,\n   370→      coinflipMatch: t.matchPda,\n   371→    })\n   372→    .rpc();\n   373→}\n   374→\n   375→async function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n   376→  const account = await t.context.banksClient.getAccount(pubkey);\n   377→  return account ? Number(account.lamports) : 0;\n   378→}\n   379→\n   380→async function warpPastDeadline(t: TestContext) {\n   381→  const clock = await t.context.banksClient.getClock();\n   382→  t.context.setClock(\n   383→    new Clock(\n   384→      clock.slot + BigInt(300),\n   385→      clock.epochStartTimestamp,\n   386→      clock.epoch,\n   387→      clock.leaderScheduleEpoch,\n   388→      clock.unixTimestamp + BigInt(DEFAULT_RESOLVE_TIMEOUT + 10)\n   389→    )\n   390→  );\n   391→}\n   392→\n   393→// ===========================================================================\n   394→// Tests\n   395→// ===========================================================================\n   396→describe(\"coinflip\", () => {\n   397→  // -----------------------------------------------------------------------\n   398→  // initialize_config\n   399→  // -----------------------------------------------------------------------\n   400→  describe(\"initialize_config\", () => {\n   401→    it(\"creates config with treasury and paused=false\", async () => {\n   402→      const t = await createTestContext();\n   403→      await initConfig(t);\n   404→\n   405→      const config = await t.creatorProgram.account.coinflipConfig.fetch(\n   406→        t.configPda\n   407→      );\n   408→      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n   409→      expect(config.treasury.toBase58()).to.equal(\n   410→        t.treasury.publicKey.toBase58()\n   411→      );\n   412→      expect(config.paused).to.equal(false);\n   413→    });\n   414→  });\n   415→\n   416→  // -----------------------------------------------------------------------\n   417→  // create_match\n   418→  // -----------------------------------------------------------------------\n   419→  describe(\"create_match\", () => {\n   420→    it(\"creates match in Waiting phase with correct escrow and commitment\", async () => {\n   421→      const t = await createTestContext();\n   422→      await initConfig(t);\n   423→      const secret = generateSecret();\n   424→      await createMatch(t, secret);\n   425→\n   426→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   427→      expect(m.creator.toBase58()).to.equal(t.creator.toBase58());\n   428→      expect(m.opponent.toBase58()).to.equal(PublicKey.default.toBase58());\n   429→      expect(m.server.toBase58()).to.equal(t.server.publicKey.toBase58());\n   430→      expect(m.tier).to.equal(TIER_IRON);\n   431→      expect(m.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   432→      expect(m.creatorSide).to.equal(SIDE_HEADS);\n   433→      expect(m.phase).to.equal(0); // WAITING\n   434→      expect(m.algorithmVer).to.equal(1);\n   435→      expect(m.createdAt.toNumber()).to.be.greaterThan(0);\n   436→\n   437→      // Verify commitment matches\n   438→      const expectedCommitment = computeCommitment(secret);\n   439→      expect(Buffer.from(m.commitment)).to.deep.equal(expectedCommitment);\n   440→    });\n   441→\n   442→    it(\"escrows correct lamport amount (rent as entry)\", async () => {\n   443→      const t = await createTestContext();\n   444→      await initConfig(t);\n   445→      const balanceBefore = await getBalance(t, t.creator);\n   446→\n   447→      const secret = generateSecret();\n   448→      await createMatch(t, secret);\n   449→\n   450→      const matchBalance = await getBalance(t, t.matchPda);\n   451→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   452→      expect(m.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   453→\n   454→      // PDA holds max(entry, rent). For Iron tier, entry > rent so PDA = entry.\n   455→      expect(matchBalance).to.be.greaterThanOrEqual(TIER_IRON_AMOUNT);\n   456→\n   457→      const balanceAfter = await getBalance(t, t.creator);\n   458→      const spent = balanceBefore - balanceAfter;\n   459→      // Creator paid max(entry, rent) + tx fee (10000 for 2 signers)\n   460→      expect(spent - matchBalance).to.equal(10000);\n   461→    });\n   462→\n   463→    it(\"copper tier: rent covers entry, no extra transfer\", async () => {\n   464→      const t = await createTestContext();\n   465→      await initConfig(t);\n   466→      const balanceBefore = await getBalance(t, t.creator);\n   467→\n   468→      const secret = generateSecret();\n   469→      await createMatch(t, secret, TIER_COPPER, SIDE_HEADS);\n   470→\n   471→      const matchBalance = await getBalance(t, t.matchPda);\n   472→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   473→      expect(m.entryAmount.toNumber()).to.equal(TIER_COPPER_AMOUNT);\n   474→\n   475→      // For Copper, rent > entry, so PDA only has rent (no extra transfer).\n   476→      // Creator cost = rent + tx_fee, NOT rent + entry + tx_fee.\n   477→      const balanceAfter = await getBalance(t, t.creator);\n   478→      const spent = balanceBefore - balanceAfter;\n   479→      // spent = matchBalance (rent only) + tx_fee\n   480→      expect(spent - matchBalance).to.equal(10000);\n   481→      // matchBalance should be rent-exempt minimum (> entry_amount for copper)\n   482→      expect(matchBalance).to.be.greaterThan(TIER_COPPER_AMOUNT);\n   483→    });\n   484→\n   485→    it(\"rejects invalid side\", async () => {\n   486→      const t = await createTestContext();\n   487→      await initConfig(t);\n   488→      const secret = generateSecret();\n   489→      const commitment = computeCommitment(secret);\n   490→      try {\n   491→        await t.creatorProgram.methods\n   492→          .createMatch(\n   493→            Array.from(commitment) as unknown as number[],\n   494→            TIER_IRON,\n   495→            3,\n   496→            new BN(0)\n   497→          )\n   498→          .accounts({\n   499→            creator: t.creator,\n   500→            server: t.server.publicKey,\n   501→            coinflipMatch: t.matchPda,\n   502→            config: t.configPda,\n   503→            systemProgram: SystemProgram.programId,\n   504→          })\n   505→          .signers([t.server])\n   506→          .rpc();\n   507→        expect.fail(\"Expected InvalidSide error\");\n   508→      } catch (err) {\n   509→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   510→          \"InvalidSide\"\n   511→        );\n   512→      }\n   513→    });\n   514→\n   515→    it(\"rejects invalid tier\", async () => {\n   516→      const t = await createTestContext();\n   517→      await initConfig(t);\n   518→      const secret = generateSecret();\n   519→      const commitment = computeCommitment(secret);\n   520→      try {\n   521→        await t.creatorProgram.methods\n   522→          .createMatch(\n   523→            Array.from(commitment) as unknown as number[],\n   524→            99,\n   525→            SIDE_HEADS,\n   526→            new BN(0)\n   527→          )\n   528→          .accounts({\n   529→            creator: t.creator,\n   530→            server: t.server.publicKey,\n   531→            coinflipMatch: t.matchPda,\n   532→            config: t.configPda,\n   533→            systemProgram: SystemProgram.programId,\n   534→          })\n   535→          .signers([t.server])\n   536→          .rpc();\n   537→        expect.fail(\"Expected InvalidTier error\");\n   538→      } catch (err) {\n   539→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   540→          \"InvalidTier\"\n   541→        );\n   542→      }\n   543→    });\n   544→  });\n   545→\n   546→  // -----------------------------------------------------------------------\n   547→  // join_match\n   548→  // -----------------------------------------------------------------------\n   549→  describe(\"join_match\", () => {\n   550→    it(\"transitions to Locked, adds opponent entry, sets target_slot\", async () => {\n   551→      const t = await createTestContext();\n   552→      await initConfig(t);\n   553→      const secret = generateSecret();\n   554→      await createMatch(t, secret);\n   555→\n   556→      const escrowBefore = await getBalance(t, t.matchPda);\n   557→      await joinMatch(t);\n   558→\n   559→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   560→      expect(m.opponent.toBase58()).to.equal(\n   561→        t.opponent.publicKey.toBase58()\n   562→      );\n   563→      expect(m.phase).to.equal(1); // LOCKED\n   564→      expect(m.targetSlot.toNumber()).to.be.greaterThan(0);\n   565→      expect(m.resolveDeadline.toNumber()).to.be.greaterThan(0);\n   566→\n   567→      // Opponent adds exactly entry_amount\n   568→      const escrowAfter = await getBalance(t, t.matchPda);\n   569→      expect(escrowAfter - escrowBefore).to.equal(TIER_IRON_AMOUNT);\n   570→    });\n   571→\n   572→    it(\"rejects self-join\", async () => {\n   573→      const t = await createTestContext();\n   574→      await initConfig(t);\n   575→      const secret = generateSecret();\n   576→      await createMatch(t, secret);\n   577→\n   578→      try {\n   579→        await t.creatorProgram.methods\n   580→          .joinMatch()\n   581→          .accounts({\n   582→            opponent: t.creator,\n   583→            coinflipMatch: t.matchPda,\n   584→            config: t.configPda,\n   585→            systemProgram: SystemProgram.programId,\n   586→          })\n   587→          .rpc();\n   588→        expect.fail(\"Expected CannotJoinOwnMatch error\");\n   589→      } catch (err) {\n   590→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   591→          \"CannotJoinOwnMatch\"\n   592→        );\n   593→      }\n   594→    });\n   595→\n   596→    it(\"rejects join when already Locked\", async () => {\n   597→      const t = await createTestContext();\n   598→      await initConfig(t);\n   599→      const secret = generateSecret();\n   600→      await createMatch(t, secret);\n   601→      await joinMatch(t);\n   602→\n   603→      const secondOpponent = Keypair.generate();\n   604→      t.context.setAccount(secondOpponent.publicKey, fundedAccountData());\n   605→      const secondProvider = new BankrunProvider(\n   606→        t.context,\n   607→        new Wallet(secondOpponent)\n   608→      );\n   609→      const secondProgram = new Program<Coinflip>(IDL, secondProvider);\n   610→\n   611→      try {\n   612→        await secondProgram.methods\n   613→          .joinMatch()\n   614→          .accounts({\n   615→            opponent: secondOpponent.publicKey,\n   616→            coinflipMatch: t.matchPda,\n   617→            config: t.configPda,\n   618→            systemProgram: SystemProgram.programId,\n   619→          })\n   620→          .rpc();\n   621→        expect.fail(\"Expected InvalidPhase error\");\n   622→      } catch (err) {\n   623→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   624→          \"InvalidPhase\"\n   625→        );\n   626→      }\n   627→    });\n   628→  });\n   629→\n   630→  // -----------------------------------------------------------------------\n   631→  // settle\n   632→  // -----------------------------------------------------------------------\n   633→  describe(\"settle\", () => {\n   634→    it(\"creator wins — winner takes all remaining (payout + rent)\", async () => {\n   635→      const t = await createTestContext();\n   636→      await initConfig(t);\n   637→      await setupPlatform(t);\n   638→\n   639→      // Generate secret that produces HEADS with this entropy+PDA\n   640→      let secret: Buffer;\n   641→      let resultSide: number;\n   642→      const entropyData = Buffer.alloc(32);\n   643→      entropyData[0] = 0xab;\n   644→      entropyData[1] = 0xcd;\n   645→      entropyData[15] = 0x42;\n   646→      do {\n   647→        secret = generateSecret();\n   648→        const resultHash = deriveResult(secret, entropyData, t.matchPda, 1);\n   649→        resultSide = resultHash[0] % 2;\n   650→      } while (resultSide !== SIDE_HEADS);\n   651→\n   652→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n   653→\n   654→      // Capture PDA balance after create (includes rent)\n   655→      const pdaAfterCreate = await getBalance(t, t.matchPda);\n   656→\n   657→      await joinMatch(t);\n   658→\n   659→      const pool = TIER_IRON_AMOUNT * 2;\n   660→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   661→      // Winner gets ALL remaining = pdaAfterCreate + opponent_entry - fee\n   662→      const expectedWinnerPayout = pdaAfterCreate + TIER_IRON_AMOUNT - fee;\n   663→\n   664→      const winnerBefore = await getBalance(t, t.creator);\n   665→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   666→\n   667→      await settle(t, secret);\n   668→\n   669→      const winnerAfter = await getBalance(t, t.creator);\n   670→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   671→\n   672→      // Winner receives payout + rent surplus (all remaining after fee)\n   673→      expect(winnerAfter - winnerBefore).to.equal(expectedWinnerPayout);\n   674→      // Treasury receives exact fee\n   675→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   676→    });\n   677→\n   678→    it(\"opponent wins — winner takes all remaining\", async () => {\n   679→      const t = await createTestContext();\n   680→      await initConfig(t);\n   681→      await setupPlatform(t);\n   682→\n   683→      // Find secret that produces TAILS (opponent wins when creator picks HEADS)\n   684→      let secret: Buffer;\n   685→      let resultSide: number;\n   686→      const entropyData = Buffer.alloc(32);\n   687→      entropyData[0] = 0xab;\n   688→      entropyData[1] = 0xcd;\n   689→      entropyData[15] = 0x42;\n   690→      do {\n   691→        secret = generateSecret();\n   692→        const resultHash = deriveResult(secret, entropyData, t.matchPda, 1);\n   693→        resultSide = resultHash[0] % 2;\n   694→      } while (resultSide !== SIDE_TAILS);\n   695→\n   696→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n   697→      const pdaAfterCreate = await getBalance(t, t.matchPda);\n   698→      await joinMatch(t);\n   699→\n   700→      const pool = TIER_IRON_AMOUNT * 2;\n   701→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   702→      const expectedWinnerPayout = pdaAfterCreate + TIER_IRON_AMOUNT - fee;\n   703→\n   704→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   705→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   706→\n   707→      await settle(t, secret);\n   708→\n   709→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n   710→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   711→\n   712→      // Opponent receives all remaining (payout + rent surplus)\n   713→      expect(opponentAfter - opponentBefore).to.equal(expectedWinnerPayout);\n   714→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   715→    });\n   716→\n   717→    it(\"rejects invalid secret (commitment mismatch)\", async () => {\n   718→      const t = await createTestContext();\n   719→      await initConfig(t);\n   720→      await setupPlatform(t);\n   721→      const secret = generateSecret();\n   722→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n   723→      await joinMatch(t);\n   724→\n   725→      const wrongSecret = generateSecret();\n   726→      try {\n   727→        await settle(t, wrongSecret);\n   728→        expect.fail(\"Expected CommitmentMismatch error\");\n   729→      } catch (err) {\n   730→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   731→          \"CommitmentMismatch\"\n   732→        );\n   733→      }\n   734→    });\n   735→\n   736→    it(\"permissionless settle — third party with valid secret succeeds\", async () => {\n   737→      const t = await createTestContext();\n   738→      await initConfig(t);\n   739→      await setupPlatform(t);\n   740→      const secret = generateSecret();\n   741→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n   742→      await joinMatch(t);\n   743→\n   744→      const thirdParty = Keypair.generate();\n   745→      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n   746→      const thirdProvider = new BankrunProvider(\n   747→        t.context,\n   748→        new Wallet(thirdParty)\n   749→      );\n   750→      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n   751→\n   752→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   753→      await settle(t, secret, thirdProgram, thirdParty.publicKey);\n   754→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   755→\n   756→      // Fee was paid to treasury\n   757→      const pool = TIER_IRON_AMOUNT * 2;\n   758→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   759→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   760→\n   761→      // PDA closed\n   762→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   763→      expect(matchAccount).to.be.null;\n   764→    });\n   765→\n   766→    it(\"match PDA closed after settle\", async () => {\n   767→      const t = await createTestContext();\n   768→      await initConfig(t);\n   769→      await setupPlatform(t);\n   770→      const secret = generateSecret();\n   771→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n   772→      await joinMatch(t);\n   773→      await settle(t, secret);\n   774→\n   775→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   776→      expect(matchAccount).to.be.null;\n   777→    });\n   778→\n   779→    it(\"updates player profiles via CPI — creator wins\", async () => {\n   780→      const t = await createTestContext();\n   781→      await initConfig(t);\n   782→      await setupPlatform(t);\n   783→\n   784→      // Find secret that gives creator (HEADS) a win\n   785→      let secret: Buffer;\n   786→      const entropyData = Buffer.alloc(32);\n   787→      entropyData[0] = 0xab;\n   788→      entropyData[1] = 0xcd;\n   789→      entropyData[15] = 0x42;\n   790→      do {\n   791→        secret = generateSecret();\n   792→      } while (\n   793→        deriveResult(secret, entropyData, t.matchPda, 1)[0] % 2 !==\n   794→        SIDE_HEADS\n   795→      );\n   796→\n   797→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n   798→      await joinMatch(t);\n   799→      await settle(t, secret);\n   800→\n   801→      // Profile stats use nominal payout (pool - fee), not actual lamports\n   802→      const pool = TIER_IRON_AMOUNT * 2;\n   803→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   804→      const payout = pool - fee;\n   805→\n   806→      const cp = await t.platformProgram.account.playerProfile.fetch(\n   807→        t.creatorProfilePda\n   808→      );\n   809→      expect(cp.totalGames.toNumber()).to.equal(1);\n   810→      expect(cp.wins.toNumber()).to.equal(1);\n   811→      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   812→      expect(cp.totalWon.toNumber()).to.equal(payout);\n   813→\n   814→      const op = await t.platformProgram.account.playerProfile.fetch(\n   815→        t.opponentProfilePda\n   816→      );\n   817→      expect(op.totalGames.toNumber()).to.equal(1);\n   818→      expect(op.wins.toNumber()).to.equal(0);\n   819→      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   820→      expect(op.totalWon.toNumber()).to.equal(0);\n   821→    });\n   822→\n   823→    it(\"updates player profiles via CPI — opponent wins\", async () => {\n   824→      const t = await createTestContext();\n   825→      await initConfig(t);\n   826→      await setupPlatform(t);\n   827→\n   828→      // Find secret that gives opponent (TAILS) a win when creator picks HEADS\n   829→      let secret: Buffer;\n   830→      const entropyData = Buffer.alloc(32);\n   831→      entropyData[0] = 0xab;\n   832→      entropyData[1] = 0xcd;\n   833→      entropyData[15] = 0x42;\n   834→      do {\n   835→        secret = generateSecret();\n   836→      } while (\n   837→        deriveResult(secret, entropyData, t.matchPda, 1)[0] % 2 !==\n   838→        SIDE_TAILS\n   839→      );\n   840→\n   841→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n   842→      await joinMatch(t);\n   843→      await settle(t, secret);\n   844→\n   845→      const pool = TIER_IRON_AMOUNT * 2;\n   846→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   847→      const payout = pool - fee;\n   848→\n   849→      const cp = await t.platformProgram.account.playerProfile.fetch(\n   850→        t.creatorProfilePda\n   851→      );\n   852→      expect(cp.totalGames.toNumber()).to.equal(1);\n   853→      expect(cp.wins.toNumber()).to.equal(0);\n   854→      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   855→      expect(cp.totalWon.toNumber()).to.equal(0);\n   856→\n   857→      const op = await t.platformProgram.account.playerProfile.fetch(\n   858→        t.opponentProfilePda\n   859→      );\n   860→      expect(op.totalGames.toNumber()).to.equal(1);\n   861→      expect(op.wins.toNumber()).to.equal(1);\n   862→      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   863→      expect(op.totalWon.toNumber()).to.equal(payout);\n   864→    });\n   865→  });\n   866→\n   867→  // -----------------------------------------------------------------------\n   868→  // cancel_match\n   869→  // -----------------------------------------------------------------------\n   870→  describe(\"cancel_match\", () => {\n   871→    it(\"creator cancels Waiting match, full refund\", async () => {\n   872→      const t = await createTestContext();\n   873→      await initConfig(t);\n   874→      const secret = generateSecret();\n   875→      await createMatch(t, secret);\n   876→\n   877→      const balanceBefore = await getBalance(t, t.creator);\n   878→      await cancelMatch(t);\n   879→      const balanceAfter = await getBalance(t, t.creator);\n   880→\n   881→      // Creator gets back all PDA lamports minus cancel tx fee (5000)\n   882→      const TX_FEE = 5_000;\n   883→      expect(balanceAfter - balanceBefore).to.be.greaterThanOrEqual(\n   884→        TIER_IRON_AMOUNT - TX_FEE\n   885→      );\n   886→\n   887→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   888→      expect(matchAccount).to.be.null;\n   889→    });\n   890→\n   891→    it(\"rejects cancel after Locked (CannotCancel)\", async () => {\n   892→      const t = await createTestContext();\n   893→      await initConfig(t);\n   894→      const secret = generateSecret();\n   895→      await createMatch(t, secret);\n   896→      await joinMatch(t);\n   897→\n   898→      try {\n   899→        await cancelMatch(t);\n   900→        expect.fail(\"Expected CannotCancel error\");\n   901→      } catch (err) {\n   902→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   903→          \"CannotCancel\"\n   904→        );\n   905→      }\n   906→    });\n   907→\n   908→    it(\"rejects cancel by non-creator\", async () => {\n   909→      const t = await createTestContext();\n   910→      await initConfig(t);\n   911→      const secret = generateSecret();\n   912→      await createMatch(t, secret);\n   913→\n   914→      const opponentMatchPda = getMatchPda(t.opponent.publicKey);\n   915→      try {\n   916→        await t.opponentProgram.methods\n   917→          .cancelMatch()\n   918→          .accounts({\n   919→            creator: t.opponent.publicKey,\n   920→            coinflipMatch: opponentMatchPda,\n   921→            systemProgram: SystemProgram.programId,\n   922→          })\n   923→          .rpc();\n   924→        expect.fail(\"Expected error\");\n   925→      } catch (err) {\n   926→        expect(err).to.exist;\n   927→      }\n   928→    });\n   929→  });\n   930→\n   931→  // -----------------------------------------------------------------------\n   932→  // timeout_refund\n   933→  // -----------------------------------------------------------------------\n   934→  describe(\"timeout_refund\", () => {\n   935→    it(\"permissionless refund after deadline\", async () => {\n   936→      const t = await createTestContext();\n   937→      await initConfig(t);\n   938→      const secret = generateSecret();\n   939→      await createMatch(t, secret);\n   940→      await joinMatch(t);\n   941→\n   942→      await warpPastDeadline(t);\n   943→\n   944→      const creatorBefore = await getBalance(t, t.creator);\n   945→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   946→\n   947→      // Third party triggers timeout (permissionless)\n   948→      const thirdParty = Keypair.generate();\n   949→      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n   950→      const thirdProvider = new BankrunProvider(\n   951→        t.context,\n   952→        new Wallet(thirdParty)\n   953→      );\n   954→      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n   955→\n   956→      await timeoutRefund(t, thirdProgram, thirdParty.publicKey);\n   957→\n   958→      const creatorAfter = await getBalance(t, t.creator);\n   959→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n   960→\n   961→      // Opponent refunded exact entry_amount\n   962→      expect(opponentAfter - opponentBefore).to.equal(TIER_IRON_AMOUNT);\n   963→      // Creator refunded entry + rent (all remaining PDA lamports)\n   964→      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n   965→        TIER_IRON_AMOUNT\n   966→      );\n   967→\n   968→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   969→      expect(matchAccount).to.be.null;\n   970→    });\n   971→\n   972→    it(\"rejects timeout before deadline\", async () => {\n   973→      const t = await createTestContext();\n   974→      await initConfig(t);\n   975→      const secret = generateSecret();\n   976→      await createMatch(t, secret);\n   977→      await joinMatch(t);\n   978→\n   979→      try {\n   980→        await timeoutRefund(t, t.creatorProgram, t.creator);\n   981→        expect.fail(\"Expected LockTimeoutNotElapsed error\");\n   982→      } catch (err) {\n   983→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   984→          \"LockTimeoutNotElapsed\"\n   985→        );\n   986→      }\n   987→    });\n   988→\n   989→    it(\"settle blocked after timeout refund\", async () => {\n   990→      const t = await createTestContext();\n   991→      await initConfig(t);\n   992→      await setupPlatform(t);\n   993→      const secret = generateSecret();\n   994→      await createMatch(t, secret);\n   995→      await joinMatch(t);\n   996→\n   997→      await warpPastDeadline(t);\n   998→      await timeoutRefund(t, t.creatorProgram, t.creator);\n   999→\n  1000→      // Account closed — settle should fail\n  1001→      try {\n  1002→        await settle(t, secret);\n  1003→        expect.fail(\"Expected error — account closed\");\n  1004→      } catch (err) {\n  1005→        expect(err).to.exist;\n  1006→      }\n  1007→    });\n  1008→  });\n  1009→\n  1010→  // -----------------------------------------------------------------------\n  1011→  // request_refund (mutual refund)\n  1012→  // -----------------------------------------------------------------------\n  1013→  describe(\"request_refund\", () => {\n  1014→    it(\"both players vote → refund executes immediately\", async () => {\n  1015→      const t = await createTestContext();\n  1016→      await initConfig(t);\n  1017→      const secret = generateSecret();\n  1018→      await createMatch(t, secret);\n  1019→      await joinMatch(t);\n  1020→\n  1021→      const creatorBefore = await getBalance(t, t.creator);\n  1022→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n  1023→\n  1024→      // Creator votes first — no refund yet\n  1025→      await requestRefund(t, t.creatorProgram, t.creator);\n  1026→      let m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n  1027→      expect(m.creatorWantsRefund).to.equal(true);\n  1028→      expect(m.opponentWantsRefund).to.equal(false);\n  1029→      expect(m.phase).to.equal(1); // still LOCKED\n  1030→\n  1031→      // Opponent votes — refund executes\n  1032→      await requestRefund(t, t.opponentProgram, t.opponent.publicKey);\n  1033→\n  1034→      const creatorAfter = await getBalance(t, t.creator);\n  1035→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n  1036→\n  1037→      // Both get entry back minus their own tx fees (request_refund = 5000 each)\n  1038→      const TX_FEE = 5_000;\n  1039→      // Creator gets all remaining (= entry for Iron tier) minus request_refund tx fee\n  1040→      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n  1041→        TIER_IRON_AMOUNT - TX_FEE\n  1042→      );\n  1043→      // Opponent gets entry back minus request_refund tx fee\n  1044→      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(\n  1045→        TIER_IRON_AMOUNT - TX_FEE\n  1046→      );\n  1047→\n  1048→      // PDA closed\n  1049→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n  1050→      expect(matchAccount).to.be.null;\n  1051→    });\n  1052→\n  1053→    it(\"single vote does not refund\", async () => {\n  1054→      const t = await createTestContext();\n  1055→      await initConfig(t);\n  1056→      const secret = generateSecret();\n  1057→      await createMatch(t, secret);\n  1058→      await joinMatch(t);\n  1059→\n  1060→      await requestRefund(t, t.creatorProgram, t.creator);\n  1061→\n  1062→      // PDA still exists, phase still LOCKED\n  1063→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n  1064→      expect(m.phase).to.equal(1);\n  1065→      expect(m.creatorWantsRefund).to.equal(true);\n  1066→      expect(m.opponentWantsRefund).to.equal(false);\n  1067→    });\n  1068→\n  1069→    it(\"rejects double vote from same player\", async () => {\n  1070→      const t = await createTestContext();\n  1071→      await initConfig(t);\n  1072→      const secret = generateSecret();\n  1073→      await createMatch(t, secret);\n  1074→      await joinMatch(t);\n  1075→\n  1076→      await requestRefund(t, t.creatorProgram, t.creator);\n  1077→\n  1078→      try {\n  1079→        await requestRefund(t, t.creatorProgram, t.creator);\n  1080→        expect.fail(\"Expected AlreadyVotedRefund error\");\n  1081→      } catch (err) {\n  1082→        expect((err as AnchorError).error.errorCode.code).to.equal(\n  1083→          \"AlreadyVotedRefund\"\n  1084→        );\n  1085→      }\n  1086→    });\n  1087→\n  1088→    it(\"rejects non-participant\", async () => {\n  1089→      const t = await createTestContext();\n  1090→      await initConfig(t);\n  1091→      const secret = generateSecret();\n  1092→      await createMatch(t, secret);\n  1093→      await joinMatch(t);\n  1094→\n  1095→      const thirdParty = Keypair.generate();\n  1096→      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n  1097→      const thirdProvider = new BankrunProvider(\n  1098→        t.context,\n  1099→        new Wallet(thirdParty)\n  1100→      );\n  1101→      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n  1102→\n  1103→      try {\n  1104→        await requestRefund(t, thirdProgram, thirdParty.publicKey);\n  1105→        expect.fail(\"Expected NotParticipant error\");\n  1106→      } catch (err) {\n  1107→        expect((err as AnchorError).error.errorCode.code).to.equal(\n  1108→          \"NotParticipant\"\n  1109→        );\n  1110→      }\n  1111→    });\n  1112→\n  1113→    it(\"settle blocked after mutual refund\", async () => {\n  1114→      const t = await createTestContext();\n  1115→      await initConfig(t);\n  1116→      await setupPlatform(t);\n  1117→      const secret = generateSecret();\n  1118→      await createMatch(t, secret);\n  1119→      await joinMatch(t);\n  1120→\n  1121→      // Both vote → refund\n  1122→      await requestRefund(t, t.creatorProgram, t.creator);\n  1123→      await requestRefund(t, t.opponentProgram, t.opponent.publicKey);\n  1124→\n  1125→      // Account closed — settle should fail\n  1126→      try {\n  1127→        await settle(t, secret);\n  1128→        expect.fail(\"Expected error — account closed\");\n  1129→      } catch (err) {\n  1130→        expect(err).to.exist;\n  1131→      }\n  1132→    });\n  1133→  });\n  1134→\n  1135→  // -----------------------------------------------------------------------\n  1136→  // full lifecycle\n  1137→  // -----------------------------------------------------------------------\n  1138→  describe(\"full lifecycle\", () => {\n  1139→    it(\"create → join → settle → PDA closed\", async () => {\n  1140→      const t = await createTestContext();\n  1141→      await initConfig(t);\n  1142→      await setupPlatform(t);\n  1143→      const secret = generateSecret();\n  1144→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n  1145→\n  1146→      let m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n  1147→      expect(m.phase).to.equal(0); // WAITING\n  1148→\n  1149→      await joinMatch(t);\n  1150→      m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n  1151→      expect(m.phase).to.equal(1); // LOCKED\n  1152→\n  1153→      const pool = TIER_IRON_AMOUNT * 2;\n  1154→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n  1155→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n  1156→\n  1157→      await settle(t, secret);\n  1158→\n  1159→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n  1160→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n  1161→\n  1162→      const closed = await t.context.banksClient.getAccount(t.matchPda);\n  1163→      expect(closed).to.be.null;\n  1164→    });\n  1165→\n  1166→    it(\"create → cancel → create again (different nonce)\", async () => {\n  1167→      const t = await createTestContext();\n  1168→      await initConfig(t);\n  1169→\n  1170→      const secret1 = generateSecret();\n  1171→      await createMatch(t, secret1, TIER_IRON, SIDE_HEADS, 0);\n  1172→      await cancelMatch(t);\n  1173→\n  1174→      const closed = await t.context.banksClient.getAccount(t.matchPda);\n  1175→      expect(closed).to.be.null;\n  1176→\n  1177→      // Create again with nonce=1 (different PDA)\n  1178→      const secret2 = generateSecret();\n  1179→      const matchPda1 = getMatchPda(t.creator, 1);\n  1180→      await createMatch(t, secret2, TIER_IRON, SIDE_TAILS, 1);\n  1181→      const m = await t.creatorProgram.account.coinflipMatch.fetch(matchPda1);\n  1182→      expect(m.creatorSide).to.equal(SIDE_TAILS);\n  1183→      expect(m.phase).to.equal(0); // WAITING\n  1184→    });\n  1185→\n  1186→    it(\"create → join → timeout → both refunded\", async () => {\n  1187→      const t = await createTestContext();\n  1188→      await initConfig(t);\n  1189→\n  1190→      const secret = generateSecret();\n  1191→      await createMatch(t, secret, TIER_IRON, SIDE_HEADS);\n  1192→      await joinMatch(t);\n  1193→\n  1194→      await warpPastDeadline(t);\n  1195→\n  1196→      const creatorBefore = await getBalance(t, t.creator);\n  1197→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n  1198→\n  1199→      await timeoutRefund(t, t.opponentProgram, t.opponent.publicKey);\n  1200→\n  1201→      const creatorAfter = await getBalance(t, t.creator);\n  1202→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n  1203→\n  1204→      // Creator gets all remaining (entry + rent)\n  1205→      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n  1206→        TIER_IRON_AMOUNT\n  1207→      );\n  1208→      // Opponent gets entry back minus tx fee for calling timeout_refund\n  1209→      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(\n  1210→        TIER_IRON_AMOUNT - 5000\n  1211→      );\n  1212→    });\n  1213→\n  1214→    it(\"copper tier (new lowest) works end-to-end\", async () => {\n  1215→      const t = await createTestContext();\n  1216→      await initConfig(t);\n  1217→      await setupPlatform(t);\n  1218→\n  1219→      const secret = generateSecret();\n  1220→      await createMatch(t, secret, TIER_COPPER, SIDE_HEADS);\n  1221→\n  1222→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n  1223→      expect(m.entryAmount.toNumber()).to.equal(TIER_COPPER_AMOUNT);\n  1224→\n  1225→      await joinMatch(t);\n  1226→      await settle(t, secret);\n  1227→\n  1228→      const closed = await t.context.banksClient.getAccount(t.matchPda);\n  1229→      expect(closed).to.be.null;\n  1230→    });\n  1231→  });\n  1232→});\n  1233→"}]},"parent_tool_use_id":"toolu_01T8L2CnBtwDrecLKqJNthcz","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"a5f173c5-3561-4d4c-b5b1-9cfba3521338"}
