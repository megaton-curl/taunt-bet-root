{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SDMbs3UE4jBpJqBBk1voDg","type":"tool_result","content":"     1→/// Compile-time safety cap: no fee can ever exceed 10% (1000 bps).\n     2→pub const MAX_FEE_BPS: u16 = 1000;\n     3→\n     4→/// Total platform fee: 3% (300 basis points)\n     5→/// - 200 bps: platform revenue\n     6→/// - 70 bps: rakeback pool (raid boss rewards)\n     7→/// - 30 bps: chest treasury\n     8→pub const TOTAL_FEE_BPS: u16 = 300;\n     9→pub const REVENUE_BPS: u16 = 200;\n    10→pub const RAKEBACK_BPS: u16 = 70;\n    11→pub const CHEST_BPS: u16 = 30;\n    12→\n    13→// Compile-time assertion: fee must never exceed safety cap.\n    14→const _: () = assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n    15→\n    16→/// Calculate the total fee for a given amount.\n    17→/// Returns the fee in lamports.\n    18→pub fn calculate_fee(amount: u64) -> u64 {\n    19→    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n    20→}\n    21→\n    22→/// Calculate fee and net payout for a given pool amount.\n    23→/// Returns `(fee, net_payout)` where `net_payout = pool - fee`.\n    24→/// Fee rounds down (integer division truncates), favoring the player.\n    25→pub fn calculate_net_payout(pool: u64) -> (u64, u64) {\n    26→    let fee = calculate_fee(pool);\n    27→    (fee, pool - fee)\n    28→}\n    29→\n    30→/// Split a fee amount into (revenue, rakeback, chest).\n    31→pub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    32→    let revenue = (fee as u128 * REVENUE_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    33→    let rakeback = (fee as u128 * RAKEBACK_BPS as u128 / TOTAL_FEE_BPS as u128) as u64;\n    34→    let chest = fee - revenue - rakeback; // remainder avoids rounding loss\n    35→    (revenue, rakeback, chest)\n    36→}\n    37→\n    38→#[cfg(test)]\n    39→mod tests {\n    40→    use super::*;\n    41→\n    42→    #[test]\n    43→    fn test_calculate_fee() {\n    44→        assert_eq!(calculate_fee(10_000), 300);\n    45→        assert_eq!(calculate_fee(1_000_000), 30_000);\n    46→        assert_eq!(calculate_fee(0), 0);\n    47→    }\n    48→\n    49→    #[test]\n    50→    fn test_calculate_net_payout() {\n    51→        let (fee, net) = calculate_net_payout(1_000_000);\n    52→        assert_eq!(fee, 30_000);\n    53→        assert_eq!(net, 970_000);\n    54→        assert_eq!(fee + net, 1_000_000);\n    55→\n    56→        // Zero pool\n    57→        let (fee, net) = calculate_net_payout(0);\n    58→        assert_eq!(fee, 0);\n    59→        assert_eq!(net, 0);\n    60→\n    61→        // Small amount where rounding truncates (favors player)\n    62→        // 100 lamports * 300 / 10000 = 3.0 exactly\n    63→        let (fee, net) = calculate_net_payout(100);\n    64→        assert_eq!(fee, 3);\n    65→        assert_eq!(net, 97);\n    66→\n    67→        // Non-round amount: 1 lamport → fee rounds to 0\n    68→        let (fee, net) = calculate_net_payout(1);\n    69→        assert_eq!(fee, 0);\n    70→        assert_eq!(net, 1);\n    71→    }\n    72→\n    73→    #[test]\n    74→    fn test_max_fee_bps_cap() {\n    75→        assert!(TOTAL_FEE_BPS <= MAX_FEE_BPS);\n    76→    }\n    77→\n    78→    #[test]\n    79→    fn test_split_fee() {\n    80→        let (rev, rake, chest) = split_fee(300);\n    81→        assert_eq!(rev, 200);\n    82→        assert_eq!(rake, 70);\n    83→        assert_eq!(chest, 30);\n    84→        assert_eq!(rev + rake + chest, 300);\n    85→    }\n    86→}\n    87→"}]},"parent_tool_use_id":"toolu_01T8L2CnBtwDrecLKqJNthcz","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"825fe97a-f847-4df1-9330-80d5389a283a"}
