  168→\n   169→  const opponentProvider = new BankrunProvider(context, new Wallet(opponent));\n   170→  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n   171→\n   172→  const serverProvider = new BankrunProvider(context, new Wallet(server));\n   173→  const serverProgram = new Program<Coinflip>(IDL, serverProvider);\n   174→\n   175→  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n   176→  const opponentPlatformProgram = new Program<Platform>(\n   177→    PLATFORM_IDL,\n   178→    opponentProvider\n   179→  );\n   180→\n   181→  const creator = creatorProvider.wallet.publicKey;\n   182→  const configPda = getConfigPda();\n   183→  const matchPda = getMatchPda(creator);\n   184→  const platformConfigPda = getPlatformConfigPda();\n   185→  const creatorProfilePda = getPlayerProfilePda(creator);\n   186→  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n   187→\n   188→  return {\n   189→    context,\n   190→    creator,\n   191→    opponent,\n   192→    treasury,\n   193→    server,\n   194→    mockEntropy,\n   195→    creatorProgram,\n   196→    opponentProgram,\n   197→    serverProgram,\n   198→    platformProgram,\n   199→    opponentPlatformProgram,\n   200→    configPda,\n   201→    matchPda,\n   202→    platformConfigPda,\n   203→    creatorProfilePda,\n   204→    opponentProfilePda,\n   205→  };\n   206→}\n   207→\n   208→// ---------------------------------------------------------------------------\n   209→// Instruction helpers\n   210→// ---------------------------------------------------------------------------\n   211→async function initConfig(t: TestContext) {\n   212→  await t.creatorProgram.methods\n   213→    .initializeConfig(t.treasury.publicKey)\n   214→    .accounts({\n   215→      authority: t.creator,\n   216→      config: t.configPda,\n   217→      systemProgram: SystemProgram.programId,\n   218→    })\n   219→    .rpc();\n   220→}\n   221→\n   222→async function initPlatform(t: TestContext) {\n   223→  await t.platformProgram.methods\n   224→    .initializePlatform(t.treasury.publicKey)\n   225→    .accounts({\n   226→      authority: t.creator,\n   227→      config: t.platformConfigPda,\n   228→      systemProgram: SystemProgram.programId,\n   229→    })\n   230→    .rpc();\n   231→}\n   232→\n   233→async function createPlayerProfile(\n   234→  t: TestContext,\n   235→  program: Program<Platform>,\n   236→  player: PublicKey\n   237→) {\n   238→  const profilePda = getPlayerProfilePda(player);\n   239→  await program.methods\n   240→    .createPlayerProfile()\n   241→    .accounts({\n   242→      player,\n   243→      profile: profilePda,\n   244→      systemProgram: SystemProgram.programId,\n   245→    })\n   246→    .rpc();\n   247→}\n   248→\n   249→async function setupPlatform(t: TestContext) {\n   250→  await initPlatform(t);\n   251→  await createPlayerProfile(t, t.platformProgram, t.creator);\n   252→  await createPlayerProfile(\n   253→    t,\n   254→    t.opponentPlatformProgram,\n   255→    t.opponent.publicKey\n   256→  );\n   257→}\n   258→\n   259→function generateSecret(): Buffer {\n   260→  const buf = Buffer.alloc(32);\n   261→  for (let i = 0; i < 32; i++) {\n   262→    buf[i] = Math.floor(Math.random() * 256);\n   263→  }\n   264→  return buf;\n   265→}\n   266→\n   267→async function createMatch(\n   268→  t: TestContext,\n   269→  secret: Buffer,\n   270→  tier = TIER_IRON,\n   271→  side = SIDE_HEADS,\n   272→  nonce = 0\n   273→) {\n   274→  const commitment = computeCommitment(secret);\n   275→  const matchPda = nonce === 0 ? t.matchPda : getMatchPda(t.creator, nonce);\n   276→  await t.creatorProgram.methods\n   277→    .createMatch(\n   278→      Array.from(commitment) as unknown as number[],\n   279→      tier,\n   280→      side,\n   281→      new BN(nonce)\n   282→    )\n   283→    .accounts({\n   284→      creator: t.creator,\n   285→      server: t.server.publicKey,\n   286→      coinflipMatch: matchPda,\n   287→      config: t.configPda,\n   288→      systemProgram: SystemProgram.programId,\n   289→    })\n   290→    .signers([t.server])\n   291→    .rpc();\n   292→}\n   293→\n   294→async function joinMatch(t: TestContext) {\n   295→  await t.opponentProgram.methods\n   296→    .joinMatch()\n   297→    .accounts({\n   298→      opponent: t.opponent.publicKey,\n   299→      coinflipMatch: t.matchPda,\n   300→      config: t.configPda,\n   301→      systemProgram: SystemProgram.programId,\n   302→    })\n   303→    .rpc();\n   304→}\n   305→\n   306→async function settle(\n   307→  t: TestContext,\n   308→  secret: Buffer,\n   309→  callerProgram?: Program<Coinflip>,\n   310→  callerPubkey?: PublicKey\n   311→) {\n   312→  const program = callerProgram ?? t.serverProgram;\n   313→  const caller = callerPubkey ?? t.server.publicKey;\n   314→  await program.methods\n   315→    .settle(Array.from(secret) as unknown as number[])\n   316→    .accounts({\n   317→      caller,\n   318→      coinflipMatch: t.matchPda,\n   319→      config: t.configPda,"}]},"parent_tool_use_id":null,"session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"f02164ed-f7d4-48c4-9bf8-e02a1e2bb4fa","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/coinflip.ts","content":"interface TestContext {\n  context: Awaited<ReturnType<typeof startAnchor>>;\n  creator: PublicKey;\n  opponent: Keypair;\n  treasury: Keypair;\n  server: Keypair;\n  mockEntropy: Keypair;\n  creatorProgram: Program<Coinflip>;\n  opponentProgram: Program<Coinflip>;\n  serverProgram: Program<Coinflip>;\n  platformProgram: Program<Platform>;\n  opponentPlatformProgram: Program<Platform>;\n  configPda: PublicKey;\n  matchPda: PublicKey;\n  platformConfigPda: PublicKey;\n  creatorProfilePda: PublicKey;\n  opponentProfilePda: PublicKey;\n}\n\nasync function createTestContext(): Promise<TestContext> {\n  const opponent = Keypair.generate();\n  const treasury = Keypair.generate();\n  const server = Keypair.generate();\n  const mockEntropy = Keypair.generate();\n\n  // Entropy account: 32 bytes of non-zero data\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  const context = await startAnchor(\"./\", [], [\n    { address: opponent.publicKey, info: fundedAccountData() },\n    { address: treasury.publicKey, info: fundedAccountData() },\n    { address: server.publicKey, info: fundedAccountData() },\n    {\n      address: mockEntropy.publicKey,\n      info: {\n        lamports: LAMPORTS_PER_SOL,\n        data: entropyData,\n        owner: SystemProgram.programId,\n        executable: false,\n      },\n    },\n  ]);\n\n  const creatorProvider = new BankrunProvider(context);\n  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n\n  const opponentProvider = new BankrunProvider(context, new Wallet(opponent));\n  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n\n  const serverProvider = new BankrunProvider(context, new Wallet(server));\n  const serverProgram = new Program<Coinflip>(IDL, serverProvider);\n\n  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n  const opponentPlatformProgram = new Program<Platform>(\n    PLATFORM_IDL,\n    opponentProvider\n  );\n\n  const creator = creatorProvider.wallet.publicKey;\n  const configPda = getConfigPda();\n  const matchPda = getMatchPda(creator);\n  const platformConfigPda = getPlatformConfigPda();\n  const creatorProfilePda = getPlayerProfilePda(creator);\n  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n\n  return {\n    context,\n    creator,\n    opponent,\n    treasury,\n    server,\n    mockEntropy,\n    creatorProgram,\n    opponentProgram,\n    serverProgram,\n    platformProgram,\n    opponentPlatformProgram,\n    configPda,\n    matchPda,\n    platformConfigPda,\n    creatorProfilePda,\n    opponentProfilePda,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Instruction helpers\n// ---------------------------------------------------------------------------\nasync function initConfig(t: TestContext) {\n  await t.creatorProgram.methods\n    .initializeConfig(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function initPlatform(t: TestContext) {\n  await t.platformProgram.methods\n    .initializePlatform(t.treasury.publicKey)\n    .accounts({\n      authority: t.creator,\n      config: t.platformConfigPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function createPlayerProfile(\n  t: TestContext,\n  program: Program<Platform>,\n  player: PublicKey\n) {\n  const profilePda = getPlayerProfilePda(player);\n  await program.methods\n    .createPlayerProfile()\n    .accounts({\n      player,\n      profile: profilePda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function setupPlatform(t: TestContext) {\n  await initPlatform(t);\n  await createPlayerProfile(t, t.platformProgram, t.creator);\n  await createPlayerProfile(\n    t,\n    t.opponentPlatformProgram,\n    t.opponent.publicKey\n  );\n}\n\nfunction generateSecret(): Buffer {\n  const buf = Buffer.alloc(32);\n  for (let i = 0; i < 32; i++) {\n    buf[i] = Math.floor(Math.random() * 256);\n  }\n  return buf;\n}\n\nasync function createMatch(\n  t: TestContext,\n  secret: Buffer,\n  tier = TIER_IRON,\n  side = SIDE_HEADS,\n  nonce = 0\n) {\n  const commitment = computeCommitment(secret);\n  const matchPda = nonce === 0 ? t.matchPda : getMatchPda(t.creator, nonce);\n  await t.creatorProgram.methods\n    .createMatch(\n      Array.from(commitment) as unknown as number[],\n      tier,\n      side,\n      new BN(nonce)\n    )\n    .accounts({\n      creator: t.creator,\n      server: t.server.publicKey,\n      coinflipMatch: matchPda,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .signers([t.server])\n    .rpc();\n}\n\nasync function joinMatch(t: TestContext) {\n  await t.opponentProgram.methods\n    .joinMatch()\n    .accounts({\n      opponent: t.opponent.publicKey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function settle(\n  t: TestContext,\n  secret: Buffer,\n  callerProgram?: Program<Coinflip>,\n  callerPubkey?: PublicKey\n) {\n  const program = callerProgram ?? t.serverProgram;\n  const caller = callerPubkey ?? t.server.publicKey;\n  await program.methods\n    .settle(Array.from(secret) as unknown as number[])\n    .accounts({\n      caller,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,","numLines":200,"startLine":120,"totalLines":1233}}}
