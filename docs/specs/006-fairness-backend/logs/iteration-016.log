{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GYMw4ZnGuF6vNvqJDrhz6K","type":"tool_result","content":"     1→import { describe, it, expect } from \"vitest\";\n     2→import { Hono } from \"hono\";\n     3→import { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n     4→\n     5→function createTestApp(\n     6→  config = { perWallet: 3, global: 10, windowMs: 60_000 },\n     7→) {\n     8→  const app = new Hono();\n     9→  app.use(\"/*\", createRateLimitMiddleware(config));\n    10→  app.post(\"/test\", (c) => c.json({ ok: true }));\n    11→  app.get(\"/test\", (c) => c.json({ ok: true }));\n    12→  return app;\n    13→}\n    14→\n    15→function post(wallet: string) {\n    16→  return {\n    17→    method: \"POST\" as const,\n    18→    headers: { \"Content-Type\": \"application/json\" },\n    19→    body: JSON.stringify({ wallet }),\n    20→  };\n    21→}\n    22→\n    23→describe(\"rate-limit middleware\", () => {\n    24→  it(\"allows requests within per-wallet limit\", async () => {\n    25→    const app = createTestApp({ perWallet: 3, global: 100, windowMs: 60_000 });\n    26→    for (let i = 0; i < 3; i++) {\n    27→      const res = await app.request(\"/test\", post(\"wallet1\"));\n    28→      expect(res.status).toBe(200);\n    29→    }\n    30→  });\n    31→\n    32→  it(\"blocks requests exceeding per-wallet limit\", async () => {\n    33→    const app = createTestApp({ perWallet: 2, global: 100, windowMs: 60_000 });\n    34→    await app.request(\"/test\", post(\"wallet1\"));\n    35→    await app.request(\"/test\", post(\"wallet1\"));\n    36→    const res = await app.request(\"/test\", post(\"wallet1\"));\n    37→    expect(res.status).toBe(429);\n    38→  });\n    39→\n    40→  it(\"returns Retry-After header on per-wallet 429\", async () => {\n    41→    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    42→    await app.request(\"/test\", post(\"wallet1\"));\n    43→    const res = await app.request(\"/test\", post(\"wallet1\"));\n    44→    expect(res.status).toBe(429);\n    45→    expect(res.headers.get(\"Retry-After\")).toBe(\"60\");\n    46→  });\n    47→\n    48→  it(\"tracks wallets independently\", async () => {\n    49→    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    50→    const r1 = await app.request(\"/test\", post(\"wallet1\"));\n    51→    const r2 = await app.request(\"/test\", post(\"wallet2\"));\n    52→    expect(r1.status).toBe(200);\n    53→    expect(r2.status).toBe(200);\n    54→    // wallet1 is now exhausted\n    55→    const r3 = await app.request(\"/test\", post(\"wallet1\"));\n    56→    expect(r3.status).toBe(429);\n    57→    // wallet2 is also exhausted\n    58→    const r4 = await app.request(\"/test\", post(\"wallet2\"));\n    59→    expect(r4.status).toBe(429);\n    60→  });\n    61→\n    62→  it(\"enforces global limit across all wallets\", async () => {\n    63→    const app = createTestApp({ perWallet: 10, global: 3, windowMs: 60_000 });\n    64→    await app.request(\"/test\", post(\"w1\"));\n    65→    await app.request(\"/test\", post(\"w2\"));\n    66→    await app.request(\"/test\", post(\"w3\"));\n    67→    const res = await app.request(\"/test\", post(\"w4\"));\n    68→    expect(res.status).toBe(429);\n    69→  });\n    70→\n    71→  it(\"returns correct Retry-After seconds based on window\", async () => {\n    72→    const app = createTestApp({ perWallet: 10, global: 1, windowMs: 30_000 });\n    73→    await app.request(\"/test\", post(\"w1\"));\n    74→    const res = await app.request(\"/test\", post(\"w2\"));\n    75→    expect(res.status).toBe(429);\n    76→    expect(res.headers.get(\"Retry-After\")).toBe(\"30\");\n    77→  });\n    78→\n    79→  it(\"does not rate-limit GET requests\", async () => {\n    80→    const app = createTestApp({ perWallet: 1, global: 1, windowMs: 60_000 });\n    81→    // Exhaust POST limits\n    82→    await app.request(\"/test\", post(\"w1\"));\n    83→    // GET should still work\n    84→    const res = await app.request(\"/test\", { method: \"GET\" });\n    85→    expect(res.status).toBe(200);\n    86→  });\n    87→});\n    88→"}]},"parent_tool_use_id":"toolu_019c2BAXd8iatmYKcyH36SRp","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"d03d333b-e067-435f-973b-acb97dc81d3f"}
