{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019yxb7rinkC7PdniFWqSb6Z","type":"tool_result","content":"     1→/**\n     2→ * Simple SQL migration runner with version tracking.\n     3→ *\n     4→ * Reads numbered `.sql` files from `../migrations/`, applies them in order,\n     5→ * and tracks which have been applied in a `_migrations` table. Each migration\n     6→ * runs inside a transaction so partial application is impossible.\n     7→ *\n     8→ * Migrations are idempotent: re-running skips already-applied files.\n     9→ *\n    10→ * Usage:  tsx src/migrate.ts          (uses DATABASE_URL from env)\n    11→ *         tsx src/migrate.ts status   (shows applied migrations)\n    12→ */\n    13→\n    14→import { readdir, readFile } from \"node:fs/promises\";\n    15→import { join, dirname } from \"node:path\";\n    16→import { fileURLToPath } from \"node:url\";\n    17→import postgres from \"postgres\";\n    18→\n    19→const __dirname = dirname(fileURLToPath(import.meta.url));\n    20→const MIGRATIONS_DIR = join(__dirname, \"..\", \"migrations\");\n    21→\n    22→interface MigrationFile {\n    23→  version: number;\n    24→  name: string;\n    25→  path: string;\n    26→}\n    27→\n    28→async function loadMigrationFiles(): Promise<MigrationFile[]> {\n    29→  const entries = await readdir(MIGRATIONS_DIR);\n    30→  const sqlFiles = entries\n    31→    .filter((f) => f.endsWith(\".sql\"))\n    32→    .sort();\n    33→\n    34→  return sqlFiles.map((name) => {\n    35→    const version = parseInt(name.split(\"_\")[0]!, 10);\n    36→    if (Number.isNaN(version)) {\n    37→      throw new Error(`Migration file ${name} does not start with a numeric version`);\n    38→    }\n    39→    return { version, name, path: join(MIGRATIONS_DIR, name) };\n    40→  });\n    41→}\n    42→\n    43→async function ensureMigrationsTable(sql: postgres.Sql): Promise<void> {\n    44→  await sql`\n    45→    CREATE TABLE IF NOT EXISTS _migrations (\n    46→      version   INT PRIMARY KEY,\n    47→      name      TEXT NOT NULL,\n    48→      applied_at TIMESTAMPTZ DEFAULT now()\n    49→    )\n    50→  `;\n    51→}\n    52→\n    53→async function getAppliedVersions(sql: postgres.Sql): Promise<Set<number>> {\n    54→  const rows = await sql<{ version: number }[]>`\n    55→    SELECT version FROM _migrations ORDER BY version\n    56→  `;\n    57→  return new Set(rows.map((r) => r.version));\n    58→}\n    59→\n    60→async function applyMigration(\n    61→  sql: postgres.Sql,\n    62→  migration: MigrationFile,\n    63→): Promise<void> {\n    64→  const content = await readFile(migration.path, \"utf-8\");\n    65→\n    66→  // Run migration SQL (idempotent via IF NOT EXISTS), then record it.\n    67→  // Using sql.begin with unsafe for both statements to stay in one transaction.\n    68→  await sql.begin(async (tx) => {\n    69→    await tx.unsafe(content);\n    70→    await tx.unsafe(\n    71→      \"INSERT INTO _migrations (version, name) VALUES ($1, $2)\",\n    72→      [migration.version, migration.name],\n    73→    );\n    74→  });\n    75→}\n    76→\n    77→export async function runMigrations(databaseUrl: string): Promise<void> {\n    78→  const sql = postgres(databaseUrl);\n    79→\n    80→  try {\n    81→    await ensureMigrationsTable(sql);\n    82→\n    83→    const applied = await getAppliedVersions(sql);\n    84→    const files = await loadMigrationFiles();\n    85→    const pending = files.filter((f) => !applied.has(f.version));\n    86→\n    87→    if (pending.length === 0) {\n    88→      console.log(\"All migrations are up to date.\");\n    89→      return;\n    90→    }\n    91→\n    92→    for (const migration of pending) {\n    93→      console.log(`Applying migration ${migration.name}...`);\n    94→      await applyMigration(sql, migration);\n    95→      console.log(`  ✓ ${migration.name} applied.`);\n    96→    }\n    97→\n    98→    console.log(`${pending.length} migration(s) applied successfully.`);\n    99→  } finally {\n   100→    await sql.end();\n   101→  }\n   102→}\n   103→\n   104→async function showStatus(databaseUrl: string): Promise<void> {\n   105→  const sql = postgres(databaseUrl);\n   106→\n   107→  try {\n   108→    await ensureMigrationsTable(sql);\n   109→\n   110→    const applied = await getAppliedVersions(sql);\n   111→    const files = await loadMigrationFiles();\n   112→\n   113→    console.log(\"Migration status:\");\n   114→    for (const file of files) {\n   115→      const status = applied.has(file.version) ? \"[applied]\" : \"[pending]\";\n   116→      console.log(`  ${status} ${file.name}`);\n   117→    }\n   118→  } finally {\n   119→    await sql.end();\n   120→  }\n   121→}\n   122→\n   123→// CLI entry point\n   124→const command = process.argv[2];\n   125→const databaseUrl = process.env.DATABASE_URL;\n   126→\n   127→if (!databaseUrl) {\n   128→  console.error(\"DATABASE_URL environment variable is required\");\n   129→  process.exit(1);\n   130→}\n   131→\n   132→if (command === \"status\") {\n   133→  await showStatus(databaseUrl);\n   134→} else {\n   135→  await runMigrations(databaseUrl);\n   136→}\n   137→"}]},"parent_tool_use_id":"toolu_019c2BAXd8iatmYKcyH36SRp","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"51c81149-5aef-4f71-9bb4-4693829892c6"}
