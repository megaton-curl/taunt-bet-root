{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JmwAGaGEBV5QtXrpGqWdEG","type":"tool_result","content":"     1→/**\n     2→ * Settlement worker — polls the chain for PHASE_LOCKED CoinflipMatch accounts\n     3→ * co-signed by this server and detects when they are ready for settlement.\n     4→ */\n     5→\n     6→import { Connection, PublicKey } from \"@solana/web3.js\";\n     7→import bs58 from \"bs58\";\n     8→import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n     9→import type { Db } from \"../db.js\";\n    10→import { logger } from \"../logger.js\";\n    11→\n    12→// CoinflipMatch account layout offsets (includes 8-byte Anchor discriminator)\n    13→const ACCOUNT_SIZE = 246;\n    14→const SERVER_OFFSET = 72;\n    15→const PHASE_OFFSET = 114;\n    16→const TARGET_SLOT_OFFSET = 148;\n    17→\n    18→const PHASE_LOCKED_VALUE = 1;\n    19→\n    20→export interface SettlementWorkerDeps {\n    21→  db: Db;\n    22→  connection: Connection;\n    23→  serverKey: PublicKey;\n    24→  pollIntervalMs: number;\n    25→  /** Called when a match is detected as ready for settlement (target_slot reached). */\n    26→  onSettleReady?: (pda: string) => Promise<void>;\n    27→}\n    28→\n    29→export interface SettlementWorker {\n    30→  start(): void;\n    31→  stop(): void;\n    32→  readonly isRunning: boolean;\n    33→  /** Run a single poll cycle (exposed for testing). */\n    34→  poll(): Promise<void>;\n    35→}\n    36→\n    37→export function createSettlementWorker(\n    38→  deps: SettlementWorkerDeps,\n    39→): SettlementWorker {\n    40→  const { db, connection, serverKey, pollIntervalMs } = deps;\n    41→  const discoveredPdas = new Set<string>();\n    42→  let running = false;\n    43→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    44→\n    45→  async function poll(): Promise<void> {\n    46→    const currentSlot = await connection.getSlot();\n    47→\n    48→    // Query chain for PHASE_LOCKED CoinflipMatch accounts with our server key\n    49→    const accounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n    50→      filters: [\n    51→        { dataSize: ACCOUNT_SIZE },\n    52→        {\n    53→          memcmp: {\n    54→            offset: PHASE_OFFSET,\n    55→            bytes: bs58.encode(Uint8Array.from([PHASE_LOCKED_VALUE])),\n    56→          },\n    57→        },\n    58→        {\n    59→          memcmp: {\n    60→            offset: SERVER_OFFSET,\n    61→            bytes: serverKey.toBase58(),\n    62→          },\n    63→        },\n    64→      ],\n    65→    });\n    66→\n    67→    for (const { pubkey, account } of accounts) {\n    68→      const pda = pubkey.toBase58();\n    69→      const data = Buffer.from(account.data);\n    70→\n    71→      // Parse target_slot (u64 LE at offset 148)\n    72→      const targetSlot = data.readBigUInt64LE(TARGET_SLOT_OFFSET);\n    73→\n    74→      // Log match_detected for newly discovered locked matches\n    75→      if (!discoveredPdas.has(pda)) {\n    76→        discoveredPdas.add(pda);\n    77→\n    78→        const round = await db.getRoundByPda(pda);\n    79→        if (round && round.phase === \"created\") {\n    80→          // Transition from created → locked in DB\n    81→          await db.updateRoundPhase(pda, \"locked\", {\n    82→            target_slot: targetSlot.toString(),\n    83→          });\n    84→          await db.insertOperatorEvent(pda, \"match_detected\", {\n    85→            targetSlot: targetSlot.toString(),\n    86→            currentSlot,\n    87→          });\n    88→        } else if (!round) {\n    89→          // Match on-chain but not in our DB — we don't have the secret, skip\n    90→          continue;\n    91→        }\n    92→      }\n    93→\n    94→      // Check if target_slot reached — match is ready for settlement\n    95→      if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n    96→        await deps.onSettleReady(pda);\n    97→      }\n    98→    }\n    99→  }\n   100→\n   101→  async function loop(): Promise<void> {\n   102→    if (!running) return;\n   103→    try {\n   104→      await poll();\n   105→    } catch (err) {\n   106→      // Log but don't crash — transient RPC errors are expected\n   107→      logger.error(\"settlement worker poll error\", {\n   108→        error: err instanceof Error ? err.message : String(err),\n   109→      });\n   110→    }\n   111→    if (running) {\n   112→      timeoutId = setTimeout(loop, pollIntervalMs);\n   113→    }\n   114→  }\n   115→\n   116→  return {\n   117→    start() {\n   118→      if (running) return;\n   119→      running = true;\n   120→      loop();\n   121→    },\n   122→    stop() {\n   123→      running = false;\n   124→      if (timeoutId) {\n   125→        clearTimeout(timeoutId);\n   126→        timeoutId = null;\n   127→      }\n   128→    },\n   129→    get isRunning() {\n   130→      return running;\n   131→    },\n   132→    poll,\n   133→  };\n   134→}\n   135→"}]},"parent_tool_use_id":null,"session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"58e47837-1949-4f16-8c6f-20ef7c163ad8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settlement.ts","content":"/**\n * Settlement worker — polls the chain for PHASE_LOCKED CoinflipMatch accounts\n * co-signed by this server and detects when they are ready for settlement.\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\n// CoinflipMatch account layout offsets (includes 8-byte Anchor discriminator)\nconst ACCOUNT_SIZE = 246;\nconst SERVER_OFFSET = 72;\nconst PHASE_OFFSET = 114;\nconst TARGET_SLOT_OFFSET = 148;\n\nconst PHASE_LOCKED_VALUE = 1;\n\nexport interface SettlementWorkerDeps {\n  db: Db;\n  connection: Connection;\n  serverKey: PublicKey;\n  pollIntervalMs: number;\n  /** Called when a match is detected as ready for settlement (target_slot reached). */\n  onSettleReady?: (pda: string) => Promise<void>;\n}\n\nexport interface SettlementWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single poll cycle (exposed for testing). */\n  poll(): Promise<void>;\n}\n\nexport function createSettlementWorker(\n  deps: SettlementWorkerDeps,\n): SettlementWorker {\n  const { db, connection, serverKey, pollIntervalMs } = deps;\n  const discoveredPdas = new Set<string>();\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  async function poll(): Promise<void> {\n    const currentSlot = await connection.getSlot();\n\n    // Query chain for PHASE_LOCKED CoinflipMatch accounts with our server key\n    const accounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n      filters: [\n        { dataSize: ACCOUNT_SIZE },\n        {\n          memcmp: {\n            offset: PHASE_OFFSET,\n            bytes: bs58.encode(Uint8Array.from([PHASE_LOCKED_VALUE])),\n          },\n        },\n        {\n          memcmp: {\n            offset: SERVER_OFFSET,\n            bytes: serverKey.toBase58(),\n          },\n        },\n      ],\n    });\n\n    for (const { pubkey, account } of accounts) {\n      const pda = pubkey.toBase58();\n      const data = Buffer.from(account.data);\n\n      // Parse target_slot (u64 LE at offset 148)\n      const targetSlot = data.readBigUInt64LE(TARGET_SLOT_OFFSET);\n\n      // Log match_detected for newly discovered locked matches\n      if (!discoveredPdas.has(pda)) {\n        discoveredPdas.add(pda);\n\n        const round = await db.getRoundByPda(pda);\n        if (round && round.phase === \"created\") {\n          // Transition from created → locked in DB\n          await db.updateRoundPhase(pda, \"locked\", {\n            target_slot: targetSlot.toString(),\n          });\n          await db.insertOperatorEvent(pda, \"match_detected\", {\n            targetSlot: targetSlot.toString(),\n            currentSlot,\n          });\n        } else if (!round) {\n          // Match on-chain but not in our DB — we don't have the secret, skip\n          continue;\n        }\n      }\n\n      // Check if target_slot reached — match is ready for settlement\n      if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n        await deps.onSettleReady(pda);\n      }\n    }\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await poll();\n    } catch (err) {\n      // Log but don't crash — transient RPC errors are expected\n      logger.error(\"settlement worker poll error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      timeoutId = setTimeout(loop, pollIntervalMs);\n    }\n  }\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n      loop();\n    },\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n    },\n    get isRunning() {\n      return running;\n    },\n    poll,\n  };\n}\n","numLines":135,"startLine":1,"totalLines":135}}}
