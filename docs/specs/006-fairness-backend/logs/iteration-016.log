{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NTwyUQ8PFoYfARfWvfe7Bm","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import {\n    11→  Connection,\n    12→  Keypair,\n    13→  PublicKey,\n    14→  SystemProgram,\n    15→  Transaction,\n    16→  TransactionInstruction,\n    17→} from \"@solana/web3.js\";\n    18→import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n    19→import type { Db } from \"../db.js\";\n    20→\n    21→// ---------------------------------------------------------------------------\n    22→// Constants\n    23→// ---------------------------------------------------------------------------\n    24→\n    25→const PLATFORM_PROGRAM_ID = new PublicKey(\n    26→  \"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\",\n    27→);\n    28→\n    29→/** settle instruction discriminator: SHA256(\"global:settle\")[0..8] */\n    30→const SETTLE_DISCRIMINATOR = Buffer.from([\n    31→  175, 42, 185, 87, 144, 131, 102, 212,\n    32→]);\n    33→\n    34→// CoinflipMatch account offsets (includes 8-byte Anchor discriminator)\n    35→const CREATOR_OFFSET = 8;\n    36→const OPPONENT_OFFSET = 40;\n    37→const CREATOR_SIDE_OFFSET = 113;\n    38→const ALGO_VER_OFFSET = 147;\n    39→\n    40→// CoinflipConfig account offsets\n    41→const CONFIG_TREASURY_OFFSET = 40; // 8 disc + 32 authority\n    42→\n    43→// ---------------------------------------------------------------------------\n    44→// Types\n    45→// ---------------------------------------------------------------------------\n    46→\n    47→export interface SettleTxDeps {\n    48→  db: Db;\n    49→  connection: Connection;\n    50→  serverKeypair: Keypair;\n    51→  entropyAccount: PublicKey;\n    52→}\n    53→\n    54→export interface SettleResult {\n    55→  txSignature: string;\n    56→  resultHash: Buffer;\n    57→  resultSide: number;\n    58→  winner: string;\n    59→}\n    60→\n    61→// ---------------------------------------------------------------------------\n    62→// PDA helpers\n    63→// ---------------------------------------------------------------------------\n    64→\n    65→function deriveConfigPda(): [PublicKey, number] {\n    66→  return PublicKey.findProgramAddressSync(\n    67→    [Buffer.from(\"coinflip_config\")],\n    68→    COINFLIP_PROGRAM_ID,\n    69→  );\n    70→}\n    71→\n    72→function derivePlayerProfilePda(wallet: PublicKey): [PublicKey, number] {\n    73→  return PublicKey.findProgramAddressSync(\n    74→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    75→    PLATFORM_PROGRAM_ID,\n    76→  );\n    77→}\n    78→\n    79→// ---------------------------------------------------------------------------\n    80→// Instruction encoding\n    81→// ---------------------------------------------------------------------------\n    82→\n    83→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    84→function encodeSettleData(secret: Buffer): Buffer {\n    85→  const buf = Buffer.alloc(40);\n    86→  SETTLE_DISCRIMINATOR.copy(buf, 0);\n    87→  secret.copy(buf, 8);\n    88→  return buf;\n    89→}\n    90→\n    91→// ---------------------------------------------------------------------------\n    92→// Result derivation (mirrors on-chain derive_result)\n    93→// ---------------------------------------------------------------------------\n    94→\n    95→/**\n    96→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n    97→ * Must match shared/src/fairness.rs `derive_result()`.\n    98→ */\n    99→function deriveResult(\n   100→  secret: Buffer,\n   101→  entropy: Buffer,\n   102→  matchPdaBytes: Buffer,\n   103→  algoVer: number,\n   104→): Buffer {\n   105→  return createHash(\"sha256\")\n   106→    .update(secret)\n   107→    .update(entropy)\n   108→    .update(matchPdaBytes)\n   109→    .update(Buffer.from([algoVer]))\n   110→    .digest();\n   111→}\n   112→\n   113→// ---------------------------------------------------------------------------\n   114→// Core settle function\n   115→// ---------------------------------------------------------------------------\n   116→\n   117→/**\n   118→ * Build, submit, and confirm a settle transaction for a locked match.\n   119→ *\n   120→ * Steps:\n   121→ * 1. Retrieve secret from DB\n   122→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   123→ * 3. Fetch config account data (treasury)\n   124→ * 4. Read entropy from the entropy account\n   125→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   126→ * 6. Build + submit settle tx\n   127→ * 7. Update DB on confirmation\n   128→ */\n   129→export async function settleMatch(\n   130→  deps: SettleTxDeps,\n   131→  pda: string,\n   132→): Promise<SettleResult> {\n   133→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   134→  const matchPubkey = new PublicKey(pda);\n   135→\n   136→  // 1. Retrieve secret from DB\n   137→  const round = await db.getRoundByPda(pda);\n   138→  if (!round) {\n   139→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   140→  }\n   141→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   142→    throw new PermanentSettleError(\n   143→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   144→    );\n   145→  }\n   146→\n   147→  const secret = Buffer.from(round.secret);\n   148→\n   149→  // Transition to settling (locked → settling)\n   150→  if (round.phase === \"locked\") {\n   151→    await db.updateRoundPhase(pda, \"settling\");\n   152→  }\n   153→\n   154→  // Log settle_submitted\n   155→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   156→    attempt: round.settle_attempts + 1,\n   157→  });\n   158→\n   159→  // 2. Fetch match account data\n   160→  const matchAccountInfo = await connection.getAccountInfo(matchPubkey);\n   161→  if (!matchAccountInfo) {\n   162→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   163→  }\n   164→  const matchData = Buffer.from(matchAccountInfo.data);\n   165→\n   166→  const creator = new PublicKey(\n   167→    matchData.subarray(CREATOR_OFFSET, CREATOR_OFFSET + 32),\n   168→  );\n   169→  const opponent = new PublicKey(\n   170→    matchData.subarray(OPPONENT_OFFSET, OPPONENT_OFFSET + 32),\n   171→  );\n   172→  const creatorSide = matchData.readUInt8(CREATOR_SIDE_OFFSET);\n   173→  const algoVer = matchData.readUInt8(ALGO_VER_OFFSET);\n   174→\n   175→  // 3. Fetch config to get treasury\n   176→  const [configPda] = deriveConfigPda();\n   177→  const configAccountInfo = await connection.getAccountInfo(configPda);\n   178→  if (!configAccountInfo) {\n   179→    throw new PermanentSettleError(\"Coinflip config account not found\");\n   180→  }\n   181→  const configData = Buffer.from(configAccountInfo.data);\n   182→  const treasury = new PublicKey(\n   183→    configData.subarray(\n   184→      CONFIG_TREASURY_OFFSET,\n   185→      CONFIG_TREASURY_OFFSET + 32,\n   186→    ),\n   187→  );\n   188→\n   189→  // 4. Read entropy\n   190→  const entropyInfo = await connection.getAccountInfo(entropyAccount);\n   191→  if (!entropyInfo) {\n   192→    throw new TransientSettleError(\"Entropy account not available yet\");\n   193→  }\n   194→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   195→\n   196→  // 5. Pre-compute result\n   197→  const matchPdaBytes = matchPubkey.toBuffer();\n   198→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   199→  const resultSide = resultHash[0]! % 2;\n   200→  const winner = resultSide === creatorSide ? creator : opponent;\n   201→\n   202→  // 6. Derive profile PDAs\n   203→  const [creatorProfile] = derivePlayerProfilePda(creator);\n   204→  const [opponentProfile] = derivePlayerProfilePda(opponent);\n   205→\n   206→  // 7. Build settle instruction\n   207→  const data = encodeSettleData(secret);\n   208→\n   209→  const instruction = new TransactionInstruction({\n   210→    keys: [\n   211→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   212→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   213→      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n   214→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // entropy\n   215→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   216→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   217→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   218→      { pubkey: creatorProfile, isSigner: false, isWritable: true }, // creator_profile\n   219→      { pubkey: opponentProfile, isSigner: false, isWritable: true }, // opponent_profile\n   220→      {\n   221→        pubkey: PLATFORM_PROGRAM_ID,\n   222→        isSigner: false,\n   223→        isWritable: false,\n   224→      }, // platform_program\n   225→      {\n   226→        pubkey: SystemProgram.programId,\n   227→        isSigner: false,\n   228→        isWritable: false,\n   229→      }, // system_program\n   230→    ],\n   231→    programId: COINFLIP_PROGRAM_ID,\n   232→    data,\n   233→  });\n   234→\n   235→  const { blockhash, lastValidBlockHeight } =\n   236→    await connection.getLatestBlockhash();\n   237→\n   238→  const tx = new Transaction({\n   239→    feePayer: serverKeypair.publicKey,\n   240→    blockhash,\n   241→    lastValidBlockHeight,\n   242→  });\n   243→  tx.add(instruction);\n   244→  tx.sign(serverKeypair);\n   245→\n   246→  // 8. Submit and confirm\n   247→  const rawTx = tx.serialize();\n   248→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   249→    skipPreflight: false,\n   250→  });\n   251→\n   252→  await connection.confirmTransaction(\n   253→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   254→    \"confirmed\",\n   255→  );\n   256→\n   257→  // 9. Update DB — phase settling → settled\n   258→  await db.updateRoundPhase(pda, \"settled\", {\n   259→    settle_tx: txSignature,\n   260→    result_hash: resultHash,\n   261→    result_side: resultSide,\n   262→    winner: winner.toBase58(),\n   263→    settle_attempts: round.settle_attempts + 1,\n   264→  });\n   265→\n   266→  // Log settle_confirmed\n   267→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   268→    txSignature,\n   269→    resultSide,\n   270→    winner: winner.toBase58(),\n   271→  });\n   272→\n   273→  return {\n   274→    txSignature,\n   275→    resultHash,\n   276→    resultSide,\n   277→    winner: winner.toBase58(),\n   278→  };\n   279→}\n   280→\n   281→// ---------------------------------------------------------------------------\n   282→// Error types\n   283→// ---------------------------------------------------------------------------\n   284→\n   285→/** Permanent failure — should not be retried. */\n   286→export class PermanentSettleError extends Error {\n   287→  readonly permanent = true;\n   288→  constructor(message: string) {\n   289→    super(message);\n   290→    this.name = \"PermanentSettleError\";\n   291→  }\n   292→}\n   293→\n   294→/** Transient failure — safe to retry. */\n   295→export class TransientSettleError extends Error {\n   296→  readonly permanent = false;\n   297→  constructor(message: string) {\n   298→    super(message);\n   299→    this.name = \"TransientSettleError\";\n   300→  }\n   301→}\n   302→"}]},"parent_tool_use_id":"toolu_019c2BAXd8iatmYKcyH36SRp","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"e8747cb3-c1c6-47fa-9b54-e71271141313"}
