{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HUvF4vMxN63teTmTu3DPiH","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Default timeout (seconds) for VRF-based games (lordofrngs). Server has 120s to fulfill.\n     4→pub const DEFAULT_RESOLVE_TIMEOUT_SECONDS: i64 = 120;\n     5→\n     6→/// Timeout (seconds) after which a coinflip match can be publicly refunded (24 hours).\n     7→/// Separate from VRF timeout because commit-reveal settlement can be done permissionlessly,\n     8→/// so only a long backstop is needed.\n     9→pub const COINFLIP_RESOLVE_TIMEOUT_SECONDS: i64 = 86_400;\n    10→\n    11→#[error_code]\n    12→pub enum TimeoutError {\n    13→    #[msg(\"Resolve deadline has been exceeded\")]\n    14→    ResolveDeadlineExceeded,\n    15→}\n    16→\n    17→/// Returns `true` when the current time is at or past the resolve deadline.\n    18→pub fn is_expired(resolve_deadline: i64, now: i64) -> bool {\n    19→    now >= resolve_deadline\n    20→}\n    21→\n    22→/// Returns `Ok(())` if the deadline has NOT been exceeded, or an error if it has.\n    23→pub fn enforce_not_expired(resolve_deadline: i64, now: i64) -> Result<()> {\n    24→    if is_expired(resolve_deadline, now) {\n    25→        Err(TimeoutError::ResolveDeadlineExceeded.into())\n    26→    } else {\n    27→        Ok(())\n    28→    }\n    29→}\n    30→\n    31→#[cfg(test)]\n    32→mod tests {\n    33→    use super::*;\n    34→\n    35→    #[test]\n    36→    fn expired_exactly_at_deadline() {\n    37→        assert!(is_expired(1000, 1000));\n    38→    }\n    39→\n    40→    #[test]\n    41→    fn not_expired_one_second_before() {\n    42→        assert!(!is_expired(1000, 999));\n    43→    }\n    44→\n    45→    #[test]\n    46→    fn expired_one_second_after() {\n    47→        assert!(is_expired(1000, 1001));\n    48→    }\n    49→\n    50→    #[test]\n    51→    fn enforce_not_expired_ok_before_deadline() {\n    52→        assert!(enforce_not_expired(1000, 999).is_ok());\n    53→    }\n    54→\n    55→    #[test]\n    56→    fn enforce_not_expired_fails_at_deadline() {\n    57→        assert!(enforce_not_expired(1000, 1000).is_err());\n    58→    }\n    59→\n    60→    #[test]\n    61→    fn enforce_not_expired_fails_after_deadline() {\n    62→        assert!(enforce_not_expired(1000, 1001).is_err());\n    63→    }\n    64→}\n    65→"}]},"parent_tool_use_id":"toolu_01T8L2CnBtwDrecLKqJNthcz","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"37629eca-d90e-46d0-a959-527da2f7d23d"}
