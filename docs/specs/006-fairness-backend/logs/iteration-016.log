{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q3vei1e9HLMz3jdXrNT9rH","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Global configuration for the coinflip program.\n     4→/// PDA seeds: [b\"coinflip_config\"]\n     5→#[account]\n     6→#[derive(InitSpace)]\n     7→pub struct CoinflipConfig {\n     8→    /// Admin authority (can update config).\n     9→    pub authority: Pubkey,\n    10→    /// Fee destination wallet.\n    11→    pub treasury: Pubkey,\n    12→    /// Whether the game is paused (rejects new matches).\n    13→    pub paused: bool,\n    14→    /// Bump seed for PDA derivation.\n    15→    pub bump: u8,\n    16→}\n    17→\n    18→/// A coinflip match between two players (commit-reveal model).\n    19→/// PDA seeds: [b\"match\", creator.key().as_ref(), &nonce.to_le_bytes()]\n    20→#[account]\n    21→#[derive(InitSpace)]\n    22→pub struct CoinflipMatch {\n    23→    /// The player who created the match.\n    24→    pub creator: Pubkey,\n    25→    /// The player who joined (Pubkey::default() if empty).\n    26→    pub opponent: Pubkey,\n    27→    /// Server key that co-signed create and will settle.\n    28→    pub server: Pubkey,\n    29→    /// Tier index (0-7).\n    30→    pub tier: u8,\n    31→    /// Entry amount in lamports (derived from tier).\n    32→    pub entry_amount: u64,\n    33→    /// Side chosen by creator (0 = Heads, 1 = Tails).\n    34→    pub creator_side: u8,\n    35→    /// Current phase (0=Waiting, 1=Locked, 2=Settled, 3=Refunded).\n    36→    pub phase: u8,\n    37→    /// SHA256(server_secret) — committed at create time.\n    38→    pub commitment: [u8; 32],\n    39→    /// Algorithm version used for result derivation.\n    40→    pub algorithm_ver: u8,\n    41→    /// Slot at which entropy should be read (set on join).\n    42→    pub target_slot: u64,\n    43→    /// Unix timestamp deadline for server to settle; after this, timeout refund is available.\n    44→    pub resolve_deadline: i64,\n    45→    /// Derived result hash (set on settle).\n    46→    pub result_hash: [u8; 32],\n    47→    /// The winning side after settlement (0 or 1, only valid when settled).\n    48→    pub result: u8,\n    49→    /// The winner's pubkey (Pubkey::default() until settled).\n    50→    pub winner: Pubkey,\n    51→    /// Unix timestamp when the match was created.\n    52→    pub created_at: i64,\n    53→    /// Match creation nonce from player profile (used in PDA seeds for uniqueness).\n    54→    pub nonce: u64,\n    55→    /// Bump seed for PDA derivation.\n    56→    pub bump: u8,\n    57→    /// Creator has voted for mutual refund.\n    58→    pub creator_wants_refund: bool,\n    59→    /// Opponent has voted for mutual refund.\n    60→    pub opponent_wants_refund: bool,\n    61→}\n    62→\n    63→/// Phase constants\n    64→pub const PHASE_WAITING: u8 = 0;\n    65→pub const PHASE_LOCKED: u8 = 1;\n    66→pub const PHASE_SETTLED: u8 = 2;\n    67→pub const PHASE_REFUNDED: u8 = 3;\n    68→\n    69→/// Event emitted when a match is settled.\n    70→#[event]\n    71→pub struct MatchSettled {\n    72→    pub creator: Pubkey,\n    73→    pub opponent: Pubkey,\n    74→    pub winner: Pubkey,\n    75→    pub commitment: [u8; 32],\n    76→    pub secret: [u8; 32],\n    77→    pub entropy: [u8; 32],\n    78→    pub result_hash: [u8; 32],\n    79→    pub result_side: u8,\n    80→    pub payout_amount: u64,\n    81→    pub fee_amount: u64,\n    82→}\n    83→"}]},"parent_tool_use_id":"toolu_01T8L2CnBtwDrecLKqJNthcz","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"be1b7920-b95b-4091-b7e0-412489199404"}
