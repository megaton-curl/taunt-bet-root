{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012wNxeh2kuCZaHyhMUnifqr","type":"tool_result","content":"     1→import {\n     2→  Connection,\n     3→  Keypair,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→  TransactionInstruction,\n     8→} from \"@solana/web3.js\";\n     9→import { COINFLIP_PROGRAM_ID, deriveMatchPda } from \"./fairness.js\";\n    10→\n    11→/**\n    12→ * create_match instruction discriminator from the coinflip IDL.\n    13→ * SHA256(\"global:create_match\")[0..8]\n    14→ */\n    15→const CREATE_MATCH_DISCRIMINATOR = Buffer.from([\n    16→  107, 2, 184, 145, 70, 142, 17, 165,\n    17→]);\n    18→\n    19→/** Derive the coinflip config PDA (seeds: [\"coinflip_config\"]). */\n    20→function deriveConfigPda(): [PublicKey, number] {\n    21→  return PublicKey.findProgramAddressSync(\n    22→    [Buffer.from(\"coinflip_config\")],\n    23→    COINFLIP_PROGRAM_ID,\n    24→  );\n    25→}\n    26→\n    27→/**\n    28→ * Borsh-encode the create_match instruction data.\n    29→ * Layout: discriminator(8) + commitment(32) + tier(1) + side(1) + nonce(8) = 50 bytes\n    30→ */\n    31→function encodeCreateMatchData(\n    32→  commitment: Buffer,\n    33→  tier: number,\n    34→  side: number,\n    35→  nonce: bigint,\n    36→): Buffer {\n    37→  const buf = Buffer.alloc(50);\n    38→  let offset = 0;\n    39→\n    40→  CREATE_MATCH_DISCRIMINATOR.copy(buf, offset);\n    41→  offset += 8;\n    42→\n    43→  commitment.copy(buf, offset);\n    44→  offset += 32;\n    45→\n    46→  buf.writeUInt8(tier, offset);\n    47→  offset += 1;\n    48→\n    49→  buf.writeUInt8(side, offset);\n    50→  offset += 1;\n    51→\n    52→  buf.writeBigUInt64LE(nonce, offset);\n    53→\n    54→  return buf;\n    55→}\n    56→\n    57→export interface BuildCreateMatchTxParams {\n    58→  connection: Connection;\n    59→  creator: PublicKey;\n    60→  serverKeypair: Keypair;\n    61→  commitment: Buffer;\n    62→  tier: number;\n    63→  side: number;\n    64→  nonce: bigint;\n    65→}\n    66→\n    67→export interface BuildCreateMatchTxResult {\n    68→  /** Base64-serialized partially-signed transaction. */\n    69→  transaction: string;\n    70→  /** The match PDA address. */\n    71→  matchPda: PublicKey;\n    72→}\n    73→\n    74→/**\n    75→ * Build a `create_match` transaction, partially signed by the server.\n    76→ *\n    77→ * - Creator wallet is set as fee payer (server pays zero on-chain cost).\n    78→ * - Server keypair partially signs (as the `server: Signer` account).\n    79→ * - Recent blockhash is fetched at build time.\n    80→ * - Returns base64-serialized tx for the client to co-sign and submit.\n    81→ */\n    82→export async function buildCreateMatchTx(\n    83→  params: BuildCreateMatchTxParams,\n    84→): Promise<BuildCreateMatchTxResult> {\n    85→  const { connection, creator, serverKeypair, commitment, tier, side, nonce } =\n    86→    params;\n    87→\n    88→  const [matchPda] = deriveMatchPda(creator, nonce);\n    89→  const [configPda] = deriveConfigPda();\n    90→\n    91→  const data = encodeCreateMatchData(commitment, tier, side, nonce);\n    92→\n    93→  const instruction = new TransactionInstruction({\n    94→    keys: [\n    95→      { pubkey: creator, isSigner: true, isWritable: true },\n    96→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: false },\n    97→      { pubkey: matchPda, isSigner: false, isWritable: true },\n    98→      { pubkey: configPda, isSigner: false, isWritable: false },\n    99→      {\n   100→        pubkey: SystemProgram.programId,\n   101→        isSigner: false,\n   102→        isWritable: false,\n   103→      },\n   104→    ],\n   105→    programId: COINFLIP_PROGRAM_ID,\n   106→    data,\n   107→  });\n   108→\n   109→  const { blockhash, lastValidBlockHeight } =\n   110→    await connection.getLatestBlockhash();\n   111→\n   112→  const tx = new Transaction({\n   113→    feePayer: creator,\n   114→    blockhash,\n   115→    lastValidBlockHeight,\n   116→  });\n   117→  tx.add(instruction);\n   118→\n   119→  // Partially sign with server keypair only — creator signs client-side\n   120→  tx.partialSign(serverKeypair);\n   121→\n   122→  const serialized = tx\n   123→    .serialize({ requireAllSignatures: false })\n   124→    .toString(\"base64\");\n   125→\n   126→  return { transaction: serialized, matchPda };\n   127→}\n   128→"}]},"parent_tool_use_id":null,"session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"2e6cf312-a62c-41e2-b663-56c0bbbc2c11","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/tx-builder.ts","content":"import {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport { COINFLIP_PROGRAM_ID, deriveMatchPda } from \"./fairness.js\";\n\n/**\n * create_match instruction discriminator from the coinflip IDL.\n * SHA256(\"global:create_match\")[0..8]\n */\nconst CREATE_MATCH_DISCRIMINATOR = Buffer.from([\n  107, 2, 184, 145, 70, 142, 17, 165,\n]);\n\n/** Derive the coinflip config PDA (seeds: [\"coinflip_config\"]). */\nfunction deriveConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n\n/**\n * Borsh-encode the create_match instruction data.\n * Layout: discriminator(8) + commitment(32) + tier(1) + side(1) + nonce(8) = 50 bytes\n */\nfunction encodeCreateMatchData(\n  commitment: Buffer,\n  tier: number,\n  side: number,\n  nonce: bigint,\n): Buffer {\n  const buf = Buffer.alloc(50);\n  let offset = 0;\n\n  CREATE_MATCH_DISCRIMINATOR.copy(buf, offset);\n  offset += 8;\n\n  commitment.copy(buf, offset);\n  offset += 32;\n\n  buf.writeUInt8(tier, offset);\n  offset += 1;\n\n  buf.writeUInt8(side, offset);\n  offset += 1;\n\n  buf.writeBigUInt64LE(nonce, offset);\n\n  return buf;\n}\n\nexport interface BuildCreateMatchTxParams {\n  connection: Connection;\n  creator: PublicKey;\n  serverKeypair: Keypair;\n  commitment: Buffer;\n  tier: number;\n  side: number;\n  nonce: bigint;\n}\n\nexport interface BuildCreateMatchTxResult {\n  /** Base64-serialized partially-signed transaction. */\n  transaction: string;\n  /** The match PDA address. */\n  matchPda: PublicKey;\n}\n\n/**\n * Build a `create_match` transaction, partially signed by the server.\n *\n * - Creator wallet is set as fee payer (server pays zero on-chain cost).\n * - Server keypair partially signs (as the `server: Signer` account).\n * - Recent blockhash is fetched at build time.\n * - Returns base64-serialized tx for the client to co-sign and submit.\n */\nexport async function buildCreateMatchTx(\n  params: BuildCreateMatchTxParams,\n): Promise<BuildCreateMatchTxResult> {\n  const { connection, creator, serverKeypair, commitment, tier, side, nonce } =\n    params;\n\n  const [matchPda] = deriveMatchPda(creator, nonce);\n  const [configPda] = deriveConfigPda();\n\n  const data = encodeCreateMatchData(commitment, tier, side, nonce);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: creator, isSigner: true, isWritable: true },\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: false },\n      { pubkey: matchPda, isSigner: false, isWritable: true },\n      { pubkey: configPda, isSigner: false, isWritable: false },\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      },\n    ],\n    programId: COINFLIP_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } =\n    await connection.getLatestBlockhash();\n\n  const tx = new Transaction({\n    feePayer: creator,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n\n  // Partially sign with server keypair only — creator signs client-side\n  tx.partialSign(serverKeypair);\n\n  const serialized = tx\n    .serialize({ requireAllSignatures: false })\n    .toString(\"base64\");\n\n  return { transaction: serialized, matchPda };\n}\n","numLines":128,"startLine":1,"totalLines":128}}}
