{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SDjGMJSe1hwnMJRayKhA15","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type OperatorEventType =\n    17→  | \"secret_generated\"\n    18→  | \"tx_built\"\n    19→  | \"match_detected\"\n    20→  | \"settle_submitted\"\n    21→  | \"settle_confirmed\"\n    22→  | \"settle_failed\"\n    23→  | \"settle_retried\"\n    24→  | \"timeout_detected\";\n    25→\n    26→export interface Round {\n    27→  pda: string;\n    28→  game: string;\n    29→  creator: string;\n    30→  server_key: string;\n    31→  secret: Buffer;\n    32→  commitment: Buffer;\n    33→  tier: number;\n    34→  side: number;\n    35→  nonce: string; // bigint comes back as string from postgres driver\n    36→  phase: RoundPhase;\n    37→  target_slot: string | null;\n    38→  settle_tx: string | null;\n    39→  settle_attempts: number;\n    40→  result_hash: Buffer | null;\n    41→  result_side: number | null;\n    42→  winner: string | null;\n    43→  created_at: Date;\n    44→  updated_at: Date;\n    45→}\n    46→\n    47→export interface InsertRoundParams {\n    48→  pda: string;\n    49→  game: string;\n    50→  creator: string;\n    51→  serverKey: string;\n    52→  secret: Buffer;\n    53→  commitment: Buffer;\n    54→  tier: number;\n    55→  side: number;\n    56→  nonce: bigint | number;\n    57→  phase: RoundPhase;\n    58→}\n    59→\n    60→export interface OperatorEvent {\n    61→  id: string;\n    62→  pda: string | null;\n    63→  event_type: OperatorEventType;\n    64→  payload: unknown;\n    65→  created_at: Date;\n    66→}\n    67→\n    68→// ---------------------------------------------------------------------------\n    69→// Phase transition guard\n    70→// ---------------------------------------------------------------------------\n    71→\n    72→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n    73→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n    74→  created: [\"locked\", \"expired\"],\n    75→  locked: [\"settling\"],\n    76→  settling: [\"settled\"],\n    77→  settled: [],\n    78→  expired: [],\n    79→};\n    80→\n    81→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n    82→  const allowed = VALID_TRANSITIONS[from];\n    83→  if (!allowed.includes(to)) {\n    84→    throw new Error(\n    85→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    86→    );\n    87→  }\n    88→}\n    89→\n    90→// ---------------------------------------------------------------------------\n    91→// DB client\n    92→// ---------------------------------------------------------------------------\n    93→\n    94→export interface Db {\n    95→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n    96→  insertRound(params: InsertRoundParams): Promise<Round>;\n    97→\n    98→  /** Transition a round's phase. Enforces unidirectional state machine.\n    99→   *  Optional `updates` can set additional columns alongside the phase change. */\n   100→  updateRoundPhase(\n   101→    pda: string,\n   102→    newPhase: RoundPhase,\n   103→    updates?: Partial<\n   104→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   105→    >,\n   106→  ): Promise<Round>;\n   107→\n   108→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   109→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   110→\n   111→  /** Get all rounds matching a given phase. */\n   112→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   113→\n   114→  /** Append an operator event to the audit log. */\n   115→  insertOperatorEvent(\n   116→    pda: string | null,\n   117→    eventType: OperatorEventType,\n   118→    payload?: unknown,\n   119→  ): Promise<OperatorEvent>;\n   120→\n   121→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   122→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   123→\n   124→  /** Gracefully close the connection pool. */\n   125→  close(): Promise<void>;\n   126→}\n   127→\n   128→export function createDb(databaseUrl: string): Db {\n   129→  const sql = postgres(databaseUrl);\n   130→\n   131→  return {\n   132→    async insertRound(params) {\n   133→      const rows = await sql<Round[]>`\n   134→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, tier, side, nonce, phase)\n   135→        VALUES (\n   136→          ${params.pda},\n   137→          ${params.game},\n   138→          ${params.creator},\n   139→          ${params.serverKey},\n   140→          ${params.secret},\n   141→          ${params.commitment},\n   142→          ${params.tier},\n   143→          ${params.side},\n   144→          ${Number(params.nonce)},\n   145→          ${params.phase}\n   146→        )\n   147→        RETURNING *\n   148→      `;\n   149→      return rows[0]!;\n   150→    },\n   151→\n   152→    async updateRoundPhase(pda, newPhase, updates) {\n   153→      // Fetch current phase to validate transition\n   154→      const current = await sql<Pick<Round, \"phase\">[]>`\n   155→        SELECT phase FROM rounds WHERE pda = ${pda}\n   156→      `;\n   157→\n   158→      if (current.length === 0) {\n   159→        throw new Error(`Round not found: ${pda}`);\n   160→      }\n   161→\n   162→      const currentPhase = current[0]!.phase as RoundPhase;\n   163→      assertPhaseTransition(currentPhase, newPhase);\n   164→\n   165→      // Build the update — always set phase + updated_at\n   166→      const rows = await sql<Round[]>`\n   167→        UPDATE rounds SET\n   168→          phase = ${newPhase},\n   169→          updated_at = now(),\n   170→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   171→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   172→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   173→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   174→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   175→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   176→        WHERE pda = ${pda}\n   177→        RETURNING *\n   178→      `;\n   179→\n   180→      return rows[0]!;\n   181→    },\n   182→\n   183→    async getRoundByPda(pda) {\n   184→      const rows = await sql<Round[]>`\n   185→        SELECT * FROM rounds WHERE pda = ${pda}\n   186→      `;\n   187→      return rows[0];\n   188→    },\n   189→\n   190→    async getRoundsByPhase(phase) {\n   191→      return sql<Round[]>`\n   192→        SELECT * FROM rounds WHERE phase = ${phase}\n   193→      `;\n   194→    },\n   195→\n   196→    async insertOperatorEvent(pda, eventType, payload) {\n   197→      const rows = await sql<OperatorEvent[]>`\n   198→        INSERT INTO operator_events (pda, event_type, payload)\n   199→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   200→        RETURNING *\n   201→      `;\n   202→      return rows[0]!;\n   203→    },\n   204→\n   205→    async getUnsettledStats() {\n   206→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   207→        SELECT\n   208→          COUNT(*)::text AS count,\n   209→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   210→        FROM rounds\n   211→        WHERE phase NOT IN ('settled', 'expired')\n   212→      `;\n   213→      const row = rows[0]!;\n   214→      return {\n   215→        count: parseInt(row.count, 10),\n   216→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   217→      };\n   218→    },\n   219→\n   220→    async close() {\n   221→      await sql.end();\n   222→    },\n   223→  };\n   224→}\n   225→"}]},"parent_tool_use_id":"toolu_019c2BAXd8iatmYKcyH36SRp","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"e6c35fc2-22cd-443a-bcef-700d35f38361"}
