{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pz4xbJEE22z797WTBb3Whr","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→#[error_code]\n     4→pub enum CoinflipError {\n     5→    /// 6100 (Anchor adds 6000 base offset)\n     6→    #[msg(\"Invalid side: must be 0 (Heads) or 1 (Tails)\")]\n     7→    InvalidSide = 100,\n     8→\n     9→    /// 6101\n    10→    #[msg(\"Invalid tier index\")]\n    11→    InvalidTier,\n    12→\n    13→    /// 6102\n    14→    #[msg(\"Match is not in the expected phase\")]\n    15→    InvalidPhase,\n    16→\n    17→    /// 6103\n    18→    #[msg(\"Insufficient funds for entry amount\")]\n    19→    InsufficientFunds,\n    20→\n    21→    /// 6104\n    22→    #[msg(\"Creator cannot join their own match\")]\n    23→    CannotJoinOwnMatch,\n    24→\n    25→    /// 6105\n    26→    #[msg(\"Server key mismatch\")]\n    27→    ServerMismatch,\n    28→\n    29→    /// 6106\n    30→    #[msg(\"Commitment does not match sha256(secret)\")]\n    31→    CommitmentMismatch,\n    32→\n    33→    /// 6107\n    34→    #[msg(\"Match can only be cancelled in WAITING phase\")]\n    35→    CannotCancel,\n    36→\n    37→    /// 6108\n    38→    #[msg(\"Lock timeout has not elapsed yet\")]\n    39→    LockTimeoutNotElapsed,\n    40→\n    41→    /// 6109\n    42→    #[msg(\"Entropy account must have at least 32 bytes\")]\n    43→    EntropyTooShort,\n    44→\n    45→    /// 6110\n    46→    #[msg(\"Resolve deadline has not been reached yet\")]\n    47→    DeadlineNotReached,\n    48→\n    49→    /// 6111\n    50→    #[msg(\"Account key does not match expected value\")]\n    51→    AccountMismatch,\n    52→\n    53→    /// 6112\n    54→    #[msg(\"Caller is not a participant in this match\")]\n    55→    NotParticipant,\n    56→\n    57→    /// 6113\n    58→    #[msg(\"Caller has already voted for refund\")]\n    59→    AlreadyVotedRefund,\n    60→}\n    61→"}]},"parent_tool_use_id":"toolu_01T8L2Cn