seInt(\n      process.env.WORKER_POLL_INTERVAL_MS ?? \"2000\",\n      10,\n    ),\n    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n  };\n}\n","numLines":61,"startLine":1,"totalLines":61}}}
