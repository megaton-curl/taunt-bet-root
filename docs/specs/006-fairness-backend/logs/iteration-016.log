{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KZanhD2hFcdjfTg6P43Q9q","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→use rng_shared::fairness::{derive_result, read_mock_entropy, verify_commitment};\n     4→use rng_shared::fees::calculate_net_payout;\n     5→\n     6→use crate::error::CoinflipError;\n     7→use crate::state::{CoinflipConfig, CoinflipMatch, MatchSettled, PHASE_LOCKED, PHASE_SETTLED};\n     8→\n     9→/// Anyone with the secret can settle a locked match (permissionless).\n    10→#[derive(Accounts)]\n    11→pub struct Settle<'info> {\n    12→    /// The caller submitting the settlement. Anyone can call if they have the secret.\n    13→    #[account(mut)]\n    14→    pub caller: Signer<'info>,\n    15→\n    16→    /// The match PDA.\n    17→    #[account(\n    18→        mut,\n    19→        seeds = [b\"match\", coinflip_match.creator.as_ref(), &coinflip_match.nonce.to_le_bytes()],\n    20→        bump = coinflip_match.bump,\n    21→    )]\n    22→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    23→\n    24→    /// The config PDA (for treasury address).\n    25→    #[account(\n    26→        seeds = [b\"coinflip_config\"],\n    27→        bump = config.bump,\n    28→    )]\n    29→    pub config: Account<'info, CoinflipConfig>,\n    30→\n    31→    /// CHECK: Raw account providing 32 bytes of entropy (mock slot hash).\n    32→    pub entropy: UncheckedAccount<'info>,\n    33→\n    34→    /// The treasury account to receive fees.\n    35→    /// CHECK: Validated against config.treasury.\n    36→    #[account(mut)]\n    37→    pub treasury: AccountInfo<'info>,\n    38→\n    39→    /// The creator account.\n    40→    /// CHECK: Validated against coinflip_match.creator.\n    41→    #[account(mut)]\n    42→    pub creator: AccountInfo<'info>,\n    43→\n    44→    /// The opponent account.\n    45→    /// CHECK: Validated against coinflip_match.opponent.\n    46→    #[account(mut)]\n    47→    pub opponent: AccountInfo<'info>,\n    48→\n    49→    /// Creator's player profile PDA on the platform program.\n    50→    /// CHECK: Validated by platform program via CPI (if account exists).\n    51→    #[account(mut)]\n    52→    pub creator_profile: AccountInfo<'info>,\n    53→\n    54→    /// Opponent's player profile PDA on the platform program.\n    55→    /// CHECK: Validated by platform program via CPI (if account exists).\n    56→    #[account(mut)]\n    57→    pub opponent_profile: AccountInfo<'info>,\n    58→\n    59→    /// The platform program for CPI calls.\n    60→    pub platform_program: Program<'info, platform::program::Platform>,\n    61→\n    62→    pub system_program: Program<'info, System>,\n    63→}\n    64→\n    65→pub fn handler(ctx: Context<Settle>, secret: [u8; 32]) -> Result<()> {\n    66→    let match_key: [u8; 32] = ctx.accounts.coinflip_match.key().to_bytes();\n    67→\n    68→    // Read entropy before mutable borrow\n    69→    let entropy = read_mock_entropy(&ctx.accounts.entropy).map_err(|_| CoinflipError::EntropyTooShort)?;\n    70→\n    71→    // Validate account keys\n    72→    require!(\n    73→        ctx.accounts.treasury.key() == ctx.accounts.config.treasury,\n    74→        CoinflipError::AccountMismatch\n    75→    );\n    76→    require!(\n    77→        ctx.accounts.creator.key() == ctx.accounts.coinflip_match.creator,\n    78→        CoinflipError::AccountMismatch\n    79→    );\n    80→    require!(\n    81→        ctx.accounts.opponent.key() == ctx.accounts.coinflip_match.opponent,\n    82→        CoinflipError::AccountMismatch\n    83→    );\n    84→\n    85→    // State reads and writes in scoped borrow\n    86→    let (creator_key, winner_key, nominal_payout, fee, entry_amount, event_base) = {\n    87→        let m = &mut ctx.accounts.coinflip_match;\n    88→        require!(m.phase == PHASE_LOCKED, CoinflipError::InvalidPhase);\n    89→\n    90→        verify_commitment(&m.commitment, &secret).map_err(|_| CoinflipError::CommitmentMismatch)?;\n    91→\n    92→        let result_hash = derive_result(&secret, &entropy, &match_key, m.algorithm_ver);\n    93→        let result_side = result_hash[0] % 2;\n    94→\n    95→        let winner_key = if result_side == m.creator_side {\n    96→            m.creator\n    97→        } else {\n    98→            m.opponent\n    99→        };\n   100→\n   101→        let pool = m.entry_amount.checked_mul(2).unwrap();\n   102→        let (fee, nominal_payout) = calculate_net_payout(pool);\n   103→\n   104→        m.result_hash = result_hash;\n   105→        m.result = result_side;\n   106→        m.winner = winner_key;\n   107→        m.phase = PHASE_SETTLED;\n   108→\n   109→        let event_base = MatchSettled {\n   110→            creator: m.creator,\n   111→            opponent: m.opponent,\n   112→            winner: winner_key,\n   113→            commitment: m.commitment,\n   114→            secret,\n   115→            entropy,\n   116→            result_hash,\n   117→            result_side,\n   118→            payout_amount: 0, // filled after fee transfer\n   119→            fee_amount: fee,\n   120→        };\n   121→\n   122→        (m.creator, winner_key, nominal_payout, fee, m.entry_amount, event_base)\n   123→    };\n   124→\n   125→    // Transfer fee to treasury\n   126→    let match_info = ctx.accounts.coinflip_match.to_account_info();\n   127→    transfer_lamports_from_pda(&match_info, &ctx.accounts.treasury, fee)?;\n   128→\n   129→    // CPI update both player profiles (using nominal payout for stats)\n   130→    let config_bump = ctx.accounts.config.bump;\n   131→    let signer_seeds: &[&[u8]] = &[b\"coinflip_config\", &[config_bump]];\n   132→\n   133→    let creator_is_winner = winner_key == creator_key;\n   134→    rng_shared::cpi::update_player_profile_cpi(\n   135→        &ctx.accounts.platform_program.to_account_info(),\n   136→        &ctx.accounts.creator_profile,\n   137→        &ctx.accounts.config.to_account_info(),\n   138→        signer_seeds,\n   139→        1,\n   140→        if creator_is_winner { 1 } else { 0 },\n   141→        entry_amount,\n   142→        if creator_is_winner { nominal_payout } else { 0 },\n   143→        0, // game_type: coinflip\n   144→    )?;\n   145→\n   146→    rng_shared::cpi::update_player_profile_cpi(\n   147→        &ctx.accounts.platform_program.to_account_info(),\n   148→        &ctx.accounts.opponent_profile,\n   149→        &ctx.accounts.config.to_account_info(),\n   150→        signer_seeds,\n   151→        1,\n   152→        if creator_is_winner { 0 } else { 1 },\n   153→        entry_amount,\n   154→        if creator_is_winner { 0 } else { nominal_payout },\n   155→        0, // game_type: coinflip\n   156→    )?;\n   157→\n   158→    // Winner takes ALL remaining lamports (payout + any rent surplus), zero PDA\n   159→    let winner_account = if winner_key == creator_key {\n   160→        ctx.accounts.creator.to_account_info()\n   161→    } else {\n   162→        ctx.accounts.opponent.to_account_info()\n   163→    };\n   164→    let winner_payout = match_info.lamports();\n   165→    emit!(MatchSettled {\n   166→        payout_amount: winner_payout,\n   167→        ..event_base\n   168→    });\n   169→\n   170→    **winner_account.try_borrow_mut_lamports()? += winner_payout;\n   171→    **match_info.try_borrow_mut_lamports()? = 0;\n   172→    match_info.data.borrow_mut().fill(0);\n   173→\n   174→    Ok(())\n   175→}\n   176→"}]},"parent_tool_use_id":"toolu_01T8L2CnBtwDrecLKqJNthcz","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"ef508470-132b-45c5-9162-e8eea491b1da"}
