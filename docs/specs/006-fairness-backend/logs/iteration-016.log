{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013JHqTvhcCokigjze9etaAZ","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→\n     3→export interface Config {\n     4→  port: number;\n     5→  databaseUrl: string;\n     6→  rpcUrl: string;\n     7→  serverKeypair: Keypair;\n     8→  authClockSkewSeconds: number;\n     9→  rateLimitPerWallet: number;\n    10→  rateLimitGlobal: number;\n    11→  workerPollIntervalMs: number;\n    12→  entropyAccount: string;\n    13→  minSolBalance: number;\n    14→}\n    15→\n    16→function requireEnv(name: string): string {\n    17→  const value = process.env[name];\n    18→  if (!value) {\n    19→    throw new Error(`Missing required environment variable: ${name}`);\n    20→  }\n    21→  return value;\n    22→}\n    23→\n    24→function parseKeypair(raw: string): Keypair {\n    25→  try {\n    26→    const bytes = JSON.parse(raw) as number[];\n    27→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    28→  } catch {\n    29→    throw new Error(\n    30→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    31→    );\n    32→  }\n    33→}\n    34→\n    35→export function loadConfig(): Config {\n    36→  return {\n    37→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    38→    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    39→    rpcUrl: requireEnv(\"RPC_URL\"),\n    40→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    41→    authClockSkewSeconds: parseInt(\n    42→      process.env.AUTH_CLOCK_SKEW_SECONDS ?? \"60\",\n    43→      10,\n    44→    ),\n    45→    rateLimitPerWallet: parseInt(\n    46→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    47→      10,\n    48→    ),\n    49→    rateLimitGlobal: parseInt(\n    50→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    51→      10,\n    52→    ),\n    53→    workerPollIntervalMs: parseInt(\n    54→      process.env.WORKER_POLL_INTERVAL_MS ?? \"2000\",\n    55→      10,\n    56→    ),\n    57→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    58→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    59→  };\n    60→}\n    61→"}]},"parent_tool_use_id":"toolu_019c2BAXd8iatmYKcyH36SRp","session_id":"571f6196-8768-4189-b912-c43475f582e6","uuid":"5c7e9fa2-571f-4c7b-8c6e-80cff91ac284"}
