{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D9QWexEcXjG6xWhgpDYhXT","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→\n     3→export interface Config {\n     4→  port: number;\n     5→  databaseUrl: string;\n     6→  rpcUrl: string;\n     7→  serverKeypair: Keypair;\n     8→  authClockSkewSeconds: number;\n     9→  rateLimitPerWallet: number;\n    10→  rateLimitGlobal: number;\n    11→  workerPollIntervalMs: number;\n    12→}\n    13→\n    14→function requireEnv(name: string): string {\n    15→  const value = process.env[name];\n    16→  if (!value) {\n    17→    throw new Error(`Missing required environment variable: ${name}`);\n    18→  }\n    19→  return value;\n    20→}\n    21→\n    22→function parseKeypair(raw: string): Keypair {\n    23→  try {\n    24→    const bytes = JSON.parse(raw) as number[];\n    25→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    26→  } catch {\n    27→    throw new Error(\n    28→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    29→    );\n    30→  }\n    31→}\n    32→\n    33→export function loadConfig(): Config {\n    34→  return {\n    35→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    36→    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    37→    rpcUrl: requireEnv(\"RPC_URL\"),\n    38→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    39→    authClockSkewSeconds: parseInt(\n    40→      process.env.AUTH_CLOCK_SKEW_SECONDS ?? \"60\",\n    41→      10,\n    42→    ),\n    43→    rateLimitPerWallet: parseInt(\n    44→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    45→      10,\n    46→    ),\n    47→    rateLimitGlobal: parseInt(\n    48→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    49→      10,\n    50→    ),\n    51→    workerPollIntervalMs: parseInt(\n    52→      process.env.WORKER_POLL_INTERVAL_MS ?? \"2000\",\n    53→      10,\n    54→    ),\n    55→  };\n    56→}\n    57→"}]},"parent_tool_use_id":"toolu_01GuyvLbeHWRzmx4ztUM7ohY","session_id":"af244c03-5c35-4a31-9aaa-3171645fdb08","uuid":"36f5a2f2-201e-423b-bce8-9419c6b2bef1"}
