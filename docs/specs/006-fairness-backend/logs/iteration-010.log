.rpcUrl);\n\nconst app = new Hono();\n\n// Health check (placeholder — full implementation in a later checklist item)\napp.get(\"/health\", (c) => {\n  return c.json({ status: \"ok\", version: \"0.1.0\" });\n});\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/fairness/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Auth middleware — verifies wallet Ed25519 signatures on POST requests\napp.use(\n  \"/fairness/*\",\n  createAuthMiddleware({ clockSkewSeconds: config.authClockSkewSeconds }),\n);\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair }),\n);\n\n// Start settlement worker\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n});\nworker.start();\n\nconst port = config.port;\nconsole.log(`fairness-backend listening on :${port}`);\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","structuredPatch":[{"oldStart":1,"oldLines":11,"newStart":1,"newLines":12,"lines":[" import { Hono } from \"hono\";","-import { Connection } from \"@solana/web3.js\";","+import { Connection, PublicKey } from \"@solana/web3.js\";"," import { loadConfig } from \"./config.js\";"," import { createDb } from \"./db.js\";"," import { createCoinflipRoutes } from \"./routes/create.js\";"," import { createAuthMiddleware } from \"./middleware/auth.js\";"," import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";"," import { createSettlementWorker } from \"./worker/settlement.js\";","+import { settleMatch } from \"./worker/settle-tx.js\";"," "," const config = loadConfig();"," const db = createDb(config.databaseUrl);"]}],"userModified":false,"replaceAll":false}}
