nection: Connection;\n  serverKeypair: Keypair;\n  entropyAccount: PublicKey;\n}\n\nexport interface SettleResult {\n  txSignature: string;\n  resultHash: Buffer;\n  resultSide: number;\n  winner: string;\n}\n\n// ---------------------------------------------------------------------------\n// PDA helpers\n// ---------------------------------------------------------------------------\n\nfunction deriveConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n\nfunction derivePlayerProfilePda(wallet: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    PLATFORM_PROGRAM_ID,\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Instruction encoding\n// ---------------------------------------------------------------------------\n\n/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\nfunction encodeSettleData(secret: Buffer): Buffer {\n  const buf = Buffer.alloc(40);\n  SETTLE_DISCRIMINATOR.copy(buf, 0);\n  secret.copy(buf, 8);\n  return buf;\n}\n\n// ---------------------------------------------------------------------------\n// Result derivation (mirrors on-chain derive_result)\n// ---------------------------------------------------------------------------\n\n/**\n * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n * Must match shared/src/fairness.rs `derive_result()`.\n */\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")\n    .update(secret)\n    .update(entropy)\n    .update(matchPdaBytes)\n    .update(Buffer.from([algoVer]))\n    .digest();\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on confirmation\n */\nexport async function settleMatch(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const matchPubkey = new PublicKey(pda);\n\n  // 1. Retrieve secret from DB\n  const round = await db.getRoundByPda(pda);\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  // Transition to settling (locked → settling)\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  // Log settle_submitted\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n  });\n\n  // 2. Fetch match account data\n  const matchAccountInfo = await connection.getAccountInfo(matchPubkey);\n  if (!matchAccountInfo) {\n    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n  }\n  const matchData = Buffer.from(matchAccountInfo.data);\n\n  const creator = new PublicKey(\n    matchData.subarray(CREATOR_OFFSET, CREATOR_OFFSET + 32),\n  );\n  const opponent = new PublicKey(\n    matchData.subarray(OPPONENT_OFFSET, OPPONENT_OFFSET + 32),\n  );\n  const creatorSide = matchData.readUInt8(CREATOR_SIDE_OFFSET);\n  const algoVer = matchData.readUInt8(ALGO_VER_OFFSET);\n\n  // 3. Fetch config to get treasury\n  const [configPda] = deriveConfigPda();\n  const configAccountInfo = await connection.getAccountInfo(configPda);\n  if (!configAccountInfo) {\n    throw new PermanentSettleError(\"Coinflip config account not found\");\n  }\n  const configData = Buffer.from(configAccountInfo.data);\n  const treasury = new PublicKey(\n    configData.subarray(\n      CONFIG_TREASURY_OFFSET,\n      CONFIG_TREASURY_OFFSET + 32,\n    ),\n  );\n\n  // 4. Read entropy\n  const entropyInfo = await connection.getAccountInfo(entropyAccount);\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n\n  // 5. Pre-compute result\n  const matchPdaBytes = matchPubkey.toBuffer();\n  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n  const resultSide = resultHash[0]! % 2;\n  const winner = resultSide === creatorSide ? creator : opponent;\n\n  // 6. Derive profile PDAs\n  const [creatorProfile] = derivePlayerProfilePda(creator);\n  const [opponentProfile] = derivePlayerProfilePda(opponent);\n\n  // 7. Build settle instruction\n  const data = encodeSettleData(secret);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n      { pubkey: configPda, isSigner: false, isWritable: false }, // config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // entropy\n      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n      { pubkey: creatorProfile, isSigner: false, isWritable: true }, // creator_profile\n      { pubkey: opponentProfile, isSigner: false, isWritable: true }, // opponent_profile\n      {\n        pubkey: PLATFORM_PROGRAM_ID,\n        isSigner: false,\n        isWritable: false,\n      }, // platform_program\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      }, // system_program\n    ],\n    programId: COINFLIP_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } =\n    await connection.getLatestBlockhash();\n\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  // 8. Submit and confirm\n  const rawTx = tx.serialize();\n  const txSignature = await connection.sendRawTransaction(rawTx, {\n    skipPreflight: false,\n  });\n\n  await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n\n  // 9. Update DB — phase settling → settled\n  await db.updateRoundPhase(pda, \"settled\", {\n    settle_tx: txSignature,\n    result_hash: resultHash,\n    result_side: resultSide,\n    winner: winner.toBase58(),\n    settle_attempts: round.settle_attempts + 1,\n  });\n\n  // Log settle_confirmed\n  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    resultSide,\n    winner: winner.toBase58(),\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------\n\n/** Permanent failure — should not be retried. */\nexport class PermanentSettleError extends Error {\n  readonly permanent = true;\n  constructor(message: string) {\n    super(message);\n    this.name = \"PermanentSettleError\";\n  }\n}\n\n/** Transient failure — safe to retry. */\nexport class TransientSettleError extends Error {\n  readonly permanent = false;\n  constructor(message: string) {\n    super(message);\n    this.name = \"TransientSettleError\";\n  }\n}\n","structuredPatch":[],"originalFile":null}}
