{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GfrXUyeGaqcJG2CmEQjRP5","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→\n     3→export interface Config {\n     4→  port: number;\n     5→  databaseUrl: string;\n     6→  rpcUrl: string;\n     7→  serverKeypair: Keypair;\n     8→  authClockSkewSeconds: number;\n     9→  rateLimitPerWallet: number;\n    10→  rateLimitGlobal: number;\n    11→  workerPollIntervalMs: number;\n    12→}\n    13→\n    14→function requireEnv(name: string): string {\n    15→  const value = process.env[name];\n    16→  if (!value) {\n    17→    throw new Error(`Missing required environment variable: ${name}`);\n    18→  }\n    19→  return value;\n    20→}\n    21→\n    22→function parseKeypair(raw: string): Keypair {\n    23→  try {\n    24→    const bytes = JSON.parse(raw) as number[];\n    25→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    26→  } catch {\n    27→    throw new Error(\n    28→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    29→    );\n    30→  }\n    31→}\n    32→\n    33→export function loadConfig(): Config {\n    34→  return {\n    35→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    36→    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    37→    rpcUrl: requireEnv(\"RPC_URL\"),\n    38→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    39→    authClockSkewSeconds: parseInt(\n    40→      process.env.AUTH_CLOCK_SKEW_SECONDS ?? \"60\",\n    41→      10,\n    42→    ),\n    43→    rateLimitPerWallet: parseInt(\n    44→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    45→      10,\n    46→    ),\n    47→    rateLimitGlobal: parseInt(\n    48→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    49→      10,\n    50→    ),\n    51→    workerPollIntervalMs: parseInt(\n    52→      process.env.WORKER_POLL_INTERVAL_MS ?? \"2000\",\n    53→      10,\n    54→    ),\n    55→  };\n    56→}\n    57→"}]},"parent_tool_use_id":null,"session_id":"af244c03-5c35-4a31-9aaa-3171645fdb08","uuid":"324acf2d-f697-4c92-b362-64005c2ae2ef","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/config.ts","content":"import { Keypair } from \"@solana/web3.js\";\n\nexport interface Config {\n  port: number;\n  databaseUrl: string;\n  rpcUrl: string;\n  serverKeypair: Keypair;\n  authClockSkewSeconds: number;\n  rateLimitPerWallet: number;\n  rateLimitGlobal: number;\n  workerPollIntervalMs: number;\n}\n\nfunction requireEnv(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction parseKeypair(raw: string): Keypair {\n  try {\n    const bytes = JSON.parse(raw) as number[];\n    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n  } catch {\n    throw new Error(\n      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    );\n  }\n}\n\nexport function loadConfig(): Config {\n  return {\n    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    authClockSkewSeconds: parseInt(\n      process.env.AUTH_CLOCK_SKEW_SECONDS ?? \"60\",\n      10,\n    ),\n    rateLimitPerWallet: parseInt(\n      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n      10,\n    ),\n    rateLimitGlobal: parseInt(\n      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n      10,\n    ),\n    workerPollIntervalMs: parseInt(\n      process.env.WORKER_POLL_INTERVAL_MS ?? \"2000\",\n      10,\n    ),\n  };\n}\n","numLines":57,"startLine":1,"totalLines":57}}}
