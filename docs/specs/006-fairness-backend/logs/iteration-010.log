{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RrERnEJUtFSKAnbwNumbaj","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→pub mod error;\n     4→pub mod instructions;\n     5→pub mod state;\n     6→\n     7→use instructions::*;\n     8→\n     9→declare_id!(\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\");\n    10→\n    11→#[program]\n    12→pub mod coinflip {\n    13→    use super::*;\n    14→\n    15→    pub fn initialize_config(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n    16→        instructions::initialize_config::handler(ctx, treasury)\n    17→    }\n    18→\n    19→    pub fn create_match(\n    20→        ctx: Context<CreateMatch>,\n    21→        commitment: [u8; 32],\n    22→        tier: u8,\n    23→        side: u8,\n    24→        nonce: u64,\n    25→    ) -> Result<()> {\n    26→        instructions::create_match::handler(ctx, commitment, tier, side, nonce)\n    27→    }\n    28→\n    29→    pub fn join_match(ctx: Context<JoinMatch>) -> Result<()> {\n    30→        instructions::join_match::handler(ctx)\n    31→    }\n    32→\n    33→    pub fn settle(ctx: Context<Settle>, secret: [u8; 32]) -> Result<()> {\n    34→        instructions::settle::handler(ctx, secret)\n    35→    }\n    36→\n    37→    pub fn cancel_match(ctx: Context<CancelMatch>) -> Result<()> {\n    38→        instructions::cancel_match::handler(ctx)\n    39→    }\n    40→\n    41→    pub fn request_refund(ctx: Context<RequestRefund>) -> Result<()> {\n    42→        instructions::request_refund::handler(ctx)\n    43→    }\n    44→\n    45→    pub fn timeout_refund(ctx: Context<TimeoutRefund>) -> Result<()> {\n    46→        instructions::timeout_refund::handler(ctx)\n    47→    }\n    48→}\n    49→"}]},"parent_tool_use_id":"toolu_01LexjPTDJ3dVvrSLmKz3vny","session_id":"af244c03-5c35-4a31-9aaa-3171645fdb08","uuid":"324b9d3a-bb8e-4c5e-b54a-a532d3d4c61a"}
