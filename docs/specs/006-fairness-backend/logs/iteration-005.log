{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QoU6NCYsKAsxawjGvvay24","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→/// Fixed tier entry amounts in lamports.\n     4→/// Index 0 = Copper, 1 = Iron, 2 = Bronze, 3 = Silver, 4 = Gold,\n     5→/// 5 = Platinum, 6 = Diamond, 7 = Emerald\n     6→pub const TIER_AMOUNTS: [u64; 8] = [\n     7→    2_500_000,       // 0.0025 SOL — Copper\n     8→    5_000_000,       // 0.005  SOL — Iron\n     9→    10_000_000,      // 0.01   SOL — Bronze\n    10→    50_000_000,      // 0.05   SOL — Silver\n    11→    100_000_000,     // 0.1    SOL — Gold\n    12→    250_000_000,     // 0.25   SOL — Platinum\n    13→    500_000_000,     // 0.5    SOL — Diamond\n    14→    1_000_000_000,   // 1.0    SOL — Emerald\n    15→];\n    16→\n    17→pub const TIER_COUNT: usize = TIER_AMOUNTS.len();\n    18→\n    19→/// Returns the entry amount for the given tier index, or an error if out of range.\n    20→pub fn get_tier_amount(tier: u8) -> Result<u64> {\n    21→    TIER_AMOUNTS\n    22→        .get(tier as usize)\n    23→        .copied()\n    24→        .ok_or_else(|| error!(TierError::InvalidTier))\n    25→}\n    26→\n    27→#[error_code]\n    28→pub enum TierError {\n    29→    #[msg(\"Invalid tier index\")]\n    30→    InvalidTier,\n    31→}\n    32→"}]},"parent_tool_use_id":"toolu_01VDTZs1DRBrxXWb3diEQCix","session_id":"3430bba8-c97c-4931-9858-17bde76503d2","uuid":"2ab00091-f4e4-48bd-aec0-4ecb49257559"}
