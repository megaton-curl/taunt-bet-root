is not paused (`check_not_paused`)\n2. Validates side is valid (0 or 1) — error `InvalidSide`\n3. Looks up tier amount via `get_tier_amount(tier)` — error `InvalidTier`\n4. Calculates rent-exempt minimum balance\n5. Transfers lamports from creator to match PDA if entry amount exceeds rent\n6. Initializes `CoinflipMatch` state with:\n   - creator, server, tier, entry_amount, creator_side\n   - phase = PHASE_WAITING (0)\n   - commitment = hash parameter\n   - algorithm_ver = ALGORITHM_VERSION (1)\n   - nonce, bump, created_at (current Unix timestamp)\n   - All other fields zeroed/default\n\n---\n\n### State Structures\n**File**: `/workspaces/rng-utopia/sources/rng-utopia/solana/programs/coinflip/src/state.rs`\n\n**CoinflipMatch**:\n```rust\n#[account]\n#[derive(InitSpace)]\npub struct CoinflipMatch {\n    pub creator: Pubkey,                          // 32 bytes\n    pub opponent: Pubkey,                         // 32 bytes (default if empty)\n    pub server: Pubkey,                           // 32 bytes\n    pub tier: u8,                                 // 1 byte (0-7)\n    pub entry_amount: u64,                        // 8 bytes (derived from tier)\n    pub creator_side: u8,                         // 1 byte (0=Heads, 1=Tails)\n    pub phase: u8,                                // 1 byte (0=Waiting, 1=Locked, 2=Settled, 3=Refunded)\n    pub commitment: [u8; 32],                     // 32 bytes (SHA256(server_secret))\n    pub algorithm_ver: u8,                        // 1 byte\n    pub target_slot: u64,                         // 8 bytes (set on join)\n    pub resolve_deadline: i64,                    // 8 bytes (timestamp deadline)\n    pub result_hash: [u8; 32],                    // 32 bytes (set on settle)\n    pub result: u8,                               // 1 byte (winning side, 0 or 1)\n    pub winner: Pubkey,                           // 32 bytes\n    pub created_at: i64,                          // 8 bytes (Unix timestamp)\n    pub nonce: u64,                               // 8 bytes (match nonce)\n    pub bump: u8,                                 // 1 byte (PDA bump)\n    pub creator_wants_refund: bool,               // 1 byte\n    pub opponent_wants_refund: bool,              // 1 byte\n}\n// Total: 8 (discriminator) + 238 (InitSpace) = 246 bytes\n```\n\n**CoinflipConfig**:\n```rust\n#[account]\n#[derive(InitSpace)]\npub struct CoinflipConfig {\n    pub authority: Pubkey,                        // Admin authority\n    pub treasury: Pubkey,                         // Fee destination\n    pub paused: bool,                             // Whether game is paused\n    pub bump: u8,                                 // PDA bump\n}\n```\n\n---\n\n### Tier System\n**File**: `/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/tiers.rs`\n\n```rust\npub const TIER_AMOUNTS: [u64; 8] = [\n    2_500_000,       // 0.0025 SOL — Copper (tier 0)\n    5_000_000,       // 0.005  SOL — Iron (tier 1)\n    10_000_000,      // 0.01   SOL — Bronze (tier 2)\n    50_000_000,      // 0.05   SOL — Silver (tier 3)\n    100_000_000,     // 0.1    SOL — Gold (tier 4)\n    250_000_000,     // 0.25   SOL — Platinum (tier 5)\n    500_000_000,     // 0.5    SOL — Diamond (tier 6)\n    1_000_000_000,   // 1.0    SOL — Emerald (tier 7)\n];\n\npub fn get_tier_amount(tier: u8) -> Result<u64> {\n    TIER_AMOUNTS\n        .get(tier as usize)\n        .copied()\n        .ok_or_else(|| error!(TierError::InvalidTier))\n}\n```\n\n---\n\n### Constants & Fairness\n**File**: `/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/constants.rs`\n\n```rust\npub const SIDE_HEADS: u8 = 0;\npub const SIDE_TAILS: u8 = 1;\n\npub fn is_valid_side(side: u8) -> bool {\n    side == SIDE_HEADS || side == SIDE_TAILS\n}\n```\n\n**File**: `/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/fairness.rs`\n\n```rust\npub const ALGORITHM_VERSION: u8 = 1;\n\n/// Verifies that SHA256(secret) matches the stored commitment.\npub fn verify_commitment(commitment: &[u8; 32], secret: &[u8; 32]) -> Result<()> {\n    let hash = hashv(&[secret]);\n    require!(\n        hash.to_bytes() == *commitment,\n        FairnessError::CommitmentMismatch\n    );\n    Ok(())\n}\n\n/// Derives a deterministic result hash from secret + entropy + game PDA + algorithm version.\npub fn derive_result(\n    secret: &[u8; 32],\n    entropy: &[u8; 32],\n    game_pda: &[u8; 32],\n    algo_ver: u8,\n) -> [u8; 32] {\n    hashv(&[secret, entropy, game_pda, &[algo_ver]]).to_bytes()\n}\n```\n\n---\n\n### Fee Structure\n**File**: `/workspaces/rng-utopia/sources/rng-utopia/solana/shared/src/fees.rs`\n\n```rust\npub const TOTAL_FEE_BPS: u16 = 300;      // 3% total\npub const REVENUE_BPS: u16 = 200;        // 2% platform revenue\npub const RAKEBACK_BPS: u16 = 70;        // 0.7% rakeback pool\npub const CHEST_BPS: u16 = 30;           // 0.3% chest treasury\n\npub fn calculate_fee(amount: u64) -> u64 {\n    (amount as u128 * TOTAL_FEE_BPS as u128 / 10_000) as u64\n}\n\npub fn split_fee(fee: u64) -> (u64, u64, u64) {\n    // Returns: (revenue, rakeback, chest)\n}\n```\n\n---\n\n### Backend Fairness Utilities\n**File**: `/workspaces/rng-utopia/services/backend/src/fairness.ts`\n\n```typescript\nconst COINFLIP_PROGRAM_ID = new PublicKey(\n  \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n);\n\nexport function generateSecret(): Buffer {\n  return randomBytes(32);\n}\n\nexport function computeCommitment(secret: Buffer): Buffer {\n  return createHash(\"sha256\").update(secret).digest();\n}\n\nexport function deriveMatchPda(\n  creator: PublicKey,\n  nonce: number | bigint,\n): [PublicKey, number] {\n  const nonceBuf = Buffer.alloc(8);\n  nonceBuf.writeBigUInt64LE(BigInt(nonce));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n```\n\n---\n\n### Backend Config\n**File**: `/workspaces/rng-utopia/services/backend/src/config.ts`\n\n```typescript\nexport interface Config {\n  port: number;\n  databaseUrl: string;\n  rpcUrl: string;\n  serverKeypair: Keypair;\n}\n\nexport function loadConfig(): Config {\n  return {\n    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n  };\n}\n```\n\n---\n\n### Backend Dependencies\n**File**: `/workspaces/rng-utopia/services/backend/package.json`\n\n```json\n{\n  \"name\": \"@rng-utopia/backend\",\n  \"version\": \"0.1.0\",\n  \"type\": \"module\",\n  \"dependencies\": {\n    \"hono\": \"^4.6.0\",\n    \"postgres\": \"^3.4.0\",\n    \"@solana/web3.js\": \"^1.98.0\"\n  },\n  \"devDependencies\": {\n    \"@rng-utopia/config\": \"workspace:*\",\n    \"@types/node\": \"^22.10.0\",\n    \"tsx\": \"^4.7.0\",\n    \"typescript\": \"^5.7.0\",\n    \"vitest\": \"^2.1.0\"\n  }\n}\n```\n\n---\n\n## Summary for Transaction Builder\n\nTo build a `create_match` transaction in your backend service, you will need to:\n\n1. **Generate a server secret** using `generateSecret()` from the fairness module\n2. **Compute the commitment** hash using `computeCommitment(secret)`\n3. **Derive the match PDA** using `deriveMatchPda(creatorPublicKey, nonce)`\n4. **Validate inputs**: \n   - Tier must be 0-7\n   - Side must be 0 (Heads) or 1 (Tails)\n   - Nonce should come from the creator's player profile\n5. **Assemble accounts**:\n   - creator (signer, writable)\n   - server (signer, must be your serverKeypair)\n   - coinflip_match (PDA derived above)\n   - config (PDA with seed `[\"coinflip_config\"]`)\n   - system_program\n6. **Build instruction** with args: `[commitment, tier, side, nonce]`\n7. **Sign with both creator and server keypairs**\n\nAll files are located at `/workspaces/rng-utopia/sources/rng-utopia/` with relative paths shown above."}],"totalDurationMs":65997,"totalTokens":54393,"totalToolUseCount":19,"usage":{"input_tokens":5,"cache_creation_input_tokens":1442,"cache_read_inp