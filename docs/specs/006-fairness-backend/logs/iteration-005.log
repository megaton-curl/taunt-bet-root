{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dj7uqsYF5c3BDuqyEoxCqZ","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use solana_sha256_hasher::hashv;\n     3→\n     4→/// Current algorithm version for result derivation.\n     5→pub const ALGORITHM_VERSION: u8 = 1;\n     6→\n     7→/// Number of slots to wait after join before entropy can be read.\n     8→pub const ENTROPY_SLOT_OFFSET: u64 = 12;\n     9→\n    10→/// Verifies that `SHA256(secret)` matches the stored commitment.\n    11→pub fn verify_commitment(commitment: &[u8; 32], secret: &[u8; 32]) -> Result<()> {\n    12→    let hash = hashv(&[secret]);\n    13→    require!(\n    14→        hash.to_bytes() == *commitment,\n    15→        FairnessError::CommitmentMismatch\n    16→    );\n    17→    Ok(())\n    18→}\n    19→\n    20→/// Derives a deterministic result hash from secret + entropy + game PDA + algorithm version.\n    21→pub fn derive_result(\n    22→    secret: &[u8; 32],\n    23→    entropy: &[u8; 32],\n    24→    game_pda: &[u8; 32],\n    25→    algo_ver: u8,\n    26→) -> [u8; 32] {\n    27→    hashv(&[secret, entropy, game_pda, &[algo_ver]]).to_bytes()\n    28→}\n    29→\n    30→/// Reads 32 bytes of entropy from a raw account (mock slot hash in tests).\n    31→pub fn read_mock_entropy(account: &AccountInfo) -> Result<[u8; 32]> {\n    32→    let data = account.try_borrow_data()?;\n    33→    require!(data.len() >= 32, FairnessError::EntropyTooShort);\n    34→    let mut entropy = [0u8; 32];\n    35→    entropy.copy_from_slice(&data[..32]);\n    36→    Ok(entropy)\n    37→}\n    38→\n    39→#[error_code]\n    40→pub enum FairnessError {\n    41→    #[msg(\"Commitment does not match sha256(secret)\")]\n    42→    CommitmentMismatch,\n    43→    #[msg(\"Entropy account must have at least 32 bytes\")]\n    44→    EntropyTooShort,\n    45→}\n    46→\n    47→#[cfg(test)]\n    48→mod tests {\n    49→    use super::*;\n    50→\n    51→    #[test]\n    52→    fn verify_commitment_valid() {\n    53→        let secret = [42u8; 32];\n    54→        let commitment = hashv(&[&secret]).to_bytes();\n    55→        assert!(verify_commitment(&commitment, &secret).is_ok());\n    56→    }\n    57→\n    58→    #[test]\n    59→    fn verify_commitment_invalid() {\n    60→        let secret = [42u8; 32];\n    61→        let wrong_secret = [99u8; 32];\n    62→        let commitment = hashv(&[&secret]).to_bytes();\n    63→        assert!(verify_commitment(&commitment, &wrong_secret).is_err());\n    64→    }\n    65→\n    66→    #[test]\n    67→    fn derive_result_deterministic() {\n    68→        let secret = [1u8; 32];\n    69→        let entropy = [2u8; 32];\n    70→        let pda = [3u8; 32];\n    71→        let r1 = derive_result(&secret, &entropy, &pda, 1);\n    72→        let r2 = derive_result(&secret, &entropy, &pda, 1);\n    73→        assert_eq!(r1, r2);\n    74→    }\n    75→\n    76→    #[test]\n    77→    fn derive_result_different_inputs() {\n    78→        let secret = [1u8; 32];\n    79→        let entropy = [2u8; 32];\n    80→        let pda = [3u8; 32];\n    81→        let r1 = derive_result(&secret, &entropy, &pda, 1);\n    82→        let r2 = derive_result(&secret, &entropy, &pda, 2);\n    83→        assert_ne!(r1, r2);\n    84→    }\n    85→}\n    86→"}]},"parent_tool_use_id":"toolu_01VDTZs1DRBrxXWb3diEQCix","session_id":"3430bba8-c97c-4931-9858-17bde76503d2","uuid":"ecbb6ccc-520a-4875-8c20-cfc92acfa39a"}
