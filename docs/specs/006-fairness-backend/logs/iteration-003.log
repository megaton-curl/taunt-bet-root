{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015tn9C9yTJZbCkku3kVcKSf","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→\n     3→export interface Config {\n     4→  port: number;\n     5→  databaseUrl: string;\n     6→  rpcUrl: string;\n     7→  serverKeypair: Keypair;\n     8→}\n     9→\n    10→function requireEnv(name: string): string {\n    11→  const value = process.env[name];\n    12→  if (!value) {\n    13→    throw new Error(`Missing required environment variable: ${name}`);\n    14→  }\n    15→  return value;\n    16→}\n    17→\n    18→function parseKeypair(raw: string): Keypair {\n    19→  try {\n    20→    const bytes = JSON.parse(raw) as number[];\n    21→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    22→  } catch {\n    23→    throw new Error(\n    24→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    25→    );\n    26→  }\n    27→}\n    28→\n    29→export function loadConfig(): Config {\n    30→  return {\n    31→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    32→    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    33→    rpcUrl: requireEnv(\"RPC_URL\"),\n    34→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    35→  };\n    36→}\n    37→"}]},"parent_tool_use_id":null,"session_id":"06cad3ba-f7e8-434b-bb69-4c100d6ca881","uuid":"ed732bbf-181e-4483-9f04-37d48dc2b6ce","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/config.ts","content":"import { Keypair } from \"@solana/web3.js\";\n\nexport interface Config {\n  port: number;\n  databaseUrl: string;\n  rpcUrl: string;\n  serverKeypair: Keypair;\n}\n\nfunction requireEnv(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction parseKeypair(raw: string): Keypair {\n  try {\n    const bytes = JSON.parse(raw) as number[];\n    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n  } catch {\n    throw new Error(\n      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    );\n  }\n}\n\nexport function loadConfig(): Config {\n  return {\n    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n  };\n}\n","numLines":37,"startLine":1,"totalLines":37}}}
