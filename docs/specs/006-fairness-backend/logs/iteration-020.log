  TypeScript only (lint + typecheck + build + test)\n#   ./scripts/verify --devnet     Devnet E2E tests (non-blocking, skips if env vars missing)\n# =============================================================================\n\n# Color codes\nGREEN='\\033[0;32m'\nRED='\\033[0;31m'\nYELLOW='\\033[0;33m'\nNC='\\033[0m'\n\nMODE=\"${1:-full}\"\n\n# Normalize flags\ncase \"$MODE\" in\n    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n    --ts|--ts-only|ts) MODE=\"ts\" ;;\n    --devnet|devnet) MODE=\"devnet\" ;;\n    --full|full|\"\") MODE=\"full\" ;;\n    *)\n        echo \"Usage: ./scripts/verify [--anchor|--ts|--devnet|--full]\"\n        exit 1\n        ;;\nesac\n\necho -e \"${GREEN}=== RNG Utopia Verification ($MODE) ===${NC}\"\n\n# Check for submodule\nif [ ! -f \"sources/rng-utopia/package.json\" ]; then\n    echo -e \"${RED}[FAIL] Submodule not initialized.${NC}\"\n    echo \"Run: git submodule update --init --recursive\"\n    exit 1\nfi\n\n# ---------------------------------------------------------------------------\n# TypeScript steps (lint, typecheck, build, test)\n# ---------------------------------------------------------------------------\nrun_ts() {\n    cd sources/rng-utopia\n\n    # Install dependencies if missing\n    if [ ! -d \"node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n        pnpm install\n    fi\n\n    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n    pnpm lint\n\n    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n    pnpm typecheck\n\n    echo -e \"${GREEN}[STEP] Building frontend entrypoint (apps/platform)...${NC}\"\n    pnpm build\n\n    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n    pnpm test\n\n    echo -e \"${GREEN}[STEP] Visual regression tests...${NC}\"\n    pnpm test:visual\n\n    cd ../..\n}\n\n# ---------------------------------------------------------------------------\n# Anchor steps (build + test)\n# ---------------------------------------------------------------------------\nrun_anchor() {\n    if ! command -v anchor &>/dev/null; then\n        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n        return 0\n    fi\n\n    cd sources/rng-utopia/solana\n\n    if [ ! -d \"node_modules\" ]; then\n        pnpm install --ignore-workspace\n    fi\n\n    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n    anchor build\n\n    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n    pnpm exec mocha --require tsx/cjs -t 1000000 --exit tests/coinflip.ts tests/lordofrngs.ts tests/platform.ts\n\n    cd ../../..\n}\n\n# ---------------------------------------------------------------------------\n# Devnet E2E tests (non-blocking)\n# ---------------------------------------------------------------------------\nrun_devnet_e2e() {\n    if [ -z \"${VITE_COINFLIP_PROGRAM_ID:-}\" ]; then\n        echo -e \"${YELLOW}[SKIP] Devnet E2E (VITE_COINFLIP_PROGRAM_ID not set)${NC}\"\n        return 0\n    fi\n\n    cd sources/rng-utopia\n\n    if [ ! -d \"node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n        pnpm install\n    fi\n\n    echo -e \"${GREEN}[STEP] Running devnet E2E tests...${NC}\"\n    if pnpm test:e2e:devnet; then\n        echo -e \"${GREEN}[PASS] Devnet E2E tests passed${NC}\"\n    else\n        echo -e \"${YELLOW}[WARN] Devnet E2E tests failed (non-blocking)${NC}\"\n    fi\n\n    cd ../..\n    return 0\n}\n\n# ---------------------------------------------------------------------------\n# Run based on mode\n# ---------------------------------------------------------------------------\ncase \"$MODE\" in\n    full)\n        run_ts\n        run_anchor\n        ;;\n    ts)\n        run_ts\n        ;;\n    anchor)\n        run_anchor\n        ;;\n    devnet)\n        run_devnet_e2e\n        ;;\nesac\n\necho -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\nexit 0\n","numLines":146,"startLine":1,"totalLines":146}}}
