{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YUgdgyfvFo6H4jvdkVLZjd","type":"tool_result","content":"     1→#!/bin/bash\n     2→set -e\n     3→export CI=true\n     4→\n     5→# =============================================================================\n     6→# verify — End-to-end verification for RNG Utopia\n     7→#\n     8→# Usage:\n     9→#   ./scripts/verify              Full verification (all steps)\n    10→#   ./scripts/verify --anchor     Anchor programs only (build + test)\n    11→#   ./scripts/verify --ts         TypeScript only (lint + typecheck + build + test)\n    12→#   ./scripts/verify --devnet     Devnet E2E tests (non-blocking, skips if env vars missing)\n    13→# =============================================================================\n    14→\n    15→# Color codes\n    16→GREEN='\\033[0;32m'\n    17→RED='\\033[0;31m'\n    18→YELLOW='\\033[0;33m'\n    19→NC='\\033[0m'\n    20→\n    21→MODE=\"${1:-full}\"\n    22→\n    23→# Normalize flags\n    24→case \"$MODE\" in\n    25→    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n    26→    --ts|--ts-only|ts) MODE=\"ts\" ;;\n    27→    --devnet|devnet) MODE=\"devnet\" ;;\n    28→    --full|full|\"\") MODE=\"full\" ;;\n    29→    *)\n    30→        echo \"Usage: ./scripts/verify [--anchor|--ts|--devnet|--full]\"\n    31→        exit 1\n    32→        ;;\n    33→esac\n    34→\n    35→echo -e \"${GREEN}=== RNG Utopia Verification ($MODE) ===${NC}\"\n    36→\n    37→# Check for submodule\n    38→if [ ! -f \"sources/rng-utopia/package.json\" ]; then\n    39→    echo -e \"${RED}[FAIL] Submodule not initialized.${NC}\"\n    40→    echo \"Run: git submodule update --init --recursive\"\n    41→    exit 1\n    42→fi\n    43→\n    44→# ---------------------------------------------------------------------------\n    45→# TypeScript steps (lint, typecheck, build, test)\n    46→# ---------------------------------------------------------------------------\n    47→run_ts() {\n    