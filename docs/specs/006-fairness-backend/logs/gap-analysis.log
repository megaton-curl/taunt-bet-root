{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y6AVDfUZWsduLf3aJSMZVi","type":"tool_result","content":"     1→import { randomBytes, createHash } from \"node:crypto\";\n     2→import { PublicKey } from \"@solana/web3.js\";\n     3→\n     4→export const COINFLIP_PROGRAM_ID = new PublicKey(\n     5→  \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n     6→);\n     7→\n     8→/** Generate a 32-byte cryptographically secure random secret. */\n     9→export function generateSecret(): Buffer {\n    10→  return randomBytes(32);\n    11→}\n    12→\n    13→/**\n    14→ * Compute commitment = sha256(secret).\n    15→ * Matches the algorithm in packages/fairness/src/commitment.ts.\n    16→ */\n    17→export function computeCommitment(secret: Buffer): Buffer {\n    18→  return createHash(\"sha256\").update(secret).digest();\n    19→}\n    20→\n    21→/**\n    22→ * Derive match PDA using seeds [\"match\", creator, nonce.to_le_bytes()].\n    23→ * Matches the on-chain program's PDA derivation.\n    24→ */\n    25→export function deriveMatchPda(\n    26→  creator: PublicKey,\n    27→  nonce: number | bigint,\n    28→): [PublicKey, number] {\n    29→  const nonceBuf = Buffer.alloc(8);\n    30→  nonceBuf.writeBigUInt64LE(BigInt(nonce));\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    33→    COINFLIP_PROGRAM_ID,\n    34→  );\n    35→}\n    36→"}]},"parent_tool_use_id":null,"session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"cee0a8c4-f475-478c-904f-93722a8abe5f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/fairness.ts","content":"import { randomBytes, createHash } from \"node:crypto\";\nimport { PublicKey } from \"@solana/web3.js\";\n\nexport const COINFLIP_PROGRAM_ID = new PublicKey(\n  \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n);\n\n/** Generate a 32-byte cryptographically secure random secret. */\nexport function generateSecret(): Buffer {\n  return randomBytes(32);\n}\n\n/**\n * Compute commitment = sha256(secret).\n * Matches the algorithm in packages/fairness/src/commitment.ts.\n */\nexport function computeCommitment(secret: Buffer): Buffer {\n  return createHash(\"sha256\").update(secret).digest();\n}\n\n/**\n * Derive match PDA using seeds [\"match\", creator, nonce.to_le_bytes()].\n * Matches the on-chain program's PDA derivation.\n */\nexport function deriveMatchPda(\n  creator: PublicKey,\n  nonce: number | bigint,\n): [PublicKey, number] {\n  const nonceBuf = Buffer.alloc(8);\n  nonceBuf.writeBigUInt64LE(BigInt(nonce));\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    COINFLIP_PROGRAM_ID,\n  );\n}\n","numLines":36,"startLine":1,"totalLines":36}}}
