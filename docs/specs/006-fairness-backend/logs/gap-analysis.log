{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SqZmc5Q1BuKFNd68R4wg96","type":"tool_result","content":"     1→import { sha256 } from \"@noble/hashes/sha256\";\n     2→import { bytesToHex, hexToBytes } from \"@noble/hashes/utils\";\n     3→\n     4→/**\n     5→ * Compute a commitment from a server seed\n     6→ * commitment = sha256(serverSeed)\n     7→ */\n     8→export function computeCommitment(serverSeed: string): string {\n     9→  const seedBytes = hexToBytes(serverSeed);\n    10→  const hash = sha256(seedBytes);\n    11→  return bytesToHex(hash);\n    12→}\n    13→\n    14→/**\n    15→ * Verify that a server seed matches its commitment\n    16→ */\n    17→export function verifyCommitment(serverSeed: string, commitment: string): boolean {\n    18→  const computed = computeCommitment(serverSeed);\n    19→  return computed.toLowerCase() === commitment.toLowerCase();\n    20→}\n    21→"}]},"parent_tool_use_id":"toolu_013SMc3BMP8E6SA5d6gqSxGa","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"5278b4da-0b82-4f21-9058-d52ea079092a"}
