{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015Ffb4dpE165kAV1DiNKvyN","type":"tool_result","content":"     1→{\n     2→  \"address\": \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n     3→  \"metadata\": {\n     4→    \"name\": \"coinflip\",\n     5→    \"version\": \"0.1.0\",\n     6→    \"spec\": \"0.1.0\"\n     7→  },\n     8→  \"instructions\": [\n     9→    {\n    10→      \"name\": \"cancel_match\",\n    11→      \"discriminator\": [\n    12→        142,\n    13→        136,\n    14→        247,\n    15→        45,\n    16→        92,\n    17→        112,\n    18→        180,\n    19→        83\n    20→      ],\n    21→      \"accounts\": [\n    22→        {\n    23→          \"name\": \"creator\",\n    24→          \"docs\": [\n    25→            \"The creator cancelling their match.\"\n    26→          ],\n    27→          \"writable\": true,\n    28→          \"signer\": true\n    29→        },\n    30→        {\n    31→          \"name\": \"coinflip_match\",\n    32→          \"docs\": [\n    33→            \"The match PDA (closed on cancel — escrow + rent refunded to creator).\"\n    34→          ],\n    35→          \"writable\": true,\n    36→          \"pda\": {\n    37→            \"seeds\": [\n    38→              {\n    39→                \"kind\": \"const\",\n    40→                \"value\": [\n    41→                  109,\n    42→                  97,\n    43→                  116,\n    44→                  99,\n    45→                  104\n    46→                ]\n    47→              },\n    48→              {\n    49→                \"kind\": \"account\",\n    50→                \"path\": \"creator\"\n    51→              },\n    52→              {\n    53→                \"kind\": \"account\",\n    54→                \"path\": \"coinflip_match.nonce\",\n    55→                \"account\": \"CoinflipMatch\"\n    56→              }\n    57→            ]\n    58→          }\n    59→        },\n    60→        {