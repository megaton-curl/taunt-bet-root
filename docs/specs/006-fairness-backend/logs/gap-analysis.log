{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_018rxgaDbbx9Hdvivcgv83Ge","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Wsk86k2777BfJ3JmeK9qbG","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4986,"cache_read_input_tokens":60403,"cache_creation":{"ephemeral_5m_input_tokens":4986,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01AjWj6Dy3kJJJmaV1n984WU","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"06e7b5fe-f4ee-4631-b6a7-71f2876ee3f3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wsk86k2777BfJ3JmeK9qbG","type":"tool_result","content":"     1→/**\n     2→ * HTTP endpoint tests — exercises the full middleware stack (rate limit + auth)\n     3→ * and route handlers for all endpoints:\n     4→ *\n     5→ * POST /fairness/coinflip/create:\n     6→ *   - 200 with valid auth\n     7→ *   - 401 with invalid signature\n     8→ *   - 401 with expired timestamp\n     9→ *   - 409 with duplicate nonce\n    10→ *   - 429 when rate limit exceeded\n    11→ *\n    12→ * GET /fairness/rounds/:pda:\n    13→ *   - 200 for known PDA\n    14→ *   - 404 for unknown PDA\n    15→ *\n    16→ * GET /health:\n    17→ *   - 200 with expected fields\n    18→ */\n    19→\n    20→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    21→import { Hono } from \"hono\";\n    22→import { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\n    23→import type { Connection } from \"@solana/web3.js\";\n    24→import nacl from \"tweetnacl\";\n    25→import bs58 from \"bs58\";\n    26→import postgres from \"postgres\";\n    27→import { createDb, type Db } from \"../db.js\";\n    28→import { createCoinflipRoutes } from \"../routes/create.js\";\n    29→import { createRoundsRoutes } from \"../routes/rounds.js\";\n    30→import { createHealthRoutes } from \"../routes/health.js\";\n    31→import { createAuthMiddleware } from \"../middleware/auth.js\";\n    32→import { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n    33→\n    34→// ---------------------------------------------------------------------------\n    35→// Constants\n    36→// ---------------------------------------------------------------------------\n    37→\n    38→const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    39→const TIER_IRON = 1;\n    40→const SIDE_HEADS = 0;\n    41→\n    42→// ---------------------------------------------------------------------------\n    43→// Minimal mock Connection (only what routes + health need)\n    44→// ---------------------------------------------------------------------------\n    45→\n    46→class MockConnection {\n    47→  async getLatestBlockhash() {\n    48→    return {\n    49→      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n    50→      lastValidBlockHeight: 999_999,\n    51→    };\n    52→  }\n    53→\n    54→  async getBalance() {\n    55→    return 1.5 * LAMPORTS_PER_SOL;\n    56→  }\n    57→}\n    58→\n    59→// ---------------------------------------------------------------------------\n    60→// Auth helper\n    61→// ---------------------------------------------------------------------------\n    62→\n    63→function signCreateRequest(\n    64→  keypair: Keypair,\n    65→  body: { wallet: string; tier: number; side: number; nonce: number; timestamp: number },\n    66→): string {\n    67→  const canonical = JSON.stringify({\n    68→    wallet: body.wallet,\n    69→    tier: body.tier,\n    70→    side: body.side,\n    71→    nonce: body.nonce,\n    72→    timestamp: body.timestamp,\n    73→  });\n    74→  const messageBytes = new TextEncoder().encode(canonical);\n    75→  const sigBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n    76→  return bs58.encode(sigBytes);\n    77→}\n    78→\n    79→function makeBody(wallet: string, overrides?: Partial<{ tier: number; side: number; nonce: number; timestamp: number }>) {\n    80→  return {\n    81→    wallet,\n    82→    tier: overrides?.tier ?? TIER_IRON,\n    83→    side: overrides?.side ?? SIDE_HEADS,\n    84→    nonce: overrides?.nonce ?? Math.floor(Math.random() * 1_000_000),\n    85→    timestamp: overrides?.timestamp ?? Math.floor(Date.now() / 1000),\n    86→  };\n    87→}\n    88→\n    89→// ---------------------------------------------------------------------------\n    90→// Test suite\n    91→// ---------------------------------------------------------------------------\n    92→\n    93→describe(\"HTTP endpoint tests\", () => {\n    94→  let db: Db;\n    95→  let rawSql: ReturnType<typeof postgres>;\n    96→  let mockConn: MockConnection;\n    97→\n    98→  const serverKeypair = Keypair.generate();\n    99→  const creatorKeypair = Keypair.generate();\n   100→\n   101→  beforeAll(async () => {\n   102→    db = createDb(DATABASE_URL);\n   103→    rawSql = postgres(DATABASE_URL);\n   104→  });\n   105→\n   106→  afterAll(async () => {\n   107→    await db.close();\n   108→    await rawSql.end();\n   109→  });\n   110→\n   111→  beforeEach(async () => {\n   112→    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n   113→    mockConn = new MockConnection();\n   114→  });\n   115→\n   116→  // -----------------------------------------------------------------------\n   117→  // Helper: build a fresh Hono app with full middleware stack\n   118→  // -----------------------------------------------------------------------\n   119→\n   120→  function buildApp(opts?: { perWallet?: number; global?: number }) {\n   121→    const app = new Hono();\n   122→\n   123→    app.use(\n   124→      \"/fairness/*\",\n   125→      createRateLimitMiddleware({\n   126→        perWallet: opts?.perWallet ?? 10,\n   127→        global: opts?.global ?? 100,\n   128→        windowMs: 60_000,\n   129→      }),\n   130→    );\n   131→\n   132→    app.use(\n   133→      \"/fairness/*\",\n   134→      createAuthMiddleware({ clockSkewSeconds: 60 }),\n   135→    );\n   136→\n   137→    app.route(\n   138→      \"/fairness/coinflip\",\n   139→      createCoinflipRoutes({\n   140→        db,\n   141→        connection: mockConn as unknown as Connection,\n   142→        serverKeypair,\n   143→      }),\n   144→    );\n   145→\n   146→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   147→\n   148→    app.route(\n   149→      \"/health\",\n   150→      createHealthRoutes({\n   151→        db,\n   152→        connection: mockConn as unknown as Connection,\n   153→        serverKey: serverKeypair.publicKey,\n   154→        isWorkerRunning: () => true,\n   155→        minSolBalance: 0.1,\n   156→      }),\n   157→    );\n   158→\n   159→    return app;\n   160→  }\n   161→\n   162→  // -----------------------------------------------------------------------\n   163→  // POST /fairness/coinflip/create\n   164→  // -----------------------------------------------------------------------\n   165→\n   166→  describe(\"POST /fairness/coinflip/create\", () => {\n   167→    it(\"returns 200 with valid auth\", async () => {\n   168→      const app = buildApp();\n   169→      const wallet = creatorKeypair.publicKey.toBase58();\n   170→      const body = makeBody(wallet);\n   171→      const signature = signCreateRequest(creatorKeypair, body);\n   172→\n   173→      const res = await app.request(\"/fairness/coinflip/create\", {\n   174→        method: \"POST\",\n   175→        headers: { \"Content-Type\": \"application/json\" },\n   176→        body: JSON.stringify({ ...body, signature }),\n   177→      });\n   178→\n   179→      expect(res.status).toBe(200);\n   180→      const json = (await res.json()) as Record<string, unknown>;\n   181→      expect(json.transaction).toBeDefined();\n   182→      expect(typeof json.transaction).toBe(\"string\");\n   183→      expect(json.matchPda).toBeDefined();\n   184→      expect(typeof json.matchPda).toBe(\"string\");\n   185→      expect(json.commitment).toBeDefined();\n   186→      expect(typeof json.commitment).toBe(\"string\");\n   187→      // Commitment should be 64 hex chars (32 bytes)\n   188→      expect((json.commitment as string).length).toBe(64);\n   189→    });\n   190→\n   191→    it(\"returns 401 with invalid signature\", async () => {\n   192→      const app = buildApp();\n   193→      const wallet = creatorKeypair.publicKey.toBase58();\n   194→      const body = makeBody(wallet);\n   195→      // Sign with a DIFFERENT keypair\n   196→      const wrongKeypair = Keypair.generate();\n   197→      const badSignature = signCreateRequest(wrongKeypair, body);\n   198→\n   199→      const res = await app.request(\"/fairness/coinflip/create\", {\n   200→        method: \"POST\",\n   201→        headers: { \"Content-Type\": \"application/json\" },\n   202→        body: JSON.stringify({ ...body, signature: badSignature }),\n   203→      });\n   204→\n   205→      expect(res.status).toBe(401);\n   206→      const json = (await res.json()) as Record<string, unknown>;\n   207→      expect(json.error).toBeDefined();\n   208→    });\n   209→\n   210→    it(\"returns 401 with expired timestamp\", async () => {\n   211→      const app = buildApp();\n   212→      const wallet = creatorKeypair.publicKey.toBase58();\n   213→      // Timestamp 120 seconds in the past (exceeds 60s clock skew)\n   214→      const body = makeBody(wallet, { timestamp: Math.floor(Date.now() / 1000) - 120 });\n   215→      const signature = signCreateRequest(creatorKeypair, body);\n   216→\n   217→      const res = await app.request(\"/fairness/coinflip/create\", {\n   218→        method: \"POST\",\n   219→        headers: { \"Content-Type\": \"application/json\" },\n   220→        body: JSON.stringify({ ...body, signature }),\n   221→      });\n   222→\n   223→      expect(res.status).toBe(401);\n   224→      const json = (await res.json()) as Record<string, unknown>;\n   225→      expect(json.error).toContain(\"expired\");\n   226→    });\n   227→\n   228→    it(\"returns 409 with duplicate nonce\", async () => {\n   229→      const app = buildApp();\n   230→      const wallet = creatorKeypair.publicKey.toBase58();\n   231→      const nonce = 42;\n   232→\n   233→      // First request — should succeed\n   234→      const body1 = makeBody(wallet, { nonce });\n   235→      const sig1 = signCreateRequest(creatorKeypair, body1);\n   236→      const res1 = await app.request(\"/fairness/coinflip/create\", {\n   237→        method: \"POST\",\n   238→        headers: { \"Content-Type\": \"application/json\" },\n   239→        body: JSON.stringify({ ...body1, signature: sig1 }),\n   240→      });\n   241→      expect(res1.status).toBe(200);\n   242→\n   243→      // Second request with same nonce — should conflict\n   244→      const body2 = makeBody(wallet, { nonce });\n   245→      const sig2 = signCreateRequest(creatorKeypair, body2);\n   246→      const res2 = await app.request(\"/fairness/coinflip/create\", {\n   247→        method: \"POST\",\n   248→        headers: { \"Content-Type\": \"application/json\" },\n   249→        body: JSON.stringify({ ...body2, signature: sig2 }),\n   250→      });\n   251→      expect(res2.status).toBe(409);\n   252→      const json = (await res2.json()) as Record<string, unknown>;\n   253→      expect(json.error).toContain(\"already exists\");\n   254→    });\n   255→\n   256→    it(\"returns 429 when rate limit exceeded\", async () => {\n   257→      // Create app with very low per-wallet limit\n   258→      const app = buildApp({ perWallet: 2, global: 100 });\n   259→      const wallet = creatorKeypair.publicKey.toBase58();\n   260→\n   261→      // Send 2 requests (within limit)\n   262→      for (let i = 0; i < 2; i++) {\n   263→        const body = makeBody(wallet, { nonce: 1000 + i });\n   264→        const sig = signCreateRequest(creatorKeypair, body);\n   265→        const res = await app.request(\"/fairness/coinflip/create\", {\n   266→          method: \"POST\",\n   267→          headers: { \"Content-Type\": \"application/json\" },\n   268→          body: JSON.stringify({ ...body, signature: sig }),\n   269→        });\n   270→        expect(res.status).toBe(200);\n   271→      }\n   272→\n   273→      // Third request should be rate-limited\n   274→      const body3 = makeBody(wallet, { nonce: 1002 });\n   275→      const sig3 = signCreateRequest(creatorKeypair, body3);\n   276→      const res3 = await app.request(\"/fairness/coinflip/create\", {\n   277→        method: \"POST\",\n   278→        headers: { \"Content-Type\": \"application/json\" },\n   279→        body: JSON.stringify({ ...body3, signature: sig3 }),\n   280→      });\n   281→      expect(res3.status).toBe(429);\n   282→      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n   283→      const json = (await res3.json()) as Record<string, unknown>;\n   284→      expect(json.error).toContain(\"Too many\");\n   285→    });\n   286→  });\n   287→\n   288→  // -----------------------------------------------------------------------\n   289→  // GET /fairness/rounds/:pda\n   290→  // -----------------------------------------------------------------------\n   291→\n   292→  describe(\"GET /fairness/rounds/:pda\", () => {\n   293→    it(\"returns 200 for known PDA\", async () => {\n   294→      const app = buildApp();\n   295→      const wallet = creatorKeypair.publicKey.toBase58();\n   296→      const body = makeBody(wallet);\n   297→      const signature = signCreateRequest(creatorKeypair, body);\n   298→\n   299→      // Create a round first\n   300→      const createRes = await app.request(\"/fairness/coinflip/create\", {\n   301→        method: \"POST\",\n   302→        headers: { \"Content-Type\": \"application/json\" },\n   303→        body: JSON.stringify({ ...body, signature }),\n   304→      });\n   305→      expect(createRes.status).toBe(200);\n   306→      const createJson = (await createRes.json()) as { matchPda: string; commitment: string };\n   307→\n   308→      // Fetch the round\n   309→      const roundRes = await app.request(`/fairness/rounds/${createJson.matchPda}`);\n   310→      expect(roundRes.status).toBe(200);\n   311→\n   312→      const roundJson = (await roundRes.json()) as Record<string, unknown>;\n   313→      expect(roundJson.pda).toBe(createJson.matchPda);\n   314→      expect(roundJson.game).toBe(\"coinflip\");\n   315→      expect(roundJson.phase).toBe(\"created\");\n   316→      expect(roundJson.creator).toBe(wallet);\n   317→      expect(roundJson.commitment).toBe(createJson.commitment);\n   318→      expect(roundJson.tier).toBe(TIER_IRON);\n   319→      expect(roundJson.side).toBe(SIDE_HEADS);\n   320→      expect(roundJson.createdAt).toBeDefined();\n   321→      expect(roundJson.updatedAt).toBeDefined();\n   322→      // Unsettled: secret and verification should NOT be present\n   323→      expect(roundJson.secret).toBeUndefined();\n   324→      expect(roundJson.verification).toBeUndefined();\n   325→    });\n   326→\n   327→    it(\"returns 404 for unknown PDA\", async () => {\n   328→      const app = buildApp();\n   329→      const unknownPda = Keypair.generate().publicKey.toBase58();\n   330→      const res = await app.request(`/fairness/rounds/${unknownPda}`);\n   331→      expect(res.status).toBe(404);\n   332→      const json = (await res.json()) as Record<string, unknown>;\n   333→      expect(json.error).toContain(\"not found\");\n   334→    });\n   335→  });\n   336→\n   337→  // -----------------------------------------------------------------------\n   338→  // GET /health\n   339→  // -----------------------------------------------------------------------\n   340→\n   341→  describe(\"GET /health\", () => {\n   342→    it(\"returns 200 with expected fields\", async () => {\n   343→      const app = buildApp();\n   344→      const res = await app.request(\"/health\");\n   345→      expect(res.status).toBe(200);\n   346→\n   347→      const json = (await res.json()) as Record<string, unknown>;\n   348→      expect(json.status).toBe(\"ok\");\n   349→      expect(json.version).toBe(\"0.1.0\");\n   350→      expect(json.serverKey).toBe(serverKeypair.publicKey.toBase58());\n   351→      expect(typeof json.solBalance).toBe(\"number\");\n   352→      expect(json.solBalance).toBe(1.5);\n   353→      expect(json.dbConnected).toBe(true);\n   354→      expect(json.workerRunning).toBe(true);\n   355→      expect(typeof json.unsettledCount).toBe(\"number\");\n   356→      expect(typeof json.oldestUnsettledAge).toBe(\"number\");\n   357→    });\n   358→\n   359→    it(\"reflects unsettled round count\", async () => {\n   360→      const app = buildApp();\n   361→\n   362→      // Create a round so there's an unsettled one\n   363→      const wallet = creatorKeypair.publicKey.toBase58();\n   364→      const body = makeBody(wallet);\n   365→      const signature = signCreateRequest(creatorKeypair, body);\n   366→      const createRes = await app.request(\"/fairness/coinflip/create\", {\n   367→        method: \"POST\",\n   368→        headers: { \"Content-Type\": \"application/json\" },\n   369→        body: JSON.stringify({ ...body, signature }),\n   370→      });\n   371→      expect(createRes.status).toBe(200);\n   372→\n   373→      const healthRes = await app.request(\"/health\");\n   374→      expect(healthRes.status).toBe(200);\n   375→      const json = (await healthRes.json()) as Record<string, unknown>;\n   376→      expect(json.unsettledCount).toBe(1);\n   377→    });\n   378→  });\n   379→});\n   380→"}]},"parent_tool_use_id":"toolu_01AjWj6Dy3kJJJmaV1n984WU","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"61e273eb-af6f-4bb2-be3d-0eed04ab45db"}
