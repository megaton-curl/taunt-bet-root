{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HgJtDgDZY9jJZSQwt5LRXp","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→\n     4→use crate::error::CoinflipError;\n     5→use crate::state::{CoinflipMatch, PHASE_LOCKED, PHASE_REFUNDED};\n     6→\n     7→/// Either player can request a mutual refund. When both have voted, refund executes immediately.\n     8→#[derive(Accounts)]\n     9→pub struct RequestRefund<'info> {\n    10→    /// Must be creator or opponent.\n    11→    pub caller: Signer<'info>,\n    12→\n    13→    /// The creator's account — receives remaining lamports if refund executes.\n    14→    /// CHECK: Validated against coinflip_match.creator.\n    15→    #[account(mut)]\n    16→    pub creator: AccountInfo<'info>,\n    17→\n    18→    /// The opponent's account — receives entry_amount if refund executes.\n    19→    /// CHECK: Validated against coinflip_match.opponent.\n    20→    #[account(mut)]\n    21→    pub opponent: AccountInfo<'info>,\n    22→\n    23→    /// The match PDA.\n    24→    #[account(\n    25→        mut,\n    26→        seeds = [b\"match\", coinflip_match.creator.as_ref(), &coinflip_match.nonce.to_le_bytes()],\n    27→        bump = coinflip_match.bump,\n    28→    )]\n    29→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    30→}\n    31→\n    32→pub fn handler(ctx: Context<RequestRefund>) -> Result<()> {\n    33→    let caller_key = ctx.accounts.caller.key();\n    34→\n    35→    // Validation reads (immutable)\n    36→    let creator_key = ctx.accounts.coinflip_match.creator;\n    37→    let opponent_key = ctx.accounts.coinflip_match.opponent;\n    38→    let phase = ctx.accounts.coinflip_match.phase;\n    39→    let entry_amount = ctx.accounts.coinflip_match.entry_amount;\n    40→    let already_creator = ctx.accounts.coinflip_match.creator_wants_refund;\n    41→    let already_opponent = ctx.accounts.coinflip_match.opponent_wants_refund;\n    42→\n    43→    require!(phase == PHASE_LOCKED, CoinflipError::InvalidPhase);\n    44→    require_keys_eq!(ctx.accounts.creator.key(), creator_key);\n    45→    require_keys_eq!(ctx.accounts.opponent.key(), opponent_key);\n    46→\n    47→    let is_creator = caller_key == creator_key;\n    48→    let is_opponent = caller_key == opponent_key;\n    49→    require!(is_creator || is_opponent, CoinflipError::NotParticipant);\n    50→\n    51→    if is_creator {\n    52→        require!(!already_creator, CoinflipError::AlreadyVotedRefund);\n    53→    } else {\n    54→        require!(!already_opponent, CoinflipError::AlreadyVotedRefund);\n    55→    }\n    56→\n    57→    // Mutable writes\n    58→    let m = &mut ctx.accounts.coinflip_match;\n    59→    if is_creator {\n    60→        m.creator_wants_refund = true;\n    61→    } else {\n    62→        m.opponent_wants_refund = true;\n    63→    }\n    64→\n    65→    let both_voted = m.creator_wants_refund && m.opponent_wants_refund;\n    66→\n    67→    if both_voted {\n    68→        m.phase = PHASE_REFUNDED;\n    69→    }\n    70→\n    71→    // Drop mutable borrow before lamport manipulation\n    72→    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    73→\n    74→    if both_voted {\n    75→        // Opponent gets entry_amount back\n    76→        transfer_lamports_from_pda(&match_info, &ctx.accounts.opponent, entry_amount)?;\n    77→\n    78→        // Creator gets all remaining (entry + rent surplus), zero PDA\n    79→        let remaining = match_info.lamports();\n    80→        **ctx.accounts.creator.try_borrow_mut_lamports()? += remaining;\n    81→        **match_info.try_borrow_mut_lamports()? = 0;\n    82→        match_info.data.borrow_mut().fill(0);\n    83→    }\n    84→\n    85→    Ok(())\n    86→}\n    87→"}]},"parent_tool_use_id":"toolu_013SMc3BMP8E6SA5d6gqSxGa","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"93bca28c-1227-435a-9390-a947e0fefc48"}
