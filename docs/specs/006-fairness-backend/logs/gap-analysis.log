{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lcro1vLreVk7ynVYMsF7Fq","type":"tool_result","content":"     1→/**\n     2→ * Settlement retry logic — wraps settleMatch with exponential backoff\n     3→ * for transient failures and proper handling of permanent failures.\n     4→ *\n     5→ * Called by the settlement worker's onSettleReady callback on each poll\n     6→ * cycle for every locked match whose target_slot has been reached.\n     7→ */\n     8→\n     9→import { Connection, PublicKey } from \"@solana/web3.js\";\n    10→import type { Db } from \"../db.js\";\n    11→import type { SettleResult } from \"./settle-tx.js\";\n    12→import { PermanentSettleError } from \"./settle-tx.js\";\n    13→import { logger } from \"../logger.js\";\n    14→\n    15→// ---------------------------------------------------------------------------\n    16→// Constants\n    17→// ---------------------------------------------------------------------------\n    18→\n    19→const MAX_RETRIES = 5;\n    20→const BASE_DELAY_MS = 2_000;\n    21→const MAX_DELAY_MS = 30_000;\n    22→\n    23→/** resolve_deadline: i64 at offset 156 in CoinflipMatch account data */\n    24→const RESOLVE_DEADLINE_OFFSET = 156;\n    25→\n    26→// ---------------------------------------------------------------------------\n    27→// Types\n    28→// ---------------------------------------------------------------------------\n    29→\n    30→export interface RetrySettlerDeps {\n    31→  db: Db;\n    32→  connection: Connection;\n    33→  settleMatch: (pda: string) => Promise<SettleResult>;\n    34→}\n    35→\n    36→interface RetryState {\n    37→  attempts: number;\n    38→  /** Timestamp (ms) at which next retry is allowed. */\n    39→  nextRetryAt: number;\n    40→}\n    41→\n    42→export interface RetrySettler {\n    43→  /**\n    44→   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n    45→   * failure tracking, and resolve_deadline timeout detection.\n    46→   *\n    47→   * Safe to call repeatedly — skips if a retry is scheduled but not yet due,\n    48→   * or if the PDA has already been marked as permanently failed / timed out.\n    49→   */\n    50→  attemptSettle(pda: string): Promise<void>;\n    51→}\n    52→\n    53→// ---------------------------------------------------------------------------\n    54→// Factory\n    55→// ---------------------------------------------------------------------------\n    56→\n    57→export function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n    58→  const { db, connection, settleMatch } = deps;\n    59→\n    60→  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n    61→  const retryStates = new Map<string, RetryState>();\n    62→\n    63→  /** PDAs that hit a permanent (non-retryable) error. */\n    64→  const failedPdas = new Set<string>();\n    65→\n    66→  /** PDAs whose resolve_deadline has passed. */\n    67→  const timeoutPdas = new Set<string>();\n    68→\n    69→  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n    70→  function getDelay(attempt: number): number {\n    71→    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n    72→  }\n    73→\n    74→  /**\n    75→   * Check whether the on-chain resolve_deadline has passed for a match.\n    76→   * Returns true if the deadline is in the past (timeout refund eligible).\n    77→   */\n    78→  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    79→    try {\n    80→      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n    81→      if (!accountInfo) return true; // account gone — treat as expired\n    82→      const data = Buffer.from(accountInfo.data);\n    83→      if (data.length < RESOLVE_DEADLINE_OFFSET + 8) return false;\n    84→      const resolveDeadline = Number(data.readBigInt64LE(RESOLVE_DEADLINE_OFFSET));\n    85→      if (resolveDeadline <= 0) return false; // not set yet\n    86→      const nowUnix = Math.floor(Date.now() / 1000);\n    87→      return nowUnix >= resolveDeadline;\n    88→    } catch {\n    89→      return false; // can't read — don't assume timeout\n    90→    }\n    91→  }\n    92→\n    93→  async function attemptSettle(pda: string): Promise<void> {\n    94→    // Skip permanently failed or timed-out PDAs\n    95→    if (failedPdas.has(pda) || timeoutPdas.has(pda)) return;\n    96→\n    97→    const state = retryStates.get(pda);\n    98→\n    99→    // If a retry is scheduled but not yet due, skip\n   100→    if (state && Date.now() < state.nextRetryAt) return;\n   101→\n   102→    // If max retries exceeded, mark as failed\n   103→    if (state && state.attempts >= MAX_RETRIES) {\n   104→      failedPdas.add(pda);\n   105→      retryStates.delete(pda);\n   106→      await db.insertOperatorEvent(pda, \"settle_failed\", {\n   107→        reason: \"max retries exceeded\",\n   108→        attempts: state.attempts,\n   109→      });\n   110→      logger.error(\"settle failed — max retries exceeded\", {\n   111→        pda,\n   112→        attempts: state.attempts,\n   113→      });\n   114→      return;\n   115→    }\n   116→\n   117→    // Check resolve_deadline before attempting\n   118→    if (await isResolveDeadlinePassed(pda)) {\n   119→      timeoutPdas.add(pda);\n   120→      retryStates.delete(pda);\n   121→      await db.insertOperatorEvent(pda, \"timeout_detected\", {\n   122→        reason: \"resolve_deadline passed without successful settlement\",\n   123→        attempts: state?.attempts ?? 0,\n   124→      });\n   125→      logger.warn(\"resolve deadline passed, stopping settlement attempts\", {\n   126→        pda,\n   127→      });\n   128→      return;\n   129→    }\n   130→\n   131→    try {\n   132→      const result = await settleMatch(pda);\n   133→\n   134→      // Success — clear retry state\n   135→      retryStates.delete(pda);\n   136→      logger.info(\"match settled\", {\n   137→        pda,\n   138→        tx: result.txSignature,\n   139→        resultSide: result.resultSide,\n   140→        winner: result.winner,\n   141→      });\n   142→    } catch (err) {\n   143→      if (err instanceof PermanentSettleError) {\n   144→        // Permanent failure — do not retry\n   145→        failedPdas.add(pda);\n   146→        retryStates.delete(pda);\n   147→        await db.insertOperatorEvent(pda, \"settle_failed\", {\n   148→          reason: err.message,\n   149→          permanent: true,\n   150→        });\n   151→        logger.error(\"settle permanently failed\", {\n   152→          pda,\n   153→          error: err.message,\n   154→        });\n   155→      } else {\n   156→        // Transient failure — schedule retry with exponential backoff\n   157→        const attempts = (state?.attempts ?? 0) + 1;\n   158→        const delay = getDelay(attempts - 1);\n   159→\n   160→        retryStates.set(pda, {\n   161→          attempts,\n   162→          nextRetryAt: Date.now() + delay,\n   163→        });\n   164→\n   165→        await db.insertOperatorEvent(pda, \"settle_retried\", {\n   166→          attempt: attempts,\n   167→          nextRetryInMs: delay,\n   168→          error: err instanceof Error ? err.message : String(err),\n   169→        });\n   170→        logger.warn(\"settle transient failure, scheduling retry\", {\n   171→          pda,\n   172→          attempt: attempts,\n   173→          nextRetryInMs: delay,\n   174→          error: err instanceof Error ? err.message : String(err),\n   175→        });\n   176→      }\n   177→    }\n   178→  }\n   179→\n   180→  return { attemptSettle };\n   181→}\n   182→"}]},"parent_tool_use_id":null,"session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"bad1b29e-0719-4959-9fba-bf24c187886f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/retry.ts","content":"/**\n * Settlement retry logic — wraps settleMatch with exponential backoff\n * for transient failures and proper handling of permanent failures.\n *\n * Called by the settlement worker's onSettleReady callback on each poll\n * cycle for every locked match whose target_slot has been reached.\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport type { SettleResult } from \"./settle-tx.js\";\nimport { PermanentSettleError } from \"./settle-tx.js\";\nimport { logger } from \"../logger.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst MAX_RETRIES = 5;\nconst BASE_DELAY_MS = 2_000;\nconst MAX_DELAY_MS = 30_000;\n\n/** resolve_deadline: i64 at offset 156 in CoinflipMatch account data */\nconst RESOLVE_DEADLINE_OFFSET = 156;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface RetrySettlerDeps {\n  db: Db;\n  connection: Connection;\n  settleMatch: (pda: string) => Promise<SettleResult>;\n}\n\ninterface RetryState {\n  attempts: number;\n  /** Timestamp (ms) at which next retry is allowed. */\n  nextRetryAt: number;\n}\n\nexport interface RetrySettler {\n  /**\n   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n   * failure tracking, and resolve_deadline timeout detection.\n   *\n   * Safe to call repeatedly — skips if a retry is scheduled but not yet due,\n   * or if the PDA has already been marked as permanently failed / timed out.\n   */\n  attemptSettle(pda: string): Promise<void>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n  const { db, connection, settleMatch } = deps;\n\n  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n  const retryStates = new Map<string, RetryState>();\n\n  /** PDAs that hit a permanent (non-retryable) error. */\n  const failedPdas = new Set<string>();\n\n  /** PDAs whose resolve_deadline has passed. */\n  const timeoutPdas = new Set<string>();\n\n  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n  function getDelay(attempt: number): number {\n    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n  }\n\n  /**\n   * Check whether the on-chain resolve_deadline has passed for a match.\n   * Returns true if the deadline is in the past (timeout refund eligible).\n   */\n  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    try {\n      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n      if (!accountInfo) return true; // account gone — treat as expired\n      const data = Buffer.from(accountInfo.data);\n      if (data.length < RESOLVE_DEADLINE_OFFSET + 8) return false;\n      const resolveDeadline = Number(data.readBigInt64LE(RESOLVE_DEADLINE_OFFSET));\n      if (resolveDeadline <= 0) return false; // not set yet\n      const nowUnix = Math.floor(Date.now() / 1000);\n      return nowUnix >= resolveDeadline;\n    } catch {\n      return false; // can't read — don't assume timeout\n    }\n  }\n\n  async function attemptSettle(pda: string): Promise<void> {\n    // Skip permanently failed or timed-out PDAs\n    if (failedPdas.has(pda) || timeoutPdas.has(pda)) return;\n\n    const state = retryStates.get(pda);\n\n    // If a retry is scheduled but not yet due, skip\n    if (state && Date.now() < state.nextRetryAt) return;\n\n    // If max retries exceeded, mark as failed\n    if (state && state.attempts >= MAX_RETRIES) {\n      failedPdas.add(pda);\n      retryStates.delete(pda);\n      await db.insertOperatorEvent(pda, \"settle_failed\", {\n        reason: \"max retries exceeded\",\n        attempts: state.attempts,\n      });\n      logger.error(\"settle failed — max retries exceeded\", {\n        pda,\n        attempts: state.attempts,\n      });\n      return;\n    }\n\n    // Check resolve_deadline before attempting\n    if (await isResolveDeadlinePassed(pda)) {\n      timeoutPdas.add(pda);\n      retryStates.delete(pda);\n      await db.insertOperatorEvent(pda, \"timeout_detected\", {\n        reason: \"resolve_deadline passed without successful settlement\",\n        attempts: state?.attempts ?? 0,\n      });\n      logger.warn(\"resolve deadline passed, stopping settlement attempts\", {\n        pda,\n      });\n      return;\n    }\n\n    try {\n      const result = await settleMatch(pda);\n\n      // Success — clear retry state\n      retryStates.delete(pda);\n      logger.info(\"match settled\", {\n        pda,\n        tx: result.txSignature,\n        resultSide: result.resultSide,\n        winner: result.winner,\n      });\n    } catch (err) {\n      if (err instanceof PermanentSettleError) {\n        // Permanent failure — do not retry\n        failedPdas.add(pda);\n        retryStates.delete(pda);\n        await db.insertOperatorEvent(pda, \"settle_failed\", {\n          reason: err.message,\n          permanent: true,\n        });\n        logger.error(\"settle permanently failed\", {\n          pda,\n          error: err.message,\n        });\n      } else {\n        // Transient failure — schedule retry with exponential backoff\n        const attempts = (state?.attempts ?? 0) + 1;\n        const delay = getDelay(attempts - 1);\n\n        retryStates.set(pda, {\n          attempts,\n          nextRetryAt: Date.now() + delay,\n        });\n\n        await db.insertOperatorEvent(pda, \"settle_retried\", {\n          attempt: attempts,\n          nextRetryInMs: delay,\n          error: err instanceof Error ? err.message : String(err),\n        });\n        logger.warn(\"settle transient failure, scheduling retry\", {\n          pda,\n          attempt: attempts,\n          nextRetryInMs: delay,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n    }\n  }\n\n  return { attemptSettle };\n}\n","numLines":182,"startLine":1,"totalLines":182}}}
