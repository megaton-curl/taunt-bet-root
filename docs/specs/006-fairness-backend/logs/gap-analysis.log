{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TM4rAe1K7rhNiebrq45hE7","type":"tool_result","content":"     1→/**\n     2→ * GET /health — operational health endpoint.\n     3→ *\n     4→ * Returns service version, server pubkey, SOL balance, DB connectivity,\n     5→ * worker running status, unsettled round count, and oldest unsettled age.\n     6→ */\n     7→\n     8→import { Hono } from \"hono\";\n     9→import { Connection, type PublicKey } from \"@solana/web3.js\";\n    10→import type { Db } from \"../db.js\";\n    11→import { logger } from \"../logger.js\";\n    12→\n    13→export interface HealthDeps {\n    14→  db: Db;\n    15→  connection: Connection;\n    16→  serverKey: PublicKey;\n    17→  isWorkerRunning: () => boolean;\n    18→  minSolBalance: number;\n    19→}\n    20→\n    21→export function createHealthRoutes(deps: HealthDeps): Hono {\n    22→  const { db, connection, serverKey, isWorkerRunning, minSolBalance } = deps;\n    23→  const app = new Hono();\n    24→\n    25→  app.get(\"/\", async (c) => {\n    26→    let dbConnected = false;\n    27→    let unsettledCount = 0;\n    28→    let oldestUnsettledAge = 0;\n    29→\n    30→    // Check DB connectivity + query unsettled stats\n    31→    try {\n    32→      const stats = await db.getUnsettledStats();\n    33→      dbConnected = true;\n    34→      unsettledCount = stats.count;\n    35→      oldestUnsettledAge = stats.oldestAgeSeconds;\n    36→    } catch {\n    37→      dbConnected = false;\n    38→    }\n    39→\n    40→    // Get SOL balance of server keypair\n    41→    let solBalance = 0;\n    42→    try {\n    43→      const lamports = await connection.getBalance(serverKey);\n    44→      solBalance = lamports / 1e9;\n    45→    } catch {\n    46→      // If RPC fails, report 0\n    47→    }\n    48→\n    49→    // Warn if SOL balance is below threshold\n    50→    if (solBalance < minSolBalance) {\n    51→      logger.warn(\"Server SOL balance below threshold\", {\n    52→        solBalance,\n    53→        threshold: minSolBalance,\n    54→        serverKey: serverKey.toBase58(),\n    55→      });\n    56→    }\n    57→\n    58→    return c.json({\n    59→      status: \"ok\",\n    60→      version: \"0.1.0\",\n    61→      serverKey: serverKey.toBase58(),\n    62→      solBalance,\n    63→      dbConnected,\n    64→      workerRunning: isWorkerRunning(),\n    65→      unsettledCount,\n    66→      oldestUnsettledAge,\n    67→    });\n    68→  });\n    69→\n    70→  return app;\n    71→}\n    72→"}]},"parent_tool_use_id":null,"session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"60e88164-f3fb-43f4-bd13-9e60b835d317","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/health.ts","content":"/**\n * GET /health — operational health endpoint.\n *\n * Returns service version, server pubkey, SOL balance, DB connectivity,\n * worker running status, unsettled round count, and oldest unsettled age.\n */\n\nimport { Hono } from \"hono\";\nimport { Connection, type PublicKey } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface HealthDeps {\n  db: Db;\n  connection: Connection;\n  serverKey: PublicKey;\n  isWorkerRunning: () => boolean;\n  minSolBalance: number;\n}\n\nexport function createHealthRoutes(deps: HealthDeps): Hono {\n  const { db, connection, serverKey, isWorkerRunning, minSolBalance } = deps;\n  const app = new Hono();\n\n  app.get(\"/\", async (c) => {\n    let dbConnected = false;\n    let unsettledCount = 0;\n    let oldestUnsettledAge = 0;\n\n    // Check DB connectivity + query unsettled stats\n    try {\n      const stats = await db.getUnsettledStats();\n      dbConnected = true;\n      unsettledCount = stats.count;\n      oldestUnsettledAge = stats.oldestAgeSeconds;\n    } catch {\n      dbConnected = false;\n    }\n\n    // Get SOL balance of server keypair\n    let solBalance = 0;\n    try {\n      const lamports = await connection.getBalance(serverKey);\n      solBalance = lamports / 1e9;\n    } catch {\n      // If RPC fails, report 0\n    }\n\n    // Warn if SOL balance is below threshold\n    if (solBalance < minSolBalance) {\n      logger.warn(\"Server SOL balance below threshold\", {\n        solBalance,\n        threshold: minSolBalance,\n        serverKey: serverKey.toBase58(),\n      });\n    }\n\n    return c.json({\n      status: \"ok\",\n      version: \"0.1.0\",\n      serverKey: serverKey.toBase58(),\n      solBalance,\n      dbConnected,\n      workerRunning: isWorkerRunning(),\n      unsettledCount,\n      oldestUnsettledAge,\n    });\n  });\n\n  return app;\n}\n","numLines":72,"startLine":1,"totalLines":72}}}
