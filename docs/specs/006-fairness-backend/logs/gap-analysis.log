{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B4jGHUPDdCyCpo9SAmM5gz","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::error::CoinflipError;\n     4→use crate::state::{CoinflipMatch, PHASE_WAITING};\n     5→\n     6→#[derive(Accounts)]\n     7→pub struct CancelMatch<'info> {\n     8→    /// The creator cancelling their match.\n     9→    #[account(mut)]\n    10→    pub creator: Signer<'info>,\n    11→\n    12→    /// The match PDA (closed on cancel — escrow + rent refunded to creator).\n    13→    #[account(\n    14→        mut,\n    15→        close = creator,\n    16→        seeds = [b\"match\", creator.key().as_ref(), &coinflip_match.nonce.to_le_bytes()],\n    17→        bump = coinflip_match.bump,\n    18→    )]\n    19→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    20→\n    21→    pub system_program: Program<'info, System>,\n    22→}\n    23→\n    24→pub fn handler(ctx: Context<CancelMatch>) -> Result<()> {\n    25→    let coinflip_match = &ctx.accounts.coinflip_match;\n    26→\n    27→    // Cancel is only allowed from Waiting phase (before opponent joins).\n    28→    require!(\n    29→        coinflip_match.phase == PHASE_WAITING,\n    30→        CoinflipError::CannotCancel\n    31→    );\n    32→\n    33→    // Account is closed by Anchor's `close = creator` constraint —\n    34→    // all lamports (escrow + rent) are returned to creator.\n    35→\n    36→    Ok(())\n    37→}\n    38→"}]},"parent_tool_use_id":"toolu_013SMc3BMP8E6SA5d6gqSxGa","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"d4503f88-a574-4804-b58e-eca39dd939bf"}
