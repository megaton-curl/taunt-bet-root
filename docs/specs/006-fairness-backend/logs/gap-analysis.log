ts tables for fairness backend\n\nCREATE TABLE IF NOT EXISTS rounds (\n  pda            TEXT PRIMARY KEY,\n  game           TEXT NOT NULL,\n  creator        TEXT NOT NULL,\n  server_key     TEXT NOT NULL,\n  secret         BYTEA NOT NULL,\n  commitment     BYTEA NOT NULL,\n  tier           SMALLINT NOT NULL,\n  side           SMALLINT NOT NULL,\n  nonce          BIGINT NOT NULL,\n  phase          TEXT NOT NULL,\n  target_slot    BIGINT,\n  settle_tx      TEXT,\n  settle_attempts INT DEFAULT 0,\n  result_hash    BYTEA,\n  result_side    SMALLINT,\n  winner         TEXT,\n  created_at     TIMESTAMPTZ DEFAULT now(),\n  updated_at     TIMESTAMPTZ DEFAULT now()\n);\n\nCREATE TABLE IF NOT EXISTS operator_events (\n  id             BIGSERIAL PRIMARY KEY,\n  pda            TEXT,\n  event_type     TEXT NOT NULL,\n  payload        JSONB,\n  created_at     TIMESTAMPTZ DEFAULT now()\n);\n\n-- Indexes\nCREATE INDEX IF NOT EXISTS idx_rounds_phase ON rounds(phase);\nCREATE INDEX IF NOT EXISTS idx_rounds_creator ON rounds(creator);\nCREATE INDEX IF NOT EXISTS idx_operator_events_pda_created ON operator_events(pda, created_at);\nCREATE INDEX IF NOT EXISTS idx_operator_events_type_created ON operator_events(event_type, created_at);\n","numLines":37,"startLine":1,"totalLines":37}}}
