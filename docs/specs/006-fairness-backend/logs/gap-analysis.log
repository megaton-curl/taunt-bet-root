{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B1tffcMGRta3GA2XFo4Vwn","type":"tool_result","content":"     1→/**\n     2→ * GET /health — operational health endpoint.\n     3→ *\n     4→ * Returns service version, server pubkey, SOL balance, DB connectivity,\n     5→ * worker running status, unsettled round count, and oldest unsettled age.\n     6→ */\n     7→\n     8→import { Hono } from \"hono\";\n     9→import { Connection, type PublicKey } from \"@solana/web3.js\";\n    10→import type { Db } from \"../db.js\";\n    11→import { logger } from \"../logger.js\";\n    12→\n    13→export interface HealthDeps {\n    14→  db: Db;\n    15→  connection: Connection;\n    16→  serverKey: PublicKey;\n    17→  isWorkerRunning: () => boolean;\n    18→  minSolBalance: number;\n    19→}\n    20→\n    21→export function createHealthRoutes(deps: HealthDeps): Hono {\n    22→  const { db, connection, serverKey, isWorkerRunning, minSolBalance } = deps;\n    23→  const app = new Hono();\n    24→\n    25→  app.get(\"/\", async (c) => {\n    26→    let dbConnected = false;\n    27→    let unsettledCount = 0;\n    28→    let oldestUnsettledAge = 0;\n    29→\n    30→    // Check DB connectivity + query unsettled stats\n    31→    try {\n    32→      const stats = await db.getUnsettledStats();\n    33→      dbConnected = true;\n    34→      unsettledCount = stats.count;\n    35→      oldestUnsettledAge = stats.oldestAgeSeconds;\n    36→    } catch {\n    37→      dbConnected = false;\n    38→    }\n    39→\n    40→    // Get SOL balance of server keypair\n    41→    let solBalance = 0;\n    42→    try {\n    43→      const lamports = await connection.getBalance(serverKey);\n    44→      solBalance = lamports / 1e9;\n    45→    } catch {\n    46→      // If RPC fails, report 0\n    47→    }\n    48→\n    49→    // Warn if SOL balance is below threshold\n    50→    if (solBalance < minSolBalance) {\n    51→      logger.warn(\"Server SOL balance below threshold\", {\n    52→        solBalance,\n    53→        threshold: minSolBalance,\n    54→        serverKey: serverKey.toBase58(),\n    55→      });\n    56→    }\n    57→\n    58→    return c.json({\n    59→      status: \"ok\",\n    60→      version: \"0.1.0\",\n    61→      serverKey: serverKey.toBase58(),\n    62→      solBalance,\n    63→      dbConnected,\n    64→      workerRunning: isWorkerRunning(),\n    65→      unsettledCount,\n    66→      oldestUnsettledAge,\n    67→    });\n    68→  });\n    69→\n    70→  return app;\n    71→}\n    72→"}]},"parent_tool_use_id":"toolu_01AjWj6Dy3kJJJmaV1n984WU","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"e54cfd6d-129a-4af0-9193-3440d7a8f76c"}
