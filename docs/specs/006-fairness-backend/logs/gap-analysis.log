{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WVyMTV7MBjf8FqaC4aC9Dg","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→\n     3→use crate::state::CoinflipConfig;\n     4→\n     5→#[derive(Accounts)]\n     6→pub struct InitializeConfig<'info> {\n     7→    /// Admin authority who initializes the config.\n     8→    #[account(mut)]\n     9→    pub authority: Signer<'info>,\n    10→\n    11→    /// The config PDA (singleton).\n    12→    #[account(\n    13→        init,\n    14→        payer = authority,\n    15→        space = 8 + CoinflipConfig::INIT_SPACE,\n    16→        seeds = [b\"coinflip_config\"],\n    17→        bump,\n    18→    )]\n    19→    pub config: Account<'info, CoinflipConfig>,\n    20→\n    21→    pub system_program: Program<'info, System>,\n    22→}\n    23→\n    24→pub fn handler(ctx: Context<InitializeConfig>, treasury: Pubkey) -> Result<()> {\n    25→    let config = &mut ctx.accounts.config;\n    26→    config.authority = ctx.accounts.authority.key();\n    27→    config.treasury = treasury;\n    28→    config.paused = false;\n    29→    config.bump = ctx.bumps.config;\n    30→\n    31→    Ok(())\n    32→}\n    33→"}]},"parent_tool_use_id":"toolu_013SMc3BMP8E6SA5d6gqSxGa","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"a9f5c2d1-24b1-4e1b-a10f-656dcabb4c2d"}
