{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013rUHML6Ma4r5uzYLRFe8Nt","type":"tool_result","content":"     1→/**\n     2→ * POST /fairness/coinflip/create — endpoint handler.\n     3→ *\n     4→ * Generates a server secret, computes the commitment, builds a partially-signed\n     5→ * create_match transaction, stores the round in the DB, and returns the\n     6→ * serialized transaction + match PDA + commitment to the caller.\n     7→ */\n     8→\n     9→import { Hono } from \"hono\";\n    10→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n    11→import { generateSecret, computeCommitment, deriveMatchPda } from \"../fairness.js\";\n    12→import { buildCreateMatchTx } from \"../tx-builder.js\";\n    13→import type { Db } from \"../db.js\";\n    14→\n    15→export interface CreateRoutesDeps {\n    16→  db: Db;\n    17→  connection: Connection;\n    18→  serverKeypair: Keypair;\n    19→}\n    20→\n    21→interface CreateRequestBody {\n    22→  wallet: string;\n    23→  tier: number;\n    24→  side: number;\n    25→  nonce: number;\n    26→  timestamp: number;\n    27→  signature: string;\n    28→}\n    29→\n    30→function isValidBase58(s: string): boolean {\n    31→  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n    32→}\n    33→\n    34→function validateBody(body: unknown): CreateRequestBody {\n    35→  if (!body || typeof body !== \"object\") {\n    36→    throw new Error(\"Request body must be a JSON object\");\n    37→  }\n    38→\n    39→  const b = body as Record<string, unknown>;\n    40→\n    41→  if (typeof b.wallet !== \"string\" || !isValidBase58(b.wallet)) {\n    42→    throw new Error(\"wallet must be a valid base58 public key\");\n    43→  }\n    44→\n    45→  if (typeof b.tier !== \"number\" || !Number.isInteger(b.tier) || b.tier < 0 || b.tier > 255) {\n    46→    throw new Error(\"tier must be an integer 0-255\");\n    47→  }\n    48→\n    49→  if (typeof b.side !== \"number\" || (b.side !== 0 && b.side !== 1)) {\n    50→    throw new Error(\"side must be 0 (Heads) or 1 (Tails)\");\n    51→  }\n    52→\n    53→  if (typeof b.nonce !== \"number\" || !Number.isInteger(b.nonce) || b.nonce < 0) {\n    54→    throw new Error(\"nonce must be a non-negative integer\");\n    55→  }\n    56→\n    57→  if (typeof b.timestamp !== \"number\" || !Number.isInteger(b.timestamp)) {\n    58→    throw new Error(\"timestamp must be an integer (unix seconds)\");\n    59→  }\n    60→\n    61→  if (typeof b.signature !== \"string\" || b.signature.length === 0) {\n    62→    throw new Error(\"signature must be a non-empty string\");\n    63→  }\n    64→\n    65→  return {\n    66→    wallet: b.wallet,\n    67→    tier: b.tier,\n    68→    side: b.side,\n    69→    nonce: b.nonce,\n    70→    timestamp: b.timestamp,\n    71→    signature: b.signature,\n    72→  };\n    73→}\n    74→\n    75→export function createCoinflipRoutes(deps: CreateRoutesDeps): Hono {\n    76→  const { db, connection, serverKeypair } = deps;\n    77→\n    78→  const app = new Hono();\n    79→\n    80→  app.post(\"/create\", async (c) => {\n    81→    // 1. Parse + validate request body\n    82→    let body: CreateRequestBody;\n    83→    try {\n    84→      const raw = await c.req.json();\n    85→      body = validateBody(raw);\n    86→    } catch (err) {\n    87→      return c.json(\n    88→        { error: err instanceof Error ? err.message : \"Invalid request body\" },\n    89→        400,\n    90→      );\n    91→    }\n    92→\n    93→    // 2. Validate wallet is a real public key\n    94→    let creatorPubkey: PublicKey;\n    95→    try {\n    96→      creatorPubkey = new PublicKey(body.wallet);\n    97→    } catch {\n    98→      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n    99→    }\n   100→\n   101→    // 3. Generate secret + commitment\n   102→    const secret = generateSecret();\n   103→    const commitment = computeCommitment(secret);\n   104→\n   105→    // 4. Derive PDA\n   106→    const [matchPda] = deriveMatchPda(creatorPubkey, body.nonce);\n   107→    const matchPdaStr = matchPda.toBase58();\n   108→\n   109→    // 5. Check for duplicate PDA in DB (409 Conflict)\n   110→    const existing = await db.getRoundByPda(matchPdaStr);\n   111→    if (existing) {\n   112→      return c.json(\n   113→        { error: \"Match with this nonce already exists\" },\n   114→        409,\n   115→      );\n   116→    }\n   117→\n   118→    // 6. Build + partial-sign transaction\n   119→    let transaction: string;\n   120→    try {\n   121→      const result = await buildCreateMatchTx({\n   122→        connection,\n   123→        creator: creatorPubkey,\n   124→        serverKeypair,\n   125→        commitment,\n   126→        tier: body.tier,\n   127→        side: body.side,\n   128→        nonce: BigInt(body.nonce),\n   129→      });\n   130→      transaction = result.transaction;\n   131→    } catch (_err) {\n   132→      return c.json(\n   133→        { error: \"Failed to build transaction\" },\n   134→        500,\n   135→      );\n   136→    }\n   137→\n   138→    // 7. Store round in DB (phase: created)\n   139→    try {\n   140→      await db.insertRound({\n   141→        pda: matchPdaStr,\n   142→        game: \"coinflip\",\n   143→        creator: body.wallet,\n   144→        serverKey: serverKeypair.publicKey.toBase58(),\n   145→        secret,\n   146→        commitment,\n   147→        tier: body.tier,\n   148→        side: body.side,\n   149→        nonce: body.nonce,\n   150→        phase: \"created\",\n   151→      });\n   152→    } catch (err) {\n   153→      // Handle race condition — another request inserted the same PDA\n   154→      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n   155→        return c.json(\n   156→          { error: \"Match with this nonce already exists\" },\n   157→          409,\n   158→        );\n   159→      }\n   160→      throw err;\n   161→    }\n   162→\n   163→    // 8. Write operator event\n   164→    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n   165→      creator: body.wallet,\n   166→      tier: body.tier,\n   167→      side: body.side,\n   168→      nonce: body.nonce,\n   169→    });\n   170→\n   171→    // 9. Return response\n   172→    return c.json({\n   173→      transaction,\n   174→      matchPda: matchPdaStr,\n   175→      commitment: commitment.toString(\"hex\"),\n   176→    });\n   177→  });\n   178→\n   179→  return app;\n   180→}\n   181→"}]},"parent_tool_use_id":"toolu_01AjWj6Dy3kJJJmaV1n984WU","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"152620b1-0a5c-40f9-ab4e-2dfd06cb6ea4"}
