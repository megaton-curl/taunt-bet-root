{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nj8f8QQdZKtWrrvfN2m3Zz","type":"tool_result","content":"     1→/**\n     2→ * GET /fairness/rounds/:pda — round verification endpoint.\n     3→ *\n     4→ * Returns round lifecycle data and post-settlement verification payloads.\n     5→ * Secret is only exposed for settled rounds.\n     6→ */\n     7→\n     8→import { Hono } from \"hono\";\n     9→import type { Db, Round } from \"../db.js\";\n    10→\n    11→export interface RoundsRoutesDeps {\n    12→  db: Db;\n    13→}\n    14→\n    15→/** Map a DB round row to a camelCase JSON response, redacting secret if unsettled. */\n    16→function formatRoundResponse(round: Round) {\n    17→  const isSettled = round.phase === \"settled\";\n    18→\n    19→  const response: Record<string, unknown> = {\n    20→    pda: round.pda,\n    21→    game: round.game,\n    22→    phase: round.phase,\n    23→    creator: round.creator,\n    24→    commitment: round.commitment.toString(\"hex\"),\n    25→    tier: round.tier,\n    26→    side: round.side,\n    27→    nonce: Number(round.nonce),\n    28→    createdAt: round.created_at.toISOString(),\n    29→    updatedAt: round.updated_at.toISOString(),\n    30→  };\n    31→\n    32→  if (round.target_slot !== null) {\n    33→    response.targetSlot = Number(round.target_slot);\n    34→  }\n    35→\n    36→  if (isSettled) {\n    37→    response.secret = round.secret.toString(\"hex\");\n    38→    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    39→    response.resultSide = round.result_side;\n    40→    response.winner = round.winner;\n    41→    response.settleTx = round.settle_tx;\n    42→    response.verification = {\n    43→      commitmentCheck: \"sha256(secret) == commitment\",\n    44→      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n    45→      entropySource: \"SlotHashes sysvar at target_slot\",\n    46→    };\n    47→  }\n    48→\n    49→  return response;\n    50→}\n    51→\n    52→export function createRoundsRoutes(deps: RoundsRoutesDeps): Hono {\n    53→  const { db } = deps;\n    54→\n    55→  const app = new Hono();\n    56→\n    57→  app.get(\"/:pda\", async (c) => {\n    58→    const pda = c.req.param(\"pda\");\n    59→\n    60→    const round = await db.getRoundByPda(pda);\n    61→    if (!round) {\n    62→      return c.json({ error: \"Round not found\" }, 404);\n    63→    }\n    64→\n    65→    return c.json(formatRoundResponse(round));\n    66→  });\n    67→\n    68→  return app;\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_01AjWj6Dy3kJJJmaV1n984WU","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"c3adf4b4-98fe-4702-9ad9-1be1314b3de8"}
