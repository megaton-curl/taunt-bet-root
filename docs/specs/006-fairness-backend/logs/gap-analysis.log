{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NR2nhA4XxB5GeKZFWNDC7n","type":"tool_result","content":"     1→/**\n     2→ * Settlement retry logic — wraps settleMatch with exponential backoff\n     3→ * for transient failures and proper handling of permanent failures.\n     4→ *\n     5→ * Called by the settlement worker's onSettleReady callback on each poll\n     6→ * cycle for every locked match whose target_slot has been reached.\n     7→ */\n     8→\n     9→import { Connection, PublicKey } from \"@solana/web3.js\";\n    10→import type { Db } from \"../db.js\";\n    11→import type { SettleResult } from \"./settle-tx.js\";\n    12→import { PermanentSettleError } from \"./settle-tx.js\";\n    13→import { logger } from \"../logger.js\";\n    14→\n    15→// ---------------------------------------------------------------------------\n    16→// Constants\n    17→// ---------------------------------------------------------------------------\n    18→\n    19→const MAX_RETRIES = 5;\n    20→const BASE_DELAY_MS = 2_000;\n    21→const MAX_DELAY_MS = 30_000;\n    22→\n    23→/** resolve_deadline: i64 at offset 156 in CoinflipMatch account data */\n    24→const RESOLVE_DEADLINE_OFFSET = 156;\n    25→\n    26→// ---------------------------------------------------------------------------\n    27→// Types\n    28→// ---------------------------------------------------------------------------\n    29→\n    30→export interface RetrySettlerDeps {\n    31→  db: Db;\n    32→  connection: Connection;\n    33→  settleMatch: (pda: string) => Promise<SettleResult>;\n    34→}\n    35→\n    36→interface RetryState {\n    37→  attempts: number;\n    38→  /** Timestamp (ms) at which next retry is allowed. */\n    39→  nextRetryAt: number;\n    40→}\n    41→\n    42→export interface RetrySettler {\n    43→  /**\n    44→   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n    45→   * failure tracking, and resolve_deadline timeout detection.\n    46→   *\n    47→   * Safe to call repeatedly — skips if a retry is scheduled but not yet due,\n    48→   * or if the PDA has already been marked as permanently failed / timed out.\n    49→   */\n    50→  attemptSettle(pda: string): Promise<void>;\n    51→}\n    52→\n    53→// ---------------------------------------------------------------------------\n    54→// Factory\n    55→// ---------------------------------------------------------------------------\n    56→\n    57→export function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n    58→  const { db, connection, settleMatch } = deps;\n    59→\n    60→  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n    61→  const retryStates = new Map<string, RetryState>();\n    62→\n    63→  /** PDAs that hit a permanent (non-retryable) error. */\n    64→  const failedPdas = new Set<string>();\n    65→\n    66→  /** PDAs whose resolve_deadline has passed. */\n    67→  const timeoutPdas = new Set<string>();\n    68→\n    69→  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n    70→  function getDelay(attempt: number): number {\n    71→    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n    72→  }\n    73→\n    74→  /**\n    75→   * Check whether the on-chain resolve_deadline has passed for a match.\n    76→   * Returns true if the deadline is in the past (timeout refund eligible).\n    77→   */\n    78→  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    79→    try {\n    80→      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n    81→      if (!accountInfo) return true; // account gone — treat as expired\n    82→      const data = Buffer.from(accountInfo.data);\n    83→      if (data.length < RESOLVE_DEADLINE_OFFSET + 8) return false;\n    84→      const resolveDeadline = Number(data.readBigInt64LE(RESOLVE_DEADLINE_OFFSET));\n    85→      if (resolveDeadline <= 0) return false; // not set yet\n    86→      const nowUnix = Math.floor(Date.now() / 1000);\n    87→      return nowUnix >= resolveDeadline;\n    88→    } catch {\n    89→      return false; // can't read — don't assume timeout\n    90→    }\n    91→  }\n    92→\n    93→  async function attemptSettle(pda: string): Promise<void> {\n    94→    // Skip permanently failed or timed-out PDAs\n    95→    if (failedPdas.has(pda) || timeoutPdas.has(pda)) return;\n    96→\n    97→    const state = retryStates.get(pda);\n    98→\n    99→    // If a retry is scheduled but not yet due, skip\n   100→    if (state && Date.now() < state.nextRetryAt) return;\n   101→\n   102→    // If max retries exceeded, mark as failed\n   103→    if (state && state.attempts >= MAX_RETRIES) {\n   104→      failedPdas.add(pda);\n   105→      retryStates.delete(pda);\n   106→      await db.insertOperatorEvent(pda, \"settle_failed\", {\n   107→        reason: \"max retries exceeded\",\n   108→        attempts: state.attempts,\n   109→      });\n   110→      logger.error(\"settle failed — max retries exceeded\", {\n   111→        pda,\n   112→        attempts: state.attempts,\n   113→      });\n   114→      return;\n   115→    }\n   116→\n   117→    // Check resolve_deadline before attempting\n   118→    if (await isResolveDeadlinePassed(pda)) {\n   119→      timeoutPdas.add(pda);\n   120→      retryStates.delete(pda);\n   121→      await db.insertOperatorEvent(pda, \"timeout_detected\", {\n   122→        reason: \"resolve_deadline passed without successful settlement\",\n   123→        attempts: state?.attempts ?? 0,\n   124→      });\n   125→      logger.warn(\"resolve deadline passed, stopping settlement attempts\", {\n   126→        pda,\n   127→      });\n   128→      return;\n   129→    }\n   130→\n   131→    try {\n   132→      const result = await settleMatch(pda);\n   133→\n   134→      // Success — clear retry state\n   135→      retryStates.delete(pda);\n   136→      logger.info(\"match settled\", {\n   137→        pda,\n   138→        tx: result.txSignature,\n   139→        resultSide: result.resultSide,\n   140→        winner: result.winner,\n   141→      });\n   142→    } catch (err) {\n   143→      if (err instanceof PermanentSettleError) {\n   144→        // Permanent failure — do not retry\n   145→        failedPdas.add(pda);\n   146→        retryStates.delete(pda);\n   147→        await db.insertOperatorEvent(pda, \"settle_failed\", {\n   148→          reason: err.message,\n   149→          permanent: true,\n   150→        });\n   151→        logger.error(\"settle permanently failed\", {\n   152→          pda,\n   153→          error: err.message,\n   154→        });\n   155→      } else {\n   156→        // Transient failure — schedule retry with exponential backoff\n   157→        const attempts = (state?.attempts ?? 0) + 1;\n   158→        const delay = getDelay(attempts - 1);\n   159→\n   160→        retryStates.set(pda, {\n   161→          attempts,\n   162→          nextRetryAt: Date.now() + delay,\n   163→        });\n   164→\n   165→        await db.insertOperatorEvent(pda, \"settle_retried\", {\n   166→          attempt: attempts,\n   167→          nextRetryInMs: delay,\n   168→          error: err instanceof Error ? err.message : String(err),\n   169→        });\n   170→        logger.warn(\"settle transient failure, scheduling retry\", {\n   171→          pda,\n   172→          attempt: attempts,\n   173→          nextRetryInMs: delay,\n   174→          error: err instanceof Error ? err.message : String(err),\n   175→        });\n   176→      }\n   177→    }\n   178→  }\n   179→\n   180→  return { attemptSettle };\n   181→}\n   182→"}]},"parent_tool_use_id":"toolu_01AjWj6Dy3kJJJmaV1n984WU","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"3c48b7fa-7304-4493-85ab-e3ab21dab835"}
