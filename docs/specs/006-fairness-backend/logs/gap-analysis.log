{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S378RaxCB6zvNFJUd42wri","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::constants::is_valid_side;\n     3→use rng_shared::escrow::transfer_lamports_to_pda;\n     4→use rng_shared::fairness::ALGORITHM_VERSION;\n     5→use rng_shared::pause::check_not_paused;\n     6→use rng_shared::tiers::get_tier_amount;\n     7→\n     8→use crate::error::CoinflipError;\n     9→use crate::state::{CoinflipConfig, CoinflipMatch, PHASE_WAITING};\n    10→\n    11→#[derive(Accounts)]\n    12→#[instruction(commitment: [u8; 32], tier: u8, side: u8, nonce: u64)]\n    13→pub struct CreateMatch<'info> {\n    14→    /// The player creating the match. Must sign and fund the escrow.\n    15→    #[account(mut)]\n    16→    pub creator: Signer<'info>,\n    17→\n    18→    /// The server that co-signs match creation and will later settle.\n    19→    pub server: Signer<'info>,\n    20→\n    21→    /// The match PDA. Seeds include nonce for uniqueness across matches.\n    22→    #[account(\n    23→        init,\n    24→        payer = creator,\n    25→        space = 8 + CoinflipMatch::INIT_SPACE,\n    26→        seeds = [b\"match\", creator.key().as_ref(), &nonce.to_le_bytes()],\n    27→        bump,\n    28→    )]\n    29→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    30→\n    31→    /// The config PDA (read-only, for pause check).\n    32→    #[account(\n    33→        seeds = [b\"coinflip_config\"],\n    34→        bump = config.bump,\n    35→    )]\n    36→    pub config: Account<'info, CoinflipConfig>,\n    37→\n    38→    pub system_program: Program<'info, System>,\n    39→}\n    40→\n    41→pub fn handler(\n    42→    ctx: Context<CreateMatch>,\n    43→    commitment: [u8; 32],\n    44→    tier: u8,\n    45→    side: u8,\n    46→    nonce: u64,\n    47→) -> Result<()> {\n    48→    check_not_paused(false, ctx.accounts.config.paused)?;\n    49→\n    50→    require!(is_valid_side(side), CoinflipError::InvalidSide);\n    51→\n    52→    let entry_amount = get_tier_amount(tier).map_err(|_| CoinflipError::InvalidTier)?;\n    53→\n    54→    // Rent is already paid by `init`. Only top up if entry exceeds rent.\n    55→    // For low tiers (e.g. Copper), rent covers the entry — no extra transfer needed.\n    56→    let rent_exempt = Rent::get()?.minimum_balance(8 + CoinflipMatch::INIT_SPACE);\n    57→    let top_up = entry_amount.saturating_sub(rent_exempt);\n    58→    if top_up > 0 {\n    59→        transfer_lamports_to_pda(\n    60→            &ctx.accounts.creator.to_account_info(),\n    61→            &ctx.accounts.coinflip_match.to_account_info(),\n    62→            top_up,\n    63→            &ctx.accounts.system_program.to_account_info(),\n    64→        )?;\n    65→    }\n    66→\n    67→    let now = Clock::get()?.unix_timestamp;\n    68→\n    69→    let m = &mut ctx.accounts.coinflip_match;\n    70→    m.creator = ctx.accounts.creator.key();\n    71→    m.opponent = Pubkey::default();\n    72→    m.server = ctx.accounts.server.key();\n    73→    m.tier = tier;\n    74→    m.entry_amount = entry_amount;\n    75→    m.creator_side = side;\n    76→    m.phase = PHASE_WAITING;\n    77→    m.commitment = commitment;\n    78→    m.algorithm_ver = ALGORITHM_VERSION;\n    79→    m.target_slot = 0;\n    80→    m.resolve_deadline = 0;\n    81→    m.result_hash = [0u8; 32];\n    82→    m.result = 0;\n    83→    m.winner = Pubkey::default();\n    84→    m.created_at = now;\n    85→    m.nonce = nonce;\n    86→    m.bump = ctx.bumps.coinflip_match;\n    87→    m.creator_wants_refund = false;\n    88→    m.opponent_wants_refund = false;\n    89→\n    90→    Ok(())\n    91→}\n    92→"}]},"parent_tool_use_id":"toolu_013SMc3BMP8E6SA5d6gqSxGa","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"375b2fe7-0c24-41e9-936e-e83c29bbddbe"}
