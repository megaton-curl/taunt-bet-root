{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FDtpNAW6A7wocuGuenrqpA","type":"tool_result","content":"     1→/**\n     2→ * In-memory sliding-window rate limiting middleware.\n     3→ *\n     4→ * Applies per-wallet and global limits to POST requests only.\n     5→ * Counters reset on service restart (acceptable for MVP).\n     6→ */\n     7→\n     8→import type { MiddlewareHandler } from \"hono\";\n     9→\n    10→export interface RateLimitConfig {\n    11→  /** Max POST requests per wallet per window (default 10). */\n    12→  perWallet: number;\n    13→  /** Max total POST requests per window (default 100). */\n    14→  global: number;\n    15→  /** Window size in milliseconds (default 60_000 = 1 minute). */\n    16→  windowMs: number;\n    17→}\n    18→\n    19→interface SlidingWindow {\n    20→  timestamps: number[];\n    21→}\n    22→\n    23→/**\n    24→ * Prune timestamps older than the window and return the current count.\n    25→ */\n    26→function countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n    27→  const cutoff = now - windowMs;\n    28→  // Remove expired entries from the front\n    29→  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n    30→    window.timestamps.shift();\n    31→  }\n    32→  return window.timestamps.length;\n    33→}\n    34→\n    35→/**\n    36→ * Creates a Hono middleware that rate-limits POST requests.\n    37→ *\n    38→ * - Per-wallet: keyed by the `wallet` field in the JSON body.\n    39→ * - Global: all POST requests combined.\n    40→ * - Returns 429 with `Retry-After` header when either limit is exceeded.\n    41→ * - GET requests pass through without rate limiting.\n    42→ */\n    43→export function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n    44→  const walletWindows = new Map<string, SlidingWindow>();\n    45→  const globalWindow: SlidingWindow = { timestamps: [] };\n    46→\n    47→  return async (c, next) => {\n    48→    if (c.req.method !== \"POST\") {\n    49→      return next();\n    50→    }\n    51→\n    52→    const now = Date.now();\n    53→    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n    54→\n    55→    // Check global limit first\n    56→    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n    57→    if (globalCount >= config.global) {\n    58→      c.header(\"Retry-After\", String(retryAfterSeconds));\n    59→      return c.json({ error: \"Too many requests\" }, 429);\n    60→    }\n    61→\n    62→    // Extract wallet from body for per-wallet limiting.\n    63→    // We clone the request so downstream handlers can still read the body.\n    64→    let wallet: string | undefined;\n    65→    try {\n    66→      const body = await c.req.json();\n    67→      wallet = typeof body.wallet === \"string\" ? body.wallet : undefined;\n    68→    } catch {\n    69→      // If body is not parseable, skip per-wallet limiting (auth middleware\n    70→      // will reject it anyway). Still count against global limit.\n    71→    }\n    72→\n    73→    // Check per-wallet limit\n    74→    if (wallet) {\n    75→      let wWindow = walletWindows.get(wallet);\n    76→      if (!wWindow) {\n    77→        wWindow = { timestamps: [] };\n    78→        walletWindows.set(wallet, wWindow);\n    79→      }\n    80→      const walletCount = countInWindow(wWindow, now, config.windowMs);\n    81→      if (walletCount >= config.perWallet) {\n    82→        c.header(\"Retry-After\", String(retryAfterSeconds));\n    83→        return c.json({ error: \"Too many requests\" }, 429);\n    84→      }\n    85→      wWindow.timestamps.push(now);\n    86→    }\n    87→\n    88→    // Record in global window\n    89→    globalWindow.timestamps.push(now);\n    90→\n    91→    return next();\n    92→  };\n    93→}\n    94→"}]},"parent_tool_use_id":null,"session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"9d44309b-f615-495d-a67d-6c7b67359506","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/middleware/rate-limit.ts","content":"/**\n * In-memory sliding-window rate limiting middleware.\n *\n * Applies per-wallet and global limits to POST requests only.\n * Counters reset on service restart (acceptable for MVP).\n */\n\nimport type { MiddlewareHandler } from \"hono\";\n\nexport interface RateLimitConfig {\n  /** Max POST requests per wallet per window (default 10). */\n  perWallet: number;\n  /** Max total POST requests per window (default 100). */\n  global: number;\n  /** Window size in milliseconds (default 60_000 = 1 minute). */\n  windowMs: number;\n}\n\ninterface SlidingWindow {\n  timestamps: number[];\n}\n\n/**\n * Prune timestamps older than the window and return the current count.\n */\nfunction countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n  const cutoff = now - windowMs;\n  // Remove expired entries from the front\n  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n    window.timestamps.shift();\n  }\n  return window.timestamps.length;\n}\n\n/**\n * Creates a Hono middleware that rate-limits POST requests.\n *\n * - Per-wallet: keyed by the `wallet` field in the JSON body.\n * - Global: all POST requests combined.\n * - Returns 429 with `Retry-After` header when either limit is exceeded.\n * - GET requests pass through without rate limiting.\n */\nexport function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n  const walletWindows = new Map<string, SlidingWindow>();\n  const globalWindow: SlidingWindow = { timestamps: [] };\n\n  return async (c, next) => {\n    if (c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const now = Date.now();\n    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n\n    // Check global limit first\n    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n    if (globalCount >= config.global) {\n      c.header(\"Retry-After\", String(retryAfterSeconds));\n      return c.json({ error: \"Too many requests\" }, 429);\n    }\n\n    // Extract wallet from body for per-wallet limiting.\n    // We clone the request so downstream handlers can still read the body.\n    let wallet: string | undefined;\n    try {\n      const body = await c.req.json();\n      wallet = typeof body.wallet === \"string\" ? body.wallet : undefined;\n    } catch {\n      // If body is not parseable, skip per-wallet limiting (auth middleware\n      // will reject it anyway). Still count against global limit.\n    }\n\n    // Check per-wallet limit\n    if (wallet) {\n      let wWindow = walletWindows.get(wallet);\n      if (!wWindow) {\n        wWindow = { timestamps: [] };\n        walletWindows.set(wallet, wWindow);\n      }\n      const walletCount = countInWindow(wWindow, now, config.windowMs);\n      if (walletCount >= config.perWallet) {\n        c.header(\"Retry-After\", String(retryAfterSeconds));\n        return c.json({ error: \"Too many requests\" }, 429);\n      }\n      wWindow.timestamps.push(now);\n    }\n\n    // Record in global window\n    globalWindow.timestamps.push(now);\n\n    return next();\n  };\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
