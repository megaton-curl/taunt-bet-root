{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L2gix4pB2PJZKYTxghJm9J","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use rng_shared::escrow::transfer_lamports_from_pda;\n     3→use rng_shared::timeout::is_expired;\n     4→\n     5→use crate::error::CoinflipError;\n     6→use crate::state::{CoinflipMatch, PHASE_LOCKED, PHASE_REFUNDED};\n     7→\n     8→/// Permissionless timeout refund after the server fails to settle within the deadline.\n     9→#[derive(Accounts)]\n    10→pub struct TimeoutRefund<'info> {\n    11→    /// Any signer can trigger a timeout refund (permissionless after deadline).\n    12→    pub caller: Signer<'info>,\n    13→\n    14→    /// The creator's account — receives entry refund + rent.\n    15→    /// CHECK: Validated against coinflip_match.creator.\n    16→    #[account(mut)]\n    17→    pub creator: AccountInfo<'info>,\n    18→\n    19→    /// The opponent's account — receives entry refund.\n    20→    /// CHECK: Validated against coinflip_match.opponent.\n    21→    #[account(mut)]\n    22→    pub opponent: AccountInfo<'info>,\n    23→\n    24→    /// The match PDA to refund.\n    25→    #[account(\n    26→        mut,\n    27→        seeds = [b\"match\", coinflip_match.creator.as_ref(), &coinflip_match.nonce.to_le_bytes()],\n    28→        bump = coinflip_match.bump,\n    29→    )]\n    30→    pub coinflip_match: Account<'info, CoinflipMatch>,\n    31→}\n    32→\n    33→pub fn handler(ctx: Context<TimeoutRefund>) -> Result<()> {\n    34→    let m = &ctx.accounts.coinflip_match;\n    35→\n    36→    require!(m.phase == PHASE_LOCKED, CoinflipError::InvalidPhase);\n    37→\n    38→    require_keys_eq!(ctx.accounts.creator.key(), m.creator);\n    39→    require_keys_eq!(ctx.accounts.opponent.key(), m.opponent);\n    40→\n    41→    let now = Clock::get()?.unix_timestamp;\n    42→    require!(\n    43→        is_expired(m.resolve_deadline, now),\n    44→        CoinflipError::LockTimeoutNotElapsed\n    45→    );\n    46→\n    47→    let entry_amount = m.entry_amount;\n    48→\n    49→    // Refund opponent's entry, then all remaining (creator's entry + rent) to creator\n    50→    let match_info = ctx.accounts.coinflip_match.to_account_info();\n    51→    transfer_lamports_from_pda(&match_info, &ctx.accounts.opponent, entry_amount)?;\n    52→\n    53→    // Set phase to refunded\n    54→    let m = &mut ctx.accounts.coinflip_match;\n    55→    m.phase = PHASE_REFUNDED;\n    56→\n    57→    // All remaining lamports (creator's entry portion + rent) → creator, zero PDA\n    58→    let remaining = match_info.lamports();\n    59→    **ctx.accounts.creator.try_borrow_mut_lamports()? += remaining;\n    60→    **match_info.try_borrow_mut_lamports()? = 0;\n    61→    match_info.data.borrow_mut().fill(0);\n    62→\n    63→    Ok(())\n    64→}\n    65→"}]},"parent_tool_use_id":"toolu_013SMc3BMP8E6SA5d6gqSxGa","session_id":"c9591fb4-7b0c-48b9-bca6-a93e05209d51","uuid":"16fe3010-aae7-4959-9536-6ad3e8100e0c"}
