{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Dfz4R3PRvne9NamXRKP4n","type":"tool_result","content":"     1→/**\n     2→ * Settlement worker — polls the chain for PHASE_LOCKED CoinflipMatch accounts\n     3→ * co-signed by this server and detects when they are ready for settlement.\n     4→ */\n     5→\n     6→import { Connection, PublicKey } from \"@solana/web3.js\";\n     7→import bs58 from \"bs58\";\n     8→import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n     9→import type { Db } from \"../db.js\";\n    10→\n    11→// CoinflipMatch account layout offsets (includes 8-byte Anchor discriminator)\n    12→const ACCOUNT_SIZE = 246;\n    13→const SERVER_OFFSET = 72;\n    14→const PHASE_OFFSET = 114;\n    15→const TARGET_SLOT_OFFSET = 148;\n    16→\n    17→const PHASE_LOCKED_VALUE = 1;\n    18→\n    19→export interface SettlementWorkerDeps {\n    20→  db: Db;\n    21→  connection: Connection;\n    22→  serverKey: PublicKey;\n    23→  pollIntervalMs: number;\n    24→  /** Called when a match is detected as ready for settlement (target_slot reached). */\n    25→  onSettleReady?: (pda: string) => Promise<void>;\n    26→}\n    27→\n    28→export interface SettlementWorker {\n    29→  start(): void;\n    30→  stop(): void;\n    31→  readonly isRunning: boolean;\n    32→  /** Run a single poll cycle (exposed for testing). */\n    33→  poll(): Promise<void>;\n    34→}\n    35→\n    36→export function createSettlementWorker(\n    37→  deps: SettlementWorkerDeps,\n    38→): SettlementWorker {\n    39→  const { db, connection, serverKey, pollIntervalMs } = deps;\n    40→  const discoveredPdas = new Set<string>();\n    41→  let running = false;\n    42→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    43→\n    44→  async function poll(): Promise<void> {\n    45→    const currentSlot = await connection.getSlot();\n    46→\n    47→    // Query chain for PHASE_LOCKED CoinflipMatch accounts with our server key\n    48→    const accounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n    49→      filters: [\n    50→        { dataSize: ACCOUNT_SIZE },\n    51→        {\n    52→          memcmp: {\n    53→            offset: PHASE_OFFSET,\n    54→            bytes: bs58.encode(Uint8Array.from([PHASE_LOCKED_VALUE])),\n    55→          },\n    56→        },\n    57→        {\n    58→          memcmp: {\n    59→            offset: SERVER_OFFSET,\n    60→            bytes: serverKey.toBase58(),\n    61→          },\n    62→        },\n    63→      ],\n    64→    });\n    65→\n    66→    for (const { pubkey, account } of accounts) {\n    67→      const pda = pubkey.toBase58();\n    68→      const data = Buffer.from(account.data);\n    69→\n    70→      // Parse target_slot (u64 LE at offset 148)\n    71→      const targetSlot = data.readBigUInt64LE(TARGET_SLOT_OFFSET);\n    72→\n    73→      // Log match_detected for newly discovered locked matches\n    74→      if (!discoveredPdas.has(pda)) {\n    75→        discoveredPdas.add(pda);\n    76→\n    77→        const round = await db.getRoundByPda(pda);\n    78→        if (round && round.phase === \"created\") {\n    79→          // Transition from created → locked in DB\n    80→          await db.updateRoundPhase(pda, \"locked\", {\n    81→            target_slot: targetSlot.toString(),\n    82→          });\n    83→          await db.insertOperatorEvent(pda, \"match_detected\", {\n    84→            targetSlot: targetSlot.toString(),\n    85→            currentSlot,\n    86→          });\n    87→        } else if (!round) {\n    88→          // Match on-chain but not in our DB — we don't have the secret, skip\n    89→          continue;\n    90→        }\n    91→      }\n    92→\n    93→      // Check if target_slot reached — match is ready for settlement\n    94→      if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n    95→        await deps.onSettleReady(pda);\n    96→      }\n    97→    }\n    98→  }\n    99→\n   100→  async function loop(): Promise<void> {\n   101→    if (!running) return;\n   102→    try {\n   103→      await poll();\n   104→    } catch (err) {\n   105→      // Log but don't crash — transient RPC errors are expected\n   106→      console.error(\n   107→        \"[settlement-worker] poll error:\",\n   108→        err instanceof Error ? err.message : err,\n   109→      );\n   110→    }\n   111→    if (running) {\n   112→      timeoutId = setTimeout(loop, pollIntervalMs);\n   113→    }\n   114→  }\n   115→\n   116→  return {\n   117→    start() {\n   118→      if (running) return;\n   119→      running = true;\n   120→      loop();\n   121→    },\n   122→    stop() {\n   123→      running = false;\n   124→      if (timeoutId) {\n   125→        clearTimeout(timeoutId);\n   126→        timeoutId = null;\n   127→      }\n   128→    },\n   129→    get isRunning() {\n   130→      return running;\n   131→    },\n   132→    poll,\n   133→  };\n   134→}\n   135→"}]},"parent_tool_use_id":null,"session_id":"65eaeb0b-2791-4aec-9b8c-bd2b8dc731bb","uuid":"61a7866f-b8e4-445c-855d-2c0ca937fab8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settlement.ts","content":"/**\n * Settlement worker — polls the chain for PHASE_LOCKED CoinflipMatch accounts\n * co-signed by this server and detects when they are ready for settlement.\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport type { Db } from \"../db.js\";\n\n// CoinflipMatch account layout offsets (includes 8-byte Anchor discriminator)\nconst ACCOUNT_SIZE = 246;\nconst SERVER_OFFSET = 72;\nconst PHASE_OFFSET = 114;\nconst TARGET_SLOT_OFFSET = 148;\n\nconst PHASE_LOCKED_VALUE = 1;\n\nexport interface SettlementWorkerDeps {\n  db: Db;\n  connection: Connection;\n  serverKey: PublicKey;\n  pollIntervalMs: number;\n  /** Called when a match is detected as ready for settlement (target_slot reached). */\n  onSettleReady?: (pda: string) => Promise<void>;\n}\n\nexport interface SettlementWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single poll cycle (exposed for testing). */\n  poll(): Promise<void>;\n}\n\nexport function createSettlementWorker(\n  deps: SettlementWorkerDeps,\n): SettlementWorker {\n  const { db, connection, serverKey, pollIntervalMs } = deps;\n  const discoveredPdas = new Set<string>();\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  async function poll(): Promise<void> {\n    const currentSlot = await connection.getSlot();\n\n    // Query chain for PHASE_LOCKED CoinflipMatch accounts with our server key\n    const accounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n      filters: [\n        { dataSize: ACCOUNT_SIZE },\n        {\n          memcmp: {\n            offset: PHASE_OFFSET,\n            bytes: bs58.encode(Uint8Array.from([PHASE_LOCKED_VALUE])),\n          },\n        },\n        {\n          memcmp: {\n            offset: SERVER_OFFSET,\n            bytes: serverKey.toBase58(),\n          },\n        },\n      ],\n    });\n\n    for (const { pubkey, account } of accounts) {\n      const pda = pubkey.toBase58();\n      const data = Buffer.from(account.data);\n\n      // Parse target_slot (u64 LE at offset 148)\n      const targetSlot = data.readBigUInt64LE(TARGET_SLOT_OFFSET);\n\n      // Log match_detected for newly discovered locked matches\n      if (!discoveredPdas.has(pda)) {\n        discoveredPdas.add(pda);\n\n        const round = await db.getRoundByPda(pda);\n        if (round && round.phase === \"created\") {\n          // Transition from created → locked in DB\n          await db.updateRoundPhase(pda, \"locked\", {\n            target_slot: targetSlot.toString(),\n          });\n          await db.insertOperatorEvent(pda, \"match_detected\", {\n            targetSlot: targetSlot.toString(),\n            currentSlot,\n          });\n        } else if (!round) {\n          // Match on-chain but not in our DB — we don't have the secret, skip\n          continue;\n        }\n      }\n\n      // Check if target_slot reached — match is ready for settlement\n      if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n        await deps.onSettleReady(pda);\n      }\n    }\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await poll();\n    } catch (err) {\n      // Log but don't crash — transient RPC errors are expected\n      console.error(\n        \"[settlement-worker] poll error:\",\n        err instanceof Error ? err.message : err,\n      );\n    }\n    if (running) {\n      timeoutId = setTimeout(loop, pollIntervalMs);\n    }\n  }\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n      loop();\n    },\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n    },\n    get isRunning() {\n      return running;\n    },\n    poll,\n  };\n}\n","numLines":135,"startLine":1,"totalLines":135}}}
