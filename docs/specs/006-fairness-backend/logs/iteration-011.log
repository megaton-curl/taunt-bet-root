{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Yan1gMxKxfaAH76Pa1pRdo","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { Connection, PublicKey } from \"@solana/web3.js\";\n     3→import { loadConfig } from \"./config.js\";\n     4→import { createDb } from \"./db.js\";\n     5→import { createCoinflipRoutes } from \"./routes/create.js\";\n     6→import { createAuthMiddleware } from \"./middleware/auth.js\";\n     7→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n     8→import { createSettlementWorker } from \"./worker/settlement.js\";\n     9→import { settleMatch } from \"./worker/settle-tx.js\";\n    10→\n    11→const config = loadConfig();\n    12→const db = createDb(config.databaseUrl);\n    13→const connection = new Connection(config.rpcUrl);\n    14→\n    15→const app = new Hono();\n    16→\n    17→// Health check (placeholder — full implementation in a later checklist item)\n    18→app.get(\"/health\", (c) => {\n    19→  return c.json({ status: \"ok\", version: \"0.1.0\" });\n    20→});\n    21→\n    22→// Rate limiting — per-wallet and global limits on POST requests\n    23→app.use(\n    24→  \"/fairness/*\",\n    25→  createRateLimitMiddleware({\n    26→    perWallet: config.rateLimitPerWallet,\n    27→    global: config.rateLimitGlobal,\n    28→    windowMs: 60_000,\n    29→  }),\n    30→);\n    31→\n    32→// Auth middleware — verifies wallet Ed25519 signatures on POST requests\n    33→app.use(\n    34→  \"/fairness/*\",\n    35→  createAuthMiddleware({ clockSkewSeconds: config.authClockSkewSeconds }),\n    36→);\n    37→\n    38→// Coinflip fairness routes\n    39→app.route(\n    40→  \"/fairness/coinflip\",\n    41→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair }),\n    42→);\n    43→\n    44→// Start settlement worker with settle-tx handler\n    45→const entropyAccount = new PublicKey(config.entropyAccount);\n    46→const worker = createSettlementWorker({\n    47→  db,\n    48→  connection,\n    49→  serverKey: config.serverKeypair.publicKey,\n    50→  pollIntervalMs: config.workerPollIntervalMs,\n    51→  async onSettleReady(pda: string) {\n    52→    try {\n    53→      const result = await settleMatch(\n    54→        { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n    55→        pda,\n    56→      );\n    57→      console.log(\n    58→        JSON.stringify({\n    59→          level: \"info\",\n    60→          msg: \"match settled\",\n    61→          pda,\n    62→          tx: result.txSignature,\n    63→          resultSide: result.resultSide,\n    64→          winner: result.winner,\n    65→        }),\n    66→      );\n    67→    } catch (err) {\n    68→      console.error(\n    69→        JSON.stringify({\n    70→          level: \"error\",\n    71→          msg: \"settle failed\",\n    72→          pda,\n    73→          error: err instanceof Error ? err.message : String(err),\n    74→        }),\n    75→      );\n    76→    }\n    77→  },\n    78→});\n    79→worker.start();\n    80→\n    81→const port = config.port;\n    82→console.log(`fairness-backend listening on :${port}`);\n    83→\n    84→export default {\n    85→  port,\n    86→  fetch: app.fetch,\n    87→};\n    88→"}]},"parent_tool_use_id":null,"session_id":"65eaeb0b-2791-4aec-9b8c-bd2b8dc731bb","uuid":"79f10eb0-b81e-4213-9843-01b4c1208590","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createAuthMiddleware } from \"./middleware/auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleMatch } from \"./worker/settle-tx.js\";\n\nconst config = loadConfig();\nconst db = createDb(config.databaseUrl);\nconst connection = new Connection(config.rpcUrl);\n\nconst app = new Hono();\n\n// Health check (placeholder — full implementation in a later checklist item)\napp.get(\"/health\", (c) => {\n  return c.json({ status: \"ok\", version: \"0.1.0\" });\n});\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/fairness/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Auth middleware — verifies wallet Ed25519 signatures on POST requests\napp.use(\n  \"/fairness/*\",\n  createAuthMiddleware({ clockSkewSeconds: config.authClockSkewSeconds }),\n);\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair }),\n);\n\n// Start settlement worker with settle-tx handler\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  async onSettleReady(pda: string) {\n    try {\n      const result = await settleMatch(\n        { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n        pda,\n      );\n      console.log(\n        JSON.stringify({\n          level: \"info\",\n          msg: \"match settled\",\n          pda,\n          tx: result.txSignature,\n          resultSide: result.resultSide,\n          winner: result.winner,\n        }),\n      );\n    } catch (err) {\n      console.error(\n        JSON.stringify({\n          level: \"error\",\n          msg: \"settle failed\",\n          pda,\n          error: err instanceof Error ? err.message : String(err),\n        }),\n      );\n    }\n  },\n});\nworker.start();\n\nconst port = config.port;\nconsole.log(`fairness-backend listening on :${port}`);\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":88,"startLine":1,"totalLines":88}}}
