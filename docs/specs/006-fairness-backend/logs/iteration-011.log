{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MXsukaybJQ6YY5FfJoMf1J","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→\n     3→export interface Config {\n     4→  port: number;\n     5→  databaseUrl: string;\n     6→  rpcUrl: string;\n     7→  serverKeypair: Keypair;\n     8→  authClockSkewSeconds: number;\n     9→  rateLimitPerWallet: number;\n    10→  rateLimitGlobal: number;\n    11→  workerPollIntervalMs: number;\n    12→  entropyAccount: string;\n    13→}\n    14→\n    15→function requireEnv(name: string): string {\n    16→  const value = process.env[name];\n    17→  if (!value) {\n    18→    throw new Error(`Missing required environment variable: ${name}`);\n    19→  }\n    20→  return value;\n    21→}\n    22→\n    23→function parseKeypair(raw: string): Keypair {\n    24→  try {\n    25→    const bytes = JSON.parse(raw) as number[];\n    26→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    27→  } catch {\n    28→    throw new Error(\n    29→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    30→    );\n    31→  }\n    32→}\n    33→\n    34→export function loadConfig(): Config {\n    35→  return {\n    36→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    37→    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    38→    rpcUrl: requireEnv(\"RPC_URL\"),\n    39→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    40→    authClockSkewSeconds: parseInt(\n    41→      process.env.AUTH_CLOCK_SKEW_SECONDS ?? \"60\",\n    42→      10,\n    43→    ),\n    44→    rateLimitPerWallet: parseInt(\n    45→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    46→      10,\n    47→    ),\n    48→    rateLimitGlobal: parseInt(\n    49→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    50→      10,\n    51→    ),\n    52→    workerPollIntervalMs: parseInt(\n    53→      process.env.WORKER_POLL_INTERVAL_MS ?? \"2000\",\n    54→      10,\n    55→    ),\n    56→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    57→  };\n    58→}\n    59→"}]},"parent_tool_use_id":"toolu_01TCr5UQbV71oF7ZKna1e4XY","session_id":"65eaeb0b-2791-4aec-9b8c-bd2b8dc731bb","uuid":"90f3d2ce-5d83-4595-83a9-9933edb7b11e"}
