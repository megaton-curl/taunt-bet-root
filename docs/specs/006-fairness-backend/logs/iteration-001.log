{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fjch2Y1qaYUPEBzNaKrhM2","type":"tool_result","content":"     1→import { sha256 } from \"@noble/hashes/sha256\";\n     2→import { bytesToHex, hexToBytes } from \"@noble/hashes/utils\";\n     3→\n     4→/**\n     5→ * Compute a commitment from a server seed\n     6→ * commitment = sha256(serverSeed)\n     7→ */\n     8→export function computeCommitment(serverSeed: string): string {\n     9→  const seedBytes = hexToBytes(serverSeed);\n    10→  const hash = sha256(seedBytes);\n    11→  return bytesToHex(hash);\n    12→}\n    13→\n    14→/**\n    15→ * Verify that a server seed matches its commitment\n    16→ */\n    17→export function verifyCommitment(serverSeed: string, commitment: string): boolean {\n    18→  const computed = computeCommitment(serverSeed);\n    19→  return computed.toLowerCase() === commitment.toLowerCase();\n    20→}\n    21→"}]},"parent_tool_use_id":null,"session_id":"6294e45f-f1b9-41ec-ad7c-8dacc5cf571a","uuid":"2aa7ac93-4cce-43c5-a94f-4c834b920d38","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/fairness/src/commitment.ts","content":"import { sha256 } from \"@noble/hashes/sha256\";\nimport { bytesToHex, hexToBytes } from \"@noble/hashes/utils\";\n\n/**\n * Compute a commitment from a server seed\n * commitment = sha256(serverSeed)\n */\nexport function computeCommitment(serverSeed: string): string {\n  const seedBytes = hexToBytes(serverSeed);\n  const hash = sha256(seedBytes);\n  return bytesToHex(hash);\n}\n\n/**\n * Verify that a server seed matches its commitment\n */\nexport function verifyCommitment(serverSeed: string, commitment: string): boolean {\n  const computed = computeCommitment(serverSeed);\n  return computed.toLowerCase() === commitment.toLowerCase();\n}\n","numLines":21,"startLine":1,"totalLines":21}}}
