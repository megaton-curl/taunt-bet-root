{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VHsLdDR9SheUdwK3MHdCXP","type":"tool_result","content":"     1→import { describe, it, expect } from \"vitest\";\n     2→import { hashToCrashPoint, computeCrashPoint } from \"./crash\";\n     3→\n     4→describe(\"hashToCrashPoint\", () => {\n     5→  it(\"always returns >= 1.0\", () => {\n     6→    // Max hash value (all f's) should still be >= 1.0\n     7→    const maxHash = \"fffffffffffff0000000000000000000000000000000000000000000000000000\";\n     8→    expect(hashToCrashPoint(maxHash)).toBeGreaterThanOrEqual(1.0);\n     9→  });\n    10→\n    11→  it(\"returns 1.0 for borderline hash values\", () => {\n    12→    // When h is very close to e, the formula yields ~1.0\n    13→    // h = e - 1 = 4503599627370495 = 0xfffffffffffff in first 13 hex chars\n    14→    // floor((100 * e - h) / (e - h)) / 100\n    15→    // = floor((100 * 4503599627370496 - 4503599627370495) / 1) / 100\n    16→    // = floor(450359962737049505) / 100 — very large\n    17→    // Actually when h is close to e, denominator is small, result is large\n    18→    // When h is close to 100*e/(100-1) ≈ e * 100/99 which exceeds e → clamp to 1.0\n    19→    // Let's use a hash that produces exactly 1.0: needs floor((100e - h)/(e - h)) = 100\n    20→    // That means (100e - h)/(e - h) < 101, i.e., h > (100e - 101*(e-1))/1 ... let's just verify the clamp\n    21→    const result = hashToCrashPoint(\"0000000000000\");\n    22→    // h = 0: floor((100 * e - 0) / (e - 0)) / 100 = floor(100) / 100 = 1.00\n    23→    expect(result).toBe(1.0);\n    24→  });\n    25→\n    26→  it(\"is deterministic — same hash yields same crash point\", () => {\n    27→    const hash = \"a1b2c3d4e5f6789012345678901234567890123456789012345678901234567890\";\n    28→    expect(hashToCrashPoint(hash)).toBe(hashToCrashPoint(hash));\n    29→  });\n    30→\n    31→  it(\"uses the formula floor((100 * 2^52 - h) / (2^52 - h)) / 100\", () => {\n    32→    // Pick a specific value and manually compute\n    33→    const hashHex = \"1000000000000\"; // h = 0x1000000000000 = 4503599627370496 / 4.something\n    34→    const h = parseInt(\"1000000000000\", 16); // = 17592186044416\n    35→    const e = Math.pow(2, 52); // 4503599627370496\n    36→    const expected = Math.max(1.0, Math.floor((100 * e - h) / (e - h)) / 100);\n    37→    expect(hashToCrashPoint(hashHex)).toBe(expected);\n    38→  });\n    39→});\n    40→\n    41→describe(\"computeCrashPoint\", () => {\n    42→  const serverSeed = \"abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789\";\n    43→  const publicSeed = \"public-seed-value\";\n    44→\n    45→  it(\"is deterministic — same inputs always produce same output\", () => {\n    46→    const a = computeCrashPoint(serverSeed, publicSeed, \"round-1\");\n    47→    const b = computeCrashPoint(serverSeed, publicSeed, \"round-1\");\n    48→    expect(a).toBe(b);\n    49→  });\n    50→\n    51→  it(\"produces different results for different roundIds\", () => {\n    52→    const a = computeCrashPoint(serverSeed, publicSeed, \"round-1\");\n    53→    const b = computeCrashPoint(serverSeed, publicSeed, \"round-2\");\n    54→    expect(a).not.toBe(b);\n    55→  });\n    56→\n    57→  it(\"produces different results for different server seeds\", () => {\n    58→    const otherSeed = \"1111111111111111111111111111111111111111111111111111111111111111\";\n    59→    const a = computeCrashPoint(serverSeed, publicSeed, \"round-1\");\n    60→    const b = computeCrashPoint(otherSeed, publicSeed, \"round-1\");\n    61→    expect(a).not.toBe(b);\n    62→  });\n    63→\n    64→  it(\"always returns >= 1.0\", () => {\n    65→    // Run a bunch of rounds and check all are >= 1.0\n    66→    for (let i = 0; i < 100; i++) {\n    67→      const result = computeCrashPoint(serverSeed, publicSeed, `round-${i}`);\n    68→      expect(result).toBeGreaterThanOrEqual(1.0);\n    69→    }\n    70→  });\n    71→\n    72→  it(\"accepts a custom gameId\", () => {\n    73→    const a = computeCrashPoint(serverSeed, publicSeed, \"round-1\", \"crash\");\n    74→    const b = computeCrashPoint(serverSeed, publicSeed, \"round-1\", \"other-game\");\n    75→    expect(a).not.toBe(b);\n    76→  });\n    77→\n    78→  it(\"defaults gameId to 'crash'\", () => {\n    79→    const withDefault = computeCrashPoint(serverSeed, publicSeed, \"round-1\");\n    80→    const explicit = computeCrashPoint(serverSeed, publicSeed, \"round-1\", \"crash\");\n    81→    expect(withDefault).toBe(explicit);\n    82→  });\n    83→});\n    84→"}]},"parent_tool_use_id":"toolu_01DzRUMjrdXcUaTjgQ46oZUi","session_id":"6294e45f-f1b9-41ec-ad7c-8dacc5cf571a","uuid":"d13008cf-358c-4598-ad4d-e1b0dd98efc6"}
