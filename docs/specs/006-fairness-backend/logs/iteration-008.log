{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QpGyb91eRXBYfQ4ZtHX1Zk","type":"tool_result","content":"     1→/**\n     2→ * Request authentication middleware.\n     3→ *\n     4→ * Verifies Ed25519 signature over a canonical JSON payload for POST requests.\n     5→ * GET requests pass through without authentication.\n     6→ */\n     7→\n     8→import type { MiddlewareHandler } from \"hono\";\n     9→import nacl from \"tweetnacl\";\n    10→import bs58 from \"bs58\";\n    11→\n    12→export interface AuthConfig {\n    13→  /** Maximum allowed clock skew in seconds (default 60). */\n    14→  clockSkewSeconds: number;\n    15→}\n    16→\n    17→/**\n    18→ * Creates a Hono middleware that authenticates POST requests by verifying an\n    19→ * Ed25519 wallet signature over the canonical payload:\n    20→ *   JSON.stringify({ wallet, tier, side, nonce, timestamp })\n    21→ *\n    22→ * GET requests are passed through without authentication.\n    23→ */\n    24→export function createAuthMiddleware(config: AuthConfig): MiddlewareHandler {\n    25→  return async (c, next) => {\n    26→    // Skip authentication for GET (and other non-POST) requests\n    27→    if (c.req.method !== \"POST\") {\n    28→      return next();\n    29→    }\n    30→\n    31→    let body: Record<string, unknown>;\n    32→    try {\n    33→      body = await c.req.json();\n    34→    } catch {\n    35→      return c.json({ error: \"Invalid JSON body\" }, 400);\n    36→    }\n    37→\n    38→    const { wallet, tier, side, nonce, timestamp, signature } = body;\n    39→\n    40→    // Require all auth-relevant fields\n    41→    if (\n    42→      typeof wallet !== \"string\" ||\n    43→      typeof signature !== \"string\" ||\n    44→      typeof timestamp !== \"number\"\n    45→    ) {\n    46→      return c.json({ error: \"Missing or invalid authentication fields\" }, 401);\n    47→    }\n    48→\n    49→    // Check timestamp freshness (replay protection)\n    50→    const nowSeconds = Math.floor(Date.now() / 1000);\n    51→    if (Math.abs(nowSeconds - timestamp) > config.clockSkewSeconds) {\n    52→      return c.json({ error: \"Request timestamp expired\" }, 401);\n    53→    }\n    54→\n    55→    // Canonical payload — keys in exact specified order\n    56→    const canonical = JSON.stringify({ wallet, tier, side, nonce, timestamp });\n    57→    const messageBytes = new TextEncoder().encode(canonical);\n    58→\n    59→    // Decode signature (base58) and public key (base58)\n    60→    let sigBytes: Uint8Array;\n    61→    let pubkeyBytes: Uint8Array;\n    62→    try {\n    63→      sigBytes = bs58.decode(signature);\n    64→      pubkeyBytes = bs58.decode(wallet);\n    65→    } catch {\n    66→      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n    67→    }\n    68→\n    69→    // Ed25519 signatures are 64 bytes, public keys are 32 bytes\n    70→    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n    71→      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n    72→    }\n    73→\n    74→    // Verify Ed25519 signature\n    75→    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n    76→    if (!valid) {\n    77→      return c.json({ error: \"Invalid signature\" }, 401);\n    78→    }\n    79→\n    80→    return next();\n    81→  };\n    82→}\n    83→"}]},"parent_tool_use_id":null,"session_id":"80c9db48-c6e9-4ca8-9b98-a9928dc69201","uuid":"2574c7eb-3e69-4548-ab91-893ae7d1fd1a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/middleware/auth.ts","content":"/**\n * Request authentication middleware.\n *\n * Verifies Ed25519 signature over a canonical JSON payload for POST requests.\n * GET requests pass through without authentication.\n */\n\nimport type { MiddlewareHandler } from \"hono\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\n\nexport interface AuthConfig {\n  /** Maximum allowed clock skew in seconds (default 60). */\n  clockSkewSeconds: number;\n}\n\n/**\n * Creates a Hono middleware that authenticates POST requests by verifying an\n * Ed25519 wallet signature over the canonical payload:\n *   JSON.stringify({ wallet, tier, side, nonce, timestamp })\n *\n * GET requests are passed through without authentication.\n */\nexport function createAuthMiddleware(config: AuthConfig): MiddlewareHandler {\n  return async (c, next) => {\n    // Skip authentication for GET (and other non-POST) requests\n    if (c.req.method !== \"POST\") {\n      return next();\n    }\n\n    let body: Record<string, unknown>;\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"Invalid JSON body\" }, 400);\n    }\n\n    const { wallet, tier, side, nonce, timestamp, signature } = body;\n\n    // Require all auth-relevant fields\n    if (\n      typeof wallet !== \"string\" ||\n      typeof signature !== \"string\" ||\n      typeof timestamp !== \"number\"\n    ) {\n      return c.json({ error: \"Missing or invalid authentication fields\" }, 401);\n    }\n\n    // Check timestamp freshness (replay protection)\n    const nowSeconds = Math.floor(Date.now() / 1000);\n    if (Math.abs(nowSeconds - timestamp) > config.clockSkewSeconds) {\n      return c.json({ error: \"Request timestamp expired\" }, 401);\n    }\n\n    // Canonical payload — keys in exact specified order\n    const canonical = JSON.stringify({ wallet, tier, side, nonce, timestamp });\n    const messageBytes = new TextEncoder().encode(canonical);\n\n    // Decode signature (base58) and public key (base58)\n    let sigBytes: Uint8Array;\n    let pubkeyBytes: Uint8Array;\n    try {\n      sigBytes = bs58.decode(signature);\n      pubkeyBytes = bs58.decode(wallet);\n    } catch {\n      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n    }\n\n    // Ed25519 signatures are 64 bytes, public keys are 32 bytes\n    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n    }\n\n    // Verify Ed25519 signature\n    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n    if (!valid) {\n      return c.json({ error: \"Invalid signature\" }, 401);\n    }\n\n    return next();\n  };\n}\n","numLines":83,"startLine":1,"totalLines":83}}}
