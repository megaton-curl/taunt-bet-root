{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01X9rtBMExHQ5AS64x957eGG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Ws4zgXVQGJQnzVhWuvdxDu","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/middleware/rate-limit.ts","content":"/**\n * In-memory sliding-window rate limiting middleware.\n *\n * Applies per-wallet and global limits to POST requests only.\n * Counters reset on service restart (acceptable for MVP).\n */\n\nimport type { MiddlewareHandler } from \"hono\";\n\nexport interface RateLimitConfig {\n  /** Max POST requests per wallet per window (default 10). */\n  perWallet: number;\n  /** Max total POST requests per window (default 100). */\n  global: number;\n  /** Window size in milliseconds (default 60_000 = 1 minute). */\n  windowMs: number;\n}\n\ninterface SlidingWindow {\n  timestamps: number[];\n}\n\n/**\n * Prune timestamps older than the window and return the current count.\n */\nfunction countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n  const cutoff = now - windowMs;\n  // Remove expired entries from the front\n  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n    window.timestamps.shift();\n  }\n  return window.timestamps.length;\n}\n\n/**\n * Creates a Hono middleware that rate-limits POST requests.\n *\n * - Per-wallet: keyed by the `wallet` field in the JSON body.\n * - Global: all POST requests combined.\n * - Returns 429 with `Retry-After` header when either limit is exceeded.\n * - GET requests pass through without rate limiting.\n */\nexport function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n  const walletWindows = new Map<string, SlidingWindow>();\n  const globalWindow: SlidingWindow = { timestamps: [] };\n\n  return async (c, next) => {\n    if (c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const now = Date.now();\n    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n\n    // Check global limit first\n    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n    if (globalCount >= config.global) {\n      c.header(\"Retry-After\", String(retryAfterSeconds));\n      return c.json({ error: \"Too many requests\" }, 429);\n    }\n\n    // Extract wallet from body for per-wallet limiting.\n    // We clone the request so downstream handlers can still read the body.\n    let wallet: string | undefined;\n    try {\n      const body = await c.req.json();\n      wallet = typeof body.wallet === \"string\" ? body.wallet : undefined;\n    } catch {\n      // If body is not parseable, skip per-wallet limiting (auth middleware\n      // will reject it anyway). Still count against global limit.\n    }\n\n    // Check per-wallet limit\n    if (wallet) {\n      let wWindow = walletWindows.get(wallet);\n      if (!wWindow) {\n        wWindow = { timestamps: [] };\n        walletWindows.set(wallet, wWindow);\n      }\n      const walletCount = countInWindow(wWindow, now, config.windowMs);\n      if (walletCount >= config.perWallet) {\n        c.header(\"Retry-After\", String(retryAfterSeconds));\n        return c.json({ error: \"Too many requests\" }, 429);\n      }\n      wWindow.timestamps.push(now);\n    }\n\n    // Record in global window\n    globalWindow.timestamps.push(now);\n\n    return next();\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7959,"cache_read_input_tokens":30164,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7959},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"80c9db48-c6e9-4ca8-9b98-a9928dc69201","uuid":"9a1edd45-4725-4ccd-abc5-82ccbb6262ce"}
