,\n);\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair }),\n);\n\nconst port = config.port;\nconsole.log(`fairness-backend listening on :${port}`);\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","structuredPatch":[{"oldStart":17,"oldLines":6,"newStart":17,"newLines":16,"lines":["   return c.json({ status: \"ok\", version: \"0.1.0\" });"," });"," ","+// Rate limiting — per-wallet and global limits on POST requests","+app.use(","+  \"/fairness/*\",","+  createRateLimitMiddleware({","+    perWallet: config.rateLimitPerWallet,","+    global: config.rateLimitGlobal,","+    windowMs: 60_000,","+  }),","+);","+"," // Auth middleware — verifies wallet Ed25519 signatures on POST requests"," app.use(","   \"/fairness/*\","]}],"userModified":false,"replaceAll":false}}
