{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CLEBahkRm8S9ftF1SM4ogt","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→\n     3→export interface Config {\n     4→  port: number;\n     5→  databaseUrl: string;\n     6→  rpcUrl: string;\n     7→  serverKeypair: Keypair;\n     8→  authClockSkewSeconds: number;\n     9→}\n    10→\n    11→function requireEnv(name: string): string {\n    12→  const value = process.env[name];\n    13→  if (!value) {\n    14→    throw new Error(`Missing required environment variable: ${name}`);\n    15→  }\n    16→  return value;\n    17→}\n    18→\n    19→function parseKeypair(raw: string): Keypair {\n    20→  try {\n    21→    const bytes = JSON.parse(raw) as number[];\n    22→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    23→  } catch {\n    24→    throw new Error(\n    25→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    26→    );\n    27→  }\n    28→}\n    29→\n    30→export function loadConfig(): Config {\n    31→  return {\n    32→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    33→    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    34→    rpcUrl: requireEnv(\"RPC_URL\"),\n    35→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    36→    authClockSkewSeconds: parseInt(\n    37→      process.env.AUTH_CLOCK_SKEW_SECONDS ?? \"60\",\n    38→      10,\n    39→    ),\n    40→  };\n    41→}\n    42→"}]},"parent_tool_use_id":null,"session_id":"80c9db48-c6e9-4ca8-9b98-a9928dc69201","uuid":"1ccf8204-1552-4d84-8b9c-ebc5e9e7fef0","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/config.ts","content":"import { Keypair } from \"@solana/web3.js\";\n\nexport interface Config {\n  port: number;\n  databaseUrl: string;\n  rpcUrl: string;\n  serverKeypair: Keypair;\n  authClockSkewSeconds: number;\n}\n\nfunction requireEnv(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction parseKeypair(raw: string): Keypair {\n  try {\n    const bytes = JSON.parse(raw) as number[];\n    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n  } catch {\n    throw new Error(\n      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    );\n  }\n}\n\nexport function loadConfig(): Config {\n  return {\n    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: requireEnv(\"DATABASE_URL\"),\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    authClockSkewSeconds: parseInt(\n      process.env.AUTH_CLOCK_SKEW_SECONDS ?? \"60\",\n      10,\n    ),\n  };\n}\n","numLines":42,"startLine":1,"totalLines":42}}}
