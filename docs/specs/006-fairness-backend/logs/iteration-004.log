{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QDb6BmAZ485HGBYtEsMotf","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\n     5→import anchor from \"@coral-xyz/anchor\";\n     6→const { BN } = anchor;\n     7→import {\n     8→  Keypair,\n     9→  PublicKey,\n    10→  SystemProgram,\n    11→  LAMPORTS_PER_SOL,\n    12→} from \"@solana/web3.js\";\n    13→import { Clock } from \"solana-bankrun\";\n    14→import { createHash } from \"crypto\";\n    15→import type { Coinflip } from \"../target/types/coinflip\";\n    16→import type { Platform } from \"../target/types/platform\";\n    17→import { readFileSync } from \"fs\";\n    18→import { dirname, join } from \"path\";\n    19→import { fileURLToPath } from \"url\";\n    20→\n    21→const __filename = fileURLToPath(import.meta.url);\n    22→const __dirname = dirname(__filename);\n    23→\n    24→const IDL = JSON.parse(\n    25→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n    26→);\n    27→const PROGRAM_ID = new PublicKey(IDL.address);\n    28→\n    29→const PLATFORM_IDL = JSON.parse(\n    30→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    31→);\n    32→const PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n    33→\n    34→// ---------------------------------------------------------------------------\n    35→// Constants matching shared crate\n    36→// ---------------------------------------------------------------------------\n    37→const SIDE_HEADS = 0;\n    38→const SIDE_TAILS = 1;\n    39→const TIER_COPPER = 0;\n    40→const TIER_COPPER_AMOUNT = 2_500_000; // 0.0025 SOL\n    41→const TIER_IRON = 1;\n    42→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL\n    43→const TOTAL_FEE_BPS = 300;\n    44→const DEFAULT_RESOLVE_TIMEOUT = 86_400; // 24 hours (seconds)\n    45→\n    46→// ---------------------------------------------------------------------------\n    47→// Crypto helpers (commit-reveal)\n    48→// ---------------------------------------------------------------------------\n    49→function sha256(data: Buffer): Buffer {\n    50→  return createHash(\"sha256\").update(data).digest();\n    51→}\n    52→\n    53→function computeCommitment(secret: Buffer): Buffer {\n    54→  return sha256(secret);\n    55→}\n    56→\n    57→function deriveResult(\n    58→  secret: Buffer,\n    59→  entropy: Buffer,\n    60→  matchPda: PublicKey,\n    61→  algorithmVer: number\n    62→): Buffer {\n    63→  const pdaBytes = matchPda.toBuffer();\n    64→  const verBuf = Buffer.from([algorithmVer]);\n    65→  return sha256(Buffer.concat([secret, entropy, pdaBytes, verBuf]));\n    66→}\n    67→\n    68→// ---------------------------------------------------------------------------\n    69→// PDA helpers\n    70→// ---------------------------------------------------------------------------\n    71→function getMatchPda(\n    72→  creator: PublicKey,\n    73→  nonce: number | bigint = 0\n    74→): PublicKey {\n    75→  const nonceBuf = Buffer.alloc(8);\n    76→  nonceBuf.writeBigUInt64LE(BigInt(nonce));\n    77→  const [pda] = PublicKey.findProgramAddressSync(\n    78→    [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    79→    PROGRAM_ID\n    80→  );\n    81→  return pda;\n    82→}\n    83→\n    84→function getConfigPda(): PublicKey {\n    85→  const [pda] = PublicKey.findProgramAddressSync(\n    86→    [Buffer.from(\"coinflip_config\")],\n    87→    PROGRAM_ID\n    88→  );\n    89→  return pda;\n    90→}\n    91→\n    92→function getPlatformConfigPda(): PublicKey {\n    93→  const [pda] = PublicKey.findProgramAddressSync(\n    94→    [Buffer.from(\"platform_config\")],\n    95→    PLATFORM_PROGRAM_ID\n    96→  );\n    97→  return pda;\n    98→}\n    99→\n   100→function getPlayerProfilePda(wallet: PublicKey): PublicKey {"}]},"parent_tool_use_id":"toolu_01UfhKew8eGwXTTEynqzJnCg","session_id":"f4316b62-2257-4469-b202-66365945525c","uuid":"cb92bc03-db4d-45fb-987f-7d168863d7e1"}
