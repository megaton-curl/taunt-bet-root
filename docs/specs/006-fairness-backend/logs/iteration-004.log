{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T19mFdPNfSKprG2bPPrGRb","type":"tool_result","content":"     1→import { Program, AnchorProvider, BN, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { CoinflipIDL, PlatformIDL, type Coinflip, type Platform } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  TIER_VALUES,\n    11→  COIN_SIDE_VALUES,\n    12→  TIER_AMOUNTS,\n    13→  type Tier,\n    14→  type CoinSide,\n    15→} from \"@rng-utopia/game-engine/browser\";\n    16→import type { UIMatch } from \"../types\";\n    17→\n    18→// ============ Constants ============\n    19→\n    20→const COINFLIP_PROGRAM_ID = new PublicKey(\n    21→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    22→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    23→);\n    24→\n    25→const PLATFORM_PROGRAM_ID = new PublicKey(\n    26→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    27→    .VITE_PLATFORM_PROGRAM_ID ?? PlatformIDL.address\n    28→);\n    29→\n    30→// Phase constants matching on-chain\n    31→const PHASE_WAITING = 0;\n    32→const PHASE_LOCKED = 1;\n    33→const PHASE_SETTLED = 2;\n    34→const PHASE_REFUNDED = 3;\n    35→\n    36→// ============ PDA Derivation ============\n    37→\n    38→export function getMatchPda(creator: PublicKey, nonce: bigint | number): [PublicKey, number] {\n    39→  const nonceBuf = Buffer.alloc(8);\n    40→  nonceBuf.writeBigUInt64LE(BigInt(nonce));\n    41→  return PublicKey.findProgramAddressSync(\n    42→    [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    43→    COINFLIP_PROGRAM_ID\n    44→  );\n    45→}\n    46→\n    47→export function getConfigPda(): [PublicKey, number] {\n    48→  return PublicKey.findProgramAddressSync(\n    49→    [Buffer.from(\"coinflip_config\")],\n    50→    COINFLIP_PROGRAM_ID\n    51→  );\n    52→}\n    53→\n    54→function getPlayerProfilePda(wallet: PublicKey): [PublicKey, number] {\n    55→  return PublicKey.findProgramAddressSync(\n    56→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    57→    PLATFORM_PROGRAM_ID\n    58→  );\n    59→}\n    60→\n    61→// ============ Program Instances ============\n    62→\n    63→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    64→  // Read-only provider (no wallet needed for queries)\n    65→  const provider = new AnchorProvider(\n    66→    connection,\n    67→    {} as AnchorProvider[\"wallet\"],\n    68→    { commitment: \"confirmed\" }\n    69→  );\n    70→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    71→}\n    72→\n    73→function getPlatformProgram(connection: Connection): Program<Platform> {\n    74→  const provider = new AnchorProvider(\n    75→    connection,\n    76→    {} as AnchorProvider[\"wallet\"],\n    77→    { commitment: \"confirmed\" }\n    78→  );\n    79→  return new Program(PlatformIDL as Idl as Platform, provider);\n    80→}\n    81→\n    82→// ============ On-Chain Account Types ============\n    83→\n    84→interface OnChainMatch {\n    85→  creator: PublicKey;\n    86→  opponent: PublicKey;\n    87→  server: PublicKey;\n    88→  tier: number;\n    89→  entryAmount: { toNumber(): number };\n    90→  creatorSide: number;\n    91→  phase: number;\n    92→  commitment: number[];\n    93→  algorithmVer: number;\n    94→  targetSlot: { toNumber(): number };\n    95→  resolveDeadline: { toNumber(): number };\n    96→  resultHash: number[];\n    97→  result: number;\n    98→  winner: PublicKey;\n    99→  createdAt: { toNumber(): number };\n   100→  nonce: { toNumber(): number };\n   101→  bump: number;\n   102→  creatorWantsRefund: boolean;\n   103→  opponentWantsRefund: boolean;\n   104→}\n   105→\n   106→// ============ Converters ============\n   107→\n   108→function tierFromIndex(index: number): Tier {\n   109→  const tiers: Tier[] = [\"copper\", \"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\", \"emerald\"];\n   110→  return tiers[index] ?? \"iron\";\n   111→}\n   112→\n   113→function sideFromIndex(index: number): CoinSide {\n   114→  return index === 0 ? \"heads\" : \"tails\";\n   115→}\n   116→\n   117→function phaseToUI(phase: number): UIMatch[\"phase\"] {\n   118→  if (phase === PHASE_WAITING) return \"created\";\n   119→  if (phase === PHASE_LOCKED) return \"ready\";\n   120→  if (phase === PHASE_SETTLED) return \"complete\";\n   121→  return \"created\";\n   122→}\n   123→\n   124→const DEFAULT_PUBKEY = PublicKey.default;\n   125→\n   126→function isDefaultPubkey(key: PublicKey): boolean {\n   127→  return key.equals(DEFAULT_PUBKEY);\n   128→}\n   129→\n   130→import { bytesToHex, sha256 } from \"./crypto\";\n   131→\n   132→export function onChainMatchToUI(\n   133→  matchPda: PublicKey,\n   134→  data: OnChainMatch\n   135→): UIMatch {\n   136→  const tier = tierFromIndex(data.tier);\n   137→  const creatorSide = sideFromIndex(data.creatorSide);\n   138→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   139→  const phase = phaseToUI(data.phase);\n   140→  const isSettled = data.phase === PHASE_SETTLED;\n   141→\n   142→  const entryAmountSol = TIER_AMOUNTS[tier];\n   143→  const totalPool = entryAmountSol * 2;\n   144→  const payoutAmount = totalPool * 0.97;\n   145→\n   146→  return {\n   147→    id: matchPda.toBase58(),\n   148→    tier,\n   149→    entryAmount: entryAmountSol,\n   150→    player1: data.creator.toBase58(),\n   151→    player1Side: creatorSide,\n   152→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   153→    player2Side: hasOpponent\n   154→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   155→      : null,\n   156→    phase,\n   157→    createdAt: data.createdAt.toNumber() * 1000,\n   158→    lockedAt: data.phase >= PHASE_LOCKED && data.resolveDeadline.toNumber() > 0\n   159→      ? (data.resolveDeadline.toNumber() - 86400) * 1000\n   160→      : undefined,\n   161→    result: isSettled ? sideFromIndex(data.result) : null,\n   162→    winner: isSettled && !isDefaultPubkey(data.winner)\n   163→      ? data.winner.toBase58()\n   164→      : null,\n   165→    payoutAmount,\n   166→    commitment: bytesToHex(data.commitment),\n   167→    resultHash: isSettled ? bytesToHex(data.resultHash) : undefined,\n   168→  };\n   169→}\n   170→\n   171→// ============ Player Profile ============\n   172→\n   173→/** Fetch a player's profile from the platform program. Returns null if not found. */\n   174→export async function fetchPlayerProfile(\n   175→  connection: Connection,\n   176→  wallet: PublicKey\n   177→): Promise<{ matchNonce: bigint } | null> {\n   178→  const program = getPlatformProgram(connection);\n   179→  const [profilePda] = getPlayerProfilePda(wallet);\n   180→  try {\n   181→    const profile = await program.account.playerProfile.fetch(profilePda);\n   182→    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   183→    const nonce = (profile as any).matchNonce;\n   184→    return { matchNonce: BigInt(nonce.toString()) };\n   185→  } catch {\n   186→    return null;\n   187→  }\n   188→}\n   189→\n   190→// ============ Account Queries ============\n   191→\n   192→export async function fetchAllOpenMatches(\n   193→  connection: Connection\n   194→): Promise<UIMatch[]> {\n   195→  const program = getCoinflipProgram(connection);\n   196→  const accounts = await program.account.coinflipMatch.all([\n   197→    { dataSize: program.account.coinflipMatch.size },\n   198→  ]);\n   199→\n   200→  return accounts\n   201→    .filter((acc) => (acc.account as unknown as OnChainMatch).phase === PHASE_WAITING)\n   202→    .map((acc) =>\n   203→      onChainMatchToUI(\n   204→        acc.publicKey,\n   205→        acc.account as unknown as OnChainMatch\n   206→      )\n   207→    );\n   208→}\n   209→\n   210→/**\n   211→ * Fetch all matches where playerPubkey is creator OR opponent,\n   212→ * phase is non-terminal (not refunded/settled with PDA closed).\n   213→ * Uses memcmp filters for efficient on-chain filtering.\n   214→ *\n   215→ * Account layout offsets (after 8-byte discriminator):\n   216→ *   creator:  8   (32 bytes)\n   217→ *   opponent: 40  (32 bytes)\n   218→ */\n   219→export async function fetchClaimableMatches(\n   220→  connection: Connection,\n   221→  playerPubkey: PublicKey\n   222→): Promise<UIMatch[]> {\n   223→  const program = getCoinflipProgram(connection);\n   224→  const playerBase58 = playerPubkey.toBase58();\n   225→\n   226→  const [asCreator, asOpponent] = await Promise.all([\n   227→    program.account.coinflipMatch.all([\n   228→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   229→      { dataSize: program.account.coinflipMatch.size },\n   230→    ]),\n   231→    program.account.coinflipMatch.all([\n   232→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   233→      { dataSize: program.account.coinflipMatch.size },\n   234→    ]),\n   235→  ]);\n   236→\n   237→  // Merge and deduplicate by public key\n   238→  const seen = new Set<string>();\n   239→  const matches: UIMatch[] = [];\n   240→\n   241→  for (const acc of [...asCreator, ...asOpponent]) {\n   242→    const key = acc.publicKey.toBase58();\n   243→    if (seen.has(key)) continue;\n   244→    seen.add(key);\n   245→\n   246→    const data = acc.account as unknown as OnChainMatch;\n   247→    // Skip terminal phases\n   248→    if (data.phase === PHASE_REFUNDED || data.phase === PHASE_SETTLED) continue;\n   249→\n   250→    matches.push(onChainMatchToUI(acc.publicKey, data));\n   251→  }\n   252→\n   253→  return matches;\n   254→}\n   255→\n   256→/**\n   257→ * Find the active (non-terminal) match for a creator using memcmp filters.\n   258→ * Returns null if no active match exists.\n   259→ */\n   260→export async function fetchMatchByCreator(\n   261→  connection: Connection,\n   262→  creator: PublicKey\n   263→): Promise<UIMatch | null> {\n   264→  const program = getCoinflipProgram(connection);\n   265→\n   266→  const matches = await program.account.coinflipMatch.all([\n   267→    { memcmp: { offset: 8, bytes: creator.toBase58() } },\n   268→    { dataSize: program.account.coinflipMatch.size },\n   269→  ]);\n   270→\n   271→  // Find first non-terminal match\n   272→  for (const acc of matches) {\n   273→    const data = acc.account as unknown as OnChainMatch;\n   274→    if (data.phase === PHASE_REFUNDED || data.phase === PHASE_SETTLED) continue;\n   275→    return onChainMatchToUI(acc.publicKey, data);\n   276→  }\n   277→\n   278→  return null;\n   279→}\n   280→\n   281→export async function fetchMatch(\n   282→  connection: Connection,\n   283→  matchPda: PublicKey\n   284→): Promise<UIMatch | null> {\n   285→  const program = getCoinflipProgram(connection);\n   286→\n   287→  try {\n   288→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   289→    const data = account as unknown as OnChainMatch;\n   290→    return onChainMatchToUI(matchPda, data);\n   291→  } catch {\n   292→    return null;\n   293→  }\n   294→}\n   295→\n   296→// ============ Crypto Helpers ============\n   297→\n   298→/** Generate a random 32-byte secret for commit-reveal. */\n   299→export function generateSecret(): Uint8Array {\n   300→  const secret = new Uint8Array(32);\n   301→  crypto.getRandomValues(secret);\n   302→  return secret;\n   303→}\n   304→\n   305→/** Compute commitment = SHA-256(secret). */\n   306→export async function computeCommitment(secret: Uint8Array): Promise<Uint8Array> {\n   307→  return sha256(secret);\n   308→}\n   309→\n   310→// ============ Instruction Builders ============\n   311→\n   312→/**\n   313→ * Build a create-match transaction with commit-reveal.\n   314→ *\n   315→ * Bundles up to 3 instructions atomically:\n   316→ * 1. create_player_profile (only if the profile doesn't exist yet)\n   317→ * 2. increment_match_nonce (bumps profile nonce from N to N+1)\n   318→ * 3. create_match(commitment, tier, side, N)\n   319→ *\n   320→ * The server keypair co-signs in dev mode (secret generated client-side).\n   321→ * Returns the secret for later settlement.\n   322→ */\n   323→export async function buildCreateMatchTx(\n   324→  connection: Connection,\n   325→  creator: PublicKey,\n   326→  tier: Tier,\n   327→  side: CoinSide,\n   328→  nonce: bigint | number,\n   329→  serverPubkey: PublicKey,\n   330→  commitment: Uint8Array,\n   331→  options?: { includeProfileCreation?: boolean },\n   332→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   333→  const program = getCoinflipProgram(connection);\n   334→  const platformProgram = getPlatformProgram(connection);\n   335→  const [matchPda] = getMatchPda(creator, nonce);\n   336→  const [configPda] = getConfigPda();\n   337→  const [profilePda] = getPlayerProfilePda(creator);\n   338→\n   339→  const tierIndex = TIER_VALUES[tier];\n   340→  const sideIndex = COIN_SIDE_VALUES[side];\n   341→\n   342→  const tx = new Transaction();\n   343→\n   344→  // Optional: create player profile if it doesn't exist\n   345→  if (options?.includeProfileCreation) {\n   346→    const createProfileIx = await platformProgram.methods\n   347→      .createPlayerProfile()\n   348→      .accountsStrict({\n   349→        player: creator,\n   350→        profile: profilePda,\n   351→        systemProgram: SystemProgram.programId,\n   352→      })\n   353→      .instruction();\n   354→    tx.add(createProfileIx);\n   355→  }\n   356→\n   357→  // Instruction: increment nonce on platform program\n   358→  const incrementIx = await platformProgram.methods\n   359→    .incrementMatchNonce()\n   360→    .accountsStrict({\n   361→      player: creator,\n   362→      profile: profilePda,\n   363→    })\n   364→    .instruction();\n   365→  tx.add(incrementIx);\n   366→\n   367→  // Instruction: create match on coinflip program (with commitment + server co-signer)\n   368→  const createIx = await program.methods\n   369→    .createMatch(\n   370→      Array.from(commitment) as unknown as number[],\n   371→      tierIndex,\n   372→      sideIndex,\n   373→      new BN(nonce.toString()),\n   374→    )\n   375→    .accountsStrict({\n   376→      creator,\n   377→      server: serverPubkey,\n   378→      coinflipMatch: matchPda,\n   379→      config: configPda,\n   380→      systemProgram: SystemProgram.programId,\n   381→    })\n   382→    .instruction();\n   383→  tx.add(createIx);\n   384→\n   385→  tx.feePayer = creator;\n   386→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   387→\n   388→  return { transaction: tx, matchPda };\n   389→}\n   390→\n   391→export async function buildJoinMatchTx(\n   392→  connection: Connection,\n   393→  opponent: PublicKey,\n   394→  matchPda: PublicKey\n   395→): Promise<Transaction> {\n   396→  const program = getCoinflipProgram(connection);\n   397→  const [configPda] = getConfigPda();\n   398→\n   399→  const ix = await program.methods\n   400→    .joinMatch()\n   401→    .accountsStrict({\n   402→      opponent,\n   403→      coinflipMatch: matchPda,\n   404→      config: configPda,\n   405→      systemProgram: SystemProgram.programId,\n   406→    })\n   407→    .instruction();\n   408→\n   409→  const tx = new Transaction().add(ix);\n   410→  tx.feePayer = opponent;\n   411→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   412→\n   413→  return tx;\n   414→}\n   415→\n   416→export async function buildCancelMatchTx(\n   417→  connection: Connection,\n   418→  creator: PublicKey,\n   419→  matchPda: PublicKey\n   420→): Promise<Transaction> {\n   421→  const program = getCoinflipProgram(connection);\n   422→\n   423→  const ix = await program.methods\n   424→    .cancelMatch()\n   425→    .accountsStrict({\n   426→      creator,\n   427→      coinflipMatch: matchPda,\n   428→      systemProgram: SystemProgram.programId,\n   429→    })\n   430→    .instruction();\n   431→\n   432→  const tx = new Transaction().add(ix);\n   433→  tx.feePayer = creator;\n   434→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   435→\n   436→  return tx;\n   437→}\n   438→\n   439→export async function buildTimeoutRefundTx(\n   440→  connection: Connection,\n   441→  caller: PublicKey,\n   442→  matchPda: PublicKey,\n   443→  matchCreator: PublicKey,\n   444→  opponent: PublicKey\n   445→): Promise<Transaction> {\n   446→  const program = getCoinflipProgram(connection);\n   447→\n   448→  const ix = await program.methods\n   449→    .timeoutRefund()\n   450→    .accountsStrict({\n   451→      caller,\n   452→      creator: matchCreator,\n   453→      opponent,\n   454→      coinflipMatch: matchPda,\n   455→    })\n   456→    .instruction();\n   457→\n   458→  const tx = new Transaction().add(ix);\n   459→  tx.feePayer = caller;\n   460→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   461→\n   462→  return tx;\n   463→}\n   464→\n   465→export async function buildSettleTx(\n   466→  connection: Connection,\n   467→  caller: PublicKey,\n   468→  matchPda: PublicKey,\n   469→  matchCreator: PublicKey,\n   470→  opponent: PublicKey,\n   471→  secret: Uint8Array,\n   472→  entropyPubkey: PublicKey,\n   473→): Promise<Transaction> {\n   474→  const program = getCoinflipProgram(connection);\n   475→  const [configPda] = getConfigPda();\n   476→\n   477→  // Fetch config to get treasury address\n   478→  const config = await program.account.coinflipConfig.fetch(configPda);\n   479→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   480→\n   481→  // Derive player profile PDAs for CPI\n   482→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   483→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   484→    PLATFORM_PROGRAM_ID\n   485→  );\n   486→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   487→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   488→    PLATFORM_PROGRAM_ID\n   489→  );\n   490→\n   491→  const ix = await program.methods\n   492→    .settle(Array.from(secret) as unknown as number[])\n   493→    .accountsStrict({\n   494→      caller,\n   495→      coinflipMatch: matchPda,\n   496→      config: configPda,\n   497→      entropy: entropyPubkey,\n   498→      treasury,\n   499→      creator: matchCreator,\n   500→      opponent,\n   501→      creatorProfile,\n   502→      opponentProfile,\n   503→      platformProgram: PLATFORM_PROGRAM_ID,\n   504→      systemProgram: SystemProgram.programId,\n   505→    })\n   506→    .instruction();\n   507→\n   508→  const tx = new Transaction().add(ix);\n   509→  tx.feePayer = caller;\n   510→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   511→\n   512→  return tx;\n   513→}\n   514→\n   515→export async function buildRequestRefundTx(\n   516→  connection: Connection,\n   517→  caller: PublicKey,\n   518→  matchPda: PublicKey,\n   519→  matchCreator: PublicKey,\n   520→  opponent: PublicKey,\n   521→): Promise<Transaction> {\n   522→  const program = getCoinflipProgram(connection);\n   523→\n   524→  const ix = await program.methods\n   525→    .requestRefund()\n   526→    .accountsStrict({\n   527→      caller,\n   528→      creator: matchCreator,\n   529→      opponent,\n   530→      coinflipMatch: matchPda,\n   531→    })\n   532→    .instruction();\n   533→\n   534→  const tx = new Transaction().add(ix);\n   535→  tx.feePayer = caller;\n   536→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   537→\n   538→  return tx;\n   539→}\n   540→"}]},"parent_tool_use_id":"toolu_01UfhKew8eGwXTTEynqzJnCg","session_id":"f4316b62-2257-4469-b202-66365945525c","uuid":"0ee73350-eec4-4d10-a3cd-83145bd95d34"}
