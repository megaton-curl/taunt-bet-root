{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Qn7sQoor1X4fEthtqo9zbQ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AwEVJau2DVjj27nkWBSnH8","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/fairness.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { createHash } from \"node:crypto\";\nimport { Keypair, PublicKey } from \"@solana/web3.js\";\nimport { generateSecret, computeCommitment, deriveMatchPda } from \"../fairness.js\";\n\ndescribe(\"generateSecret\", () => {\n  it(\"returns a 32-byte buffer\", () => {\n    const secret = generateSecret();\n    expect(Buffer.isBuffer(secret)).toBe(true);\n    expect(secret.length).toBe(32);\n  });\n\n  it(\"produces unique secrets on successive calls\", () => {\n    const a = generateSecret();\n    const b = generateSecret();\n    expect(a.equals(b)).toBe(false);\n  });\n});\n\ndescribe(\"computeCommitment\", () => {\n  it(\"returns sha256 of the secret bytes\", () => {\n    // sha256 of the zero byte (0x00) — well-known constant\n    const zeroByte = Buffer.from([0x00]);\n    const expected =\n      \"6e340b9cffb37a989ca544e6bb780a2c78901d3fb33738768511a30617afa01d\";\n    expect(computeCommitment(zeroByte).toString(\"hex\")).toBe(expected);\n  });\n\n  it(\"matches the packages/fairness commitment algorithm\", () => {\n    // The fairness package computes sha256(hexToBytes(hexSeed)).\n    // Our backend computes sha256(secretBuffer).\n    // They must agree when given the same bytes.\n    const seedHex =\n      \"abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789\";\n    const seedBytes = Buffer.from(seedHex, \"hex\");\n\n    const backendCommitment = computeCommitment(seedBytes).toString(\"hex\");\n\n    // Independently compute using Node crypto for cross-check\n    const nodeCommitment = createHash(\"sha256\").update(seedBytes).digest(\"hex\");\n\n    expect(backendCommitment).toBe(nodeCommitment);\n  });\n\n  it(\"is deterministic\", () => {\n    const secret = Buffer.alloc(32, 0x42);\n    const a = computeCommitment(secret);\n    const b = computeCommitment(secret);\n    expect(a.equals(b)).toBe(true);\n  });\n\n  it(\"produces different commitments for different secrets\", () => {\n    const a = computeCommitment(Buffer.alloc(32, 0x01));\n    const b = computeCommitment(Buffer.alloc(32, 0x02));\n    expect(a.equals(b)).toBe(false);\n  });\n});\n\ndescribe(\"deriveMatchPda\", () => {\n  const creator = Keypair.generate().publicKey;\n  const programId = new PublicKey(\n    \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n  );\n\n  it(\"returns a PublicKey and bump seed\", () => {\n    const [pda, bump] = deriveMatchPda(creator, 0);\n    expect(pda).toBeInstanceOf(PublicKey);\n    expect(typeof bump).toBe(\"number\");\n    expect(bump).toBeGreaterThanOrEqual(0);\n    expect(bump).toBeLessThanOrEqual(255);\n  });\n\n  it(\"matches manual PDA derivation with seeds [match, creator, nonce_le]\", () => {\n    const nonce = 42;\n    const nonceBuf = Buffer.alloc(8);\n    nonceBuf.writeBigUInt64LE(BigInt(nonce));\n\n    const [expected] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n      programId,\n    );\n\n    const [actual] = deriveMatchPda(creator, nonce);\n    expect(actual.equals(expected)).toBe(true);\n  });\n\n  it(\"accepts bigint nonce\", () => {\n    const [a] = deriveMatchPda(creator, 100);\n    const [b] = deriveMatchPda(creator, 100n);\n    expect(a.equals(b)).toBe(true);\n  });\n\n  it(\"produces different PDAs for different nonces\", () => {\n    const [a] = deriveMatchPda(creator, 0);\n    const [b] = deriveMatchPda(creator, 1);\n    expect(a.equals(b)).toBe(false);\n  });\n\n  it(\"produces different PDAs for different creators\", () => {\n    const other = Keypair.generate().publicKey;\n    const [a] = deriveMatchPda(creator, 0);\n    const [b] = deriveMatchPda(other, 0);\n    expect(a.equals(b)).toBe(false);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":942,"cache_read_input_tokens":44384,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":942},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f4316b62-2257-4469-b202-66365945525c","uuid":"34944060-d9f8-43f1-830e-2cf65476ac80"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AwEVJau2DVjj27nkWBSnH8","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/fairness.test.ts"}]},"parent_tool_use_id":null,"session_id":"f4316b62-2257-4469-b202-66365945525c","uuid":"a15c9b7c-f46d-49a6-9863-5ca9de5ca521","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/fairness.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { createHash } from \"node:crypto\";\nimport { Keypair, PublicKey } from \"@solana/web3.js\";\nimport { generateSecret, computeCommitment, deriveMatchPda } from \"../fairness.js\";\n\ndescribe(\"generateSecret\", () => {\n  it(\"returns a 32-byte buffer\", () => {\n    const secret = generateSecret();\n    expect(Buffer.isBuffer(secret)).toBe(true);\n    expect(secret.length).toBe(32);\n  });\n\n  it(\"produces unique secrets on successive calls\", () => {\n    const a = generateSecret();\n    const b = generateSecret();\n    expect(a.equals(b)).toBe(false);\n  });\n});\n\ndescribe(\"computeCommitment\", () => {\n  it(\"returns sha256 of the secret bytes\", () => {\n    // sha256 of the zero byte (0x00) — well-known constant\n    const zeroByte = Buffer.from([0x00]);\n    const expected =\n      \"6e340b9cffb37a989ca544e6bb780a2c78901d3fb33738768511a30617afa01d\";\n    expect(computeCommitment(zeroByte).toString(\"hex\")).toBe(expected);\n  });\n\n  it(\"matches the packages/fairness commitment algorithm\", () => {\n    // The fairness package computes sha256(hexToBytes(hexSeed)).\n    // Our backend computes sha256(secretBuffer).\n    // They must agree when given the same bytes.\n    const seedHex =\n      \"abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789\";\n    const seedBytes = Buffer.from(seedHex, \"hex\");\n\n    const backendCommitment = computeCommitment(seedBytes).toString(\"hex\");\n\n    // Independently compute using Node crypto for cross-check\n    const nodeCommitment = createHash(\"sha256\").update(seedBytes).digest(\"hex\");\n\n    expect(backendCommitment).toBe(nodeCommitment);\n  });\n\n  it(\"is deterministic\", () => {\n    const secret = Buffer.alloc(32, 0x42);\n    const a = computeCommitment(secret);\n    const b = computeCommitment(secret);\n    expect(a.equals(b)).toBe(true);\n  });\n\n  it(\"produces different commitments for different secrets\", () => {\n    const a = computeCommitment(Buffer.alloc(32, 0x01));\n    const b = computeCommitment(Buffer.alloc(32, 0x02));\n    expect(a.equals(b)).toBe(false);\n  });\n});\n\ndescribe(\"deriveMatchPda\", () => {\n  const creator = Keypair.generate().publicKey;\n  const programId = new PublicKey(\n    \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n  );\n\n  it(\"returns a PublicKey and bump seed\", () => {\n    const [pda, bump] = deriveMatchPda(creator, 0);\n    expect(pda).toBeInstanceOf(PublicKey);\n    expect(typeof bump).toBe(\"number\");\n    expect(bump).toBeGreaterThanOrEqual(0);\n    expect(bump).toBeLessThanOrEqual(255);\n  });\n\n  it(\"matches manual PDA derivation with seeds [match, creator, nonce_le]\", () => {\n    const nonce = 42;\n    const nonceBuf = Buffer.alloc(8);\n    nonceBuf.writeBigUInt64LE(BigInt(nonce));\n\n    const [expected] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n      programId,\n    );\n\n    const [actual] = deriveMatchPda(creator, nonce);\n    expect(actual.equals(expected)).toBe(true);\n  });\n\n  it(\"accepts bigint nonce\", () => {\n    const [a] = deriveMatchPda(creator, 100);\n    const [b] = deriveMatchPda(creator, 100n);\n    expect(a.equals(b)).toBe(true);\n  });\n\n  it(\"produces different PDAs for different nonces\", () => {\n    const [a] = deriveMatchPda(creator, 0);\n    const [b] = deriveMatchPda(creator, 1);\n    expect(a.equals(b)).toBe(false);\n  });\n\n  it(\"produces different PDAs for different creators\", () => {\n    const other = Keypair.generate().publicKey;\n    const [a] = deriveMatchPda(creator, 0);\n    const [b] = deriveMatchPda(other, 0);\n    expect(a.equals(b)).toBe(false);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
