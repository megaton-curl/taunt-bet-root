{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FpJgqtMYmBzMFJ4WVrm7yL","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { Connection, PublicKey } from \"@solana/web3.js\";\n     3→import { loadConfig } from \"./config.js\";\n     4→import { createDb } from \"./db.js\";\n     5→import { createCoinflipRoutes } from \"./routes/create.js\";\n     6→import { createRoundsRoutes } from \"./routes/rounds.js\";\n     7→import { createHealthRoutes } from \"./routes/health.js\";\n     8→import { createAuthMiddleware } from \"./middleware/auth.js\";\n     9→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    10→import { createSettlementWorker } from \"./worker/settlement.js\";\n    11→import { settleMatch } from \"./worker/settle-tx.js\";\n    12→import { createRetrySettler } from \"./worker/retry.js\";\n    13→import { logger } from \"./logger.js\";\n    14→\n    15→const config = loadConfig();\n    16→const db = createDb(config.databaseUrl);\n    17→const connection = new Connection(config.rpcUrl);\n    18→\n    19→const app = new Hono();\n    20→\n    21→// Rate limiting — per-wallet and global limits on POST requests\n    22→app.use(\n    23→  \"/fairness/*\",\n    24→  createRateLimitMiddleware({\n    25→    perWallet: config.rateLimitPerWallet,\n    26→    global: config.rateLimitGlobal,\n    27→    windowMs: 60_000,\n    28→  }),\n    29→);\n    30→\n    31→// Auth middleware — verifies wallet Ed25519 signatures on POST requests\n    32→app.use(\n    33→  \"/fairness/*\",\n    34→  createAuthMiddleware({ clockSkewSeconds: config.authClockSkewSeconds }),\n    35→);\n    36→\n    37→// Coinflip fairness routes\n    38→app.route(\n    39→  \"/fairness/coinflip\",\n    40→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair }),\n    41→);\n    42→\n    43→// Round verification routes\n    44→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n    45→\n    46→// Start settlement worker with retry-aware settler\n    47→const entropyAccount = new PublicKey(config.entropyAccount);\n    48→const retrySettler = createRetrySettler({\n    49→  db,\n    50→  connection,\n    51→  settleMatch: (pda) =>\n    52→    settleMatch(\n    53→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n    54→      pda,\n    55→    ),\n    56→});\n    57→const worker = createSettlementWorker({\n    58→  db,\n    59→  connection,\n    60→  serverKey: config.serverKeypair.publicKey,\n    61→  pollIntervalMs: config.workerPollIntervalMs,\n    62→  onSettleReady: (pda) => retrySettler.attemptSettle(pda),\n    63→});\n    64→worker.start();\n    65→\n    66→// Health endpoint — wired after worker exists so we can query its status\n    67→app.route(\n    68→  \"/health\",\n    69→  createHealthRoutes({\n    70→    db,\n    71→    connection,\n    72→    serverKey: config.serverKeypair.publicKey,\n    73→    isWorkerRunning: () => worker.isRunning,\n    74→    minSolBalance: config.minSolBalance,\n    75→  }),\n    76→);\n    77→\n    78→const port = config.port;\n    79→logger.info(\"fairness-backend started\", { port });\n    80→\n    81→export default {\n    82→  port,\n    83→  fetch: app.fetch,\n    84→};\n    85→"}]},"parent_tool_use_id":null,"session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"55ebf6b2-3ae0-49d4-b94f-243404d701b7","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createRoundsRoutes } from \"./routes/rounds.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createAuthMiddleware } from \"./middleware/auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleMatch } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\nconst db = createDb(config.databaseUrl);\nconst connection = new Connection(config.rpcUrl);\n\nconst app = new Hono();\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/fairness/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Auth middleware — verifies wallet Ed25519 signatures on POST requests\napp.use(\n  \"/fairness/*\",\n  createAuthMiddleware({ clockSkewSeconds: config.authClockSkewSeconds }),\n);\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair }),\n);\n\n// Round verification routes\napp.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n\n// Start settlement worker with retry-aware settler\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleMatch: (pda) =>\n    settleMatch(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n      pda,\n    ),\n});\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: (pda) => retrySettler.attemptSettle(pda),\n});\nworker.start();\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    db,\n    connection,\n    serverKey: config.serverKeypair.publicKey,\n    isWorkerRunning: () => worker.isRunning,\n    minSolBalance: config.minSolBalance,\n  }),\n);\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", { port });\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":85,"startLine":1,"totalLines":85}}}
