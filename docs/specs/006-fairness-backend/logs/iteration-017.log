 PublicKey, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";","numLines":25,"startLine":1,"totalLines":380}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SNdK2Y4KaRpG8NLLHFDHKD","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BMNaCTKYxBXtRsEbkB2PFJ","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts","old_string":"import { Keypair, PublicKey, LAMPORTS_PER_SOL } from \"@solana/web3.js\";","new_string":"import { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":461,"cache_read_input_tokens":76891,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":461},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"306924a0-7431-4070-8c45-268a41e0d843"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BMNaCTKYxBXtRsEbkB2PFJ","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"826def74-e573-4bc9-b622-14e9d4bfeb17","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts","oldString":"import { Keypair, PublicKey, LAMPORTS_PER_SOL } from \"@solana/web3.js\";","newString":"import { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";","originalFile":"/**\n * HTTP endpoint tests — exercises the full middleware stack (rate limit + auth)\n * and route handlers for all endpoints:\n *\n * POST /fairness/coinflip/create:\n *   - 200 with valid auth\n *   - 401 with invalid signature\n *   - 401 with expired timestamp\n *   - 409 with duplicate nonce\n *   - 429 when rate limit exceeded\n *\n * GET /fairness/rounds/:pda:\n *   - 200 for known PDA\n *   - 404 for unknown PDA\n *\n * GET /health:\n *   - 200 with expected fields\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, PublicKey, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createAuthMiddleware } from \"../middleware/auth.js\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst TIER_IRON = 1;\nconst SIDE_HEADS = 0;\n\n// ---------------------------------------------------------------------------\n// Minimal mock Connection (only what routes + health need)\n// ---------------------------------------------------------------------------\n\nclass MockConnection {\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getBalance() {\n    return 1.5 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Auth helper\n// ---------------------------------------------------------------------------\n\nfunction signCreateRequest(\n  keypair: Keypair,\n  body: { wallet: string; tier: number; side: number; nonce: number; timestamp: number },\n): string {\n  const canonical = JSON.stringify({\n    wallet: body.wallet,\n    tier: body.tier,\n    side: body.side,\n    nonce: body.nonce,\n    timestamp: body.timestamp,\n  });\n  const messageBytes = new TextEncoder().encode(canonical);\n  const sigBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n  return bs58.encode(sigBytes);\n}\n\nfunction makeBody(wallet: string, overrides?: Partial<{ tier: number; side: number; nonce: number; timestamp: number }>) {\n  return {\n    wallet,\n    tier: overrides?.tier ?? TIER_IRON,\n    side: overrides?.side ?? SIDE_HEADS,\n    nonce: overrides?.nonce ?? Math.floor(Math.random() * 1_000_000),\n    timestamp: overrides?.timestamp ?? Math.floor(Date.now() / 1000),\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"HTTP endpoint tests\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    db = createDb(DATABASE_URL);\n    rawSql = postgres(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n    mockConn = new MockConnection();\n  });\n\n  // -----------------------------------------------------------------------\n  // Helper: build a fresh Hono app with full middleware stack\n  // -----------------------------------------------------------------------\n\n  function buildApp(opts?: { perWallet?: number; global?: number }) {\n    const app = new Hono();\n\n    app.use(\n      \"/fairness/*\",\n      createRateLimitMiddleware({\n        perWallet: opts?.perWallet ?? 10,\n        global: opts?.global ?? 100,\n        windowMs: 60_000,\n      }),\n    );\n\n    app.use(\n      \"/fairness/*\",\n      createAuthMiddleware({ clockSkewSeconds: 60 }),\n    );\n\n    app.route(\n      \"/fairness/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n\n    app.route(\n      \"/health\",\n      createHealthRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKey: serverKeypair.publicKey,\n        isWorkerRunning: () => true,\n        minSolBalance: 0.1,\n      }),\n    );\n\n    return app;\n  }\n\n  // -----------------------------------------------------------------------\n  // POST /fairness/coinflip/create\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /fairness/coinflip/create\", () => {\n    it(\"returns 200 with valid auth\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n      const signature = signCreateRequest(creatorKeypair, body);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature }),\n      });\n\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.transaction).toBeDefined();\n      expect(typeof json.transaction).toBe(\"string\");\n      expect(json.matchPda).toBeDefined();\n      expect(typeof json.matchPda).toBe(\"string\");\n      expect(json.commitment).toBeDefined();\n      expect(typeof json.commitment).toBe(\"string\");\n      // Commitment should be 64 hex chars (32 bytes)\n      expect((json.commitment as string).length).toBe(64);\n    });\n\n    it(\"returns 401 with invalid signature\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n      // Sign with a DIFFERENT keypair\n      const wrongKeypair = Keypair.generate();\n      const badSignature = signCreateRequest(wrongKeypair, body);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature: badSignature }),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toBeDefined();\n    });\n\n    it(\"returns 401 with expired timestamp\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      // Timestamp 120 seconds in the past (exceeds 60s clock skew)\n      const body = makeBody(wallet, { timestamp: Math.floor(Date.now() / 1000) - 120 });\n      const signature = signCreateRequest(creatorKeypair, body);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature }),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"expired\");\n    });\n\n    it(\"returns 409 with duplicate nonce\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const nonce = 42;\n\n      // First request — should succeed\n      const body1 = makeBody(wallet, { nonce });\n      const sig1 = signCreateRequest(creatorKeypair, body1);\n      const res1 = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body1, signature: sig1 }),\n      });\n      expect(res1.status).toBe(200);\n\n      // Second request with same nonce — should conflict\n      const body2 = makeBody(wallet, { nonce });\n      const sig2 = signCreateRequest(creatorKeypair, body2);\n      const res2 = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body2, signature: sig2 }),\n      });\n      expect(res2.status).toBe(409);\n      const json = (await res2.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"already exists\");\n    });\n\n    it(\"returns 429 when rate limit exceeded\", async () => {\n      // Create app with very low per-wallet limit\n      const app = buildApp({ perWallet: 2, global: 100 });\n      const wallet = creatorKeypair.publicKey.toBase58();\n\n      // Send 2 requests (within limit)\n      for (let i = 0; i < 2; i++) {\n        const body = makeBody(wallet, { nonce: 1000 + i });\n        const sig = signCreateRequest(creatorKeypair, body);\n        const res = await app.request(\"/fairness/coinflip/create\", {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ ...body, signature: sig }),\n        });\n        expect(res.status).toBe(200);\n      }\n\n      // Third request should be rate-limited\n      const body3 = makeBody(wallet, { nonce: 1002 });\n      const sig3 = signCreateRequest(creatorKeypair, body3);\n      const res3 = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body3, signature: sig3 }),\n      });\n      expect(res3.status).toBe(429);\n      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n      const json = (await res3.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"Too many\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /fairness/rounds/:pda\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /fairness/rounds/:pda\", () => {\n    it(\"returns 200 for known PDA\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n      const signature = signCreateRequest(creatorKeypair, body);\n\n      // Create a round first\n      const createRes = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature }),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { matchPda: string; commitment: string };\n\n      // Fetch the round\n      const roundRes = await app.request(`/fairness/rounds/${createJson.matchPda}`);\n      expect(roundRes.status).toBe(200);\n\n      const roundJson = (await roundRes.json()) as Record<string, unknown>;\n      expect(roundJson.pda).toBe(createJson.matchPda);\n      expect(roundJson.game).toBe(\"coinflip\");\n      expect(roundJson.phase).toBe(\"created\");\n      expect(roundJson.creator).toBe(wallet);\n      expect(roundJson.commitment).toBe(createJson.commitment);\n      expect(roundJson.tier).toBe(TIER_IRON);\n      expect(roundJson.side).toBe(SIDE_HEADS);\n      expect(roundJson.createdAt).toBeDefined();\n      expect(roundJson.updatedAt).toBeDefined();\n      // Unsettled: secret and verification should NOT be present\n      expect(roundJson.secret).toBeUndefined();\n      expect(roundJson.verification).toBeUndefined();\n    });\n\n    it(\"returns 404 for unknown PDA\", async () => {\n      const app = buildApp();\n      const unknownPda = Keypair.generate().publicKey.toBase58();\n      const res = await app.request(`/fairness/rounds/${unknownPda}`);\n      expect(res.status).toBe(404);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"not found\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /health\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /health\", () => {\n    it(\"returns 200 with expected fields\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/health\");\n      expect(res.status).toBe(200);\n\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.status).toBe(\"ok\");\n      expect(json.version).toBe(\"0.1.0\");\n      expect(json.serverKey).toBe(serverKeypair.publicKey.toBase58());\n      expect(typeof json.solBalance).toBe(\"number\");\n      expect(json.solBalance).toBe(1.5);\n      expect(json.dbConnected).toBe(true);\n      expect(json.workerRunning).toBe(true);\n      expect(typeof json.unsettledCount).toBe(\"number\");\n      expect(typeof json.oldestUnsettledAge).toBe(\"number\");\n    });\n\n    it(\"reflects unsettled round count\", async () => {\n      const app = buildApp();\n\n      // Create a round so there's an unsettled one\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n      const signature = signCreateRequest(creatorKeypair, body);\n      const createRes = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature }),\n      });\n      expect(createRes.status).toBe(200);\n\n      const healthRes = await app.request(\"/health\");\n      expect(healthRes.status).toBe(200);\n      const json = (await healthRes.json()) as Record<string, unknown>;\n      expect(json.unsettledCount).toBe(1);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":19,"oldLines":7,"newStart":19,"newLines":7,"lines":[" "," import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";"," import { Hono } from \"hono\";","-import { Keypair, PublicKey, LAMPORTS_PER_SOL } from \"@solana/web3.js\";","+import { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";"," import type { Connection } from \"@solana/web3.js\";"," import nacl from \"tweetnacl\";"," import bs58 from \"bs58\";"]}],"userModified":false,"replaceAll":false}}
