{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CkdNXvNo8geyYmdLsC6MN9","type":"tool_result","content":"     1→/**\n     2→ * Integration test: full create → join → settle lifecycle.\n     3→ *\n     4→ * Uses a mock Solana Connection to simulate on-chain state while exercising\n     5→ * the real HTTP endpoints, database, settlement worker, and retry logic\n     6→ * end-to-end.\n     7→ */\n     8→\n     9→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    10→import { Hono } from \"hono\";\n    11→import {\n    12→  Keypair,\n    13→  PublicKey,\n    14→  SystemProgram,\n    15→  LAMPORTS_PER_SOL,\n    16→} from \"@solana/web3.js\";\n    17→import type { Connection } from \"@solana/web3.js\";\n    18→import nacl from \"tweetnacl\";\n    19→import bs58 from \"bs58\";\n    20→import postgres from \"postgres\";\n    21→import { createDb, type Db } from \"../db.js\";\n    22→import { createCoinflipRoutes } from \"../routes/create.js\";\n    23→import { createRoundsRoutes } from \"../routes/rounds.js\";\n    24→import { createAuthMiddleware } from \"../middleware/auth.js\";\n    25→import { createSettlementWorker } from \"../worker/settlement.js\";\n    26→import { settleMatch } from \"../worker/settle-tx.js\";\n    27→import { createRetrySettler } from \"../worker/retry.js\";\n    28→import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n    29→\n    30→// ---------------------------------------------------------------------------\n    31→// Constants\n    32→// ---------------------------------------------------------------------------\n    33→\n    34→const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    35→const TIER_IRON = 1;\n    36→const TIER_IRON_AMOUNT = 5_000_000n;\n    37→const SIDE_HEADS = 0;\n    38→const PHASE_LOCKED = 1;\n    39→\n    40→// ---------------------------------------------------------------------------\n    41→// Mock Connection\n    42→// ---------------------------------------------------------------------------\n    43→\n    44→/**\n    45→ * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n    46→ * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n    47→ * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n    48→ */\n    49→class MockConnection {\n    50→  private _slot = 200;\n    51→  private _accounts = new Map<\n    52→    string,\n    53→    {\n    54→      data: Buffer;\n    55→      lamports: number;\n    56→      owner: PublicKey;\n    57→      executable: boolean;\n    58→    }\n    59→  >();\n    60→  lastRawTx: Buffer | null = null;\n    61→\n    62→  set slot(s: number) {\n    63→    this._slot = s;\n    64→  }\n    65→  get slot() {\n    66→    return this._slot;\n    67→  }\n    68→\n    69→  setAccount(\n    70→    pubkey: PublicKey,\n    71→    data: Buffer,\n    72→    opts?: { lamports?: number; owner?: PublicKey },\n    73→  ) {\n    74→    this._accounts.set(pubkey.toBase58(), {\n    75→      data,\n    76→      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n    77→      owner: opts?.owner ?? SystemProgram.programId,\n    78→      executable: false,\n    79→    });\n    80→  }\n    81→\n    82→  removeAccount(pubkey: PublicKey) {\n    83→    this._accounts.delete(pubkey.toBase58());\n    84→  }\n    85→\n    86→  async getLatestBlockhash() {\n    87→    return {\n    88→      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n    89→      lastValidBlockHeight: 999_999,\n    90→    };\n    91→  }\n    92→\n    93→  async getSlot() {\n    94→    return this._slot;\n    95→  }\n    96→\n    97→  async getAccountInfo(pubkey: PublicKey) {\n    98→    const acc = this._accounts.get(pubkey.toBase58());\n    99→    if (!acc) return null;\n   100→    return { ...acc, rentEpoch: 0 };\n   101→  }\n   102→\n   103→  async getProgramAccounts(\n   104→    programId: PublicKey,\n   105→    config?: {\n   106→      filters?: Array<\n   107→        | { dataSize: number }\n   108→        | { memcmp: { offset: number; bytes: string } }\n   109→      >;\n   110→    },\n   111→  ) {\n   112→    const results: Array<{\n   113→      pubkey: PublicKey;\n   114→      account: {\n   115→        data: Buffer;\n   116→        lamports: number;\n   117→        owner: PublicKey;\n   118→        executable: boolean;\n   119→        rentEpoch: number;\n   120→      };\n   121→    }> = [];\n   122→\n   123→    for (const [key, acc] of this._accounts) {\n   124→      if (!acc.owner.equals(programId)) continue;\n   125→\n   126→      let matches = true;\n   127→      if (config?.filters) {\n   128→        for (const filter of config.filters) {\n   129→          if (\"dataSize\" in filter) {\n   130→            if (acc.data.length !== filter.dataSize) {\n   131→              matches = false;\n   132→              break;\n   133→            }\n   134→          }\n   135→          if (\"memcmp\" in filter) {\n   136→            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n   137→            const actual = acc.data.subarray(\n   138→              filter.memcmp.offset,\n   139→              filter.memcmp.offset + expected.length,\n   140→            );\n   141→            if (Buffer.compare(actual, expected) !== 0) {\n   142→              matches = false;\n   143→              break;\n   144→            }\n   145→          }\n   146→        }\n   147→      }\n   148→\n   149→      if (matches) {\n   150→        results.push({\n   151→          pubkey: new PublicKey(key),\n   152→          account: { ...acc, rentEpoch: 0 },\n   153→        });\n   154→      }\n   155→    }\n   156→    return results;\n   157→  }\n   158→\n   159→  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n   160→    this.lastRawTx = Buffer.from(rawTx);\n   161→    // Return a deterministic fake signature\n   162→    return bs58.encode(Buffer.alloc(64, 0x01));\n   163→  }\n   164→\n   165→  async confirmTransaction() {\n   166→    return { value: { err: null }, context: { slot: this._slot } };\n   167→  }\n   168→\n   169→  async getBalance() {\n   170→    return 2 * LAMPORTS_PER_SOL;\n   171→  }\n   172→}\n   173→\n   174→// ---------------------------------------------------------------------------\n   175→// Account data builders\n   176→// ---------------------------------------------------------------------------\n   177→\n   178→function buildMatchAccountData(params: {\n   179→  creator: PublicKey;\n   180→  opponent: PublicKey;\n   181→  server: PublicKey;\n   182→  tier: number;\n   183→  entryAmount: bigint;\n   184→  creatorSide: number;\n   185→  phase: number;\n   186→  commitment: Buffer;\n   187→  algorithmVer: number;\n   188→  targetSlot: bigint;\n   189→  resolveDeadline: bigint;\n   190→  nonce: bigint;\n   191→}): Buffer {\n   192→  const data = Buffer.alloc(246);\n   193→\n   194→  // Anchor discriminator (8 bytes) — arbitrary, not validated by backend\n   195→  data.fill(0xaa, 0, 8);\n   196→\n   197→  params.creator.toBuffer().copy(data, 8); // offset 8\n   198→  params.opponent.toBuffer().copy(data, 40); // offset 40\n   199→  params.server.toBuffer().copy(data, 72); // offset 72\n   200→  data.writeUInt8(params.tier, 104); // offset 104\n   201→  data.writeBigUInt64LE(params.entryAmount, 105); // offset 105\n   202→  data.writeUInt8(params.creatorSide, 113); // offset 113\n   203→  data.writeUInt8(params.phase, 114); // offset 114\n   204→  params.commitment.copy(data, 115); // offset 115\n   205→  data.writeUInt8(params.algorithmVer, 147); // offset 147\n   206→  data.writeBigUInt64LE(params.targetSlot, 148); // offset 148\n   207→  data.writeBigInt64LE(params.resolveDeadline, 156); // offset 156\n   208→  // result_hash (offset 164, 32 bytes) — zeroed\n   209→  // result (offset 196, 1 byte) — 0\n   210→  // winner (offset 197, 32 bytes) — zeroed\n   211→  data.writeBigInt64LE(\n   212→    BigInt(Math.floor(Date.now() / 1000)),\n   213→    229,\n   214→  ); // created_at offset 229\n   215→  data.writeBigUInt64LE(params.nonce, 237); // nonce offset 237\n   216→  // bump (offset 245) — 0\n   217→\n   218→  return data;\n   219→}\n   220→\n   221→function buildConfigAccountData(treasury: PublicKey): Buffer {\n   222→  // CoinflipConfig: 8 disc + 32 authority + 32 treasury + 1 paused + 1 bump = 74\n   223→  const data = Buffer.alloc(74);\n   224→  // authority — just fill with zeros (not used by settle)\n   225→  treasury.toBuffer().copy(data, 40); // offset 40\n   226→  return data;\n   227→}\n   228→\n   229→// ---------------------------------------------------------------------------\n   230→// Auth helper — sign a create request payload\n   231→// ---------------------------------------------------------------------------\n   232→\n   233→function signCreateRequest(\n   234→  keypair: Keypair,\n   235→  body: {\n   236→    wallet: string;\n   237→    tier: number;\n   238→    side: number;\n   239→    nonce: number;\n   240→    timestamp: number;\n   241→  },\n   242→): string {\n   243→  const canonical = JSON.stringify({\n   244→    wallet: body.wallet,\n   245→    tier: body.tier,\n   246→    side: body.side,\n   247→    nonce: body.nonce,\n   248→    timestamp: body.timestamp,\n   249→  });\n   250→  const messageBytes = new TextEncoder().encode(canonical);\n   251→  const sigBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n   252→  return bs58.encode(sigBytes);\n   253→}\n   254→\n   255→// ---------------------------------------------------------------------------\n   256→// Test suite\n   257→// ---------------------------------------------------------------------------\n   258→\n   259→describe(\"Integration: create → join → settle lifecycle\", () => {\n   260→  let db: Db;\n   261→  let rawSql: ReturnType<typeof postgres>;\n   262→  let mockConn: MockConnection;\n   263→  let app: Hono;\n   264→\n   265→  const serverKeypair = Keypair.generate();\n   266→  const creatorKeypair = Keypair.generate();\n   267→  const opponentKeypair = Keypair.generate();\n   268→  const treasuryKeypair = Keypair.generate();\n   269→  const entropyKeypair = Keypair.generate();\n   270→  const entropyAccount = entropyKeypair.publicKey;\n   271→\n   272→  const entropyData = Buffer.alloc(32);\n   273→  entropyData[0] = 0xab;\n   274→  entropyData[1] = 0xcd;\n   275→  entropyData[15] = 0x42;\n   276→\n   277→  beforeAll(async () => {\n   278→    db = createDb(DATABASE_URL);\n   279→    rawSql = postgres(DATABASE_URL);\n   280→  });\n   281→\n   282→  afterAll(async () => {\n   283→    await db.close();\n   284→    await rawSql.end();\n   285→  });\n   286→\n   287→  beforeEach(async () => {\n   288→    // Clean tables for isolation\n   289→    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n   290→\n   291→    // Fresh mock Connection\n   292→    mockConn = new MockConnection();\n   293→\n   294→    // Pre-populate mock with entropy and config accounts\n   295→    mockConn.setAccount(entropyAccount, entropyData);\n   296→\n   297→    const [configPda] = PublicKey.findProgramAddressSync(\n   298→      [Buffer.from(\"coinflip_config\")],\n   299→      COINFLIP_PROGRAM_ID,\n   300→    );\n   301→    mockConn.setAccount(\n   302→      configPda,\n   303→      buildConfigAccountData(treasuryKeypair.publicKey),\n   304→      { owner: COINFLIP_PROGRAM_ID },\n   305→    );\n   306→\n   307→    // Build the Hono app (no rate limiting for tests)\n   308→    app = new Hono();\n   309→\n   310→    app.use(\n   311→      \"/fairness/*\",\n   312→      createAuthMiddleware({ clockSkewSeconds: 120 }),\n   313→    );\n   314→\n   315→    app.route(\n   316→      \"/fairness/coinflip\",\n   317→      createCoinflipRoutes({\n   318→        db,\n   319→        connection: mockConn as unknown as Connection,\n   320→        serverKeypair,\n   321→      }),\n   322→    );\n   323→\n   324→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   325→  });\n   326→\n   327→  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n   328→    const nonce = 42;\n   329→    const wallet = creatorKeypair.publicKey.toBase58();\n   330→    const timestamp = Math.floor(Date.now() / 1000);\n   331→\n   332→    // ------------------------------------------------------------------\n   333→    // 1. POST /fairness/coinflip/create\n   334→    // ------------------------------------------------------------------\n   335→    const body = { wallet, tier: TIER_IRON, side: SIDE_HEADS, nonce, timestamp };\n   336→    const signature = signCreateRequest(creatorKeypair, body);\n   337→\n   338→    const createRes = await app.request(\"/fairness/coinflip/create\", {\n   339→      method: \"POST\",\n   340→      headers: { \"Content-Type\": \"application/json\" },\n   341→      body: JSON.stringify({ ...body, signature }),\n   342→    });\n   343→\n   344→    expect(createRes.status).toBe(200);\n   345→    const createJson = (await createRes.json()) as {\n   346→      transaction: string;\n   347→      matchPda: string;\n   348→      commitment: string;\n   349→    };\n   350→    expect(createJson.transaction).toBeDefined();\n   351→    expect(createJson.matchPda).toBeDefined();\n   352→    expect(createJson.commitment).toBeDefined();\n   353→\n   354→    const matchPda = createJson.matchPda;\n   355→    const commitmentHex = createJson.commitment;\n   356→    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n   357→\n   358→    // ------------------------------------------------------------------\n   359→    // 2. Verify DB state — round in \"created\" phase\n   360→    // ------------------------------------------------------------------\n   361→    const round = await db.getRoundByPda(matchPda);\n   362→    expect(round).toBeDefined();\n   363→    expect(round!.phase).toBe(\"created\");\n   364→    expect(round!.game).toBe(\"coinflip\");\n   365→    expect(round!.creator).toBe(wallet);\n   366→    expect(round!.tier).toBe(TIER_IRON);\n   367→    expect(round!.side).toBe(SIDE_HEADS);\n   368→    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n   369→    expect(round!.secret).toBeDefined();\n   370→    expect(round!.secret.length).toBe(32);\n   371→\n   372→    // Verify operator event was logged\n   373→    const events =\n   374→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   375→    expect(events.length).toBe(1);\n   376→    expect(events[0]!.event_type).toBe(\"secret_generated\");\n   377→\n   378→    // ------------------------------------------------------------------\n   379→    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n   380→    // ------------------------------------------------------------------\n   381→    const matchPubkey = new PublicKey(matchPda);\n   382→    const targetSlot = 150n;\n   383→    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n   384→\n   385→    const matchAccountData = buildMatchAccountData({\n   386→      creator: creatorKeypair.publicKey,\n   387→      opponent: opponentKeypair.publicKey,\n   388→      server: serverKeypair.publicKey,\n   389→      tier: TIER_IRON,\n   390→      entryAmount: TIER_IRON_AMOUNT,\n   391→      creatorSide: SIDE_HEADS,\n   392→      phase: PHASE_LOCKED,\n   393→      commitment: commitmentBuf,\n   394→      algorithmVer: 1,\n   395→      targetSlot,\n   396→      resolveDeadline,\n   397→      nonce: BigInt(nonce),\n   398→    });\n   399→\n   400→    mockConn.setAccount(matchPubkey, matchAccountData, {\n   401→      owner: COINFLIP_PROGRAM_ID,\n   402→    });\n   403→\n   404→    // Set current slot past target_slot so settlement triggers immediately\n   405→    mockConn.slot = 200;\n   406→\n   407→    // ------------------------------------------------------------------\n   408→    // 4. Create worker + retry settler, trigger poll\n   409→    // ------------------------------------------------------------------\n   410→    let settlePromise: Promise<void> | null = null;\n   411→\n   412→    const retrySettler = createRetrySettler({\n   413→      db,\n   414→      connection: mockConn as unknown as Connection,\n   415→      settleMatch: (pda) =>\n   416→        settleMatch(\n   417→          {\n   418→            db,\n   419→            connection: mockConn as unknown as Connection,\n   420→            serverKeypair,\n   421→            entropyAccount,\n   422→          },\n   423→          pda,\n   424→        ),\n   425→    });\n   426→\n   427→    const worker = createSettlementWorker({\n   428→      db,\n   429→      connection: mockConn as unknown as Connection,\n   430→      serverKey: serverKeypair.publicKey,\n   431→      pollIntervalMs: 60_000, // won't auto-poll\n   432→      onSettleReady: (pda) => {\n   433→        settlePromise = retrySettler.attemptSettle(pda);\n   434→        return settlePromise;\n   435→      },\n   436→    });\n   437→\n   438→    // Single poll cycle — should discover locked match and settle it\n   439→    await worker.poll();\n   440→    if (settlePromise) await settlePromise;\n   441→\n   442→    // ------------------------------------------------------------------\n   443→    // 5. Verify DB updated to \"settled\" with result data\n   444→    // ------------------------------------------------------------------\n   445→    const settled = await db.getRoundByPda(matchPda);\n   446→    expect(settled).toBeDefined();\n   447→    expect(settled!.phase).toBe(\"settled\");\n   448→    expect(settled!.settle_tx).toBeDefined();\n   449→    expect(settled!.result_hash).toBeDefined();\n   450→    expect(settled!.result_hash!.length).toBe(32);\n   451→    expect(settled!.result_side).toBeDefined();\n   452→    expect([0, 1]).toContain(settled!.result_side);\n   453→    expect(settled!.winner).toBeDefined();\n   454→\n   455→    // Winner should be one of the two players\n   456→    expect([\n   457→      creatorKeypair.publicKey.toBase58(),\n   458→      opponentKeypair.publicKey.toBase58(),\n   459→    ]).toContain(settled!.winner);\n   460→\n   461→    // Verify operator events trail\n   462→    const allEvents =\n   463→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   464→    const eventTypes = allEvents.map(\n   465→      (e) => (e as Record<string, unknown>).event_type,\n   466→    );\n   467→    expect(eventTypes).toContain(\"secret_generated\");\n   468→    expect(eventTypes).toContain(\"match_detected\");\n   469→    expect(eventTypes).toContain(\"settle_submitted\");\n   470→    expect(eventTypes).toContain(\"settle_confirmed\");\n   471→\n   472→    // ------------------------------------------------------------------\n   473→    // 6. GET /fairness/rounds/:pda — verify response includes secret\n   474→    // ------------------------------------------------------------------\n   475→    const roundsRes = await app.request(`/fairness/rounds/${matchPda}`);\n   476→    expect(roundsRes.status).toBe(200);\n   477→\n   478→    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n   479→    expect(roundsJson.pda).toBe(matchPda);\n   480→    expect(roundsJson.phase).toBe(\"settled\");\n   481→    expect(roundsJson.game).toBe(\"coinflip\");\n   482→    expect(roundsJson.creator).toBe(wallet);\n   483→    expect(roundsJson.commitment).toBe(commitmentHex);\n   484→\n   485→    // Settled round should include secret + verification payload\n   486→    expect(roundsJson.secret).toBeDefined();\n   487→    expect(typeof roundsJson.secret).toBe(\"string\");\n   488→    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n   489→    expect(roundsJson.resultHash).toBeDefined();\n   490→    expect(roundsJson.resultSide).toBeDefined();\n   491→    expect(roundsJson.winner).toBeDefined();\n   492→    expect(roundsJson.settleTx).toBeDefined();\n   493→\n   494→    // Verification object\n   495→    const verification = roundsJson.verification as Record<string, string>;\n   496→    expect(verification).toBeDefined();\n   497→    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n   498→    expect(verification.resultFormula).toContain(\"sha256(secret\");\n   499→    expect(verification.entropySource).toContain(\"SlotHashes\");\n   500→  });\n   501→\n   502→  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n   503→    const unknownPda = Keypair.generate().publicKey.toBase58();\n   504→    const res = await app.request(`/fairness/rounds/${unknownPda}`);\n   505→    expect(res.status).toBe(404);\n   506→  });\n   507→\n   508→  it(\"unsettled round does not expose secret\", async () => {\n   509→    const nonce = 99;\n   510→    const wallet = creatorKeypair.publicKey.toBase58();\n   511→    const timestamp = Math.floor(Date.now() / 1000);\n   512→\n   513→    const body = { wallet, tier: TIER_IRON, side: SIDE_HEADS, nonce, timestamp };\n   514→    const signature = signCreateRequest(creatorKeypair, body);\n   515→\n   516→    const res = await app.request(\"/fairness/coinflip/create\", {\n   517→      method: \"POST\",\n   518→      headers: { \"Content-Type\": \"application/json\" },\n   519→      body: JSON.stringify({ ...body, signature }),\n   520→    });\n   521→    expect(res.status).toBe(200);\n   522→    const json = (await res.json()) as { matchPda: string };\n   523→\n   524→    // GET the unsettled round\n   525→    const roundRes = await app.request(`/fairness/rounds/${json.matchPda}`);\n   526→    expect(roundRes.status).toBe(200);\n   527→    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n   528→    expect(roundJson.phase).toBe(\"created\");\n   529→    expect(roundJson.secret).toBeUndefined();\n   530→    expect(roundJson.resultHash).toBeUndefined();\n   531→    expect(roundJson.verification).toBeUndefined();\n   532→  });\n   533→\n   534→  it(\"duplicate nonce returns 409\", async () => {\n   535→    const nonce = 7;\n   536→    const wallet = creatorKeypair.publicKey.toBase58();\n   537→    const timestamp = Math.floor(Date.now() / 1000);\n   538→\n   539→    const body = { wallet, tier: TIER_IRON, side: SIDE_HEADS, nonce, timestamp };\n   540→    const signature = signCreateRequest(creatorKeypair, body);\n   541→    const payload = JSON.stringify({ ...body, signature });\n   542→\n   543→    // First request succeeds\n   544→    const res1 = await app.request(\"/fairness/coinflip/create\", {\n   545→      method: \"POST\",\n   546→      headers: { \"Content-Type\": \"application/json\" },\n   547→      body: payload,\n   548→    });\n   549→    expect(res1.status).toBe(200);\n   550→\n   551→    // Second request with same nonce → 409\n   552→    const timestamp2 = Math.floor(Date.now() / 1000);\n   553→    const body2 = { wallet, tier: TIER_IRON, side: SIDE_HEADS, nonce, timestamp: timestamp2 };\n   554→    const signature2 = signCreateRequest(creatorKeypair, body2);\n   555→    const res2 = await app.request(\"/fairness/coinflip/create\", {\n   556→      method: \"POST\",\n   557→      headers: { \"Content-Type\": \"application/json\" },\n   558→      body: JSON.stringify({ ...body2, signature: signature2 }),\n   559→    });\n   560→    expect(res2.status).toBe(409);\n   561→  });\n   562→});\n   563→"}]},"parent_tool_use_id":null,"session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"88b1e73d-d0e0-441c-9336-cc5a361494e8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/integration.test.ts","content":"/**\n * Integration test: full create → join → settle lifecycle.\n *\n * Uses a mock Solana Connection to simulate on-chain state while exercising\n * the real HTTP endpoints, database, settlement worker, and retry logic\n * end-to-end.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createAuthMiddleware } from \"../middleware/auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst TIER_IRON = 1;\nconst TIER_IRON_AMOUNT = 5_000_000n;\nconst SIDE_HEADS = 0;\nconst PHASE_LOCKED = 1;\n\n// ---------------------------------------------------------------------------\n// Mock Connection\n// ---------------------------------------------------------------------------\n\n/**\n * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n */\nclass MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getSlot() {\n    return this._slot;\n  }\n\n  async getAccountInfo(pubkey: PublicKey) {\n    const acc = this._accounts.get(pubkey.toBase58());\n    if (!acc) return null;\n    return { ...acc, rentEpoch: 0 };\n  }\n\n  async getProgramAccounts(\n    programId: PublicKey,\n    config?: {\n      filters?: Array<\n        | { dataSize: number }\n        | { memcmp: { offset: number; bytes: string } }\n      >;\n    },\n  ) {\n    const results: Array<{\n      pubkey: PublicKey;\n      account: {\n        data: Buffer;\n        lamports: number;\n        owner: PublicKey;\n        executable: boolean;\n        rentEpoch: number;\n      };\n    }> = [];\n\n    for (const [key, acc] of this._accounts) {\n      if (!acc.owner.equals(programId)) continue;\n\n      let matches = true;\n      if (config?.filters) {\n        for (const filter of config.filters) {\n          if (\"dataSize\" in filter) {\n            if (acc.data.length !== filter.dataSize) {\n              matches = false;\n              break;\n            }\n          }\n          if (\"memcmp\" in filter) {\n            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n            const actual = acc.data.subarray(\n              filter.memcmp.offset,\n              filter.memcmp.offset + expected.length,\n            );\n            if (Buffer.compare(actual, expected) !== 0) {\n              matches = false;\n              break;\n            }\n          }\n        }\n      }\n\n      if (matches) {\n        results.push({\n          pubkey: new PublicKey(key),\n          account: { ...acc, rentEpoch: 0 },\n        });\n      }\n    }\n    return results;\n  }\n\n  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n    this.lastRawTx = Buffer.from(rawTx);\n    // Return a deterministic fake signature\n    return bs58.encode(Buffer.alloc(64, 0x01));\n  }\n\n  async confirmTransaction() {\n    return { value: { err: null }, context: { slot: this._slot } };\n  }\n\n  async getBalance() {\n    return 2 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Account data builders\n// ---------------------------------------------------------------------------\n\nfunction buildMatchAccountData(params: {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  tier: number;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: Buffer;\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  nonce: bigint;\n}): Buffer {\n  const data = Buffer.alloc(246);\n\n  // Anchor discriminator (8 bytes) — arbitrary, not validated by backend\n  data.fill(0xaa, 0, 8);\n\n  params.creator.toBuffer().copy(data, 8); // offset 8\n  params.opponent.toBuffer().copy(data, 40); // offset 40\n  params.server.toBuffer().copy(data, 72); // offset 72\n  data.writeUInt8(params.tier, 104); // offset 104\n  data.writeBigUInt64LE(params.entryAmount, 105); // offset 105\n  data.writeUInt8(params.creatorSide, 113); // offset 113\n  data.writeUInt8(params.phase, 114); // offset 114\n  params.commitment.copy(data, 115); // offset 115\n  data.writeUInt8(params.algorithmVer, 147); // offset 147\n  data.writeBigUInt64LE(params.targetSlot, 148); // offset 148\n  data.writeBigInt64LE(params.resolveDeadline, 156); // offset 156\n  // result_hash (offset 164, 32 bytes) — zeroed\n  // result (offset 196, 1 byte) — 0\n  // winner (offset 197, 32 bytes) — zeroed\n  data.writeBigInt64LE(\n    BigInt(Math.floor(Date.now() / 1000)),\n    229,\n  ); // created_at offset 229\n  data.writeBigUInt64LE(params.nonce, 237); // nonce offset 237\n  // bump (offset 245) — 0\n\n  return data;\n}\n\nfunction buildConfigAccountData(treasury: PublicKey): Buffer {\n  // CoinflipConfig: 8 disc + 32 authority + 32 treasury + 1 paused + 1 bump = 74\n  const data = Buffer.alloc(74);\n  // authority — just fill with zeros (not used by settle)\n  treasury.toBuffer().copy(data, 40); // offset 40\n  return data;\n}\n\n// ---------------------------------------------------------------------------\n// Auth helper — sign a create request payload\n// ---------------------------------------------------------------------------\n\nfunction signCreateRequest(\n  keypair: Keypair,\n  body: {\n    wallet: string;\n    tier: number;\n    side: number;\n    nonce: number;\n    timestamp: number;\n  },\n): string {\n  const canonical = JSON.stringify({\n    wallet: body.wallet,\n    tier: body.tier,\n    side: body.side,\n    nonce: body.nonce,\n    timestamp: body.timestamp,\n  });\n  const messageBytes = new TextEncoder().encode(canonical);\n  const sigBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n  return bs58.encode(sigBytes);\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Integration: create → join → settle lifecycle\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    db = createDb(DATABASE_URL);\n    rawSql = postgres(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean tables for isolation\n    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n\n    // Fresh mock Connection\n    mockConn = new MockConnection();\n\n    // Pre-populate mock with entropy and config accounts\n    mockConn.setAccount(entropyAccount, entropyData);\n\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"coinflip_config\")],\n      COINFLIP_PROGRAM_ID,\n    );\n    mockConn.setAccount(\n      configPda,\n      buildConfigAccountData(treasuryKeypair.publicKey),\n      { owner: COINFLIP_PROGRAM_ID },\n    );\n\n    // Build the Hono app (no rate limiting for tests)\n    app = new Hono();\n\n    app.use(\n      \"/fairness/*\",\n      createAuthMiddleware({ clockSkewSeconds: 120 }),\n    );\n\n    app.route(\n      \"/fairness/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n  });\n\n  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n    const nonce = 42;\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const timestamp = Math.floor(Date.now() / 1000);\n\n    // ------------------------------------------------------------------\n    // 1. POST /fairness/coinflip/create\n    // ------------------------------------------------------------------\n    const body = { wallet, tier: TIER_IRON, side: SIDE_HEADS, nonce, timestamp };\n    const signature = signCreateRequest(creatorKeypair, body);\n\n    const createRes = await app.request(\"/fairness/coinflip/create\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ ...body, signature }),\n    });\n\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      transaction: string;\n      matchPda: string;\n      commitment: string;\n    };\n    expect(createJson.transaction).toBeDefined();\n    expect(createJson.matchPda).toBeDefined();\n    expect(createJson.commitment).toBeDefined();\n\n    const matchPda = createJson.matchPda;\n    const commitmentHex = createJson.commitment;\n    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n\n    // ------------------------------------------------------------------\n    // 2. Verify DB state — round in \"created\" phase\n    // ------------------------------------------------------------------\n    const round = await db.getRoundByPda(matchPda);\n    expect(round).toBeDefined();\n    expect(round!.phase).toBe(\"created\");\n    expect(round!.game).toBe(\"coinflip\");\n    expect(round!.creator).toBe(wallet);\n    expect(round!.tier).toBe(TIER_IRON);\n    expect(round!.side).toBe(SIDE_HEADS);\n    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n    expect(round!.secret).toBeDefined();\n    expect(round!.secret.length).toBe(32);\n\n    // Verify operator event was logged\n    const events =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n    expect(events.length).toBe(1);\n    expect(events[0]!.event_type).toBe(\"secret_generated\");\n\n    // ------------------------------------------------------------------\n    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n    // ------------------------------------------------------------------\n    const matchPubkey = new PublicKey(matchPda);\n    const targetSlot = 150n;\n    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n\n    const matchAccountData = buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      tier: TIER_IRON,\n      entryAmount: TIER_IRON_AMOUNT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot,\n      resolveDeadline,\n      nonce: BigInt(nonce),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n\n    // Set current slot past target_slot so settlement triggers immediately\n    mockConn.slot = 200;\n\n    // ------------------------------------------------------------------\n    // 4. Create worker + retry settler, trigger poll\n    // ------------------------------------------------------------------\n    let settlePromise: Promise<void> | null = null;\n\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleMatch: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000, // won't auto-poll\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    // Single poll cycle — should discover locked match and settle it\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    // ------------------------------------------------------------------\n    // 5. Verify DB updated to \"settled\" with result data\n    // ------------------------------------------------------------------\n    const settled = await db.getRoundByPda(matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n    expect(settled!.settle_tx).toBeDefined();\n    expect(settled!.result_hash).toBeDefined();\n    expect(settled!.result_hash!.length).toBe(32);\n    expect(settled!.result_side).toBeDefined();\n    expect([0, 1]).toContain(settled!.result_side);\n    expect(settled!.winner).toBeDefined();\n\n    // Winner should be one of the two players\n    expect([\n      creatorKeypair.publicKey.toBase58(),\n      opponentKeypair.publicKey.toBase58(),\n    ]).toContain(settled!.winner);\n\n    // Verify operator events trail\n    const allEvents =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n    const eventTypes = allEvents.map(\n      (e) => (e as Record<string, unknown>).event_type,\n    );\n    expect(eventTypes).toContain(\"secret_generated\");\n    expect(eventTypes).toContain(\"match_detected\");\n    expect(eventTypes).toContain(\"settle_submitted\");\n    expect(eventTypes).toContain(\"settle_confirmed\");\n\n    // ------------------------------------------------------------------\n    // 6. GET /fairness/rounds/:pda — verify response includes secret\n    // ------------------------------------------------------------------\n    const roundsRes = await app.request(`/fairness/rounds/${matchPda}`);\n    expect(roundsRes.status).toBe(200);\n\n    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n    expect(roundsJson.pda).toBe(matchPda);\n    expect(roundsJson.phase).toBe(\"settled\");\n    expect(roundsJson.game).toBe(\"coinflip\");\n    expect(roundsJson.creator).toBe(wallet);\n    expect(roundsJson.commitment).toBe(commitmentHex);\n\n    // Settled round should include secret + verification payload\n    expect(roundsJson.secret).toBeDefined();\n    expect(typeof roundsJson.secret).toBe(\"string\");\n    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n    expect(roundsJson.resultHash).toBeDefined();\n    expect(roundsJson.resultSide).toBeDefined();\n    expect(roundsJson.winner).toBeDefined();\n    expect(roundsJson.settleTx).toBeDefined();\n\n    // Verification object\n    const verification = roundsJson.verification as Record<string, string>;\n    expect(verification).toBeDefined();\n    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n    expect(verification.resultFormula).toContain(\"sha256(secret\");\n    expect(verification.entropySource).toContain(\"SlotHashes\");\n  });\n\n  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n    const unknownPda = Keypair.generate().publicKey.toBase58();\n    const res = await app.request(`/fairness/rounds/${unknownPda}`);\n    expect(res.status).toBe(404);\n  });\n\n  it(\"unsettled round does not expose secret\", async () => {\n    const nonce = 99;\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const timestamp = Math.floor(Date.now() / 1000);\n\n    const body = { wallet, tier: TIER_IRON, side: SIDE_HEADS, nonce, timestamp };\n    const signature = signCreateRequest(creatorKeypair, body);\n\n    const res = await app.request(\"/fairness/coinflip/create\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ ...body, signature }),\n    });\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { matchPda: string };\n\n    // GET the unsettled round\n    const roundRes = await app.request(`/fairness/rounds/${json.matchPda}`);\n    expect(roundRes.status).toBe(200);\n    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n    expect(roundJson.phase).toBe(\"created\");\n    expect(roundJson.secret).toBeUndefined();\n    expect(roundJson.resultHash).toBeUndefined();\n    expect(roundJson.verification).toBeUndefined();\n  });\n\n  it(\"duplicate nonce returns 409\", async () => {\n    const nonce = 7;\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const timestamp = Math.floor(Date.now() / 1000);\n\n    const body = { wallet, tier: TIER_IRON, side: SIDE_HEADS, nonce, timestamp };\n    const signature = signCreateRequest(creatorKeypair, body);\n    const payload = JSON.stringify({ ...body, signature });\n\n    // First request succeeds\n    const res1 = await app.request(\"/fairness/coinflip/create\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: payload,\n    });\n    expect(res1.status).toBe(200);\n\n    // Second request with same nonce → 409\n    const timestamp2 = Math.floor(Date.now() / 1000);\n    const body2 = { wallet, tier: TIER_IRON, side: SIDE_HEADS, nonce, timestamp: timestamp2 };\n    const signature2 = signCreateRequest(creatorKeypair, body2);\n    const res2 = await app.request(\"/fairness/coinflip/create\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ ...body2, signature: signature2 }),\n    });\n    expect(res2.status).toBe(409);\n  });\n});\n","numLines":563,"startLine":1,"totalLines":563}}}
