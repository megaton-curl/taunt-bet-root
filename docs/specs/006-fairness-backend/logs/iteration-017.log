{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FGXzHTYW391aVH4hbPh3PC","type":"tool_result","content":"     1→import { describe, it, expect } from \"vitest\";\n     2→import { createHash } from \"node:crypto\";\n     3→import { Keypair, PublicKey } from \"@solana/web3.js\";\n     4→import { generateSecret, computeCommitment, deriveMatchPda } from \"../fairness.js\";\n     5→\n     6→describe(\"generateSecret\", () => {\n     7→  it(\"returns a 32-byte buffer\", () => {\n     8→    const secret = generateSecret();\n     9→    expect(Buffer.isBuffer(secret)).toBe(true);\n    10→    expect(secret.length).toBe(32);\n    11→  });\n    12→\n    13→  it(\"produces unique secrets on successive calls\", () => {\n    14→    const a = generateSecret();\n    15→    const b = generateSecret();\n    16→    expect(a.equals(b)).toBe(false);\n    17→  });\n    18→});\n    19→\n    20→describe(\"computeCommitment\", () => {\n    21→  it(\"returns sha256 of the secret bytes\", () => {\n    22→    // sha256 of the zero byte (0x00) — well-known constant\n    23→    const zeroByte = Buffer.from([0x00]);\n    24→    const expected =\n    25→      \"6e340b9cffb37a989ca544e6bb780a2c78901d3fb33738768511a30617afa01d\";\n    26→    expect(computeCommitment(zeroByte).toString(\"hex\")).toBe(expected);\n    27→  });\n    28→\n    29→  it(\"matches the packages/fairness commitment algorithm\", () => {\n    30→    // The fairness package computes sha256(hexToBytes(hexSeed)).\n    31→    // Our backend computes sha256(secretBuffer).\n    32→    // They must agree when given the same bytes.\n    33→    const seedHex =\n    34→      \"abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789\";\n    35→    const seedBytes = Buffer.from(seedHex, \"hex\");\n    36→\n    37→    const backendCommitment = computeCommitment(seedBytes).toString(\"hex\");\n    38→\n    39→    // Independently compute using Node crypto for cross-check\n    40→    const nodeCommitment = createHash(\"sha256\").update(seedBytes).digest(\"hex\");\n    41→\n    42→    expect(backendCommitment).toBe(nodeCommitment);\n    43→  });\n    44→\n    45→  it(\"is deterministic\", () => {\n    46→    const secret = Buffer.alloc(32, 0x42);\n    47→    const a = computeCommitment(secret);\n    48→    const b = computeCommitment(secret);\n    49→    expect(a.equals(b)).toBe(true);\n    50→  });\n    51→\n    52→  it(\"produces different commitments for different secrets\", () => {\n    53→    const a = computeCommitment(Buffer.alloc(32, 0x01));\n    54→    const b = computeCommitment(Buffer.alloc(32, 0x02));\n    55→    expect(a.equals(b)).toBe(false);\n    56→  });\n    57→});\n    58→\n    59→describe(\"deriveMatchPda\", () => {\n    60→  const creator = Keypair.generate().publicKey;\n    61→  const programId = new PublicKey(\n    62→    \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n    63→  );\n    64→\n    65→  it(\"returns a PublicKey and bump seed\", () => {\n    66→    const [pda, bump] = deriveMatchPda(creator, 0);\n    67→    expect(pda).toBeInstanceOf(PublicKey);\n    68→    expect(typeof bump).toBe(\"number\");\n    69→    expect(bump).toBeGreaterThanOrEqual(0);\n    70→    expect(bump).toBeLessThanOrEqual(255);\n    71→  });\n    72→\n    73→  it(\"matches manual PDA derivation with seeds [match, creator, nonce_le]\", () => {\n    74→    const nonce = 42;\n    75→    const nonceBuf = Buffer.alloc(8);\n    76→    nonceBuf.writeBigUInt64LE(BigInt(nonce));\n    77→\n    78→    const [expected] = PublicKey.findProgramAddressSync(\n    79→      [Buffer.from(\"match\"), creator.toBuffer(), nonceBuf],\n    80→      programId,\n    81→    );\n    82→\n    83→    const [actual] = deriveMatchPda(creator, nonce);\n    84→    expect(actual.equals(expected)).toBe(true);\n    85→  });\n    86→\n    87→  it(\"accepts bigint nonce\", () => {\n    88→    const [a] = deriveMatchPda(creator, 100);\n    89→    const [b] = deriveMatchPda(creator, 100n);\n    90→    expect(a.equals(b)).toBe(true);\n    91→  });\n    92→\n    93→  it(\"produces different PDAs for different nonces\", () => {\n    94→    const [a] = deriveMatchPda(creator, 0);\n    95→    const [b] = deriveMatchPda(creator, 1);\n    96→    expect(a.equals(b)).toBe(false);\n    97→  });\n    98→\n    99→  it(\"produces different PDAs for different creators\", () => {\n   100→    const other = Keypair.generate().publicKey;\n   101→    const [a] = deriveMatchPda(creator, 0);\n   102→    const [b] = deriveMatchPda(other, 0);\n   103→    expect(a.equals(b)).toBe(false);\n   104→  });\n   105→});\n   106→"}]},"parent_tool_use_id":"toolu_01PEFENHuj6MhCVhrNkDt4mq","session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"f3995236-e183-43dd-ba52-287968f308dd"}
