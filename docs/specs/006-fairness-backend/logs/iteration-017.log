{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011f5E4QahdM1pmBw1BG2FVe","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type OperatorEventType =\n    17→  | \"secret_generated\"\n    18→  | \"tx_built\"\n    19→  | \"match_detected\"\n    20→  | \"settle_submitted\"\n    21→  | \"settle_confirmed\"\n    22→  | \"settle_failed\"\n    23→  | \"settle_retried\"\n    24→  | \"timeout_detected\";\n    25→\n    26→export interface Round {\n    27→  pda: string;\n    28→  game: string;\n    29→  creator: string;\n    30→  server_key: string;\n    31→  secret: Buffer;\n    32→  commitment: Buffer;\n    33→  tier: number;\n    34→  side: number;\n    35→  nonce: string; // bigint comes back as string from postgres driver\n    36→  phase: RoundPhase;\n    37→  target_slot: string | null;\n    38→  settle_tx: string | null;\n    39→  settle_attempts: number;\n    40→  result_hash: Buffer | null;\n    41→  result_side: number | null;\n    42→  winner: string | null;\n    43→  created_at: Date;\n    44→  updated_at: Date;\n    45→}\n    46→\n    47→export interface InsertRoundParams {\n    48→  pda: string;\n    49→  game: string;\n    50→  creator: string;\n    51→  serverKey: string;\n    52→  secret: Buffer;\n    53→  commitment: Buffer;\n    54→  tier: number;\n    55→  side: number;\n    56→  nonce: bigint | number;\n    57→  phase: RoundPhase;\n    58→}\n    59→\n    60→export interface OperatorEvent {\n    61→  id: string;\n    62→  pda: string | null;\n    63→  event_type: OperatorEventType;\n    64→  payload: unknown;\n    65→  created_at: Date;\n    66→}\n    67→\n    68→// ---------------------------------------------------------------------------\n    69→// Phase transition guard\n    70→// ---------------------------------------------------------------------------\n    71→\n    72→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n    73→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n    74→  created: [\"locked\", \"expired\"],\n    75→  locked: [\"settling\"],\n    76→  settling: [\"settled\"],\n    77→  settled: [],\n    78→  expired: [],\n    79→};\n    80→\n    81→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n    82→  const allowed = VALID_TRANSITIONS[from];\n    83→  if (!allowed.includes(to)) {\n    84→    throw new Error(\n    85→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    86→    );\n    87→  }\n    88→}\n    89→\n    90→// ---------------------------------------------------------------------------\n    91→// DB client\n    92→// ---------------------------------------------------------------------------\n    93→\n    94→export interface Db {\n    95→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n    96→  insertRound(params: InsertRoundParams): Promise<Round>;\n    97→\n    98→  /** Transition a round's phase. Enforces unidirectional state machine.\n    99→   *  Optional `updates` can set additional columns alongside the phase change. */\n   100→  updateRoundPhase(\n   101→    pda: string,\n   102→    newPhase: RoundPhase,\n   103→    updates?: Partial<\n   104→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   105→    >,\n   106→  ): Promise<Round>;\n   107→\n   108→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   109→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   110→\n   111→  /** Get all rounds matching a given phase. */\n   112→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   113→\n   114→  /** Append an operator event to the audit log. */\n   115→  insertOperatorEvent(\n   116→    pda: string | null,\n   117→    eventType: OperatorEventType,\n   118→    payload?: unknown,\n   119→  ): Promise<OperatorEvent>;\n   120→\n   121→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   122→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   123→\n   124→  /** Gracefully close the connection pool. */\n   125→  close(): Promise<void>;\n   126→}\n   127→\n   128→export function createDb(databaseUrl: string): Db {\n   129→  const sql = postgres(databaseUrl);\n   130→\n   131→  return {\n   132→    async insertRound(params) {\n   133→      const rows = await sql<Round[]>`\n   134→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, tier, side, nonce, phase)\n   135→        VALUES (\n   136→          ${params.pda},\n   137→          ${params.game},\n   138→          ${params.creator},\n   139→          ${params.serverKey},\n   140→          ${params.secret},\n   141→          ${params.commitment},\n   142→          ${params.tier},\n   143→          ${params.side},\n   144→          ${Number(params.nonce)},\n   145→          ${params.phase}\n   146→        )\n   147→        RETURNING *\n   148→      `;\n   149→      return rows[0]!;\n   150→    },\n   151→\n   152→    async updateRoundPhase(pda, newPhase, updates) {\n   153→      // Fetch current phase to validate transition\n   154→      const current = await sql<Pick<Round, \"phase\">[]>`\n   155→        SELECT phase FROM rounds WHERE pda = ${pda}\n   156→      `;\n   157→\n   158→      if (current.length === 0) {\n   159→        throw new Error(`Round not found: ${pda}`);\n   160→      }\n   161→\n   162→      const currentPhase = current[0]!.phase as RoundPhase;\n   163→      assertPhaseTransition(currentPhase, newPhase);\n   164→\n   165→      // Build the update — always set phase + updated_at\n   166→      const rows = await sql<Round[]>`\n   167→        UPDATE rounds SET\n   168→          phase = ${newPhase},\n   169→          updated_at = now(),\n   170→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   171→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   172→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   173→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   174→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   175→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   176→        WHERE pda = ${pda}\n   177→        RETURNING *\n   178→      `;\n   179→\n   180→      return rows[0]!;\n   181→    },\n   182→\n   183→    async getRoundByPda(pda) {\n   184→      const rows = await sql<Round[]>`\n   185→        SELECT * FROM rounds WHERE pda = ${pda}\n   186→      `;\n   187→      return rows[0];\n   188→    },\n   189→\n   190→    async getRoundsByPhase(phase) {\n   191→      return sql<Round[]>`\n   192→        SELECT * FROM rounds WHERE phase = ${phase}\n   193→      `;\n   194→    },\n   195→\n   196→    async insertOperatorEvent(pda, eventType, payload) {\n   197→      const rows = await sql<OperatorEvent[]>`\n   198→        INSERT INTO operator_events (pda, event_type, payload)\n   199→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   200→        RETURNING *\n   201→      `;\n   202→      return rows[0]!;\n   203→    },\n   204→\n   205→    async getUnsettledStats() {\n   206→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   207→        SELECT\n   208→          COUNT(*)::text AS count,\n   209→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   210→        FROM rounds\n   211→        WHERE phase NOT IN ('settled', 'expired')\n   212→      `;\n   213→      const row = rows[0]!;\n   214→      return {\n   215→        count: parseInt(row.count, 10),\n   216→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   217→      };\n   218→    },\n   219→\n   220→    async close() {\n   221→      await sql.end();\n   222→    },\n   223→  };\n   224→}\n   225→"}]},"parent_tool_use_id":null,"session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"f61cae86-acd2-43ff-bd95-6a5b341f552f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/db.ts","content":"/**\n * Database client module — typed query functions for `rounds` and `operator_events`.\n *\n * Phase transitions are unidirectional: created → locked → settling → settled,\n * or created → expired. The application layer rejects backward transitions.\n */\n\nimport postgres from \"postgres\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n\nexport type OperatorEventType =\n  | \"secret_generated\"\n  | \"tx_built\"\n  | \"match_detected\"\n  | \"settle_submitted\"\n  | \"settle_confirmed\"\n  | \"settle_failed\"\n  | \"settle_retried\"\n  | \"timeout_detected\";\n\nexport interface Round {\n  pda: string;\n  game: string;\n  creator: string;\n  server_key: string;\n  secret: Buffer;\n  commitment: Buffer;\n  tier: number;\n  side: number;\n  nonce: string; // bigint comes back as string from postgres driver\n  phase: RoundPhase;\n  target_slot: string | null;\n  settle_tx: string | null;\n  settle_attempts: number;\n  result_hash: Buffer | null;\n  result_side: number | null;\n  winner: string | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface InsertRoundParams {\n  pda: string;\n  game: string;\n  creator: string;\n  serverKey: string;\n  secret: Buffer;\n  commitment: Buffer;\n  tier: number;\n  side: number;\n  nonce: bigint | number;\n  phase: RoundPhase;\n}\n\nexport interface OperatorEvent {\n  id: string;\n  pda: string | null;\n  event_type: OperatorEventType;\n  payload: unknown;\n  created_at: Date;\n}\n\n// ---------------------------------------------------------------------------\n// Phase transition guard\n// ---------------------------------------------------------------------------\n\n/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\nconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n  created: [\"locked\", \"expired\"],\n  locked: [\"settling\"],\n  settling: [\"settled\"],\n  settled: [],\n  expired: [],\n};\n\nfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n  const allowed = VALID_TRANSITIONS[from];\n  if (!allowed.includes(to)) {\n    throw new Error(\n      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    );\n  }\n}\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db {\n  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n  insertRound(params: InsertRoundParams): Promise<Round>;\n\n  /** Transition a round's phase. Enforces unidirectional state machine.\n   *  Optional `updates` can set additional columns alongside the phase change. */\n  updateRoundPhase(\n    pda: string,\n    newPhase: RoundPhase,\n    updates?: Partial<\n      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n    >,\n  ): Promise<Round>;\n\n  /** Get a single round by its PDA. Returns `undefined` if not found. */\n  getRoundByPda(pda: string): Promise<Round | undefined>;\n\n  /** Get all rounds matching a given phase. */\n  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n\n  /** Append an operator event to the audit log. */\n  insertOperatorEvent(\n    pda: string | null,\n    eventType: OperatorEventType,\n    payload?: unknown,\n  ): Promise<OperatorEvent>;\n\n  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n\n  /** Gracefully close the connection pool. */\n  close(): Promise<void>;\n}\n\nexport function createDb(databaseUrl: string): Db {\n  const sql = postgres(databaseUrl);\n\n  return {\n    async insertRound(params) {\n      const rows = await sql<Round[]>`\n        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, tier, side, nonce, phase)\n        VALUES (\n          ${params.pda},\n          ${params.game},\n          ${params.creator},\n          ${params.serverKey},\n          ${params.secret},\n          ${params.commitment},\n          ${params.tier},\n          ${params.side},\n          ${Number(params.nonce)},\n          ${params.phase}\n        )\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async updateRoundPhase(pda, newPhase, updates) {\n      // Fetch current phase to validate transition\n      const current = await sql<Pick<Round, \"phase\">[]>`\n        SELECT phase FROM rounds WHERE pda = ${pda}\n      `;\n\n      if (current.length === 0) {\n        throw new Error(`Round not found: ${pda}`);\n      }\n\n      const currentPhase = current[0]!.phase as RoundPhase;\n      assertPhaseTransition(currentPhase, newPhase);\n\n      // Build the update — always set phase + updated_at\n      const rows = await sql<Round[]>`\n        UPDATE rounds SET\n          phase = ${newPhase},\n          updated_at = now(),\n          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n          winner = COALESCE(${updates?.winner ?? null}, winner)\n        WHERE pda = ${pda}\n        RETURNING *\n      `;\n\n      return rows[0]!;\n    },\n\n    async getRoundByPda(pda) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE pda = ${pda}\n      `;\n      return rows[0];\n    },\n\n    async getRoundsByPhase(phase) {\n      return sql<Round[]>`\n        SELECT * FROM rounds WHERE phase = ${phase}\n      `;\n    },\n\n    async insertOperatorEvent(pda, eventType, payload) {\n      const rows = await sql<OperatorEvent[]>`\n        INSERT INTO operator_events (pda, event_type, payload)\n        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getUnsettledStats() {\n      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n        SELECT\n          COUNT(*)::text AS count,\n          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n        FROM rounds\n        WHERE phase NOT IN ('settled', 'expired')\n      `;\n      const row = rows[0]!;\n      return {\n        count: parseInt(row.count, 10),\n        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n      };\n    },\n\n    async close() {\n      await sql.end();\n    },\n  };\n}\n","numLines":225,"startLine":1,"totalLines":225}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FL8ojLXuMshEkJc7DS7ZGU","type":"message","role":"assistant","content":[{"type":"text","text":"Now I have everything I need. Let me create the HTTP endpoint tests file."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3198,"cache_read_input_tokens":62223,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3198},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"1b3281b2-d239-4c1f-8ea7-8bbe932bec60"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FL8ojLXuMshEkJc7DS7ZGU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UzEwAfp9mo3VzUyFrQy93X","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts","content":"/**\n * HTTP endpoint tests — exercises the full middleware stack (rate limit + auth)\n * and route handlers for all endpoints:\n *\n * POST /fairness/coinflip/create:\n *   - 200 with valid auth\n *   - 401 with invalid signature\n *   - 401 with expired timestamp\n *   - 409 with duplicate nonce\n *   - 429 when rate limit exceeded\n *\n * GET /fairness/rounds/:pda:\n *   - 200 for known PDA\n *   - 404 for unknown PDA\n *\n * GET /health:\n *   - 200 with expected fields\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, PublicKey, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createAuthMiddleware } from \"../middleware/auth.js\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst TIER_IRON = 1;\nconst SIDE_HEADS = 0;\n\n// ---------------------------------------------------------------------------\n// Minimal mock Connection (only what routes + health need)\n// ---------------------------------------------------------------------------\n\nclass MockConnection {\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getBalance() {\n    return 1.5 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Auth helper\n// ---------------------------------------------------------------------------\n\nfunction signCreateRequest(\n  keypair: Keypair,\n  body: { wallet: string; tier: number; side: number; nonce: number; timestamp: number },\n): string {\n  const canonical = JSON.stringify({\n    wallet: body.wallet,\n    tier: body.tier,\n    side: body.side,\n    nonce: body.nonce,\n    timestamp: body.timestamp,\n  });\n  const messageBytes = new TextEncoder().encode(canonical);\n  const sigBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n  return bs58.encode(sigBytes);\n}\n\nfunction makeBody(wallet: string, overrides?: Partial<{ tier: number; side: number; nonce: number; timestamp: number }>) {\n  return {\n    wallet,\n    tier: overrides?.tier ?? TIER_IRON,\n    side: overrides?.side ?? SIDE_HEADS,\n    nonce: overrides?.nonce ?? Math.floor(Math.random() * 1_000_000),\n    timestamp: overrides?.timestamp ?? Math.floor(Date.now() / 1000),\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"HTTP endpoint tests\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    db = createDb(DATABASE_URL);\n    rawSql = postgres(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n    mockConn = new MockConnection();\n  });\n\n  // -----------------------------------------------------------------------\n  // Helper: build a fresh Hono app with full middleware stack\n  // -----------------------------------------------------------------------\n\n  function buildApp(opts?: { perWallet?: number; global?: number }) {\n    const app = new Hono();\n\n    app.use(\n      \"/fairness/*\",\n      createRateLimitMiddleware({\n        perWallet: opts?.perWallet ?? 10,\n        global: opts?.global ?? 100,\n        windowMs: 60_000,\n      }),\n    );\n\n    app.use(\n      \"/fairness/*\",\n      createAuthMiddleware({ clockSkewSeconds: 60 }),\n    );\n\n    app.route(\n      \"/fairness/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n\n    app.route(\n      \"/health\",\n      createHealthRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKey: serverKeypair.publicKey,\n        isWorkerRunning: () => true,\n        minSolBalance: 0.1,\n      }),\n    );\n\n    return app;\n  }\n\n  // -----------------------------------------------------------------------\n  // POST /fairness/coinflip/create\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /fairness/coinflip/create\", () => {\n    it(\"returns 200 with valid auth\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n      const signature = signCreateRequest(creatorKeypair, body);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature }),\n      });\n\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.transaction).toBeDefined();\n      expect(typeof json.transaction).toBe(\"string\");\n      expect(json.matchPda).toBeDefined();\n      expect(typeof json.matchPda).toBe(\"string\");\n      expect(json.commitment).toBeDefined();\n      expect(typeof json.commitment).toBe(\"string\");\n      // Commitment should be 64 hex chars (32 bytes)\n      expect((json.commitment as string).length).toBe(64);\n    });\n\n    it(\"returns 401 with invalid signature\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n      // Sign with a DIFFERENT keypair\n      const wrongKeypair = Keypair.generate();\n      const badSignature = signCreateRequest(wrongKeypair, body);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature: badSignature }),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toBeDefined();\n    });\n\n    it(\"returns 401 with expired timestamp\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      // Timestamp 120 seconds in the past (exceeds 60s clock skew)\n      const body = makeBody(wallet, { timestamp: Math.floor(Date.now() / 1000) - 120 });\n      const signature = signCreateRequest(creatorKeypair, body);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature }),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"expired\");\n    });\n\n    it(\"returns 409 with duplicate nonce\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const nonce = 42;\n\n      // First request — should succeed\n      const body1 = makeBody(wallet, { nonce });\n      const sig1 = signCreateRequest(creatorKeypair, body1);\n      const res1 = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body1, signature: sig1 }),\n      });\n      expect(res1.status).toBe(200);\n\n      // Second request with same nonce — should conflict\n      const body2 = makeBody(wallet, { nonce });\n      const sig2 = signCreateRequest(creatorKeypair, body2);\n      const res2 = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body2, signature: sig2 }),\n      });\n      expect(res2.status).toBe(409);\n      const json = (await res2.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"already exists\");\n    });\n\n    it(\"returns 429 when rate limit exceeded\", async () => {\n      // Create app with very low per-wallet limit\n      const app = buildApp({ perWallet: 2, global: 100 });\n      const wallet = creatorKeypair.publicKey.toBase58();\n\n      // Send 2 requests (within limit)\n      for (let i = 0; i < 2; i++) {\n        const body = makeBody(wallet, { nonce: 1000 + i });\n        const sig = signCreateRequest(creatorKeypair, body);\n        const res = await app.request(\"/fairness/coinflip/create\", {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ ...body, signature: sig }),\n        });\n        expect(res.status).toBe(200);\n      }\n\n      // Third request should be rate-limited\n      const body3 = makeBody(wallet, { nonce: 1002 });\n      const sig3 = signCreateRequest(creatorKeypair, body3);\n      const res3 = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body3, signature: sig3 }),\n      });\n      expect(res3.status).toBe(429);\n      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n      const json = (await res3.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"Too many\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /fairness/rounds/:pda\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /fairness/rounds/:pda\", () => {\n    it(\"returns 200 for known PDA\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n      const signature = signCreateRequest(creatorKeypair, body);\n\n      // Create a round first\n      const createRes = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature }),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { matchPda: string; commitment: string };\n\n      // Fetch the round\n      const roundRes = await app.request(`/fairness/rounds/${createJson.matchPda}`);\n      expect(roundRes.status).toBe(200);\n\n      const roundJson = (await roundRes.json()) as Record<string, unknown>;\n      expect(roundJson.pda).toBe(createJson.matchPda);\n      expect(roundJson.game).toBe(\"coinflip\");\n      expect(roundJson.phase).toBe(\"created\");\n      expect(roundJson.creator).toBe(wallet);\n      expect(roundJson.commitment).toBe(createJson.commitment);\n      expect(roundJson.tier).toBe(TIER_IRON);\n      expect(roundJson.side).toBe(SIDE_HEADS);\n      expect(roundJson.createdAt).toBeDefined();\n      expect(roundJson.updatedAt).toBeDefined();\n      // Unsettled: secret and verification should NOT be present\n      expect(roundJson.secret).toBeUndefined();\n      expect(roundJson.verification).toBeUndefined();\n    });\n\n    it(\"returns 404 for unknown PDA\", async () => {\n      const app = buildApp();\n      const unknownPda = Keypair.generate().publicKey.toBase58();\n      const res = await app.request(`/fairness/rounds/${unknownPda}`);\n      expect(res.status).toBe(404);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"not found\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /health\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /health\", () => {\n    it(\"returns 200 with expected fields\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/health\");\n      expect(res.status).toBe(200);\n\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.status).toBe(\"ok\");\n      expect(json.version).toBe(\"0.1.0\");\n      expect(json.serverKey).toBe(serverKeypair.publicKey.toBase58());\n      expect(typeof json.solBalance).toBe(\"number\");\n      expect(json.solBalance).toBe(1.5);\n      expect(json.dbConnected).toBe(true);\n      expect(json.workerRunning).toBe(true);\n      expect(typeof json.unsettledCount).toBe(\"number\");\n      expect(typeof json.oldestUnsettledAge).toBe(\"number\");\n    });\n\n    it(\"reflects unsettled round count\", async () => {\n      const app = buildApp();\n\n      // Create a round so there's an unsettled one\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n      const signature = signCreateRequest(creatorKeypair, body);\n      const createRes = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ ...body, signature }),\n      });\n      expect(createRes.status).toBe(200);\n\n      const healthRes = await app.request(\"/health\");\n      expect(healthRes.status).toBe(200);\n      const json = (await healthRes.json()) as Record<string, unknown>;\n      expect(json.unsettledCount).toBe(1);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3198,"cache_read_input_tokens":62223,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3198},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"f5e00643-d312-412d-bfd1-38ab70c5728f"}
