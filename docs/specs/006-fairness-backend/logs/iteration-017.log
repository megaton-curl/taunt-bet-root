{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pm3vmMHyKVsQECg3SobbJb","type":"tool_result","content":"     1→{\n     2→  \"name\": \"@rng-utopia/backend\",\n     3→  \"version\": \"0.1.0\",\n     4→  \"private\": true,\n     5→  \"type\": \"module\",\n     6→  \"main\": \"./src/index.ts\",\n     7→  \"types\": \"./src/index.ts\",\n     8→  \"exports\": {\n     9→    \".\": \"./src/index.ts\"\n    10→  },\n    11→  \"scripts\": {\n    12→    \"dev\": \"tsx watch src/index.ts\",\n    13→    \"build\": \"tsc --noEmit\",\n    14→    \"lint\": \"eslint .\",\n    15→    \"lint:fix\": \"eslint . --fix\",\n    16→    \"typecheck\": \"tsc --noEmit\",\n    17→    \"migrate\": \"tsx src/migrate.ts\",\n    18→    \"migrate:status\": \"tsx src/migrate.ts status\",\n    19→    \"test\": \"vitest --passWithNoTests\"\n    20→  },\n    21→  \"dependencies\": {\n    22→    \"@solana/web3.js\": \"^1.98.0\",\n    23→    \"bs58\": \"^6.0.0\",\n    24→    \"hono\": \"^4.6.0\",\n    25→    \"postgres\": \"^3.4.0\",\n    26→    \"tweetnacl\": \"^1.0.3\"\n    27→  },\n    28→  \"devDependencies\": {\n    29→    \"@rng-utopia/config\": \"workspace:*\",\n    30→    \"@types/node\": \"^22.10.0\",\n    31→    \"tsx\": \"^4.7.0\",\n    32→    \"typescript\": \"^5.7.0\",\n    33→    \"vitest\": \"^2.1.0\"\n    34→  }\n    35→}\n    36→"}]},"parent_tool_use_id":"toolu_01PEFENHuj6MhCVhrNkDt4mq","session_id":"0ef57e86-e719-4cc8-af9e-8c35c2cc8927","uuid":"30ff0458-c83d-40f1-980a-6d165ee0aab7"}
