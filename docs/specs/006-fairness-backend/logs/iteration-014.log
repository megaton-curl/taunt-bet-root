{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KgXD7vhSuNEdd6ugFgyhnS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MM5qYnFMYtAHe87o3Fnj9Z","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/auth.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { createAuthMiddleware } from \"../middleware/auth.js\";\n\nfunction createTestApp(clockSkewSeconds = 60) {\n  const app = new Hono();\n  app.use(\"/*\", createAuthMiddleware({ clockSkewSeconds }));\n  app.post(\"/test\", (c) => c.json({ ok: true }));\n  app.get(\"/test\", (c) => c.json({ ok: true }));\n  return app;\n}\n\nfunction makeSignedRequest(\n  keypair: nacl.SignKeyPair,\n  overrides: Record<string, unknown> = {},\n) {\n  const wallet = bs58.encode(keypair.publicKey);\n  const fields = {\n    wallet,\n    tier: 3,\n    side: 0,\n    nonce: 42,\n    timestamp: Math.floor(Date.now() / 1000),\n    ...overrides,\n  };\n\n  // Canonical payload — keys in spec-defined order\n  const canonical = JSON.stringify({\n    wallet: fields.wallet,\n    tier: fields.tier,\n    side: fields.side,\n    nonce: fields.nonce,\n    timestamp: fields.timestamp,\n  });\n\n  const messageBytes = new TextEncoder().encode(canonical);\n  const signature = nacl.sign.detached(messageBytes, keypair.secretKey);\n\n  return {\n    ...fields,\n    signature: bs58.encode(signature),\n  };\n}\n\nfunction post(body: unknown) {\n  return {\n    method: \"POST\" as const,\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify(body),\n  };\n}\n\ndescribe(\"auth middleware\", () => {\n  const keypair = nacl.sign.keyPair();\n\n  it(\"accepts a valid signature\", async () => {\n    const app = createTestApp();\n    const body = makeSignedRequest(keypair);\n    const res = await app.request(\"/test\", post(body));\n    expect(res.status).toBe(200);\n  });\n\n  it(\"rejects an invalid (zeroed) signature\", async () => {\n    const app = createTestApp();\n    const body = makeSignedRequest(keypair);\n    body.signature = bs58.encode(new Uint8Array(64));\n    const res = await app.request(\"/test\", post(body));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects a signature from the wrong keypair\", async () => {\n    const app = createTestApp();\n    const other = nacl.sign.keyPair();\n    // Sign with `other` but claim wallet is `keypair`\n    const wallet = bs58.encode(keypair.publicKey);\n    const fields = {\n      wallet,\n      tier: 3,\n      side: 0,\n      nonce: 42,\n      timestamp: Math.floor(Date.now() / 1000),\n    };\n    const canonical = JSON.stringify(fields);\n    const sig = nacl.sign.detached(\n      new TextEncoder().encode(canonical),\n      other.secretKey,\n    );\n    const res = await app.request(\n      \"/test\",\n      post({ ...fields, signature: bs58.encode(sig) }),\n    );\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects an expired timestamp\", async () => {\n    const app = createTestApp(60);\n    const body = makeSignedRequest(keypair, {\n      timestamp: Math.floor(Date.now() / 1000) - 120,\n    });\n    const res = await app.request(\"/test\", post(body));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"accepts a timestamp within clock skew\", async () => {\n    const app = createTestApp(60);\n    const body = makeSignedRequest(keypair, {\n      timestamp: Math.floor(Date.now() / 1000) - 30,\n    });\n    const res = await app.request(\"/test\", post(body));\n    expect(res.status).toBe(200);\n  });\n\n  it(\"rejects a missing signature field\", async () => {\n    const app = createTestApp();\n    const { signature: _, ...body } = makeSignedRequest(keypair);\n    void _;\n    const res = await app.request(\"/test\", post(body));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects a missing timestamp field\", async () => {\n    const app = createTestApp();\n    const body = makeSignedRequest(keypair);\n    const { timestamp: _, ...noTs } = body;\n    void _;\n    const res = await app.request(\"/test\", post(noTs));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"passes GET requests without authentication\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":15152,"cache_read_input_tokens":33975,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":15152},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"394f7cd7-08a9-47a0-9ea5-46b8c6f2106f","uuid":"660e5d77-f42f-45db-9377-a73015f58557"}
