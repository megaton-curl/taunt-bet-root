, ...body } = makeSignedRequest(keypair);\n    void _;\n    const res = await app.request(\"/test\", post(body));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects a missing timestamp field\", async () => {\n    const app = createTestApp();\n    const body = makeSignedRequest(keypair);\n    const { timestamp: _, ...noTs } = body;\n    void _;\n    const res = await app.request(\"/test\", post(noTs));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"passes GET requests without authentication\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KgXD7vhSuNEdd6ugFgyhnS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Dxt86GzvNMDujGmQGSjCj1","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/rate-limit.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n\nfunction createTestApp(\n  config = { perWallet: 3, global: 10, windowMs: 60_000 },\n) {\n  const app = new Hono();\n  app.use(\"/*\", createRateLimitMiddleware(config));\n  app.post(\"/test\", (c) => c.json({ ok: true }));\n  app.get(\"/test\", (c) => c.json({ ok: true }));\n  return app;\n}\n\nfunction post(wallet: string) {\n  return {\n    method: \"POST\" as const,\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  };\n}\n\ndescribe(\"rate-limit middleware\", () => {\n  it(\"allows requests within per-wallet limit\", async () => {\n    const app = createTestApp({ perWallet: 3, global: 100, windowMs: 60_000 });\n    for (let i = 0; i < 3; i++) {\n      const res = await app.request(\"/test\", post(\"wallet1\"));\n      expect(res.status).toBe(200);\n    }\n  });\n\n  it(\"blocks requests exceeding per-wallet limit\", async () => {\n    const app = createTestApp({ perWallet: 2, global: 100, windowMs: 60_000 });\n    await app.request(\"/test\", post(\"wallet1\"));\n    await app.request(\"/test\", post(\"wallet1\"));\n    const res = await app.request(\"/test\", post(\"wallet1\"));\n    expect(res.status).toBe(429);\n  });\n\n  it(\"returns Retry-After header on per-wallet 429\", async () => {\n    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    await app.request(\"/test\", post(\"wallet1\"));\n    const res = await app.request(\"/test\", post(\"wallet1\"));\n    expect(res.status).toBe(429);\n    expect(res.headers.get(\"Retry-After\")).toBe(\"60\");\n  });\n\n  it(\"tracks wallets independently\", async () => {\n    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    const r1 = await app.request(\"/test\", post(\"wallet1\"));\n    const r2 = await app.request(\"/test\", post(\"wallet2\"));\n    expect(r1.status).toBe(200);\n    expect(r2.status).toBe(200);\n    // wallet1 is now exhausted\n    const r3 = await app.request(\"/test\", post(\"wallet1\"));\n    expect(r3.status).toBe(429);\n    // wallet2 is also exhausted\n    const r4 = await app.request(\"/test\", post(\"wallet2\"));\n    expect(r4.status).toBe(429);\n  });\n\n  it(\"enforces global limit across all wallets\", async () => {\n    const app = createTestApp({ perWallet: 10, global: 3, windowMs: 60_000 });\n    await app.request(\"/test\", post(\"w1\"));\n    await app.request(\"/test\", post(\"w2\"));\n    await app.request(\"/test\", post(\"w3\"));\n    const res = await app.request(\"/test\", post(\"w4\"));\n    expect(res.status).toBe(429);\n  });\n\n  it(\"returns correct Retry-After seconds based on window\", async () => {\n    const app = createTestApp({ perWallet: 10, global: 1, windowMs: 30_000 });\n    await app.request(\"/test\", post(\"w1\"));\n    const res = await app.request(\"/test\", post(\"w2\"));\n    expect(res.status).toBe(429);\n    expect(res.headers.get(\"Retry-After\")).toBe(\"30\");\n  });\n\n  it(\"does not rate-limit GET requests\", async () => {\n    const app = createTestApp({ perWallet: 1, global: 1, windowMs: 60_000 });\n    // Exhaust POST limits\n    await app.request(\"/test\", post(\"w1\"));\n    // GET should still work\n    const res = await app.request(\"/test\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":15152,"cache_read_input_tokens":33975,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":15152},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"394f7cd7-08a9-47a0-9ea5-46b8c6f2106f","uuid":"be398d11-f4a3-4626-a945-2c8668e5a73c"}
