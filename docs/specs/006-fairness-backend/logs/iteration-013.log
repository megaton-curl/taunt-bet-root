on;\n  settleMatch: (pda: string) => Promise<SettleResult>;\n}\n\ninterface RetryState {\n  attempts: number;\n  /** Timestamp (ms) at which next retry is allowed. */\n  nextRetryAt: number;\n}\n\nexport interface RetrySettler {\n  /**\n   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n   * failure tracking, and resolve_deadline timeout detection.\n   *\n   * Safe to call repeatedly — skips if a retry is scheduled but not yet due,\n   * or if the PDA has already been marked as permanently failed / timed out.\n   */\n  attemptSettle(pda: string): Promise<void>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n  const { db, connection, settleMatch } = deps;\n\n  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n  const retryStates = new Map<string, RetryState>();\n\n  /** PDAs that hit a permanent (non-retryable) error. */\n  const failedPdas = new Set<string>();\n\n  /** PDAs whose resolve_deadline has passed. */\n  const timeoutPdas = new Set<string>();\n\n  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n  function getDelay(attempt: number): number {\n    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n  }\n\n  /**\n   * Check whether the on-chain resolve_deadline has passed for a match.\n   * Returns true if the deadline is in the past (timeout refund eligible).\n   */\n  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    try {\n      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n      if (!accountInfo) return true; // account gone — treat as expired\n      const data = Buffer.from(accountInfo.data);\n      if (data.length < RESOLVE_DEADLINE_OFFSET + 8) return false;\n      const resolveDeadline = Number(data.readBigInt64LE(RESOLVE_DEADLINE_OFFSET));\n      if (resolveDeadline <= 0) return false; // not set yet\n      const nowUnix = Math.floor(Date.now() / 1000);\n      return nowUnix >= resolveDeadline;\n    } catch {\n      return false; // can't read — don't assume timeout\n    }\n  }\n\n  async function attemptSettle(pda: string): Promise<void> {\n    // Skip permanently failed or timed-out PDAs\n    if (failedPdas.has(pda) || timeoutPdas.has(pda)) return;\n\n    const state = retryStates.get(pda);\n\n    // If a retry is scheduled but not yet due, skip\n    if (state && Date.now() < state.nextRetryAt) return;\n\n    // If max retries exceeded, mark as failed\n    if (state && state.attempts >= MAX_RETRIES) {\n      failedPdas.add(pda);\n      retryStates.delete(pda);\n      await db.insertOperatorEvent(pda, \"settle_failed\", {\n        reason: \"max retries exceeded\",\n        attempts: state.attempts,\n      });\n      logger.error(\"settle failed — max retries exceeded\", {\n        pda,\n        attempts: state.attempts,\n      });\n      return;\n    }\n\n    // Check resolve_deadline before attempting\n    if (await isResolveDeadlinePassed(pda)) {\n      timeoutPdas.add(pda);\n      retryStates.delete(pda);\n      await db.insertOperatorEvent(pda, \"timeout_detected\", {\n        reason: \"resolve_deadline passed without successful settlement\",\n        attempts: state?.attempts ?? 0,\n      });\n      console.warn(\n        JSON.stringify({\n          level: \"warn\",\n          msg: \"resolve deadline passed, stopping settlement attempts\",\n          pda,\n        }),\n      );\n      return;\n    }\n\n    try {\n      const result = await settleMatch(pda);\n\n      // Success — clear retry state\n      retryStates.delete(pda);\n      console.log(\n        JSON.stringify({\n          level: \"info\",\n          msg: \"match settled\",\n          pda,\n          tx: result.txSignature,\n          resultSide: result.resultSide,\n          winner: result.winner,\n        }),\n      );\n    } catch (err) {\n      if (err instanceof PermanentSettleError) {\n        // Permanent failure — do not retry\n        failedPdas.add(pda);\n        retryStates.delete(pda);\n        await db.insertOperatorEvent(pda, \"settle_failed\", {\n          reason: err.message,\n          permanent: true,\n        });\n        console.error(\n          JSON.stringify({\n            level: \"error\",\n            msg: \"settle permanently failed\",\n            pda,\n            error: err.message,\n          }),\n        );\n      } else {\n        // Transient failure — schedule retry with exponential backoff\n        const attempts = (state?.attempts ?? 0) + 1;\n        const delay = getDelay(attempts - 1);\n\n        retryStates.set(pda, {\n          attempts,\n          nextRetryAt: Date.now() + delay,\n        });\n\n        await db.insertOperatorEvent(pda, \"settle_retried\", {\n          attempt: attempts,\n          nextRetryInMs: delay,\n          error: err instanceof Error ? err.message : String(err),\n        });\n        console.warn(\n          JSON.stringify({\n            level: \"warn\",\n            msg: \"settle transient failure, scheduling retry\",\n            pda,\n            attempt: attempts,\n            nextRetryInMs: delay,\n            error: err instanceof Error ? err.message : String(err),\n          }),\n        );\n      }\n    }\n  }\n\n  return { attemptSettle };\n}\n","structuredPatch":[{"oldStart":122,"oldLines":13,"newStart":122,"newLines":9,"lines":["         reason: \"resolve_deadline passed without successful settlement\",","         attempts: state?.attempts ?? 0,","       });","-      console.warn(","-        JSON.stringify({","-          level: \"warn\",","-          msg: \"resolve deadline passed, stopping settlement attempts\",","-          pda,","-        }),","-      );","+      logger.warn(\"resolve deadline passed, stopping settlement attempts\", {","+        pda,","+      });","       return;","     }"," "]}],"userModified":false,"replaceAll":false}}
