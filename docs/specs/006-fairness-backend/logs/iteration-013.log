e below threshold\", {\n        solBalance,\n        threshold: minSolBalance,\n        serverKey: serverKey.toBase58(),\n      });\n    }\n\n    return c.json({\n      status: \"ok\",\n      version: \"0.1.0\",\n      serverKey: serverKey.toBase58(),\n      solBalance,\n      dbConnected,\n      workerRunning: isWorkerRunning(),\n      unsettledCount,\n      oldestUnsettledAge,\n    });\n  });\n\n  return app;\n}\n","structuredPatch":[],"originalFile":null}}
