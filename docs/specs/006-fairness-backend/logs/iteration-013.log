(\n      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n      10,\n    ),\n    workerPollIntervalMs: parseInt(\n      process.env.WORKER_POLL_INTERVAL_MS ?? \"2000\",\n      10,\n    ),\n    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n  };\n}\n","structuredPatch":[{"oldStart":10,"oldLines":6,"newStart":10,"newLines":7,"lines":["   rateLimitGlobal: number;","   workerPollIntervalMs: number;","   entropyAccount: string;","+  minSolBalance: number;"," }"," "," function requireEnv(name: string): string {"]}],"userModified":false,"replaceAll":false}}
