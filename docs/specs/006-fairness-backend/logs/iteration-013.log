to use the structured logger throughout.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":8060,"cache_read_input_tokens":42043,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":8060},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c4dc42e4-d0e2-427a-a9ba-b27b08b0ec0d","uuid":"228ee252-8d69-4b89-811a-e1972837e89b"}
