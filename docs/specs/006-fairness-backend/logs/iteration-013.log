{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QgSXaHN7NHym2zDnyoCxbs","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settlement.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"c4dc42e4-d0e2-427a-a9ba-b27b08b0ec0d","uuid":"d546437f-ac03-47c8-813c-55c0d796b280","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settlement.ts","oldString":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport type { Db } from \"../db.js\";","newString":"import { Connection, PublicKey } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";","originalFile":"/**\n * Settlement worker — polls the chain for PHASE_LOCKED CoinflipMatch accounts\n * co-signed by this server and detects when they are ready for settlement.\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport type { Db } from \"../db.js\";\n\n// CoinflipMatch account layout offsets (includes 8-byte Anchor discriminator)\nconst ACCOUNT_SIZE = 246;\nconst SERVER_OFFSET = 72;\nconst PHASE_OFFSET = 114;\nconst TARGET_SLOT_OFFSET = 148;\n\nconst PHASE_LOCKED_VALUE = 1;\n\nexport interface SettlementWorkerDeps {\n  db: Db;\n  connection: Connection;\n  serverKey: PublicKey;\n  pollIntervalMs: number;\n  /** Called when a match is detected as ready for settlement (target_slot reached). */\n  onSettleReady?: (pda: string) => Promise<void>;\n}\n\nexport interface SettlementWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single poll cycle (exposed for testing). */\n  poll(): Promise<void>;\n}\n\nexport function createSettlementWorker(\n  deps: SettlementWorkerDeps,\n): SettlementWorker {\n  const { db, connection, serverKey, pollIntervalMs } = deps;\n  const discoveredPdas = new Set<string>();\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  async function poll(): Promise<void> {\n    const currentSlot = await connection.getSlot();\n\n    // Query chain for PHASE_LOCKED CoinflipMatch accounts with our server key\n    const accounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n      filters: [\n        { dataSize: ACCOUNT_SIZE },\n        {\n          memcmp: {\n            offset: PHASE_OFFSET,\n            bytes: bs58.encode(Uint8Array.from([PHASE_LOCKED_VALUE])),\n          },\n        },\n        {\n          memcmp: {\n            offset: SERVER_OFFSET,\n            bytes: serverKey.toBase58(),\n          },\n        },\n      ],\n    });\n\n    for (const { pubkey, account } of accounts) {\n      const pda = pubkey.toBase58();\n      const data = Buffer.from(account.data);\n\n      // Parse target_slot (u64 LE at offset 148)\n      const targetSlot = data.readBigUInt64LE(TARGET_SLOT_OFFSET);\n\n      // Log match_detected for newly discovered locked matches\n      if (!discoveredPdas.has(pda)) {\n        discoveredPdas.add(pda);\n\n        const round = await db.getRoundByPda(pda);\n        if (round && round.phase === \"created\") {\n          // Transition from created → locked in DB\n          await db.updateRoundPhase(pda, \"locked\", {\n            target_slot: targetSlot.toString(),\n          });\n          await db.insertOperatorEvent(pda, \"match_detected\", {\n            targetSlot: targetSlot.toString(),\n            currentSlot,\n          });\n        } else if (!round) {\n          // Match on-chain but not in our DB — we don't have the secret, skip\n          continue;\n        }\n      }\n\n      // Check if target_slot reached — match is ready for settlement\n      if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n        await deps.onSettleReady(pda);\n      }\n    }\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await poll();\n    } catch (err) {\n      // Log but don't crash — transient RPC errors are expected\n      console.error(\n        \"[settlement-worker] poll error:\",\n        err instanceof Error ? err.message : err,\n      );\n    }\n    if (running) {\n      timeoutId = setTimeout(loop, pollIntervalMs);\n    }\n  }\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n      loop();\n    },\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n    },\n    get isRunning() {\n      return running;\n    },\n    poll,\n  };\n}\n","structuredPatch":[{"oldStart":7,"oldLines":6,"newStart":7,"newLines":7,"lines":[" import bs58 from \"bs58\";"," import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";"," import type { Db } from \"../db.js\";","+import { logger } from \"../logger.js\";"," "," // CoinflipMatch account layout offsets (includes 8-byte Anchor discriminator)"," const ACCOUNT_SIZE = 246;"]}],"userModified":false,"replaceAll":false}}
