{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G9aQYF9ic13kSVSU3a9Wpi","type":"tool_result","content":"     1→/**\n     2→ * Settlement retry logic — wraps settleMatch with exponential backoff\n     3→ * for transient failures and proper handling of permanent failures.\n     4→ *\n     5→ * Called by the settlement worker's onSettleReady callback on each poll\n     6→ * cycle for every locked match whose target_slot has been reached.\n     7→ */\n     8→\n     9→import { Connection, PublicKey } from \"@solana/web3.js\";\n    10→import type { Db } from \"../db.js\";\n    11→import type { SettleResult } from \"./settle-tx.js\";\n    12→import { PermanentSettleError } from \"./settle-tx.js\";\n    13→\n    14→// ---------------------------------------------------------------------------\n    15→// Constants\n    16→// ---------------------------------------------------------------------------\n    17→\n    18→const MAX_RETRIES = 5;\n    19→const BASE_DELAY_MS = 2_000;\n    20→const MAX_DELAY_MS = 30_000;\n    21→\n    22→/** resolve_deadline: i64 at offset 156 in CoinflipMatch account data */\n    23→const RESOLVE_DEADLINE_OFFSET = 156;\n    24→\n    25→// ---------------------------------------------------------------------------\n    26→// Types\n    27→// ---------------------------------------------------------------------------\n    28→\n    29→export interface RetrySettlerDeps {\n    30→  db: Db;\n    31→  connection: Connection;\n    32→  settleMatch: (pda: string) => Promise<SettleResult>;\n    33→}\n    34→\n    35→interface RetryState {\n    36→  attempts: number;\n    37→  /** Timestamp (ms) at which next retry is allowed. */\n    38→  nextRetryAt: number;\n    39→}\n    40→\n    41→export interface RetrySettler {\n    42→  /**\n    43→   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n    44→   * failure tracking, and resolve_deadline timeout detection.\n    45→   *\n    46→   * Safe to call repeatedly — skips if a retry is scheduled but not yet due,\n    47→   * or if the PDA has already been marked as permanently failed / timed out.\n    48→   */\n    49→  attemptSettle(pda: string): Promise<void>;\n    50→}\n    51→\n    52→// ---------------------------------------------------------------------------\n    53→// Factory\n    54→// ---------------------------------------------------------------------------\n    55→\n    56→export function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n    57→  const { db, connection, settleMatch } = deps;\n    58→\n    59→  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n    60→  const retryStates = new Map<string, RetryState>();\n    61→\n    62→  /** PDAs that hit a permanent (non-retryable) error. */\n    63→  const failedPdas = new Set<string>();\n    64→\n    65→  /** PDAs whose resolve_deadline has passed. */\n    66→  const timeoutPdas = new Set<string>();\n    67→\n    68→  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n    69→  function getDelay(attempt: number): number {\n    70→    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n    71→  }\n    72→\n    73→  /**\n    74→   * Check whether the on-chain resolve_deadline has passed for a match.\n    75→   * Returns true if the deadline is in the past (timeout refund eligible).\n    76→   */\n    77→  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    78→    try {\n    79→      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n    80→      if (!accountInfo) return true; // account gone — treat as expired\n    81→      const data = Buffer.from(accountInfo.data);\n    82→      if (data.length < RESOLVE_DEADLINE_OFFSET + 8) return false;\n    83→      const resolveDeadline = Number(data.readBigInt64LE(RESOLVE_DEADLINE_OFFSET));\n    84→      if (resolveDeadline <= 0) return false; // not set yet\n    85→      const nowUnix = Math.floor(Date.now() / 1000);\n    86→      return nowUnix >= resolveDeadline;\n    87→    } catch {\n    88→      return false; // can't read — don't assume timeout\n    89→    }\n    90→  }\n    91→\n    92→  async function attemptSettle(pda: string): Promise<void> {\n    93→    // Skip permanently failed or timed-out PDAs\n    94→    if (failedPdas.has(pda) || timeoutPdas.has(pda)) return;\n    95→\n    96→    const state = retryStates.get(pda);\n    97→\n    98→    // If a retry is scheduled but not yet due, skip\n    99→    if (state && Date.now() < state.nextRetryAt) return;\n   100→\n   101→    // If max retries exceeded, mark as failed\n   102→    if (state && state.attempts >= MAX_RETRIES) {\n   103→      failedPdas.add(pda);\n   104→      retryStates.delete(pda);\n   105→      await db.insertOperatorEvent(pda, \"settle_failed\", {\n   106→        reason: \"max retries exceeded\",\n   107→        attempts: state.attempts,\n   108→      });\n   109→      console.error(\n   110→        JSON.stringify({\n   111→          level: \"error\",\n   112→          msg: \"settle failed — max retries exceeded\",\n   113→          pda,\n   114→          attempts: state.attempts,\n   115→        }),\n   116→      );\n   117→      return;\n   118→    }\n   119→\n   120→    // Check resolve_deadline before attempting\n   121→    if (await isResolveDeadlinePassed(pda)) {\n   122→      timeoutPdas.add(pda);\n   123→      retryStates.delete(pda);\n   124→      await db.insertOperatorEvent(pda, \"timeout_detected\", {\n   125→        reason: \"resolve_deadline passed without successful settlement\",\n   126→        attempts: state?.attempts ?? 0,\n   127→      });\n   128→      console.warn(\n   129→        JSON.stringify({\n   130→          level: \"warn\",\n   131→          msg: \"resolve deadline passed, stopping settlement attempts\",\n   132→          pda,\n   133→        }),\n   134→      );\n   135→      return;\n   136→    }\n   137→\n   138→    try {\n   139→      const result = await settleMatch(pda);\n   140→\n   141→      // Success — clear retry state\n   142→      retryStates.delete(pda);\n   143→      console.log(\n   144→        JSON.stringify({\n   145→          level: \"info\",\n   146→          msg: \"match settled\",\n   147→          pda,\n   148→          tx: result.txSignature,\n   149→          resultSide: result.resultSide,\n   150→          winner: result.winner,\n   151→        }),\n   152→      );\n   153→    } catch (err) {\n   154→      if (err instanceof PermanentSettleError) {\n   155→        // Permanent failure — do not retry\n   156→        failedPdas.add(pda);\n   157→        retryStates.delete(pda);\n   158→        await db.insertOperatorEvent(pda, \"settle_failed\", {\n   159→          reason: err.message,\n   160→          permanent: true,\n   161→        });\n   162→        console.error(\n   163→          JSON.stringify({\n   164→            level: \"error\",\n   165→            msg: \"settle permanently failed\",\n   166→            pda,\n   167→            error: err.message,\n   168→          }),\n   169→        );\n   170→      } else {\n   171→        // Transient failure — schedule retry with exponential backoff\n   172→        const attempts = (state?.attempts ?? 0) + 1;\n   173→        const delay = getDelay(attempts - 1);\n   174→\n   175→        retryStates.set(pda, {\n   176→          attempts,\n   177→          nextRetryAt: Date.now() + delay,\n   178→        });\n   179→\n   180→        await db.insertOperatorEvent(pda, \"settle_retried\", {\n   181→          attempt: attempts,\n   182→          nextRetryInMs: delay,\n   183→          error: err instanceof Error ? err.message : String(err),\n   184→        });\n   185→        console.warn(\n   186→          JSON.stringify({\n   187→            level: \"warn\",\n   188→            msg: \"settle transient failure, scheduling retry\",\n   189→            pda,\n   190→            attempt: attempts,\n   191→            nextRetryInMs: delay,\n   192→            error: err instanceof Error ? err.message : String(err),\n   193→          }),\n   194→        );\n   195→      }\n   196→    }\n   197→  }\n   198→\n   199→  return { attemptSettle };\n   200→}\n   201→"}]},"parent_tool_use_id":null,"session_id":"c4dc42e4-d0e2-427a-a9ba-b27b08b0ec0d","uuid":"c7003cc3-38d0-4850-aae2-996ccc67366a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/retry.ts","content":"/**\n * Settlement retry logic — wraps settleMatch with exponential backoff\n * for transient failures and proper handling of permanent failures.\n *\n * Called by the settlement worker's onSettleReady callback on each poll\n * cycle for every locked match whose target_slot has been reached.\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport type { SettleResult } from \"./settle-tx.js\";\nimport { PermanentSettleError } from \"./settle-tx.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst MAX_RETRIES = 5;\nconst BASE_DELAY_MS = 2_000;\nconst MAX_DELAY_MS = 30_000;\n\n/** resolve_deadline: i64 at offset 156 in CoinflipMatch account data */\nconst RESOLVE_DEADLINE_OFFSET = 156;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface RetrySettlerDeps {\n  db: Db;\n  connection: Connection;\n  settleMatch: (pda: string) => Promise<SettleResult>;\n}\n\ninterface RetryState {\n  attempts: number;\n  /** Timestamp (ms) at which next retry is allowed. */\n  nextRetryAt: number;\n}\n\nexport interface RetrySettler {\n  /**\n   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n   * failure tracking, and resolve_deadline timeout detection.\n   *\n   * Safe to call repeatedly — skips if a retry is scheduled but not yet due,\n   * or if the PDA has already been marked as permanently failed / timed out.\n   */\n  attemptSettle(pda: string): Promise<void>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n  const { db, connection, settleMatch } = deps;\n\n  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n  const retryStates = new Map<string, RetryState>();\n\n  /** PDAs that hit a permanent (non-retryable) error. */\n  const failedPdas = new Set<string>();\n\n  /** PDAs whose resolve_deadline has passed. */\n  const timeoutPdas = new Set<string>();\n\n  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n  function getDelay(attempt: number): number {\n    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n  }\n\n  /**\n   * Check whether the on-chain resolve_deadline has passed for a match.\n   * Returns true if the deadline is in the past (timeout refund eligible).\n   */\n  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    try {\n      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n      if (!accountInfo) return true; // account gone — treat as expired\n      const data = Buffer.from(accountInfo.data);\n      if (data.length < RESOLVE_DEADLINE_OFFSET + 8) return false;\n      const resolveDeadline = Number(data.readBigInt64LE(RESOLVE_DEADLINE_OFFSET));\n      if (resolveDeadline <= 0) return false; // not set yet\n      const nowUnix = Math.floor(Date.now() / 1000);\n      return nowUnix >= resolveDeadline;\n    } catch {\n      return false; // can't read — don't assume timeout\n    }\n  }\n\n  async function attemptSettle(pda: string): Promise<void> {\n    // Skip permanently failed or timed-out PDAs\n    if (failedPdas.has(pda) || timeoutPdas.has(pda)) return;\n\n    const state = retryStates.get(pda);\n\n    // If a retry is scheduled but not yet due, skip\n    if (state && Date.now() < state.nextRetryAt) return;\n\n    // If max retries exceeded, mark as failed\n    if (state && state.attempts >= MAX_RETRIES) {\n      failedPdas.add(pda);\n      retryStates.delete(pda);\n      await db.insertOperatorEvent(pda, \"settle_failed\", {\n        reason: \"max retries exceeded\",\n        attempts: state.attempts,\n      });\n      console.error(\n        JSON.stringify({\n          level: \"error\",\n          msg: \"settle failed — max retries exceeded\",\n          pda,\n          attempts: state.attempts,\n        }),\n      );\n      return;\n    }\n\n    // Check resolve_deadline before attempting\n    if (await isResolveDeadlinePassed(pda)) {\n      timeoutPdas.add(pda);\n      retryStates.delete(pda);\n      await db.insertOperatorEvent(pda, \"timeout_detected\", {\n        reason: \"resolve_deadline passed without successful settlement\",\n        attempts: state?.attempts ?? 0,\n      });\n      console.warn(\n        JSON.stringify({\n          level: \"warn\",\n          msg: \"resolve deadline passed, stopping settlement attempts\",\n          pda,\n        }),\n      );\n      return;\n    }\n\n    try {\n      const result = await settleMatch(pda);\n\n      // Success — clear retry state\n      retryStates.delete(pda);\n      console.log(\n        JSON.stringify({\n          level: \"info\",\n          msg: \"match settled\",\n          pda,\n          tx: result.txSignature,\n          resultSide: result.resultSide,\n          winner: result.winner,\n        }),\n      );\n    } catch (err) {\n      if (err instanceof PermanentSettleError) {\n        // Permanent failure — do not retry\n        failedPdas.add(pda);\n        retryStates.delete(pda);\n        await db.insertOperatorEvent(pda, \"settle_failed\", {\n          reason: err.message,\n          permanent: true,\n        });\n        console.error(\n          JSON.stringify({\n            level: \"error\",\n            msg: \"settle permanently failed\",\n            pda,\n            error: err.message,\n          }),\n        );\n      } else {\n        // Transient failure — schedule retry with exponential backoff\n        const attempts = (state?.attempts ?? 0) + 1;\n        const delay = getDelay(attempts - 1);\n\n        retryStates.set(pda, {\n          attempts,\n          nextRetryAt: Date.now() + delay,\n        });\n\n        await db.insertOperatorEvent(pda, \"settle_retried\", {\n          attempt: attempts,\n          nextRetryInMs: delay,\n          error: err instanceof Error ? err.message : String(err),\n        });\n        console.warn(\n          JSON.stringify({\n            level: \"warn\",\n            msg: \"settle transient failure, scheduling retry\",\n            pda,\n            attempt: attempts,\n            nextRetryInMs: delay,\n            error: err instanceof Error ? err.message : String(err),\n          }),\n        );\n      }\n    }\n  }\n\n  return { attemptSettle };\n}\n","numLines":201,"startLine":1,"totalLines":201}}}
