{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017nb31TYFRoanNvWhj66Rmx","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type OperatorEventType =\n    17→  | \"secret_generated\"\n    18→  | \"tx_built\"\n    19→  | \"match_detected\"\n    20→  | \"settle_submitted\"\n    21→  | \"settle_confirmed\"\n    22→  | \"settle_failed\"\n    23→  | \"settle_retried\"\n    24→  | \"timeout_detected\";\n    25→\n    26→export interface Round {\n    27→  pda: string;\n    28→  game: string;\n    29→  creator: string;\n    30→  server_key: string;\n    31→  secret: Buffer;\n    32→  commitment: Buffer;\n    33→  tier: number;\n    34→  side: number;\n    35→  nonce: string; // bigint comes back as string from postgres driver\n    36→  phase: RoundPhase;\n    37→  target_slot: string | null;\n    38→  settle_tx: string | null;\n    39→  settle_attempts: number;\n    40→  result_hash: Buffer | null;\n    41→  result_side: number | null;\n    42→  winner: string | null;\n    43→  created_at: Date;\n    44→  updated_at: Date;\n    45→}\n    46→\n    47→export interface InsertRoundParams {\n    48→  pda: string;\n    49→  game: string;\n    50→  creator: string;\n    51→  serverKey: string;\n    52→  secret: Buffer;\n    53→  commitment: Buffer;\n    54→  tier: number;\n    55→  side: number;\n    56→  nonce: bigint | number;\n    57→  phase: RoundPhase;\n    58→}\n    59→\n    60→export interface OperatorEvent {\n    61→  id: string;\n    62→  pda: string | null;\n    63→  event_type: OperatorEventType;\n    64→  payload: unknown;\n    65→  created_at: Date;\n    66→}\n    67→\n    68→// ---------------------------------------------------------------------------\n    69→// Phase transition guard\n    70→// ---------------------------------------------------------------------------\n    71→\n    72→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n    73→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n    74→  created: [\"locked\", \"expired\"],\n    75→  locked: [\"settling\"],\n    76→  settling: [\"settled\"],\n    77→  settled: [],\n    78→  expired: [],\n    79→};\n    80→\n    81→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n    82→  const allowed = VALID_TRANSITIONS[from];\n    83→  if (!allowed.includes(to)) {\n    84→    throw new Error(\n    85→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    86→    );\n    87→  }\n    88→}\n    89→\n    90→// ---------------------------------------------------------------------------\n    91→// DB client\n    92→// ---------------------------------------------------------------------------\n    93→\n    94→export interface Db {\n    95→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n    96→  insertRound(params: InsertRoundParams): Promise<Round>;\n    97→\n    98→  /** Transition a round's phase. Enforces unidirectional state machine.\n    99→   *  Optional `updates` can set additional columns alongside the phase change. */\n   100→  updateRoundPhase(\n   101→    pda: string,\n   102→    newPhase: RoundPhase,\n   103→    updates?: Partial<\n   104→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   105→    >,\n   106→  ): Promise<Round>;\n   107→\n   108→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   109→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   110→\n   111→  /** Get all rounds matching a given phase. */\n   112→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   113→\n   114→  /** Append an operator event to the audit log. */\n   115→  insertOperatorEvent(\n   116→    pda: string | null,\n   117→    eventType: OperatorEventType,\n   118→    payload?: unknown,\n   119→  ): Promise<OperatorEvent>;\n   120→\n   121→  /** Gracefully close the connection pool. */\n   122→  close(): Promise<void>;\n   123→}\n   124→\n   125→export function createDb(databaseUrl: string): Db {\n   126→  const sql = postgres(databaseUrl);\n   127→\n   128→  return {\n   129→    async insertRound(params) {\n   130→      const rows = await sql<Round[]>`\n   131→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, tier, side, nonce, phase)\n   132→        VALUES (\n   133→          ${params.pda},\n   134→          ${params.game},\n   135→          ${params.creator},\n   136→          ${params.serverKey},\n   137→          ${params.secret},\n   138→          ${params.commitment},\n   139→          ${params.tier},\n   140→          ${params.side},\n   141→          ${Number(params.nonce)},\n   142→          ${params.phase}\n   143→        )\n   144→        RETURNING *\n   145→      `;\n   146→      return rows[0]!;\n   147→    },\n   148→\n   149→    async updateRoundPhase(pda, newPhase, updates) {\n   150→      // Fetch current phase to validate transition\n   151→      const current = await sql<Pick<Round, \"phase\">[]>`\n   152→        SELECT phase FROM rounds WHERE pda = ${pda}\n   153→      `;\n   154→\n   155→      if (current.length === 0) {\n   156→        throw new Error(`Round not found: ${pda}`);\n   157→      }\n   158→\n   159→      const currentPhase = current[0]!.phase as RoundPhase;\n   160→      assertPhaseTransition(currentPhase, newPhase);\n   161→\n   162→      // Build the update — always set phase + updated_at\n   163→      const rows = await sql<Round[]>`\n   164→        UPDATE rounds SET\n   165→          phase = ${newPhase},\n   166→          updated_at = now(),\n   167→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   168→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   169→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   170→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   171→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   172→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   173→        WHERE pda = ${pda}\n   174→        RETURNING *\n   175→      `;\n   176→\n   177→      return rows[0]!;\n   178→    },\n   179→\n   180→    async getRoundByPda(pda) {\n   181→      const rows = await sql<Round[]>`\n   182→        SELECT * FROM rounds WHERE pda = ${pda}\n   183→      `;\n   184→      return rows[0];\n   185→    },\n   186→\n   187→    async getRoundsByPhase(phase) {\n   188→      return sql<Round[]>`\n   189→        SELECT * FROM rounds WHERE phase = ${phase}\n   190→      `;\n   191→    },\n   192→\n   193→    async insertOperatorEvent(pda, eventType, payload) {\n   194→      const rows = await sql<OperatorEvent[]>`\n   195→        INSERT INTO operator_events (pda, event_type, payload)\n   196→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   197→        RETURNING *\n   198→      `;\n   199→      return rows[0]!;\n   200→    },\n   201→\n   202→    async close() {\n   203→      await sql.end();\n   204→    },\n   205→  };\n   206→}\n   207→"}]},"parent_tool_use_id":"toolu_01TrCzqohKVcSn7VVFtRWdQK","session_id":"da7de446-89c1-4a15-9d69-05c743d03aa4","uuid":"eed0ee2a-3a23-4c0c-8291-69b626467726"}
