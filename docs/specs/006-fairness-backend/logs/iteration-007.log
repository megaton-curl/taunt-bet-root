conds }),\n);\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair }),\n);","originalFile":"import { Hono } from \"hono\";\nimport { Connection } from \"@solana/web3.js\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\n\nconst config = loadConfig();\nconst db = createDb(config.databaseUrl);\nconst connection = new Connection(config.rpcUrl);\n\nconst app = new Hono();\n\n// Health check (placeholder — full implementation in a later checklist item)\napp.get(\"/health\", (c) => {\n  return c.json({ status: \"ok\", version: \"0.1.0\" });\n});\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair }),\n);\n\nconst port = config.port;\nconsole.log(`fairness-backend listening on :${port}`);\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","structuredPatch":[{"oldStart":3,"oldLines":6,"newStart":3,"newLines":7,"lines":[" import { loadConfig } from \"./config.js\";"," import { createDb } from \"./db.js\";"," import { createCoinflipRoutes } from \"./routes/create.js\";","+import { createAuthMiddleware } from \"./middleware/auth.js\";"," "," const config = loadConfig();"," const db = createDb(config.databaseUrl);"]},{"oldStart":15,"oldLines":6,"newStart":16,"newLines":12,"lines":["   return c.json({ status: \"ok\", version: \"0.1.0\" });"," });"," ","+// Auth middleware — verifies wallet Ed25519 signatures on POST requests","+app.use(","+  \"/fairness/*\",","+  createAuthMiddleware({ clockSkewSeconds: config.authClockSkewSeconds }),","+);","+"," // Coinflip fairness routes"," app.route(","   \"/fairness/coinflip\","]}],"userModified":false,"replaceAll":false}}
