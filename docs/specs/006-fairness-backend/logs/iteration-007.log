{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0143QJPDdHesi28iyZeVPDoA","type":"tool_result","content":"     1→import { hmac } from \"@noble/hashes/hmac\";\n     2→import { sha256 } from \"@noble/hashes/sha256\";\n     3→import { bytesToHex, hexToBytes } from \"@noble/hashes/utils\";\n     4→\n     5→/**\n     6→ * Convert a hash to a crash point using the standard algorithm\n     7→ * Produces values from 1.00 to theoretical infinity (but typically < 100x)\n     8→ */\n     9→export function hashToCrashPoint(hashHex: string): number {\n    10→  // Take first 52 bits (13 hex chars)\n    11→  const h = parseInt(hashHex.substring(0, 13), 16);\n    12→\n    13→  // 2^52 = 4503599627370496\n    14→  const e = Math.pow(2, 52);\n    15→\n    16→  // This formula ensures:\n    17→  // - Result >= 1.00\n    18→  // - ~50% chance of crashing at or below 2x\n    19→  // - Expected value is balanced\n    20→  const result = Math.floor((100 * e - h) / (e - h)) / 100;\n    21→\n    22→  return Math.max(1.0, result);\n    23→}\n    24→\n    25→/**\n    26→ * Compute crash point from server seed and public seed\n    27→ * Uses HMAC-SHA256 for deterministic, verifiable randomness\n    28→ */\n    29→export function computeCrashPoint(\n    30→  serverSeed: string,\n    31→  publicSeed: string,\n    32→  roundId: string,\n    33→  gameId: string = \"crash\"\n    34→): number {\n    35→  const serverSeedBytes = hexToBytes(serverSeed);\n    36→  const message = `${publicSeed}:${roundId}:${gameId}`;\n    37→  const messageBytes = new TextEncoder().encode(message);\n    38→\n    39→  const hash = hmac(sha256, serverSeedBytes, messageBytes);\n    40→  const hashHex = bytesToHex(hash);\n    41→\n    42→  return hashToCrashPoint(hashHex);\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_01MZeN5x941SN9UtJQefNzkt","session_id":"612240eb-bf1a-44cf-9ae4-1551e7c0525e","uuid":"60b0c9b2-42e5-4c34-bcea-423b56225dfb"}
