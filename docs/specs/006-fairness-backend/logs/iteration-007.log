{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ShwTyX1u2RYbrqiSMsDhaS","type":"tool_result","content":"     1→/** Shared crypto utilities for coinflip commit-reveal. */\n     2→\n     3→/** Convert a byte array to a hex string. */\n     4→export function bytesToHex(bytes: number[] | Uint8Array): string {\n     5→  return Array.from(bytes)\n     6→    .map((b) => b.toString(16).padStart(2, \"0\"))\n     7→    .join(\"\");\n     8→}\n     9→\n    10→/** Convert a hex string to a Uint8Array. */\n    11→export function hexToBytes(hex: string): Uint8Array {\n    12→  const bytes = new Uint8Array(hex.length / 2);\n    13→  for (let i = 0; i < hex.length; i += 2) {\n    14→    bytes[i / 2] = parseInt(hex.slice(i, i + 2), 16);\n    15→  }\n    16→  return bytes;\n    17→}\n    18→\n    19→/** SHA-256 hash using Web Crypto API (browser-compatible). */\n    20→export async function sha256(data: Uint8Array): Promise<Uint8Array> {\n    21→  const hashBuffer = await crypto.subtle.digest(\"SHA-256\", data as unknown as ArrayBuffer);\n    22→  return new Uint8Array(hashBuffer);\n    23→}\n    24→"}]},"parent_tool_use_id":"toolu_01MZeN5x941SN9UtJQefNzkt","session_id":"612240eb-bf1a-44cf-9ae4-1551e7c0525e","uuid":"fce5404f-f82a-4e03-b0c8-485f6aa9af60"}
