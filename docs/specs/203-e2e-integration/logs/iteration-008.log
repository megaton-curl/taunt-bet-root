     </div>\n   266→                  <div className=\"coinflip-win-animation__coins\">\n   267→                    {[...Array(6)].map((_, i) => (\n   268→                      <span key={i} className=\"coinflip-win-animation__coin\" style={{ '--coin-index': i } as React.CSSProperties}>●</span>\n   269→                    ))}\n   270→                  </div>\n   271→                </div>\n   272→              )}\n   273→\n   274→              <div\n   275→                className={`coinflip-result ${\n   276→                  isWinner ? \"coinflip-result--won\" : \"coinflip-result--lost\"\n   277→                }`}\n   278→              >\n   279→                <p className=\"coinflip-result__outcome\">\n   280→                  Result: <strong\n   281→                    style={{\n   282→                      color: match.result === \"heads\" ? \"#45b058\" : \"#e09030\",\n   283→                      textShadow: `0 0 6px ${match.result === \"heads\" ? \"#45b058\" : \"#e09030\"}`\n   284→                    }}\n   285→                  >{match.result?.toUpperCase()}</strong>\n   286→                </p>\n   287→                {isWinner && (\n   288→                  <p className=\"coinflip-result__payout\">\n   289→                    Payout: <strong>{\"$\"}{match.payoutAmount.toFixed(4)}</strong>\n   290→                  </p>\n   291→                )}\n   292→              </div>\n   293→\n   294→              {/* Action buttons */}\n   295→              <div className=\"coinflip-active-match__actions\">\n   296→                {!match.claimed && onClaim && (\n   297→                  <button\n   298→                    type=\"button\"\n   299→                    className=\"coinflip-action-btn\"\n   300→                    onClick={onClaim}\n   301→                    disabled={claiming}\n   302→                  >\n   303→                    {claiming\n   304→                      ? \"Settling...\"\n   305→                      : isWinner\n   306→                        ? \"Claim Payout\"\n   307→                        : \"Settle & Return to Lobby\"}\n   308→                  </button>\n   309→                )}\n   310→                {match.claimed && (\n   311→                  <div className=\"coinflip-active-match__post-claim\">\n   312→                    {onVerify && claimTxSignature && (\n   313→                      <button\n   314→                        type=\"button\"\n   315→                        className=\"coinflip-action-btn\"\n   316→                        onClick={onVerify}\n   317→                        disabled={verifying || !!verificationResult}\n   318→                      >\n   319→                        {verifying ? \"Verifying...\" : verificationResult ? \"Verified\" : \"Verify Fairness\"}\n   320→                      </button>\n   321→                    )}\n   322→                    {onRematch && (\n   323→                      <button\n   324→                        type=\"button\"\n   325→                        className=\"coinflip-action-btn\"\n   326→                        onClick={onRematch}\n   327→                        disabled={rematching}\n   328→                      >\n   329→                        {rematching ? \"Creating...\" : \"Play Again\"}\n   330→                      </button>\n   331→                    )}\n   332→                    {onClearMatch && (\n   333→                      <button\n   334→                        type=\"button\"\n   335→                        className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   336→                        onClick={onClearMatch}\n   337→                      >\n   338→                        Back to Lobby\n   339→                      </button>\n   340→                    )}\n   341→                  </div>\n   342→                )}\n   343→              </div>\n   344→\n   345→              {/* Verification panel — shown after verifyMatch completes */}\n   346→              {verificationResult && (\n   347→                <div className=\"coinflip-verification\">\n   348→                  <h4 className=\"coinflip-verification__title\">\n   349→                    Fairness Verification\n   350→                  </h4>\n   351→                  <div className={`coinflip-verification__badge ${verificationResult.verified ? \"coinflip-verification__badge--verified\" : \"coinflip-verification__badge--failed\"}`}>\n   352→                    {verificationResult.verified ? \"Verified\" : \"Failed\"}\n   353→                  </div>\n   354→                  <div className=\"coinflip-verification__rows\">\n   355→                    <div className=\"coinflip-verification__row\">\n   356→                      <span>Claim TX</span>\n   357→                      <span className=\"coinflip-verification__hash\" title={claimTxSignature ?? \"\"}>\n   358→                        {claimTxSignature ? `${claimTxSignature.slice(0, 8)}...${claimTxSignature.slice(-8)}` : \"—\"}\n   359→                      </span>\n   360→                    </div>\n   361→                    <div className=\"coinflip-verification__row\">\n   362→                      <span>Randomness</span>\n   363→                      <span className=\"coinflip-verification__hash\" title={verificationResult.randomnessHex}>\n   364→                        {verificationResult.randomnessHex.slice(0, 16)}...\n   365→                      </span>\n   366→                    </div>\n   367→                    <div className=\"coinflip-verification__row\">\n   368→                      <span>Derived Result</span>\n   369→                      <span className={`side-${verificationResult.derivedResult}`}>\n   370→                        {verificationResult.derivedResult.toUpperCase()}\n   371→                      </span>\n   372→                    </div>\n   373→                    <div className=\"coinflip-verification__row\">\n   374→                      <span>Winner</span>\n   375→                      <span className=\"coinflip-verification__hash\" title={verificationResult.winner}>\n   376→                        {verificationResult.winner.slice(0, 4)}...{verificationResult.winner.slice(-4)}\n   377→                      </span>\n   378→                    </div>\n   379→                    <div className=\"coinflip-verification__row\">\n   380→                      <span>VRF Fulfilled</span>\n   381→                      <span className={verificationResult.vrfFulfilled ? \"coinflip-verification__check\" : \"coinflip-verification__cross\"}>\n   382→                        {verificationResult.vrfFulfilled ? \"Yes\" : \"No\"}\n   383→                      </span>\n   384→                    </div>\n   385→                  </div>\n   386→                  <a href=\"/fairness\" className=\"coinflip-verification__link\">\n   387→                    Full Verification Page\n   388→                  </a>\n   389→                </div>\n   390→              )}\n   391→\n   392→            </>\n   393→          )}\n   394→        </div>\n   395→      )}\n   396→    </div>\n   397→  );\n   398→}\n   399→"}]},"parent_tool_use_id":"toolu_01PB93kLiFJtuA7bXxssvkB7","session_id":"b0a0dcb3-1758-4eec-aea3-903a9f33143b","uuid":"ae730fb6-fada-468d-85ba-23681c813d5e"}
