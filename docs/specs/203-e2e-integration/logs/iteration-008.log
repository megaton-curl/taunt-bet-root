{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H5t93q8SEo5pnbYp5LZspU","type":"tool_result","content":"     1→import type { CoinSide } from \"../types\";\n     2→\n     3→interface CoinSideSelectorProps {\n     4→  selectedSide: CoinSide | null;\n     5→  onSelect: (side: CoinSide) => void;\n     6→  disabled?: boolean;\n     7→  lockedSide?: CoinSide; // For P2 who gets auto-assigned\n     8→}\n     9→\n    10→// Pixel art RNG text component\n    11→function RNGPixelArt({ variant }: { variant: \"heads\" | \"tails\" }) {\n    12→  return (\n    13→    <div className={`rng-pixel-art rng-pixel-art--${variant}`}>\n    14→      <span className=\"rng-pixel-art__text\">RNG</span>\n    15→    </div>\n    16→  );\n    17→}\n    18→\n    19→export function CoinSideSelector({\n    20→  selectedSide,\n    21→  onSelect,\n    22→  disabled = false,\n    23→  lockedSide,\n    24→}: CoinSideSelectorProps) {\n    25→  const isLocked = lockedSide !== undefined;\n    26→\n    27→  return (\n    28→    <div className=\"coinflip-side-selector\">\n    29→      <button\n    30→        type=\"button\"\n    31→        className={`coinflip-side-btn coinflip-side-btn--heads ${\n    32→          selectedSide === \"heads\" ? \"coinflip-side-btn--selected\" : \"\"\n    33→        } ${lockedSide === \"heads\" ? \"coinflip-side-btn--locked\" : \"\"}`}\n    34→        onClick={() => !disabled && !isLocked && onSelect(\"heads\")}\n    35→        disabled={disabled || isLocked}\n    36→      >\n    37→        <div className=\"coinflip-side-btn__icon coinflip-side-btn__icon--heads\">\n    38→          <img src=\"/sprites/green-shield.png\" alt=\"Heads\" className=\"coinflip-shield-sprite\" />\n    39→        </div>\n    40→        <span className=\"coinflip-side-btn__label\">Heads</span>\n    41→      </button>\n    42→\n    43→      <button\n    44→        type=\"button\"\n    45→        className={`coinflip-side-btn coinflip-side-btn--tails ${\n    46→          selectedSide === \"tails\" ? \"coinflip-side-btn--selected\" : \"\"\n    47→        } ${lockedSide === \"tails\" ? \"coinflip-side-btn--locked\" : \"\"}`}\n    48→        onClick={() => !disabled && !isLocked && onSelect(\"tails\")}\n    49→        disabled={disabled || isLocked}\n    50→      >\n    51→        <div className=\"coinflip-side-btn__icon coinflip-side-btn__icon--tails\">\n    52→          <img src=\"/sprites/red-shield.png\" alt=\"Tails\" className=\"coinflip-shield-sprite\" />\n    53→        </div>\n    54→        <span className=\"coinflip-side-btn__label\">Tails</span>\n    55→      </button>\n    56→    </div>\n    57→  );\n    58→}\n    59→\n    60→export { RNGPixelArt };\n    61→"}]},"parent_tool_use_id":"toolu_01PB93kLiFJtuA7bXxssvkB7","session_id":"b0a0dcb3-1758-4eec-aea3-903a9f33143b","uuid":"4b46ab37-9c7f-43c2-a8be-ccb9682813a4"}
