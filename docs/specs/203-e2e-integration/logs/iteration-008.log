{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G27jd6ss5LiUcUrdkeqeQk","type":"tool_result","content":"     1→[package]\n     2→name = \"coinflip\"\n     3→version = \"0.1.0\"\n     4→edition = \"2021\"\n     5→\n     6→[lib]\n     7→crate-type = [\"cdylib\", \"lib\"]\n     8→name = \"coinflip\"\n     9→\n    10→[dependencies]\n    11→anchor-lang = { workspace = true }\n    12→rng-shared = { workspace = true }\n    13→platform = { path = \"../platform\", features = [\"cpi\"] }\n    14→orao-solana-vrf = { workspace = true }\n    15→\n    16→[features]\n    17→no-entrypoint = []\n    18→no-idl = []\n    19→no-log-ix-name = []\n    20→cpi = [\"no-entrypoint\"]\n    21→default = [\"mock-vrf\"]\n    22→mock-vrf = [\"rng-shared/mock-vrf\"]\n    23→idl-build = [\"anchor-lang/idl-build\"]\n    24→"}]},"parent_tool_use_id":"toolu_01EKVJc8H8sfxNcz3oBUmfjQ","session_id":"b0a0dcb3-1758-4eec-aea3-903a9f33143b","uuid":"7fc06abb-d01b-40c9-8b98-b1feed84fe74"}
