{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BiFuVB6EqUfZUqiMczNs6f","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HeSqiaSsECjYm6DwQRw8zU","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/lifecycle.spec.ts","content":"/**\n * Local lifecycle E2E test: create → join → resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. The local validator has mock-VRF enabled,\n * and the randomness account is pre-loaded with fulfilled data\n * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n *\n * Prerequisites (handled by localnet-bootstrap.sh):\n * - solana-test-validator running with coinflip + platform programs\n * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport { fundTestWallets, PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  // Fund test wallets and initialize program configs\n  await fundTestWallets();\n  await initializeLocalnet();\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n  playerAPage,\n  playerBPage,\n}) => {\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 10_000 });\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 15_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // 4. Both players wait for the result.\n  //    VRF is pre-fulfilled (HEADS) → creator (Player A) wins.\n  //    The frontend polls every 5s for VRF fulfillment, then shows\n  //    a 3s flip animation before the \"complete\" phase.\n  const [resultA, resultB] = await Promise.all([\n    po.waitForResult(playerAPage, 30_000),\n    po.waitForResult(playerBPage, 30_000),\n  ]);\n\n  // 5. Verify results: Player A (creator, chose HEADS) should win\n  expect(resultA).toBe(\"won\");\n  expect(resultB).toBe(\"lost\");\n\n  // 6. Player A (winner) claims payout\n  await po.claimOrSettle(playerAPage);\n\n  // Player A sees \"Back to Lobby\" after successful claim\n  await expect(\n    playerAPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible();\n\n  // 7. Player A returns to lobby\n  await po.backToLobby(playerAPage);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":327,"cache_read_input_tokens":129359,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":327},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b0a0dcb3-1758-4eec-aea3-903a9f33143b","uuid":"ede5152c-f6da-4e28-82fd-2db30876703f"}
