Profile(\n  t: TestContext,\n  program: Program<Platform>,\n  player: PublicKey\n) {\n  const profilePda = getPlayerProfilePda(player);\n  await program.methods\n    .createPlayerProfile()\n    .accounts({\n      player,\n      profile: profilePda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function setupPlatform(t: TestContext) {\n  await initPlatform(t);\n  await createPlayerProfile(t, t.platformProgram, t.creator);\n  await createPlayerProfile(\n    t,\n    t.opponentPlatformProgram,\n    t.opponent.publicKey\n  );\n}\n\nasync function createMatch(\n  t: TestContext,\n  tier = TIER_IRON,\n  side = SIDE_HEADS\n) {\n  await t.creatorProgram.methods\n    .createMatch(tier, side)\n    .accounts({\n      creator: t.creator,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function joinMatch(t: TestContext) {\n  await t.opponentProgram.methods\n    .joinMatch()\n    .accounts({\n      opponent: t.opponent.publicKey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      oraoProgram: t.mockOraoProgram.publicKey,\n      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n      oraoTreasury: t.mockOraoTreasury.publicKey,\n      oraoRandom: t.mockRandomness.publicKey,\n      systemProgram: SystemProgram.programId,\n    })\n    .rpc();\n}\n\nasync function claimPayout(\n  t: TestContext,\n  callerProgram: Program<Coinflip>,\n  callerPubkey: PublicKey\n) {\n  await callerProgram.methods\n    .claimPayout()\n    .accounts({\n      caller: callerPubkey,\n      coinflipMatch: t.matchPda,\n      config: t.configPda,\n      treasury: t.treasury.publicKey,\n      creator: t.creator,\n      opponent: t.opponent.publicKey,\n      randomnessAccount: t.mockRandomness.publicKey,\n      creatorProfile: t.creatorProfilePda,\n      opponentProfile: t.opponentProfilePda,\n      platformProgram: PLATFORM_PROGRAM_ID,\n      systemProgram: SystemProg