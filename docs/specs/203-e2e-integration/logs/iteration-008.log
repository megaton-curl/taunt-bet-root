{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YQ2xMTtAR6a9WxbbgVZwta","type":"tool_result","content":"     1→[toolchain]\n     2→anchor_version = \"0.32.1\"\n     3→\n     4→[features]\n     5→resolution = true\n     6→skip-lint = false\n     7→\n     8→[programs.localnet]\n     9→coinflip = \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n    10→platform = \"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n    11→\n    12→[programs.devnet]\n    13→coinflip = \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n    14→platform = \"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n    15→\n    16→[registry]\n    17→url = \"https://api.apr.dev\"\n    18→\n    19→[provider]\n    20→cluster = \"Localnet\"\n    21→wallet = \"~/.config/solana/id.json\"\n    22→\n    23→[scripts]\n    24→test = \"pnpm exec mocha --require tsx/cjs -t 1000000 tests/**/*.ts\"\n    25→"}]},"parent_tool_use_id":"toolu_01LSyZ9Lz3n3Z9ZghgA4zcQo","session_id":"b0a0dcb3-1758-4eec-aea3-903a9f33143b","uuid":"c678b5e8-ba5d-4176-a525-3a76a163be91"}
