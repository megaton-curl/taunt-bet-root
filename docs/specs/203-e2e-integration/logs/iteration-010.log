createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Verify active match is in waiting state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 10_000 });\n\n  // On-chain: verify match PDA exists in waiting phase\n  const { matchPda } = await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    0, // iron tier\n    0, // heads\n  );\n\n  // Balance after create should be lower (entry + rent + tx fee)\n  const balanceAfterCreate = await getBalanceLamports(\n    connection,\n    PLAYER_A.publicKey,\n  );\n  expect(balanceAfterCreate).toBeLessThan(balanceBefore);\n\n  // 2. Cancel the match\n  await po.cancelMatch(playerAPage);\n\n  // 3. Verify lobby is visible again and the match is gone\n  await po.waitForLobby(playerAPage);\n  await po.assertLobbyEmpty(playerAPage);\n\n  // On-chain: verify match PDA is closed\n  await assertMatchClosed(connection, matchPda);\n\n  // 4. Verify refund: balance after cancel should recover (entry + rent returned)\n  const balanceAfterCancel = await getBalanceLamports(\n    connection,\n    PLAYER_A.publicKey,\n  );\n  // Balance should be higher than after create (got refund)\n  expect(balanceAfterCancel).toBeGreaterThan(balanceAfterCreate);\n  // Net cost should be minimal — just transaction fees for create + cancel\n  // (typically ~10k lamports each, well under 0.01 SOL = 10M lamports)\n  const netCost = balanceBefore - balanceAfterCancel;\n  expect(netCost).toBeLessThan(10_000_000);\n\n  // 5. Recreate: creator can immediately create a new match after cancellation\n  await po.createMatch(playerAPage, \"iron\", \"tails\");\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 10_000 });\n\n  // On-chain: verify new match PDA exists (same PDA address, new side)\n  await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    0, // iron tier\n    1, // tails (different from first match)\n  );\n\n  // Clean up: cancel