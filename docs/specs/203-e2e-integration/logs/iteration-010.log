{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015QgYWFJEqPdRpevmJLF1H2","type":"tool_result","content":"     1→/**\n     2→ * Local lifecycle E2E test: create → join → resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. The local validator has mock-VRF enabled,\n     6→ * and the randomness account is pre-loaded with fulfilled data\n     7→ * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n     8→ *\n     9→ * Prerequisites (handled by localnet-bootstrap.sh):\n    10→ * - solana-test-validator running with coinflip + platform programs\n    11→ * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n    12→ */\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import { fundTestWallets, PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    16→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    17→import {\n    18→  assertMatchCreated,\n    19→  assertMatchClosed,\n    20→  assertTreasuryFee,\n    21→  assertPlayerProfileDelta,\n    22→  snapshotBalance,\n    23→  snapshotPlayerProfile,\n    24→  getTreasuryAddress,\n    25→  calculateExpectedFee,\n    26→} from \"./helpers/on-chain\";\n    27→\n    28→// ── Suite setup ────────────────────────────────────────────────────────\n    29→\n    30→test.beforeAll(async () => {\n    31→  // Fund test wallets and initialize program configs\n    32→  await fundTestWallets();\n    33→  await initializeLocalnet();\n    34→});\n    35→\n    36→// ── Full lifecycle test ────────────────────────────────────────────────\n    37→\n    38→test(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n    39→  playerAPage,\n    40→  playerBPage,\n    41→  connection,\n    42→}) => {\n    43→  // On-chain constants for iron tier\n    44→  const TIER_IRON = 0;\n    45→  const SIDE_HEADS = 0;\n    46→  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n    47→\n    48→  // Track console errors in both contexts\n    49→  const consoleA = po.trackConsoleErrors(playerAPage);\n    50→  const consoleB = po.trackConsoleErrors(playerBPage);\n    51→\n    52→  // 1. Player A navigates and creates a match (iron tier, heads)\n    53→  await po.navigateToCoinflip(playerAPage);\n    54→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n    55→\n    56→  // Player A should see the active match in \"waiting\" state\n    57→  await expect(\n    58→    playerAPage.locator(po.sel.activeMatchWaiting),\n    59→  ).toBeVisible({ timeout: 10_000 });\n    60→\n    61→  // ── On-chain: verify match PDA after creation ──\n    62→  const { matchPda } = await assertMatchCreated(\n    63→    connection,\n    64→    PLAYER_A.publicKey,\n    65→    TIER_IRON,\n    66→    SIDE_HEADS,\n    67→  );\n    68→\n    69→  // 2. Player B navigates (after match is created) and sees it in the lobby\n    70→  await po.navigateToCoinflip(playerBPage);\n    71→  await po.waitForLobbyMatch(playerBPage, 15_000);\n    72→\n    73→  // 3. Player B joins the match\n    74→  await po.joinMatch(playerBPage);\n    75→\n    76→  // ── On-chain: snapshot treasury + profiles before resolution/claim ──\n    77→  const treasury = await getTreasuryAddress(connection);\n    78→  const treasuryBefore = await snapshotBalance(connection, treasury);\n    79→  const profileABefore = await snapshotPlayerProfile(connection, PLAYER_A.publicKey);\n    80→  const profileBBefore = await snapshotPlayerProfile(connection, PLAYER_B.publicKey);\n    81→\n    82→  // 4. Both players wait for the result.\n    83→  //    VRF is pre-fulfilled (HEADS) → creator (Player A) wins.\n    84→  //    The frontend polls every 5s for VRF fulfillment, then shows\n    85→  //    a 3s flip animation before the \"complete\" phase.\n    86→  const [resultA, resultB] = await Promise.all([\n    87→    po.waitForResult(playerAPage, 30_000),\n    88→    po.waitForResult(playerBPage, 30_000),\n    89→  ]);\n    90→\n    91→  // 5. Verify results: Player A (creator, chose HEADS) should win\n    92→  expect(resultA).toBe(\"won\");\n    93→  expect(resultB).toBe(\"lost\");\n    94→\n    95→  // 6. Player A (winner) claims payout\n    96→  await po.claimOrSettle(playerAPage);\n    97→\n    98→  // Player A sees \"Back to Lobby\" after successful claim\n    99→  await expect(\n   100→    playerAPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   101→  ).toBeVisible();\n   102→\n   103→  // ── On-chain: verify match PDA is closed after claim ──\n   104→  await assertMatchClosed(connection, matchPda);\n   105→\n   106→  // ── On-chain: verify treasury received the 3% fee ──\n   107→  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n   108→\n   109→  // ── On-chain: verify player profile updates ──\n   110→  const { payout } = calculateExpectedFee(ENTRY_AMOUNT);\n   111→\n   112→  // Player A (winner): +1 game, +1 win, wagered entry, won payout\n   113→  await assertPlayerProfileDelta(connection, PLAYER_A.publicKey, profileABefore, {\n   114→    totalGames: 1,\n   115→    wins: 1,\n   116→    totalWagered: ENTRY_AMOUNT,\n   117→    totalWon: payout,\n   118→  });\n   119→\n   120→  // Player B (loser): +1 game, +0 wins, wagered entry, won nothing\n   121→  await assertPlayerProfileDelta(connection, PLAYER_B.publicKey, profileBBefore, {\n   122→    totalGames: 1,\n   123→    wins: 0,\n   124→    totalWagered: ENTRY_AMOUNT,\n   125→    totalWon: 0,\n   126→  });\n   127→\n   128→  // 7. Player A returns to lobby\n   129→  await po.backToLobby(playerAPage);\n   130→\n   131→  // No unhandled console errors in either context\n   132→  consoleA.assertClean();\n   133→  consoleB.assertClean();\n   134→});\n   135→"}]},"parent_tool_use_id":null,"session_id":"4693177a-8d7b-4a03-b79e-8bfa2852241e","uuid":"e7407428-bbf2-42de-a2b8-18cda77d89e4","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/lifecycle.spec.ts","content":"/**\n * Local lifecycle E2E test: create → join → resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. The local validator has mock-VRF enabled,\n * and the randomness account is pre-loaded with fulfilled data\n * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n *\n * Prerequisites (handled by localnet-bootstrap.sh):\n * - solana-test-validator running with coinflip + platform programs\n * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport { fundTestWallets, PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\nimport {\n  assertMatchCreated,\n  assertMatchClosed,\n  assertTreasuryFee,\n  assertPlayerProfileDelta,\n  snapshotBalance,\n  snapshotPlayerProfile,\n  getTreasuryAddress,\n  calculateExpectedFee,\n} from \"./helpers/on-chain\";\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  // Fund test wallets and initialize program configs\n  await fundTestWallets();\n  await initializeLocalnet();\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // On-chain constants for iron tier\n  const TIER_IRON = 0;\n  const SIDE_HEADS = 0;\n  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 10_000 });\n\n  // ── On-chain: verify match PDA after creation ──\n  const { matchPda } = await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    TIER_IRON,\n    SIDE_HEADS,\n  );\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 15_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // ── On-chain: snapshot treasury + profiles before resolution/claim ──\n  const treasury = await getTreasuryAddress(connection);\n  const treasuryBefore = await snapshotBalance(connection, treasury);\n  const profileABefore = await snapshotPlayerProfile(connection, PLAYER_A.publicKey);\n  const profileBBefore = await snapshotPlayerProfile(connection, PLAYER_B.publicKey);\n\n  // 4. Both players wait for the result.\n  //    VRF is pre-fulfilled (HEADS) → creator (Player A) wins.\n  //    The frontend polls every 5s for VRF fulfillment, then shows\n  //    a 3s flip animation before the \"complete\" phase.\n  const [resultA, resultB] = await Promise.all([\n    po.waitForResult(playerAPage, 30_000),\n    po.waitForResult(playerBPage, 30_000),\n  ]);\n\n  // 5. Verify results: Player A (creator, chose HEADS) should win\n  expect(resultA).toBe(\"won\");\n  expect(resultB).toBe(\"lost\");\n\n  // 6. Player A (winner) claims payout\n  await po.claimOrSettle(playerAPage);\n\n  // Player A sees \"Back to Lobby\" after successful claim\n  await expect(\n    playerAPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible();\n\n  // ── On-chain: verify match PDA is closed after claim ──\n  await assertMatchClosed(connection, matchPda);\n\n  // ── On-chain: verify treasury received the 3% fee ──\n  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n\n  // ── On-chain: verify player profile updates ──\n  const { payout } = calculateExpectedFee(ENTRY_AMOUNT);\n\n  // Player A (winner): +1 game, +1 win, wagered entry, won payout\n  await assertPlayerProfileDelta(connection, PLAYER_A.publicKey, profileABefore, {\n    totalGames: 1,\n    wins: 1,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: payout,\n  });\n\n  // Player B (loser): +1 game, +0 wins, wagered entry, won nothing\n  await assertPlayerProfileDelta(connection, PLAYER_B.publicKey, profileBBefore, {\n    totalGames: 1,\n    wins: 0,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: 0,\n  });\n\n  // 7. Player A returns to lobby\n  await po.backToLobby(playerAPage);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","numLines":135,"startLine":1,"totalLines":135}}}
