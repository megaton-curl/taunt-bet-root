\n    \"gaming\",\n    \"vrf\",\n    \"provably-fair\"\n  ],\n  \"license\": \"UNLICENSED\"\n}\n","structuredPatch":[{"oldStart":21,"oldLines":6,"newStart":21,"newLines":7,"lines":["     \"build:platform\": \"pnpm --filter @rng-utopia/platform build\",","     \"dev:programs\": \"cd solana && anchor build\",","     \"test:programs\": \"cd solana && anchor test --skip-local-validator --skip-deploy\",","+    \"test:e2e\": \"pnpm --filter @rng-utopia/platform test:e2e\",","     \"format\": \"prettier --write \\\"**/*.{ts,tsx,js,jsx,json,md}\\\"\",","     \"format:check\": \"prettier --check \\\"**/*.{ts,tsx,js,jsx,json,md}\\\"\"","   },"]}],"userModified":false,"replaceAll":false}}
