.ts:247:    // Upgrade Locked → complete when VRF has resolved\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:248:    if (isPhase(data.phase, \"locked\") && await isVrfFulfilled(connection, data.vrfRequestKey)) {\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:270:    if (isPhase(data.phase, \"locked\") && await isVrfFulfilled(connection, data.vrfRequestKey)) {\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:292:    // If on-chain phase is Locked but VRF has resolved, show as \"complete\"\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:294:    if (isPhase(data.phase, \"locked\") && await isVrfFulfilled(connection, data.vrfRequestKey)) {\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:345:  // Orao VRF accounts — derive PDAs and fetch treasury from network state\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:346:  const oraoNetworkState = getOraoNetworkStatePda();\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:347:  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:348:  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:349:  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:350:  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:351:  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:359:      oraoProgram: ORAO_VRF_PROGRAM_ID,\nsources/rng-utopia/apps/platform/src/features/coinflip/utils/chain.ts:360:      oraoNetworkState,\nsources