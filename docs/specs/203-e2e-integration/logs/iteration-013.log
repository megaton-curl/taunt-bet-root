{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AbpBvV9Fap8eXbDNBPNLp8","type":"tool_result","content":"     1→import { defineConfig } from \"vite\";\n     2→import react from \"@vitejs/plugin-react\";\n     3→import { nodePolyfills } from \"vite-plugin-node-polyfills\";\n     4→import { resolve } from \"path\";\n     5→\n     6→export default defineConfig({\n     7→  plugins: [\n     8→    react(),\n     9→    nodePolyfills({\n    10→      include: [\"buffer\", \"crypto\", \"stream\", \"util\"],\n    11→      globals: { Buffer: true },\n    12→    }),\n    13→  ],\n    14→  resolve: {\n    15→    alias: {\n    16→      \"@\": resolve(__dirname, \"./src\"),\n    17→    },\n    18→  },\n    19→  server: {\n    20→    port: 3000,\n    21→    host: true,\n    22→  },\n    23→  build: {\n    24→    // Disable sourcemaps for production (saves memory during build)\n    25→    sourcemap: false,\n    26→    // Increase chunk size warning limit\n    27→    chunkSizeWarningLimit: 1000,\n    28→    rollupOptions: {\n    29→      output: {\n    30→        // Manual chunks to optimize bundle splitting\n    31→        manualChunks(id) {\n    32→          // React ecosystem\n    33→          if (id.includes(\"node_modules/react\") ||\n    34→              id.includes(\"node_modules/react-dom\") ||\n    35→              id.includes(\"node_modules/react-router\")) {\n    36→            return \"vendor-react\";\n    37→          }\n    38→          // Solana SDK (if present - transitively imported by wallet mock)\n    39→          if (id.includes(\"node_modules/@solana\")) {\n    40→            return \"vendor-solana\";\n    41→          }\n    42→        },\n    43→      },\n    44→    },\n    45→  },\n    46→});\n    47→"}]},"parent_tool_use_id":"toolu_01XQUMkGpuUiPf6eYq4Um4nY","session_id":"6dadced6-465c-4292-ac5d-45e74b91a9b8","uuid":"ac9f3826-4f27-44b2-a7bc-4c2607b01ed1"}
