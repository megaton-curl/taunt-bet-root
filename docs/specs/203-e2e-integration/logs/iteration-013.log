{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LcXtFLtofSZgm7pncCabb1","type":"tool_result","content":"     1→import { ReactNode } from \"react\";\n     2→import { Keypair } from \"@solana/web3.js\";\n     3→import { TestWalletProvider } from \"./TestWalletProvider\";\n     4→\n     5→interface TestWalletWrapperProps {\n     6→  children: ReactNode;\n     7→}\n     8→\n     9→/**\n    10→ * Reads a 32-byte seed from `window.__TEST_WALLET_SEED__` (injected by\n    11→ * Playwright `addInitScript`) and renders TestWalletProvider with the\n    12→ * corresponding Keypair.\n    13→ *\n    14→ * This component is lazy-loaded by WalletProvider when VITE_TEST_WALLET=\"true\".\n    15→ */\n    16→export function TestWalletWrapper({ children }: TestWalletWrapperProps) {\n    17→  const seed: Uint8Array | undefined =\n    18→    typeof window !== \"undefined\"\n    19→      ? ((window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ as\n    20→          | Uint8Array\n    21→          | undefined)\n    22→      : undefined;\n    23→\n    24→  if (!seed) {\n    25→    throw new Error(\n    26→      \"TestWalletWrapper: window.__TEST_WALLET_SEED__ not found. \" +\n    27→        \"Inject it via Playwright addInitScript before loading the app.\",\n    28→    );\n    29→  }\n    30→\n    31→  const keypair = Keypair.fromSeed(new Uint8Array(seed));\n    32→  const rpcUrl =\n    33→    typeof import.meta !== \"undefined\"\n    34→      ? (import.meta.env?.VITE_RPC_URL as string | undefined)\n    35→      : undefined;\n    36→\n    37→  return (\n    38→    <TestWalletProvider keypair={keypair} rpcUrl={rpcUrl || undefined}>\n    39→      {children}\n    40→    </TestWalletProvider>\n    41→  );\n    42→}\n    43→"}]},"parent_tool_use_id":"toolu_01XQUMkGpuUiPf6eYq4Um4nY","session_id":"6dadced6-465c-4292-ac5d-45e74b91a9b8","uuid":"b3e7a7a2-2570-409d-a537-57a79348ecc1"}
