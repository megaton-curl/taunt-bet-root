{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LZyku1trCrriN4Bp1Fowvi","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  TIER_VALUES,\n    11→  COIN_SIDE_VALUES,\n    12→  TIER_AMOUNTS,\n    13→  type Tier,\n    14→  type CoinSide,\n    15→} from \"@rng-utopia/game-engine/browser\";\n    16→import type { UIMatch } from \"../types\";\n    17→\n    18→// ============ Constants ============\n    19→\n    20→const COINFLIP_PROGRAM_ID = new PublicKey(\n    21→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    22→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    23→);\n    24→\n    25→// Orao VRF program (on-chain VRF provider)\n    26→const ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n    27→\n    28→// ============ PDA Derivation ============\n    29→\n    30→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer()],\n    33→    COINFLIP_PROGRAM_ID\n    34→  );\n    35→}\n    36→\n    37→export function getConfigPda(): [PublicKey, number] {\n    38→  return PublicKey.findProgramAddressSync(\n    39→    [Buffer.from(\"coinflip_config\")],\n    40→    COINFLIP_PROGRAM_ID\n    41→  );\n    42→}\n    43→\n    44→/** Orao VRF network state PDA (stores config + treasury). */\n    45→function getOraoNetworkStatePda(): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    48→    ORAO_VRF_PROGRAM_ID\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→/** Orao VRF randomness PDA derived from a 32-byte seed. */\n    54→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    55→  const [pda] = PublicKey.findProgramAddressSync(\n    56→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    57→    ORAO_VRF_PROGRAM_ID\n    58→  );\n    59→  return pda;\n    60→}\n    61→\n    62→// ============ Program Instance ============\n    63→\n    64→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    65→  // Read-only provider (no wallet needed for queries)\n    66→  const provider = new AnchorProvider(\n    67→    connection,\n    68→    {} as AnchorProvider[\"wallet\"],\n    69→    { commitment: \"confirmed\" }\n    70→  );\n    71→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    72→}\n    73→\n    74→// ============ On-Chain Account Types ============\n    75→\n    76→/** Anchor enum variant representation — one key with empty object value. */\n    77→type RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n    78→  | { resolving: object } | { settled: object } | { refunded: object };\n    79→\n    80→interface OnChainMatch {\n    81→  creator: PublicKey;\n    82→  opponent: PublicKey;\n    83→  tier: number;\n    84→  entryAmount: { toNumber(): number };\n    85→  creatorSide: number;\n    86→  phase: RoundPhaseVariant;\n    87→  result: number;\n    88→  winner: PublicKey;\n    89→  claimed: boolean;\n    90→  createdAt: { toNumber(): number };\n    91→  lockedAt: { toNumber(): number };\n    92→  resolveDeadline: { toNumber(): number };\n    93→  vrfRequestKey: PublicKey;\n    94→  bump: number;\n    95→}\n    96→\n    97→// ============ Converters ============\n    98→\n    99→function tierFromIndex(index: number): Tier {\n   100→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];"}]},"parent_tool_use_id":"toolu_01XQUMkGpuUiPf6eYq4Um4nY","session_id":"6dadced6-465c-4292-ac5d-45e74b91a9b8","uuid":"38b37dbb-3eb3-4887-a8b3-163756ef5c02"}
