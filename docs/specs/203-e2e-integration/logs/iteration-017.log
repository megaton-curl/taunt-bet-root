{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013fnhaDihMaMibF9fJdbGju","type":"tool_result","content":"     1→/**\n     2→ * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. Connects to deployed devnet programs with\n     6→ * real Orao VRF fulfillment (no mock resolve shortcut).\n     7→ *\n     8→ * Prerequisites:\n     9→ * - Coinflip + Platform programs deployed to devnet\n    10→ * - Orao VRF initialized on devnet\n    11→ * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n    12→ * - Test wallets funded on devnet (handled in beforeAll)\n    13→ */\n    14→import { test, expect } from \"./fixtures\";\n    15→import * as po from \"../local/helpers/page-objects\";\n    16→import { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\n    17→import { validateDevnetEnv } from \"./helpers/env\";\n    18→import {\n    19→  pollVrfFulfillment,\n    20→  logRecentSignatures,\n    21→} from \"./helpers/vrf-polling\";\n    22→import { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n    23→\n    24→// ── Devnet wallet funding ─────────────────────────────────────────────\n    25→\n    26→/** Minimum SOL balance required to run the test (entry + tx fees). */\n    27→const MIN_BALANCE_SOL = 0.1;\n    28→\n    29→/** Airdrop amount per request on devnet (max 2 SOL per request). */\n    30→const AIRDROP_SOL = 1;\n    31→\n    32→/**\n    33→ * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n    34→ * is below the minimum threshold. Retries once on failure (devnet rate limits).\n    35→ */\n    36→async function ensureFunded(\n    37→  connection: Connection,\n    38→  pubkey: PublicKey,\n    39→  label: string,\n    40→): Promise<void> {\n    41→  const balance = await connection.getBalance(pubkey);\n    42→  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    43→    console.log(\n    44→      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    45→    );\n    46→    return;\n    47→  }\n    48→\n    49→  console.log(\n    50→    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n    51→  );\n    52→\n    53→  for (let attempt = 1; attempt <= 2; attempt++) {\n    54→    try {\n    55→      const sig = await connection.requestAirdrop(\n    56→        pubkey,\n    57→        AIRDROP_SOL * LAMPORTS_PER_SOL,\n    58→      );\n    59→      const { blockhash, lastValidBlockHeight } =\n    60→        await connection.getLatestBlockhash();\n    61→      await connection.confirmTransaction(\n    62→        { signature: sig, blockhash, lastValidBlockHeight },\n    63→        \"confirmed\",\n    64→      );\n    65→      const newBalance = await connection.getBalance(pubkey);\n    66→      console.log(\n    67→        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n    68→      );\n    69→      return;\n    70→    } catch (err) {\n    71→      if (attempt < 2) {\n    72→        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n    73→        await new Promise((r) => setTimeout(r, 2_000));\n    74→      } else {\n    75→        throw new Error(\n    76→          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n    77→        );\n    78→      }\n    79→    }\n    80→  }\n    81→}\n    82→\n    83→// ── VRF fulfillment timeout ───────────────────────────────────────────\n    84→\n    85→/**\n    86→ * Timeout for waiting on real VRF fulfillment.\n    87→ * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n    88→ */\n    89→const VRF_FULFILLMENT_TIMEOUT = 90_000;\n    90→\n    91→// ── Suite setup ────────────────────────────────────────────────────────\n    92→\n    93→test.beforeAll(async () => {\n    94→  const config = validateDevnetEnv();\n    95→  console.log(\"Devnet lifecycle: funding test wallets...\");\n    96→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n    97→  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n    98→  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n    99→});\n   100→\n   101→// ── Full lifecycle test ────────────────────────────────────────────────\n   102→\n   103→test(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n   104→  playerAPage,\n   105→  playerBPage,\n   106→  connection,\n   107→}) => {\n   108→  // Track console errors in both contexts\n   109→  const consoleA = po.trackConsoleErrors(playerAPage);\n   110→  const consoleB = po.trackConsoleErrors(playerBPage);\n   111→\n   112→  // 1. Player A navigates and creates a match (iron tier, heads)\n   113→  await po.navigateToCoinflip(playerAPage);\n   114→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n   115→\n   116→  // Player A should see the active match in \"waiting\" state\n   117→  await expect(\n   118→    playerAPage.locator(po.sel.activeMatchWaiting),\n   119→  ).toBeVisible({ timeout: 15_000 });\n   120→\n   121→  // 2. Player B navigates (after match is created) and sees it in the lobby\n   122→  await po.navigateToCoinflip(playerBPage);\n   123→  await po.waitForLobbyMatch(playerBPage, 30_000);\n   124→\n   125→  // 3. Player B joins the match\n   126→  await po.joinMatch(playerBPage);\n   127→\n   128→  // 4. Wait for real VRF fulfillment using dual strategy:\n   129→  //    a) On-chain polling with exponential backoff (detects VRF callback)\n   130→  //    b) UI result wait in parallel (detects frontend state update)\n   131→  //    Whichever resolves first wins — this ensures robustness even if\n   132→  //    the UI polling cycle is slow.\n   133→  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n   134→  const vrfStartTime = Date.now();\n   135→\n   136→  const [vrfPollResult, resultA, resultB] = await Promise.all([\n   137→    // On-chain poll: check match PDA phase with exponential backoff\n   138→    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n   139→      .then((r) => {\n   140→        console.log(\n   141→          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n   142→        );\n   143→        return r;\n   144→      })\n   145→      .catch((err) => {\n   146→        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n   147→        return null; // Don't fail test if UI detects it first\n   148→      }),\n   149→    // UI wait: Playwright waits for result CSS class on Player A's page\n   150→    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n   151→    // UI wait: Playwright waits for result CSS class on Player B's page\n   152→    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n   153→  ]);\n   154→\n   155→  const vrfElapsed = Date.now() - vrfStartTime;\n   156→  console.log(\n   157→    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n   158→  );\n   159→  if (vrfPollResult) {\n   160→    console.log(\n   161→      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n   162→    );\n   163→  }\n   164→\n   165→  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n   166→  expect(\n   167→    (resultA === \"won\" && resultB === \"lost\") ||\n   168→      (resultA === \"lost\" && resultB === \"won\"),\n   169→  ).toBe(true);\n   170→\n   171→  // 6. Winner claims payout\n   172→  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n   173→  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n   174→  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n   175→\n   176→  await po.claimOrSettle(winnerPage);\n   177→  console.log(`${winnerLabel} claimed payout`);\n   178→\n   179→  // Winner sees \"Back to Lobby\" after successful claim\n   180→  await expect(\n   181→    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   182→  ).toBeVisible({ timeout: 15_000 });\n   183→\n   184→  // 7. Winner returns to lobby\n   185→  await po.backToLobby(winnerPage);\n   186→\n   187→  // 8. Loser settles (closes their view)\n   188→  await po.claimOrSettle(loserPage);\n   189→  await expect(\n   190→    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   191→  ).toBeVisible({ timeout: 15_000 });\n   192→  await po.backToLobby(loserPage);\n   193→\n   194→  // 9. Log transaction signatures for both players (diagnostic artifact)\n   195→  console.log(\"\\n--- Transaction Signature Log ---\");\n   196→  await logRecentSignatures(connection, PLAYER_A.publicKey, `Player A (${resultA})`);\n   197→  await logRecentSignatures(connection, PLAYER_B.publicKey, `Player B (${resultB})`);\n   198→\n   199→  // No unhandled console errors in either context\n   200→  consoleA.assertClean();\n   201→  consoleB.assertClean();\n   202→});\n   203→"}]},"parent_tool_use_id":null,"session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"1c4d453d-c4cd-43d9-a975-d0c57b69f4f2","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts","content":"/**\n * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. Connects to deployed devnet programs with\n * real Orao VRF fulfillment (no mock resolve shortcut).\n *\n * Prerequisites:\n * - Coinflip + Platform programs deployed to devnet\n * - Orao VRF initialized on devnet\n * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n * - Test wallets funded on devnet (handled in beforeAll)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"../local/helpers/page-objects\";\nimport { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\nimport { validateDevnetEnv } from \"./helpers/env\";\nimport {\n  pollVrfFulfillment,\n  logRecentSignatures,\n} from \"./helpers/vrf-polling\";\nimport { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n\n// ── Devnet wallet funding ─────────────────────────────────────────────\n\n/** Minimum SOL balance required to run the test (entry + tx fees). */\nconst MIN_BALANCE_SOL = 0.1;\n\n/** Airdrop amount per request on devnet (max 2 SOL per request). */\nconst AIRDROP_SOL = 1;\n\n/**\n * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n * is below the minimum threshold. Retries once on failure (devnet rate limits).\n */\nasync function ensureFunded(\n  connection: Connection,\n  pubkey: PublicKey,\n  label: string,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    console.log(\n      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    );\n    return;\n  }\n\n  console.log(\n    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n  );\n\n  for (let attempt = 1; attempt <= 2; attempt++) {\n    try {\n      const sig = await connection.requestAirdrop(\n        pubkey,\n        AIRDROP_SOL * LAMPORTS_PER_SOL,\n      );\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      await connection.confirmTransaction(\n        { signature: sig, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      const newBalance = await connection.getBalance(pubkey);\n      console.log(\n        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n      );\n      return;\n    } catch (err) {\n      if (attempt < 2) {\n        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n        await new Promise((r) => setTimeout(r, 2_000));\n      } else {\n        throw new Error(\n          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n        );\n      }\n    }\n  }\n}\n\n// ── VRF fulfillment timeout ───────────────────────────────────────────\n\n/**\n * Timeout for waiting on real VRF fulfillment.\n * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n */\nconst VRF_FULFILLMENT_TIMEOUT = 90_000;\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  const config = validateDevnetEnv();\n  console.log(\"Devnet lifecycle: funding test wallets...\");\n  const connection = new Connection(config.rpcUrl, \"confirmed\");\n  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 30_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // 4. Wait for real VRF fulfillment using dual strategy:\n  //    a) On-chain polling with exponential backoff (detects VRF callback)\n  //    b) UI result wait in parallel (detects frontend state update)\n  //    Whichever resolves first wins — this ensures robustness even if\n  //    the UI polling cycle is slow.\n  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n  const vrfStartTime = Date.now();\n\n  const [vrfPollResult, resultA, resultB] = await Promise.all([\n    // On-chain poll: check match PDA phase with exponential backoff\n    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n      .then((r) => {\n        console.log(\n          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n        );\n        return r;\n      })\n      .catch((err) => {\n        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n        return null; // Don't fail test if UI detects it first\n      }),\n    // UI wait: Playwright waits for result CSS class on Player A's page\n    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n    // UI wait: Playwright waits for result CSS class on Player B's page\n    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n  ]);\n\n  const vrfElapsed = Date.now() - vrfStartTime;\n  console.log(\n    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n  );\n  if (vrfPollResult) {\n    console.log(\n      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n    );\n  }\n\n  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n  expect(\n    (resultA === \"won\" && resultB === \"lost\") ||\n      (resultA === \"lost\" && resultB === \"won\"),\n  ).toBe(true);\n\n  // 6. Winner claims payout\n  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n\n  await po.claimOrSettle(winnerPage);\n  console.log(`${winnerLabel} claimed payout`);\n\n  // Winner sees \"Back to Lobby\" after successful claim\n  await expect(\n    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 7. Winner returns to lobby\n  await po.backToLobby(winnerPage);\n\n  // 8. Loser settles (closes their view)\n  await po.claimOrSettle(loserPage);\n  await expect(\n    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n  await po.backToLobby(loserPage);\n\n  // 9. Log transaction signatures for both players (diagnostic artifact)\n  console.log(\"\\n--- Transaction Signature Log ---\");\n  await logRecentSignatures(connection, PLAYER_A.publicKey, `Player A (${resultA})`);\n  await logRecentSignatures(connection, PLAYER_B.publicKey, `Player B (${resultB})`);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","numLines":203,"startLine":1,"totalLines":203}}}
