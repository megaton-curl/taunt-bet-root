{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L2NCvArfmovLvM5E3dQ91A","type":"tool_result","content":"     1→/**\n     2→ * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. Connects to deployed devnet programs with\n     6→ * real Orao VRF fulfillment (no mock resolve shortcut).\n     7→ *\n     8→ * Prerequisites:\n     9→ * - Coinflip + Platform programs deployed to devnet\n    10→ * - Orao VRF initialized on devnet\n    11→ * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n    12→ * - Test wallets funded on devnet (handled in beforeAll)\n    13→ */\n    14→import { test, expect } from \"./fixtures\";\n    15→import * as po from \"../local/helpers/page-objects\";\n    16→import { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\n    17→import { validateDevnetEnv } from \"./helpers/env\";\n    18→import {\n    19→  pollVrfFulfillment,\n    20→  logRecentSignatures,\n    21→} from \"./helpers/vrf-polling\";\n    22→import { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n    23→\n    24→// ── Devnet wallet funding ─────────────────────────────────────────────\n    25→\n    26→/** Minimum SOL balance required to run the test (entry + tx fees). */\n    27→const MIN_BALANCE_SOL = 0.1;\n    28→\n    29→/** Airdrop amount per request on devnet (max 2 SOL per request). */\n    30→const AIRDROP_SOL = 1;\n    31→\n    32→/**\n    33→ * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n    34→ * is below the minimum threshold. Retries once on failure (devnet rate limits).\n    35→ */\n    36→async function ensureFunded(\n    37→  connection: Connection,\n    38→  pubkey: PublicKey,\n    39→  label: string,\n    40→): Promise<void> {\n    41→  const balance = await connection.getBalance(pubkey);\n    42→  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    43→    console.log(\n    44→      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    45→    );\n    46→    return;\n    47→  }\n    48→\n    49→  console.log(\n    50→    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n    51→  );\n    52→\n    53→  for (let attempt = 1; attempt <= 2; attempt++) {\n    54→    try {\n    55→      const sig = await connection.requestAirdrop(\n    56→        pubkey,\n    57→        AIRDROP_SOL * LAMPORTS_PER_SOL,\n    58→      );\n    59→      const { blockhash, lastValidBlockHeight } =\n    60→        await connection.getLatestBlockhash();\n    61→      await connection.confirmTransaction(\n    62→        { signature: sig, blockhash, lastValidBlockHeight },\n    63→        \"confirmed\",\n    64→      );\n    65→      const newBalance = await connection.getBalance(pubkey);\n    66→      console.log(\n    67→        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n    68→      );\n    69→      return;\n    70→    } catch (err) {\n    71→      if (attempt < 2) {\n    72→        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n    73→        await new Promise((r) => setTimeout(r, 2_000));\n    74→      } else {\n    75→        throw new Error(\n    76→          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n    77→        );\n    78→      }\n    79→    }\n    80→  }\n    81→}\n    82→\n    83→// ── VRF fulfillment timeout ───────────────────────────────────────────\n    84→\n    85→/**\n    86→ * Timeout for waiting on real VRF fulfillment.\n    87→ * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n    88→ */\n    89→const VRF_FULFILLMENT_TIMEOUT = 90_000;\n    90→\n    91→// ── Suite setup ────────────────────────────────────────────────────────\n    92→\n    93→test.beforeAll(async () => {\n    94→  const config = validateDevnetEnv();\n    95→  console.log(\"Devnet lifecycle: funding test wallets...\");\n    96→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n    97→  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n    98→  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n    99→});\n   100→\n   101→// ── Full lifecycle test ────────────────────────────────────────────────\n   102→\n   103→test(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n   104→  playerAPage,\n   105→  playerBPage,\n   106→  connection,\n   107→}) => {\n   108→  // Track console errors in both contexts\n   109→  const consoleA = po.trackConsoleErrors(playerAPage);\n   110→  const consoleB = po.trackConsoleErrors(playerBPage);\n   111→\n   112→  // 1. Player A navigates and creates a match (iron tier, heads)\n   113→  await po.navigateToCoinflip(playerAPage);\n   114→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n   115→\n   116→  // Player A should see the active match in \"waiting\" state\n   117→  await expect(\n   118→    playerAPage.locator(po.sel.activeMatchWaiting),\n   119→  ).toBeVisible({ timeout: 15_000 });\n   120→\n   121→  // 2. Player B navigates (after match is created) and sees it in the lobby\n   122→  await po.navigateToCoinflip(playerBPage);\n   123→  await po.waitForLobbyMatch(playerBPage, 30_000);\n   124→\n   125→  // 3. Player B joins the match\n   126→  await po.joinMatch(playerBPage);\n   127→\n   128→  // 4. Wait for real VRF fulfillment using dual strategy:\n   129→  //    a) On-chain polling with exponential backoff (detects VRF callback)\n   130→  //    b) UI result wait in parallel (detects frontend state update)\n   131→  //    Whichever resolves first wins — this ensures robustness even if\n   132→  //    the UI polling cycle is slow.\n   133→  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n   134→  const vrfStartTime = Date.now();\n   135→\n   136→  const [vrfPollResult, resultA, resultB] = await Promise.all([\n   137→    // On-chain poll: check match PDA phase with exponential backoff\n   138→    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n   139→      .then((r) => {\n   140→        console.log(\n   141→          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n   142→        );\n   143→        return r;\n   144→      })\n   145→      .catch((err) => {\n   146→        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n   147→        return null; // Don't fail test if UI detects it first\n   148→      }),\n   149→    // UI wait: Playwright waits for result CSS class on Player A's page\n   150→    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n   151→    // UI wait: Playwright waits for result CSS class on Player B's page\n   152→    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n   153→  ]);\n   154→\n   155→  const vrfElapsed = Date.now() - vrfStartTime;\n   156→  console.log(\n   157→    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n   158→  );\n   159→  if (vrfPollResult) {\n   160→    console.log(\n   161→      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n   162→    );\n   163→  }\n   164→\n   165→  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n   166→  expect(\n   167→    (resultA === \"won\" && resultB === \"lost\") ||\n   168→      (resultA === \"lost\" && resultB === \"won\"),\n   169→  ).toBe(true);\n   170→\n   171→  // 6. Winner claims payout\n   172→  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n   173→  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n   174→  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n   175→\n   176→  await po.claimOrSettle(winnerPage);\n   177→  console.log(`${winnerLabel} claimed payout`);\n   178→\n   179→  // Winner sees \"Back to Lobby\" after successful claim\n   180→  await expect(\n   181→    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   182→  ).toBeVisible({ timeout: 15_000 });\n   183→\n   184→  // 7. Winner returns to lobby\n   185→  await po.backToLobby(winnerPage);\n   186→\n   187→  // 8. Loser settles (closes their view)\n   188→  await po.claimOrSettle(loserPage);\n   189→  await expect(\n   190→    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   191→  ).toBeVisible({ timeout: 15_000 });\n   192→  await po.backToLobby(loserPage);\n   193→\n   194→  // 9. Log transaction signatures for both players (diagnostic artifact)\n   195→  console.log(\"\\n--- Transaction Signature Log ---\");\n   196→  await logRecentSignatures(connection, PLAYER_A.publicKey, `Player A (${resultA})`);\n   197→  await logRecentSignatures(connection, PLAYER_B.publicKey, `Player B (${resultB})`);\n   198→\n   199→  // No unhandled console errors in either context\n   200→  consoleA.assertClean();\n   201→  consoleB.assertClean();\n   202→});\n   203→"}]},"parent_tool_use_id":"toolu_017x6EBQF9GvVsHLnExQwqDr","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"c867235f-e951-4a5c-a7ff-c91e160e3a78"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_0182uqfx8L5poeEfrfHV6Xzs","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016Z6q6oEVoRxv9eiVQJrQkC","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/fixtures.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":4144,"cache_read_input_tokens":20451,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4144},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017x6EBQF9GvVsHLnExQwqDr","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"df51b494-587d-4cc7-9104-58b94da673e9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Z6q6oEVoRxv9eiVQJrQkC","type":"tool_result","content":"     1→/**\n     2→ * Dual-browser-context fixture for devnet E2E tests.\n     3→ *\n     4→ * Same isolated dual-player pattern as local fixtures, but connects\n     5→ * to the devnet RPC instead of a local validator. The RPC URL comes\n     6→ * from the validated devnet env config.\n     7→ *\n     8→ * Usage in tests:\n     9→ * ```ts\n    10→ * import { test, expect } from \"./fixtures\";\n    11→ *\n    12→ * test(\"devnet lifecycle\", async ({ playerAPage, playerBPage, connection }) => {\n    13→ *   // playerAPage and playerBPage target devnet via real RPC\n    14→ * });\n    15→ * ```\n    16→ */\n    17→import { test as base, type BrowserContext, type Page } from \"@playwright/test\";\n    18→import { Keypair, Connection } from \"@solana/web3.js\";\n    19→import { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\n    20→import { type DevnetConfig, validateDevnetEnv } from \"./helpers/env\";\n    21→\n    22→export interface DevnetDualPlayerFixtures {\n    23→  /** Validated devnet configuration (RPC URL, program IDs). */\n    24→  devnetConfig: DevnetConfig;\n    25→  /** Isolated browser context for player A (keypair injected). */\n    26→  playerAContext: BrowserContext;\n    27→  /** Isolated browser context for player B (keypair injected). */\n    28→  playerBContext: BrowserContext;\n    29→  /** Page within player A's context. */\n    30→  playerAPage: Page;\n    31→  /** Page within player B's context. */\n    32→  playerBPage: Page;\n    33→  /** Player A's deterministic keypair. */\n    34→  playerAKeypair: Keypair;\n    35→  /** Player B's deterministic keypair. */\n    36→  playerBKeypair: Keypair;\n    37→  /** Shared RPC connection to the devnet cluster. */\n    38→  connection: Connection;\n    39→}\n    40→\n    41→/**\n    42→ * Inject a 32-byte keypair seed into a new browser context via addInitScript.\n    43→ */\n    44→async function createPlayerContext(\n    45→  browser: BrowserContext[\"browser\"],\n    46→  keypair: Keypair,\n    47→): Promise<BrowserContext> {\n    48→  const context = await browser!.newContext();\n    49→  const seedArray = Array.from(keypair.secretKey.slice(0, 32));\n    50→  await context.addInitScript((seed: number[]) => {\n    51→    (window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ =\n    52→      new Uint8Array(seed);\n    53→  }, seedArray);\n    54→  return context;\n    55→}\n    56→\n    57→export const test = base.extend<DevnetDualPlayerFixtures>({\n    58→  // Validate devnet env once per test (sync, cached by Playwright)\n    59→  // eslint-disable-next-line no-empty-pattern\n    60→  devnetConfig: async ({}, use) => {\n    61→    const config = validateDevnetEnv();\n    62→    await use(config);\n    63→  },\n    64→\n    65→  // Expose keypairs as fixtures\n    66→  playerAKeypair: [PLAYER_A, { option: true }],\n    67→  playerBKeypair: [PLAYER_B, { option: true }],\n    68→\n    69→  // Shared connection to devnet\n    70→  connection: async ({ devnetConfig }, use) => {\n    71→    const conn = new Connection(devnetConfig.rpcUrl, \"confirmed\");\n    72→    await use(conn);\n    73→  },\n    74→\n    75→  // --- Player A context + page ---\n    76→  playerAContext: async ({ browser, playerAKeypair }, use) => {\n    77→    const context = await createPlayerContext(browser, playerAKeypair);\n    78→    await use(context);\n    79→    await context.close();\n    80→  },\n    81→\n    82→  playerAPage: async ({ playerAContext }, use) => {\n    83→    const page = await playerAContext.newPage();\n    84→    await use(page);\n    85→  },\n    86→\n    87→  // --- Player B context + page ---\n    88→  playerBContext: async ({ browser, playerBKeypair }, use) => {\n    89→    const context = await createPlayerContext(browser, playerBKeypair);\n    90→    await use(context);\n    91→    await context.close();\n    92→  },\n    93→\n    94→  playerBPage: async ({ playerBContext }, use) => {\n    95→    const page = await playerBContext.newPage();\n    96→    await use(page);\n    97→  },\n    98→});\n    99→\n   100→export { expect } from \"@playwright/test\";\n   101→"}]},"parent_tool_use_id":"toolu_017x6EBQF9GvVsHLnExQwqDr","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"8e385761-7ccb-4c4d-9d61-2166911a28e6"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_0182uqfx8L5poeEfrfHV6Xzs","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LctD2RwxtzC28dJVPPD1bn","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/helpers/env.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":4144,"cache_read_input_tokens":20451,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4144},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017x6EBQF9GvVsHLnExQwqDr","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"81feeef7-b236-4b71-bce7-23ef1940d689"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LctD2RwxtzC28dJVPPD1bn","type":"tool_result","content":"     1→/**\n     2→ * Devnet E2E environment contract.\n     3→ *\n     4→ * Validates that all required environment variables are present and well-formed\n     5→ * before any devnet test runs. Fails fast with clear error messages so CI\n     6→ * doesn't waste time on doomed runs.\n     7→ *\n     8→ * Required env vars:\n     9→ *   VITE_RPC_URL             — Devnet RPC endpoint (https URL)\n    10→ *   VITE_COINFLIP_PROGRAM_ID — Deployed coinflip program address (base58)\n    11→ *   VITE_PLATFORM_PROGRAM_ID — Deployed platform program address (base58)\n    12→ *\n    13→ * Optional (with defaults):\n    14→ *   VITE_SOLANA_NETWORK      — Cluster name (default: \"devnet\")\n    15→ */\n    16→\n    17→import { Connection, PublicKey } from \"@solana/web3.js\";\n    18→\n    19→// Orao VRF program ID (hardcoded — same address on all clusters)\n    20→const ORAO_VRF_PROGRAM_ID = new PublicKey(\n    21→  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\",\n    22→);\n    23→\n    24→/** Validated devnet configuration. */\n    25→export interface DevnetConfig {\n    26→  rpcUrl: string;\n    27→  network: string;\n    28→  coinflipProgramId: PublicKey;\n    29→  platformProgramId: PublicKey;\n    30→  oraoVrfProgramId: PublicKey;\n    31→}\n    32→\n    33→/** Validate a base58 public key string. Throws if invalid. */\n    34→function parsePublicKey(value: string, label: string): PublicKey {\n    35→  try {\n    36→    return new PublicKey(value);\n    37→  } catch {\n    38→    throw new Error(\n    39→      `${label} is not a valid Solana address (base58): \"${value}\"`,\n    40→    );\n    41→  }\n    42→}\n    43→\n    44→/** Validate a URL string. Throws if malformed. */\n    45→function parseUrl(value: string, label: string): string {\n    46→  try {\n    47→    const url = new URL(value);\n    48→    if (![\"http:\", \"https:\"].includes(url.protocol)) {\n    49→      throw new Error(\"not http(s)\");\n    50→    }\n    51→    return value;\n    52→  } catch {\n    53→    throw new Error(\n    54→      `${label} is not a valid HTTP(S) URL: \"${value}\"`,\n    55→    );\n    56→  }\n    57→}\n    58→\n    59→/**\n    60→ * Read and validate all required devnet env vars.\n    61→ * Throws with a consolidated error listing every missing/invalid variable.\n    62→ */\n    63→export function validateDevnetEnv(): DevnetConfig {\n    64→  const errors: string[] = [];\n    65→\n    66→  // --- Required ---\n    67→  const rpcUrl = process.env.VITE_RPC_URL;\n    68→  if (!rpcUrl) {\n    69→    errors.push(\"VITE_RPC_URL is required (devnet RPC endpoint)\");\n    70→  }\n    71→\n    72→  const coinflipId = process.env.VITE_COINFLIP_PROGRAM_ID;\n    73→  if (!coinflipId) {\n    74→    errors.push(\n    75→      \"VITE_COINFLIP_PROGRAM_ID is required (deployed coinflip program address)\",\n    76→    );\n    77→  }\n    78→\n    79→  const platformId = process.env.VITE_PLATFORM_PROGRAM_ID;\n    80→  if (!platformId) {\n    81→    errors.push(\n    82→      \"VITE_PLATFORM_PROGRAM_ID is required (deployed platform program address)\",\n    83→    );\n    84→  }\n    85→\n    86→  // Fail fast if any required var is missing\n    87→  if (errors.length > 0) {\n    88→    throw new Error(\n    89→      `Devnet E2E env validation failed:\\n  - ${errors.join(\"\\n  - \")}\\n\\n` +\n    90→        `Hint: copy .env.devnet to .env.local and update program IDs, ` +\n    91→        `or export the variables before running tests.`,\n    92→    );\n    93→  }\n    94→\n    95→  // --- Format validation ---\n    96→  const validatedUrl = parseUrl(rpcUrl!, \"VITE_RPC_URL\");\n    97→  const coinflipProgramId = parsePublicKey(\n    98→    coinflipId!,\n    99→    \"VITE_COINFLIP_PROGRAM_ID\",\n   100→  );\n   101→  const platformProgramId = parsePublicKey(\n   102→    platformId!,\n   103→    \"VITE_PLATFORM_PROGRAM_ID\",\n   104→  );\n   105→\n   106→  // --- Optional with default ---\n   107→  const network = process.env.VITE_SOLANA_NETWORK ?? \"devnet\";\n   108→\n   109→  return {\n   110→    rpcUrl: validatedUrl,\n   111→    network,\n   112→    coinflipProgramId,\n   113→    platformProgramId,\n   114→    oraoVrfProgramId: ORAO_VRF_PROGRAM_ID,\n   115→  };\n   116→}\n   117→\n   118→/**\n   119→ * Verify that the devnet RPC is reachable and that required programs\n   120→ * are deployed. Call this once in globalSetup or the first test's beforeAll.\n   121→ */\n   122→export async function verifyDevnetDeployments(\n   123→  config: DevnetConfig,\n   124→): Promise<void> {\n   125→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n   126→\n   127→  // 1. RPC health check\n   128→  try {\n   129→    await connection.getLatestBlockhash();\n   130→  } catch (err) {\n   131→    throw new Error(\n   132→      `Cannot reach devnet RPC at ${config.rpcUrl}: ${err instanceof Error ? err.message : err}`,\n   133→    );\n   134→  }\n   135→\n   136→  // 2. Coinflip program deployed\n   137→  const coinflipAccount = await connection.getAccountInfo(\n   138→    config.coinflipProgramId,\n   139→  );\n   140→  if (!coinflipAccount || !coinflipAccount.executable) {\n   141→    throw new Error(\n   142→      `Coinflip program not found or not executable at ${config.coinflipProgramId.toBase58()}`,\n   143→    );\n   144→  }\n   145→\n   146→  // 3. Platform program deployed\n   147→  const platformAccount = await connection.getAccountInfo(\n   148→    config.platformProgramId,\n   149→  );\n   150→  if (!platformAccount || !platformAccount.executable) {\n   151→    throw new Error(\n   152→      `Platform program not found or not executable at ${config.platformProgramId.toBase58()}`,\n   153→    );\n   154→  }\n   155→\n   156→  // 4. Orao VRF program deployed\n   157→  const oraoAccount = await connection.getAccountInfo(\n   158→    config.oraoVrfProgramId,\n   159→  );\n   160→  if (!oraoAccount || !oraoAccount.executable) {\n   161→    throw new Error(\n   162→      `Orao VRF program not found or not executable at ${config.oraoVrfProgramId.toBase58()}`,\n   163→    );\n   164→  }\n   165→\n   166→  // 5. Orao VRF network state PDA exists (proves VRF is initialized)\n   167→  const [oraoNetworkState] = PublicKey.findProgramAddressSync(\n   168→    [Buffer.from(\"orao-vrf-network-configuration\")],\n   169→    config.oraoVrfProgramId,\n   170→  );\n   171→  const networkState = await connection.getAccountInfo(oraoNetworkState);\n   172→  if (!networkState) {\n   173→    throw new Error(\n   174→      `Orao VRF network state PDA not found at ${oraoNetworkState.toBase58()} — ` +\n   175→        `VRF provider may not be initialized on this cluster`,\n   176→    );\n   177→  }\n   178→}\n   179→"}]},"parent_tool_use_id":"toolu_017x6EBQF9GvVsHLnExQwqDr","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"28c99823-b636-41bb-8dcd-e3de1a650d8c"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_0182uqfx8L5poeEfrfHV6Xzs","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XF87vroTGi9mi8eM5CBYyG","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/helpers/vrf-polling.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":4144,"cache_read_input_tokens":20451,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4144},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017x6EBQF9GvVsHLnExQwqDr","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"432f4089-4df2-476a-b6a6-13d0feebf52e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XF87vroTGi9mi8eM5CBYyG","type":"tool_result","content":"     1→/**\n     2→ * Robust VRF fulfillment polling with exponential backoff and timeout budget\n     3→ * tracking for devnet E2E tests.\n     4→ *\n     5→ * Polls the match PDA on-chain to detect phase transitions (locked → resolved)\n     6→ * as evidence of real VRF fulfillment. Provides detailed timing logs and\n     7→ * transaction signature collection for failure diagnostics.\n     8→ */\n     9→import { Connection, PublicKey } from \"@solana/web3.js\";\n    10→import {\n    11→  fetchMatch,\n    12→  getMatchPda,\n    13→  type MatchAccount,\n    14→} from \"../../local/helpers/on-chain\";\n    15→\n    16→// ── Polling config ──────────────────────────────────────────────────────\n    17→\n    18→/** Initial polling interval (ms). */\n    19→const INITIAL_INTERVAL = 2_000;\n    20→\n    21→/** Maximum polling interval after backoff (ms). */\n    22→const MAX_INTERVAL = 10_000;\n    23→\n    24→/** Backoff multiplier per poll attempt. */\n    25→const BACKOFF_FACTOR = 1.5;\n    26→\n    27→// ── Types ───────────────────────────────────────────────────────────────\n    28→\n    29→export interface VrfPollResult {\n    30→  /** Final match account state after fulfillment. */\n    31→  match: MatchAccount;\n    32→  /** Match PDA address. */\n    33→  matchPda: PublicKey;\n    34→  /** Phase detected (\"resolved\" on success). */\n    35→  phase: string;\n    36→  /** Total wall-clock time spent polling (ms). */\n    37→  elapsedMs: number;\n    38→  /** Number of RPC poll attempts made. */\n    39→  attempts: number;\n    40→}\n    41→\n    42→export interface VrfTimeoutError extends Error {\n    43→  /** Elapsed time before timeout (ms). */\n    44→  elapsedMs: number;\n    45→  /** Number of poll attempts made. */\n    46→  attempts: number;\n    47→  /** Last observed phase (if any). */\n    48→  lastPhase: string | null;\n    49→  /** Transaction signatures on the match PDA (for debugging). */\n    50→  signatures: string[];\n    51→}\n    52→\n    53→// ── Helpers ─────────────────────────────────────────────────────────────\n    54→\n    55→/**\n    56→ * Collect recent transaction signatures for a match PDA.\n    57→ * Used for failure diagnostics — shows what transactions touched the account.\n    58→ */\n    59→export async function collectMatchSignatures(\n    60→  connection: Connection,\n    61→  matchPda: PublicKey,\n    62→  limit = 10,\n    63→): Promise<string[]> {\n    64→  try {\n    65→    const sigs = await connection.getSignaturesForAddress(matchPda, { limit });\n    66→    return sigs.map((s) => s.signature);\n    67→  } catch {\n    68→    return [];\n    69→  }\n    70→}\n    71→\n    72→/**\n    73→ * Format a duration in milliseconds to a human-readable string.\n    74→ */\n    75→function formatMs(ms: number): string {\n    76→  if (ms < 1_000) return `${ms}ms`;\n    77→  return `${(ms / 1_000).toFixed(1)}s`;\n    78→}\n    79→\n    80→// ── Main polling function ───────────────────────────────────────────────\n    81→\n    82→/**\n    83→ * Poll the match PDA on-chain for VRF fulfillment with exponential backoff.\n    84→ *\n    85→ * Waits for the match phase to transition from \"locked\" to \"resolved\",\n    86→ * which indicates the Orao VRF callback has executed. Logs timing budget\n    87→ * at each attempt for observability.\n    88→ *\n    89→ * @param connection - Solana RPC connection\n    90→ * @param creator - Match creator's public key (used to derive PDA)\n    91→ * @param timeoutMs - Maximum time to poll before giving up\n    92→ * @returns VrfPollResult on success\n    93→ * @throws VrfTimeoutError with diagnostics on timeout\n    94→ */\n    95→export async function pollVrfFulfillment(\n    96→  connection: Connection,\n    97→  creator: PublicKey,\n    98→  timeoutMs: number,\n    99→): Promise<VrfPollResult> {\n   100→  const [matchPda] = getMatchPda(creator);\n   101→  const startTime = Date.now();\n   102→  let interval = INITIAL_INTERVAL;\n   103→  let attempts = 0;\n   104→  let lastPhase: string | null = null;\n   105→\n   106→  console.log(\n   107→    `[vrf-poll] Starting VRF fulfillment polling for match PDA ${matchPda.toBase58()}`,\n   108→  );\n   109→  console.log(\n   110→    `[vrf-poll] Timeout budget: ${formatMs(timeoutMs)}, initial interval: ${formatMs(INITIAL_INTERVAL)}`,\n   111→  );\n   112→\n   113→  while (true) {\n   114→    const elapsed = Date.now() - startTime;\n   115→    const remaining = timeoutMs - elapsed;\n   116→\n   117→    if (remaining <= 0) {\n   118→      // Timeout — collect diagnostic info\n   119→      console.log(`[vrf-poll] TIMEOUT after ${formatMs(elapsed)} (${attempts} attempts)`);\n   120→      const signatures = await collectMatchSignatures(connection, matchPda);\n   121→      if (signatures.length > 0) {\n   122→        console.log(`[vrf-poll] Match PDA transaction signatures:`);\n   123→        signatures.forEach((sig, i) => console.log(`  [${i}] ${sig}`));\n   124→      } else {\n   125→        console.log(`[vrf-poll] No transaction signatures found on match PDA`);\n   126→      }\n   127→\n   128→      const err = new Error(\n   129→        `VRF fulfillment timed out after ${formatMs(elapsed)} (${attempts} attempts). ` +\n   130→          `Last phase: ${lastPhase ?? \"unknown\"}. ` +\n   131→          `Signatures: ${signatures.length > 0 ? signatures.join(\", \") : \"none\"}`,\n   132→      ) as VrfTimeoutError;\n   133→      err.elapsedMs = elapsed;\n   134→      err.attempts = attempts;\n   135→      err.lastPhase = lastPhase;\n   136→      err.signatures = signatures;\n   137→      throw err;\n   138→    }\n   139→\n   140→    // Wait before polling (skip initial wait on first attempt)\n   141→    if (attempts > 0) {\n   142→      const sleepMs = Math.min(interval, remaining);\n   143→      await new Promise((r) => setTimeout(r, sleepMs));\n   144→    }\n   145→\n   146→    attempts++;\n   147→    const elapsed2 = Date.now() - startTime;\n   148→    const budgetPct = Math.round((elapsed2 / timeoutMs) * 100);\n   149→\n   150→    try {\n   151→      const match = await fetchMatch(connection, matchPda);\n   152→\n   153→      if (!match) {\n   154→        // Match PDA closed (claimed before we could observe resolved state)\n   155→        console.log(\n   156→          `[vrf-poll] Attempt ${attempts}: match PDA closed (already claimed?) ` +\n   157→            `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n   158→        );\n   159→        lastPhase = \"closed\";\n   160→      } else {\n   161→        const phase = Object.keys(match.phase)[0];\n   162→        lastPhase = phase;\n   163→\n   164→        console.log(\n   165→          `[vrf-poll] Attempt ${attempts}: phase=\"${phase}\" ` +\n   166→            `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n   167→        );\n   168→\n   169→        if (phase === \"resolved\") {\n   170→          console.log(\n   171→            `[vrf-poll] VRF fulfilled! Detected in ${formatMs(elapsed2)} after ${attempts} attempts`,\n   172→          );\n   173→\n   174→          // Log the fulfillment transaction signatures\n   175→          const signatures = await collectMatchSignatures(connection, matchPda);\n   176→          if (signatures.length > 0) {\n   177→            console.log(`[vrf-poll] Match PDA transaction signatures:`);\n   178→            signatures.forEach((sig, i) => console.log(`  [${i}] ${sig}`));\n   179→          }\n   180→\n   181→          return {\n   182→            match,\n   183→            matchPda,\n   184→            phase,\n   185→            elapsedMs: elapsed2,\n   186→            attempts,\n   187→          };\n   188→        }\n   189→      }\n   190→    } catch (err) {\n   191→      console.log(\n   192→        `[vrf-poll] Attempt ${attempts}: RPC error — ${err} ` +\n   193→          `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n   194→      );\n   195→    }\n   196→\n   197→    // Exponential backoff\n   198→    interval = Math.min(interval * BACKOFF_FACTOR, MAX_INTERVAL);\n   199→  }\n   200→}\n   201→\n   202→/**\n   203→ * Log transaction signatures for a player's recent activity on devnet.\n   204→ * Useful for post-failure diagnostics.\n   205→ *\n   206→ * @param connection - Solana RPC connection\n   207→ * @param address - Address to inspect\n   208→ * @param label - Human-readable label for logging\n   209→ * @param limit - Max signatures to fetch\n   210→ */\n   211→export async function logRecentSignatures(\n   212→  connection: Connection,\n   213→  address: PublicKey,\n   214→  label: string,\n   215→  limit = 5,\n   216→): Promise<string[]> {\n   217→  try {\n   218→    const sigs = await connection.getSignaturesForAddress(address, { limit });\n   219→    if (sigs.length === 0) {\n   220→      console.log(`[tx-log] ${label}: no recent signatures`);\n   221→      return [];\n   222→    }\n   223→    console.log(`[tx-log] ${label}: ${sigs.length} recent signature(s):`);\n   224→    const result: string[] = [];\n   225→    for (const sig of sigs) {\n   226→      const status = sig.err ? `FAILED: ${JSON.stringify(sig.err)}` : \"OK\";\n   227→      console.log(`  ${sig.signature} [slot ${sig.slot}, ${status}]`);\n   228→      result.push(sig.signature);\n   229→    }\n   230→    return result;\n   231→  } catch {\n   232→    console.log(`[tx-log] ${label}: failed to fetch signatures`);\n   233→    return [];\n   234→  }\n   235→}\n   236→"}]},"parent_tool_use_id":"toolu_017x6EBQF9GvVsHLnExQwqDr","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"a746271a-2cb6-4704-be9c-4a85d96c4d80"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_015oWp2f8tRW9AVi89Bycxv4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019PUmBmKDwLj2LqJZyq2TyA","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/on-chain.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":3137,"cache_read_input_tokens":21458,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3137},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01AeENyYJpdjuUxBr5j77amo","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"4ec0ab8f-3e03-40b8-bfa8-e360ad410c9b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019PUmBmKDwLj2LqJZyq2TyA","type":"tool_result","content":"     1→/**\n     2→ * On-chain assertion helpers for local E2E tests.\n     3→ *\n     4→ * Provides RPC-based helpers to query and assert match PDA state,\n     5→ * treasury fee deltas, and player profile stat updates.\n     6→ */\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     9→import {\n    10→  CoinflipIDL,\n    11→  PlatformIDL,\n    12→  type Coinflip,\n    13→  type Platform,\n    14→} from \"@rng-utopia/anchor-client\";\n    15→\n    16→// ============ Program IDs ============\n    17→\n    18→/** Coinflip program address (from IDL). */\n    19→export const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    20→\n    21→/** Platform program address (from IDL). */\n    22→export const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n    23→\n    24→/** Platform fee: 300 basis points = 3%. */\n    25→export const FEE_BPS = 300;\n    26→\n    27→// ============ PDA Derivation ============\n    28→\n    29→/** Derive the match PDA for a creator. Seeds: [\"match\", creator]. */\n    30→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer()],\n    33→    COINFLIP_PROGRAM_ID,\n    34→  );\n    35→}\n    36→\n    37→/** Derive the coinflip config PDA. Seeds: [\"coinflip_config\"]. */\n    38→export function getConfigPda(): [PublicKey, number] {\n    39→  return PublicKey.findProgramAddressSync(\n    40→    [Buffer.from(\"coinflip_config\")],\n    41→    COINFLIP_PROGRAM_ID,\n    42→  );\n    43→}\n    44→\n    45→/** Derive a player profile PDA. Seeds: [\"player_profile\", wallet]. */\n    46→export function getPlayerProfilePda(wallet: PublicKey): [PublicKey, number] {\n    47→  return PublicKey.findProgramAddressSync(\n    48→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    49→    PLATFORM_PROGRAM_ID,\n    50→  );\n    51→}\n    52→\n    53→// ============ Program Instances ============\n    54→\n    55→/**\n    56→ * Create a read-only Coinflip program instance.\n    57→ *\n    58→ * @param connection - Solana RPC connection\n    59→ */\n    60→export function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    61→  const provider = new AnchorProvider(\n    62→    connection,\n    63→    {} as AnchorProvider[\"wallet\"],\n    64→    { commitment: \"confirmed\" },\n    65→  );\n    66→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    67→}\n    68→\n    69→/**\n    70→ * Create a read-only Platform program instance.\n    71→ *\n    72→ * @param connection - Solana RPC connection\n    73→ */\n    74→export function getPlatformProgram(connection: Connection): Program<Platform> {\n    75→  const provider = new AnchorProvider(\n    76→    connection,\n    77→    {} as AnchorProvider[\"wallet\"],\n    78→    { commitment: \"confirmed\" },\n    79→  );\n    80→  return new Program(PlatformIDL as Idl as Platform, provider);\n    81→}\n    82→\n    83→// ============ Account Types ============\n    84→\n    85→/** Deserialized match account shape. */\n    86→export interface MatchAccount {\n    87→  creator: PublicKey;\n    88→  opponent: PublicKey;\n    89→  tier: number;\n    90→  entryAmount: { toNumber(): number };\n    91→  creatorSide: number;\n    92→  phase: Record<string, object>;\n    93→  result: number;\n    94→  winner: PublicKey;\n    95→  claimed: boolean;\n    96→  createdAt: { toNumber(): number };\n    97→  lockedAt: { toNumber(): number };\n    98→  resolveDeadline: { toNumber(): number };\n    99→  vrfRequestKey: PublicKey;\n   100→  bump: number;\n   101→}\n   102→\n   103→/** Deserialized player profile account shape. */\n   104→export interface PlayerProfileAccount {\n   105→  authority: PublicKey;\n   106→  totalGames: { toNumber(): number };\n   107→  wins: { toNumber(): number };\n   108→  totalWagered: { toNumber(): number };\n   109→  totalWon: { toNumber(): number };\n   110→  bump: number;\n   111→}\n   112→\n   113→// ============ Fetch Helpers ============\n   114→\n   115→/**\n   116→ * Fetch a match PDA account. Returns null if the account is closed.\n   117→ *\n   118→ * @param connection - Solana RPC connection\n   119→ * @param matchPda - The match PDA address\n   120→ */\n   121→export async function fetchMatch(\n   122→  connection: Connection,\n   123→  matchPda: PublicKey,\n   124→): Promise<MatchAccount | null> {\n   125→  const program = getCoinflipProgram(connection);\n   126→  try {\n   127→    return (await program.account.coinflipMatch.fetch(\n   128→      matchPda,\n   129→    )) as unknown as MatchAccount;\n   130→  } catch {\n   131→    // Account not found (closed or never created)\n   132→    return null;\n   133→  }\n   134→}\n   135→\n   136→/**\n   137→ * Fetch a player profile PDA account. Returns null if it doesn't exist.\n   138→ *\n   139→ * @param connection - Solana RPC connection\n   140→ * @param profilePda - The player profile PDA address\n   141→ */\n   142→export async function fetchPlayerProfile(\n   143→  connection: Connection,\n   144→  profilePda: PublicKey,\n   145→): Promise<PlayerProfileAccount | null> {\n   146→  const program = getPlatformProgram(connection);\n   147→  try {\n   148→    return (await program.account.playerProfile.fetch(\n   149→      profilePda,\n   150→    )) as unknown as PlayerProfileAccount;\n   151→  } catch {\n   152→    return null;\n   153→  }\n   154→}\n   155→\n   156→/**\n   157→ * Get the treasury wallet address from the coinflip config PDA.\n   158→ *\n   159→ * @param connection - Solana RPC connection\n   160→ */\n   161→export async function getTreasuryAddress(\n   162→  connection: Connection,\n   163→): Promise<PublicKey> {\n   164→  const program = getCoinflipProgram(connection);\n   165→  const [configPda] = getConfigPda();\n   166→  const config = await program.account.coinflipConfig.fetch(configPda);\n   167→  return (config as unknown as { treasury: PublicKey }).treasury;\n   168→}\n   169→\n   170→// ============ Balance Helpers ============\n   171→\n   172→/**\n   173→ * Get the SOL balance of an address in lamports.\n   174→ *\n   175→ * @param connection - Solana RPC connection\n   176→ * @param address - Public key to check\n   177→ */\n   178→export async function getBalanceLamports(\n   179→  connection: Connection,\n   180→  address: PublicKey,\n   181→): Promise<number> {\n   182→  return connection.getBalance(address);\n   183→}\n   184→\n   185→/**\n   186→ * Capture a balance snapshot for later delta comparison.\n   187→ *\n   188→ * @param connection - Solana RPC connection\n   189→ * @param address - Public key to snapshot\n   190→ */\n   191→export async function snapshotBalance(\n   192→  connection: Connection,\n   193→  address: PublicKey,\n   194→): Promise<number> {\n   195→  return connection.getBalance(address);\n   196→}\n   197→\n   198→// ============ Fee Calculation ============\n   199→\n   200→/**\n   201→ * Calculate the expected fee and net payout for a coinflip match.\n   202→ * Mirrors on-chain logic: fee = floor(pool * FEE_BPS / 10_000).\n   203→ *\n   204→ * @param entryAmount - Single player's entry in lamports\n   205→ * @returns Object with pool, fee, and payout amounts in lamports\n   206→ */\n   207→export function calculateExpectedFee(entryAmount: number): {\n   208→  pool: number;\n   209→  fee: number;\n   210→  payout: number;\n   211→} {\n   212→  const pool = entryAmount * 2;\n   213→  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n   214→  const payout = pool - fee;\n   215→  return { pool, fee, payout };\n   216→}\n   217→\n   218→// ============ Assertion Helpers ============\n   219→\n   220→/**\n   221→ * Assert match PDA state after creation (Waiting phase).\n   222→ *\n   223→ * @param connection - Solana RPC connection\n   224→ * @param creator - Creator's public key\n   225→ * @param expectedTier - Expected tier index\n   226→ * @param expectedSide - Expected creator side (0 = heads, 1 = tails)\n   227→ */\n   228→export async function assertMatchCreated(\n   229→  connection: Connection,\n   230→  creator: PublicKey,\n   231→  expectedTier: number,\n   232→  expectedSide: number,\n   233→): Promise<{ matchPda: PublicKey; match: MatchAccount }> {\n   234→  const [matchPda] = getMatchPda(creator);\n   235→  const match = await fetchMatch(connection, matchPda);\n   236→  if (!match) throw new Error(`Match PDA not found for creator ${creator}`);\n   237→\n   238→  const phase = Object.keys(match.phase)[0];\n   239→  if (phase !== \"waiting\") {\n   240→    throw new Error(`Expected phase 'waiting', got '${phase}'`);\n   241→  }\n   242→  if (match.creator.toBase58() !== creator.toBase58()) {\n   243→    throw new Error(\"Match creator does not match expected creator\");\n   244→  }\n   245→  if (match.tier !== expectedTier) {\n   246→    throw new Error(`Expected tier ${expectedTier}, got ${match.tier}`);\n   247→  }\n   248→  if (match.creatorSide !== expectedSide) {\n   249→    throw new Error(`Expected side ${expectedSide}, got ${match.creatorSide}`);\n   250→  }\n   251→  if (match.opponent.toBase58() !== PublicKey.default.toBase58()) {\n   252→    throw new Error(\"Expected no opponent in waiting phase\");\n   253→  }\n   254→  if (match.claimed) {\n   255→    throw new Error(\"Expected claimed=false after creation\");\n   256→  }\n   257→\n   258→  return { matchPda, match };\n   259→}\n   260→\n   261→/**\n   262→ * Assert match PDA is closed (account no longer exists).\n   263→ *\n   264→ * @param connection - Solana RPC connection\n   265→ * @param matchPda - The match PDA address to check\n   266→ */\n   267→export async function assertMatchClosed(\n   268→  connection: Connection,\n   269→  matchPda: PublicKey,\n   270→): Promise<void> {\n   271→  const match = await fetchMatch(connection, matchPda);\n   272→  if (match !== null) {\n   273→    const phase = Object.keys(match.phase)[0];\n   274→    throw new Error(\n   275→      `Expected match PDA to be closed, but it still exists (phase: ${phase})`,\n   276→    );\n   277→  }\n   278→}\n   279→\n   280→/**\n   281→ * Assert that the treasury received the expected fee.\n   282→ * Call snapshotBalance before the payout, then call this after.\n   283→ *\n   284→ * @param connection - Solana RPC connection\n   285→ * @param treasury - Treasury public key\n   286→ * @param balanceBefore - Treasury balance in lamports before claim\n   287→ * @param entryAmount - Single player's entry in lamports\n   288→ */\n   289→export async function assertTreasuryFee(\n   290→  connection: Connection,\n   291→  treasury: PublicKey,\n   292→  balanceBefore: number,\n   293→  entryAmount: number,\n   294→): Promise<void> {\n   295→  const balanceAfter = await getBalanceLamports(connection, treasury);\n   296→  const { fee } = calculateExpectedFee(entryAmount);\n   297→  const actualDelta = balanceAfter - balanceBefore;\n   298→\n   299→  if (actualDelta !== fee) {\n   300→    throw new Error(\n   301→      `Treasury fee mismatch: expected ${fee} lamports, got delta ${actualDelta}`,\n   302→    );\n   303→  }\n   304→}\n   305→\n   306→/**\n   307→ * Assert player profile stats after a game.\n   308→ *\n   309→ * @param connection - Solana RPC connection\n   310→ * @param wallet - Player's wallet public key\n   311→ * @param expected - Expected stat values\n   312→ */\n   313→export async function assertPlayerProfile(\n   314→  connection: Connection,\n   315→  wallet: PublicKey,\n   316→  expected: {\n   317→    totalGames: number;\n   318→    wins: number;\n   319→    totalWagered: number;\n   320→    totalWon: number;\n   321→  },\n   322→): Promise<void> {\n   323→  const [profilePda] = getPlayerProfilePda(wallet);\n   324→  const profile = await fetchPlayerProfile(connection, profilePda);\n   325→  if (!profile) {\n   326→    throw new Error(`Player profile not found for ${wallet}`);\n   327→  }\n   328→\n   329→  const actual = {\n   330→    totalGames: profile.totalGames.toNumber(),\n   331→    wins: profile.wins.toNumber(),\n   332→    totalWagered: profile.totalWagered.toNumber(),\n   333→    totalWon: profile.totalWon.toNumber(),\n   334→  };\n   335→\n   336→  for (const key of Object.keys(expected) as (keyof typeof expected)[]) {\n   337→    if (actual[key] !== expected[key]) {\n   338→      throw new Error(\n   339→        `Profile ${key} mismatch for ${wallet}: expected ${expected[key]}, got ${actual[key]}`,\n   340→      );\n   341→    }\n   342→  }\n   343→}\n   344→\n   345→/**\n   346→ * Assert player profile stats changed by a specific delta since a snapshot.\n   347→ *\n   348→ * @param connection - Solana RPC connection\n   349→ * @param wallet - Player's wallet public key\n   350→ * @param before - Profile stats snapshot before the action\n   351→ * @param delta - Expected stat deltas\n   352→ */\n   353→export async function assertPlayerProfileDelta(\n   354→  connection: Connection,\n   355→  wallet: PublicKey,\n   356→  before: { totalGames: number; wins: number; totalWagered: number; totalWon: number },\n   357→  delta: { totalGames: number; wins: number; totalWagered: number; totalWon: number },\n   358→): Promise<void> {\n   359→  const expected = {\n   360→    totalGames: before.totalGames + delta.totalGames,\n   361→    wins: before.wins + delta.wins,\n   362→    totalWagered: before.totalWagered + delta.totalWagered,\n   363→    totalWon: before.totalWon + delta.totalWon,\n   364→  };\n   365→  await assertPlayerProfile(connection, wallet, expected);\n   366→}\n   367→\n   368→/**\n   369→ * Snapshot a player profile's current stats (for later delta comparison).\n   370→ * Returns zero-stats if the profile doesn't exist yet.\n   371→ *\n   372→ * @param connection - Solana RPC connection\n   373→ * @param wallet - Player's wallet public key\n   374→ */\n   375→export async function snapshotPlayerProfile(\n   376→  connection: Connection,\n   377→  wallet: PublicKey,\n   378→): Promise<{ totalGames: number; wins: number; totalWagered: number; totalWon: number }> {\n   379→  const [profilePda] = getPlayerProfilePda(wallet);\n   380→  const profile = await fetchPlayerProfile(connection, profilePda);\n   381→  if (!profile) {\n   382→    return { totalGames: 0, wins: 0, totalWagered: 0, totalWon: 0 };\n   383→  }\n   384→  return {\n   385→    totalGames: profile.totalGames.toNumber(),\n   386→    wins: profile.wins.toNumber(),\n   387→    totalWagered: profile.totalWagered.toNumber(),\n   388→    totalWon: profile.totalWon.toNumber(),\n   389→  };\n   390→}\n   391→"}]},"parent_tool_use_id":"toolu_01AeENyYJpdjuUxBr5j77amo","session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"760767e4-44e4-41d5-a22c-e565fa5b193b"}
