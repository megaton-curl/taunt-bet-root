{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SaNRZ4CLFf51MnoKQ4wKGi","type":"tool_result","content":"     1→/**\n     2→ * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. Connects to deployed devnet programs with\n     6→ * real Orao VRF fulfillment (no mock resolve shortcut).\n     7→ *\n     8→ * Prerequisites:\n     9→ * - Coinflip + Platform programs deployed to devnet\n    10→ * - Orao VRF initialized on devnet\n    11→ * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n    12→ * - Test wallets funded on devnet (handled in beforeAll)\n    13→ */\n    14→import { test, expect } from \"./fixtures\";\n    15→import * as po from \"../local/helpers/page-objects\";\n    16→import { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\n    17→import { validateDevnetEnv } from \"./helpers/env\";\n    18→import {\n    19→  pollVrfFulfillment,\n    20→  logRecentSignatures,\n    21→} from \"./helpers/vrf-polling\";\n    22→import {\n    23→  assertMatchCreated,\n    24→  assertMatchClosed,\n    25→  assertTreasuryFee,\n    26→  assertPlayerProfileDelta,\n    27→  calculateExpectedFee,\n    28→  getTreasuryAddress,\n    29→  snapshotBalance,\n    30→  snapshotPlayerProfile,\n    31→  getMatchPda,\n    32→} from \"../local/helpers/on-chain\";\n    33→import { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n    34→\n    35→// ── Devnet wallet funding ─────────────────────────────────────────────\n    36→\n    37→/** Minimum SOL balance required to run the test (entry + tx fees). */\n    38→const MIN_BALANCE_SOL = 0.1;\n    39→\n    40→/** Airdrop amount per request on devnet (max 2 SOL per request). */\n    41→const AIRDROP_SOL = 1;\n    42→\n    43→/**\n    44→ * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n    45→ * is below the minimum threshold. Retries once on failure (devnet rate limits).\n    46→ */\n    47→async function ensureFunded(\n    48→  connection: Connection,\n    49→  pubkey: PublicKey,\n    50→  label: string,\n    51→): Promise<void> {\n    52→  const balance = await connection.getBalance(pubkey);\n    53→  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    54→    console.log(\n    55→      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    56→    );\n    57→    return;\n    58→  }\n    59→\n    60→  console.log(\n    61→    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n    62→  );\n    63→\n    64→  for (let attempt = 1; attempt <= 2; attempt++) {\n    65→    try {\n    66→      const sig = await connection.requestAirdrop(\n    67→        pubkey,\n    68→        AIRDROP_SOL * LAMPORTS_PER_SOL,\n    69→      );\n    70→      const { blockhash, lastValidBlockHeight } =\n    71→        await connection.getLatestBlockhash();\n    72→      await connection.confirmTransaction(\n    73→        { signature: sig, blockhash, lastValidBlockHeight },\n    74→        \"confirmed\",\n    75→      );\n    76→      const newBalance = await connection.getBalance(pubkey);\n    77→      console.log(\n    78→        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n    79→      );\n    80→      return;\n    81→    } catch (err) {\n    82→      if (attempt < 2) {\n    83→        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n    84→        await new Promise((r) => setTimeout(r, 2_000));\n    85→      } else {\n    86→        throw new Error(\n    87→          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n    88→        );\n    89→      }\n    90→    }\n    91→  }\n    92→}\n    93→\n    94→// ── On-chain constants ───────────────────────────────────────────────\n    95→\n    96→/** Iron tier index. */\n    97→const TIER_IRON = 0;\n    98→\n    99→/** Heads side index. */\n   100→const SIDE_HEADS = 0;\n   101→\n   102→/** Iron tier entry amount in lamports (0.005 SOL). */\n   103→const ENTRY_AMOUNT = 5_000_000;\n   104→\n   105→// ── VRF fulfillment timeout ───────────────────────────────────────────\n   106→\n   107→/**\n   108→ * Timeout for waiting on real VRF fulfillment.\n   109→ * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n   110→ */\n   111→const VRF_FULFILLMENT_TIMEOUT = 90_000;\n   112→\n   113→// ── Suite setup ────────────────────────────────────────────────────────\n   114→\n   115→test.beforeAll(async () => {\n   116→  const config = validateDevnetEnv();\n   117→  console.log(\"Devnet lifecycle: funding test wallets...\");\n   118→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n   119→  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n   120→  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n   121→});\n   122→\n   123→// ── Full lifecycle test ────────────────────────────────────────────────\n   124→\n   125→test(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n   126→  playerAPage,\n   127→  playerBPage,\n   128→  connection,\n   129→}) => {\n   130→  // Track console errors in both contexts\n   131→  const consoleA = po.trackConsoleErrors(playerAPage);\n   132→  const consoleB = po.trackConsoleErrors(playerBPage);\n   133→\n   134→  // 1. Player A navigates and creates a match (iron tier, heads)\n   135→  await po.navigateToCoinflip(playerAPage);\n   136→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n   137→\n   138→  // Player A should see the active match in \"waiting\" state\n   139→  await expect(\n   140→    playerAPage.locator(po.sel.activeMatchWaiting),\n   141→  ).toBeVisible({ timeout: 15_000 });\n   142→\n   143→  // On-chain: verify match PDA state after creation\n   144→  const { matchPda } = await assertMatchCreated(\n   145→    connection,\n   146→    PLAYER_A.publicKey,\n   147→    TIER_IRON,\n   148→    SIDE_HEADS,\n   149→  );\n   150→  console.log(`[on-chain] Match PDA verified: ${matchPda.toBase58()}`);\n   151→\n   152→  // 2. Player B navigates (after match is created) and sees it in the lobby\n   153→  await po.navigateToCoinflip(playerBPage);\n   154→  await po.waitForLobbyMatch(playerBPage, 30_000);\n   155→\n   156→  // 3. Player B joins the match\n   157→  await po.joinMatch(playerBPage);\n   158→\n   159→  // On-chain: snapshot treasury and player profiles before resolution\n   160→  const treasury = await getTreasuryAddress(connection);\n   161→  const [treasuryBefore, profileABefore, profileBBefore] = await Promise.all([\n   162→    snapshotBalance(connection, treasury),\n   163→    snapshotPlayerProfile(connection, PLAYER_A.publicKey),\n   164→    snapshotPlayerProfile(connection, PLAYER_B.publicKey),\n   165→  ]);\n   166→  console.log(\n   167→    `[on-chain] Pre-claim snapshots: treasury=${treasuryBefore}, ` +\n   168→      `profileA=(games=${profileABefore.totalGames},wins=${profileABefore.wins}), ` +\n   169→      `profileB=(games=${profileBBefore.totalGames},wins=${profileBBefore.wins})`,\n   170→  );\n   171→\n   172→  // 4. Wait for real VRF fulfillment using dual strategy:\n   173→  //    a) On-chain polling with exponential backoff (detects VRF callback)\n   174→  //    b) UI result wait in parallel (detects frontend state update)\n   175→  //    Whichever resolves first wins — this ensures robustness even if\n   176→  //    the UI polling cycle is slow.\n   177→  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n   178→  const vrfStartTime = Date.now();\n   179→\n   180→  const [vrfPollResult, resultA, resultB] = await Promise.all([\n   181→    // On-chain poll: check match PDA phase with exponential backoff\n   182→    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n   183→      .then((r) => {\n   184→        console.log(\n   185→          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n   186→        );\n   187→        return r;\n   188→      })\n   189→      .catch((err) => {\n   190→        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n   191→        return null; // Don't fail test if UI detects it first\n   192→      }),\n   193→    // UI wait: Playwright waits for result CSS class on Player A's page\n   194→    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n   195→    // UI wait: Playwright waits for result CSS class on Player B's page\n   196→    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n   197→  ]);\n   198→\n   199→  const vrfElapsed = Date.now() - vrfStartTime;\n   200→  console.log(\n   201→    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n   202→  );\n   203→  if (vrfPollResult) {\n   204→    console.log(\n   205→      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n   206→    );\n   207→  }\n   208→\n   209→  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n   210→  expect(\n   211→    (resultA === \"won\" && resultB === \"lost\") ||\n   212→      (resultA === \"lost\" && resultB === \"won\"),\n   213→  ).toBe(true);\n   214→\n   215→  // 6. Winner claims payout\n   216→  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n   217→  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n   218→  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n   219→\n   220→  await po.claimOrSettle(winnerPage);\n   221→  console.log(`${winnerLabel} claimed payout`);\n   222→\n   223→  // Winner sees \"Back to Lobby\" after successful claim\n   224→  await expect(\n   225→    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   226→  ).toBeVisible({ timeout: 15_000 });\n   227→\n   228→  // 7. On-chain: verify match PDA is closed after claim\n   229→  await assertMatchClosed(connection, matchPda);\n   230→  console.log(\"[on-chain] Match PDA closed after claim\");\n   231→\n   232→  // 8. On-chain: verify treasury received expected fee\n   233→  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n   234→  const { fee, payout } = calculateExpectedFee(ENTRY_AMOUNT);\n   235→  console.log(`[on-chain] Treasury fee verified: ${fee} lamports`);\n   236→\n   237→  // 9. On-chain: verify player profile deltas\n   238→  const winnerKey = resultA === \"won\" ? PLAYER_A.publicKey : PLAYER_B.publicKey;\n   239→  const loserKey = resultA === \"lost\" ? PLAYER_A.publicKey : PLAYER_B.publicKey;\n   240→  const winnerProfileBefore = resultA === \"won\" ? profileABefore : profileBBefore;\n   241→  const loserProfileBefore = resultA === \"lost\" ? profileABefore : profileBBefore;\n   242→\n   243→  await assertPlayerProfileDelta(connection, winnerKey, winnerProfileBefore, {\n   244→    totalGames: 1,\n   245→    wins: 1,\n   246→    totalWagered: ENTRY_AMOUNT,\n   247→    totalWon: payout,\n   248→  });\n   249→  console.log(`[on-chain] Winner profile delta verified (${winnerLabel})`);\n   250→\n   251→  await assertPlayerProfileDelta(connection, loserKey, loserProfileBefore, {\n   252→    totalGames: 1,\n   253→    wins: 0,\n   254→    totalWagered: ENTRY_AMOUNT,\n   255→    totalWon: 0,\n   256→  });\n   257→  const loserLabel = resultA === \"lost\" ? \"Player A\" : \"Player B\";\n   258→  console.log(`[on-chain] Loser profile delta verified (${loserLabel})`);\n   259→\n   260→  // 10. Winner returns to lobby\n   261→  await po.backToLobby(winnerPage);\n   262→\n   263→  // 11. Loser settles (closes their view)\n   264→  await po.claimOrSettle(loserPage);\n   265→  await expect(\n   266→    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   267→  ).toBeVisible({ timeout: 15_000 });\n   268→  await po.backToLobby(loserPage);\n   269→\n   270→  // 12. Log transaction signatures for both players (diagnostic artifact)\n   271→  console.log(\"\\n--- Transaction Signature Log ---\");\n   272→  await logRecentSignatures(connection, PLAYER_A.publicKey, `Player A (${resultA})`);\n   273→  await logRecentSignatures(connection, PLAYER_B.publicKey, `Player B (${resultB})`);\n   274→\n   275→  // No unhandled console errors in either context\n   276→  consoleA.assertClean();\n   277→  consoleB.assertClean();\n   278→});\n   279→"}]},"parent_tool_use_id":null,"session_id":"1e7f5c42-b5f0-4a8d-9a19-a937ae16d5af","uuid":"e6036fc8-bf19-448b-af46-5cd960614664","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts","content":"/**\n * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. Connects to deployed devnet programs with\n * real Orao VRF fulfillment (no mock resolve shortcut).\n *\n * Prerequisites:\n * - Coinflip + Platform programs deployed to devnet\n * - Orao VRF initialized on devnet\n * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n * - Test wallets funded on devnet (handled in beforeAll)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"../local/helpers/page-objects\";\nimport { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\nimport { validateDevnetEnv } from \"./helpers/env\";\nimport {\n  pollVrfFulfillment,\n  logRecentSignatures,\n} from \"./helpers/vrf-polling\";\nimport {\n  assertMatchCreated,\n  assertMatchClosed,\n  assertTreasuryFee,\n  assertPlayerProfileDelta,\n  calculateExpectedFee,\n  getTreasuryAddress,\n  snapshotBalance,\n  snapshotPlayerProfile,\n  getMatchPda,\n} from \"../local/helpers/on-chain\";\nimport { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n\n// ── Devnet wallet funding ─────────────────────────────────────────────\n\n/** Minimum SOL balance required to run the test (entry + tx fees). */\nconst MIN_BALANCE_SOL = 0.1;\n\n/** Airdrop amount per request on devnet (max 2 SOL per request). */\nconst AIRDROP_SOL = 1;\n\n/**\n * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n * is below the minimum threshold. Retries once on failure (devnet rate limits).\n */\nasync function ensureFunded(\n  connection: Connection,\n  pubkey: PublicKey,\n  label: string,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    console.log(\n      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    );\n    return;\n  }\n\n  console.log(\n    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n  );\n\n  for (let attempt = 1; attempt <= 2; attempt++) {\n    try {\n      const sig = await connection.requestAirdrop(\n        pubkey,\n        AIRDROP_SOL * LAMPORTS_PER_SOL,\n      );\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      await connection.confirmTransaction(\n        { signature: sig, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      const newBalance = await connection.getBalance(pubkey);\n      console.log(\n        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n      );\n      return;\n    } catch (err) {\n      if (attempt < 2) {\n        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n        await new Promise((r) => setTimeout(r, 2_000));\n      } else {\n        throw new Error(\n          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n        );\n      }\n    }\n  }\n}\n\n// ── On-chain constants ───────────────────────────────────────────────\n\n/** Iron tier index. */\nconst TIER_IRON = 0;\n\n/** Heads side index. */\nconst SIDE_HEADS = 0;\n\n/** Iron tier entry amount in lamports (0.005 SOL). */\nconst ENTRY_AMOUNT = 5_000_000;\n\n// ── VRF fulfillment timeout ───────────────────────────────────────────\n\n/**\n * Timeout for waiting on real VRF fulfillment.\n * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n */\nconst VRF_FULFILLMENT_TIMEOUT = 90_000;\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  const config = validateDevnetEnv();\n  console.log(\"Devnet lifecycle: funding test wallets...\");\n  const connection = new Connection(config.rpcUrl, \"confirmed\");\n  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // On-chain: verify match PDA state after creation\n  const { matchPda } = await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    TIER_IRON,\n    SIDE_HEADS,\n  );\n  console.log(`[on-chain] Match PDA verified: ${matchPda.toBase58()}`);\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 30_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // On-chain: snapshot treasury and player profiles before resolution\n  const treasury = await getTreasuryAddress(connection);\n  const [treasuryBefore, profileABefore, profileBBefore] = await Promise.all([\n    snapshotBalance(connection, treasury),\n    snapshotPlayerProfile(connection, PLAYER_A.publicKey),\n    snapshotPlayerProfile(connection, PLAYER_B.publicKey),\n  ]);\n  console.log(\n    `[on-chain] Pre-claim snapshots: treasury=${treasuryBefore}, ` +\n      `profileA=(games=${profileABefore.totalGames},wins=${profileABefore.wins}), ` +\n      `profileB=(games=${profileBBefore.totalGames},wins=${profileBBefore.wins})`,\n  );\n\n  // 4. Wait for real VRF fulfillment using dual strategy:\n  //    a) On-chain polling with exponential backoff (detects VRF callback)\n  //    b) UI result wait in parallel (detects frontend state update)\n  //    Whichever resolves first wins — this ensures robustness even if\n  //    the UI polling cycle is slow.\n  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n  const vrfStartTime = Date.now();\n\n  const [vrfPollResult, resultA, resultB] = await Promise.all([\n    // On-chain poll: check match PDA phase with exponential backoff\n    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n      .then((r) => {\n        console.log(\n          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n        );\n        return r;\n      })\n      .catch((err) => {\n        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n        return null; // Don't fail test if UI detects it first\n      }),\n    // UI wait: Playwright waits for result CSS class on Player A's page\n    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n    // UI wait: Playwright waits for result CSS class on Player B's page\n    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n  ]);\n\n  const vrfElapsed = Date.now() - vrfStartTime;\n  console.log(\n    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n  );\n  if (vrfPollResult) {\n    console.log(\n      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n    );\n  }\n\n  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n  expect(\n    (resultA === \"won\" && resultB === \"lost\") ||\n      (resultA === \"lost\" && resultB === \"won\"),\n  ).toBe(true);\n\n  // 6. Winner claims payout\n  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n\n  await po.claimOrSettle(winnerPage);\n  console.log(`${winnerLabel} claimed payout`);\n\n  // Winner sees \"Back to Lobby\" after successful claim\n  await expect(\n    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 7. On-chain: verify match PDA is closed after claim\n  await assertMatchClosed(connection, matchPda);\n  console.log(\"[on-chain] Match PDA closed after claim\");\n\n  // 8. On-chain: verify treasury received expected fee\n  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n  const { fee, payout } = calculateExpectedFee(ENTRY_AMOUNT);\n  console.log(`[on-chain] Treasury fee verified: ${fee} lamports`);\n\n  // 9. On-chain: verify player profile deltas\n  const winnerKey = resultA === \"won\" ? PLAYER_A.publicKey : PLAYER_B.publicKey;\n  const loserKey = resultA === \"lost\" ? PLAYER_A.publicKey : PLAYER_B.publicKey;\n  const winnerProfileBefore = resultA === \"won\" ? profileABefore : profileBBefore;\n  const loserProfileBefore = resultA === \"lost\" ? profileABefore : profileBBefore;\n\n  await assertPlayerProfileDelta(connection, winnerKey, winnerProfileBefore, {\n    totalGames: 1,\n    wins: 1,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: payout,\n  });\n  console.log(`[on-chain] Winner profile delta verified (${winnerLabel})`);\n\n  await assertPlayerProfileDelta(connection, loserKey, loserProfileBefore, {\n    totalGames: 1,\n    wins: 0,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: 0,\n  });\n  const loserLabel = resultA === \"lost\" ? \"Player A\" : \"Player B\";\n  console.log(`[on-chain] Loser profile delta verified (${loserLabel})`);\n\n  // 10. Winner returns to lobby\n  await po.backToLobby(winnerPage);\n\n  // 11. Loser settles (closes their view)\n  await po.claimOrSettle(loserPage);\n  await expect(\n    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n  await po.backToLobby(loserPage);\n\n  // 12. Log transaction signatures for both players (diagnostic artifact)\n  console.log(\"\\n--- Transaction Signature Log ---\");\n  await logRecentSignatures(connection, PLAYER_A.publicKey, `Player A (${resultA})`);\n  await logRecentSignatures(connection, PLAYER_B.publicKey, `Player B (${resultB})`);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","numLines":279,"startLine":1,"totalLines":279}}}
