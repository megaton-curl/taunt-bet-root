typecheck: > @rng-utopia/game-of-trades@0.1.0 typecheck /workspaces/rng-utopia/sources/rng-utopia/apps/game-of-trades\n@rng-utopia/game-of-trades:typecheck: > tsc --noEmit\n@rng-utopia/game-of-trades:typecheck: \n@rng-utopia/lord-of-rngs:typecheck: \n@rng-utopia/lord-of-rngs:typecheck: > @rng-utopia/lord-of-rngs@0.1.0 typecheck /workspaces/rng-utopia/sources/rng-utopia/apps/lord-of-rngs\n@rng-utopia/lord-of-rngs:typecheck: > tsc --noEmit\n@rng-utopia/lord-of-rngs:typecheck: \n\n Tasks:    17 successful, 17 total\nCached:    7 cached, 17 total\n  Time:    17.706s","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
