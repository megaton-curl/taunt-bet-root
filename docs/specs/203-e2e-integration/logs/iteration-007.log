\n      ? import.meta.env?.VITE_RPC_URL\n      : undefined;\n  return envUrl || DEFAULT_RPC_URL;\n}\n\ninterface WalletProviderProps {\n  children: ReactNode;\n}\n\nfunction delay(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nconst baseFetch = globalThis.fetch?.bind(globalThis);\n\nconst rpcFetch: typeof fetch = async (input, init) => {\n  if (!baseFetch) {\n    throw new Error(\"Global fetch is not available in this environment.\");\n  }\n\n  let attempt = 0;\n  let retryDelayMs = RPC_INITIAL_RETRY_DELAY_MS;\n  let response = await baseFetch(input, init);\n\n  while (response.status === 429 && attempt < RPC_MAX_RETRIES) {\n    await delay(retryDelayMs);\n    attempt += 1;\n    retryDelayMs *= 2;\n    response = await baseFetch(input, init);\n  }\n\n  return response;\n};\n\nconst connectionConfig: ConnectionConfig = {\n  commitment: \"confirmed\",\n  // Disable web3.js internal 429 retries so we can control retry timing.\n  disableRetryOnRateLimit: true,\n  fetch: rpcFetch,\n};\n\nfunction isMockMode(): boolean {\n  const flag =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_MOCK_MODE\n      : undefined;\n  // Default to real mode — only mock when explicitly set to \"true\"\n  return flag === \"true\";\n}\n\n/**\n * Unified WalletProvider.\n * Wraps both Mock and Real providers with a shared ConnectionProvider.\n */\nexport function WalletProvider({ children }: WalletProviderProps) {\n  const endpoint = getRpcUrl();\n\n  const inner = isMockMode() ? (\n    <MockWalletProvider>{children}</MockWalletProvider>\n  ) : (\n    <Suspense fallback={null}>\n      <RealWalletProvider>{children}</RealWalletProvider>\n    </Suspense>\n  );\n\n  return (\n    <ConnectionProvider endpoint={endpoint} config={connectionConfig}>\n      {inner}\n    </ConnectionProvider>\n  );\n}\n","structuredPatch":[{"oldStart":10,"oldLines":6,"newStart":10,"newLines":13,"lines":["   })),"," );"," ","+// Lazy-load TestWall