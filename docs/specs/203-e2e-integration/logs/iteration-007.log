om \"@playwright/test\";\n\n/**\n * Playwright config for local E2E integration tests.\n *\n * Runs against a local solana-test-validator with real wallet mode.\n * The validator + program deploy is handled by external bootstrap scripts;\n * this config only starts the Vite dev server.\n */\nexport default defineConfig({\n  testDir: \"./e2e\",\n  fullyParallel: false,\n  forbidOnly: !!process.env.CI,\n  retries: 0,\n  workers: 1,\n  reporter: \"list\",\n  timeout: 60_000,\n\n  use: {\n    baseURL: \"http://localhost:3002\",\n    screenshot: \"off\",\n    trace: \"retain-on-failure\",\n    ...devices[\"Desktop Chrome\"],\n    viewport: { width: 1280, height: 1080 },\n  },\n\n  projects: [\n    {\n      name: \"local-e2e\",\n      testMatch: \"local/**/*.spec.ts\",\n      use: { ...devices[\"Desktop Chrome\"], viewport: { width: 1280, height: 1080 } },\n    },\n  ],\n\n  webServer: {\n    command: \"npx vite --port 3002\",\n    url: \"http://localhost:3002\",\n    reuseExistingServer: !process.env.CI,\n    timeout: 30_000,\n    env: {\n      VITE_MOCK_MODE: \"false\",\n      VITE_RPC_URL: \"http://127.0.0.1:8899\",\n      VITE_SOLANA_NETWORK: \"localnet\",\n    },\n  },\n});\n","numLines":47,"startLine":1,"totalLines":47}}}
