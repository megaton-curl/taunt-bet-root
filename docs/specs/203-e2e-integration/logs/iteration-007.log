{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SDkZY2cbWr4iVchxpLEdVf","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Ee6PSDCeLJcBUN6oUKyRyr","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/test/TestWalletWrapper.tsx","content":"import { ReactNode } from \"react\";\nimport { Keypair } from \"@solana/web3.js\";\nimport { TestWalletProvider } from \"./TestWalletProvider\";\n\ninterface TestWalletWrapperProps {\n  children: ReactNode;\n}\n\n/**\n * Reads a 32-byte seed from `window.__TEST_WALLET_SEED__` (injected by\n * Playwright `addInitScript`) and renders TestWalletProvider with the\n * corresponding Keypair.\n *\n * This component is lazy-loaded by WalletProvider when VITE_TEST_WALLET=\"true\".\n */\nexport function TestWalletWrapper({ children }: TestWalletWrapperProps) {\n  const seed: Uint8Array | undefined =\n    typeof window !== \"undefined\"\n      ? (window as Record<string, unknown>).__TEST_WALLET_SEED__ as\n          | Uint8Array\n          | undefined\n      : undefined;\n\n  if (!seed) {\n    throw new Error(\n      \"TestWalletWrapper: window.__TEST_WALLET_SEED__ not found. \" +\n        \"Inject it via Playwright addInitScript before loading the app.\",\n    );\n  }\n\n  const keypair = Keypair.fromSeed(new Uint8Array(seed));\n  const rpcUrl =\n    typeof import.meta !== \"undefined\"\n      ? (import.meta.env?.VITE_RPC_URL as string | undefined)\n      : undefined;\n\n  return (\n    <TestWalletProvider keypair={keypair} rpcUrl={rpcUrl || undefined}>\n      {children}\n    </TestWalletProvider>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":495,"cache_read_input_tokens":61322,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":495},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"610aad72-d9dc-40e7-807d-09548f27772e","uuid":"669ed16d-09b8-429c-ac2d-7c2e1529e50c"}
