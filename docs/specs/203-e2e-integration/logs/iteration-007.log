{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CXfPGTgz6gBuFJ3HN4ndG6","type":"tool_result","content":"     1→import { PublicKey, Transaction } from \"@solana/web3.js\";\n     2→\n     3→export interface WalletState {\n     4→  connected: boolean;\n     5→  connecting: boolean;\n     6→  address: string | null;\n     7→  publicKey: PublicKey | null;\n     8→}\n     9→\n    10→export interface WalletContextValue extends WalletState {\n    11→  connect: () => Promise<void>;\n    12→  disconnect: () => Promise<void>;\n    13→  sendTransaction: (transaction: Transaction) => Promise<string>;\n    14→  signMessage: (message: Uint8Array) => Promise<Uint8Array>;\n    15→  /** True if using mock wallet */\n    16→  isMock?: boolean;\n    17→  /** Get mock balance in SOL (mock mode only) */\n    18→  getBalance?: () => number;\n    19→  /** Get mock balance in lamports (mock mode only) */\n    20→  getBalanceLamports?: () => number;\n    21→  /** Update mock balance (mock mode only) */\n    22→  updateBalance?: (deltaLamports: number) => void;\n    23→}\n    24→"}]},"parent_tool_use_id":"toolu_012fuyv1SijUPFi6jhXvC6cK","session_id":"610aad72-d9dc-40e7-807d-09548f27772e","uuid":"4357c071-8de5-4aa4-b548-e45288b18c2e"}
