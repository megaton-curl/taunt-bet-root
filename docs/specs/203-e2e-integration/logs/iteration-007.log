new Uint8Array(seed));\n  const rpcUrl =\n    typeof import.meta !== \"undefined\"\n      ? (import.meta.env?.VITE_RPC_URL as string | undefined)\n      : undefined;\n\n  return (\n    <TestWalletProvider keypair={keypair} rpcUrl={rpcUrl || undefined}>\n      {children}\n    </TestWalletProvider>\n  );\n}\n","structuredPatch":[{"oldStart":16,"oldLines":9,"newStart":16,"newLines":9,"lines":[" export function TestWalletWrapper({ children }: TestWalletWrapperProps) {","   const seed: Uint8Array | undefined =","     typeof window !== \"undefined\"","-      ? (window as Record<string, unknown>).__TEST_WALLET_SEED__ as","+      ? ((window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ as","           | Uint8Array","-          | undefined","+          | undefined)","       : undefined;"," ","   if (!seed) {"]}],"userModified":false,"replaceAll":false}}
