{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KoeQSKrS4K4QPRxpj6fgpA","type":"tool_result","content":"     1→import { ReactNode, useCallback, useMemo } from \"react\";\n     2→import { Transaction } from \"@solana/web3.js\";\n     3→import {\n     4→  useConnection,\n     5→  useWallet as useAdapterWallet,\n     6→} from \"@solana/wallet-adapter-react\";\n     7→import {\n     8→  UnifiedWalletProvider,\n     9→  useUnifiedWalletContext,\n    10→} from \"@jup-ag/wallet-adapter\";\n    11→import { WalletContext } from \"../context\";\n    12→import type { WalletContextValue } from \"../types\";\n    13→\n    14→function getCluster(): \"devnet\" | \"testnet\" | \"mainnet-beta\" {\n    15→  const network =\n    16→    typeof import.meta !== \"undefined\"\n    17→      ? import.meta.env?.VITE_SOLANA_NETWORK\n    18→      : undefined;\n    19→  if (network === \"mainnet-beta\" || network === \"testnet\") return network;\n    20→  return \"devnet\";\n    21→}\n    22→\n    23→/**\n    24→ * Bridge component that reads from @solana/wallet-adapter-react hooks\n    25→ * and maps them to our WalletContextValue, then provides via WalletContext.\n    26→ */\n    27→function WalletBridge({ children }: { children: ReactNode }) {\n    28→  const adapter = useAdapterWallet();\n    29→  const { connection } = useConnection();\n    30→  const { setShowModal } = useUnifiedWalletContext();\n    31→\n    32→  const connect = useCallback(async () => {\n    33→    // If already connected to a wallet, just reconnect\n    34→    if (adapter.wallet) {\n    35→      await adapter.connect();\n    36→      return;\n    37→    }\n    38→    // Otherwise open the Unified Wallet modal for wallet selection\n    39→    setShowModal(true);\n    40→  }, [adapter, setShowModal]);\n    41→\n    42→  const disconnect = useCallback(async () => {\n    43→    await adapter.disconnect();\n    44→  }, [adapter]);\n    45→\n    46→  const sendTransaction = useCallback(\n    47→    async (transaction: Transaction): Promise<string> => {\n    48→      if (!adapter.publicKey) {\n    49→        throw new Error(\"Wallet not connected\");\n    50→      }\n    51→      const signature = await adapter.sendTransaction(transaction, connection);\n    52→      return signature;\n    53→    },\n    54→    [adapter, connection],\n    55→  );\n    56→\n    57→  const signMessage = useCallback(\n    58→    async (message: Uint8Array): Promise<Uint8Array> => {\n    59→      if (!adapter.signMessage) {\n    60→        throw new Error(\"Wallet does not support message signing\");\n    61→      }\n    62→      return adapter.signMessage(message);\n    63→    },\n    64→    [adapter],\n    65→  );\n    66→\n    67→  const value: WalletContextValue = useMemo(\n    68→    () => ({\n    69→      connected: adapter.connected,\n    70→      connecting: adapter.connecting,\n    71→      address: adapter.publicKey?.toBase58() ?? null,\n    72→      publicKey: adapter.publicKey,\n    73→      connect,\n    74→      disconnect,\n    75→      sendTransaction,\n    76→      signMessage,\n    77→      isMock: false,\n    78→    }),\n    79→    [\n    80→      adapter.connected,\n    81→      adapter.connecting,\n    82→      adapter.publicKey,\n    83→      connect,\n    84→      disconnect,\n    85→      sendTransaction,\n    86→      signMessage,\n    87→    ],\n    88→  );\n    89→\n    90→  return (\n    91→    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n    92→  );\n    93→}\n    94→\n    95→interface RealWalletProviderProps {\n    96→  children: ReactNode;\n    97→}\n    98→\n    99→export function RealWalletProvider({ children }: RealWalletProviderProps) {\n   100→  const cluster = getCluster();\n   101→\n   102→  return (\n   103→    <UnifiedWalletProvider\n   104→      wallets={[]}\n   105→      config={{\n   106→        autoConnect: true,\n   107→        env: cluster,\n   108→        metadata: {\n   109→          name: \"RNG Utopia\",\n   110→          description: \"The ultimate on-chain gaming platform\",\n   111→          url: \"https://rngutopia.com\",\n   112→          iconUrls: [],\n   113→        },\n   114→        theme: \"dark\",\n   115→      }}\n   116→    >\n   117→      <WalletBridge>{children}</WalletBridge>\n   118→    </UnifiedWalletProvider>\n   119→  );\n   120→}\n   121→"}]},"parent_tool_use_id":"toolu_012fuyv1SijUPFi6jhXvC6cK","session_id":"610aad72-d9dc-40e7-807d-09548f27772e","uuid":"9f0db930-3a28-4152-8e8a-4656e17644f8"}
