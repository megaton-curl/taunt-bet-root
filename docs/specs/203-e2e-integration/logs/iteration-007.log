{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JrtrkErDs1ZGxkqjMJndhi","type":"tool_result","content":"     1→import { ReactNode, lazy, Suspense } from \"react\";\n     2→import { ConnectionProvider } from \"@solana/wallet-adapter-react\";\n     3→import type { ConnectionConfig } from \"@solana/web3.js\";\n     4→import { MockWalletProvider } from \"./mock\";\n     5→\n     6→// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     7→const RealWalletProvider = lazy(() =>\n     8→  import(\"./real/RealWalletProvider\").then((m) => ({\n     9→    default: m.RealWalletProvider,\n    10→  })),\n    11→);\n    12→\n    13→// Re-export WalletContext from the shared context file\n    14→export { WalletContext } from \"./context\";\n    15→\n    16→const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    17→const RPC_MAX_RETRIES = 3;\n    18→const RPC_INITIAL_RETRY_DELAY_MS = 1000;\n    19→\n    20→function getRpcUrl(): string {\n    21→  const envUrl =\n    22→    typeof import.meta !== \"undefined\"\n    23→      ? import.meta.env?.VITE_RPC_URL\n    24→      : undefined;\n    25→  return envUrl || DEFAULT_RPC_URL;\n    26→}\n    27→\n    28→interface WalletProviderProps {\n    29→  children: ReactNode;\n    30→}\n    31→\n    32→function delay(ms: number): Promise<void> {\n    33→  return new Promise((resolve) => setTimeout(resolve, ms));\n    34→}\n    35→\n    36→const baseFetch = globalThis.fetch?.bind(globalThis);\n    37→\n    38→const rpcFetch: typeof fetch = async (input, init) => {\n    39→  if (!baseFetch) {\n    40→    throw new Error(\"Global fetch is not available in this environment.\");\n    41→  }\n    42→\n    43→  let attempt = 0;\n    44→  let retryDelayMs = RPC_INITIAL_RETRY_DELAY_MS;\n    45→  let response = await baseFetch(input, init);\n    46→\n    47→  while (response.status === 429 && attempt < RPC_MAX_RETRIES) {\n    48→    await delay(retryDelayMs);\n    49→    attempt += 1;\n    50→    retryDelayMs *= 2;\n    51→    response = await baseFetch(input, init);\n    52→  }\n    53→\n    54→  return response;\n    55→};\n    56→\n    57→const connectionConfig: ConnectionConfig = {\n    58→  commitment: \"confirmed\",\n    59→  // Disable web3.js internal 429 retries so we can control retry timing.\n    60→  disableRetryOnRateLimit: true,\n    61→  fetch: rpcFetch,\n    62→};\n    63→\n    64→function isMockMode(): boolean {\n    65→  const flag =\n    66→    typeof import.meta !== \"undefined\"\n    67→      ? import.meta.env?.VITE_MOCK_MODE\n    68→      : undefined;\n    69→  // Default to real mode — only mock when explicitly set to \"true\"\n    70→  return flag === \"true\";\n    71→}\n    72→\n    73→/**\n    74→ * Unified WalletProvider.\n    75→ * Wraps both Mock and Real providers with a shared ConnectionProvider.\n    76→ */\n    77→export function WalletProvider({ children }: WalletProviderProps) {\n    78→  const endpoint = getRpcUrl();\n    79→\n    80→  const inner = isMockMode() ? (\n    81→    <MockWalletProvider>{children}</MockWalletProvider>\n    82→  ) : (\n    83→    <Suspense fallback={null}>\n    84→      <RealWalletProvider>{children}</RealWalletProvider>\n    85→    </Suspense>\n    86→  );\n    87→\n    88→  return (\n    89→    <ConnectionProvider endpoint={endpoint} config={connectionConfig}>\n    90→      {inner}\n    91→    </ConnectionProvider>\n    92→  );\n    93→}\n    94→"}]},"parent_tool_use_id":null,"session_id":"610aad72-d9dc-40e7-807d-09548f27772e","uuid":"550a3344-61d7-4736-be9e-c58c093d262a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/WalletProvider.tsx","content":"import { ReactNode, lazy, Suspense } from \"react\";\nimport { ConnectionProvider } from \"@solana/wallet-adapter-react\";\nimport type { ConnectionConfig } from \"@solana/web3.js\";\nimport { MockWalletProvider } from \"./mock\";\n\n// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\nconst RealWalletProvider = lazy(() =>\n  import(\"./real/RealWalletProvider\").then((m) => ({\n    default: m.RealWalletProvider,\n  })),\n);\n\n// Re-export WalletContext from the shared context file\nexport { WalletContext } from \"./context\";\n\nconst DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\nconst RPC_MAX_RETRIES = 3;\nconst RPC_INITIAL_RETRY_DELAY_MS = 1000;\n\nfunction getRpcUrl(): string {\n  const envUrl =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_RPC_URL\n      : undefined;\n  return envUrl || DEFAULT_RPC_URL;\n}\n\ninterface WalletProviderProps {\n  children: ReactNode;\n}\n\nfunction delay(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nconst baseFetch = globalThis.fetch?.bind(globalThis);\n\nconst rpcFetch: typeof fetch = async (input, init) => {\n  if (!baseFetch) {\n    throw new Error(\"Global fetch is not available in this environment.\");\n  }\n\n  let attempt = 0;\n  let retryDelayMs = RPC_INITIAL_RETRY_DELAY_MS;\n  let response = await baseFetch(input, init);\n\n  while (response.status === 429 && attempt < RPC_MAX_RETRIES) {\n    await delay(retryDelayMs);\n    attempt += 1;\n    retryDelayMs *= 2;\n    response = await baseFetch(input, init);\n  }\n\n  return response;\n};\n\nconst connectionConfig: ConnectionConfig = {\n  commitment: \"confirmed\",\n  // Disable web3.js internal 429 retries so we can control retry timing.\n  disableRetryOnRateLimit: true,\n  fetch: rpcFetch,\n};\n\nfunction isMockMode(): boolean {\n  const flag =\n    typeof import.meta !== \"undefined\"\n      ? import.meta.env?.VITE_MOCK_MODE\n      : undefined;\n  // Default to real mode — only mock when explicitly set to \"true\"\n  return flag === \"true\";\n}\n\n/**\n * Unified WalletProvider.\n * Wraps both Mock and Real providers with a shared ConnectionProvider.\n */\nexport function WalletProvider({ children }: WalletProviderProps) {\n  const endpoint = getRpcUrl();\n\n  const inner = isMockMode() ? (\n    <MockWalletProvider>{children}</MockWalletProvider>\n  ) : (\n    <Suspense fallback={null}>\n      <RealWalletProvider>{children}</RealWalletProvider>\n    </Suspense>\n  );\n\n  return (\n    <ConnectionProvider endpoint={endpoint} config={connectionConfig}>\n      {inner}\n    </ConnectionProvider>\n  );\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
