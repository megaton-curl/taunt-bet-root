io_uring; Docker blocks it unless --security-opt=seccomp=unconfined\n    43→if python3 -c \"import ctypes, ctypes.util; libc=ctypes.CDLL(ctypes.util.find_library('c'),use_errno=True); libc.syscall(425,1,ctypes.c_char_p(b'\\0'*120)); import ctypes; exit(0 if ctypes.get_errno()!=38 else 1)\" 2>/dev/null; then\n    44→  : # io_uring available\n    45→else\n    46→  echo \"ERROR: io_uring syscall blocked (ENOSYS). Solana 3.x requires io_uring.\" >&2\n    47→  echo \"       Add '--security-opt=seccomp=unconfined' to your Docker/devcontainer runArgs.\" >&2\n    48→  exit 1\n    49→fi\n    50→\n    51→# ── Kill any existing validator ───────────────────────────────────────\n    52→if [[ -f \"$PID_FILE\" ]]; then\n    53→  OLD_PID=$(cat \"$PID_FILE\")\n    54→  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    55→    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    56→    kill \"$OLD_PID\" 2>/dev/null || true\n    57→    sleep 1\n    58→    kill -9 \"$OLD_PID\" 2>/dev/null || true\n    59→  fi\n    60→  rm -f \"$PID_FILE\"\n    61→fi\n    62→\n    63→# Also kill any stray validator on the same port\n    64→if lsof -ti :8899 &>/dev/null; then\n    65→  echo \"Killing process on port 8899...\"\n    66→  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n    67→  sleep 1\n    68→fi\n    69→\n    70→# ── Clean ledger for fresh state ──────────────────────────────────────\n    71→rm -rf \"$LEDGER_DIR\"\n    72→\n    73→# ── Start validator with programs preloaded at genesis ────────────────\n    74→echo \"Starting solana-test-validator...\"\n    75→solana-test-validator \\\n    76→  --ledger \"$LEDGER_DIR\" \\\n    77→  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n    78→  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n    79→  --account 5ER1oENnV4srxYdAynUfRzWeQCPQaqMiAp4VqyMbSqnK \"$ACCOUNTS_DIR/orao-network-state.json\" \\\n    80→  --account S4ne8ejGPUwNMNsE8L7gtjbTaBLBfVGdWNH6VQrL58a \"$ACCOUNTS_DIR/orao-random-player-a.json\" \\\n    81→  --account Ecs89dz8NsNoSxyUtp54G2HPbmvJr8qZnxnWUqiLT92r \"$ACCOUNTS_DIR/orao-treasury.json\" \\\n    82→  --reset \\\n    83→  --quiet \\\n    84→  > \"$LOG_FILE\" 2>&1 &\n    85→\n    86→VALIDATOR_PID=$!\n    87→echo \"$VALIDATOR_PID\" > \"$PID_FILE\"\n    88→echo \"Validator PID: $VALIDATOR_PID\"\n    89→\n    90→# ── Wait for RPC readiness ────────────────────────────────────────────\n    91→echo -n \"Waiting for RPC at $RPC_URL\"\n    92→ELAPSED=0\n    93→while (( ELAPSED < MAX_WAIT )); do\n    94→  if curl -s \"$RPC_URL\" \\\n    95→    -X POST \\\n    96→    -H \"Content-Type: application/json\" \\\n    97→    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    98→    | grep -q '\"result\"'; then\n    99→    echo \" ready (${ELAPSED}s)\"\n   100→    echo \"Localnet bootstrap complete.\"\n   101→    exit 0\n   102→  fi\n   103→\n   104→  # Check validator is still running\n   105→  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n   106→    echo \"\"\n   107→    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n   108→    tail -20 \"$LOG_FILE\" >&2\n   109→    rm -f \"$PID_FILE\"\n   110→    exit 1\n   111→  fi\n   112→\n   113→  sleep 1\n   114→  (( ELAPSED++ ))\n   115→  echo -n \".\"\n   116→done\n   117→\n   118→echo \"\"\n   119→echo \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\n   120→tail -20 \"$LOG_FILE\" >&2\n   121→kill \"$VALIDATOR_PID\" 2>/dev/null || true\n   122→rm -f \"$PID_FILE\"\n   123→exit 1\n   124→"}]},"parent_tool_use_id":null,"session_id":"2ba24589-b147-45b6-b7a4-325b1a39ca4a","uuid":"c70780b6-00a2-44e2-be7a-10d5de5ba549","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/scripts/localnet-bootstrap.sh","content":"#!/usr/bin/env bash\n# localnet-bootstrap.sh — Start a fresh solana-test-validator with coinflip + platform programs.\n# Usage: ./scripts/localnet-bootstrap.sh\n# Writes validator PID to .localnet.pid for teardown.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nPLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\nSOLANA_DIR=\"$(cd \"$PLATFORM_DIR/../../solana\" && pwd)\"\n\nCOINFLIP_SO=\"$SOLANA_DIR/target/deploy/coinflip.so\"\nPLATFORM_SO=\"$SOLANA_DIR/target/deploy/platform.so\"\nCOINFLIP_KEYPAIR=\"$SOLANA_DIR/target/deploy/coinflip-keypair.json\"\nPLATFORM_KEYPAIR=\"$SOLANA_DIR/target/deploy/platform-keypair.json\"\n\nCOINFLIP_ID=\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\nPLATFORM_ID=\"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n\n# Mock Orao VRF accounts (pre-loaded for deterministic local E2E tests)\nACCOUNTS_DIR=\"$SCRIPT_DIR/localnet-accounts\"\n\nRPC_URL=\"http://127.0.0.1:8899\"\nPID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\nLEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\nLOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n\nMAX_WAIT=30  # seconds to wait for RPC readiness\n\n# ── Preflight checks ─────────────────────────────────────────────────\nfor f in \"$COINFLIP_SO\" \"$PLATFORM_SO\" \"$COINFLIP_KEYPAIR\" \"$PLATFORM_KEYPAIR\"; do\n  if [[ ! -f \"$f\" ]]; then\n    echo \"ERROR: Missing $f — run 'anchor build' first.\" >&2\n    exit 1\n  fi\ndone\n\nif ! command -v solana-test-validator &>/dev/null; then\n  echo \"ERROR: solana-test-validator not found on PATH.\" >&2\n  exit 1\nfi\n\n# Solana 3.x requires io_uring; Docker blocks it unless --security-opt=seccomp=unconfined\nif python3 -c \"import ctypes, ctypes.util; libc=ctypes.CDLL(ctypes.util.find_library('c'),use_errno=True); libc.syscall(425,1,ctypes.c_char_p(b'\\0'*120)); import ctypes; exit(0 if ctypes.get_errno()!=38 else 1)\" 2>/dev/null; then\n  : # io_uring available\nelse\n  echo \"ERROR: io_uring syscall blocked (ENOSYS). Solana 3.x requires io_uring.\" >&2\n  echo \"       Add '--security-opt=seccomp=unconfined' to your Docker/devcontainer runArgs.\" >&2\n  exit 1\nfi\n\n# ── Kill any existing validator ───────────────────────────────────────\nif [[ -f \"$PID_FILE\" ]]; then\n  OLD_PID=$(cat \"$PID_FILE\")\n  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    kill \"$OLD_PID\" 2>/dev/null || true\n    sleep 1\n    kill -9 \"$OLD_PID\" 2>/dev/null || true\n  fi\n  rm -f \"$PID_FILE\"\nfi\n\n# Also kill any stray validator on the same port\nif lsof -ti :8899 &>/dev/null; then\n  echo \"Killing process on port 8899...\"\n  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n  sleep 1\nfi\n\n# ── Clean ledger for fresh state ──────────────────────────────────────\nrm -rf \"$LEDGER_DIR\"\n\n# ── Start validator with programs preloaded at genesis ────────────────\necho \"Starting solana-test-validator...\"\nsolana-test-validator \\\n  --ledger \"$LEDGER_DIR\" \\\n  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n  --account 5ER1oENnV4srxYdAynUfRzWeQCPQaqMiAp4VqyMbSqnK \"$ACCOUNTS_DIR/orao-network-state.json\" \\\n  --account S4ne8ejGPUwNMNsE8L7gtjbTaBLBfVGdWNH6VQrL58a \"$ACCOUNTS_DIR/orao-random-player-a.json\" \\\n  --account Ecs89dz8NsNoSxyUtp54G2HPbmvJr8qZnxnWUqiLT92r \"$ACCOUNTS_DIR/orao-treasury.json\" \\\n  --reset \\\n  --quiet \\\n  > \"$LOG_FILE\" 2>&1 &\n\nVALIDATOR_PID=$!\necho \"$VALIDATOR_PID\" > \"$PID_FILE\"\necho \"Validator PID: $VALIDATOR_PID\"\n\n# ── Wait for RPC readiness ────────────────────────────────────────────\necho -n \"Waiting for RPC at $RPC_URL\"\nELAPSED=0\nwhile (( ELAPSED < MAX_WAIT )); do\n  if curl -s \"$RPC_URL\" \\\n    -X POST \\\n    -H \"Content-Type: application/json\" \\\n    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    | grep -q '\"result\"'; then\n    echo \" ready (${ELAPSED}s)\"\n    echo \"Localnet bootstrap complete.\"\n    exit 0\n  fi\n\n  # Check validator is still running\n  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n    echo \"\"\n    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n    tail -20 \"$LOG_FILE\" >&2\n    rm -f \"$PID_FILE\"\n    exit 1\n  fi\n\n  sleep 1\n  (( ELAPSED++ ))\n  echo -n \".\"\ndone\n\necho \"\"\necho \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\ntail -20 \"$LOG_FILE\" >&2\nkill \"$VALIDATOR_PID\" 2>/dev/null || true\nrm -f \"$PID_FILE\"\nexit 1\n","numLines":124,"startLine":1,"totalLines":124}}}
