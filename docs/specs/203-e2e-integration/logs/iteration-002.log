{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WBR9sbzdRW6GTvnWp5Tm4Q","type":"tool_result","content":"{\n  \"address\": \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\",\n  \"metadata\": {\n    \"name\": \"coinflip\",\n    \"version\": \"0.1.0\",\n    \"spec\": \"0.1.0\"\n  },\n  \"instructions\": [\n    {\n      \"name\": \"cancel_match\",\n      \"discriminator\": [\n        142,\n        136,\n        247,\n        45,\n        92,\n        112,\n        180,\n        83\n      ],\n      \"accounts\": [\n        {\n          \"name\": \"creator\",\n          \"docs\": [\n            \"The creator cancelling their match.\"\n          ],\n          \"writable\": true,\n          \"signer\": true\n        },\n        {\n          \"name\": \"coinflip_match\",\n          \"docs\": [\n            \"The match PDA (closed on cancel — escrow + rent refunded to creator).\"\n          ],\n          \"writable\": true,\n          \"pda\": {\n            \"seeds\": [\n              {\n                \"kind\": \"const\",\n                \"value\": [\n                  109,\n                  97,\n                  116,\n                  99,\n                  104\n                ]\n              },\n              {\n                \"kind\": \"account\",\n                \"path\": \"creator\"","is_error":false}]},"parent_tool_use_id":"toolu_01P2K54iU7mrVvMfRJygFGdW","session_id":"faf1a871-f71a-4e6b-a898-077ce425db1a","uuid":"a3367bb4-39ca-4487-9e84-0b3038aaa68d"}
