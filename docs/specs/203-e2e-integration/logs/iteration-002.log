{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HpQvR3WaKtLW6ozTNBmQjA","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { Program, Wallet } from \"@coral-xyz/anchor\";\n     5→import {\n     6→  Keypair,\n     7→  PublicKey,\n     8→  SystemProgram,\n     9→} from \"@solana/web3.js\";\n    10→import type { Platform } from \"../target/types/platform\";\n    11→import { readFileSync } from \"fs\";\n    12→import { dirname, join } from \"path\";\n    13→import { fileURLToPath } from \"url\";\n    14→\n    15→const __filename = fileURLToPath(import.meta.url);\n    16→const __dirname = dirname(__filename);\n    17→\n    18→const IDL = JSON.parse(\n    19→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    20→);\n    21→const PROGRAM_ID = new PublicKey(IDL.address);\n    22→\n    23→const TOTAL_FEE_BPS = 300;\n    24→\n    25→// ---------------------------------------------------------------------------\n    26→// PDA helpers\n    27→// ---------------------------------------------------------------------------\n    28→function getConfigPda(): PublicKey {\n    29→  const [pda] = PublicKey.findProgramAddressSync(\n    30→    [Buffer.from(\"platform_config\")],\n    31→    PROGRAM_ID\n    32→  );\n    33→  return pda;\n    34→}\n    35→\n    36→function getPlayerProfilePda(wallet: PublicKey): PublicKey {\n    37→  const [pda] = PublicKey.findProgramAddressSync(\n    38→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    39→    PROGRAM_ID\n    40→  );\n    41→  return pda;\n    42→}\n    43→\n    44→// ---------------------------------------------------------------------------\n    45→// Bankrun context factory\n    46→// ---------------------------------------------------------------------------\n    47→interface TestContext {\n    48→  context: Awaited<ReturnType<typeof startAnchor>>;\n    49→  authority: PublicKey;\n    50→  treasury: Keypair;\n    51→  authorityProgram: Program<Platform>;\n    52→  configPda: PublicKey;\n    53→}\n    54→\n    55→async function createTestContext(): Promise<TestContext> {\n    56→  const treasury = Keypair.generate();\n    57→\n    58→  const context = await startAnchor(\"./\", [], []);\n    59→\n    60→  const authorityProvider = new BankrunProvider(context);\n    61→  const authorityProgram = new Program<Platform>(IDL, authorityProvider);\n    62→\n    63→  const authority = authorityProvider.wallet.publicKey;\n    64→  const configPda = getConfigPda();\n    65→\n    66→  return {\n    67→    context,\n    68→    authority,\n    69→    treasury,\n    70→    authorityProgram,\n    71→    configPda,\n    72→  };\n    73→}\n    74→\n    75→// ---------------------------------------------------------------------------\n    76→// Helpers\n    77→// ---------------------------------------------------------------------------\n    78→async function initPlatform(t: TestContext) {\n    79→  await t.authorityProgram.methods\n    80→    .initializePlatform(t.treasury.publicKey)\n    81→    .accounts({\n    82→      authority: t.authority,\n    83→      config: t.configPda,\n    84→      systemProgram: SystemProgram.programId,\n    85→    })\n    86→    .rpc();\n    87→}\n    88→\n    89→// ===========================================================================\n    90→// Tests\n    91→// ===========================================================================\n    92→describe(\"platform\", () => {\n    93→  // -------------------------------------------------------------------------\n    94→  // initialize_platform\n    95→  // -------------------------------------------------------------------------\n    96→  describe(\"initialize_platform\", () => {\n    97→    it(\"creates config with authority, treasury, and fee_bps\", async () => {\n    98→      const t = await createTestContext();\n    99→      await initPlatform(t);\n   100→\n   101→      const config = await t.authorityProgram.account.platformConfig.fetch(\n   102→        t.configPda\n   103→      );\n   104→      expect(config.authority.toBase58()).to.equal(t.authority.toBase58());\n   105→      expect(config.treasury.toBase58()).to.equal(\n   106→        t.treasury.publicKey.toBase58()\n   107→      );\n   108→      expect(config.feeBps).to.equal(TOTAL_FEE_BPS);\n   109→    });\n   110→\n   111→    it(\"rejects double initialization\", async () => {\n   112→      const t = await createTestContext();\n   113→      await initPlatform(t);\n   114→\n   115→      try {\n   116→        await initPlatform(t);\n   117→        expect.fail(\"Expected error on double init\");\n   118→      } catch (err) {\n   119→        // PDA already exists → anchor constraint error\n   120→        expect(err).to.exist;\n   121→      }\n   122→    });\n   123→  });\n   124→\n   125→  // -------------------------------------------------------------------------\n   126→  // create_player_profile\n   127→  // -------------------------------------------------------------------------\n   128→  describe(\"create_player_profile\", () => {\n   129→    it(\"creates a player profile with zeroed stats\", async () => {\n   130→      const t = await createTestContext();\n   131→      const profilePda = getPlayerProfilePda(t.authority);\n   132→\n   133→      await t.authorityProgram.methods\n   134→        .createPlayerProfile()\n   135→        .accounts({\n   136→          player: t.authority,\n   137→          profile: profilePda,\n   138→          systemProgram: SystemProgram.programId,\n   139→        })\n   140→        .rpc();\n   141→\n   142→      const profile = await t.authorityProgram.account.playerProfile.fetch(\n   143→        profilePda\n   144→      );\n   145→      expect(profile.authority.toBase58()).to.equal(t.authority.toBase58());\n   146→      expect(profile.totalGames.toNumber()).to.equal(0);\n   147→      expect(profile.wins.toNumber()).to.equal(0);\n   148→      expect(profile.totalWagered.toNumber()).to.equal(0);\n   149→      expect(profile.totalWon.toNumber()).to.equal(0);\n   150→    });"}]},"parent_tool_use_id":"toolu_01Fg2oF6HdFHJ5cxyCxCS2wb","session_id":"faf1a871-f71a-4e6b-a898-077ce425db1a","uuid":"6cabfb2e-c4f7-4550-a246-ef91b3a942db"}
