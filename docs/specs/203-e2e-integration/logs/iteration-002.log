{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01StwPzT82sfwuJjcNGWnv8U","type":"tool_result","content":"     1→#!/bin/bash\n     2→set -e\n     3→export CI=true\n     4→\n     5→# =============================================================================\n     6→# verify — End-to-end verification for RNG Utopia\n     7→#\n     8→# Usage:\n     9→#   ./scripts/verify              Full verification (all steps)\n    10→#   ./scripts/verify --anchor     Anchor programs only (build + test)\n    11→#   ./scripts/verify --ts         TypeScript only (lint + typecheck + build + test)\n    12→# =============================================================================\n    13→\n    14→# Color codes\n    15→GREEN='\\033[0;32m'\n    16→RED='\\033[0;31m'\n    17→YELLOW='\\033[0;33m'\n    18→NC='\\033[0m'\n    19→\n    20→MODE=\"${1:-full}\"\n    21→\n    22→# Normalize flags\n    23→case \"$MODE\" in\n    24→    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n    25→    --ts|--ts-only|ts) MODE=\"ts\" ;;\n    26→    --full|full|\"\") MODE=\"full\" ;;\n    27→    *)\n    28→        echo \"Usage: ./scripts/verify [--anchor|--ts|--full]\"\n    29→        exit 1\n    30→        ;;\n    31→esac\n    32→\n    33→echo -e \"${GREEN}=== RNG Utopia Verification ($MODE) ===${NC}\"\n    34→\n    35→# Check for submodule\n    36→if [ ! -f \"sources/rng-utopia/package.json\" ]; then\n    37→    echo -e \"${RED}[FAIL] Submodule not initialized.${NC}\"\n    38→    echo \"Run: git submodule update --init --recursive\"\n    39→    exit 1\n    40→fi\n    41→\n    42→# ---------------------------------------------------------------------------\n    43→# TypeScript steps (lint, typecheck, build, test)\n    44→# ---------------------------------------------------------------------------\n    45→run_ts() {\n    46→    cd sources/rng-utopia\n    47→\n    48→    # Install dependencies if missing\n    49→    if [ ! -d \"node_modules\" ]; then\n    50→        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n    51→        pnpm install\n    52→    fi\n    53→\n    54→    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n    55→    pnpm lint\n    56→\n    57→    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n    58→    pnpm typecheck\n    59→\n    60→    echo -e \"${GREEN}[STEP] Building frontend entrypoint (apps/platform)...${NC}\"\n    61→    pnpm build\n    62→\n    63→    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n    64→    pnpm test\n    65→\n    66→    echo -e \"${GREEN}[STEP] Visual regression tests...${NC}\"\n    67→    pnpm test:visual\n    68→\n    69→    cd ../..\n    70→}\n    71→\n    72→# ---------------------------------------------------------------------------\n    73→# Anchor steps (build + test)\n    74→# ---------------------------------------------------------------------------\n    75→run_anchor() {\n    76→    if ! command -v anchor &>/dev/null; then\n    77→        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n    78→        return 0\n    79→    fi\n    80→\n    81→    cd sources/rng-utopia/solana\n    82→\n    83→    if [ ! -d \"node_modules\" ]; then\n    84→        pnpm install --ignore-workspace\n    85→    fi\n    86→\n    87→    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n    88→    anchor build\n    89→\n    90→    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n    91→    anchor test --skip-local-validator --skip-deploy\n    92→\n    93→    cd ../../..\n    94→}\n    95→\n    96→# ---------------------------------------------------------------------------\n    97→# Run based on mode\n    98→# ---------------------------------------------------------------------------\n    99→case \"$MODE\" in\n   100→    full)\n   101→        run_ts\n   102→        run_anchor\n   103→        ;;\n   104→    ts)\n   105→        run_ts\n   106→        ;;\n   107→    anchor)\n   108→        run_anchor\n   109→        ;;\n   110→esac\n   111→\n   112→echo -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\n   113→exit 0\n   114→"}]},"parent_tool_use_id":"toolu_01Fg2oF6HdFHJ5cxyCxCS2wb","session_id":"faf1a871-f71a-4e6b-a898-077ce425db1a","uuid":"f7610511-8ea5-423f-b83b-7a7a89ba08a4"}
