{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019jYfCf8T4uXbuamwVCcwH8","type":"tool_result","content":"     1→#!/bin/bash\n     2→set -e\n     3→\n     4→# Deploy coinflip + platform programs to Solana devnet with VRF enabled.\n     5→# Usage: ./scripts/deploy-devnet.sh\n     6→#\n     7→# Prerequisites:\n     8→#   - Anchor CLI, Solana CLI installed\n     9→#   - Deployer wallet at ~/.config/solana/id.json with devnet SOL\n    10→#   - Run from solana/ directory (where Anchor.toml lives)\n    11→\n    12→cd \"$(dirname \"$0\")/..\"\n    13→\n    14→echo \"=== RNG Utopia — Devnet Deployment ===\"\n    15→\n    16→# 1. Verify toolchain\n    17→echo \"\"\n    18→echo \"Toolchain:\"\n    19→echo \"  anchor: $(anchor --version)\"\n    20→echo \"  solana: $(solana --version | head -1)\"\n    21→echo \"  cargo-build-sbf: $(cargo-build-sbf --version 2>&1 | head -1)\"\n    22→\n    23→# Preflight: reject known-incompatible SBF toolchains before long builds.\n    24→SBF_VERSION_OUTPUT=\"$(cargo-build-sbf --version 2>&1)\"\n    25→PLATFORM_TOOLS=\"$(printf '%s\\n' \"$SBF_VERSION_OUTPUT\" | sed -n 's/.*platform-tools v\\([0-9][0-9]*\\)\\.\\([0-9][0-9]*\\).*/\\1 \\2/p' | head -1)\"\n    26→if [ -z \"$PLATFORM_TOOLS\" ]; then\n    27→    echo \"ERROR: Could not parse platform-tools version from cargo-build-sbf output.\"\n    28→    echo \"$SBF_VERSION_OUTPUT\"\n    29→    exit 1\n    30→fi\n    31→\n    32→PT_MAJOR=\"$(echo \"$PLATFORM_TOOLS\" | awk '{print $1}')\"\n    33→PT_MINOR=\"$(echo \"$PLATFORM_TOOLS\" | awk '{print $2}')\"\n    34→if [ \"$PT_MAJOR\" -lt 1 ] || { [ \"$PT_MAJOR\" -eq 1 ] && [ \"$PT_MINOR\" -lt 52 ]; }; then\n    35→    echo \"ERROR: platform-tools v1.52+ required (found v${PT_MAJOR}.${PT_MINOR}).\"\n    36→    echo \"Fix: agave-install init beta (or newer compatible channel), then retry.\"\n    37→    exit 1\n    38→fi\n    39→\n    40→# 2. Switch to devnet\n    41→echo \"\"\n    42→echo \"Switching to devnet...\"\n    43→solana config set --url devnet\n    44→\n    45→# 3. Check wallet balance\n    46→WALLET=$(solana address)\n    47→echo \"Deployer: $WALLET\"\n    48→BALANCE=$(solana balance --lamports | awk '{print $1}')\n    49→MIN_BALANCE=5000000000  # 5 SOL minimum for deploy\n    50→\n    51→if [ \"$BALANCE\" -lt \"$MIN_BALANCE\" ]; then\n    52→    echo \"Balance: $(solana balance) (insufficient — need ~5 SOL)\"\n    53→    echo \"Requesting airdrop...\"\n    54→    solana airdrop 5 || {\n    55→        echo \"Airdrop failed. Fund manually: solana airdrop 5\"\n    56→        exit 1\n    57→    }\n    58→    echo \"New balance: $(solana balance)\"\n    59→else\n    60→    echo \"Balance: $(solana balance) (OK)\"\n    61→fi\n    62→\n    63→# 4. Build with VRF enabled (no mock-oracle)\n    64→echo \"\"\n    65→echo \"Building programs with VRF enabled (--no-default-features)...\"\n    66→anchor build -- --no-default-features\n    67→\n    68→# 5. Deploy\n    69→echo \"\"\n    70→echo \"Deploying to devnet...\"\n    71→anchor deploy --provider.cluster devnet\n    72→\n    73→# 6. Print program IDs\n    74→echo \"\"\n    75→echo \"=== Deployed Program IDs ===\"\n    76→echo \"coinflip: $(solana address -k target/deploy/coinflip-keypair.json)\"\n    77→echo \"platform: $(solana address -k target/deploy/platform-keypair.json)\"\n    78→\n    79→# 7. Initialize config accounts (idempotent — skips if already created)\n    80→echo \"\"\n    81→echo \"Initializing config accounts...\"\n    82→npx tsx scripts/init-devnet-config.ts\n    83→\n    84→echo \"\"\n    85→echo \"=== Deployment complete ===\"\n    86→"}]},"parent_tool_use_id":"toolu_01P2K54iU7mrVvMfRJygFGdW","session_id":"faf1a871-f71a-4e6b-a898-077ce425db1a","uuid":"31df997d-a162-47fa-973f-0f813d2e70a2"}
