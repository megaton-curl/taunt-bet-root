{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JmmL7BzyEBNJuF5QHm7xnR","type":"tool_result","content":"   120→          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n   121→            {isWinner ? \"WON\" : \"LOST\"}\n   122→          </span>\n   123→        </span>\n   124→      ),\n   125→      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n   126→      timestamp: new Date(match.completedAt ?? match.createdAt),\n   127→      verified: true,\n   128→      won: isWinner,\n   129→      onClick: () => setSelectedHistoryMatch(match),\n   130→    };\n   131→  });\n   132→\n   133→  // Calculate potential payout\n   134→  const potentialPayout = selectedTier\n   135→    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n   136→    : 0;\n   137→\n   138→  const handleCreateMatch = () => {\n   139→    createMatch();\n   140→  };\n   141→\n   142→  const handleJoinMatch = (matchId: string) => {\n   143→    joinMatch(matchId);\n   144→  };\n   145→\n   146→  // Sidebar content\n   147→  const sidebar = (\n   148→    <div className=\"coinflip-sidebar\">\n   149→      {!activeMatch ? (\n   150→        <>\n   151→          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n   152→\n   153→          {/* Tier Selection */}\n   154→          <div className=\"coinflip-sidebar__section\">\n   155→            <div className=\"coinflip-sidebar__label-row\">\n   156→              <label className=\"coinflip-sidebar__label\">\n   157→                Select Tier\n   158→              </label>\n   159→              <button\n   160→                type=\"button\"\n   161→                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n   162→                onClick={() => setSelectedTier(null)}\n   163→              >\n   164→                All\n   165→              </button>\n   166→            </div>\n   167→            <TierSelector\n   168→              selectedTier={selectedTier}\n   169→              onSelect={setSelectedTier}\n   170→            />\n   171→          </div>\n   172→\n   173→          {/* Side Selection */}\n   174→          <div className=\"coinflip-sidebar__section\">\n   175→            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n   176→            <CoinSideSelector\n   177→              selectedSide={selectedSide}\n   178→              onSelect={setSelectedSide}\n   179→              disabled={!connected}\n   180→            />\n   181→          </div>\n   182→\n   183→          {/* Summary */}\n   184→          {selectedTier && selectedSide && (\n   185→            <div className=\"coinflip-sidebar__summary\">\n   186→              <div className=\"coinflip-sidebar__row\">\n   187→                <span>Entry</span>\n   188→                <span>{`$${TIER_AMOUNTS[selectedTier]}`}</span>\n   189→              </div>\n   190→              <div className=\"coinflip-sidebar__row\">\n   191→                <span>Potential Payout</span>\n   192→                <span className=\"coinflip-sidebar__payout\">\n   193→                  {`$${potentialPayout.toFixed(2)}`}\n   194→                </span>\n   195→              </div>\n   196→            </div>\n   197→          )}\n   198→\n   199→          {/* Action Button */}\n   200→          {!connected ? (\n   201→            <button\n   202→              type=\"button\"\n   203→              className=\"coinflip-action-btn\"\n   204→              onClick={connect}\n   205→            >\n   206→              Connect Wallet\n   207→            </button>\n   208→          ) : (\n   209→            <button\n   210→              type=\"button\"\n   211→              className=\"coinflip-action-btn\"\n   212→              onClick={handleCreateMatch}\n   213→              disabled={!selectedTier || !selectedSide || creating}\n   214→            >\n   215→              {creating ? \"Creating...\" : \"Create Game\"}\n   216→            </button>\n   217→          )}\n   218→        </>\n   219→      ) : (\n   220→        <>\n   221→          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n   222→\n   223→          <div className=\"coinflip-sidebar__game-info\">\n   224→            <div className=\"coinflip-sidebar__row\">\n   225→              <span>Tier</span>\n   226→              <span\n   227→                className=\"coinflip-sidebar__tier\"\n   228→                style={{\n   229→                  color: TIER_COLORS[activeMatch.tier],\n   230→                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n   231→                }}\n   232→              >\n   233→                {activeMatch.tier}\n   234→              </span>\n   235→            </div>\n   236→            <div className=\"coinflip-sidebar__row\">\n   237→              <span>Your Side</span>\n   238→              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n   239→                {(activeMatch.player1 === address\n   240→                  ? activeMatch.player1Side\n   241→                  : activeMatch.player2Side\n   242→                )?.toUpperCase()}\n   243→              </span>\n   244→            </div>\n   245→            <div className=\"coinflip-sidebar__row\">\n   246→              <span>Entry</span>\n   247→              <span>{`$${activeMatch.entryAmount}`}</span>\n   248→            </div>\n   249→            <div className=\"coinflip-sidebar__row\">\n   250→              <span>Pot</span>\n   251→              <span className=\"coinflip-sidebar__pot\">{`$${activeMatch.entryAmount * 2}`}</span>\n   252→            </div>\n   253→            <div className=\"coinflip-sidebar__row\">\n   254→              <span>Status</span>\n   255→              <span className=\"coinflip-sidebar__status\">\n   256→                {activeMatch.phase === \"created\" && \"Waiting...\"}\n   257→                {activeMatch.phase === \"ready\" && \"Ready!\"}\n   258→                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n   259→                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n   260→                {activeMatch.phase === \"complete\" && \"Complete\"}\n   261→              </span>\n   262→            </div>\n   263→          </div>\n   264→\n   265→          {/* Round Fairness Info */}\n   266→          <div className=\"coinflip-sidebar__fairness\">\n   267→            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n   268→            <div className=\"coinflip-sidebar__fairness-row\">\n   269→              <span>Match ID</span>\n   270→              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n   271→                {activeMatch.id.slice(-8)}\n   272→              </span>\n   273→            </div>\n   274→            <div className=\"coinflip-sidebar__fairness-row\">\n   275→              <span>Seed Hash</span>\n   276→              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n   277→                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n   278→              </span>\n   279→            </div>\n   280→            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n   281→              <>\n   282→                <div className=\"coinflip-sidebar__fairness-row\">\n   283→                  <span>Server Seed</span>\n   284→                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n   285→                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n   286→                  </span>\n   287→                </div>\n   288→                {activeMatch.blockHash && (\n   289→                  <div className=\"coinflip-sidebar__fairness-row\">\n   290→                    <span>Block Hash</span>\n   291→                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n   292→                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n   293→                    </span>\n   294→                  </div>\n   295→                )}\n   296→              </>\n   297→            )}\n   298→          </div>\n   299→\n   300→          {activeMatch.phase === \"complete\" && !activeMatch.claimed && (\n   301→            <button\n   302→              type=\"button\"\n   303→              className=\"coinflip-action-btn\"\n   304→              onClick={claimPayout}\n   305→              disabled={claiming}\n   306→            >\n   307→              {claiming\n   308→                ? \"Settling...\"\n   309→                : activeMatch.winner === address\n   310→                  ? \"Claim Payout\"\n   311→                  : \"Settle & Return\"}\n   312→            </button>\n   313→          )}\n   314→          {activeMatch.phase === \"complete\" && activeMatch.claimed && (\n   315→            <button\n   316→              type=\"button\"\n   317→              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n   318→              onClick={clearActiveMatch}\n   319→            >\n   320→              Back to Lobby\n   321→            </button>\n   322→          )}\n   323→        </>\n   324→      )}\n   325→    </div>\n   326→  );\n   327→\n   328→  // Helper to get side display for modal\n   329→  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n   330→    const side = isPlayer1 ? match.player1Side : match.player2Side;\n   331→    return side?.toUpperCase() ?? \"?\";\n   332→  };\n   333→\n   334→  return (\n   335→    <>\n   336→      <GameLayout\n   337→        gameName=\"Coinflip\"\n   338→        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n   339→        sidebar={sidebar}\n   340→        historyEntries={historyEntries}\n   341→        showHistory={true}\n   342→      >\n   343→        <div className=\"coinflip-main\">\n   344→          {/* Show active match or lobby */}\n   345→          {activeMatch ? (\n   346→            <ActiveMatchView\n   347→              match={activeMatch}\n   348→              currentUserAddress={address ?? \"\"}\n   349→              onCancel={activeMatch.phase === \"created\" ? cancelMatch : undefined}\n   350→              onTimeoutCancel={timeoutCancel}\n   351→              onClaim={claimPayout}\n   352→              onClearMatch={clearActiveMatch}\n   353→              onRematch={handleRematch}\n   354→              claiming={claiming}\n   355→              rematching={creating}\n   356→              claimTxSignature={lastClaimSignature}\n   357→              verificationResult={verificationResult}\n   358→              verifying={verifying}\n   359→              onVerify={handleVerify}\n   360→            />\n   361→          ) : (\n   362→            <div className=\"coinflip-lobby\">\n   363→              {/* Your Matches — claimable/active matches for the current player */}\n   364→              {connected && claimableMatches.length > 0 && (\n   365→                <div className=\"coinflip-matches coinflip-your-matches\">\n   366→                  <div className=\"coinflip-matches__header\">\n   367→                    <h3 className=\"coinflip-matches__title\">Your Matches</h3>\n   368→                    <span className=\"coinflip-matches__count\">\n   369→                      {claimableMatches.length} active\n   370→                    </span>\n   371→                  </div>\n   372→                  <div className=\"coinflip-matches__list\">\n   373→                    {claimableMatches.map((match) => {\n   374→                      const isCreator = match.player1 === address;\n   375→                      let actionLabel: string;\n   376→                      if (match.phase === \"complete\") {\n   377→                        actionLabel = match.winner === address ? \"Claim\" : \"Settle\";\n   378→                      } else if (match.phase === \"created\" && isCreator) {\n   379→                        actionLabel = \"Cancel\";\n   380→                      } else {\n   381→                        actionLabel = \"View\";\n   382→                      }\n   383→\n   384→                      return (\n   385→                        <div\n   386→                          key={match.id}\n   387→                          className=\"coinflip-match-card coinflip-match-card--claimable\"\n   388→                          onClick={() => selectMatch(match)}\n   389→                          role=\"button\"\n   390→                          tabIndex={0}\n   391→                          onKeyDown={(e) => { if (e.key === \"Enter\") selectMatch(match); }}\n   392→                        >\n   393→                          <div className=\"coinflip-match-card__bet\">\n   394→                            <div\n   395→                              className=\"coinflip-match-card__amount\"\n   396→                              style={{ color: TIER_COLORS[match.tier] }}\n   397→                            >\n   398→                              {\"$\"}{match.entryAmount}\n   399→                            </div>\n   400→                            <span className=\"coinflip-match-card__phase\">\n   401→                              {match.phase === \"created\" && \"Waiting\"}\n   402→                              {match.phase === \"ready\" && \"Locked\"}\n   403→                              {match.phase === \"complete\" && \"Settled\"}\n   404→                            </span>\n   405→                          </div>\n   406→                          <div className=\"coinflip-match-card__actions\">\n   407→                            <button\n   408→                              type=\"button\"\n   409→                              className=\"coinflip-match-card__join-btn\"\n   410→                              onClick={(e) => { e.stopPropagation(); selectMatch(match); }}\n   411→                            >\n   412→                              {actionLabel}\n   413→                            </button>\n   414→                          </div>\n   415→                        </div>\n   416→                      );\n   417→                    })}\n   418→                  </div>\n   419→                </div>\n   420→              )}\n   421→\n   422→              <OpenMatchesList\n   423→                matches={openMatches}\n   424→                loading={loading}\n   425→                onJoin={handleJoinMatch}\n   426→                joiningMatchId={joiningMatchId}\n   427→                currentUserAddress={address}\n   428→                selectedTier={selectedTier}\n   429→                isConnected={connected}\n   430→              />\n   431→            </div>\n   432→          )}\n   433→        </div>\n   434→      </GameLayout>\n   435→\n   436→      {/* Error Toast */}\n   437→      {error && createPortal(\n   438→        <div className=\"coinflip-error-toast\">\n   439→          <Toast variant=\"error\" message={error} onClose={clearError} />\n   440→        </div>,\n   441→        document.body\n   442→      )}\n   443→\n   444→      {/* History Detail Modal */}\n   445→      <Modal\n   446→        isOpen={selectedHistoryMatch !== null}\n   447→        onClose={() => setSelectedHistoryMatch(null)}\n   448→        title=\"Match Details\"\n   449→      >\n   450→        {selectedHistoryMatch && (() => {\n   451→          const isPlayer1 = selectedHistoryMatch.player1 === address;\n   452→          const isWinner = selectedHistoryMatch.winner === address;\n   453→          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n   454→          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n   455→\n   456→          return (\n   457→            <div className=\"coinflip-history-modal\">\n   458→              {/* Match Stats */}\n   459→              <div className=\"coinflip-history-modal__section\">\n   460→                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n   461→                <div className=\"coinflip-history-modal__row\">\n   462→                  <span>Tier</span>\n   463→                  <span\n   464→                    style={{\n   465→                      color: TIER_COLORS[selectedHistoryMatch.tier],\n   466→                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n   467→                      textTransform: \"capitalize\",\n   468→                    }}\n   469→                  >\n   470→                    {selectedHistoryMatch.tier}\n   471→                  </span>\n   472→                </div>\n   473→                <div className=\"coinflip-history-modal__row\">\n   474→                  <span>Your Side</span>\n   475→                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n   476→                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n   477→                  </span>\n   478→                </div>\n   479→                <div className=\"coinflip-history-modal__row\">\n   480→                  <span>Entry</span>\n   481→                  <span>{`$${selectedHistoryMatch.entryAmount}`}</span>\n   482→                </div>\n   483→                <div className=\"coinflip-history-modal__row\">\n   484→                  <span>Total Pot</span>\n   485→                  <span className=\"coinflip-history-modal__highlight\">\n   486→                    {`$${(selectedHistoryMatch.entryAmount * 2).toFixed(2)}`}\n   487→                  </span>\n   488→                </div>\n   489→                <div className=\"coinflip-history-modal__row\">\n   490→                  <span>Result</span>\n   491→                  <span\n   492→                    style={{\n   493→                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n   494→                      textShadow: selectedHistoryMatch.result\n   495→                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n   496→                        : undefined,\n   497→                    }}\n   498→                  >\n   499→                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n   500→                  </span>\n   501→                </div>\n   502→                <div className=\"coinflip-history-modal__row\">\n   503→                  <span>Outcome</span>\n   504→                  <span\n   505→                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n   506→                    style={{ color: isWinner ? \"#45b058\" : \"#d45d5d\" }}\n   507→                  >\n   508→                    {isWinner ? \"WON!\" : \"LOST\"}\n   509→                  </span>\n   510→                </div>\n   511→                <div className=\"coinflip-history-modal__row\">\n   512→                  <span>Payout</span>\n   513→                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n   514→                    {isWinner ? `+$${selectedHistoryMatch.payoutAmount.toFixed(2)}` : `-$${selectedHistoryMatch.entryAmount.toFixed(2)}`}\n   515→                  </span>\n   516→                </div>\n   517→              </div>\n   518→\n   519→              {/* Match Fairness */}\n   520→              <div className=\"coinflip-history-modal__section\">\n   521→                <h4 className=\"coinflip-history-modal__section-title\">\n   522→                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n   523→                  Round Fairness\n   524→                </h4>\n   525→                <div className=\"coinflip-history-modal__row\">\n   526→                  <span>Match ID</span>\n   527→                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n   528→                    {selectedHistoryMatch.id}\n   529→                  </span>\n   530→                </div>\n   531→                <div className=\"coinflip-history-modal__row\">\n   532→                  <span>Seed Hash</span>\n   533→                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n   534→                    {selectedHistoryMatch.seedHash}\n   535→                  </span>\n   536→                </div>\n   537→                {selectedHistoryMatch.serverSeed && (\n   538→                  <div className=\"coinflip-history-modal__row\">\n   539→                    <span>Server Seed</span>\n   540→                    <span\n   541→                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n   542→                      title={selectedHistoryMatch.serverSeed}\n   543→                    >\n   544→                      {selectedHistoryMatch.serverSeed}\n   545→                    </span>\n   546→                  </div>\n   547→                )}\n   548→                {selectedHistoryMatch.blockHash && (\n   549→                  <div className=\"coinflip-history-modal__row\">\n   550→                    <span>Block Hash</span>\n   551→                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n   552→                      {selectedHistoryMatch.blockHash}\n   553→                    </span>\n   554→                  </div>\n   555→                )}\n   556→                {selectedHistoryMatch.vrfProof && (\n   557→                  <div className=\"coinflip-history-modal__row\">\n   558→                    <span>VRF Proof</span>\n   559→                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n   560→                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n   561→                    </span>\n   562→                  </div>\n   563→                )}\n   564→              </div>\n   565→\n   566→              {/* Verify Link */}\n   567→              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n   568→                Verify on Fairness Page →\n   569→              </a>\n   570→            </div>\n   571→          );\n   572→        })()}\n   573→      </Modal>\n   574→    </>\n   575→  );\n   576→}\n   577→\n   578→export function CoinflipPage() {\n   579→  return (\n   580→    <CoinflipProvider>\n   581→      <CoinflipPageContent />\n   582→    </CoinflipProvider>\n   583→  );\n   584→}\n   585→"}]},"parent_tool_use_id":null,"session_id":"339d09be-5189-43e7-b291-e94f665f152d","uuid":"27006fc8-449c-4a37-8907-5f6ab5abb607","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/pages/CoinflipPage.tsx","content":"          <span style={{ color: outcomeColor, textShadow: `0 0 4px ${outcomeColor}` }}>\n            {isWinner ? \"WON\" : \"LOST\"}\n          </span>\n        </span>\n      ),\n      payout: isWinner ? match.payoutAmount : -match.entryAmount,\n      timestamp: new Date(match.completedAt ?? match.createdAt),\n      verified: true,\n      won: isWinner,\n      onClick: () => setSelectedHistoryMatch(match),\n    };\n  });\n\n  // Calculate potential payout\n  const potentialPayout = selectedTier\n    ? TIER_AMOUNTS[selectedTier] * 2 * 0.97\n    : 0;\n\n  const handleCreateMatch = () => {\n    createMatch();\n  };\n\n  const handleJoinMatch = (matchId: string) => {\n    joinMatch(matchId);\n  };\n\n  // Sidebar content\n  const sidebar = (\n    <div className=\"coinflip-sidebar\">\n      {!activeMatch ? (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Create Game</h3>\n\n          {/* Tier Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <div className=\"coinflip-sidebar__label-row\">\n              <label className=\"coinflip-sidebar__label\">\n                Select Tier\n              </label>\n              <button\n                type=\"button\"\n                className={`coinflip-sidebar__all-btn ${selectedTier === null ? \"coinflip-sidebar__all-btn--active\" : \"\"}`}\n                onClick={() => setSelectedTier(null)}\n              >\n                All\n              </button>\n            </div>\n            <TierSelector\n              selectedTier={selectedTier}\n              onSelect={setSelectedTier}\n            />\n          </div>\n\n          {/* Side Selection */}\n          <div className=\"coinflip-sidebar__section\">\n            <label className=\"coinflip-sidebar__label\">Choose Your Side</label>\n            <CoinSideSelector\n              selectedSide={selectedSide}\n              onSelect={setSelectedSide}\n              disabled={!connected}\n            />\n          </div>\n\n          {/* Summary */}\n          {selectedTier && selectedSide && (\n            <div className=\"coinflip-sidebar__summary\">\n              <div className=\"coinflip-sidebar__row\">\n                <span>Entry</span>\n                <span>{`$${TIER_AMOUNTS[selectedTier]}`}</span>\n              </div>\n              <div className=\"coinflip-sidebar__row\">\n                <span>Potential Payout</span>\n                <span className=\"coinflip-sidebar__payout\">\n                  {`$${potentialPayout.toFixed(2)}`}\n                </span>\n              </div>\n            </div>\n          )}\n\n          {/* Action Button */}\n          {!connected ? (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={connect}\n            >\n              Connect Wallet\n            </button>\n          ) : (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={handleCreateMatch}\n              disabled={!selectedTier || !selectedSide || creating}\n            >\n              {creating ? \"Creating...\" : \"Create Game\"}\n            </button>\n          )}\n        </>\n      ) : (\n        <>\n          <h3 className=\"coinflip-sidebar__title\">Current Game</h3>\n\n          <div className=\"coinflip-sidebar__game-info\">\n            <div className=\"coinflip-sidebar__row\">\n              <span>Tier</span>\n              <span\n                className=\"coinflip-sidebar__tier\"\n                style={{\n                  color: TIER_COLORS[activeMatch.tier],\n                  textShadow: `0 0 8px ${TIER_COLORS[activeMatch.tier]}`\n                }}\n              >\n                {activeMatch.tier}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Your Side</span>\n              <span className={`side-${activeMatch.player1 === address ? activeMatch.player1Side : activeMatch.player2Side}`}>\n                {(activeMatch.player1 === address\n                  ? activeMatch.player1Side\n                  : activeMatch.player2Side\n                )?.toUpperCase()}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Entry</span>\n              <span>{`$${activeMatch.entryAmount}`}</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Pot</span>\n              <span className=\"coinflip-sidebar__pot\">{`$${activeMatch.entryAmount * 2}`}</span>\n            </div>\n            <div className=\"coinflip-sidebar__row\">\n              <span>Status</span>\n              <span className=\"coinflip-sidebar__status\">\n                {activeMatch.phase === \"created\" && \"Waiting...\"}\n                {activeMatch.phase === \"ready\" && \"Ready!\"}\n                {activeMatch.phase === \"countdown\" && \"Countdown...\"}\n                {activeMatch.phase === \"flipping\" && \"Flipping...\"}\n                {activeMatch.phase === \"complete\" && \"Complete\"}\n              </span>\n            </div>\n          </div>\n\n          {/* Round Fairness Info */}\n          <div className=\"coinflip-sidebar__fairness\">\n            <h4 className=\"coinflip-sidebar__fairness-title\">Round Fairness</h4>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Match ID</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.id}>\n                {activeMatch.id.slice(-8)}\n              </span>\n            </div>\n            <div className=\"coinflip-sidebar__fairness-row\">\n              <span>Seed Hash</span>\n              <span className=\"coinflip-sidebar__hash\" title={activeMatch.seedHash}>\n                {activeMatch.seedHash.slice(0, 8)}...{activeMatch.seedHash.slice(-4)}\n              </span>\n            </div>\n            {activeMatch.phase === \"complete\" && activeMatch.serverSeed && (\n              <>\n                <div className=\"coinflip-sidebar__fairness-row\">\n                  <span>Server Seed</span>\n                  <span className=\"coinflip-sidebar__hash coinflip-sidebar__hash--revealed\" title={activeMatch.serverSeed}>\n                    {activeMatch.serverSeed.slice(0, 8)}...{activeMatch.serverSeed.slice(-4)}\n                  </span>\n                </div>\n                {activeMatch.blockHash && (\n                  <div className=\"coinflip-sidebar__fairness-row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-sidebar__hash\" title={activeMatch.blockHash}>\n                      {activeMatch.blockHash.slice(0, 8)}...{activeMatch.blockHash.slice(-4)}\n                    </span>\n                  </div>\n                )}\n              </>\n            )}\n          </div>\n\n          {activeMatch.phase === \"complete\" && !activeMatch.claimed && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn\"\n              onClick={claimPayout}\n              disabled={claiming}\n            >\n              {claiming\n                ? \"Settling...\"\n                : activeMatch.winner === address\n                  ? \"Claim Payout\"\n                  : \"Settle & Return\"}\n            </button>\n          )}\n          {activeMatch.phase === \"complete\" && activeMatch.claimed && (\n            <button\n              type=\"button\"\n              className=\"coinflip-action-btn coinflip-action-btn--secondary\"\n              onClick={clearActiveMatch}\n            >\n              Back to Lobby\n            </button>\n          )}\n        </>\n      )}\n    </div>\n  );\n\n  // Helper to get side display for modal\n  const getSideDisplay = (match: UIMatch, isPlayer1: boolean) => {\n    const side = isPlayer1 ? match.player1Side : match.player2Side;\n    return side?.toUpperCase() ?? \"?\";\n  };\n\n  return (\n    <>\n      <GameLayout\n        gameName=\"Coinflip\"\n        gameDescription=\"Heads or Tails - 1v1 battles with 50/50 odds\"\n        sidebar={sidebar}\n        historyEntries={historyEntries}\n        showHistory={true}\n      >\n        <div className=\"coinflip-main\">\n          {/* Show active match or lobby */}\n          {activeMatch ? (\n            <ActiveMatchView\n              match={activeMatch}\n              currentUserAddress={address ?? \"\"}\n              onCancel={activeMatch.phase === \"created\" ? cancelMatch : undefined}\n              onTimeoutCancel={timeoutCancel}\n              onClaim={claimPayout}\n              onClearMatch={clearActiveMatch}\n              onRematch={handleRematch}\n              claiming={claiming}\n              rematching={creating}\n              claimTxSignature={lastClaimSignature}\n              verificationResult={verificationResult}\n              verifying={verifying}\n              onVerify={handleVerify}\n            />\n          ) : (\n            <div className=\"coinflip-lobby\">\n              {/* Your Matches — claimable/active matches for the current player */}\n              {connected && claimableMatches.length > 0 && (\n                <div className=\"coinflip-matches coinflip-your-matches\">\n                  <div className=\"coinflip-matches__header\">\n                    <h3 className=\"coinflip-matches__title\">Your Matches</h3>\n                    <span className=\"coinflip-matches__count\">\n                      {claimableMatches.length} active\n                    </span>\n                  </div>\n                  <div className=\"coinflip-matches__list\">\n                    {claimableMatches.map((match) => {\n                      const isCreator = match.player1 === address;\n                      let actionLabel: string;\n                      if (match.phase === \"complete\") {\n                        actionLabel = match.winner === address ? \"Claim\" : \"Settle\";\n                      } else if (match.phase === \"created\" && isCreator) {\n                        actionLabel = \"Cancel\";\n                      } else {\n                        actionLabel = \"View\";\n                      }\n\n                      return (\n                        <div\n                          key={match.id}\n                          className=\"coinflip-match-card coinflip-match-card--claimable\"\n                          onClick={() => selectMatch(match)}\n                          role=\"button\"\n                          tabIndex={0}\n                          onKeyDown={(e) => { if (e.key === \"Enter\") selectMatch(match); }}\n                        >\n                          <div className=\"coinflip-match-card__bet\">\n                            <div\n                              className=\"coinflip-match-card__amount\"\n                              style={{ color: TIER_COLORS[match.tier] }}\n                            >\n                              {\"$\"}{match.entryAmount}\n                            </div>\n                            <span className=\"coinflip-match-card__phase\">\n                              {match.phase === \"created\" && \"Waiting\"}\n                              {match.phase === \"ready\" && \"Locked\"}\n                              {match.phase === \"complete\" && \"Settled\"}\n                            </span>\n                          </div>\n                          <div className=\"coinflip-match-card__actions\">\n                            <button\n                              type=\"button\"\n                              className=\"coinflip-match-card__join-btn\"\n                              onClick={(e) => { e.stopPropagation(); selectMatch(match); }}\n                            >\n                              {actionLabel}\n                            </button>\n                          </div>\n                        </div>\n                      );\n                    })}\n                  </div>\n                </div>\n              )}\n\n              <OpenMatchesList\n                matches={openMatches}\n                loading={loading}\n                onJoin={handleJoinMatch}\n                joiningMatchId={joiningMatchId}\n                currentUserAddress={address}\n                selectedTier={selectedTier}\n                isConnected={connected}\n              />\n            </div>\n          )}\n        </div>\n      </GameLayout>\n\n      {/* Error Toast */}\n      {error && createPortal(\n        <div className=\"coinflip-error-toast\">\n          <Toast variant=\"error\" message={error} onClose={clearError} />\n        </div>,\n        document.body\n      )}\n\n      {/* History Detail Modal */}\n      <Modal\n        isOpen={selectedHistoryMatch !== null}\n        onClose={() => setSelectedHistoryMatch(null)}\n        title=\"Match Details\"\n      >\n        {selectedHistoryMatch && (() => {\n          const isPlayer1 = selectedHistoryMatch.player1 === address;\n          const isWinner = selectedHistoryMatch.winner === address;\n          const yourSide = isPlayer1 ? selectedHistoryMatch.player1Side : selectedHistoryMatch.player2Side;\n          const sideColor = yourSide ? SIDE_COLORS[yourSide] : \"#888\";\n\n          return (\n            <div className=\"coinflip-history-modal\">\n              {/* Match Stats */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">Match Stats</h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Tier</span>\n                  <span\n                    style={{\n                      color: TIER_COLORS[selectedHistoryMatch.tier],\n                      textShadow: `0 0 4px ${TIER_COLORS[selectedHistoryMatch.tier]}`,\n                      textTransform: \"capitalize\",\n                    }}\n                  >\n                    {selectedHistoryMatch.tier}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Your Side</span>\n                  <span style={{ color: sideColor, textShadow: `0 0 4px ${sideColor}` }}>\n                    {getSideDisplay(selectedHistoryMatch, isPlayer1)}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Entry</span>\n                  <span>{`$${selectedHistoryMatch.entryAmount}`}</span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Total Pot</span>\n                  <span className=\"coinflip-history-modal__highlight\">\n                    {`$${(selectedHistoryMatch.entryAmount * 2).toFixed(2)}`}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Result</span>\n                  <span\n                    style={{\n                      color: selectedHistoryMatch.result ? SIDE_COLORS[selectedHistoryMatch.result] : \"#888\",\n                      textShadow: selectedHistoryMatch.result\n                        ? `0 0 4px ${SIDE_COLORS[selectedHistoryMatch.result]}`\n                        : undefined,\n                    }}\n                  >\n                    {selectedHistoryMatch.result?.toUpperCase() ?? \"?\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Outcome</span>\n                  <span\n                    className={isWinner ? \"coinflip-history-modal__winner--you\" : \"\"}\n                    style={{ color: isWinner ? \"#45b058\" : \"#d45d5d\" }}\n                  >\n                    {isWinner ? \"WON!\" : \"LOST\"}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Payout</span>\n                  <span className={isWinner ? \"coinflip-history-modal__highlight\" : \"\"}>\n                    {isWinner ? `+$${selectedHistoryMatch.payoutAmount.toFixed(2)}` : `-$${selectedHistoryMatch.entryAmount.toFixed(2)}`}\n                  </span>\n                </div>\n              </div>\n\n              {/* Match Fairness */}\n              <div className=\"coinflip-history-modal__section\">\n                <h4 className=\"coinflip-history-modal__section-title\">\n                  <span className=\"coinflip-history-modal__lock\">🔒</span>\n                  Round Fairness\n                </h4>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Match ID</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.id}>\n                    {selectedHistoryMatch.id}\n                  </span>\n                </div>\n                <div className=\"coinflip-history-modal__row\">\n                  <span>Seed Hash</span>\n                  <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.seedHash}>\n                    {selectedHistoryMatch.seedHash}\n                  </span>\n                </div>\n                {selectedHistoryMatch.serverSeed && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Server Seed</span>\n                    <span\n                      className=\"coinflip-history-modal__hash coinflip-history-modal__hash--revealed\"\n                      title={selectedHistoryMatch.serverSeed}\n                    >\n                      {selectedHistoryMatch.serverSeed}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.blockHash && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>Block Hash</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.blockHash}>\n                      {selectedHistoryMatch.blockHash}\n                    </span>\n                  </div>\n                )}\n                {selectedHistoryMatch.vrfProof && (\n                  <div className=\"coinflip-history-modal__row\">\n                    <span>VRF Proof</span>\n                    <span className=\"coinflip-history-modal__hash\" title={selectedHistoryMatch.vrfProof}>\n                      {selectedHistoryMatch.vrfProof.slice(0, 32)}...\n                    </span>\n                  </div>\n                )}\n              </div>\n\n              {/* Verify Link */}\n              <a href=\"/fairness\" className=\"coinflip-history-modal__verify-link\">\n                Verify on Fairness Page →\n              </a>\n            </div>\n          );\n        })()}\n      </Modal>\n    </>\n  );\n}\n\nexport function CoinflipPage() {\n  return (\n    <CoinflipProvider>\n      <CoinflipPageContent />\n    </CoinflipProvider>\n  );\n}\n","numLines":466,"startLine":120,"totalLines":585}}}
