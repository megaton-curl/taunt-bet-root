{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QAy3Y2MeQ3q7SwBhQFBdTh","type":"tool_result","content":"     1→/**\n     2→ * Deterministic wallet-funding helper for local E2E tests.\n     3→ *\n     4→ * Generates fixed keypairs from seed bytes so tests are reproducible,\n     5→ * then airdrops SOL and confirms before tests run.\n     6→ */\n     7→import {\n     8→  Connection,\n     9→  Keypair,\n    10→  LAMPORTS_PER_SOL,\n    11→  PublicKey,\n    12→} from \"@solana/web3.js\";\n    13→\n    14→// --- Deterministic keypairs ---\n    15→// Fixed 32-byte seeds produce the same keypairs on every run.\n    16→const SEED_PLAYER_A = new Uint8Array(32).fill(0xaa);\n    17→const SEED_PLAYER_B = new Uint8Array(32).fill(0xbb);\n    18→\n    19→export const PLAYER_A = Keypair.fromSeed(SEED_PLAYER_A);\n    20→export const PLAYER_B = Keypair.fromSeed(SEED_PLAYER_B);\n    21→\n    22→/** Default RPC URL for local test validator. */\n    23→export const LOCAL_RPC_URL = \"http://127.0.0.1:8899\";\n    24→\n    25→/** Default airdrop amount per wallet (10 SOL). */\n    26→const DEFAULT_AIRDROP_SOL = 10;\n    27→\n    28→/**\n    29→ * Airdrop SOL to a single wallet and confirm the transaction.\n    30→ *\n    31→ * @param connection - Solana RPC connection\n    32→ * @param to - Public key to fund\n    33→ * @param solAmount - Amount in SOL (default: 10)\n    34→ */\n    35→export async function fundWallet(\n    36→  connection: Connection,\n    37→  to: PublicKey,\n    38→  solAmount = DEFAULT_AIRDROP_SOL,\n    39→): Promise<void> {\n    40→  const lamports = solAmount * LAMPORTS_PER_SOL;\n    41→  const sig = await connection.requestAirdrop(to, lamports);\n    42→  const { blockhash, lastValidBlockHeight } =\n    43→    await connection.getLatestBlockhash();\n    44→  await connection.confirmTransaction(\n    45→    { signature: sig, blockhash, lastValidBlockHeight },\n    46→    \"confirmed\",\n    47→  );\n    48→}\n    49→\n    50→/**\n    51→ * Fund both test players on the local validator.\n    52→ * Call this in a `beforeAll` or global setup before the E2E suite starts.\n    53→ *\n    54→ * @param rpcUrl - RPC endpoint (default: local validator)\n    55→ * @param solAmount - SOL to airdrop per player (default: 10)\n    56→ */\n    57→export async function fundTestWallets(\n    58→  rpcUrl = LOCAL_RPC_URL,\n    59→  solAmount = DEFAULT_AIRDROP_SOL,\n    60→): Promise<{ playerA: Keypair; playerB: Keypair; connection: Connection }> {\n    61→  const connection = new Connection(rpcUrl, \"confirmed\");\n    62→\n    63→  await Promise.all([\n    64→    fundWallet(connection, PLAYER_A.publicKey, solAmount),\n    65→    fundWallet(connection, PLAYER_B.publicKey, solAmount),\n    66→  ]);\n    67→\n    68→  // Sanity-check: verify balances are present\n    69→  const [balA, balB] = await Promise.all([\n    70→    connection.getBalance(PLAYER_A.publicKey),\n    71→    connection.getBalance(PLAYER_B.publicKey),\n    72→  ]);\n    73→\n    74→  const minExpected = solAmount * LAMPORTS_PER_SOL;\n    75→  if (balA < minExpected) {\n    76→    throw new Error(\n    77→      `Player A funding failed: expected >= ${minExpected} lamports, got ${balA}`,\n    78→    );\n    79→  }\n    80→  if (balB < minExpected) {\n    81→    throw new Error(\n    82→      `Player B funding failed: expected >= ${minExpected} lamports, got ${balB}`,\n    83→    );\n    84→  }\n    85→\n    86→  return { playerA: PLAYER_A, playerB: PLAYER_B, connection };\n    87→}\n    88→"}]},"parent_tool_use_id":null,"session_id":"339d09be-5189-43e7-b291-e94f665f152d","uuid":"9721d115-8921-472c-9d46-ac913be3b186","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/wallets.ts","content":"/**\n * Deterministic wallet-funding helper for local E2E tests.\n *\n * Generates fixed keypairs from seed bytes so tests are reproducible,\n * then airdrops SOL and confirms before tests run.\n */\nimport {\n  Connection,\n  Keypair,\n  LAMPORTS_PER_SOL,\n  PublicKey,\n} from \"@solana/web3.js\";\n\n// --- Deterministic keypairs ---\n// Fixed 32-byte seeds produce the same keypairs on every run.\nconst SEED_PLAYER_A = new Uint8Array(32).fill(0xaa);\nconst SEED_PLAYER_B = new Uint8Array(32).fill(0xbb);\n\nexport const PLAYER_A = Keypair.fromSeed(SEED_PLAYER_A);\nexport const PLAYER_B = Keypair.fromSeed(SEED_PLAYER_B);\n\n/** Default RPC URL for local test validator. */\nexport const LOCAL_RPC_URL = \"http://127.0.0.1:8899\";\n\n/** Default airdrop amount per wallet (10 SOL). */\nconst DEFAULT_AIRDROP_SOL = 10;\n\n/**\n * Airdrop SOL to a single wallet and confirm the transaction.\n *\n * @param connection - Solana RPC connection\n * @param to - Public key to fund\n * @param solAmount - Amount in SOL (default: 10)\n */\nexport async function fundWallet(\n  connection: Connection,\n  to: PublicKey,\n  solAmount = DEFAULT_AIRDROP_SOL,\n): Promise<void> {\n  const lamports = solAmount * LAMPORTS_PER_SOL;\n  const sig = await connection.requestAirdrop(to, lamports);\n  const { blockhash, lastValidBlockHeight } =\n    await connection.getLatestBlockhash();\n  await connection.confirmTransaction(\n    { signature: sig, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n}\n\n/**\n * Fund both test players on the local validator.\n * Call this in a `beforeAll` or global setup before the E2E suite starts.\n *\n * @param rpcUrl - RPC endpoint (default: local validator)\n * @param solAmount - SOL to airdrop per player (default: 10)\n */\nexport async function fundTestWallets(\n  rpcUrl = LOCAL_RPC_URL,\n  solAmount = DEFAULT_AIRDROP_SOL,\n): Promise<{ playerA: Keypair; playerB: Keypair; connection: Connection }> {\n  const connection = new Connection(rpcUrl, \"confirmed\");\n\n  await Promise.all([\n    fundWallet(connection, PLAYER_A.publicKey, solAmount),\n    fundWallet(connection, PLAYER_B.publicKey, solAmount),\n  ]);\n\n  // Sanity-check: verify balances are present\n  const [balA, balB] = await Promise.all([\n    connection.getBalance(PLAYER_A.publicKey),\n    connection.getBalance(PLAYER_B.publicKey),\n  ]);\n\n  const minExpected = solAmount * LAMPORTS_PER_SOL;\n  if (balA < minExpected) {\n    throw new Error(\n      `Player A funding failed: expected >= ${minExpected} lamports, got ${balA}`,\n    );\n  }\n  if (balB < minExpected) {\n    throw new Error(\n      `Player B funding failed: expected >= ${minExpected} lamports, got ${balB}`,\n    );\n  }\n\n  return { playerA: PLAYER_A, playerB: PLAYER_B, connection };\n}\n","numLines":88,"startLine":1,"totalLines":88}}}
