{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DKryaqWA9CNWqjEPPYHtn9","type":"tool_result","content":"     1→// Context & Hooks\n     2→export { CoinflipProvider, useCoinflip } from \"./context/CoinflipContext\";\n     3→\n     4→// Components\n     5→export {\n     6→  CoinSideSelector,\n     7→  CoinAnimation,\n     8→  MatchCard,\n     9→  OpenMatchesList,\n    10→  ActiveMatchView,\n    11→} from \"./components\";\n    12→\n    13→// Types\n    14→export type { UIMatch, CoinSide, CoinflipPhase } from \"./types\";\n    15→\n    16→// Utils\n    17→export { truncateAddress } from \"./utils/helpers\";\n    18→"}]},"parent_tool_use_id":"toolu_01R7tqGeoym5azkT7Zf4QGRt","session_id":"339d09be-5189-43e7-b291-e94f665f152d","uuid":"8404ce12-1a76-4a68-9279-3967df9f90f9"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01KAMozV8bfMMQLqQ2ZdoTT6","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011cHxVYdqiCVP3vggNupCQm","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/coinflip/context/CoinflipContext.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":4,"cache_creation_input_tokens":11089,"cache_read_input_tokens":27468,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":11089},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01R7tqGeoym5azkT7Zf4QGRt","session_id":"339d09be-5189-43e7-b291-e94f665f152d","uuid":"d68f680e-5b35-47d8-8fda-1ebf01c361c5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011cHxVYdqiCVP3vggNupCQm","type":"tool_result","content":"     1→import {\n     2→  createContext,\n     3→  useContext,\n     4→  useState,\n     5→  useCallback,\n     6→  useEffect,\n     7→  useRef,\n     8→  type ReactNode,\n     9→} from \"react\";\n    10→import { PublicKey, type Transaction } from \"@solana/web3.js\";\n    11→import type { Tier } from \"@rng-utopia/game-engine/browser\";\n    12→import type { UIMatch, CoinSide } from \"../types\";\n    13→import {\n    14→  fetchAllOpenMatches,\n    15→  fetchClaimableMatches,\n    16→  fetchMatchByCreator,\n    17→  fetchMatch,\n    18→  getMatchPda,\n    19→  buildCreateMatchTx,\n    20→  buildJoinMatchTx,\n    21→  buildCancelMatchTx,\n    22→  buildTimeoutCancelTx,\n    23→  buildClaimPayoutTx,\n    24→} from \"../utils/chain\";\n    25→import { useWallet, useConnection, useBalance } from \"@rng-utopia/wallet/hooks\";\n    26→\n    27→/** Parse Solana/wallet errors into user-friendly messages */\n    28→function parseTransactionError(err: unknown): string {\n    29→  const msg = err instanceof Error ? err.message : String(err);\n    30→\n    31→  // Wallet not connected\n    32→  if (msg.includes(\"Wallet not connected\") || msg.includes(\"WalletNotConnectedError\")) {\n    33→    return \"Wallet not connected. Please connect your wallet first.\";\n    34→  }\n    35→\n    36→  // User rejected\n    37→  if (msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")) {\n    38→    return \"Transaction cancelled by user.\";\n    39→  }\n    40→\n    41→  // Insufficient funds (Solana runtime error)\n    42→  if (msg.includes(\"insufficient lamports\") || msg.includes(\"Insufficient funds\") || msg.includes(\"0x1\")) {\n    43→    return \"Insufficient balance. You need more SOL to complete this transaction.\";\n    44→  }\n    45→\n    46→  // Account already in use (match already exists)\n    47→  if (msg.includes(\"already in use\")) {\n    48→    return \"You already have an active match. Cancel it before creating a new one.\";\n    49→  }\n    50→\n    51→  // Network / RPC errors\n    52→  if (msg.includes(\"Failed to fetch\") || msg.includes(\"NetworkError\") || msg.includes(\"ECONNREFUSED\")) {\n    53→    return \"Network error. Please check your connection and try again.\";\n    54→  }\n    55→\n    56→  // Anchor program errors\n    57→  if (msg.includes(\"InvalidPhase\")) {\n    58→    return \"This match is no longer available.\";\n    59→  }\n    60→  if (msg.includes(\"CannotJoinOwnMatch\")) {\n    61→    return \"You cannot join your own match.\";\n    62→  }\n    63→\n    64→  // Simulation / preflight failures\n    65→  if (msg.includes(\"Simulation failed\") || msg.includes(\"Transaction simulation failed\")) {\n    66→    return \"Transaction simulation failed. The match may no longer be available.\";\n    67→  }\n    68→\n    69→  // Blockhash expiry\n    70→  if (msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")) {\n    71→    return \"Transaction expired. Please try again.\";\n    72→  }\n    73→\n    74→  // Generic fallback — log full error for debugging\n    75→  console.error(\"[coinflip] unhandled transaction error:\", err);\n    76→  return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n    77→}\n    78→\n    79→interface CoinflipContextValue {\n    80→  // State\n    81→  activeMatch: UIMatch | null;\n    82→  openMatches: UIMatch[];\n    83→  claimableMatches: UIMatch[];\n    84→  userHistory: UIMatch[];\n    85→  selectedTier: Tier | null;\n    86→  selectedSide: CoinSide | null;\n    87→\n    88→  // Loading states\n    89→  loading: boolean;\n    90→  creating: boolean;\n    91→  joining: boolean;\n    92→  claiming: boolean;\n    93→  joiningMatchId: string | null;\n    94→\n    95→  // Error state\n    96→  error: string | null;\n    97→  clearError: () => void;\n    98→\n    99→  // Verification\n   100→  lastClaimSignature: string | null;\n   101→\n   102→  // Actions\n   103→  setSelectedTier: (tier: Tier | null) => void;\n   104→  setSelectedSide: (side: CoinSide | null) => void;\n   105→  createMatch: () => Promise<void>;\n   106→  joinMatch: (matchId: string) => Promise<void>;\n   107→  cancelMatch: () => Promise<void>;\n   108→  timeoutCancel: () => Promise<void>;\n   109→  claimPayout: () => Promise<void>;\n   110→  clearActiveMatch: () => void;\n   111→  selectMatch: (match: UIMatch) => void;\n   112→  refreshMatches: () => void;\n   113→}\n   114→\n   115→const CoinflipContext = createContext<CoinflipContextValue | null>(null);\n   116→\n   117→export function CoinflipProvider({ children }: { children: ReactNode }) {\n   118→  const { connected, publicKey, sendTransaction } = useWallet();\n   119→  const { connection } = useConnection();\n   120→  const { refresh: refreshBalance } = useBalance();\n   121→\n   122→  // Selection state\n   123→  const [selectedTier, setSelectedTier] = useState<Tier | null>(null);\n   124→  const [selectedSide, setSelectedSide] = useState<CoinSide | null>(null);\n   125→\n   126→  // Match state\n   127→  const [activeMatch, setActiveMatch] = useState<UIMatch | null>(null);\n   128→  const [openMatches, setOpenMatches] = useState<UIMatch[]>([]);\n   129→  const [claimableMatches, setClaimableMatches] = useState<UIMatch[]>([]);\n   130→  const [userHistory] = useState<UIMatch[]>([]);\n   131→\n   132→  // Loading states\n   133→  const [loading, setLoading] = useState(true);\n   134→  const [creating, setCreating] = useState(false);\n   135→  const [joining, setJoining] = useState(false);\n   136→  const [claiming, setClaiming] = useState(false);\n   137→  const [joiningMatchId, setJoiningMatchId] = useState<string | null>(null);\n   138→\n   139→  // Error state\n   140→  const [error, setError] = useState<string | null>(null);\n   141→  const clearError = useCallback(() => setError(null), []);\n   142→\n   143→  // Verification — last claim tx signature for fairness verification\n   144→  const [lastClaimSignature, setLastClaimSignature] = useState<string | null>(null);\n   145→\n   146→  // Timer ref for flip animation delay (ready→flipping→complete)\n   147→  const flipTimerRef = useRef<number | null>(null);\n   148→  const refreshInFlightRef = useRef(false);\n   149→  const activeMatchFetchInFlightRef = useRef(false);\n   150→\n   151→  // Ref to prevent polling races from restoring a dismissed match.\n   152→  // When the user clicks \"Back to Lobby\", a dangling fetchMatch promise\n   153→  // from the previous poll interval may resolve and call setActiveMatch,\n   154→  // putting them back on the match view. This ref blocks that.\n   155→  const dismissedMatchRef = useRef<string | null>(null);\n   156→\n   157→  /** Send transaction, wait for on-chain confirmation, and refresh balance. */\n   158→  const sendAndConfirm = useCallback(\n   159→    async (transaction: Transaction): Promise<string> => {\n   160→      // Refresh blockhash right before sending so it doesn't expire\n   161→      // if the user took time on the wallet confirmation screen.\n   162→      const { blockhash, lastValidBlockHeight } =\n   163→        await connection.getLatestBlockhash(\"confirmed\");\n   164→      transaction.recentBlockhash = blockhash;\n   165→      const signature = await sendTransaction(transaction);\n   166→      await connection.confirmTransaction(\n   167→        { signature, blockhash, lastValidBlockHeight },\n   168→        \"confirmed\",\n   169→      );\n   170→      await refreshBalance();\n   171→      return signature;\n   172→    },\n   173→    [connection, sendTransaction, refreshBalance],\n   174→  );\n   175→\n   176→  // Fetch open matches + claimable matches from on-chain (lobby data).\n   177→  // Only called when the user is in the lobby — NOT during an active match.\n   178→  const refreshMatches = useCallback(async () => {\n   179→    if (refreshInFlightRef.current) return;\n   180→    refreshInFlightRef.current = true;\n   181→\n   182→    try {\n   183→      const [matches, claimable] = await Promise.all([\n   184→        fetchAllOpenMatches(connection),\n   185→        publicKey\n   186→          ? fetchClaimableMatches(connection, publicKey)\n   187→          : Promise.resolve([]),\n   188→      ]);\n   189→\n   190→      setOpenMatches(matches);\n   191→      setClaimableMatches(claimable);\n   192→    } catch {\n   193→      // Ignore transient RPC failures; polling will retry on next cycle.\n   194→    } finally {\n   195→      setLoading(false);\n   196→      refreshInFlightRef.current = false;\n   197→    }\n   198→  }, [connection, publicKey]);\n   199→\n   200→  // Initial load\n   201→  useEffect(() => {\n   202→    setLoading(true);\n   203→    void refreshMatches();\n   204→  }, [refreshMatches]);\n   205→\n   206→  // Poll interval — faster when waiting for VRF callback (LOCKED→SETTLED),\n   207→  // slower for lobby polling to avoid devnet rate limits.\n   208→  const isAwaitingVrf = activeMatch?.phase === \"ready\";\n   209→  const pollInterval = isAwaitingVrf ? 5000 : 30000;\n   210→\n   211→  useEffect(() => {\n   212→    const interval = setInterval(() => {\n   213→      if (activeMatch) {\n   214→        // In-game: only poll the active match — no lobby or claimable fetches.\n   215→        if (\n   216→          activeMatch.phase !== \"flipping\" &&\n   217→          !activeMatch.claimed &&\n   218→          !activeMatchFetchInFlightRef.current\n   219→        ) {\n   220→          activeMatchFetchInFlightRef.current = true;\n   221→          const matchPda = new PublicKey(activeMatch.id);\n   222→          fetchMatch(connection, matchPda)\n   223→            .then((updated) => {\n   224→              if (dismissedMatchRef.current === matchPda.toBase58()) return;\n   225→\n   226→              if (updated) {\n   227→                // Intercept ready→complete: insert 3s flip animation first\n   228→                if (activeMatch.phase === \"ready\" && updated.phase === \"complete\") {\n   229→                  setActiveMatch({ ...updated, phase: \"flipping\" });\n   230→                  flipTimerRef.current = window.setTimeout(() => {\n   231→                    flipTimerRef.current = null;\n   232→                    setActiveMatch((current) =>\n   233→                      current?.phase === \"flipping\" ? updated : current\n   234→                    );\n   235→                  }, 3000);\n   236→                } else {\n   237→                  setActiveMatch(updated);\n   238→                }\n   239→              } else {\n   240→                // Match account closed (claimed or cancelled)\n   241→                setActiveMatch(null);\n   242→              }\n   243→            })\n   244→            .catch(() => {\n   245→              // Ignore polling errors\n   246→            })\n   247→            .finally(() => {\n   248→              activeMatchFetchInFlightRef.current = false;\n   249→            });\n   250→        }\n   251→      } else {\n   252→        // Lobby: poll open matches + claimable\n   253→        void refreshMatches();\n   254→      }\n   255→    }, pollInterval);\n   256→    return () => clearInterval(interval);\n   257→  }, [refreshMatches, activeMatch, connection, pollInterval]);\n   258→\n   259→  // Cleanup flip timer on unmount\n   260→  useEffect(() => {\n   261→    return () => {\n   262→      if (flipTimerRef.current !== null) {\n   263→        clearTimeout(flipTimerRef.current);\n   264→      }\n   265→    };\n   266→  }, []);\n   267→\n   268→  const createMatch = useCallback(async () => {\n   269→    if (!connected || !publicKey) {\n   270→      setError(\"Wallet not connected. Please connect your wallet first.\");\n   271→      return;\n   272→    }\n   273→    if (!selectedTier || !selectedSide) {\n   274→      setError(\"Select tier and side first.\");\n   275→      return;\n   276→    }\n   277→\n   278→    setCreating(true);\n   279→    setError(null);\n   280→    try {\n   281→      // Pre-check: if the match PDA already exists on-chain, prevent duplicate init\n   282→      const [matchPda] = getMatchPda(publicKey);\n   283→      const existing = await fetchMatch(connection, matchPda);\n   284→      if (existing) {\n   285→        if (existing.phase === \"complete\") {\n   286→          // Match is settled — show it so user can settle (winner claims, loser closes)\n   287→          setActiveMatch(existing);\n   288→          dismissedMatchRef.current = null;\n   289→          setError(\"Settle your previous match first.\");\n   290→        } else {\n   291→          // Match still in progress\n   292→          setActiveMatch(existing);\n   293→          dismissedMatchRef.current = null;\n   294→          setError(\"You already have an active match.\");\n   295→        }\n   296→        return;\n   297→      }\n   298→\n   299→      const { transaction } = await buildCreateMatchTx(\n   300→        connection,\n   301→        publicKey,\n   302→        selectedTier,\n   303→        selectedSide\n   304→      );\n   305→\n   306→      await sendAndConfirm(transaction);\n   307→\n   308→      // Clear dismissed ref — this is a new intentional match\n   309→      dismissedMatchRef.current = null;\n   310→\n   311→      // Fetch the created match from on-chain\n   312→      const match = await fetchMatch(connection, matchPda);\n   313→      if (match) {\n   314→        setActiveMatch(match);\n   315→      }\n   316→\n   317→      setSelectedSide(null);\n   318→      refreshMatches();\n   319→    } catch (err) {\n   320→      setError(parseTransactionError(err));\n   321→    } finally {\n   322→      setCreating(false);\n   323→    }\n   324→  }, [connected, publicKey, selectedTier, selectedSide, connection, sendAndConfirm, refreshMatches]);\n   325→\n   326→  const joinMatch = useCallback(\n   327→    async (matchId: string) => {\n   328→      if (!connected || !publicKey) {\n   329→        setError(\"Wallet not connected. Please connect your wallet first.\");\n   330→        return;\n   331→      }\n   332→\n   333→      setJoining(true);\n   334→      setJoiningMatchId(matchId);\n   335→      setError(null);\n   336→      try {\n   337→        // matchId is the match PDA base58 — fetch to get the creator\n   338→        const matchPda = new PublicKey(matchId);\n   339→        const existingMatch = await fetchMatch(connection, matchPda);\n   340→        if (!existingMatch) {\n   341→          setError(\"Match not found. It may have been cancelled.\");\n   342→          return;\n   343→        }\n   344→\n   345→        const matchCreator = new PublicKey(existingMatch.player1);\n   346→        const transaction = await buildJoinMatchTx(\n   347→          connection,\n   348→          publicKey,\n   349→          matchCreator\n   350→        );\n   351→\n   352→        await sendAndConfirm(transaction);\n   353→\n   354→        // Clear dismissed ref — this is a new intentional match\n   355→        dismissedMatchRef.current = null;\n   356→\n   357→        // Fetch updated match\n   358→        const updated = await fetchMatch(connection, matchPda);\n   359→        if (updated) {\n   360→          setActiveMatch(updated);\n   361→        }\n   362→\n   363→        refreshMatches();\n   364→      } catch (err) {\n   365→        setError(parseTransactionError(err));\n   366→      } finally {\n   367→        setJoining(false);\n   368→        setJoiningMatchId(null);\n   369→      }\n   370→    },\n   371→    [connected, publicKey, connection, sendAndConfirm, refreshMatches]\n   372→  );\n   373→\n   374→  const cancelMatch = useCallback(async () => {\n   375→    if (!connected || !publicKey || !activeMatch) {\n   376→      setError(\"No active match to cancel.\");\n   377→      return;\n   378→    }\n   379→\n   380→    setError(null);\n   381→    try {\n   382→      const transaction = await buildCancelMatchTx(connection, publicKey);\n   383→      await sendAndConfirm(transaction);\n   384→      setActiveMatch(null);\n   385→      refreshMatches();\n   386→    } catch (err) {\n   387→      setError(parseTransactionError(err));\n   388→    }\n   389→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   390→\n   391→  const timeoutCancel = useCallback(async () => {\n   392→    if (!connected || !publicKey || !activeMatch) {\n   393→      setError(\"No active match to cancel.\");\n   394→      return;\n   395→    }\n   396→    if (!activeMatch.player2) {\n   397→      setError(\"Match has no opponent.\");\n   398→      return;\n   399→    }\n   400→\n   401→    setError(null);\n   402→    try {\n   403→      const matchCreator = new PublicKey(activeMatch.player1);\n   404→      const opponent = new PublicKey(activeMatch.player2);\n   405→\n   406→      const transaction = await buildTimeoutCancelTx(\n   407→        connection,\n   408→        publicKey,\n   409→        matchCreator,\n   410→        opponent\n   411→      );\n   412→      await sendAndConfirm(transaction);\n   413→      setActiveMatch(null);\n   414→      refreshMatches();\n   415→    } catch (err) {\n   416→      // If timeout cancel failed, VRF may have resolved in the meantime.\n   417→      // Re-fetch the match — if it's still Locked, the VRF fulfilled and\n   418→      // claimPayout is the correct action. Update the UI to show Settle.\n   419→      const [matchPda] = getMatchPda(new PublicKey(activeMatch.player1));\n   420→      const refreshed = await fetchMatch(connection, matchPda).catch(() => null);\n   421→      if (refreshed && refreshed.phase === \"ready\") {\n   422→        // Match still locked → VRF likely resolved, show as complete\n   423→        // so the Settle button appears.\n   424→        setActiveMatch({ ...refreshed, phase: \"complete\" });\n   425→        setError(\"VRF resolved — the match has a result. Settle to claim your payout.\");\n   426→        return;\n   427→      }\n   428→\n   429→      setError(parseTransactionError(err));\n   430→    }\n   431→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   432→\n   433→  /** Settle the match on-chain: read VRF result, derive winner, send payout, close PDA.\n   434→   *  Can be called by either player — winner is derived on-chain from VRF randomness. */\n   435→  const claimPayout = useCallback(async () => {\n   436→    if (!connected || !publicKey || !activeMatch) {\n   437→      setError(\"No active match to claim.\");\n   438→      return;\n   439→    }\n   440→    if (!activeMatch.player2) {\n   441→      setError(\"Match has no opponent yet.\");\n   442→      return;\n   443→    }\n   444→\n   445→    setClaiming(true);\n   446→    setError(null);\n   447→    try {\n   448→      const matchCreator = new PublicKey(activeMatch.player1);\n   449→      const opponent = new PublicKey(activeMatch.player2);\n   450→\n   451→      const transaction = await buildClaimPayoutTx(\n   452→        connection,\n   453→        publicKey,   // caller (either player — winner derived on-chain from VRF)\n   454→        matchCreator,\n   455→        opponent\n   456→      );\n   457→\n   458→      const signature = await sendAndConfirm(transaction);\n   459→\n   460→      // Match PDA is now closed on-chain. Keep activeMatch locally with\n   461→      // claimed=true so the user can verify fairness before returning to lobby.\n   462→      setLastClaimSignature(signature);\n   463→      setActiveMatch((prev) => prev ? { ...prev, claimed: true } : null);\n   464→      refreshMatches();\n   465→    } catch (err) {\n   466→      setError(parseTransactionError(err));\n   467→    } finally {\n   468→      setClaiming(false);\n   469→    }\n   470→  }, [connected, publicKey, activeMatch, connection, sendAndConfirm, refreshMatches]);\n   471→\n   472→  // Track if user explicitly cleared the match\n   473→  const [userClearedMatch, setUserClearedMatch] = useState(false);\n   474→\n   475→  /** Open a match from the claimable list in ActiveMatchView. */\n   476→  const selectMatch = useCallback((match: UIMatch) => {\n   477→    dismissedMatchRef.current = null;\n   478→    setActiveMatch(match);\n   479→    setUserClearedMatch(false);\n   480→  }, []);\n   481→\n   482→  const clearActiveMatch = useCallback(() => {\n   483→    // Record the dismissed match ID so in-flight polls don't restore it\n   484→    dismissedMatchRef.current = activeMatch?.id ?? null;\n   485→    setActiveMatch(null);\n   486→    setLastClaimSignature(null);\n   487→    setUserClearedMatch(true);\n   488→    setError(null);\n   489→    refreshMatches();\n   490→  }, [activeMatch, refreshMatches]);\n   491→\n   492→  // Check for existing active match on wallet connect\n   493→  useEffect(() => {\n   494→    if (publicKey && !activeMatch && !userClearedMatch) {\n   495→      fetchMatchByCreator(connection, publicKey)\n   496→        .then((match) => {\n   497→          if (match) {\n   498→            // Don't restore a match the user explicitly dismissed\n   499→            if (dismissedMatchRef.current === match.id) return;\n   500→            setActiveMatch(match);\n   501→          }\n   502→        })\n   503→        .catch(() => {\n   504→          // No active match found\n   505→        });\n   506→    }\n   507→  }, [publicKey, activeMatch, userClearedMatch, connection]);\n   508→\n   509→  // Reset userClearedMatch when creating or joining a new match\n   510→  useEffect(() => {\n   511→    if (activeMatch) {\n   512→      setUserClearedMatch(false);\n   513→    }\n   514→  }, [activeMatch]);\n   515→\n   516→  const value: CoinflipContextValue = {\n   517→    activeMatch,\n   518→    openMatches,\n   519→    claimableMatches,\n   520→    userHistory,\n   521→    selectedTier,\n   522→    selectedSide,\n   523→    loading,\n   524→    creating,\n   525→    joining,\n   526→    claiming,\n   527→    joiningMatchId,\n   528→    error,\n   529→    clearError,\n   530→    lastClaimSignature,\n   531→    setSelectedTier,\n   532→    setSelectedSide,\n   533→    createMatch,\n   534→    joinMatch,\n   535→    cancelMatch,\n   536→    timeoutCancel,\n   537→    claimPayout,\n   538→    clearActiveMatch,\n   539→    selectMatch,\n   540→    refreshMatches,\n   541→  };\n   542→\n   543→  return (\n   544→    <CoinflipContext.Provider value={value}>\n   545→      {children}\n   546→    </CoinflipContext.Provider>\n   547→  );\n   548→}\n   549→\n   550→export function useCoinflip(): CoinflipContextValue {\n   551→  const context = useContext(CoinflipContext);\n   552→  if (!context) {\n   553→    throw new Error(\"useCoinflip must be used within CoinflipProvider\");\n   554→  }\n   555→  return context;\n   556→}\n   557→"}]},"parent_tool_use_id":"toolu_01R7tqGeoym5azkT7Zf4QGRt","session_id":"339d09be-5189-43e7-b291-e94f665f152d","uuid":"2e3227b7-533e-498d-b710-fe8ac839a1d5"}
