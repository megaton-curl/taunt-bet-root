{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QS9Ub5J9W9FgeRyzDBktzF","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/page-objects.ts"}]},"parent_tool_use_id":null,"session_id":"339d09be-5189-43e7-b291-e94f665f152d","uuid":"29074c3a-dc9a-4d37-a088-40157393b612","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/page-objects.ts","content":"/**\n * Shared E2E page-object helpers for coinflip tests.\n *\n * CSS-class-based selectors matching the actual component markup.\n * Provides create, join, claim, cancel actions and reusable wait/assert primitives.\n */\nimport { type Page, type Locator, expect } from \"@playwright/test\";\n\n// ---------------------------------------------------------------------------\n// Selectors (CSS classes from CoinflipPage, ActiveMatchView, OpenMatchesList)\n// ---------------------------------------------------------------------------\n\nexport const sel = {\n  // Page structure\n  lobby: \".coinflip-lobby\",\n  sidebar: \".coinflip-sidebar\",\n  main: \".coinflip-main\",\n\n  // Sidebar — create flow\n  sidebarTitle: \".coinflip-sidebar__title\",\n  tierSelector: \".rng-tier-selector\",\n  tierButton: (tier: string) => `.rng-tier-btn:has(.rng-tier-gem--${tier})`,\n  tierButtonSelected: \".rng-tier-btn--selected\",\n  sideSelector: \".coinflip-side-selector\",\n  sideButtonHeads: \".coinflip-side-btn--heads\",\n  sideButtonTails: \".coinflip-side-btn--tails\",\n  sideButtonSelected: \".coinflip-side-btn--selected\",\n  summary: \".coinflip-sidebar__summary\",\n  actionButton: \".coinflip-action-btn\",\n  actionButtonSecondary: \".coinflip-action-btn--secondary\",\n\n  // Lobby — open matches\n  matchesList: \".coinflip-matches__list\",\n  matchesCount: \".coinflip-matches__count\",\n  matchCard: \".coinflip-match-card\",\n  matchCardOwn: \".coinflip-match-card--own\",\n  matchCardClaimable: \".coinflip-match-card--claimable\",\n  matchCardJoinBtn: \".coinflip-match-card__join-btn\",\n  matchCardAmount: \".coinflip-match-card__amount\",\n  matchCardAddress: \".coinflip-match-card__address\",\n\n  // Active match view\n  activeMatch: \".coinflip-active-match\",\n  activeMatchTitle: \".coinflip-active-match__title\",\n  activeMatchTitleWon: \".coinflip-active-match__title--won\",\n  activeMatchTitleLost: \".coinflip-active-match__title--lost\",\n  activeMatchWaiting: \".coinflip-active-match__waiting\",\n  activeMatchPlaying: \".coinflip-active-match__playing\",\n\n  // Result\n  resultOutcome: \".coinflip-result__outcome\",\n  resultPayout: \".coinflip-result__payout\",\n\n  // Post-claim\n  postClaim: \".coinflip-active-match__post-claim\",\n\n  // Error\n  errorToast: \".coinflip-error-toast\",\n  toastMessage: \".rng-toast__message\",\n\n  // Sidebar — active match info\n  sidebarStatus: \".coinflip-sidebar__status\",\n  sidebarPot: \".coinflip-sidebar__pot\",\n} as const;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type Tier =\n  | \"iron\"\n  | \"bronze\"\n  | \"silver\"\n  | \"gold\"\n  | \"platinum\"\n  | \"diamond\";\n\n// ---------------------------------------------------------------------------\n// Page-object actions\n// ---------------------------------------------------------------------------\n\n/**\n * Navigate to the coinflip page and wait for the lobby to render.\n */\nexport async function navigateToCoinflip(page: Page): Promise<void> {\n  await page.goto(\"/coinflip\", { waitUntil: \"networkidle\" });\n  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 10_000 });\n}\n\n/**\n * Select a tier in the sidebar tier selector.\n */\nexport async function selectTier(page: Page, tier: Tier): Promise<void> {\n  await page.click(sel.tierButton(tier));\n  await expect(page.locator(sel.tierButton(tier))).toHaveClass(/rng-tier-btn--selected/);\n}\n\n/**\n * Select a coin side (heads or tails) in the sidebar.\n */\nexport async function selectSide(page: Page, side: CoinSide): Promise<void> {\n  const selector =\n    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n  await page.click(selector);\n  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n}\n\n/**\n * Create a match: select tier, select side, click \"Create Game\".\n * Returns when the active match view (waiting state) is visible.\n */\nexport async function createMatch(\n  page: Page,\n  tier: Tier,\n  side: CoinSide,\n): Promise<void> {\n  await selectTier(page, tier);\n  await selectSide(page, side);\n\n  // Click create — button text is \"Create Game\"\n  const createBtn = page.locator(sel.actionButton, {\n    hasText: \"Create Game\",\n  });\n  await expect(createBtn).toBeEnabled();\n  await createBtn.click();\n\n  // Wait for transition to active match (waiting for opponent)\n  await page.waitForSelector(sel.activeMatch, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Join a match visible in the lobby. If `matchIndex` is provided, join that\n * specific card (0-based). Otherwise joins the first joinable match.\n */\nexport async function joinMatch(\n  page: Page,\n  matchIndex = 0,\n): Promise<void> {\n  const cards = page.locator(\n    `${sel.matchCard}:not(${sel.matchCardOwn}):not(${sel.matchCardClaimable})`,\n  );\n  const joinBtn = cards.nth(matchIndex).locator(sel.matchCardJoinBtn);\n  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n  await joinBtn.click();\n\n  // Wait for active match view to appear\n  await page.waitForSelector(sel.activeMatch, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Cancel the currently active match (phase = \"created\", waiting for opponent).\n * Clicks \"Cancel Match\" button in the ActiveMatchView.\n */\nexport async function cancelMatch(page: Page): Promise<void> {\n  const cancelBtn = page.locator(\"button\", { hasText: \"Cancel Match\" });\n  await expect(cancelBtn).toBeVisible({ timeout: 5_000 });\n  await cancelBtn.click();\n\n  // Wait for lobby to reappear\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Claim payout for the winner, or settle for the loser.\n * Clicks the \"Claim Payout\" or \"Settle & Return\" button in the sidebar.\n */\nexport async function claimOrSettle(page: Page): Promise<void> {\n  // The claim/settle button is in the sidebar (CoinflipPage renders it there)\n  const claimBtn = page.locator(sel.sidebar).locator(sel.actionButton).first();\n  await expect(claimBtn).toBeEnabled({ timeout: 15_000 });\n  await claimBtn.click();\n\n  // Wait for \"Back to Lobby\" button to confirm claim completed\n  await expect(\n    page.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n}\n\n/**\n * Click \"Back to Lobby\" to return after claiming.\n */\nexport async function backToLobby(page: Page): Promise<void> {\n  const btn = page.locator(\"button\", { hasText: \"Back to Lobby\" });\n  await expect(btn).toBeVisible();\n  await btn.click();\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout: 10_000,\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Wait / assert primitives\n// ---------------------------------------------------------------------------\n\n/**\n * Wait until the sidebar status text matches the expected phase label.\n * Phase labels: \"Waiting...\", \"Ready!\", \"Countdown...\", \"Flipping...\", \"Complete\"\n */\nexport async function waitForPhaseLabel(\n  page: Page,\n  label: string,\n  timeout = 30_000,\n): Promise<void> {\n  await expect(page.locator(sel.sidebarStatus)).toHaveText(label, {\n    timeout,\n  });\n}\n\n/**\n * Wait for the active match title to indicate a win or loss.\n */\nexport async function waitForResult(\n  page: Page,\n  timeout = 30_000,\n): Promise<\"won\" | \"lost\"> {\n  // Wait for either won or lost title class to appear\n  const wonLocator = page.locator(sel.activeMatchTitleWon);\n  const lostLocator = page.locator(sel.activeMatchTitleLost);\n\n  await expect(wonLocator.or(lostLocator)).toBeVisible({ timeout });\n\n  if (await wonLocator.isVisible()) return \"won\";\n  return \"lost\";\n}\n\n/**\n * Wait for a match to appear in the lobby's open match list.\n */\nexport async function waitForLobbyMatch(\n  page: Page,\n  timeout = 15_000,\n): Promise<Locator> {\n  const card = page.locator(\n    `${sel.matchCard}:not(${sel.matchCardClaimable})`,\n  ).first();\n  await expect(card).toBeVisible({ timeout });\n  return card;\n}\n\n/**\n * Assert the lobby is empty (no open matches).\n */\nexport async function assertLobbyEmpty(\n  page: Page,\n  timeout = 10_000,\n): Promise<void> {\n  // Either the empty state text or zero non-claimable match cards\n  await expect(\n    page.locator(`${sel.matchCard}:not(${sel.matchCardClaimable})`),\n  ).toHaveCount(0, { timeout });\n}\n\n/**\n * Assert that an error toast is visible with the given message substring.\n */\nexport async function assertErrorToast(\n  page: Page,\n  messageSubstring: string,\n  timeout = 5_000,\n): Promise<void> {\n  const toast = page.locator(sel.errorToast);\n  await expect(toast).toBeVisible({ timeout });\n  await expect(toast).toContainText(messageSubstring);\n}\n\n/**\n * Assert that no error toasts are visible.\n */\nexport async function assertNoErrorToast(page: Page): Promise<void> {\n  await expect(page.locator(sel.errorToast)).toHaveCount(0);\n}\n\n/**\n * Get the current balance displayed or fetched from connection for a wallet.\n * This is a convenience wrapper for reading SOL balance via RPC, not UI-based.\n */\nexport async function getSolBalance(\n  page: Page,\n  walletAddress: string,\n  rpcUrl = \"http://127.0.0.1:8899\",\n): Promise<number> {\n  return page.evaluate(\n    async ({ address, rpc }) => {\n      const res = await fetch(rpc, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          jsonrpc: \"2.0\",\n          id: 1,\n          method: \"getBalance\",\n          params: [address, { commitment: \"confirmed\" }],\n        }),\n      });\n      const json = await res.json();\n      return (json.result?.value ?? 0) / 1_000_000_000;\n    },\n    { address: walletAddress, rpc: rpcUrl },\n  );\n}\n\n/**\n * Collect console errors from a page. Returns a cleanup function\n * and an array that accumulates errors.\n */\nexport function trackConsoleErrors(page: Page): {\n  errors: string[];\n  assertClean: () => void;\n} {\n  const errors: string[] = [];\n  page.on(\"console\", (msg) => {\n    if (msg.type() === \"error\") errors.push(msg.text());\n  });\n  return {\n    errors,\n    assertClean: () => {\n      // Filter out known non-critical browser noise\n      const real = errors.filter(\n        (e) =>\n          !e.includes(\"favicon.ico\") &&\n          !e.includes(\"downloadable font\") &&\n          !e.includes(\"third-party cookie\"),\n      );\n      expect(real).toEqual([]);\n    },\n  };\n}\n\n/**\n * Wait for a specific text to appear anywhere on the page.\n */\nexport async function waitForText(\n  page: Page,\n  text: string,\n  timeout = 10_000,\n): Promise<void> {\n  await expect(page.getByText(text).first()).toBeVisible({ timeout });\n}\n\n/**\n * Wait for the lobby to be visible (no active match).\n */\nexport async function waitForLobby(\n  page: Page,\n  timeout = 15_000,\n): Promise<void> {\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout,\n  });\n}\n","structuredPatch":[],"originalFile":null}}
