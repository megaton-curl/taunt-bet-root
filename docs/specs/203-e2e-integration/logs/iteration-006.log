{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012R3AeayjkEi4ZygfzNLxcj","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→import {\n     3→  Tier,\n     4→  CoinSide,\n     5→  TIER_AMOUNTS,\n     6→} from \"./types\";\n     7→\n     8→// ============ Program IDs ============\n     9→\n    10→export const COINFLIP_PROGRAM_ID = new PublicKey(\n    11→  \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n    12→);\n    13→\n    14→/** @deprecated Use COINFLIP_PROGRAM_ID instead */\n    15→export const PROGRAM_IDS = {\n    16→  COINFLIP: COINFLIP_PROGRAM_ID,\n    17→};\n    18→\n    19→// ============ PDA Derivation ============\n    20→\n    21→/**\n    22→ * Derive the match PDA for a creator.\n    23→ * Seeds: [\"match\", creator.toBytes()]\n    24→ */\n    25→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    26→  return PublicKey.findProgramAddressSync(\n    27→    [Buffer.from(\"match\"), creator.toBuffer()],\n    28→    COINFLIP_PROGRAM_ID\n    29→  );\n    30→}\n    31→\n    32→/**\n    33→ * Derive the global config PDA.\n    34→ * Seeds: [\"coinflip_config\"]\n    35→ */\n    36→export function getConfigPda(): [PublicKey, number] {\n    37→  return PublicKey.findProgramAddressSync(\n    38→    [Buffer.from(\"coinflip_config\")],\n    39→    COINFLIP_PROGRAM_ID\n    40→  );\n    41→}\n    42→\n    43→// ============ Helper Functions ============\n    44→\n    45→/**\n    46→ * Calculate the entry amount for a tier in lamports\n    47→ */\n    48→export function getEntryAmount(tier: Tier): number {\n    49→  return TIER_AMOUNTS[tier];\n    50→}\n    51→\n    52→/**\n    53→ * Calculate potential payout (winner gets total minus 3% fee)\n    54→ */\n    55→export function calculatePotentialPayout(tier: Tier): number {\n    56→  const entryAmount = TIER_AMOUNTS[tier];\n    57→  const totalPool = entryAmount * 2; // Two players\n    58→  const fee = Math.floor(totalPool * 0.03);\n    59→  return totalPool - fee;\n    60→}\n    61→\n    62→/**\n    63→ * Get the opposite coin side\n    64→ */\n    65→export function getOppositeSide(side: CoinSide): CoinSide {\n    66→  return side === \"heads\" ? \"tails\" : \"heads\";\n    67→}\n    68→\n    69→/**\n    70→ * Determine winner from randomness bytes\n    71→ */\n    72→export function determineWinnerFromRandomness(\n    73→  randomness: Uint8Array,\n    74→  player1Side: CoinSide\n    75→): { result: CoinSide; player1Wins: boolean } {\n    76→  // Match the on-chain logic: first byte % 2\n    77→  const firstByte = randomness[0] ?? 0;\n    78→  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n    79→  const player1Wins = player1Side === result;\n    80→  return { result, player1Wins };\n    81→}\n    82→"}]},"parent_tool_use_id":"toolu_01Jkhu1N3TE3QLubzbzdSuqF","session_id":"5c7393b1-80a9-4d3b-9693-3efb14711fd2","uuid":"f44d313d-ecd2-40f6-b650-339c0f8f1f16"}
