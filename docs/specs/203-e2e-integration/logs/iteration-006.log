{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A5ivHcd4BnR73RcyD7JT1e","type":"tool_result","content":"     1→use anchor_lang::prelude::*;\n     2→use anchor_lang::system_program;\n     3→\n     4→/// Error codes for escrow operations.\n     5→#[error_code]\n     6→pub enum EscrowError {\n     7→    /// The escrow PDA does not hold enough lamports for the requested transfer.\n     8→    #[msg(\"Insufficient escrow balance\")]\n     9→    InsufficientEscrowBalance,\n    10→}\n    11→\n    12→/// Transfers lamports from a PDA to a recipient using direct lamport manipulation.\n    13→///\n    14→/// This is the standard pattern for moving funds out of a program-owned PDA\n    15→/// (e.g., paying out a winner, refunding a player, sending fees to treasury).\n    16→///\n    17→/// # Example\n    18→/// ```ignore\n    19→/// transfer_lamports_from_pda(\n    20→///     &ctx.accounts.coinflip_match.to_account_info(),\n    21→///     &ctx.accounts.winner.to_account_info(),\n    22→///     payout_amount,\n    23→/// )?;\n    24→/// ```\n    25→pub fn transfer_lamports_from_pda(\n    26→    pda: &AccountInfo,\n    27→    recipient: &AccountInfo,\n    28→    amount: u64,\n    29→) -> Result<()> {\n    30→    let pda_balance = pda.lamports();\n    31→    require!(pda_balance >= amount, EscrowError::InsufficientEscrowBalance);\n    32→\n    33→    **pda.try_borrow_mut_lamports()? -= amount;\n    34→    **recipient.try_borrow_mut_lamports()? += amount;\n    35→\n    36→    Ok(())\n    37→}\n    38→\n    39→/// Transfers lamports from a signer to a PDA using system program CPI.\n    40→///\n    41→/// This is the standard pattern for depositing funds into an escrow PDA\n    42→/// (e.g., a player funding a match entry).\n    43→///\n    44→/// # Example\n    45→/// ```ignore\n    46→/// transfer_lamports_to_pda(\n    47→///     &ctx.accounts.creator.to_account_info(),\n    48→///     &ctx.accounts.coinflip_match.to_account_info(),\n    49→///     entry_amount,\n    50→///     &ctx.accounts.system_program.to_account_info(),\n    51→/// )?;\n    52→/// ```\n    53→pub fn transfer_lamports_to_pda<'a>(\n    54→    from: &AccountInfo<'a>,\n    55→    pda: &AccountInfo<'a>,\n    56→    amount: u64,\n    57→    system_program_info: &AccountInfo<'a>,\n    58→) -> Result<()> {\n    59→    system_program::transfer(\n    60→        CpiContext::new(\n    61→            system_program_info.clone(),\n    62→            system_program::Transfer {\n    63→                from: from.clone(),\n    64→                to: pda.clone(),\n    65→            },\n    66→        ),\n    67→        amount,\n    68→    )\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_01X4amqsgwJbtQwdiupE6A2A","session_id":"5c7393b1-80a9-4d3b-9693-3efb14711fd2","uuid":"fba39dfd-7847-418b-9b65-b6dff66c616a"}
