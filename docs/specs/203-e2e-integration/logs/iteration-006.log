0.03);\n    59→  return totalPool - fee;\n    60→}\n    61→\n    62→/**\n    63→ * Get the opposite coin side\n    64→ */\n    65→export function getOppositeSide(side: CoinSide): CoinSide {\n    66→  return side === \"heads\" ? \"tails\" : \"heads\";\n    67→}\n    68→\n    69→/**\n    70→ * Determine winner from randomness bytes\n    71→ */\n    72→export function determineWinnerFromRandomness(\n    73→  randomness: Uint8Array,\n    74→  player1Side: CoinSide\n    75→): { result: CoinSide; player1Wins: boolean } {\n    76→  // Match the on-chain logic: first byte % 2\n    77→  const firstByte = randomness[0] ?? 0;\n    78→  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n    79→  const player1Wins = player1Side === result;\n    80→  return { result, player1Wins };\n    81→}\n    82→"}]},"parent_tool_use_id":null,"session_id":"5c7393b1-80a9-4d3b-9693-3efb14711fd2","uuid":"f66309e7-2339-44b3-b4ab-5a9c1b0a0060","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/game-engine/src/coinflip.ts","content":"import { PublicKey } from \"@solana/web3.js\";\nimport {\n  Tier,\n  CoinSide,\n  TIER_AMOUNTS,\n} from \"./types\";\n\n// ============ Program IDs ============\n\nexport const COINFLIP_PROGRAM_ID = new PublicKey(\n  \"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n);\n\n/** @deprecated Use COINFLIP_PROGRAM_ID instead */\nexport const PROGRAM_IDS = {\n  COINFLIP: COINFLIP_PROGRAM_ID,\n};\n\n// ============ PDA Derivation ============\n\n/**\n * Derive the match PDA for a creator.\n * Seeds: [\"match\", creator.toBytes()]\n */\nexport function getMatchPda(creator: PublicKey): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"match\"), creator.toBuffer()],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n/**\n * Derive the global config PDA.\n * Seeds: [\"coinflip_config\"]\n */\nexport function getConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID\n  );\n}\n\n// ============ Helper Functions ============\n\n/**\n * Calculate the entry amount for a tier in lamports\n */\nexport function getEntryAmount(tier: Tier): number {\n  return TIER_AMOUNTS[tier];\n}\n\n/**\n * Calculate potential payout (winner gets total minus 3% fee)\n */\nexport function calculatePotentialPayout(tier: Tier): number {\n  const entryAmount = TIER_AMOUNTS[tier];\n  const totalPool = entryAmount * 2; // Two players\n  const fee = Math.floor(totalPool * 0.03);\n  return totalPool - fee;\n}\n\n/**\n * Get the opposite coin side\n */\nexport function getOppositeSide(side: CoinSide): CoinSide {\n  return side === \"heads\" ? \"tails\" : \"heads\";\n}\n\n/**\n * Determine winner from randomness bytes\n */\nexport function determineWinnerFromRandomness(\n  randomness: Uint8Array,\n  player1Side: CoinSide\n): { result: CoinSide; player1Wins: boolean } {\n  // Match the on-chain logic: first byte % 2\n  const firstByte = randomness[0] ?? 0;\n  const result: CoinSide = firstByte % 2 === 0 ? \"heads\" : \"tails\";\n  const player1Wins = player1Side === result;\n  return { result, player1Wins };\n}\n","numLines":82,"startLine":1,"totalLines":82}}}
