      \"docs\": [\n   329→              \"Total SOL won (in lamports).\"\n   330→            ],\n   331→            \"type\": \"u64\"\n   332→          },\n   333→          {\n   334→            \"name\": \"bump\",\n   335→            \"docs\": [\n   336→              \"Bump seed for PDA derivation.\"\n   337→            ],\n   338→            \"type\": \"u8\"\n   339→          }\n   340→        ]\n   341→      }\n   342→    }\n   343→  ]\n   344→};\n   345→"}]},"parent_tool_use_id":"toolu_01X4amqsgwJbtQwdiupE6A2A","session_id":"5c7393b1-80a9-4d3b-9693-3efb14711fd2","uuid":"4218f8e5-8673-446a-8c31-ae812497a458"}
