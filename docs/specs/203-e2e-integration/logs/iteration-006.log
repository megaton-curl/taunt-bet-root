ser/src/workspace.d.ts:    [key: string]: Program<Idl>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/browser/src/native/index.d.ts:    static system(provider?: Provider): Program<SystemProgram>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/browser/src/native/system.d.ts:export declare function program(provider?: Provider): Program<SystemProgram>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/browser/src/program/index.d.ts:export declare class Program<IDL extends Idl = Idl> {\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/browser/src/program/index.d.ts:    static at<IDL extends Idl = Idl>(address: Address, provider?: Provider): Promise<Program<IDL>>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/cjs/workspace.d.ts:    [key: string]: Program<Idl>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/cjs/native/index.d.ts:    static system(provider?: Provider): Program<SystemProgram>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/cjs/native/system.d.ts:export declare function program(provider?: Provider): Program<SystemProgram>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/cjs/program/index.d.ts:export declare class Program<IDL extends Idl = Idl> {\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.32.1_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/cjs/program/index.d.ts:    static at<IDL extends Idl = Idl>(address: Address, provider?: Provider): Promise<Program<IDL>>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.29.0_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/esm/workspace.d.ts:    [key: string]: Program<import(\"./idl.js\").Idl>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.29.0_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/esm/native/index.d.ts:    static system(provider?: Provider): Program<SystemProgram>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.29.0_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/esm/native/system.d.ts:export declare function program(provider?: Provider): Program<SystemProgram>;\n/workspaces/rng-utopia/sources/rng-utopia/node_modules/.pnpm/@coral-xyz+anchor@0.29.0_bufferutil@4.1.0_encoding@0.1.13_typescript@5.9.3_utf-8-validate@5.0.10/node_modules/@coral-xyz/anchor/dist/esm/program/index.d.ts:export declare class Program<IDL extends Idl = Idl> {","is_error":false}]},"parent_tool_use_id":"toolu_01Jkhu1N3TE3QLubzbzdSuqF","session_id":"5c7393b1-80a9-4d3b-9693-3efb14711fd2","uuid":"070e73ff-1005-4c27-8b0f-d1d755c93fed"}
