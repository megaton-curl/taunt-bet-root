{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013PSzKv17VEbRiYjPRHKmkh","type":"tool_result","content":"     1→import { ReactNode, lazy, Suspense } from \"react\";\n     2→import { ConnectionProvider } from \"@solana/wallet-adapter-react\";\n     3→import type { ConnectionConfig } from \"@solana/web3.js\";\n     4→import { MockWalletProvider } from \"./mock\";\n     5→\n     6→// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     7→const RealWalletProvider = lazy(() =>\n     8→  import(\"./real/RealWalletProvider\").then((m) => ({\n     9→    default: m.RealWalletProvider,\n    10→  })),\n    11→);\n    12→\n    13→// Re-export WalletContext from the shared context file\n    14→export { WalletContext } from \"./context\";\n    15→\n    16→const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    17→const RPC_MAX_RETRIES = 3;\n    18→const RPC_INITIAL_RETRY_DELAY_MS = 1000;\n    19→\n    20→function getRpcUrl(): string {\n    21→  const envUrl =\n    22→    typeof import.meta !== \"undefined\"\n    23→      ? import.meta.env?.VITE_RPC_URL\n    24→      : undefined;\n    25→  return envUrl || DEFAULT_RPC_URL;\n    26→}\n    27→\n    28→interface WalletProviderProps {\n    29→  children: ReactNode;\n    30→}\n    31→\n    32→function delay(ms: number): Promise<void> {\n    33→  return new Promise((resolve) => setTimeout(resolve, ms));\n    34→}\n    35→\n    36→const baseFetch = globalThis.fetch?.bind(globalThis);\n    37→\n    38→const rpcFetch: typeof fetch = async (input, init) => {\n    39→  if (!baseFetch) {\n    40→    throw new Error(\"Global fetch is not available in this environment.\");\n    41→  }\n    42→\n    43→  let attempt = 0;\n    44→  let retryDelayMs = RPC_INITIAL_RETRY_DELAY_MS;\n    45→  let response = await baseFetch(input, init);\n    46→\n    47→  while (response.status === 429 && attempt < RPC_MAX_RETRIES) {\n    48→    await delay(retryDelayMs);\n    49→    attempt += 1;\n    50→    retryDelayMs *= 2;\n    51→    response = await baseFetch(input, init);\n    52→  }\n    53→\n    54→  return response;\n    55→};\n    56→\n    57→const connectionConfig: ConnectionConfig = {\n    58→  commitment: \"confirmed\",\n    59→  // Disable web3.js internal 429 retries so we can control retry timing.\n    60→  disableRetryOnRateLimit: true,\n    61→  fetch: rpcFetch,\n    62→};\n    63→\n    64→function isMockMode(): boolean {\n    65→  const flag =\n    66→    typeof import.meta !== \"undefined\"\n    67→      ? import.meta.env?.VITE_MOCK_MODE\n    68→      : undefined;\n    69→  // Default to real mode — only mock when explicitly set to \"true\"\n    70→  return flag === \"true\";\n    71→}\n    72→\n    73→/**\n    74→ * Unified WalletProvider.\n    75→ * Wraps both Mock and Real providers with a shared ConnectionProvider.\n    76→ */\n    77→export function WalletProvider({ children }: WalletProviderProps) {\n    78→  const endpoint = getRpcUrl();\n    79→\n    80→  const inner = isMockMode() ? (\n    81→    <MockWalletProvider>{children}</MockWalletProvider>\n    82→  ) : (\n    83→    <Suspense fallback={null}>\n    84→      <RealWalletProvider>{children}</RealWalletProvider>\n    85→    </Suspense>\n    86→  );\n    87→\n    88→  return (\n    89→    <ConnectionProvider endpoint={endpoint} config={connectionConfig}>\n    90→      {inner}\n    91→    </ConnectionProvider>\n    92→  );\n    93→}\n    94→"}]},"parent_tool_use_id":"toolu_01YMw6MqDidTq39wsiBPVT5b","session_id":"f6036e3a-bc98-4f9f-8839-caeed7dcba03","uuid":"1d38c74d-2c5d-4499-a766-7e8c2b0f2a72"}
