{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VegkPnKDposPLsFRtJSxBi","type":"tool_result","content":"     1→/**\n     2→ * Devnet E2E environment contract.\n     3→ *\n     4→ * Validates that all required environment variables are present and well-formed\n     5→ * before any devnet test runs. Fails fast with clear error messages so CI\n     6→ * doesn't waste time on doomed runs.\n     7→ *\n     8→ * Required env vars:\n     9→ *   VITE_RPC_URL             — Devnet RPC endpoint (https URL)\n    10→ *   VITE_COINFLIP_PROGRAM_ID — Deployed coinflip program address (base58)\n    11→ *   VITE_PLATFORM_PROGRAM_ID — Deployed platform program address (base58)\n    12→ *\n    13→ * Optional (with defaults):\n    14→ *   VITE_SOLANA_NETWORK      — Cluster name (default: \"devnet\")\n    15→ */\n    16→\n    17→import { Connection, PublicKey } from \"@solana/web3.js\";\n    18→\n    19→// Orao VRF program ID (hardcoded — same address on all clusters)\n    20→const ORAO_VRF_PROGRAM_ID = new PublicKey(\n    21→  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\",\n    22→);\n    23→\n    24→/** Validated devnet configuration. */\n    25→export interface DevnetConfig {\n    26→  rpcUrl: string;\n    27→  network: string;\n    28→  coinflipProgramId: PublicKey;\n    29→  platformProgramId: PublicKey;\n    30→  oraoVrfProgramId: PublicKey;\n    31→}\n    32→\n    33→/** Validate a base58 public key string. Throws if invalid. */\n    34→function parsePublicKey(value: string, label: string): PublicKey {\n    35→  try {\n    36→    return new PublicKey(value);\n    37→  } catch {\n    38→    throw new Error(\n    39→      `${label} is not a valid Solana address (base58): \"${value}\"`,\n    40→    );\n    41→  }\n    42→}\n    43→\n    44→/** Validate a URL string. Throws if malformed. */\n    45→function parseUrl(value: string, label: string): string {\n    46→  try {\n    47→    const url = new URL(value);\n    48→    if (![\"http:\", \"https:\"].includes(url.protocol)) {\n    49→      throw new Error(\"not http(s)\");\n    50→    }\n    51→    return value;\n    52→  } catch {\n    53→    throw new Error(\n    54→      `${label} is not a valid HTTP(S) URL: \"${value}\"`,\n    55→    );\n    56→  }\n    57→}\n    58→\n    59→/**\n    60→ * Read and validate all required devnet env vars.\n    61→ * Throws with a consolidated error listing every missing/invalid variable.\n    62→ */\n    63→export function validateDevnetEnv(): DevnetConfig {\n    64→  const errors: string[] = [];\n    65→\n    66→  // --- Required ---\n    67→  const rpcUrl = process.env.VITE_RPC_URL;\n    68→  if (!rpcUrl) {\n    69→    errors.push(\"VITE_RPC_URL is required (devnet RPC endpoint)\");\n    70→  }\n    71→\n    72→  const coinflipId = process.env.VITE_COINFLIP_PROGRAM_ID;\n    73→  if (!coinflipId) {\n    74→    errors.push(\n    75→      \"VITE_COINFLIP_PROGRAM_ID is required (deployed coinflip program address)\",\n    76→    );\n    77→  }\n    78→\n    79→  const platformId = process.env.VITE_PLATFORM_PROGRAM_ID;\n    80→  if (!platformId) {\n    81→    errors.push(\n    82→      \"VITE_PLATFORM_PROGRAM_ID is required (deployed platform program address)\",\n    83→    );\n    84→  }\n    85→\n    86→  // Fail fast if any required var is missing\n    87→  if (errors.length > 0) {\n    88→    throw new Error(\n    89→      `Devnet E2E env validation failed:\\n  - ${errors.join(\"\\n  - \")}\\n\\n` +\n    90→        `Hint: copy .env.devnet to .env.local and update program IDs, ` +\n    91→        `or export the variables before running tests.`,\n    92→    );\n    93→  }\n    94→\n    95→  // --- Format validation ---\n    96→  const validatedUrl = parseUrl(rpcUrl!, \"VITE_RPC_URL\");\n    97→  const coinflipProgramId = parsePublicKey(\n    98→    coinflipId!,\n    99→    \"VITE_COINFLIP_PROGRAM_ID\",\n   100→  );\n   101→  const platformProgramId = parsePublicKey(\n   102→    platformId!,\n   103→    \"VITE_PLATFORM_PROGRAM_ID\",\n   104→  );\n   105→\n   106→  // --- Optional with default ---\n   107→  const network = process.env.VITE_SOLANA_NETWORK ?? \"devnet\";\n   108→\n   109→  return {\n   110→    rpcUrl: validatedUrl,\n   111→    network,\n   112→    coinflipProgramId,\n   113→    platformProgramId,\n   114→    oraoVrfProgramId: ORAO_VRF_PROGRAM_ID,\n   115→  };\n   116→}\n   117→\n   118→/**\n   119→ * Verify that the devnet RPC is reachable and that required programs\n   120→ * are deployed. Call this once in globalSetup or the first test's beforeAll.\n   121→ */\n   122→export async function verifyDevnetDeployments(\n   123→  config: DevnetConfig,\n   124→): Promise<void> {\n   125→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n   126→\n   127→  // 1. RPC health check\n   128→  try {\n   129→    await connection.getLatestBlockhash();\n   130→  } catch (err) {\n   131→    throw new Error(\n   132→      `Cannot reach devnet RPC at ${config.rpcUrl}: ${err instanceof Error ? err.message : err}`,\n   133→    );\n   134→  }\n   135→\n   136→  // 2. Coinflip program deployed\n   137→  const coinflipAccount = await connection.getAccountInfo(\n   138→    config.coinflipProgramId,\n   139→  );\n   140→  if (!coinflipAccount || !coinflipAccount.executable) {\n   141→    throw new Error(\n   142→      `Coinflip program not found or not executable at ${config.coinflipProgramId.toBase58()}`,\n   143→    );\n   144→  }\n   145→\n   146→  // 3. Platform program deployed\n   147→  const platformAccount = await connection.getAccountInfo(\n   148→    config.platformProgramId,\n   149→  );\n   150→  if (!platformAccount || !platformAccount.executable) {\n   151→    throw new Error(\n   152→      `Platform program not found or not executable at ${config.platformProgramId.toBase58()}`,\n   153→    );\n   154→  }\n   155→\n   156→  // 4. Orao VRF program deployed\n   157→  const oraoAccount = await connection.getAccountInfo(\n   158→    config.oraoVrfProgramId,\n   159→  );\n   160→  if (!oraoAccount || !oraoAccount.executable) {\n   161→    throw new Error(\n   162→      `Orao VRF program not found or not executable at ${config.oraoVrfProgramId.toBase58()}`,\n   163→    );\n   164→  }\n   165→\n   166→  // 5. Orao VRF network state PDA exists (proves VRF is initialized)\n   167→  const [oraoNetworkState] = PublicKey.findProgramAddressSync(\n   168→    [Buffer.from(\"orao-vrf-network-configuration\")],\n   169→    config.oraoVrfProgramId,\n   170→  );\n   171→  const networkState = await connection.getAccountInfo(oraoNetworkState);\n   172→  if (!networkState) {\n   173→    throw new Error(\n   174→      `Orao VRF network state PDA not found at ${oraoNetworkState.toBase58()} — ` +\n   175→        `VRF provider may not be initialized on this cluster`,\n   176→    );\n   177→  }\n   178→}\n   179→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"9e0ca16a-3f8e-4df9-99ac-bd2e7460e38a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/helpers/env.ts","content":"/**\n * Devnet E2E environment contract.\n *\n * Validates that all required environment variables are present and well-formed\n * before any devnet test runs. Fails fast with clear error messages so CI\n * doesn't waste time on doomed runs.\n *\n * Required env vars:\n *   VITE_RPC_URL             — Devnet RPC endpoint (https URL)\n *   VITE_COINFLIP_PROGRAM_ID — Deployed coinflip program address (base58)\n *   VITE_PLATFORM_PROGRAM_ID — Deployed platform program address (base58)\n *\n * Optional (with defaults):\n *   VITE_SOLANA_NETWORK      — Cluster name (default: \"devnet\")\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\n\n// Orao VRF program ID (hardcoded — same address on all clusters)\nconst ORAO_VRF_PROGRAM_ID = new PublicKey(\n  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\",\n);\n\n/** Validated devnet configuration. */\nexport interface DevnetConfig {\n  rpcUrl: string;\n  network: string;\n  coinflipProgramId: PublicKey;\n  platformProgramId: PublicKey;\n  oraoVrfProgramId: PublicKey;\n}\n\n/** Validate a base58 public key string. Throws if invalid. */\nfunction parsePublicKey(value: string, label: string): PublicKey {\n  try {\n    return new PublicKey(value);\n  } catch {\n    throw new Error(\n      `${label} is not a valid Solana address (base58): \"${value}\"`,\n    );\n  }\n}\n\n/** Validate a URL string. Throws if malformed. */\nfunction parseUrl(value: string, label: string): string {\n  try {\n    const url = new URL(value);\n    if (![\"http:\", \"https:\"].includes(url.protocol)) {\n      throw new Error(\"not http(s)\");\n    }\n    return value;\n  } catch {\n    throw new Error(\n      `${label} is not a valid HTTP(S) URL: \"${value}\"`,\n    );\n  }\n}\n\n/**\n * Read and validate all required devnet env vars.\n * Throws with a consolidated error listing every missing/invalid variable.\n */\nexport function validateDevnetEnv(): DevnetConfig {\n  const errors: string[] = [];\n\n  // --- Required ---\n  const rpcUrl = process.env.VITE_RPC_URL;\n  if (!rpcUrl) {\n    errors.push(\"VITE_RPC_URL is required (devnet RPC endpoint)\");\n  }\n\n  const coinflipId = process.env.VITE_COINFLIP_PROGRAM_ID;\n  if (!coinflipId) {\n    errors.push(\n      \"VITE_COINFLIP_PROGRAM_ID is required (deployed coinflip program address)\",\n    );\n  }\n\n  const platformId = process.env.VITE_PLATFORM_PROGRAM_ID;\n  if (!platformId) {\n    errors.push(\n      \"VITE_PLATFORM_PROGRAM_ID is required (deployed platform program address)\",\n    );\n  }\n\n  // Fail fast if any required var is missing\n  if (errors.length > 0) {\n    throw new Error(\n      `Devnet E2E env validation failed:\\n  - ${errors.join(\"\\n  - \")}\\n\\n` +\n        `Hint: copy .env.devnet to .env.local and update program IDs, ` +\n        `or export the variables before running tests.`,\n    );\n  }\n\n  // --- Format validation ---\n  const validatedUrl = parseUrl(rpcUrl!, \"VITE_RPC_URL\");\n  const coinflipProgramId = parsePublicKey(\n    coinflipId!,\n    \"VITE_COINFLIP_PROGRAM_ID\",\n  );\n  const platformProgramId = parsePublicKey(\n    platformId!,\n    \"VITE_PLATFORM_PROGRAM_ID\",\n  );\n\n  // --- Optional with default ---\n  const network = process.env.VITE_SOLANA_NETWORK ?? \"devnet\";\n\n  return {\n    rpcUrl: validatedUrl,\n    network,\n    coinflipProgramId,\n    platformProgramId,\n    oraoVrfProgramId: ORAO_VRF_PROGRAM_ID,\n  };\n}\n\n/**\n * Verify that the devnet RPC is reachable and that required programs\n * are deployed. Call this once in globalSetup or the first test's beforeAll.\n */\nexport async function verifyDevnetDeployments(\n  config: DevnetConfig,\n): Promise<void> {\n  const connection = new Connection(config.rpcUrl, \"confirmed\");\n\n  // 1. RPC health check\n  try {\n    await connection.getLatestBlockhash();\n  } catch (err) {\n    throw new Error(\n      `Cannot reach devnet RPC at ${config.rpcUrl}: ${err instanceof Error ? err.message : err}`,\n    );\n  }\n\n  // 2. Coinflip program deployed\n  const coinflipAccount = await connection.getAccountInfo(\n    config.coinflipProgramId,\n  );\n  if (!coinflipAccount || !coinflipAccount.executable) {\n    throw new Error(\n      `Coinflip program not found or not executable at ${config.coinflipProgramId.toBase58()}`,\n    );\n  }\n\n  // 3. Platform program deployed\n  const platformAccount = await connection.getAccountInfo(\n    config.platformProgramId,\n  );\n  if (!platformAccount || !platformAccount.executable) {\n    throw new Error(\n      `Platform program not found or not executable at ${config.platformProgramId.toBase58()}`,\n    );\n  }\n\n  // 4. Orao VRF program deployed\n  const oraoAccount = await connection.getAccountInfo(\n    config.oraoVrfProgramId,\n  );\n  if (!oraoAccount || !oraoAccount.executable) {\n    throw new Error(\n      `Orao VRF program not found or not executable at ${config.oraoVrfProgramId.toBase58()}`,\n    );\n  }\n\n  // 5. Orao VRF network state PDA exists (proves VRF is initialized)\n  const [oraoNetworkState] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"orao-vrf-network-configuration\")],\n    config.oraoVrfProgramId,\n  );\n  const networkState = await connection.getAccountInfo(oraoNetworkState);\n  if (!networkState) {\n    throw new Error(\n      `Orao VRF network state PDA not found at ${oraoNetworkState.toBase58()} — ` +\n        `VRF provider may not be initialized on this cluster`,\n    );\n  }\n}\n","numLines":179,"startLine":1,"totalLines":179}}}
