{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013HrWzTQnwxc4ro4Uhyo2aP","type":"tool_result","content":"     1→/**\n     2→ * Local error-flow E2E tests: insufficient balance, join unavailable match,\n     3→ * settle already-claimed match.\n     4→ *\n     5→ * Tests run serially because later tests depend on chain state left by earlier\n     6→ * ones (e.g. additional airdrop in test 2).\n     7→ *\n     8→ * Prerequisites (handled by localnet-bootstrap.sh):\n     9→ * - solana-test-validator running with coinflip + platform programs\n    10→ * - Orao mock accounts pre-loaded (required for lifecycle in test 3)\n    11→ */\n    12→import { Connection } from \"@solana/web3.js\";\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import {\n    16→  fundWallet,\n    17→  PLAYER_A,\n    18→  PLAYER_B,\n    19→  LOCAL_RPC_URL,\n    20→} from \"./helpers/wallets\";\n    21→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    22→import { assertMatchClosed, getMatchPda } from \"./helpers/on-chain\";\n    23→\n    24→// ── Serial execution: skip remaining tests if one fails ───────────────\n    25→\n    26→test.describe(\"Error flow tests\", () => {\n    27→  test.describe.configure({ mode: \"serial\" });\n    28→\n    29→  test.beforeAll(async () => {\n    30→    await initializeLocalnet();\n    31→    const connection = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    32→    // Fund Player A with minimal SOL — insufficient for iron tier (0.005 SOL)\n    33→    await fundWallet(connection, PLAYER_A.publicKey, 0.001);\n    34→    // Fund Player B with standard amount\n    35→    await fundWallet(connection, PLAYER_B.publicKey, 10);\n    36→  });\n    37→\n    38→  // ── Test 1: Insufficient balance ─────────────────────────────────────\n    39→\n    40→  test(\"insufficient balance: creating match shows error toast\", async ({\n    41→    playerAPage,\n    42→    connection,\n    43→  }) => {\n    44→    await po.navigateToCoinflip(playerAPage);\n    45→    await po.selectTier(playerAPage, \"iron\");\n    46→    await po.selectSide(playerAPage, \"heads\");\n    47→\n    48→    // Click \"Create Game\" — balance (0.001 SOL) < iron entry (0.005 SOL)\n    49→    const createBtn = playerAPage.locator(po.sel.actionButton, {\n    50→      hasText: \"Create Game\",\n    51→    });\n    52→    await expect(createBtn).toBeEnabled();\n    53→    await createBtn.click();\n    54→\n    55→    // Error toast should appear with insufficient balance message\n    56→    await po.assertErrorToast(playerAPage, \"Insufficient balance\", 10_000);\n    57→\n    58→    // Verify no match was created on-chain\n    59→    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    60→    await assertMatchClosed(connection, matchPda);\n    61→  });\n    62→\n    63→  // ── Test 2: Join unavailable (cancelled) match ───────────────────────\n    64→\n    65→  test(\"joining unavailable match shows error toast\", async ({\n    66→    playerAPage,\n    67→    playerBPage,\n    68→    connection,\n    69→  }) => {\n    70→    // Fund A properly for this test (previous test left A with 0.001 SOL)\n    71→    await fundWallet(connection, PLAYER_A.publicKey, 10);\n    72→\n    73→    // A creates a match (iron tier, heads)\n    74→    await po.navigateToCoinflip(playerAPage);\n    75→    await po.createMatch(playerAPage, \"iron\", \"heads\");\n    76→\n    77→    // B navigates and sees the match in lobby\n    78→    await po.navigateToCoinflip(playerBPage);\n    79→    await po.waitForLobbyMatch(playerBPage, 15_000);\n    80→\n    81→    // A cancels the match — PDA closes on-chain\n    82→    await po.cancelMatch(playerAPage);\n    83→    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    84→    await assertMatchClosed(connection, matchPda);\n    85→\n    86→    // B tries to join the stale lobby card (lobby hasn't re-polled yet)\n    87→    const joinBtn = playerBPage\n    88→      .locator(\n    89→        `${po.sel.matchCard}:not(${po.sel.matchCardOwn}):not(${po.sel.matchCardClaimable})`,\n    90→      )\n    91→      .first()\n    92→      .locator(po.sel.matchCardJoinBtn);\n    93→    await joinBtn.click();\n    94→\n    95→    // Error toast should appear on B's page\n    96→    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n    97→      timeout: 10_000,\n    98→    });\n    99→  });\n   100→\n   101→  // ── Test 3: Settle already-claimed match ─────────────────────────────\n   102→\n   103→  test(\"settling already-claimed match shows error toast\", async ({\n   104→    playerAPage,\n   105→    playerBPage,\n   106→    connection,\n   107→  }) => {\n   108→    // A creates a match (iron tier, heads)\n   109→    await po.navigateToCoinflip(playerAPage);\n   110→    await po.createMatch(playerAPage, \"iron\", \"heads\");\n   111→\n   112→    // B navigates and joins\n   113→    await po.navigateToCoinflip(playerBPage);\n   114→    await po.waitForLobbyMatch(playerBPage, 15_000);\n   115→    await po.joinMatch(playerBPage);\n   116→\n   117→    // Both wait for VRF resolution (pre-loaded: HEADS → A wins)\n   118→    const [resultA, resultB] = await Promise.all([\n   119→      po.waitForResult(playerAPage, 30_000),\n   120→      po.waitForResult(playerBPage, 30_000),\n   121→    ]);\n   122→    expect(resultA).toBe(\"won\");\n   123→    expect(resultB).toBe(\"lost\");\n   124→\n   125→    // A (winner) claims payout — match PDA closes\n   126→    await po.claimOrSettle(playerAPage);\n   127→    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n   128→    await assertMatchClosed(connection, matchPda);\n   129→\n   130→    // B still sees \"Settle & Return\" because B's context hasn't refreshed.\n   131→    // B tries to settle — fails because match PDA is already closed.\n   132→    const settleBtn = playerBPage\n   133→      .locator(po.sel.sidebar)\n   134→      .locator(po.sel.actionButton)\n   135→      .first();\n   136→    await expect(settleBtn).toBeVisible({ timeout: 5_000 });\n   137→    await settleBtn.click();\n   138→\n   139→    // Error toast should appear on B's page\n   140→    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n   141→      timeout: 10_000,\n   142→    });\n   143→  });\n   144→});\n   145→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"b2b69d27-c755-409e-84a9-947fbe3d1b76","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/01-error-flow.spec.ts","content":"/**\n * Local error-flow E2E tests: insufficient balance, join unavailable match,\n * settle already-claimed match.\n *\n * Tests run serially because later tests depend on chain state left by earlier\n * ones (e.g. additional airdrop in test 2).\n *\n * Prerequisites (handled by localnet-bootstrap.sh):\n * - solana-test-validator running with coinflip + platform programs\n * - Orao mock accounts pre-loaded (required for lifecycle in test 3)\n */\nimport { Connection } from \"@solana/web3.js\";\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport {\n  fundWallet,\n  PLAYER_A,\n  PLAYER_B,\n  LOCAL_RPC_URL,\n} from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\nimport { assertMatchClosed, getMatchPda } from \"./helpers/on-chain\";\n\n// ── Serial execution: skip remaining tests if one fails ───────────────\n\ntest.describe(\"Error flow tests\", () => {\n  test.describe.configure({ mode: \"serial\" });\n\n  test.beforeAll(async () => {\n    await initializeLocalnet();\n    const connection = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    // Fund Player A with minimal SOL — insufficient for iron tier (0.005 SOL)\n    await fundWallet(connection, PLAYER_A.publicKey, 0.001);\n    // Fund Player B with standard amount\n    await fundWallet(connection, PLAYER_B.publicKey, 10);\n  });\n\n  // ── Test 1: Insufficient balance ─────────────────────────────────────\n\n  test(\"insufficient balance: creating match shows error toast\", async ({\n    playerAPage,\n    connection,\n  }) => {\n    await po.navigateToCoinflip(playerAPage);\n    await po.selectTier(playerAPage, \"iron\");\n    await po.selectSide(playerAPage, \"heads\");\n\n    // Click \"Create Game\" — balance (0.001 SOL) < iron entry (0.005 SOL)\n    const createBtn = playerAPage.locator(po.sel.actionButton, {\n      hasText: \"Create Game\",\n    });\n    await expect(createBtn).toBeEnabled();\n    await createBtn.click();\n\n    // Error toast should appear with insufficient balance message\n    await po.assertErrorToast(playerAPage, \"Insufficient balance\", 10_000);\n\n    // Verify no match was created on-chain\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n  });\n\n  // ── Test 2: Join unavailable (cancelled) match ───────────────────────\n\n  test(\"joining unavailable match shows error toast\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n  }) => {\n    // Fund A properly for this test (previous test left A with 0.001 SOL)\n    await fundWallet(connection, PLAYER_A.publicKey, 10);\n\n    // A creates a match (iron tier, heads)\n    await po.navigateToCoinflip(playerAPage);\n    await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n    // B navigates and sees the match in lobby\n    await po.navigateToCoinflip(playerBPage);\n    await po.waitForLobbyMatch(playerBPage, 15_000);\n\n    // A cancels the match — PDA closes on-chain\n    await po.cancelMatch(playerAPage);\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n\n    // B tries to join the stale lobby card (lobby hasn't re-polled yet)\n    const joinBtn = playerBPage\n      .locator(\n        `${po.sel.matchCard}:not(${po.sel.matchCardOwn}):not(${po.sel.matchCardClaimable})`,\n      )\n      .first()\n      .locator(po.sel.matchCardJoinBtn);\n    await joinBtn.click();\n\n    // Error toast should appear on B's page\n    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n      timeout: 10_000,\n    });\n  });\n\n  // ── Test 3: Settle already-claimed match ─────────────────────────────\n\n  test(\"settling already-claimed match shows error toast\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n  }) => {\n    // A creates a match (iron tier, heads)\n    await po.navigateToCoinflip(playerAPage);\n    await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n    // B navigates and joins\n    await po.navigateToCoinflip(playerBPage);\n    await po.waitForLobbyMatch(playerBPage, 15_000);\n    await po.joinMatch(playerBPage);\n\n    // Both wait for VRF resolution (pre-loaded: HEADS → A wins)\n    const [resultA, resultB] = await Promise.all([\n      po.waitForResult(playerAPage, 30_000),\n      po.waitForResult(playerBPage, 30_000),\n    ]);\n    expect(resultA).toBe(\"won\");\n    expect(resultB).toBe(\"lost\");\n\n    // A (winner) claims payout — match PDA closes\n    await po.claimOrSettle(playerAPage);\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n\n    // B still sees \"Settle & Return\" because B's context hasn't refreshed.\n    // B tries to settle — fails because match PDA is already closed.\n    const settleBtn = playerBPage\n      .locator(po.sel.sidebar)\n      .locator(po.sel.actionButton)\n      .first();\n    await expect(settleBtn).toBeVisible({ timeout: 5_000 });\n    await settleBtn.click();\n\n    // Error toast should appear on B's page\n    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n      timeout: 10_000,\n    });\n  });\n});\n","numLines":145,"startLine":1,"totalLines":145}}}
