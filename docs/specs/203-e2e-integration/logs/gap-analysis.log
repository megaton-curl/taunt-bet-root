{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UjR1oFFxmTeB3XdcmyVGTz","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# localnet-bootstrap.sh — Start a fresh solana-test-validator with coinflip + platform programs.\n     3→# Usage: ./scripts/localnet-bootstrap.sh\n     4→# Writes validator PID to .localnet.pid for teardown.\n     5→set -euo pipefail\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     8→PLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     9→SOLANA_DIR=\"$(cd \"$PLATFORM_DIR/../../solana\" && pwd)\"\n    10→\n    11→COINFLIP_SO=\"$SOLANA_DIR/target/deploy/coinflip.so\"\n    12→PLATFORM_SO=\"$SOLANA_DIR/target/deploy/platform.so\"\n    13→COINFLIP_KEYPAIR=\"$SOLANA_DIR/target/deploy/coinflip-keypair.json\"\n    14→PLATFORM_KEYPAIR=\"$SOLANA_DIR/target/deploy/platform-keypair.json\"\n    15→\n    16→COINFLIP_ID=\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n    17→PLATFORM_ID=\"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n    18→\n    19→# Mock Orao VRF accounts (pre-loaded for deterministic local E2E tests)\n    20→ACCOUNTS_DIR=\"$SCRIPT_DIR/localnet-accounts\"\n    21→\n    22→RPC_URL=\"http://127.0.0.1:8899\"\n    23→PID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\n    24→LEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\n    25→LOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n    26→\n    27→MAX_WAIT=30  # seconds to wait for RPC readiness\n    28→\n    29→# ── Preflight checks ─────────────────────────────────────────────────\n    30→for f in \"$COINFLIP_SO\" \"$PLATFORM_SO\" \"$COINFLIP_KEYPAIR\" \"$PLATFORM_KEYPAIR\"; do\n    31→  if [[ ! -f \"$f\" ]]; then\n    32→    echo \"ERROR: Missing $f — run 'anchor build' first.\" >&2\n    33→    exit 1\n    34→  fi\n    35→done\n    36→\n    37→if ! command -v solana-test-validator &>/dev/null; then\n    38→  echo \"ERROR: solana-test-validator not found on PATH.\" >&2\n    39→  exit 1\n    40→fi\n    41→\n    42→# Solana 3.x requires io_uring; Docker blocks it unless --security-opt=seccomp=unconfined.\n    43→# We skip the preflight syscall probe (unreliable in containers) and let the validator\n    44→# fail naturally with a clear error if io_uring is truly unavailable.\n    45→\n    46→# ── Kill any existing validator ───────────────────────────────────────\n    47→if [[ -f \"$PID_FILE\" ]]; then\n    48→  OLD_PID=$(cat \"$PID_FILE\")\n    49→  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    50→    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    51→    kill \"$OLD_PID\" 2>/dev/null || true\n    52→    sleep 1\n    53→    kill -9 \"$OLD_PID\" 2>/dev/null || true\n    54→  fi\n    55→  rm -f \"$PID_FILE\"\n    56→fi\n    57→\n    58→# Also kill any stray validator on the same port\n    59→if lsof -ti :8899 &>/dev/null; then\n    60→  echo \"Killing process on port 8899...\"\n    61→  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n    62→  sleep 1\n    63→fi\n    64→\n    65→# ── Clean ledger for fresh state ──────────────────────────────────────\n    66→rm -rf \"$LEDGER_DIR\"\n    67→\n    68→# ── Start validator with programs preloaded at genesis ────────────────\n    69→echo \"Starting solana-test-validator...\"\n    70→solana-test-validator \\\n    71→  --ledger \"$LEDGER_DIR\" \\\n    72→  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n    73→  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n    74→  --account 5ER1oENnV4srxYdAynUfRzWeQCPQaqMiAp4VqyMbSqnK \"$ACCOUNTS_DIR/orao-network-state.json\" \\\n    75→  --account S4ne8ejGPUwNMNsE8L7gtjbTaBLBfVGdWNH6VQrL58a \"$ACCOUNTS_DIR/orao-random-player-a.json\" \\\n    76→  --account Ecs89dz8NsNoSxyUtp54G2HPbmvJr8qZnxnWUqiLT92r \"$ACCOUNTS_DIR/orao-treasury.json\" \\\n    77→  --reset \\\n    78→  --quiet \\\n    79→  > \"$LOG_FILE\" 2>&1 &\n    80→\n    81→VALIDATOR_PID=$!\n    82→echo \"$VALIDATOR_PID\" > \"$PID_FILE\"\n    83→echo \"Validator PID: $VALIDATOR_PID\"\n    84→\n    85→# ── Wait for RPC readiness ────────────────────────────────────────────\n    86→echo -n \"Waiting for RPC at $RPC_URL\"\n    87→ELAPSED=0\n    88→while (( ELAPSED < MAX_WAIT )); do\n    89→  if curl -s \"$RPC_URL\" \\\n    90→    -X POST \\\n    91→    -H \"Content-Type: application/json\" \\\n    92→    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    93→    | grep -q '\"result\"'; then\n    94→    echo \" ready (${ELAPSED}s)\"\n    95→    echo \"Localnet bootstrap complete.\"\n    96→    exit 0\n    97→  fi\n    98→\n    99→  # Check validator is still running\n   100→  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n   101→    echo \"\"\n   102→    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n   103→    tail -20 \"$LOG_FILE\" >&2\n   104→    rm -f \"$PID_FILE\"\n   105→    exit 1\n   106→  fi\n   107→\n   108→  sleep 1\n   109→  ELAPSED=$(( ELAPSED + 1 ))\n   110→  echo -n \".\"\n   111→done\n   112→\n   113→echo \"\"\n   114→echo \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\n   115→tail -20 \"$LOG_FILE\" >&2\n   116→kill \"$VALIDATOR_PID\" 2>/dev/null || true\n   117→rm -f \"$PID_FILE\"\n   118→exit 1\n   119→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"6b4a3a05-0512-46c6-8a10-1460d64d8842","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/scripts/localnet-bootstrap.sh","content":"#!/usr/bin/env bash\n# localnet-bootstrap.sh — Start a fresh solana-test-validator with coinflip + platform programs.\n# Usage: ./scripts/localnet-bootstrap.sh\n# Writes validator PID to .localnet.pid for teardown.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nPLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\nSOLANA_DIR=\"$(cd \"$PLATFORM_DIR/../../solana\" && pwd)\"\n\nCOINFLIP_SO=\"$SOLANA_DIR/target/deploy/coinflip.so\"\nPLATFORM_SO=\"$SOLANA_DIR/target/deploy/platform.so\"\nCOINFLIP_KEYPAIR=\"$SOLANA_DIR/target/deploy/coinflip-keypair.json\"\nPLATFORM_KEYPAIR=\"$SOLANA_DIR/target/deploy/platform-keypair.json\"\n\nCOINFLIP_ID=\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\nPLATFORM_ID=\"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n\n# Mock Orao VRF accounts (pre-loaded for deterministic local E2E tests)\nACCOUNTS_DIR=\"$SCRIPT_DIR/localnet-accounts\"\n\nRPC_URL=\"http://127.0.0.1:8899\"\nPID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\nLEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\nLOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n\nMAX_WAIT=30  # seconds to wait for RPC readiness\n\n# ── Preflight checks ─────────────────────────────────────────────────\nfor f in \"$COINFLIP_SO\" \"$PLATFORM_SO\" \"$COINFLIP_KEYPAIR\" \"$PLATFORM_KEYPAIR\"; do\n  if [[ ! -f \"$f\" ]]; then\n    echo \"ERROR: Missing $f — run 'anchor build' first.\" >&2\n    exit 1\n  fi\ndone\n\nif ! command -v solana-test-validator &>/dev/null; then\n  echo \"ERROR: solana-test-validator not found on PATH.\" >&2\n  exit 1\nfi\n\n# Solana 3.x requires io_uring; Docker blocks it unless --security-opt=seccomp=unconfined.\n# We skip the preflight syscall probe (unreliable in containers) and let the validator\n# fail naturally with a clear error if io_uring is truly unavailable.\n\n# ── Kill any existing validator ───────────────────────────────────────\nif [[ -f \"$PID_FILE\" ]]; then\n  OLD_PID=$(cat \"$PID_FILE\")\n  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    kill \"$OLD_PID\" 2>/dev/null || true\n    sleep 1\n    kill -9 \"$OLD_PID\" 2>/dev/null || true\n  fi\n  rm -f \"$PID_FILE\"\nfi\n\n# Also kill any stray validator on the same port\nif lsof -ti :8899 &>/dev/null; then\n  echo \"Killing process on port 8899...\"\n  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n  sleep 1\nfi\n\n# ── Clean ledger for fresh state ──────────────────────────────────────\nrm -rf \"$LEDGER_DIR\"\n\n# ── Start validator with programs preloaded at genesis ────────────────\necho \"Starting solana-test-validator...\"\nsolana-test-validator \\\n  --ledger \"$LEDGER_DIR\" \\\n  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n  --account 5ER1oENnV4srxYdAynUfRzWeQCPQaqMiAp4VqyMbSqnK \"$ACCOUNTS_DIR/orao-network-state.json\" \\\n  --account S4ne8ejGPUwNMNsE8L7gtjbTaBLBfVGdWNH6VQrL58a \"$ACCOUNTS_DIR/orao-random-player-a.json\" \\\n  --account Ecs89dz8NsNoSxyUtp54G2HPbmvJr8qZnxnWUqiLT92r \"$ACCOUNTS_DIR/orao-treasury.json\" \\\n  --reset \\\n  --quiet \\\n  > \"$LOG_FILE\" 2>&1 &\n\nVALIDATOR_PID=$!\necho \"$VALIDATOR_PID\" > \"$PID_FILE\"\necho \"Validator PID: $VALIDATOR_PID\"\n\n# ── Wait for RPC readiness ────────────────────────────────────────────\necho -n \"Waiting for RPC at $RPC_URL\"\nELAPSED=0\nwhile (( ELAPSED < MAX_WAIT )); do\n  if curl -s \"$RPC_URL\" \\\n    -X POST \\\n    -H \"Content-Type: application/json\" \\\n    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    | grep -q '\"result\"'; then\n    echo \" ready (${ELAPSED}s)\"\n    echo \"Localnet bootstrap complete.\"\n    exit 0\n  fi\n\n  # Check validator is still running\n  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n    echo \"\"\n    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n    tail -20 \"$LOG_FILE\" >&2\n    rm -f \"$PID_FILE\"\n    exit 1\n  fi\n\n  sleep 1\n  ELAPSED=$(( ELAPSED + 1 ))\n  echo -n \".\"\ndone\n\necho \"\"\necho \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\ntail -20 \"$LOG_FILE\" >&2\nkill \"$VALIDATOR_PID\" 2>/dev/null || true\nrm -f \"$PID_FILE\"\nexit 1\n","numLines":119,"startLine":1,"totalLines":119}}}
