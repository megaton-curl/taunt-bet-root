{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HGXemrkmFZuqxUF3uMQaRw","type":"tool_result","content":"     1→/**\n     2→ * Local cancel-flow E2E test: create → cancel → refund → lobby clears → recreate.\n     3→ *\n     4→ * Uses a single browser context (Player A) with a deterministic keypair.\n     5→ * Verifies that cancellation refunds the creator, clears the lobby, and\n     6→ * allows immediate re-creation of a new match.\n     7→ *\n     8→ * Prerequisites (handled by localnet-bootstrap.sh):\n     9→ * - solana-test-validator running with coinflip + platform programs\n    10→ */\n    11→import { test, expect } from \"./fixtures\";\n    12→import * as po from \"./helpers/page-objects\";\n    13→import { fundTestWallets, PLAYER_A } from \"./helpers/wallets\";\n    14→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    15→import {\n    16→  assertMatchCreated,\n    17→  assertMatchClosed,\n    18→  getBalanceLamports,\n    19→} from \"./helpers/on-chain\";\n    20→\n    21→// ── Suite setup ────────────────────────────────────────────────────────\n    22→\n    23→test.beforeAll(async () => {\n    24→  await fundTestWallets();\n    25→  await initializeLocalnet();\n    26→});\n    27→\n    28→// ── Cancel flow test ───────────────────────────────────────────────────\n    29→\n    30→test(\"coinflip cancel flow: create → cancel → refund → lobby clears → recreate\", async ({\n    31→  playerAPage,\n    32→  connection,\n    33→}) => {\n    34→  const consoleA = po.trackConsoleErrors(playerAPage);\n    35→\n    36→  // Navigate to coinflip\n    37→  await po.navigateToCoinflip(playerAPage);\n    38→\n    39→  // Snapshot balance before creating match\n    40→  const balanceBefore = await getBalanceLamports(\n    41→    connection,\n    42→    PLAYER_A.publicKey,\n    43→  );\n    44→\n    45→  // 1. Create a match (iron tier, heads)\n    46→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n    47→\n    48→  // Verify active match is in waiting state\n    49→  await expect(\n    50→    playerAPage.locator(po.sel.activeMatchWaiting),\n    51→  ).toBeVisible({ timeout: 10_000 });\n    52→\n    53→  // On-chain: verify match PDA exists in waiting phase\n    54→  const { matchPda } = await assertMatchCreated(\n    55→    connection,\n    56→    PLAYER_A.publicKey,\n    57→    0, // iron tier\n    58→    0, // heads\n    59→  );\n    60→\n    61→  // Balance after create should be lower (entry + rent + tx fee)\n    62→  const balanceAfterCreate = await getBalanceLamports(\n    63→    connection,\n    64→    PLAYER_A.publicKey,\n    65→  );\n    66→  expect(balanceAfterCreate).toBeLessThan(balanceBefore);\n    67→\n    68→  // 2. Cancel the match\n    69→  await po.cancelMatch(playerAPage);\n    70→\n    71→  // 3. Verify lobby is visible again and the match is gone\n    72→  await po.waitForLobby(playerAPage);\n    73→  await po.assertLobbyEmpty(playerAPage);\n    74→\n    75→  // On-chain: verify match PDA is closed\n    76→  await assertMatchClosed(connection, matchPda);\n    77→\n    78→  // 4. Verify refund: balance after cancel should recover (entry + rent returned)\n    79→  const balanceAfterCancel = await getBalanceLamports(\n    80→    connection,\n    81→    PLAYER_A.publicKey,\n    82→  );\n    83→  // Balance should be higher than after create (got refund)\n    84→  expect(balanceAfterCancel).toBeGreaterThan(balanceAfterCreate);\n    85→  // Net cost should be minimal — just transaction fees for create + cancel\n    86→  // (typically ~10k lamports each, well under 0.01 SOL = 10M lamports)\n    87→  const netCost = balanceBefore - balanceAfterCancel;\n    88→  expect(netCost).toBeLessThan(10_000_000);\n    89→\n    90→  // 5. Recreate: creator can immediately create a new match after cancellation\n    91→  await po.createMatch(playerAPage, \"iron\", \"tails\");\n    92→  await expect(\n    93→    playerAPage.locator(po.sel.activeMatchWaiting),\n    94→  ).toBeVisible({ timeout: 10_000 });\n    95→\n    96→  // On-chain: verify new match PDA exists (same PDA address, new side)\n    97→  await assertMatchCreated(\n    98→    connection,\n    99→    PLAYER_A.publicKey,\n   100→    0, // iron tier\n   101→    1, // tails (different from first match)\n   102→  );\n   103→\n   104→  // Clean up: cancel the second match to leave a clean state\n   105→  await po.cancelMatch(playerAPage);\n   106→  await po.waitForLobby(playerAPage);\n   107→\n   108→  // No unhandled console errors\n   109→  consoleA.assertClean();\n   110→});\n   111→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"1326d053-f40b-4ebf-a977-b5866d89d82e","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/02-cancel-flow.spec.ts","content":"/**\n * Local cancel-flow E2E test: create → cancel → refund → lobby clears → recreate.\n *\n * Uses a single browser context (Player A) with a deterministic keypair.\n * Verifies that cancellation refunds the creator, clears the lobby, and\n * allows immediate re-creation of a new match.\n *\n * Prerequisites (handled by localnet-bootstrap.sh):\n * - solana-test-validator running with coinflip + platform programs\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport { fundTestWallets, PLAYER_A } from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\nimport {\n  assertMatchCreated,\n  assertMatchClosed,\n  getBalanceLamports,\n} from \"./helpers/on-chain\";\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  await fundTestWallets();\n  await initializeLocalnet();\n});\n\n// ── Cancel flow test ───────────────────────────────────────────────────\n\ntest(\"coinflip cancel flow: create → cancel → refund → lobby clears → recreate\", async ({\n  playerAPage,\n  connection,\n}) => {\n  const consoleA = po.trackConsoleErrors(playerAPage);\n\n  // Navigate to coinflip\n  await po.navigateToCoinflip(playerAPage);\n\n  // Snapshot balance before creating match\n  const balanceBefore = await getBalanceLamports(\n    connection,\n    PLAYER_A.publicKey,\n  );\n\n  // 1. Create a match (iron tier, heads)\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Verify active match is in waiting state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 10_000 });\n\n  // On-chain: verify match PDA exists in waiting phase\n  const { matchPda } = await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    0, // iron tier\n    0, // heads\n  );\n\n  // Balance after create should be lower (entry + rent + tx fee)\n  const balanceAfterCreate = await getBalanceLamports(\n    connection,\n    PLAYER_A.publicKey,\n  );\n  expect(balanceAfterCreate).toBeLessThan(balanceBefore);\n\n  // 2. Cancel the match\n  await po.cancelMatch(playerAPage);\n\n  // 3. Verify lobby is visible again and the match is gone\n  await po.waitForLobby(playerAPage);\n  await po.assertLobbyEmpty(playerAPage);\n\n  // On-chain: verify match PDA is closed\n  await assertMatchClosed(connection, matchPda);\n\n  // 4. Verify refund: balance after cancel should recover (entry + rent returned)\n  const balanceAfterCancel = await getBalanceLamports(\n    connection,\n    PLAYER_A.publicKey,\n  );\n  // Balance should be higher than after create (got refund)\n  expect(balanceAfterCancel).toBeGreaterThan(balanceAfterCreate);\n  // Net cost should be minimal — just transaction fees for create + cancel\n  // (typically ~10k lamports each, well under 0.01 SOL = 10M lamports)\n  const netCost = balanceBefore - balanceAfterCancel;\n  expect(netCost).toBeLessThan(10_000_000);\n\n  // 5. Recreate: creator can immediately create a new match after cancellation\n  await po.createMatch(playerAPage, \"iron\", \"tails\");\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 10_000 });\n\n  // On-chain: verify new match PDA exists (same PDA address, new side)\n  await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    0, // iron tier\n    1, // tails (different from first match)\n  );\n\n  // Clean up: cancel the second match to leave a clean state\n  await po.cancelMatch(playerAPage);\n  await po.waitForLobby(playerAPage);\n\n  // No unhandled console errors\n  consoleA.assertClean();\n});\n","numLines":111,"startLine":1,"totalLines":111}}}
