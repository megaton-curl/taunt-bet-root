{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NM7VAvi6y3jneWSk6EariL","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# run-e2e-local.sh — Single-entrypoint for local E2E tests.\n     3→# Runs: bootstrap → Playwright tests → teardown (always).\n     4→set -euo pipefail\n     5→\n     6→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n     7→APP_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     8→\n     9→# --- Bootstrap ---\n    10→echo \"==> Starting localnet validator…\"\n    11→if ! bash \"$SCRIPT_DIR/localnet-bootstrap.sh\"; then\n    12→  echo \"❌ Localnet bootstrap failed\"\n    13→  bash \"$SCRIPT_DIR/localnet-teardown.sh\" 2>/dev/null || true\n    14→  exit 1\n    15→fi\n    16→\n    17→# --- Run tests (capture exit code, always teardown after) ---\n    18→echo \"==> Running local E2E tests…\"\n    19→TEST_EXIT=0\n    20→(cd \"$APP_DIR\" && npx playwright test --config playwright.local.config.ts) || TEST_EXIT=$?\n    21→\n    22→# --- Teardown (always) ---\n    23→echo \"==> Stopping localnet validator…\"\n    24→bash \"$SCRIPT_DIR/localnet-teardown.sh\" || true\n    25→\n    26→# --- Report ---\n    27→if [ \"$TEST_EXIT\" -eq 0 ]; then\n    28→  echo \"✅ Local E2E tests passed\"\n    29→else\n    30→  echo \"❌ Local E2E tests failed (exit $TEST_EXIT)\"\n    31→fi\n    32→\n    33→exit \"$TEST_EXIT\"\n    34→"}]},"parent_tool_use_id":"toolu_013hbUywL2VQwbXJVCG3Uf9s","session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"c5ea18cd-c7af-4be9-8a95-ca80b5bb675f"}
