{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vq7CaeaEsvaQgA3T57gEWK","type":"tool_result","content":"     1→/**\n     2→ * Local lifecycle E2E test: create → join → resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. The local validator has mock-VRF enabled,\n     6→ * and the randomness account is pre-loaded with fulfilled data\n     7→ * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n     8→ *\n     9→ * Prerequisites (handled by localnet-bootstrap.sh):\n    10→ * - solana-test-validator running with coinflip + platform programs\n    11→ * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n    12→ */\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import { fundTestWallets, PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    16→import { initializeLocalnet, ensurePlayerProfiles } from \"./helpers/localnet-setup\";\n    17→import {\n    18→  assertMatchCreated,\n    19→  assertMatchClosed,\n    20→  assertTreasuryFee,\n    21→  assertPlayerProfileDelta,\n    22→  snapshotBalance,\n    23→  snapshotPlayerProfile,\n    24→  getTreasuryAddress,\n    25→  calculateExpectedFee,\n    26→} from \"./helpers/on-chain\";\n    27→\n    28→// ── Suite setup ────────────────────────────────────────────────────────\n    29→\n    30→test.beforeAll(async () => {\n    31→  // Fund test wallets, initialize program configs, and create player profiles\n    32→  await fundTestWallets();\n    33→  await initializeLocalnet();\n    34→  await ensurePlayerProfiles();\n    35→});\n    36→\n    37→// ── Full lifecycle test ────────────────────────────────────────────────\n    38→\n    39→test(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n    40→  playerAPage,\n    41→  playerBPage,\n    42→  connection,\n    43→}) => {\n    44→  // On-chain constants for iron tier\n    45→  const TIER_IRON = 0;\n    46→  const SIDE_HEADS = 0;\n    47→  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n    48→\n    49→  // Track console errors in both contexts\n    50→  const consoleA = po.trackConsoleErrors(playerAPage);\n    51→  const consoleB = po.trackConsoleErrors(playerBPage);\n    52→\n    53→  // 1. Player A navigates and creates a match (iron tier, heads)\n    54→  await po.navigateToCoinflip(playerAPage);\n    55→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n    56→\n    57→  // Player A should see the active match in \"waiting\" state\n    58→  await expect(\n    59→    playerAPage.locator(po.sel.activeMatchWaiting),\n    60→  ).toBeVisible({ timeout: 10_000 });\n    61→\n    62→  // ── On-chain: verify match PDA after creation ──\n    63→  const { matchPda } = await assertMatchCreated(\n    64→    connection,\n    65→    PLAYER_A.publicKey,\n    66→    TIER_IRON,\n    67→    SIDE_HEADS,\n    68→  );\n    69→\n    70→  // 2. Player B navigates (after match is created) and sees it in the lobby\n    71→  await po.navigateToCoinflip(playerBPage);\n    72→  await po.waitForLobbyMatch(playerBPage, 15_000);\n    73→\n    74→  // 3. Player B joins the match\n    75→  await po.joinMatch(playerBPage);\n    76→\n    77→  // ── On-chain: snapshot treasury + profiles before resolution/claim ──\n    78→  const treasury = await getTreasuryAddress(connection);\n    79→  const treasuryBefore = await snapshotBalance(connection, treasury);\n    80→  const profileABefore = await snapshotPlayerProfile(connection, PLAYER_A.publicKey);\n    81→  const profileBBefore = await snapshotPlayerProfile(connection, PLAYER_B.publicKey);\n    82→\n    83→  // 4. Both players wait for the result.\n    84→  //    VRF is pre-fulfilled (HEADS) → creator (Player A) wins.\n    85→  //    The frontend polls every 5s for VRF fulfillment, then shows\n    86→  //    a 3s flip animation before the \"complete\" phase.\n    87→  const [resultA, resultB] = await Promise.all([\n    88→    po.waitForResult(playerAPage, 30_000),\n    89→    po.waitForResult(playerBPage, 30_000),\n    90→  ]);\n    91→\n    92→  // 5. Verify results: Player A (creator, chose HEADS) should win\n    93→  expect(resultA).toBe(\"won\");\n    94→  expect(resultB).toBe(\"lost\");\n    95→\n    96→  // 6. Player A (winner) claims payout\n    97→  await po.claimOrSettle(playerAPage);\n    98→\n    99→  // Player A sees \"Back to Lobby\" after successful claim (scoped to sidebar)\n   100→  await expect(\n   101→    playerAPage.locator(po.sel.sidebar).locator(\"button\", { hasText: \"Back to Lobby\" }),\n   102→  ).toBeVisible();\n   103→\n   104→  // ── On-chain: verify match PDA is closed after claim ──\n   105→  await assertMatchClosed(connection, matchPda);\n   106→\n   107→  // ── On-chain: verify treasury received the 3% fee ──\n   108→  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n   109→\n   110→  // ── On-chain: verify player profile updates ──\n   111→  const { payout } = calculateExpectedFee(ENTRY_AMOUNT);\n   112→\n   113→  // Player A (winner): +1 game, +1 win, wagered entry, won payout\n   114→  await assertPlayerProfileDelta(connection, PLAYER_A.publicKey, profileABefore, {\n   115→    totalGames: 1,\n   116→    wins: 1,\n   117→    totalWagered: ENTRY_AMOUNT,\n   118→    totalWon: payout,\n   119→  });\n   120→\n   121→  // Player B (loser): +1 game, +0 wins, wagered entry, won nothing\n   122→  await assertPlayerProfileDelta(connection, PLAYER_B.publicKey, profileBBefore, {\n   123→    totalGames: 1,\n   124→    wins: 0,\n   125→    totalWagered: ENTRY_AMOUNT,\n   126→    totalWon: 0,\n   127→  });\n   128→\n   129→  // 7. Player A returns to lobby\n   130→  await po.backToLobby(playerAPage);\n   131→\n   132→  // No unhandled console errors in either context\n   133→  consoleA.assertClean();\n   134→  consoleB.assertClean();\n   135→});\n   136→"}]},"parent_tool_use_id":"toolu_013hbUywL2VQwbXJVCG3Uf9s","session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"7d7c0c46-aa4d-48ed-a7fa-c92eb5312fd4"}
{"type":"assistant","message":{"model":"claude-sonnet-4-5-20250929","id":"msg_01XhExpdAhsFq14E4VhyYfSq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NUtrXT86Rsx8miDj59MS1A","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/localnet-setup.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":7844,"cache_read_input_tokens":46197,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7844},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_013hbUywL2VQwbXJVCG3Uf9s","session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"3a8e59db-a6d5-47e7-a4c4-c0b71ddf2067"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NUtrXT86Rsx8miDj59MS1A","type":"tool_result","content":"     1→/**\n     2→ * Localnet setup helper — initializes coinflip and platform configs.\n     3→ *\n     4→ * Must be called once before the E2E suite starts, after the test validator\n     5→ * is running and wallets are funded. Initializes:\n     6→ * - Coinflip config PDA (sets authority + treasury)\n     7→ * - Platform config PDA (sets authority + treasury)\n     8→ */\n     9→import {\n    10→  Connection,\n    11→  Keypair,\n    12→  PublicKey,\n    13→  SystemProgram,\n    14→  Transaction,\n    15→  sendAndConfirmTransaction,\n    16→} from \"@solana/web3.js\";\n    17→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n    18→import {\n    19→  CoinflipIDL,\n    20→  PlatformIDL,\n    21→  type Coinflip,\n    22→  type Platform,\n    23→} from \"@rng-utopia/anchor-client\";\n    24→import { LOCAL_RPC_URL, PLAYER_A, PLAYER_B } from \"./wallets\";\n    25→\n    26→// ── Deterministic admin/treasury keypairs ──────────────────────────────\n    27→const SEED_ADMIN = new Uint8Array(32).fill(0xdd);\n    28→const SEED_TREASURY = new Uint8Array(32).fill(0xcc);\n    29→\n    30→export const ADMIN = Keypair.fromSeed(SEED_ADMIN);\n    31→export const TREASURY = Keypair.fromSeed(SEED_TREASURY);\n    32→\n    33→// ── Program IDs ────────────────────────────────────────────────────────\n    34→const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    35→const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n    36→\n    37→function getConfigPda(): PublicKey {\n    38→  const [pda] = PublicKey.findProgramAddressSync(\n    39→    [Buffer.from(\"coinflip_config\")],\n    40→    COINFLIP_PROGRAM_ID,\n    41→  );\n    42→  return pda;\n    43→}\n    44→\n    45→function getPlatformConfigPda(): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"platform_config\")],\n    48→    PLATFORM_PROGRAM_ID,\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→function makeProvider(connection: Connection, wallet: Keypair): AnchorProvider {\n    54→  return new AnchorProvider(\n    55→    connection,\n    56→    {\n    57→      publicKey: wallet.publicKey,\n    58→      signTransaction: async (tx) => {\n    59→        tx.partialSign(wallet);\n    60→        return tx;\n    61→      },\n    62→      signAllTransactions: async (txs) => {\n    63→        txs.forEach((tx) => tx.partialSign(wallet));\n    64→        return txs;\n    65→      },\n    66→    },\n    67→    { commitment: \"confirmed\" },\n    68→  );\n    69→}\n    70→\n    71→/**\n    72→ * Initialize both program configs and fund the admin/treasury accounts.\n    73→ * Idempotent: silently succeeds if configs already exist.\n    74→ */\n    75→export async function initializeLocalnet(\n    76→  rpcUrl = LOCAL_RPC_URL,\n    77→): Promise<void> {\n    78→  const connection = new Connection(rpcUrl, \"confirmed\");\n    79→\n    80→  // Fund admin and treasury\n    81→  await Promise.all([\n    82→    fundIfNeeded(connection, ADMIN.publicKey, 2),\n    83→    fundIfNeeded(connection, TREASURY.publicKey, 2),\n    84→  ]);\n    85→\n    86→  const provider = makeProvider(connection, ADMIN);\n    87→  const coinflipProgram = new Program(\n    88→    CoinflipIDL as Idl as Coinflip,\n    89→    provider,\n    90→  );\n    91→  const platformProgram = new Program(\n    92→    PlatformIDL as Idl as Platform,\n    93→    provider,\n    94→  );\n    95→\n    96→  // Initialize coinflip config (idempotent)\n    97→  const configPda = getConfigPda();\n    98→  const configExists = await connection.getAccountInfo(configPda);\n    99→  if (!configExists) {\n   100→    const ix = await coinflipProgram.methods\n   101→      .initializeConfig(TREASURY.publicKey)\n   102→      .accountsStrict({\n   103→        authority: ADMIN.publicKey,\n   104→        config: configPda,\n   105→        systemProgram: SystemProgram.programId,\n   106→      })\n   107→      .instruction();\n   108→\n   109→    const tx = new Transaction().add(ix);\n   110→    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n   111→      commitment: \"confirmed\",\n   112→    });\n   113→  }\n   114→\n   115→  // Initialize platform config (idempotent)\n   116→  const platformConfigPda = getPlatformConfigPda();\n   117→  const platformConfigExists =\n   118→    await connection.getAccountInfo(platformConfigPda);\n   119→  if (!platformConfigExists) {\n   120→    const ix = await platformProgram.methods\n   121→      .initializePlatform(TREASURY.publicKey)\n   122→      .accountsStrict({\n   123→        authority: ADMIN.publicKey,\n   124→        config: platformConfigPda,\n   125→        systemProgram: SystemProgram.programId,\n   126→      })\n   127→      .instruction();\n   128→\n   129→    const tx = new Transaction().add(ix);\n   130→    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n   131→      commitment: \"confirmed\",\n   132→    });\n   133→  }\n   134→\n   135→}\n   136→\n   137→/**\n   138→ * Ensure player profiles exist for both test wallets.\n   139→ * Call this in tests that verify profile updates (e.g., lifecycle test).\n   140→ * Separated from initializeLocalnet() to avoid changing player balances\n   141→ * in tests that depend on specific funding levels (e.g., error-flow).\n   142→ */\n   143→export async function ensurePlayerProfiles(\n   144→  rpcUrl = LOCAL_RPC_URL,\n   145→): Promise<void> {\n   146→  const connection = new Connection(rpcUrl, \"confirmed\");\n   147→  const provider = makeProvider(connection, PLAYER_A);\n   148→  const platformProgram = new Program(\n   149→    PlatformIDL as Idl as Platform,\n   150→    provider,\n   151→  );\n   152→\n   153→  await createPlayerProfileIfNeeded(connection, platformProgram, PLAYER_A);\n   154→  await createPlayerProfileIfNeeded(connection, platformProgram, PLAYER_B);\n   155→}\n   156→\n   157→function getPlayerProfilePda(player: PublicKey): PublicKey {\n   158→  const [pda] = PublicKey.findProgramAddressSync(\n   159→    [Buffer.from(\"player_profile\"), player.toBuffer()],\n   160→    PLATFORM_PROGRAM_ID,\n   161→  );\n   162→  return pda;\n   163→}\n   164→\n   165→/**\n   166→ * Create a player profile PDA if it doesn't exist.\n   167→ * Uses the ADMIN keypair as fee payer to avoid changing the player's balance,\n   168→ * but the player must still sign because `init` requires `player` as payer in\n   169→ * the on-chain instruction.\n   170→ *\n   171→ * To keep player balances predictable for tests, we use a dedicated admin\n   172→ * keypair as the actual SOL source: we transfer rent to the player, they\n   173→ * create the profile, and any leftover dust stays.\n   174→ */\n   175→async function createPlayerProfileIfNeeded(\n   176→  connection: Connection,\n   177→  platformProgram: Program<Platform>,\n   178→  player: Keypair,\n   179→): Promise<void> {\n   180→  const profilePda = getPlayerProfilePda(player.publicKey);\n   181→  const existing = await connection.getAccountInfo(profilePda);\n   182→  if (existing) return;\n   183→\n   184→  // Fund player with minimal SOL for profile rent (~0.002 SOL)\n   185→  await fundIfNeeded(connection, player.publicKey, 0.01);\n   186→\n   187→  const playerProvider = makeProvider(connection, player);\n   188→  const playerProgram = new Program(\n   189→    PlatformIDL as Idl as Platform,\n   190→    playerProvider,\n   191→  );\n   192→\n   193→  const ix = await playerProgram.methods\n   194→    .createPlayerProfile()\n   195→    .accountsStrict({\n   196→      player: player.publicKey,\n   197→      profile: profilePda,\n   198→      systemProgram: SystemProgram.programId,\n   199→    })\n   200→    .instruction();\n   201→\n   202→  const tx = new Transaction().add(ix);\n   203→  await sendAndConfirmTransaction(connection, tx, [player], {\n   204→    commitment: \"confirmed\",\n   205→  });\n   206→}\n   207→\n   208→async function fundIfNeeded(\n   209→  connection: Connection,\n   210→  pubkey: PublicKey,\n   211→  solAmount: number,\n   212→): Promise<void> {\n   213→  const balance = await connection.getBalance(pubkey);\n   214→  if (balance >= solAmount * 1_000_000_000) return;\n   215→\n   216→  const sig = await connection.requestAirdrop(\n   217→    pubkey,\n   218→    solAmount * 1_000_000_000,\n   219→  );\n   220→  const { blockhash, lastValidBlockHeight } =\n   221→    await connection.getLatestBlockhash();\n   222→  await connection.confirmTransaction(\n   223→    { signature: sig, blockhash, lastValidBlockHeight },\n   224→    \"confirmed\",\n   225→  );\n   226→}\n   227→"}]},"parent_tool_use_id":"toolu_013hbUywL2VQwbXJVCG3Uf9s","session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"f562903b-1273-497f-9751-4facdcc7d75a"}
{"type":"assistant","message":{"model":"claude-sonnet-4-5-20250929","id":"msg_01XhExpdAhsFq14E4VhyYfSq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011BZU2nAf8khxfUAN6GkTj6","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/on-chain.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":7844,"cache_read_input_tokens":46197,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7844},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_013hbUywL2VQwbXJVCG3Uf9s","session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"7169b19f-f836-431a-9b21-058af4e0fa82"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011BZU2nAf8khxfUAN6GkTj6","type":"tool_result","content":"     1→/**\n     2→ * On-chain assertion helpers for local E2E tests.\n     3→ *\n     4→ * Provides RPC-based helpers to query and assert match PDA state,\n     5→ * treasury fee deltas, and player profile stat updates.\n     6→ */\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     9→import {\n    10→  CoinflipIDL,\n    11→  PlatformIDL,\n    12→  type Coinflip,\n    13→  type Platform,\n    14→} from \"@rng-utopia/anchor-client\";\n    15→\n    16→// ============ Program IDs ============\n    17→\n    18→/** Coinflip program address (from IDL). */\n    19→export const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    20→\n    21→/** Platform program address (from IDL). */\n    22→export const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n    23→\n    24→/** Platform fee: 300 basis points = 3%. */\n    25→export const FEE_BPS = 300;\n    26→\n    27→// ============ PDA Derivation ============\n    28→\n    29→/** Derive the match PDA for a creator. Seeds: [\"match\", creator]. */\n    30→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer()],\n    33→    COINFLIP_PROGRAM_ID,\n    34→  );\n    35→}\n    36→\n    37→/** Derive the coinflip config PDA. Seeds: [\"coinflip_config\"]. */\n    38→export function getConfigPda(): [PublicKey, number] {\n    39→  return PublicKey.findProgramAddressSync(\n    40→    [Buffer.from(\"coinflip_config\")],\n    41→    COINFLIP_PROGRAM_ID,\n    42→  );\n    43→}\n    44→\n    45→/** Derive a player profile PDA. Seeds: [\"player_profile\", wallet]. */\n    46→export function getPlayerProfilePda(wallet: PublicKey): [PublicKey, number] {\n    47→  return PublicKey.findProgramAddressSync(\n    48→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    49→    PLATFORM_PROGRAM_ID,\n    50→  );\n    51→}\n    52→\n    53→// ============ Program Instances ============\n    54→\n    55→/**\n    56→ * Create a read-only Coinflip program instance.\n    57→ *\n    58→ * @param connection - Solana RPC connection\n    59→ */\n    60→export function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    61→  const provider = new AnchorProvider(\n    62→    connection,\n    63→    {} as AnchorProvider[\"wallet\"],\n    64→    { commitment: \"confirmed\" },\n    65→  );\n    66→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    67→}\n    68→\n    69→/**\n    70→ * Create a read-only Platform program instance.\n    71→ *\n    72→ * @param connection - Solana RPC connection\n    73→ */\n    74→export function getPlatformProgram(connection: Connection): Program<Platform> {\n    75→  const provider = new AnchorProvider(\n    76→    connection,\n    77→    {} as AnchorProvider[\"wallet\"],\n    78→    { commitment: \"confirmed\" },\n    79→  );\n    80→  return new Program(PlatformIDL as Idl as Platform, provider);\n    81→}\n    82→\n    83→// ============ Account Types ============\n    84→\n    85→/** Deserialized match account shape. */\n    86→export interface MatchAccount {\n    87→  creator: PublicKey;\n    88→  opponent: PublicKey;\n    89→  tier: number;\n    90→  entryAmount: { toNumber(): number };\n    91→  creatorSide: number;\n    92→  phase: Record<string, object>;\n    93→  result: number;\n    94→  winner: PublicKey;\n    95→  claimed: boolean;\n    96→  createdAt: { toNumber(): number };\n    97→  lockedAt: { toNumber(): number };\n    98→  resolveDeadline: { toNumber(): number };\n    99→  vrfRequestKey: PublicKey;\n   100→  bump: number;\n   101→}\n   102→\n   103→/** Deserialized player profile account shape. */\n   104→export interface PlayerProfileAccount {\n   105→  authority: PublicKey;\n   106→  totalGames: { toNumber(): number };\n   107→  wins: { toNumber(): number };\n   108→  totalWagered: { toNumber(): number };\n   109→  totalWon: { toNumber(): number };\n   110→  bump: number;\n   111→}\n   112→\n   113→// ============ Fetch Helpers ============\n   114→\n   115→/**\n   116→ * Fetch a match PDA account. Returns null if the account is closed.\n   117→ *\n   118→ * @param connection - Solana RPC connection\n   119→ * @param matchPda - The match PDA address\n   120→ */\n   121→export async function fetchMatch(\n   122→  connection: Connection,\n   123→  matchPda: PublicKey,\n   124→): Promise<MatchAccount | null> {\n   125→  const program = getCoinflipProgram(connection);\n   126→  try {\n   127→    return (await program.account.coinflipMatch.fetch(\n   128→      matchPda,\n   129→    )) as unknown as MatchAccount;\n   130→  } catch {\n   131→    // Account not found (closed or never created)\n   132→    return null;\n   133→  }\n   134→}\n   135→\n   136→/**\n   137→ * Fetch a player profile PDA account. Returns null if it doesn't exist.\n   138→ *\n   139→ * @param connection - Solana RPC connection\n   140→ * @param profilePda - The player profile PDA address\n   141→ */\n   142→export async function fetchPlayerProfile(\n   143→  connection: Connection,\n   144→  profilePda: PublicKey,\n   145→): Promise<PlayerProfileAccount | null> {\n   146→  const program = getPlatformProgram(connection);\n   147→  try {\n   148→    return (await program.account.playerProfile.fetch(\n   149→      profilePda,\n   150→    )) as unknown as PlayerProfileAccount;\n   151→  } catch {\n   152→    return null;\n   153→  }\n   154→}\n   155→\n   156→/**\n   157→ * Get the treasury wallet address from the coinflip config PDA.\n   158→ *\n   159→ * @param connection - Solana RPC connection\n   160→ */\n   161→export async function getTreasuryAddress(\n   162→  connection: Connection,\n   163→): Promise<PublicKey> {\n   164→  const program = getCoinflipProgram(connection);\n   165→  const [configPda] = getConfigPda();\n   166→  const config = await program.account.coinflipConfig.fetch(configPda);\n   167→  return (config as unknown as { treasury: PublicKey }).treasury;\n   168→}\n   169→\n   170→// ============ Balance Helpers ============\n   171→\n   172→/**\n   173→ * Get the SOL balance of an address in lamports.\n   174→ *\n   175→ * @param connection - Solana RPC connection\n   176→ * @param address - Public key to check\n   177→ */\n   178→export async function getBalanceLamports(\n   179→  connection: Connection,\n   180→  address: PublicKey,\n   181→): Promise<number> {\n   182→  return connection.getBalance(address);\n   183→}\n   184→\n   185→/**\n   186→ * Capture a balance snapshot for later delta comparison.\n   187→ *\n   188→ * @param connection - Solana RPC connection\n   189→ * @param address - Public key to snapshot\n   190→ */\n   191→export async function snapshotBalance(\n   192→  connection: Connection,\n   193→  address: PublicKey,\n   194→): Promise<number> {\n   195→  return connection.getBalance(address);\n   196→}\n   197→\n   198→// ============ Fee Calculation ============\n   199→\n   200→/**\n   201→ * Calculate the expected fee and net payout for a coinflip match.\n   202→ * Mirrors on-chain logic: fee = floor(pool * FEE_BPS / 10_000).\n   203→ *\n   204→ * @param entryAmount - Single player's entry in lamports\n   205→ * @returns Object with pool, fee, and payout amounts in lamports\n   206→ */\n   207→export function calculateExpectedFee(entryAmount: number): {\n   208→  pool: number;\n   209→  fee: number;\n   210→  payout: number;\n   211→} {\n   212→  const pool = entryAmount * 2;\n   213→  const fee = Math.floor((pool * FEE_BPS) / 10_000);\n   214→  const payout = pool - fee;\n   215→  return { pool, fee, payout };\n   216→}\n   217→\n   218→// ============ Assertion Helpers ============\n   219→\n   220→/**\n   221→ * Assert match PDA state after creation (Waiting phase).\n   222→ *\n   223→ * @param connection - Solana RPC connection\n   224→ * @param creator - Creator's public key\n   225→ * @param expectedTier - Expected tier index\n   226→ * @param expectedSide - Expected creator side (0 = heads, 1 = tails)\n   227→ */\n   228→export async function assertMatchCreated(\n   229→  connection: Connection,\n   230→  creator: PublicKey,\n   231→  expectedTier: number,\n   232→  expectedSide: number,\n   233→): Promise<{ matchPda: PublicKey; match: MatchAccount }> {\n   234→  const [matchPda] = getMatchPda(creator);\n   235→  const match = await fetchMatch(connection, matchPda);\n   236→  if (!match) throw new Error(`Match PDA not found for creator ${creator}`);\n   237→\n   238→  const phase = Object.keys(match.phase)[0];\n   239→  if (phase !== \"waiting\") {\n   240→    throw new Error(`Expected phase 'waiting', got '${phase}'`);\n   241→  }\n   242→  if (match.creator.toBase58() !== creator.toBase58()) {\n   243→    throw new Error(\"Match creator does not match expected creator\");\n   244→  }\n   245→  if (match.tier !== expectedTier) {\n   246→    throw new Error(`Expected tier ${expectedTier}, got ${match.tier}`);\n   247→  }\n   248→  if (match.creatorSide !== expectedSide) {\n   249→    throw new Error(`Expected side ${expectedSide}, got ${match.creatorSide}`);\n   250→  }\n   251→  if (match.opponent.toBase58() !== PublicKey.default.toBase58()) {\n   252→    throw new Error(\"Expected no opponent in waiting phase\");\n   253→  }\n   254→  if (match.claimed) {\n   255→    throw new Error(\"Expected claimed=false after creation\");\n   256→  }\n   257→\n   258→  return { matchPda, match };\n   259→}\n   260→\n   261→/**\n   262→ * Assert match PDA is closed (account no longer exists).\n   263→ *\n   264→ * @param connection - Solana RPC connection\n   265→ * @param matchPda - The match PDA address to check\n   266→ */\n   267→export async function assertMatchClosed(\n   268→  connection: Connection,\n   269→  matchPda: PublicKey,\n   270→): Promise<void> {\n   271→  const match = await fetchMatch(connection, matchPda);\n   272→  if (match !== null) {\n   273→    const phase = Object.keys(match.phase)[0];\n   274→    throw new Error(\n   275→      `Expected match PDA to be closed, but it still exists (phase: ${phase})`,\n   276→    );\n   277→  }\n   278→}\n   279→\n   280→/**\n   281→ * Assert that the treasury received the expected fee.\n   282→ * Call snapshotBalance before the payout, then call this after.\n   283→ *\n   284→ * @param connection - Solana RPC connection\n   285→ * @param treasury - Treasury public key\n   286→ * @param balanceBefore - Treasury balance in lamports before claim\n   287→ * @param entryAmount - Single player's entry in lamports\n   288→ */\n   289→export async function assertTreasuryFee(\n   290→  connection: Connection,\n   291→  treasury: PublicKey,\n   292→  balanceBefore: number,\n   293→  entryAmount: number,\n   294→): Promise<void> {\n   295→  const balanceAfter = await getBalanceLamports(connection, treasury);\n   296→  const { fee } = calculateExpectedFee(entryAmount);\n   297→  const actualDelta = balanceAfter - balanceBefore;\n   298→\n   299→  if (actualDelta !== fee) {\n   300→    throw new Error(\n   301→      `Treasury fee mismatch: expected ${fee} lamports, got delta ${actualDelta}`,\n   302→    );\n   303→  }\n   304→}\n   305→\n   306→/**\n   307→ * Assert player profile stats after a game.\n   308→ *\n   309→ * @param connection - Solana RPC connection\n   310→ * @param wallet - Player's wallet public key\n   311→ * @param expected - Expected stat values\n   312→ */\n   313→export async function assertPlayerProfile(\n   314→  connection: Connection,\n   315→  wallet: PublicKey,\n   316→  expected: {\n   317→    totalGames: number;\n   318→    wins: number;\n   319→    totalWagered: number;\n   320→    totalWon: number;\n   321→  },\n   322→): Promise<void> {\n   323→  const [profilePda] = getPlayerProfilePda(wallet);\n   324→  const profile = await fetchPlayerProfile(connection, profilePda);\n   325→  if (!profile) {\n   326→    throw new Error(`Player profile not found for ${wallet}`);\n   327→  }\n   328→\n   329→  const actual = {\n   330→    totalGames: profile.totalGames.toNumber(),\n   331→    wins: profile.wins.toNumber(),\n   332→    totalWagered: profile.totalWagered.toNumber(),\n   333→    totalWon: profile.totalWon.toNumber(),\n   334→  };\n   335→\n   336→  for (const key of Object.keys(expected) as (keyof typeof expected)[]) {\n   337→    if (actual[key] !== expected[key]) {\n   338→      throw new Error(\n   339→        `Profile ${key} mismatch for ${wallet}: expected ${expected[key]}, got ${actual[key]}`,\n   340→      );\n   341→    }\n   342→  }\n   343→}\n   344→\n   345→/**\n   346→ * Assert player profile stats changed by a specific delta since a snapshot.\n   347→ *\n   348→ * @param connection - Solana RPC connection\n   349→ * @param wallet - Player's wallet public key\n   350→ * @param before - Profile stats snapshot before the action\n   351→ * @param delta - Expected stat deltas\n   352→ */\n   353→export async function assertPlayerProfileDelta(\n   354→  connection: Connection,\n   355→  wallet: PublicKey,\n   356→  before: { totalGames: number; wins: number; totalWagered: number; totalWon: number },\n   357→  delta: { totalGames: number; wins: number; totalWagered: number; totalWon: number },\n   358→): Promise<void> {\n   359→  const expected = {\n   360→    totalGames: before.totalGames + delta.totalGames,\n   361→    wins: before.wins + delta.wins,\n   362→    totalWagered: before.totalWagered + delta.totalWagered,\n   363→    totalWon: before.totalWon + delta.totalWon,\n   364→  };\n   365→  await assertPlayerProfile(connection, wallet, expected);\n   366→}\n   367→\n   368→/**\n   369→ * Snapshot a player profile's current stats (for later delta comparison).\n   370→ * Returns zero-stats if the profile doesn't exist yet.\n   371→ *\n   372→ * @param connection - Solana RPC connection\n   373→ * @param wallet - Player's wallet public key\n   374→ */\n   375→export async function snapshotPlayerProfile(\n   376→  connection: Connection,\n   377→  wallet: PublicKey,\n   378→): Promise<{ totalGames: number; wins: number; totalWagered: number; totalWon: number }> {\n   379→  const [profilePda] = getPlayerProfilePda(wallet);\n   380→  const profile = await fetchPlayerProfile(connection, profilePda);\n   381→  if (!profile) {\n   382→    return { totalGames: 0, wins: 0, totalWagered: 0, totalWon: 0 };\n   383→  }\n   384→  return {\n   385→    totalGames: profile.totalGames.toNumber(),\n   386→    wins: profile.wins.toNumber(),\n   387→    totalWagered: profile.totalWagered.toNumber(),\n   388→    totalWon: profile.totalWon.toNumber(),\n   389→  };\n   390→}\n   391→"}]},"parent_tool_use_id":"toolu_013hbUywL2VQwbXJVCG3Uf9s","session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"55a48c1d-5e8f-4df2-9112-1d01aef52832"}
