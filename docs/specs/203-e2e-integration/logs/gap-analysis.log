{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vge1tfxpdZai1sPkcps3cP","type":"tool_result","content":"     1→/**\n     2→ * Robust VRF fulfillment polling with exponential backoff and timeout budget\n     3→ * tracking for devnet E2E tests.\n     4→ *\n     5→ * Polls the match PDA on-chain to detect phase transitions (locked → resolved)\n     6→ * as evidence of real VRF fulfillment. Provides detailed timing logs and\n     7→ * transaction signature collection for failure diagnostics.\n     8→ */\n     9→import { Connection, PublicKey } from \"@solana/web3.js\";\n    10→import {\n    11→  fetchMatch,\n    12→  getMatchPda,\n    13→  type MatchAccount,\n    14→} from \"../../local/helpers/on-chain\";\n    15→\n    16→// ── Polling config ──────────────────────────────────────────────────────\n    17→\n    18→/** Initial polling interval (ms). */\n    19→const INITIAL_INTERVAL = 2_000;\n    20→\n    21→/** Maximum polling interval after backoff (ms). */\n    22→const MAX_INTERVAL = 10_000;\n    23→\n    24→/** Backoff multiplier per poll attempt. */\n    25→const BACKOFF_FACTOR = 1.5;\n    26→\n    27→// ── Types ───────────────────────────────────────────────────────────────\n    28→\n    29→export interface VrfPollResult {\n    30→  /** Final match account state after fulfillment. */\n    31→  match: MatchAccount;\n    32→  /** Match PDA address. */\n    33→  matchPda: PublicKey;\n    34→  /** Phase detected (\"resolved\" on success). */\n    35→  phase: string;\n    36→  /** Total wall-clock time spent polling (ms). */\n    37→  elapsedMs: number;\n    38→  /** Number of RPC poll attempts made. */\n    39→  attempts: number;\n    40→}\n    41→\n    42→export interface VrfTimeoutError extends Error {\n    43→  /** Elapsed time before timeout (ms). */\n    44→  elapsedMs: number;\n    45→  /** Number of poll attempts made. */\n    46→  attempts: number;\n    47→  /** Last observed phase (if any). */\n    48→  lastPhase: string | null;\n    49→  /** Transaction signatures on the match PDA (for debugging). */\n    50→  signatures: string[];\n    51→}\n    52→\n    53→// ── Helpers ─────────────────────────────────────────────────────────────\n    54→\n    55→/**\n    56→ * Collect recent transaction signatures for a match PDA.\n    57→ * Used for failure diagnostics — shows what transactions touched the account.\n    58→ */\n    59→export async function collectMatchSignatures(\n    60→  connection: Connection,\n    61→  matchPda: PublicKey,\n    62→  limit = 10,\n    63→): Promise<string[]> {\n    64→  try {\n    65→    const sigs = await connection.getSignaturesForAddress(matchPda, { limit });\n    66→    return sigs.map((s) => s.signature);\n    67→  } catch {\n    68→    return [];\n    69→  }\n    70→}\n    71→\n    72→/**\n    73→ * Format a duration in milliseconds to a human-readable string.\n    74→ */\n    75→function formatMs(ms: number): string {\n    76→  if (ms < 1_000) return `${ms}ms`;\n    77→  return `${(ms / 1_000).toFixed(1)}s`;\n    78→}\n    79→\n    80→// ── Main polling function ───────────────────────────────────────────────\n    81→\n    82→/**\n    83→ * Poll the match PDA on-chain for VRF fulfillment with exponential backoff.\n    84→ *\n    85→ * Waits for the match phase to transition from \"locked\" to \"resolved\",\n    86→ * which indicates the Orao VRF callback has executed. Logs timing budget\n    87→ * at each attempt for observability.\n    88→ *\n    89→ * @param connection - Solana RPC connection\n    90→ * @param creator - Match creator's public key (used to derive PDA)\n    91→ * @param timeoutMs - Maximum time to poll before giving up\n    92→ * @returns VrfPollResult on success\n    93→ * @throws VrfTimeoutError with diagnostics on timeout\n    94→ */\n    95→export async function pollVrfFulfillment(\n    96→  connection: Connection,\n    97→  creator: PublicKey,\n    98→  timeoutMs: number,\n    99→): Promise<VrfPollResult> {\n   100→  const [matchPda] = getMatchPda(creator);\n   101→  const startTime = Date.now();\n   102→  let interval = INITIAL_INTERVAL;\n   103→  let attempts = 0;\n   104→  let lastPhase: string | null = null;\n   105→\n   106→  console.log(\n   107→    `[vrf-poll] Starting VRF fulfillment polling for match PDA ${matchPda.toBase58()}`,\n   108→  );\n   109→  console.log(\n   110→    `[vrf-poll] Timeout budget: ${formatMs(timeoutMs)}, initial interval: ${formatMs(INITIAL_INTERVAL)}`,\n   111→  );\n   112→\n   113→  while (true) {\n   114→    const elapsed = Date.now() - startTime;\n   115→    const remaining = timeoutMs - elapsed;\n   116→\n   117→    if (remaining <= 0) {\n   118→      // Timeout — collect diagnostic info\n   119→      console.log(`[vrf-poll] TIMEOUT after ${formatMs(elapsed)} (${attempts} attempts)`);\n   120→      const signatures = await collectMatchSignatures(connection, matchPda);\n   121→      if (signatures.length > 0) {\n   122→        console.log(`[vrf-poll] Match PDA transaction signatures:`);\n   123→        signatures.forEach((sig, i) => console.log(`  [${i}] ${sig}`));\n   124→      } else {\n   125→        console.log(`[vrf-poll] No transaction signatures found on match PDA`);\n   126→      }\n   127→\n   128→      const err = new Error(\n   129→        `VRF fulfillment timed out after ${formatMs(elapsed)} (${attempts} attempts). ` +\n   130→          `Last phase: ${lastPhase ?? \"unknown\"}. ` +\n   131→          `Signatures: ${signatures.length > 0 ? signatures.join(\", \") : \"none\"}`,\n   132→      ) as VrfTimeoutError;\n   133→      err.elapsedMs = elapsed;\n   134→      err.attempts = attempts;\n   135→      err.lastPhase = lastPhase;\n   136→      err.signatures = signatures;\n   137→      throw err;\n   138→    }\n   139→\n   140→    // Wait before polling (skip initial wait on first attempt)\n   141→    if (attempts > 0) {\n   142→      const sleepMs = Math.min(interval, remaining);\n   143→      await new Promise((r) => setTimeout(r, sleepMs));\n   144→    }\n   145→\n   146→    attempts++;\n   147→    const elapsed2 = Date.now() - startTime;\n   148→    const budgetPct = Math.round((elapsed2 / timeoutMs) * 100);\n   149→\n   150→    try {\n   151→      const match = await fetchMatch(connection, matchPda);\n   152→\n   153→      if (!match) {\n   154→        // Match PDA closed (claimed before we could observe resolved state)\n   155→        console.log(\n   156→          `[vrf-poll] Attempt ${attempts}: match PDA closed (already claimed?) ` +\n   157→            `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n   158→        );\n   159→        lastPhase = \"closed\";\n   160→      } else {\n   161→        const phase = Object.keys(match.phase)[0];\n   162→        lastPhase = phase;\n   163→\n   164→        console.log(\n   165→          `[vrf-poll] Attempt ${attempts}: phase=\"${phase}\" ` +\n   166→            `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n   167→        );\n   168→\n   169→        if (phase === \"resolved\") {\n   170→          console.log(\n   171→            `[vrf-poll] VRF fulfilled! Detected in ${formatMs(elapsed2)} after ${attempts} attempts`,\n   172→          );\n   173→\n   174→          // Log the fulfillment transaction signatures\n   175→          const signatures = await collectMatchSignatures(connection, matchPda);\n   176→          if (signatures.length > 0) {\n   177→            console.log(`[vrf-poll] Match PDA transaction signatures:`);\n   178→            signatures.forEach((sig, i) => console.log(`  [${i}] ${sig}`));\n   179→          }\n   180→\n   181→          return {\n   182→            match,\n   183→            matchPda,\n   184→            phase,\n   185→            elapsedMs: elapsed2,\n   186→            attempts,\n   187→          };\n   188→        }\n   189→      }\n   190→    } catch (err) {\n   191→      console.log(\n   192→        `[vrf-poll] Attempt ${attempts}: RPC error — ${err} ` +\n   193→          `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n   194→      );\n   195→    }\n   196→\n   197→    // Exponential backoff\n   198→    interval = Math.min(interval * BACKOFF_FACTOR, MAX_INTERVAL);\n   199→  }\n   200→}\n   201→\n   202→/**\n   203→ * Log transaction signatures for a player's recent activity on devnet.\n   204→ * Useful for post-failure diagnostics.\n   205→ *\n   206→ * @param connection - Solana RPC connection\n   207→ * @param address - Address to inspect\n   208→ * @param label - Human-readable label for logging\n   209→ * @param limit - Max signatures to fetch\n   210→ */\n   211→export async function logRecentSignatures(\n   212→  connection: Connection,\n   213→  address: PublicKey,\n   214→  label: string,\n   215→  limit = 5,\n   216→): Promise<string[]> {\n   217→  try {\n   218→    const sigs = await connection.getSignaturesForAddress(address, { limit });\n   219→    if (sigs.length === 0) {\n   220→      console.log(`[tx-log] ${label}: no recent signatures`);\n   221→      return [];\n   222→    }\n   223→    console.log(`[tx-log] ${label}: ${sigs.length} recent signature(s):`);\n   224→    const result: string[] = [];\n   225→    for (const sig of sigs) {\n   226→      const status = sig.err ? `FAILED: ${JSON.stringify(sig.err)}` : \"OK\";\n   227→      console.log(`  ${sig.signature} [slot ${sig.slot}, ${status}]`);\n   228→      result.push(sig.signature);\n   229→    }\n   230→    return result;\n   231→  } catch {\n   232→    console.log(`[tx-log] ${label}: failed to fetch signatures`);\n   233→    return [];\n   234→  }\n   235→}\n   236→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"5c9de6ac-ef1b-42a1-b5ff-36ed9c36b229","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/helpers/vrf-polling.ts","content":"/**\n * Robust VRF fulfillment polling with exponential backoff and timeout budget\n * tracking for devnet E2E tests.\n *\n * Polls the match PDA on-chain to detect phase transitions (locked → resolved)\n * as evidence of real VRF fulfillment. Provides detailed timing logs and\n * transaction signature collection for failure diagnostics.\n */\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport {\n  fetchMatch,\n  getMatchPda,\n  type MatchAccount,\n} from \"../../local/helpers/on-chain\";\n\n// ── Polling config ──────────────────────────────────────────────────────\n\n/** Initial polling interval (ms). */\nconst INITIAL_INTERVAL = 2_000;\n\n/** Maximum polling interval after backoff (ms). */\nconst MAX_INTERVAL = 10_000;\n\n/** Backoff multiplier per poll attempt. */\nconst BACKOFF_FACTOR = 1.5;\n\n// ── Types ───────────────────────────────────────────────────────────────\n\nexport interface VrfPollResult {\n  /** Final match account state after fulfillment. */\n  match: MatchAccount;\n  /** Match PDA address. */\n  matchPda: PublicKey;\n  /** Phase detected (\"resolved\" on success). */\n  phase: string;\n  /** Total wall-clock time spent polling (ms). */\n  elapsedMs: number;\n  /** Number of RPC poll attempts made. */\n  attempts: number;\n}\n\nexport interface VrfTimeoutError extends Error {\n  /** Elapsed time before timeout (ms). */\n  elapsedMs: number;\n  /** Number of poll attempts made. */\n  attempts: number;\n  /** Last observed phase (if any). */\n  lastPhase: string | null;\n  /** Transaction signatures on the match PDA (for debugging). */\n  signatures: string[];\n}\n\n// ── Helpers ─────────────────────────────────────────────────────────────\n\n/**\n * Collect recent transaction signatures for a match PDA.\n * Used for failure diagnostics — shows what transactions touched the account.\n */\nexport async function collectMatchSignatures(\n  connection: Connection,\n  matchPda: PublicKey,\n  limit = 10,\n): Promise<string[]> {\n  try {\n    const sigs = await connection.getSignaturesForAddress(matchPda, { limit });\n    return sigs.map((s) => s.signature);\n  } catch {\n    return [];\n  }\n}\n\n/**\n * Format a duration in milliseconds to a human-readable string.\n */\nfunction formatMs(ms: number): string {\n  if (ms < 1_000) return `${ms}ms`;\n  return `${(ms / 1_000).toFixed(1)}s`;\n}\n\n// ── Main polling function ───────────────────────────────────────────────\n\n/**\n * Poll the match PDA on-chain for VRF fulfillment with exponential backoff.\n *\n * Waits for the match phase to transition from \"locked\" to \"resolved\",\n * which indicates the Orao VRF callback has executed. Logs timing budget\n * at each attempt for observability.\n *\n * @param connection - Solana RPC connection\n * @param creator - Match creator's public key (used to derive PDA)\n * @param timeoutMs - Maximum time to poll before giving up\n * @returns VrfPollResult on success\n * @throws VrfTimeoutError with diagnostics on timeout\n */\nexport async function pollVrfFulfillment(\n  connection: Connection,\n  creator: PublicKey,\n  timeoutMs: number,\n): Promise<VrfPollResult> {\n  const [matchPda] = getMatchPda(creator);\n  const startTime = Date.now();\n  let interval = INITIAL_INTERVAL;\n  let attempts = 0;\n  let lastPhase: string | null = null;\n\n  console.log(\n    `[vrf-poll] Starting VRF fulfillment polling for match PDA ${matchPda.toBase58()}`,\n  );\n  console.log(\n    `[vrf-poll] Timeout budget: ${formatMs(timeoutMs)}, initial interval: ${formatMs(INITIAL_INTERVAL)}`,\n  );\n\n  while (true) {\n    const elapsed = Date.now() - startTime;\n    const remaining = timeoutMs - elapsed;\n\n    if (remaining <= 0) {\n      // Timeout — collect diagnostic info\n      console.log(`[vrf-poll] TIMEOUT after ${formatMs(elapsed)} (${attempts} attempts)`);\n      const signatures = await collectMatchSignatures(connection, matchPda);\n      if (signatures.length > 0) {\n        console.log(`[vrf-poll] Match PDA transaction signatures:`);\n        signatures.forEach((sig, i) => console.log(`  [${i}] ${sig}`));\n      } else {\n        console.log(`[vrf-poll] No transaction signatures found on match PDA`);\n      }\n\n      const err = new Error(\n        `VRF fulfillment timed out after ${formatMs(elapsed)} (${attempts} attempts). ` +\n          `Last phase: ${lastPhase ?? \"unknown\"}. ` +\n          `Signatures: ${signatures.length > 0 ? signatures.join(\", \") : \"none\"}`,\n      ) as VrfTimeoutError;\n      err.elapsedMs = elapsed;\n      err.attempts = attempts;\n      err.lastPhase = lastPhase;\n      err.signatures = signatures;\n      throw err;\n    }\n\n    // Wait before polling (skip initial wait on first attempt)\n    if (attempts > 0) {\n      const sleepMs = Math.min(interval, remaining);\n      await new Promise((r) => setTimeout(r, sleepMs));\n    }\n\n    attempts++;\n    const elapsed2 = Date.now() - startTime;\n    const budgetPct = Math.round((elapsed2 / timeoutMs) * 100);\n\n    try {\n      const match = await fetchMatch(connection, matchPda);\n\n      if (!match) {\n        // Match PDA closed (claimed before we could observe resolved state)\n        console.log(\n          `[vrf-poll] Attempt ${attempts}: match PDA closed (already claimed?) ` +\n            `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n        );\n        lastPhase = \"closed\";\n      } else {\n        const phase = Object.keys(match.phase)[0];\n        lastPhase = phase;\n\n        console.log(\n          `[vrf-poll] Attempt ${attempts}: phase=\"${phase}\" ` +\n            `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n        );\n\n        if (phase === \"resolved\") {\n          console.log(\n            `[vrf-poll] VRF fulfilled! Detected in ${formatMs(elapsed2)} after ${attempts} attempts`,\n          );\n\n          // Log the fulfillment transaction signatures\n          const signatures = await collectMatchSignatures(connection, matchPda);\n          if (signatures.length > 0) {\n            console.log(`[vrf-poll] Match PDA transaction signatures:`);\n            signatures.forEach((sig, i) => console.log(`  [${i}] ${sig}`));\n          }\n\n          return {\n            match,\n            matchPda,\n            phase,\n            elapsedMs: elapsed2,\n            attempts,\n          };\n        }\n      }\n    } catch (err) {\n      console.log(\n        `[vrf-poll] Attempt ${attempts}: RPC error — ${err} ` +\n          `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n      );\n    }\n\n    // Exponential backoff\n    interval = Math.min(interval * BACKOFF_FACTOR, MAX_INTERVAL);\n  }\n}\n\n/**\n * Log transaction signatures for a player's recent activity on devnet.\n * Useful for post-failure diagnostics.\n *\n * @param connection - Solana RPC connection\n * @param address - Address to inspect\n * @param label - Human-readable label for logging\n * @param limit - Max signatures to fetch\n */\nexport async function logRecentSignatures(\n  connection: Connection,\n  address: PublicKey,\n  label: string,\n  limit = 5,\n): Promise<string[]> {\n  try {\n    const sigs = await connection.getSignaturesForAddress(address, { limit });\n    if (sigs.length === 0) {\n      console.log(`[tx-log] ${label}: no recent signatures`);\n      return [];\n    }\n    console.log(`[tx-log] ${label}: ${sigs.length} recent signature(s):`);\n    const result: string[] = [];\n    for (const sig of sigs) {\n      const status = sig.err ? `FAILED: ${JSON.stringify(sig.err)}` : \"OK\";\n      console.log(`  ${sig.signature} [slot ${sig.slot}, ${status}]`);\n      result.push(sig.signature);\n    }\n    return result;\n  } catch {\n    console.log(`[tx-log] ${label}: failed to fetch signatures`);\n    return [];\n  }\n}\n","numLines":236,"startLine":1,"totalLines":236}}}
