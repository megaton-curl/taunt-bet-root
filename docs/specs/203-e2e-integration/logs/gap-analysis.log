{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JebL72HQWVXmgzBkKjEd7w","type":"tool_result","content":"     1→import { ReactNode, lazy, Suspense } from \"react\";\n     2→import { ConnectionProvider } from \"@solana/wallet-adapter-react\";\n     3→import type { ConnectionConfig } from \"@solana/web3.js\";\n     4→import { MockWalletProvider } from \"./mock\";\n     5→\n     6→// Lazy-load RealWalletProvider to avoid bundling wallet-adapter deps in mock mode\n     7→const RealWalletProvider = lazy(() =>\n     8→  import(\"./real/RealWalletProvider\").then((m) => ({\n     9→    default: m.RealWalletProvider,\n    10→  })),\n    11→);\n    12→\n    13→// Lazy-load TestWalletWrapper for E2E tests (reads keypair seed from window)\n    14→const TestWalletWrapper = lazy(() =>\n    15→  import(\"./test/TestWalletWrapper\").then((m) => ({\n    16→    default: m.TestWalletWrapper,\n    17→  })),\n    18→);\n    19→\n    20→// Re-export WalletContext from the shared context file\n    21→export { WalletContext } from \"./context\";\n    22→\n    23→const DEFAULT_RPC_URL = \"https://api.devnet.solana.com\";\n    24→const RPC_MAX_RETRIES = 3;\n    25→const RPC_INITIAL_RETRY_DELAY_MS = 1000;\n    26→\n    27→function getRpcUrl(): string {\n    28→  const envUrl =\n    29→    typeof import.meta !== \"undefined\"\n    30→      ? import.meta.env?.VITE_RPC_URL\n    31→      : undefined;\n    32→  return envUrl || DEFAULT_RPC_URL;\n    33→}\n    34→\n    35→interface WalletProviderProps {\n    36→  children: ReactNode;\n    37→}\n    38→\n    39→function delay(ms: number): Promise<void> {\n    40→  return new Promise((resolve) => setTimeout(resolve, ms));\n    41→}\n    42→\n    43→const baseFetch = globalThis.fetch?.bind(globalThis);\n    44→\n    45→const rpcFetch: typeof fetch = async (input, init) => {\n    46→  if (!baseFetch) {\n    47→    throw new Error(\"Global fetch is not available in this environment.\");\n    48→  }\n    49→\n    50→  let attempt = 0;\n    51→  let retryDelayMs = RPC_INITIAL_RETRY_DELAY_MS;\n    52→  let response = await baseFetch(input, init);\n    53→\n    54→  while (response.status === 429 && attempt < RPC_MAX_RETRIES) {\n    55→    await delay(retryDelayMs);\n    56→    attempt += 1;\n    57→    retryDelayMs *= 2;\n    58→    response = await baseFetch(input, init);\n    59→  }\n    60→\n    61→  return response;\n    62→};\n    63→\n    64→const connectionConfig: ConnectionConfig = {\n    65→  commitment: \"confirmed\",\n    66→  // Disable web3.js internal 429 retries so we can control retry timing.\n    67→  disableRetryOnRateLimit: true,\n    68→  fetch: rpcFetch,\n    69→};\n    70→\n    71→function isMockMode(): boolean {\n    72→  const flag =\n    73→    typeof import.meta !== \"undefined\"\n    74→      ? import.meta.env?.VITE_MOCK_MODE\n    75→      : undefined;\n    76→  // Default to real mode — only mock when explicitly set to \"true\"\n    77→  return flag === \"true\";\n    78→}\n    79→\n    80→function isTestWalletMode(): boolean {\n    81→  const flag =\n    82→    typeof import.meta !== \"undefined\"\n    83→      ? import.meta.env?.VITE_TEST_WALLET\n    84→      : undefined;\n    85→  return flag === \"true\";\n    86→}\n    87→\n    88→/**\n    89→ * Unified WalletProvider.\n    90→ * Wraps both Mock and Real providers with a shared ConnectionProvider.\n    91→ */\n    92→export function WalletProvider({ children }: WalletProviderProps) {\n    93→  const endpoint = getRpcUrl();\n    94→\n    95→  const inner = isMockMode() ? (\n    96→    <MockWalletProvider>{children}</MockWalletProvider>\n    97→  ) : isTestWalletMode() ? (\n    98→    <Suspense fallback={null}>\n    99→      <TestWalletWrapper>{children}</TestWalletWrapper>\n   100→    </Suspense>\n   101→  ) : (\n   102→    <Suspense fallback={null}>\n   103→      <RealWalletProvider>{children}</RealWalletProvider>\n   104→    </Suspense>\n   105→  );\n   106→\n   107→  return (\n   108→    <ConnectionProvider endpoint={endpoint} config={connectionConfig}>\n   109→      {inner}\n   110→    </ConnectionProvider>\n   111→  );\n   112→}\n   113→"}]},"parent_tool_use_id":"toolu_013hbUywL2VQwbXJVCG3Uf9s","session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"56dd3dc0-67fb-4d97-b23b-666f274cf529"}
