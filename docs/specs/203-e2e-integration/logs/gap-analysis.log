{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018DfJsj23ujXuwFWevpGb6j","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# localnet-teardown.sh — Stop solana-test-validator and clean temp files.\n     3→# Usage: ./scripts/localnet-teardown.sh [--keep-logs]\n     4→# Reads PID from .localnet.pid (written by localnet-bootstrap.sh).\n     5→# Safe to call multiple times or when no validator is running.\n     6→set -euo pipefail\n     7→\n     8→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     9→PLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n    10→\n    11→PID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\n    12→LEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\n    13→LOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n    14→\n    15→KEEP_LOGS=false\n    16→if [[ \"${1:-}\" == \"--keep-logs\" ]]; then\n    17→  KEEP_LOGS=true\n    18→fi\n    19→\n    20→CLEANED=false\n    21→\n    22→# ── Stop validator by PID file ───────────────────────────────────────\n    23→if [[ -f \"$PID_FILE\" ]]; then\n    24→  PID=$(cat \"$PID_FILE\")\n    25→  if kill -0 \"$PID\" 2>/dev/null; then\n    26→    echo \"Stopping validator (PID $PID)...\"\n    27→    kill \"$PID\" 2>/dev/null || true\n    28→    # Wait up to 5s for graceful shutdown\n    29→    for _ in $(seq 1 10); do\n    30→      if ! kill -0 \"$PID\" 2>/dev/null; then\n    31→        break\n    32→      fi\n    33→      sleep 0.5\n    34→    done\n    35→    # Force kill if still running\n    36→    if kill -0 \"$PID\" 2>/dev/null; then\n    37→      echo \"Force-killing validator (PID $PID)...\"\n    38→      kill -9 \"$PID\" 2>/dev/null || true\n    39→    fi\n    40→    CLEANED=true\n    41→  fi\n    42→  rm -f \"$PID_FILE\"\n    43→fi\n    44→\n    45→# ── Kill any stray validator on port 8899 ────────────────────────────\n    46→if command -v lsof &>/dev/null && lsof -ti :8899 &>/dev/null; then\n    47→  STRAY_PID=$(lsof -ti :8899)\n    48→  echo \"Killing stray process on port 8899 (PID $STRAY_PID)...\"\n    49→  kill \"$STRAY_PID\" 2>/dev/null || true\n    50→  sleep 1\n    51→  kill -9 \"$STRAY_PID\" 2>/dev/null || true\n    52→  CLEANED=true\n    53→fi\n    54→\n    55→# ── Clean temp ledger ────────────────────────────────────────────────\n    56→if [[ -d \"$LEDGER_DIR\" ]]; then\n    57→  echo \"Removing ledger directory: $LEDGER_DIR\"\n    58→  rm -rf \"$LEDGER_DIR\"\n    59→  CLEANED=true\n    60→fi\n    61→\n    62→# ── Clean log file (unless --keep-logs) ──────────────────────────────\n    63→if [[ \"$KEEP_LOGS\" == false && -f \"$LOG_FILE\" ]]; then\n    64→  echo \"Removing log file: $LOG_FILE\"\n    65→  rm -f \"$LOG_FILE\"\n    66→  CLEANED=true\n    67→fi\n    68→\n    69→if [[ \"$CLEANED\" == true ]]; then\n    70→  echo \"Localnet teardown complete.\"\n    71→else\n    72→  echo \"Nothing to clean up (no running validator or temp files found).\"\n    73→fi\n    74→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"44f2c44d-f581-46ea-9b9f-667661153d4a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/scripts/localnet-teardown.sh","content":"#!/usr/bin/env bash\n# localnet-teardown.sh — Stop solana-test-validator and clean temp files.\n# Usage: ./scripts/localnet-teardown.sh [--keep-logs]\n# Reads PID from .localnet.pid (written by localnet-bootstrap.sh).\n# Safe to call multiple times or when no validator is running.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nPLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n\nPID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\nLEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\nLOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n\nKEEP_LOGS=false\nif [[ \"${1:-}\" == \"--keep-logs\" ]]; then\n  KEEP_LOGS=true\nfi\n\nCLEANED=false\n\n# ── Stop validator by PID file ───────────────────────────────────────\nif [[ -f \"$PID_FILE\" ]]; then\n  PID=$(cat \"$PID_FILE\")\n  if kill -0 \"$PID\" 2>/dev/null; then\n    echo \"Stopping validator (PID $PID)...\"\n    kill \"$PID\" 2>/dev/null || true\n    # Wait up to 5s for graceful shutdown\n    for _ in $(seq 1 10); do\n      if ! kill -0 \"$PID\" 2>/dev/null; then\n        break\n      fi\n      sleep 0.5\n    done\n    # Force kill if still running\n    if kill -0 \"$PID\" 2>/dev/null; then\n      echo \"Force-killing validator (PID $PID)...\"\n      kill -9 \"$PID\" 2>/dev/null || true\n    fi\n    CLEANED=true\n  fi\n  rm -f \"$PID_FILE\"\nfi\n\n# ── Kill any stray validator on port 8899 ────────────────────────────\nif command -v lsof &>/dev/null && lsof -ti :8899 &>/dev/null; then\n  STRAY_PID=$(lsof -ti :8899)\n  echo \"Killing stray process on port 8899 (PID $STRAY_PID)...\"\n  kill \"$STRAY_PID\" 2>/dev/null || true\n  sleep 1\n  kill -9 \"$STRAY_PID\" 2>/dev/null || true\n  CLEANED=true\nfi\n\n# ── Clean temp ledger ────────────────────────────────────────────────\nif [[ -d \"$LEDGER_DIR\" ]]; then\n  echo \"Removing ledger directory: $LEDGER_DIR\"\n  rm -rf \"$LEDGER_DIR\"\n  CLEANED=true\nfi\n\n# ── Clean log file (unless --keep-logs) ──────────────────────────────\nif [[ \"$KEEP_LOGS\" == false && -f \"$LOG_FILE\" ]]; then\n  echo \"Removing log file: $LOG_FILE\"\n  rm -f \"$LOG_FILE\"\n  CLEANED=true\nfi\n\nif [[ \"$CLEANED\" == true ]]; then\n  echo \"Localnet teardown complete.\"\nelse\n  echo \"Nothing to clean up (no running validator or temp files found).\"\nfi\n","numLines":74,"startLine":1,"totalLines":74}}}
