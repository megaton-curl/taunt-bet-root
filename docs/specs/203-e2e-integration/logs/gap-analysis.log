{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HGetk4mP9LvR2n1qHF5vaS","type":"tool_result","content":"     1→/**\n     2→ * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. Connects to deployed devnet programs with\n     6→ * real Orao VRF fulfillment (no mock resolve shortcut).\n     7→ *\n     8→ * Prerequisites:\n     9→ * - Coinflip + Platform programs deployed to devnet\n    10→ * - Orao VRF initialized on devnet\n    11→ * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n    12→ * - Test wallets funded on devnet (handled in beforeAll)\n    13→ */\n    14→import { test, expect } from \"./fixtures\";\n    15→import * as po from \"../local/helpers/page-objects\";\n    16→import { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\n    17→import { validateDevnetEnv } from \"./helpers/env\";\n    18→import {\n    19→  pollVrfFulfillment,\n    20→  logRecentSignatures,\n    21→} from \"./helpers/vrf-polling\";\n    22→import {\n    23→  assertMatchCreated,\n    24→  assertMatchClosed,\n    25→  assertTreasuryFee,\n    26→  assertPlayerProfileDelta,\n    27→  calculateExpectedFee,\n    28→  getTreasuryAddress,\n    29→  snapshotBalance,\n    30→  snapshotPlayerProfile,\n    31→} from \"../local/helpers/on-chain\";\n    32→import { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n    33→\n    34→// ── Devnet wallet funding ─────────────────────────────────────────────\n    35→\n    36→/** Minimum SOL balance required to run the test (entry + tx fees). */\n    37→const MIN_BALANCE_SOL = 0.1;\n    38→\n    39→/** Airdrop amount per request on devnet (max 2 SOL per request). */\n    40→const AIRDROP_SOL = 1;\n    41→\n    42→/**\n    43→ * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n    44→ * is below the minimum threshold. Retries once on failure (devnet rate limits).\n    45→ */\n    46→async function ensureFunded(\n    47→  connection: Connection,\n    48→  pubkey: PublicKey,\n    49→  label: string,\n    50→): Promise<void> {\n    51→  const balance = await connection.getBalance(pubkey);\n    52→  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    53→    console.log(\n    54→      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    55→    );\n    56→    return;\n    57→  }\n    58→\n    59→  console.log(\n    60→    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n    61→  );\n    62→\n    63→  for (let attempt = 1; attempt <= 2; attempt++) {\n    64→    try {\n    65→      const sig = await connection.requestAirdrop(\n    66→        pubkey,\n    67→        AIRDROP_SOL * LAMPORTS_PER_SOL,\n    68→      );\n    69→      const { blockhash, lastValidBlockHeight } =\n    70→        await connection.getLatestBlockhash();\n    71→      await connection.confirmTransaction(\n    72→        { signature: sig, blockhash, lastValidBlockHeight },\n    73→        \"confirmed\",\n    74→      );\n    75→      const newBalance = await connection.getBalance(pubkey);\n    76→      console.log(\n    77→        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n    78→      );\n    79→      return;\n    80→    } catch (err) {\n    81→      if (attempt < 2) {\n    82→        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n    83→        await new Promise((r) => setTimeout(r, 2_000));\n    84→      } else {\n    85→        throw new Error(\n    86→          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n    87→        );\n    88→      }\n    89→    }\n    90→  }\n    91→}\n    92→\n    93→// ── On-chain constants ───────────────────────────────────────────────\n    94→\n    95→/** Iron tier index. */\n    96→const TIER_IRON = 0;\n    97→\n    98→/** Heads side index. */\n    99→const SIDE_HEADS = 0;\n   100→\n   101→/** Iron tier entry amount in lamports (0.005 SOL). */\n   102→const ENTRY_AMOUNT = 5_000_000;\n   103→\n   104→// ── VRF fulfillment timeout ───────────────────────────────────────────\n   105→\n   106→/**\n   107→ * Timeout for waiting on real VRF fulfillment.\n   108→ * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n   109→ */\n   110→const VRF_FULFILLMENT_TIMEOUT = 90_000;\n   111→\n   112→// ── Suite setup ────────────────────────────────────────────────────────\n   113→\n   114→test.beforeAll(async () => {\n   115→  const config = validateDevnetEnv();\n   116→  console.log(\"Devnet lifecycle: funding test wallets...\");\n   117→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n   118→  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n   119→  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n   120→});\n   121→\n   122→// ── Full lifecycle test ────────────────────────────────────────────────\n   123→\n   124→test(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n   125→  playerAPage,\n   126→  playerBPage,\n   127→  connection,\n   128→}) => {\n   129→  // Track console errors in both contexts\n   130→  const consoleA = po.trackConsoleErrors(playerAPage);\n   131→  const consoleB = po.trackConsoleErrors(playerBPage);\n   132→\n   133→  // 1. Player A navigates and creates a match (iron tier, heads)\n   134→  await po.navigateToCoinflip(playerAPage);\n   135→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n   136→\n   137→  // Player A should see the active match in \"waiting\" state\n   138→  await expect(\n   139→    playerAPage.locator(po.sel.activeMatchWaiting),\n   140→  ).toBeVisible({ timeout: 15_000 });\n   141→\n   142→  // On-chain: verify match PDA state after creation\n   143→  const { matchPda } = await assertMatchCreated(\n   144→    connection,\n   145→    PLAYER_A.publicKey,\n   146→    TIER_IRON,\n   147→    SIDE_HEADS,\n   148→  );\n   149→  console.log(`[on-chain] Match PDA verified: ${matchPda.toBase58()}`);\n   150→\n   151→  // 2. Player B navigates (after match is created) and sees it in the lobby\n   152→  await po.navigateToCoinflip(playerBPage);\n   153→  await po.waitForLobbyMatch(playerBPage, 30_000);\n   154→\n   155→  // 3. Player B joins the match\n   156→  await po.joinMatch(playerBPage);\n   157→\n   158→  // On-chain: snapshot treasury and player profiles before resolution\n   159→  const treasury = await getTreasuryAddress(connection);\n   160→  const [treasuryBefore, profileABefore, profileBBefore] = await Promise.all([\n   161→    snapshotBalance(connection, treasury),\n   162→    snapshotPlayerProfile(connection, PLAYER_A.publicKey),\n   163→    snapshotPlayerProfile(connection, PLAYER_B.publicKey),\n   164→  ]);\n   165→  console.log(\n   166→    `[on-chain] Pre-claim snapshots: treasury=${treasuryBefore}, ` +\n   167→      `profileA=(games=${profileABefore.totalGames},wins=${profileABefore.wins}), ` +\n   168→      `profileB=(games=${profileBBefore.totalGames},wins=${profileBBefore.wins})`,\n   169→  );\n   170→\n   171→  // 4. Wait for real VRF fulfillment using dual strategy:\n   172→  //    a) On-chain polling with exponential backoff (detects VRF callback)\n   173→  //    b) UI result wait in parallel (detects frontend state update)\n   174→  //    Whichever resolves first wins — this ensures robustness even if\n   175→  //    the UI polling cycle is slow.\n   176→  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n   177→  const vrfStartTime = Date.now();\n   178→\n   179→  const [vrfPollResult, resultA, resultB] = await Promise.all([\n   180→    // On-chain poll: check match PDA phase with exponential backoff\n   181→    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n   182→      .then((r) => {\n   183→        console.log(\n   184→          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n   185→        );\n   186→        return r;\n   187→      })\n   188→      .catch((err) => {\n   189→        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n   190→        return null; // Don't fail test if UI detects it first\n   191→      }),\n   192→    // UI wait: Playwright waits for result CSS class on Player A's page\n   193→    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n   194→    // UI wait: Playwright waits for result CSS class on Player B's page\n   195→    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n   196→  ]);\n   197→\n   198→  const vrfElapsed = Date.now() - vrfStartTime;\n   199→  console.log(\n   200→    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n   201→  );\n   202→  if (vrfPollResult) {\n   203→    console.log(\n   204→      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n   205→    );\n   206→  }\n   207→\n   208→  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n   209→  expect(\n   210→    (resultA === \"won\" && resultB === \"lost\") ||\n   211→      (resultA === \"lost\" && resultB === \"won\"),\n   212→  ).toBe(true);\n   213→\n   214→  // 6. Winner claims payout\n   215→  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n   216→  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n   217→  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n   218→\n   219→  await po.claimOrSettle(winnerPage);\n   220→  console.log(`${winnerLabel} claimed payout`);\n   221→\n   222→  // Winner sees \"Back to Lobby\" after successful claim\n   223→  await expect(\n   224→    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   225→  ).toBeVisible({ timeout: 15_000 });\n   226→\n   227→  // 7. On-chain: verify match PDA is closed after claim\n   228→  await assertMatchClosed(connection, matchPda);\n   229→  console.log(\"[on-chain] Match PDA closed after claim\");\n   230→\n   231→  // 8. On-chain: verify treasury received expected fee\n   232→  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n   233→  const { fee, payout } = calculateExpectedFee(ENTRY_AMOUNT);\n   234→  console.log(`[on-chain] Treasury fee verified: ${fee} lamports`);\n   235→\n   236→  // 9. On-chain: verify player profile deltas\n   237→  const winnerKey = resultA === \"won\" ? PLAYER_A.publicKey : PLAYER_B.publicKey;\n   238→  const loserKey = resultA === \"lost\" ? PLAYER_A.publicKey : PLAYER_B.publicKey;\n   239→  const winnerProfileBefore = resultA === \"won\" ? profileABefore : profileBBefore;\n   240→  const loserProfileBefore = resultA === \"lost\" ? profileABefore : profileBBefore;\n   241→\n   242→  await assertPlayerProfileDelta(connection, winnerKey, winnerProfileBefore, {\n   243→    totalGames: 1,\n   244→    wins: 1,\n   245→    totalWagered: ENTRY_AMOUNT,\n   246→    totalWon: payout,\n   247→  });\n   248→  console.log(`[on-chain] Winner profile delta verified (${winnerLabel})`);\n   249→\n   250→  await assertPlayerProfileDelta(connection, loserKey, loserProfileBefore, {\n   251→    totalGames: 1,\n   252→    wins: 0,\n   253→    totalWagered: ENTRY_AMOUNT,\n   254→    totalWon: 0,\n   255→  });\n   256→  const loserLabel = resultA === \"lost\" ? \"Player A\" : \"Player B\";\n   257→  console.log(`[on-chain] Loser profile delta verified (${loserLabel})`);\n   258→\n   259→  // 10. Winner returns to lobby\n   260→  await po.backToLobby(winnerPage);\n   261→\n   262→  // 11. Loser settles (closes their view)\n   263→  await po.claimOrSettle(loserPage);\n   264→  await expect(\n   265→    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   266→  ).toBeVisible({ timeout: 15_000 });\n   267→  await po.backToLobby(loserPage);\n   268→\n   269→  // 12. Log transaction signatures for both players (diagnostic artifact)\n   270→  console.log(\"\\n--- Transaction Signature Log ---\");\n   271→  await logRecentSignatures(connection, PLAYER_A.publicKey, `Player A (${resultA})`);\n   272→  await logRecentSignatures(connection, PLAYER_B.publicKey, `Player B (${resultB})`);\n   273→\n   274→  // No unhandled console errors in either context\n   275→  consoleA.assertClean();\n   276→  consoleB.assertClean();\n   277→});\n   278→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"11a9db93-71e5-4f06-8f8b-0131bacba2de","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts","content":"/**\n * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. Connects to deployed devnet programs with\n * real Orao VRF fulfillment (no mock resolve shortcut).\n *\n * Prerequisites:\n * - Coinflip + Platform programs deployed to devnet\n * - Orao VRF initialized on devnet\n * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n * - Test wallets funded on devnet (handled in beforeAll)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"../local/helpers/page-objects\";\nimport { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\nimport { validateDevnetEnv } from \"./helpers/env\";\nimport {\n  pollVrfFulfillment,\n  logRecentSignatures,\n} from \"./helpers/vrf-polling\";\nimport {\n  assertMatchCreated,\n  assertMatchClosed,\n  assertTreasuryFee,\n  assertPlayerProfileDelta,\n  calculateExpectedFee,\n  getTreasuryAddress,\n  snapshotBalance,\n  snapshotPlayerProfile,\n} from \"../local/helpers/on-chain\";\nimport { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n\n// ── Devnet wallet funding ─────────────────────────────────────────────\n\n/** Minimum SOL balance required to run the test (entry + tx fees). */\nconst MIN_BALANCE_SOL = 0.1;\n\n/** Airdrop amount per request on devnet (max 2 SOL per request). */\nconst AIRDROP_SOL = 1;\n\n/**\n * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n * is below the minimum threshold. Retries once on failure (devnet rate limits).\n */\nasync function ensureFunded(\n  connection: Connection,\n  pubkey: PublicKey,\n  label: string,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    console.log(\n      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    );\n    return;\n  }\n\n  console.log(\n    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n  );\n\n  for (let attempt = 1; attempt <= 2; attempt++) {\n    try {\n      const sig = await connection.requestAirdrop(\n        pubkey,\n        AIRDROP_SOL * LAMPORTS_PER_SOL,\n      );\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      await connection.confirmTransaction(\n        { signature: sig, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      const newBalance = await connection.getBalance(pubkey);\n      console.log(\n        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n      );\n      return;\n    } catch (err) {\n      if (attempt < 2) {\n        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n        await new Promise((r) => setTimeout(r, 2_000));\n      } else {\n        throw new Error(\n          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n        );\n      }\n    }\n  }\n}\n\n// ── On-chain constants ───────────────────────────────────────────────\n\n/** Iron tier index. */\nconst TIER_IRON = 0;\n\n/** Heads side index. */\nconst SIDE_HEADS = 0;\n\n/** Iron tier entry amount in lamports (0.005 SOL). */\nconst ENTRY_AMOUNT = 5_000_000;\n\n// ── VRF fulfillment timeout ───────────────────────────────────────────\n\n/**\n * Timeout for waiting on real VRF fulfillment.\n * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n */\nconst VRF_FULFILLMENT_TIMEOUT = 90_000;\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  const config = validateDevnetEnv();\n  console.log(\"Devnet lifecycle: funding test wallets...\");\n  const connection = new Connection(config.rpcUrl, \"confirmed\");\n  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // On-chain: verify match PDA state after creation\n  const { matchPda } = await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    TIER_IRON,\n    SIDE_HEADS,\n  );\n  console.log(`[on-chain] Match PDA verified: ${matchPda.toBase58()}`);\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 30_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // On-chain: snapshot treasury and player profiles before resolution\n  const treasury = await getTreasuryAddress(connection);\n  const [treasuryBefore, profileABefore, profileBBefore] = await Promise.all([\n    snapshotBalance(connection, treasury),\n    snapshotPlayerProfile(connection, PLAYER_A.publicKey),\n    snapshotPlayerProfile(connection, PLAYER_B.publicKey),\n  ]);\n  console.log(\n    `[on-chain] Pre-claim snapshots: treasury=${treasuryBefore}, ` +\n      `profileA=(games=${profileABefore.totalGames},wins=${profileABefore.wins}), ` +\n      `profileB=(games=${profileBBefore.totalGames},wins=${profileBBefore.wins})`,\n  );\n\n  // 4. Wait for real VRF fulfillment using dual strategy:\n  //    a) On-chain polling with exponential backoff (detects VRF callback)\n  //    b) UI result wait in parallel (detects frontend state update)\n  //    Whichever resolves first wins — this ensures robustness even if\n  //    the UI polling cycle is slow.\n  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n  const vrfStartTime = Date.now();\n\n  const [vrfPollResult, resultA, resultB] = await Promise.all([\n    // On-chain poll: check match PDA phase with exponential backoff\n    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n      .then((r) => {\n        console.log(\n          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n        );\n        return r;\n      })\n      .catch((err) => {\n        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n        return null; // Don't fail test if UI detects it first\n      }),\n    // UI wait: Playwright waits for result CSS class on Player A's page\n    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n    // UI wait: Playwright waits for result CSS class on Player B's page\n    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n  ]);\n\n  const vrfElapsed = Date.now() - vrfStartTime;\n  console.log(\n    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n  );\n  if (vrfPollResult) {\n    console.log(\n      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n    );\n  }\n\n  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n  expect(\n    (resultA === \"won\" && resultB === \"lost\") ||\n      (resultA === \"lost\" && resultB === \"won\"),\n  ).toBe(true);\n\n  // 6. Winner claims payout\n  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n\n  await po.claimOrSettle(winnerPage);\n  console.log(`${winnerLabel} claimed payout`);\n\n  // Winner sees \"Back to Lobby\" after successful claim\n  await expect(\n    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 7. On-chain: verify match PDA is closed after claim\n  await assertMatchClosed(connection, matchPda);\n  console.log(\"[on-chain] Match PDA closed after claim\");\n\n  // 8. On-chain: verify treasury received expected fee\n  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n  const { fee, payout } = calculateExpectedFee(ENTRY_AMOUNT);\n  console.log(`[on-chain] Treasury fee verified: ${fee} lamports`);\n\n  // 9. On-chain: verify player profile deltas\n  const winnerKey = resultA === \"won\" ? PLAYER_A.publicKey : PLAYER_B.publicKey;\n  const loserKey = resultA === \"lost\" ? PLAYER_A.publicKey : PLAYER_B.publicKey;\n  const winnerProfileBefore = resultA === \"won\" ? profileABefore : profileBBefore;\n  const loserProfileBefore = resultA === \"lost\" ? profileABefore : profileBBefore;\n\n  await assertPlayerProfileDelta(connection, winnerKey, winnerProfileBefore, {\n    totalGames: 1,\n    wins: 1,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: payout,\n  });\n  console.log(`[on-chain] Winner profile delta verified (${winnerLabel})`);\n\n  await assertPlayerProfileDelta(connection, loserKey, loserProfileBefore, {\n    totalGames: 1,\n    wins: 0,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: 0,\n  });\n  const loserLabel = resultA === \"lost\" ? \"Player A\" : \"Player B\";\n  console.log(`[on-chain] Loser profile delta verified (${loserLabel})`);\n\n  // 10. Winner returns to lobby\n  await po.backToLobby(winnerPage);\n\n  // 11. Loser settles (closes their view)\n  await po.claimOrSettle(loserPage);\n  await expect(\n    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n  await po.backToLobby(loserPage);\n\n  // 12. Log transaction signatures for both players (diagnostic artifact)\n  console.log(\"\\n--- Transaction Signature Log ---\");\n  await logRecentSignatures(connection, PLAYER_A.publicKey, `Player A (${resultA})`);\n  await logRecentSignatures(connection, PLAYER_B.publicKey, `Player B (${resultB})`);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","numLines":278,"startLine":1,"totalLines":278}}}
