moke\", () => {\n  test(\"app loads in real mode against local validator\", async ({\n    playerAPage,\n  }) => {\n    const consoleTracker = po.trackConsoleErrors(playerAPage);\n\n    await playerAPage.goto(\"/\", { waitUntil: \"networkidle\" });\n\n    // App renders the main title\n    await expect(playerAPage.locator(\".rpg-title\")).toBeVisible({\n      timeout: 10_000,\n    });\n\n    // Wallet icon is visible\n    await expect(playerAPage.locator(\".rpg-wallet-icon\")).toBeVisible();\n\n    // No critical console errors\n    consoleTracker.assertClean();\n  });\n});\n","numLines":31,"startLine":1,"totalLines":31}}}
