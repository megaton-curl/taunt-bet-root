   timeout: 30_000,\n    52→    env: {\n    53→      VITE_MOCK_MODE: \"false\",\n    54→      VITE_TEST_WALLET: \"true\",\n    55→      // RPC URL and program IDs are inherited from the process environment.\n    56→      // They must be set before running this config (see env.ts validation).\n    57→      // VITE_SOLANA_NETWORK defaults to \"devnet\" in the app if not set.\n    58→    },\n    59→  },\n    60→});\n    61→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"1c2c5791-ed4d-4fb7-956a-0e43bf560877","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/playwright.devnet.config.ts","content":"import { defineConfig, devices } from \"@playwright/test\";\n\n/**\n * Playwright config for devnet E2E integration tests.\n *\n * Runs against deployed devnet contracts with real VRF fulfillment.\n * Does NOT start a local validator or deploy programs — requires\n * pre-deployed contracts and env vars (see e2e/devnet/helpers/env.ts).\n *\n * Required env vars (set before running, or in .env.devnet):\n *   VITE_RPC_URL                — Devnet RPC endpoint\n *   VITE_COINFLIP_PROGRAM_ID   — Deployed coinflip program address\n *   VITE_PLATFORM_PROGRAM_ID   — Deployed platform program address\n *\n * Optional:\n *   VITE_SOLANA_NETWORK        — Cluster name (default: \"devnet\")\n */\nexport default defineConfig({\n  testDir: \"./e2e\",\n  fullyParallel: false,\n  forbidOnly: !!process.env.CI,\n  retries: 0,\n  workers: 1,\n  reporter: \"list\",\n  // Longer timeout: real VRF fulfillment can take 30–60+ seconds\n  timeout: 120_000,\n\n  use: {\n    baseURL: \"http://localhost:3003\",\n    screenshot: \"off\",\n    trace: \"retain-on-failure\",\n    ...devices[\"Desktop Chrome\"],\n    viewport: { width: 1280, height: 1080 },\n  },\n\n  projects: [\n    {\n      name: \"devnet-e2e\",\n      testMatch: \"devnet/**/*.spec.ts\",\n      use: {\n        ...devices[\"Desktop Chrome\"],\n        viewport: { width: 1280, height: 1080 },\n      },\n    },\n  ],\n\n  webServer: {\n    command: \"npx vite --port 3003\",\n    url: \"http://localhost:3003\",\n    reuseExistingServer: !process.env.CI,\n    timeout: 30_000,\n    env: {\n      VITE_MOCK_MODE: \"false\",\n      VITE_TEST_WALLET: \"true\",\n      // RPC URL and program IDs are inherited from the process environment.\n      // They must be set before running this config (see env.ts validation).\n      // VITE_SOLANA_NETWORK defaults to \"devnet\" in the app if not set.\n    },\n  },\n});\n","numLines":61,"startLine":1,"totalLines":61}}}
