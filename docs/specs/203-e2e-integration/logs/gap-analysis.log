{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FFbu5wahw1VBTeqBWM4ZkS","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# run-e2e-devnet.sh — Single-entrypoint for devnet E2E tests.\n     3→# Runs Playwright tests against deployed devnet contracts with real VRF.\n     4→# No local validator bootstrap/teardown — requires pre-deployed programs.\n     5→set -euo pipefail\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n     8→APP_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     9→\n    10→# --- Env validation (fast-fail before starting Vite) ---\n    11→MISSING=()\n    12→[ -z \"${VITE_RPC_URL:-}\" ] && MISSING+=(\"VITE_RPC_URL\")\n    13→[ -z \"${VITE_COINFLIP_PROGRAM_ID:-}\" ] && MISSING+=(\"VITE_COINFLIP_PROGRAM_ID\")\n    14→[ -z \"${VITE_PLATFORM_PROGRAM_ID:-}\" ] && MISSING+=(\"VITE_PLATFORM_PROGRAM_ID\")\n    15→\n    16→if [ ${#MISSING[@]} -gt 0 ]; then\n    17→  echo \"❌ Missing required env vars for devnet E2E: ${MISSING[*]}\"\n    18→  echo \"   Set them in your shell or in a .env.devnet file.\"\n    19→  exit 1\n    20→fi\n    21→\n    22→echo \"==> Devnet E2E config:\"\n    23→echo \"    RPC_URL:              $VITE_RPC_URL\"\n    24→echo \"    COINFLIP_PROGRAM_ID:  $VITE_COINFLIP_PROGRAM_ID\"\n    25→echo \"    PLATFORM_PROGRAM_ID:  $VITE_PLATFORM_PROGRAM_ID\"\n    26→echo \"    NETWORK:              ${VITE_SOLANA_NETWORK:-devnet}\"\n    27→\n    28→# --- Run tests ---\n    29→echo \"==> Running devnet E2E tests…\"\n    30→cd \"$APP_DIR\" && npx playwright test --config playwright.devnet.config.ts\n    31→\n    32→echo \"✅ Devnet E2E tests passed\"\n    33→"}]},"parent_tool_use_id":null,"session_id":"6e756669-5013-49f4-827b-46f540129d9e","uuid":"1083bbb1-e9aa-4516-a348-3a26fa9c8bc2","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/scripts/run-e2e-devnet.sh","content":"#!/usr/bin/env bash\n# run-e2e-devnet.sh — Single-entrypoint for devnet E2E tests.\n# Runs Playwright tests against deployed devnet contracts with real VRF.\n# No local validator bootstrap/teardown — requires pre-deployed programs.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nAPP_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n\n# --- Env validation (fast-fail before starting Vite) ---\nMISSING=()\n[ -z \"${VITE_RPC_URL:-}\" ] && MISSING+=(\"VITE_RPC_URL\")\n[ -z \"${VITE_COINFLIP_PROGRAM_ID:-}\" ] && MISSING+=(\"VITE_COINFLIP_PROGRAM_ID\")\n[ -z \"${VITE_PLATFORM_PROGRAM_ID:-}\" ] && MISSING+=(\"VITE_PLATFORM_PROGRAM_ID\")\n\nif [ ${#MISSING[@]} -gt 0 ]; then\n  echo \"❌ Missing required env vars for devnet E2E: ${MISSING[*]}\"\n  echo \"   Set them in your shell or in a .env.devnet file.\"\n  exit 1\nfi\n\necho \"==> Devnet E2E config:\"\necho \"    RPC_URL:              $VITE_RPC_URL\"\necho \"    COINFLIP_PROGRAM_ID:  $VITE_COINFLIP_PROGRAM_ID\"\necho \"    PLATFORM_PROGRAM_ID:  $VITE_PLATFORM_PROGRAM_ID\"\necho \"    NETWORK:              ${VITE_SOLANA_NETWORK:-devnet}\"\n\n# --- Run tests ---\necho \"==> Running devnet E2E tests…\"\ncd \"$APP_DIR\" && npx playwright test --config playwright.devnet.config.ts\n\necho \"✅ Devnet E2E tests passed\"\n","numLines":33,"startLine":1,"totalLines":33}}}
