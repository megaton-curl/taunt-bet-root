nMatch(t);\n   763→      setMockRandomness(t, RANDOMNESS_TAILS);\n   764→\n   765→      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n   766→\n   767→      const pool = TIER_IRON_AMOUNT * 2;\n   768→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   769→      const payout = pool - fee;\n   770→\n   771→      const cp = await t.platformProgram.account.playerProfile.fetch(\n   772→        t.creatorProfilePda\n   773→      );\n   774→      expect(cp.totalGames.toNumber()).to.equal(1);\n   775→      expect(cp.wins.toNumber()).to.equal(0);\n   776→      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   777→      expect(cp.totalWon.toNumber()).to.equal(0);\n   778→\n   779→      const op = await t.platformProgram.account.playerProfile.fetch(\n   780→        t.opponentProfilePda\n   781→      );\n   782→      expect(op.totalGames.toNumber()).to.equal(1);\n   783→      expect(op.wins.toNumber()).to.equal(1);\n   784→      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   785→      expect(op.totalWon.toNumber()).to.equal(payout);\n   786→    });\n   787→  });\n   788→\n   789→  // -----------------------------------------------------------------------\n   790→  // cancel_match\n   791→  // -----------------------------------------------------------------------\n   792→  describe(\"cancel_match\", () => {\n   793→    it(\"creator cancels Waiting match, full refund\", async () => {\n   794→      const t = await createTestContext();\n   795→      await initConfig(t);\n   796→      await createMatch(t);\n   797→\n   798→      const balanceBefore = await getBalance(t, t.creator);\n   799→      await cancelMatch(t);"}]},"parent_tool_use_id":null,"session_id":"6f57423d-52bf-4b79-9edb-534166a03339","uuid":"549a7324-d6fd-4c70-a4ef-61a71fde7523","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/solana/tests/coinflip.ts","content":"        expect((err as AnchorError).error.errorCode.code).to.equal(\n          \"UnauthorizedCaller\"\n        );\n      }\n    });\n\n    it(\"updates player profiles via CPI — creator wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      setMockRandomness(t, RANDOMNESS_HEADS);\n\n      await claimPayout(t, t.creatorProgram, t.creator);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const cp = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(cp.totalGames.toNumber()).to.equal(1);\n      expect(cp.wins.toNumber()).to.equal(1);\n      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(cp.totalWon.toNumber()).to.equal(payout);\n\n      const op = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(op.totalGames.toNumber()).to.equal(1);\n      expect(op.wins.toNumber()).to.equal(0);\n      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(op.totalWon.toNumber()).to.equal(0);\n    });\n\n    it(\"updates player profiles via CPI — opponent wins\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await setupPlatform(t);\n      await createMatch(t, TIER_IRON, SIDE_HEADS);\n      await joinMatch(t);\n      setMockRandomness(t, RANDOMNESS_TAILS);\n\n      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n\n      const pool = TIER_IRON_AMOUNT * 2;\n      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n      const payout = pool - fee;\n\n      const cp = await t.platformProgram.account.playerProfile.fetch(\n        t.creatorProfilePda\n      );\n      expect(cp.totalGames.toNumber()).to.equal(1);\n      expect(cp.wins.toNumber()).to.equal(0);\n      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(cp.totalWon.toNumber()).to.equal(0);\n\n      const op = await t.platformProgram.account.playerProfile.fetch(\n        t.opponentProfilePda\n      );\n      expect(op.totalGames.toNumber()).to.equal(1);\n      expect(op.wins.toNumber()).to.equal(1);\n      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n      expect(op.totalWon.toNumber()).to.equal(payout);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // cancel_match\n  // -----------------------------------------------------------------------\n  describe(\"cancel_match\", () => {\n    it(\"creator cancels Waiting match, full refund\", async () => {\n      const t = await createTestContext();\n      await initConfig(t);\n      await createMatch(t);\n\n      const balanceBefore = await getBalance(t, t.creator);\n      await cancelMatch(t);","numLines":80,"startLine":720,"totalLines":1011}}}
