{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014VLHnpDWe8hb9JtuFJ3pt6","type":"tool_result","content":"     1→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     2→import {\n     3→  Connection,\n     4→  PublicKey,\n     5→  SystemProgram,\n     6→  Transaction,\n     7→} from \"@solana/web3.js\";\n     8→import { CoinflipIDL, type Coinflip } from \"@rng-utopia/anchor-client\";\n     9→import {\n    10→  TIER_VALUES,\n    11→  COIN_SIDE_VALUES,\n    12→  TIER_AMOUNTS,\n    13→  type Tier,\n    14→  type CoinSide,\n    15→} from \"@rng-utopia/game-engine/browser\";\n    16→import type { UIMatch } from \"../types\";\n    17→\n    18→// ============ Constants ============\n    19→\n    20→const COINFLIP_PROGRAM_ID = new PublicKey(\n    21→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    22→    .VITE_COINFLIP_PROGRAM_ID ?? CoinflipIDL.address\n    23→);\n    24→\n    25→// Orao VRF program (on-chain VRF provider)\n    26→const ORAO_VRF_PROGRAM_ID = new PublicKey(\"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\");\n    27→\n    28→// ============ PDA Derivation ============\n    29→\n    30→export function getMatchPda(creator: PublicKey): [PublicKey, number] {\n    31→  return PublicKey.findProgramAddressSync(\n    32→    [Buffer.from(\"match\"), creator.toBuffer()],\n    33→    COINFLIP_PROGRAM_ID\n    34→  );\n    35→}\n    36→\n    37→export function getConfigPda(): [PublicKey, number] {\n    38→  return PublicKey.findProgramAddressSync(\n    39→    [Buffer.from(\"coinflip_config\")],\n    40→    COINFLIP_PROGRAM_ID\n    41→  );\n    42→}\n    43→\n    44→/** Orao VRF network state PDA (stores config + treasury). */\n    45→function getOraoNetworkStatePda(): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"orao-vrf-network-configuration\")],\n    48→    ORAO_VRF_PROGRAM_ID\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→/** Orao VRF randomness PDA derived from a 32-byte seed. */\n    54→function getOraoRandomnessPda(seed: Uint8Array): PublicKey {\n    55→  const [pda] = PublicKey.findProgramAddressSync(\n    56→    [Buffer.from(\"orao-vrf-randomness-request\"), seed],\n    57→    ORAO_VRF_PROGRAM_ID\n    58→  );\n    59→  return pda;\n    60→}\n    61→\n    62→// ============ Program Instance ============\n    63→\n    64→function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    65→  // Read-only provider (no wallet needed for queries)\n    66→  const provider = new AnchorProvider(\n    67→    connection,\n    68→    {} as AnchorProvider[\"wallet\"],\n    69→    { commitment: \"confirmed\" }\n    70→  );\n    71→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    72→}\n    73→\n    74→// ============ On-Chain Account Types ============\n    75→\n    76→/** Anchor enum variant representation — one key with empty object value. */\n    77→type RoundPhaseVariant = { waiting: object } | { active: object } | { locked: object }\n    78→  | { resolving: object } | { settled: object } | { refunded: object };\n    79→\n    80→interface OnChainMatch {\n    81→  creator: PublicKey;\n    82→  opponent: PublicKey;\n    83→  tier: number;\n    84→  entryAmount: { toNumber(): number };\n    85→  creatorSide: number;\n    86→  phase: RoundPhaseVariant;\n    87→  result: number;\n    88→  winner: PublicKey;\n    89→  claimed: boolean;\n    90→  createdAt: { toNumber(): number };\n    91→  lockedAt: { toNumber(): number };\n    92→  resolveDeadline: { toNumber(): number };\n    93→  vrfRequestKey: PublicKey;\n    94→  bump: number;\n    95→}\n    96→\n    97→// ============ Converters ============\n    98→\n    99→function tierFromIndex(index: number): Tier {\n   100→  const tiers: Tier[] = [\"iron\", \"bronze\", \"silver\", \"gold\", \"platinum\", \"diamond\"];\n   101→  return tiers[index] ?? \"iron\";\n   102→}\n   103→\n   104→function sideFromIndex(index: number): CoinSide {\n   105→  return index === 0 ? \"heads\" : \"tails\";\n   106→}\n   107→\n   108→function isPhase(phase: RoundPhaseVariant, name: string): boolean {\n   109→  return name in phase;\n   110→}\n   111→\n   112→function phaseToUI(phase: RoundPhaseVariant): UIMatch[\"phase\"] {\n   113→  if (isPhase(phase, \"waiting\")) return \"created\";\n   114→  if (isPhase(phase, \"locked\")) return \"ready\";\n   115→  if (isPhase(phase, \"settled\")) return \"complete\";\n   116→  return \"created\";\n   117→}\n   118→\n   119→const DEFAULT_PUBKEY = PublicKey.default;\n   120→\n   121→function isDefaultPubkey(key: PublicKey): boolean {\n   122→  return key.equals(DEFAULT_PUBKEY);\n   123→}\n   124→\n   125→export function onChainMatchToUI(\n   126→  matchPda: PublicKey,\n   127→  data: OnChainMatch\n   128→): UIMatch {\n   129→  const tier = tierFromIndex(data.tier);\n   130→  const creatorSide = sideFromIndex(data.creatorSide);\n   131→  const hasOpponent = !isDefaultPubkey(data.opponent);\n   132→  const phase = phaseToUI(data.phase);\n   133→  const isSettled = isPhase(data.phase, \"settled\");\n   134→\n   135→  const entryAmountSol = TIER_AMOUNTS[tier];\n   136→  const totalPool = entryAmountSol * 2;\n   137→  const payoutAmount = totalPool * 0.97;\n   138→\n   139→  const lockedAt = data.lockedAt.toNumber();\n   140→\n   141→  return {\n   142→    id: matchPda.toBase58(),\n   143→    tier,\n   144→    entryAmount: entryAmountSol,\n   145→    player1: data.creator.toBase58(),\n   146→    player1Side: creatorSide,\n   147→    player2: hasOpponent ? data.opponent.toBase58() : null,\n   148→    player2Side: hasOpponent\n   149→      ? (creatorSide === \"heads\" ? \"tails\" : \"heads\")\n   150→      : null,\n   151→    phase,\n   152→    createdAt: Date.now(),\n   153→    lockedAt: lockedAt > 0 ? lockedAt * 1000 : undefined,\n   154→    result: isSettled ? sideFromIndex(data.result) : null,\n   155→    winner: isSettled && !isDefaultPubkey(data.winner)\n   156→      ? data.winner.toBase58()\n   157→      : null,\n   158→    claimed: data.claimed,\n   159→    payoutAmount,\n   160→    seedHash: \"\",\n   161→  };\n   162→}\n   163→\n   164→/** Check whether an Orao VRF randomness account has been fulfilled. */\n   165→async function isVrfFulfilled(\n   166→  connection: Connection,\n   167→  vrfRequestKey: PublicKey\n   168→): Promise<boolean> {\n   169→  try {\n   170→    if (isDefaultPubkey(vrfRequestKey)) return false;\n   171→    const vrfAccount = await connection.getAccountInfo(vrfRequestKey);\n   172→    if (vrfAccount && vrfAccount.data.length > 8) {\n   173→      // Orao randomness account: 8-byte discriminator then randomness data.\n   174→      const randomnessData = vrfAccount.data.subarray(8, 72);\n   175→      return randomnessData.some((b: number) => b !== 0);\n   176→    }\n   177→  } catch {\n   178→    // Ignore — treat as not fulfilled\n   179→  }\n   180→  return false;\n   181→}\n   182→\n   183→// ============ Account Queries ============\n   184→\n   185→export async function fetchAllOpenMatches(\n   186→  connection: Connection\n   187→): Promise<UIMatch[]> {\n   188→  const program = getCoinflipProgram(connection);\n   189→  const accounts = await program.account.coinflipMatch.all();\n   190→\n   191→  return accounts\n   192→    .filter((acc) => isPhase((acc.account as unknown as OnChainMatch).phase, \"waiting\"))\n   193→    .map((acc) =>\n   194→      onChainMatchToUI(\n   195→        acc.publicKey,\n   196→        acc.account as unknown as OnChainMatch\n   197→      )\n   198→    );\n   199→}\n   200→\n   201→/**\n   202→ * Fetch all matches where playerPubkey is creator OR opponent,\n   203→ * claimed == false, and phase is non-terminal (not refunded).\n   204→ * Uses memcmp filters for efficient on-chain filtering.\n   205→ *\n   206→ * Account layout offsets (after 8-byte discriminator):\n   207→ *   creator:  8   (32 bytes)\n   208→ *   opponent: 40  (32 bytes)\n   209→ *   claimed:  116 (1 byte — false=0x00, base58 \"1\")\n   210→ */\n   211→export async function fetchClaimableMatches(\n   212→  connection: Connection,\n   213→  playerPubkey: PublicKey\n   214→): Promise<UIMatch[]> {\n   215→  const program = getCoinflipProgram(connection);\n   216→  const playerBase58 = playerPubkey.toBase58();\n   217→\n   218→  // claimed == false: single byte 0x00, base58-encoded as \"1\"\n   219→  const claimedFalseFilter = { memcmp: { offset: 116, bytes: \"1\" } };\n   220→\n   221→  const [asCreator, asOpponent] = await Promise.all([\n   222→    program.account.coinflipMatch.all([\n   223→      { memcmp: { offset: 8, bytes: playerBase58 } },\n   224→      claimedFalseFilter,\n   225→    ]),\n   226→    program.account.coinflipMatch.all([\n   227→      { memcmp: { offset: 40, bytes: playerBase58 } },\n   228→      claimedFalseFilter,\n   229→    ]),\n   230→  ]);\n   231→\n   232→  // Merge and deduplicate by public key\n   233→  const seen = new Set<string>();\n   234→  const matches: UIMatch[] = [];\n   235→\n   236→  for (const acc of [...asCreator, ...asOpponent]) {\n   237→    const key = acc.publicKey.toBase58();\n   238→    if (seen.has(key)) continue;\n   239→    seen.add(key);\n   240→\n   241→    const data = acc.account as unknown as OnChainMatch;\n   242→    // Skip terminal phase (refunded)\n   243→    if (isPhase(data.phase, \"refunded\")) continue;\n   244→\n   245→    const match = onChainMatchToUI(acc.publicKey, data);\n   246→\n   247→    // Upgrade Locked → complete when VRF has resolved\n   248→    if (isPhase(data.phase, \"locked\") && await isVrfFulfilled(connection, data.vrfRequestKey)) {\n   249→      matches.push({ ...match, phase: \"complete\" });\n   250→    } else {\n   251→      matches.push(match);\n   252→    }\n   253→  }\n   254→\n   255→  return matches;\n   256→}\n   257→\n   258→export async function fetchMatchByCreator(\n   259→  connection: Connection,\n   260→  creator: PublicKey\n   261→): Promise<UIMatch | null> {\n   262→  const program = getCoinflipProgram(connection);\n   263→  const [matchPda] = getMatchPda(creator);\n   264→\n   265→  try {\n   266→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   267→    const data = account as unknown as OnChainMatch;\n   268→    const match = onChainMatchToUI(matchPda, data);\n   269→\n   270→    if (isPhase(data.phase, \"locked\") && await isVrfFulfilled(connection, data.vrfRequestKey)) {\n   271→      return { ...match, phase: \"complete\" };\n   272→    }\n   273→\n   274→    return match;\n   275→  } catch {\n   276→    // Account doesn't exist\n   277→    return null;\n   278→  }\n   279→}\n   280→\n   281→export async function fetchMatch(\n   282→  connection: Connection,\n   283→  matchPda: PublicKey\n   284→): Promise<UIMatch | null> {\n   285→  const program = getCoinflipProgram(connection);\n   286→\n   287→  try {\n   288→    const account = await program.account.coinflipMatch.fetch(matchPda);\n   289→    const data = account as unknown as OnChainMatch;\n   290→    const match = onChainMatchToUI(matchPda, data);\n   291→\n   292→    // If on-chain phase is Locked but VRF has resolved, show as \"complete\"\n   293→    // so the Settle button appears instead of Cancel & Refund.\n   294→    if (isPhase(data.phase, \"locked\") && await isVrfFulfilled(connection, data.vrfRequestKey)) {\n   295→      return { ...match, phase: \"complete\" };\n   296→    }\n   297→\n   298→    return match;\n   299→  } catch {\n   300→    return null;\n   301→  }\n   302→}\n   303→\n   304→// ============ Instruction Builders ============\n   305→\n   306→export async function buildCreateMatchTx(\n   307→  connection: Connection,\n   308→  creator: PublicKey,\n   309→  tier: Tier,\n   310→  side: CoinSide\n   311→): Promise<{ transaction: Transaction; matchPda: PublicKey }> {\n   312→  const program = getCoinflipProgram(connection);\n   313→  const [matchPda] = getMatchPda(creator);\n   314→  const [configPda] = getConfigPda();\n   315→\n   316→  const tierIndex = TIER_VALUES[tier];\n   317→  const sideIndex = COIN_SIDE_VALUES[side];\n   318→\n   319→  const ix = await program.methods\n   320→    .createMatch(tierIndex, sideIndex)\n   321→    .accountsStrict({\n   322→      creator,\n   323→      coinflipMatch: matchPda,\n   324→      config: configPda,\n   325→      systemProgram: SystemProgram.programId,\n   326→    })\n   327→    .instruction();\n   328→\n   329→  const tx = new Transaction().add(ix);\n   330→  tx.feePayer = creator;\n   331→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   332→\n   333→  return { transaction: tx, matchPda };\n   334→}\n   335→\n   336→export async function buildJoinMatchTx(\n   337→  connection: Connection,\n   338→  opponent: PublicKey,\n   339→  matchCreator: PublicKey\n   340→): Promise<Transaction> {\n   341→  const program = getCoinflipProgram(connection);\n   342→  const [matchPda] = getMatchPda(matchCreator);\n   343→  const [configPda] = getConfigPda();\n   344→\n   345→  // Orao VRF accounts — derive PDAs and fetch treasury from network state\n   346→  const oraoNetworkState = getOraoNetworkStatePda();\n   347→  const networkInfo = await connection.getAccountInfo(oraoNetworkState);\n   348→  if (!networkInfo) throw new Error(\"Orao VRF network state not found on-chain\");\n   349→  // Treasury is at offset 40 in Orao NetworkState (8-byte discriminator + 32-byte authority)\n   350→  const oraoTreasury = new PublicKey(networkInfo.data.subarray(40, 72));\n   351→  const oraoRandom = getOraoRandomnessPda(matchPda.toBytes());\n   352→\n   353→  const ix = await program.methods\n   354→    .joinMatch()\n   355→    .accountsStrict({\n   356→      opponent,\n   357→      coinflipMatch: matchPda,\n   358→      config: configPda,\n   359→      oraoProgram: ORAO_VRF_PROGRAM_ID,\n   360→      oraoNetworkState,\n   361→      oraoTreasury,\n   362→      oraoRandom,\n   363→      systemProgram: SystemProgram.programId,\n   364→    })\n   365→    .instruction();\n   366→\n   367→  const tx = new Transaction().add(ix);\n   368→  tx.feePayer = opponent;\n   369→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   370→\n   371→  return tx;\n   372→}\n   373→\n   374→export async function buildCancelMatchTx(\n   375→  connection: Connection,\n   376→  creator: PublicKey\n   377→): Promise<Transaction> {\n   378→  const program = getCoinflipProgram(connection);\n   379→  const [matchPda] = getMatchPda(creator);\n   380→\n   381→  const ix = await program.methods\n   382→    .cancelMatch()\n   383→    .accountsStrict({\n   384→      creator,\n   385→      coinflipMatch: matchPda,\n   386→      systemProgram: SystemProgram.programId,\n   387→    })\n   388→    .instruction();\n   389→\n   390→  const tx = new Transaction().add(ix);\n   391→  tx.feePayer = creator;\n   392→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   393→\n   394→  return tx;\n   395→}\n   396→\n   397→export async function buildTimeoutCancelTx(\n   398→  connection: Connection,\n   399→  caller: PublicKey,\n   400→  matchCreator: PublicKey,\n   401→  opponent: PublicKey\n   402→): Promise<Transaction> {\n   403→  const program = getCoinflipProgram(connection);\n   404→  const [matchPda] = getMatchPda(matchCreator);\n   405→\n   406→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   407→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   408→\n   409→  const ix = await program.methods\n   410→    .timeoutCancel()\n   411→    .accountsStrict({\n   412→      caller,\n   413→      creator: matchCreator,\n   414→      opponent,\n   415→      coinflipMatch: matchPda,\n   416→      randomnessAccount,\n   417→    })\n   418→    .instruction();\n   419→\n   420→  const tx = new Transaction().add(ix);\n   421→  tx.feePayer = caller;\n   422→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   423→\n   424→  return tx;\n   425→}\n   426→\n   427→export async function buildClaimPayoutTx(\n   428→  connection: Connection,\n   429→  caller: PublicKey,\n   430→  matchCreator: PublicKey,\n   431→  opponent: PublicKey\n   432→): Promise<Transaction> {\n   433→  const program = getCoinflipProgram(connection);\n   434→  const [matchPda] = getMatchPda(matchCreator);\n   435→  const [configPda] = getConfigPda();\n   436→\n   437→  // Fetch config to get treasury address\n   438→  const config = await program.account.coinflipConfig.fetch(configPda);\n   439→  const treasury = (config as unknown as { treasury: PublicKey }).treasury;\n   440→\n   441→  // Derive randomness account from match PDA (VRF seed = match PDA key)\n   442→  const randomnessAccount = getOraoRandomnessPda(matchPda.toBytes());\n   443→\n   444→  // Derive player profile PDAs for CPI\n   445→  const PLATFORM_PROGRAM_ID = new PublicKey(\n   446→    (import.meta as unknown as { env: Record<string, string | undefined> }).env\n   447→      .VITE_PLATFORM_PROGRAM_ID ?? \"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n   448→  );\n   449→  const [creatorProfile] = PublicKey.findProgramAddressSync(\n   450→    [Buffer.from(\"player_profile\"), matchCreator.toBuffer()],\n   451→    PLATFORM_PROGRAM_ID\n   452→  );\n   453→  const [opponentProfile] = PublicKey.findProgramAddressSync(\n   454→    [Buffer.from(\"player_profile\"), opponent.toBuffer()],\n   455→    PLATFORM_PROGRAM_ID\n   456→  );\n   457→\n   458→  const ix = await program.methods\n   459→    .claimPayout()\n   460→    .accountsStrict({\n   461→      caller,\n   462→      coinflipMatch: matchPda,\n   463→      config: configPda,\n   464→      treasury,\n   465→      creator: matchCreator,\n   466→      opponent,\n   467→      randomnessAccount,\n   468→      creatorProfile,\n   469→      opponentProfile,\n   470→      platformProgram: PLATFORM_PROGRAM_ID,\n   471→      systemProgram: SystemProgram.programId,\n   472→    })\n   473→    .instruction();\n   474→\n   475→  const tx = new Transaction().add(ix);\n   476→  tx.feePayer = caller;\n   477→  tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;\n   478→\n   479→  return tx;\n   480→}\n   481→"}]},"parent_tool_use_id":"toolu_01UCRoC4vFJYJS38UtFE5rZN","session_id":"6f57423d-52bf-4b79-9edb-534166a03339","uuid":"ccb92096-0245-4091-ab1a-534d9a9d830d"}
