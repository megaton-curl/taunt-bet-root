{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J38B3zQuDqsAbzV3CHWMi6","type":"tool_result","content":"     1→import { PublicKey } from \"@solana/web3.js\";\n     2→\n     3→// ============ Tier System ============\n     4→\n     5→export type Tier = \"iron\" | \"bronze\" | \"silver\" | \"gold\" | \"platinum\" | \"diamond\";\n     6→\n     7→export const TIER_VALUES: Record<Tier, number> = {\n     8→  iron: 0,\n     9→  bronze: 1,\n    10→  silver: 2,\n    11→  gold: 3,\n    12→  platinum: 4,\n    13→  diamond: 5,\n    14→};\n    15→\n    16→export const TIER_AMOUNTS: Record<Tier, number> = {\n    17→  iron: 0.005,\n    18→  bronze: 0.01,\n    19→  silver: 0.1,\n    20→  gold: 0.25,\n    21→  platinum: 0.5,\n    22→  diamond: 1.0,\n    23→};\n    24→\n    25→// ============ Pool State ============\n    26→\n    27→export type PoolPhase = \"waiting\" | \"locked\" | \"resolving\" | \"settled\" | \"cancelled\";\n    28→\n    29→export const POOL_PHASE_VALUES: Record<PoolPhase, number> = {\n    30→  waiting: 0,\n    31→  locked: 1,\n    32→  resolving: 2,\n    33→  settled: 3,\n    34→  cancelled: 4,\n    35→};\n    36→\n    37→export interface Pool {\n    38→  poolId: Uint8Array;\n    39→  gameId: string;\n    40→  roundId: number;\n    41→  tier: Tier;\n    42→  entryAmount: number;\n    43→  phase: PoolPhase;\n    44→  totalPool: number;\n    45→  playerCount: number;\n    46→  maxPlayers: number;\n    47→  createdAt: Date;\n    48→  lockedAt: Date | null;\n    49→  settledAt: Date | null;\n    50→  feeBps: number;\n    51→  vrfRequest: PublicKey | null;\n    52→  randomness: Uint8Array | null;\n    53→  winner: PublicKey | null;\n    54→  authority: PublicKey;\n    55→  treasury: PublicKey;\n    56→  carryoverAmount: number;\n    57→  carryoverFromRound: number;\n    58→}\n    59→\n    60→// ============ Player Entry ============\n    61→\n    62→export type Side = \"none\" | \"green\" | \"red\";\n    63→\n    64→export const SIDE_VALUES: Record<Side, number> = {\n    65→  none: 0,\n    66→  green: 1,\n    67→  red: 2,\n    68→};\n    69→\n    70→export interface PlayerEntry {\n    71→  pool: PublicKey;\n    72→  player: PublicKey;\n    73→  amount: number;\n    74→  enteredAt: Date;\n    75→  sequence: number;\n    76→  side: Side;\n    77→  cashoutMultiplier: number | null;\n    78→  cashedOutAt: Date | null;\n    79→  claimed: boolean;\n    80→  payout: number;\n    81→  won: boolean;\n    82→  xpParticipation: number;\n    83→  xpWin: number;\n    84→}\n    85→\n    86→// ============ Game Config ============\n    87→\n    88→export interface GameConfig {\n    89→  gameId: string;\n    90→  paused: boolean;\n    91→  minBet: number;\n    92→  maxBet: number;\n    93→  feeBps: number;\n    94→  enabledTiers: Tier[];\n    95→  minPlayers: number;\n    96→  maxPlayers: number;\n    97→  roundDurationSecs: number;\n    98→  bettingWindowSecs: number;\n    99→  vrfQueue: PublicKey;\n   100→  authority: PublicKey;\n   101→  treasury: PublicKey;\n   102→  currentRound: number;\n   103→  totalRounds: number;\n   104→  totalVolume: number;\n   105→  totalFees: number;\n   106→  version: number;\n   107→  createdAt: Date;\n   108→  updatedAt: Date;\n   109→}\n   110→\n   111→// ============ Coinflip ============\n   112→\n   113→export type CoinSide = \"heads\" | \"tails\";\n   114→export type CoinflipPhase = \"created\" | \"ready\" | \"flipping\" | \"complete\";\n   115→\n   116→export const COIN_SIDE_VALUES: Record<CoinSide, number> = {\n   117→  heads: 0,\n   118→  tails: 1,\n   119→};\n   120→\n   121→export const COINFLIP_PHASE_VALUES: Record<CoinflipPhase, number> = {\n   122→  created: 0,\n   123→  ready: 1,\n   124→  flipping: 2,\n   125→  complete: 3,\n   126→};\n   127→\n   128→export interface CoinflipState {\n   129→  pool: PublicKey;\n   130→  player1: PublicKey;\n   131→  player2: PublicKey | null;\n   132→  player1Side: CoinSide;\n   133→  result: CoinSide | null;\n   134→  phase: CoinflipPhase;\n   135→  createdAt: Date;\n   136→  joinedAt: Date | null;\n   137→  flippedAt: Date | null;\n   138→  joinTimeoutSecs: number;\n   139→}\n   140→\n   141→export interface CoinflipMatch {\n   142→  pool: Pool;\n   143→  state: CoinflipState;\n   144→  player1Entry: PlayerEntry;\n   145→  player2Entry: PlayerEntry | null;\n   146→}\n   147→\n   148→// ============ Legacy Types (for backwards compatibility) ============\n   149→\n   150→/** @deprecated Use Pool instead */\n   151→export interface PoolState {\n   152→  roundId: string;\n   153→  gameId: string;\n   154→  tier: Tier;\n   155→  phase: \"waiting\" | \"betting\" | \"active\" | \"resolving\" | \"settled\";\n   156→  entries: LegacyPlayerEntry[];\n   157→  totalPool: number;\n   158→  createdAt: number;\n   159→  settledAt?: number;\n   160→  outcome?: unknown;\n   161→}\n   162→\n   163→/** @deprecated Use PlayerEntry instead */\n   164→export interface LegacyPlayerEntry {\n   165→  playerId: string;\n   166→  publicKey: string;\n   167→  tier: Tier;\n   168→  amount: number;\n   169→  timestamp: number;\n   170→  side?: \"green\" | \"red\";\n   171→  cashoutMultiplier?: number;\n   172→}\n   173→\n   174→// ============ Game IDs ============\n   175→\n   176→export const GAME_IDS = {\n   177→  COINFLIP: \"coinflip\",\n   178→  LORD_OF_RNGS: \"lord-of-rngs\",\n   179→  CRASH: \"crash\",\n   180→  CLOSE_CALL: \"close-call\",\n   181→  SLOTS: \"slots\",\n   182→  GAME_OF_TRADES: \"game-of-trades\",\n   183→  TUG_OF_EARN: \"tug-of-earn\",\n   184→  CHART_COURSE: \"chart-course\",\n   185→} as const;\n   186→\n   187→export type GameId = (typeof GAME_IDS)[keyof typeof GAME_IDS];\n   188→\n   189→// ============ XP System ============\n   190→\n   191→export const XP_BY_TIER: Record<Tier, { participation: number; win: number }> = {\n   192→  iron: { participation: 1, win: 3 },\n   193→  bronze: { participation: 1, win: 3 },\n   194→  silver: { participation: 10, win: 30 },\n   195→  gold: { participation: