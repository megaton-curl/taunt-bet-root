{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YSwsu8BedEi2cx1EFmB2J4","type":"tool_result","content":"     1→/**\n     2→ * Localnet setup helper — initializes coinflip and platform configs.\n     3→ *\n     4→ * Must be called once before the E2E suite starts, after the test validator\n     5→ * is running and wallets are funded. Initializes:\n     6→ * - Coinflip config PDA (sets authority + treasury)\n     7→ * - Platform config PDA (sets authority + treasury)\n     8→ */\n     9→import {\n    10→  Connection,\n    11→  Keypair,\n    12→  PublicKey,\n    13→  SystemProgram,\n    14→  Transaction,\n    15→  sendAndConfirmTransaction,\n    16→} from \"@solana/web3.js\";\n    17→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n    18→import {\n    19→  CoinflipIDL,\n    20→  PlatformIDL,\n    21→  type Coinflip,\n    22→  type Platform,\n    23→} from \"@rng-utopia/anchor-client\";\n    24→import { LOCAL_RPC_URL } from \"./wallets\";\n    25→\n    26→// ── Deterministic admin/treasury keypairs ──────────────────────────────\n    27→const SEED_ADMIN = new Uint8Array(32).fill(0xdd);\n    28→const SEED_TREASURY = new Uint8Array(32).fill(0xcc);\n    29→\n    30→export const ADMIN = Keypair.fromSeed(SEED_ADMIN);\n    31→export const TREASURY = Keypair.fromSeed(SEED_TREASURY);\n    32→\n    33→// ── Program IDs ────────────────────────────────────────────────────────\n    34→const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    35→const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n    36→\n    37→function getConfigPda(): PublicKey {\n    38→  const [pda] = PublicKey.findProgramAddressSync(\n    39→    [Buffer.from(\"coinflip_config\")],\n    40→    COINFLIP_PROGRAM_ID,\n    41→  );\n    42→  return pda;\n    43→}\n    44→\n    45→function getPlatformConfigPda(): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"platform_config\")],\n    48→    PLATFORM_PROGRAM_ID,\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→function makeProvider(connection: Connection, wallet: Keypair): AnchorProvider {\n    54→  return new AnchorProvider(\n    55→    connection,\n    56→    {\n    57→      publicKey: wallet.publicKey,\n    58→      signTransaction: async (tx) => {\n    59→        tx.partialSign(wallet);\n    60→        return tx;\n    61→      },\n    62→      signAllTransactions: async (txs) => {\n    63→        txs.forEach((tx) => tx.partialSign(wallet));\n    64→        return txs;\n    65→      },\n    66→    },\n    67→    { commitment: \"confirmed\" },\n    68→  );\n    69→}\n    70→\n    71→/**\n    72→ * Initialize both program configs and fund the admin/treasury accounts.\n    73→ * Idempotent: silently succeeds if configs already exist.\n    74→ */\n    75→export async function initializeLocalnet(\n    76→  rpcUrl = LOCAL_RPC_URL,\n    77→): Promise<void> {\n    78→  const connection = new Connection(rpcUrl, \"confirmed\");\n    79→\n    80→  // Fund admin and treasury\n    81→  await Promise.all([\n    82→    fundIfNeeded(connection, ADMIN.publicKey, 2),\n    83→    fundIfNeeded(connection, TREASURY.publicKey, 2),\n    84→  ]);\n    85→\n    86→  const provider = makeProvider(connection, ADMIN);\n    87→  const coinflipProgram = new Program(\n    88→    CoinflipIDL as Idl as Coinflip,\n    89→    provider,\n    90→  );\n    91→  const platformProgram = new Program(\n    92→    PlatformIDL as Idl as Platform,\n    93→    provider,\n    94→  );\n    95→\n    96→  // Initialize coinflip config (idempotent)\n    97→  const configPda = getConfigPda();\n    98→  const configExists = await connection.getAccountInfo(configPda);\n    99→  if (!configExists) {\n   100→    const ix = await coinflipProgram.methods\n   101→      .initializeConfig(TREASURY.publicKey)\n   102→      .accountsStrict({\n   103→        authority: ADMIN.publicKey,\n   104→        config: configPda,\n   105→        systemProgram: SystemProgram.programId,\n   106→      })\n   107→      .instruction();\n   108→\n   109→    const tx = new Transaction().add(ix);\n   110→    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n   111→      commitment: \"confirmed\",\n   112→    });\n   113→  }\n   114→\n   115→  // Initialize platform config (idempotent)\n   116→  const platformConfigPda = getPlatformConfigPda();\n   117→  const platformConfigExists =\n   118→    await connection.getAccountInfo(platformConfigPda);\n   119→  if (!platformConfigExists) {\n   120→    const ix = await platformProgram.methods\n   121→      .initializePlatform(TREASURY.publicKey)\n   122→      .accountsStrict({\n   123→        authority: ADMIN.publicKey,\n   124→        config: platformConfigPda,\n   125→        systemProgram: SystemProgram.programId,\n   126→      })\n   127→      .instruction();\n   128→\n   129→    const tx = new Transaction().add(ix);\n   130→    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n   131→      commitment: \"confirmed\",\n   132→    });\n   133→  }\n   134→}\n   135→\n   136→async function fundIfNeeded(\n   137→  connection: Connection,\n   138→  pubkey: PublicKey,\n   139→  solAmount: number,\n   140→): Promise<void> {\n   141→  const balance = await connection.getBalance(pubkey);\n   142→  if (balance >= solAmount * 1_000_000_000) return;\n   143→\n   144→  const sig = await connection.requestAirdrop(\n   145→    pubkey,\n   146→    solAmount * 1_000_000_000,\n   147→  );\n   148→  const { blockhash, lastValidBlockHeight } =\n   149→    await connection.getLatestBlockhash();\n   150→  await connection.confirmTransaction(\n   151→    { signature: sig, blockhash, lastValidBlockHeight },\n   152→    \"confirmed\",\n   153→  );\n   154→}\n   155→"}]},"parent_tool_use_id":null,"session_id":"c7881ac6-ae6b-4bf4-983d-8efe2357b0da","uuid":"f7bfd974-377b-4e74-b72b-c29c8ad513d8","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/localnet-setup.ts","content":"/**\n * Localnet setup helper — initializes coinflip and platform configs.\n *\n * Must be called once before the E2E suite starts, after the test validator\n * is running and wallets are funded. Initializes:\n * - Coinflip config PDA (sets authority + treasury)\n * - Platform config PDA (sets authority + treasury)\n */\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  sendAndConfirmTransaction,\n} from \"@solana/web3.js\";\nimport { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\nimport {\n  CoinflipIDL,\n  PlatformIDL,\n  type Coinflip,\n  type Platform,\n} from \"@rng-utopia/anchor-client\";\nimport { LOCAL_RPC_URL } from \"./wallets\";\n\n// ── Deterministic admin/treasury keypairs ──────────────────────────────\nconst SEED_ADMIN = new Uint8Array(32).fill(0xdd);\nconst SEED_TREASURY = new Uint8Array(32).fill(0xcc);\n\nexport const ADMIN = Keypair.fromSeed(SEED_ADMIN);\nexport const TREASURY = Keypair.fromSeed(SEED_TREASURY);\n\n// ── Program IDs ────────────────────────────────────────────────────────\nconst COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\nconst PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n\nfunction getConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"coinflip_config\")],\n    COINFLIP_PROGRAM_ID,\n  );\n  return pda;\n}\n\nfunction getPlatformConfigPda(): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PLATFORM_PROGRAM_ID,\n  );\n  return pda;\n}\n\nfunction makeProvider(connection: Connection, wallet: Keypair): AnchorProvider {\n  return new AnchorProvider(\n    connection,\n    {\n      publicKey: wallet.publicKey,\n      signTransaction: async (tx) => {\n        tx.partialSign(wallet);\n        return tx;\n      },\n      signAllTransactions: async (txs) => {\n        txs.forEach((tx) => tx.partialSign(wallet));\n        return txs;\n      },\n    },\n    { commitment: \"confirmed\" },\n  );\n}\n\n/**\n * Initialize both program configs and fund the admin/treasury accounts.\n * Idempotent: silently succeeds if configs already exist.\n */\nexport async function initializeLocalnet(\n  rpcUrl = LOCAL_RPC_URL,\n): Promise<void> {\n  const connection = new Connection(rpcUrl, \"confirmed\");\n\n  // Fund admin and treasury\n  await Promise.all([\n    fundIfNeeded(connection, ADMIN.publicKey, 2),\n    fundIfNeeded(connection, TREASURY.publicKey, 2),\n  ]);\n\n  const provider = makeProvider(connection, ADMIN);\n  const coinflipProgram = new Program(\n    CoinflipIDL as Idl as Coinflip,\n    provider,\n  );\n  const platformProgram = new Program(\n    PlatformIDL as Idl as Platform,\n    provider,\n  );\n\n  // Initialize coinflip config (idempotent)\n  const configPda = getConfigPda();\n  const configExists = await connection.getAccountInfo(configPda);\n  if (!configExists) {\n    const ix = await coinflipProgram.methods\n      .initializeConfig(TREASURY.publicKey)\n      .accountsStrict({\n        authority: ADMIN.publicKey,\n        config: configPda,\n        systemProgram: SystemProgram.programId,\n      })\n      .instruction();\n\n    const tx = new Transaction().add(ix);\n    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n      commitment: \"confirmed\",\n    });\n  }\n\n  // Initialize platform config (idempotent)\n  const platformConfigPda = getPlatformConfigPda();\n  const platformConfigExists =\n    await connection.getAccountInfo(platformConfigPda);\n  if (!platformConfigExists) {\n    const ix = await platformProgram.methods\n      .initializePlatform(TREASURY.publicKey)\n      .accountsStrict({\n        authority: ADMIN.publicKey,\n        config: platformConfigPda,\n        systemProgram: SystemProgram.programId,\n      })\n      .instruction();\n\n    const tx = new Transaction().add(ix);\n    await sendAndConfirmTransaction(connection, tx, [ADMIN], {\n      commitment: \"confirmed\",\n    });\n  }\n}\n\nasync function fundIfNeeded(\n  connection: Connection,\n  pubkey: PublicKey,\n  solAmount: number,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= solAmount * 1_000_000_000) return;\n\n  const sig = await connection.requestAirdrop(\n    pubkey,\n    solAmount * 1_000_000_000,\n  );\n  const { blockhash, lastValidBlockHeight } =\n    await connection.getLatestBlockhash();\n  await connection.confirmTransaction(\n    { signature: sig, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n}\n","numLines":155,"startLine":1,"totalLines":155}}}
