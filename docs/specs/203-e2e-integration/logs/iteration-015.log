{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018pBdHN52Fe9PRohforXppd","type":"tool_result","content":"     1→/**\n     2→ * Deterministic wallet-funding helper for local E2E tests.\n     3→ *\n     4→ * Generates fixed keypairs from seed bytes so tests are reproducible,\n     5→ * then airdrops SOL and confirms before tests run.\n     6→ */\n     7→import {\n     8→  Connection,\n     9→  Keypair,\n    10→  LAMPORTS_PER_SOL,\n    11→  PublicKey,\n    12→} from \"@solana/web3.js\";\n    13→\n    14→// --- Deterministic keypairs ---\n    15→// Fixed 32-byte seeds produce the same keypairs on every run.\n    16→const SEED_PLAYER_A = new Uint8Array(32).fill(0xaa);\n    17→const SEED_PLAYER_B = new Uint8Array(32).fill(0xbb);\n    18→\n    19→export const PLAYER_A = Keypair.fromSeed(SEED_PLAYER_A);\n    20→export const PLAYER_B = Keypair.fromSeed(SEED_PLAYER_B);\n    21→\n    22→/** Default RPC URL for local test validator. */\n    23→export const LOCAL_RPC_URL = \"http://127.0.0.1:8899\";\n    24→\n    25→/** Default airdrop amount per wallet (10 SOL). */\n    26→const DEFAULT_AIRDROP_SOL = 10;\n    27→\n    28→/**\n    29→ * Airdrop SOL to a single wallet and confirm the transaction.\n    30→ *\n    31→ * @param connection - Solana RPC connection\n    32→ * @param to - Public key to fund\n    33→ * @param solAmount - Amount in SOL (default: 10)\n    34→ */\n    35→export async function fundWallet(\n    36→  connection: Connection,\n    37→  to: PublicKey,\n    38→  solAmount = DEFAULT_AIRDROP_SOL,\n    39→): Promise<void> {\n    40→  const lamports = solAmount * LAMPORTS_PER_SOL;\n    41→  const sig = await connection.requestAirdrop(to, lamports);\n    42→  const { blockhash, lastValidBlockHeight } =\n    43→    await connection.getLatestBlockhash();\n    44→  await connection.confirmTransaction(\n    45→    { signature: sig, blockhash, lastValidBlockHeight },\n    46→    \"confirmed\",\n    47→  );\n    48→}\n    49→\n    50→/**\n    51→ * Fund both test players on the local validator.\n    52→ * Call this in a `beforeAll` or global setup before the E2E suite starts.\n    53→ *\n    54→ * @param rpcUrl - RPC endpoint (default: local validator)\n    55→ * @param solAmount - SOL to airdrop per player (default: 10)\n    56→ */\n    57→export async function fundTestWallets(\n    58→  rpcUrl = LOCAL_RPC_URL,\n    59→  solAmount = DEFAULT_AIRDROP_SOL,\n    60→): Promise<{ playerA: Keypair; playerB: Keypair; connection: Connection }> {\n    61→  const connection = new Connection(rpcUrl, \"confirmed\");\n    62→\n    63→  await Promise.all([\n    64→    fundWallet(connection, PLAYER_A.publicKey, solAmount),\n    65→    fundWallet(connection, PLAYER_B.publicKey, solAmount),\n    66→  ]);\n    67→\n    68→  // Sanity-check: verify balances are present\n    69→  const [balA, balB] = await Promise.all([\n    70→    connection.getBalance(PLAYER_A.publicKey),\n    71→    connection.getBalance(PLAYER_B.publicKey),\n    72→  ]);\n    73→\n    74→  const minExpected = solAmount * LAMPORTS_PER_SOL;\n    75→  if (balA < minExpected) {\n    76→    throw new Error(\n    77→      `Player A funding failed: expected >= ${minExpected} lamports, got ${balA}`,\n    78→    );\n    79→  }\n    80→  if (balB < minExpected) {\n    81→    throw new Error(\n    82→      `Player B funding failed: expected >= ${minExpected} lamports, got ${balB}`,\n    83→    );\n    84→  }\n    85→\n    86→  return { playerA: PLAYER_A, playerB: PLAYER_B, connection };\n    87→}\n    88→"}]},"parent_tool_use_id":null,"session_id":"c7881ac6-ae6b-4bf4-983d-8efe2357b0da","uuid":"ff7fbf6c-5151-4057-8197-5db201f6847f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/wallets.ts","content":"/**\n * Deterministic wallet-funding helper for local E2E tests.\n *\n * Generates fixed keypairs from seed bytes so tests are reproducible,\n * then airdrops SOL and confirms before tests run.\n */\nimport {\n  Connection,\n  Keypair,\n  LAMPORTS_PER_SOL,\n  PublicKey,\n} from \"@solana/web3.js\";\n\n// --- Deterministic keypairs ---\n// Fixed 32-byte seeds produce the same keypairs on every run.\nconst SEED_PLAYER_A = new Uint8Array(32).fill(0xaa);\nconst SEED_PLAYER_B = new Uint8Array(32).fill(0xbb);\n\nexport const PLAYER_A = Keypair.fromSeed(SEED_PLAYER_A);\nexport const PLAYER_B = Keypair.fromSeed(SEED_PLAYER_B);\n\n/** Default RPC URL for local test validator. */\nexport const LOCAL_RPC_URL = \"http://127.0.0.1:8899\";\n\n/** Default airdrop amount per wallet (10 SOL). */\nconst DEFAULT_AIRDROP_SOL = 10;\n\n/**\n * Airdrop SOL to a single wallet and confirm the transaction.\n *\n * @param connection - Solana RPC connection\n * @param to - Public key to fund\n * @param solAmount - Amount in SOL (default: 10)\n */\nexport async function fundWallet(\n  connection: Connection,\n  to: PublicKey,\n  solAmount = DEFAULT_AIRDROP_SOL,\n): Promise<void> {\n  const lamports = solAmount * LAMPORTS_PER_SOL;\n  const sig = await connection.requestAirdrop(to, lamports);\n  const { blockhash, lastValidBlockHeight } =\n    await connection.getLatestBlockhash();\n  await connection.confirmTransaction(\n    { signature: sig, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n}\n\n/**\n * Fund both test players on the local validator.\n * Call this in a `beforeAll` or global setup before the E2E suite starts.\n *\n * @param rpcUrl - RPC endpoint (default: local validator)\n * @param solAmount - SOL to airdrop per player (default: 10)\n */\nexport async function fundTestWallets(\n  rpcUrl = LOCAL_RPC_URL,\n  solAmount = DEFAULT_AIRDROP_SOL,\n): Promise<{ playerA: Keypair; playerB: Keypair; connection: Connection }> {\n  const connection = new Connection(rpcUrl, \"confirmed\");\n\n  await Promise.all([\n    fundWallet(connection, PLAYER_A.publicKey, solAmount),\n    fundWallet(connection, PLAYER_B.publicKey, solAmount),\n  ]);\n\n  // Sanity-check: verify balances are present\n  const [balA, balB] = await Promise.all([\n    connection.getBalance(PLAYER_A.publicKey),\n    connection.getBalance(PLAYER_B.publicKey),\n  ]);\n\n  const minExpected = solAmount * LAMPORTS_PER_SOL;\n  if (balA < minExpected) {\n    throw new Error(\n      `Player A funding failed: expected >= ${minExpected} lamports, got ${balA}`,\n    );\n  }\n  if (balB < minExpected) {\n    throw new Error(\n      `Player B funding failed: expected >= ${minExpected} lamports, got ${balB}`,\n    );\n  }\n\n  return { playerA: PLAYER_A, playerB: PLAYER_B, connection };\n}\n","numLines":88,"startLine":1,"totalLines":88}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01GMdzPsneAB3eyFoFQxjUtD","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"Now I have all the information needed. Let me create the devnet lifecycle test.\n\nKey design decisions:\n1. Since real VRF is non-deterministic, the test must handle either player winning\n2. Need to fund wallets on devnet (airdrop with retry for rate limits)\n3. Longer timeouts for VRF fulfillment (60-90s)\n4. The next checklist items cover polling/backoff and on-chain assertions, so this item should focus on the basic lifecycle flow with UI assertions\n5. Import page-objects from `../local/helpers/page-objects`\n\nLet me also check the page-object function to understand what `waitForResult` returns specifically — whether it tells us \"won\" or \"lost\".\n\n\nGood, `waitForResult` returns either `\"won\"` or `\"lost\"` by checking the CSS class on the result title. For the devnet test, I'll need to fund both wallets with a helper that checks balance first and only airdrops if needed with retry logic, then have Player A create a match, Player B join it, wait for VRF fulfillment with a longer timeout, determine the winner from the result, have the winner claim their prize while verifying the UI updates, and track any console errors from both players throughout.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1911,"cache_read_input_tokens":61906,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1911},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c7881ac6-ae6b-4bf4-983d-8efe2357b0da","uuid":"2d5c5871-657c-4587-a9ea-f6df7e5590ca"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01GMdzPsneAB3eyFoFQxjUtD","type":"message","role":"assistant","content":[{"type":"text","text":"Now I have everything I need. Let me create the devnet lifecycle test. Key design decisions:\n\n1. **Non-deterministic outcome**: Real VRF means either player can win — test handles both\n2. **Wallet funding**: Devnet airdrop (check balance first, only airdrop if needed)\n3. **Longer timeouts**: Real VRF can take 30-60s\n4. **No on-chain assertions here** (that's the next checklist item)"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1911,"cache_read_input_tokens":61906,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1911},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c7881ac6-ae6b-4bf4-983d-8efe2357b0da","uuid":"1a7bcd5e-5665-41a0-92c2-3eaabadea33d"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01GMdzPsneAB3eyFoFQxjUtD","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01G2o5ZbstiDkeNM7cLmfeb7","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts","content":"/**\n * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. Connects to deployed devnet programs with\n * real Orao VRF fulfillment (no mock resolve shortcut).\n *\n * Prerequisites:\n * - Coinflip + Platform programs deployed to devnet\n * - Orao VRF initialized on devnet\n * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n * - Test wallets funded on devnet (handled in beforeAll)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"../local/helpers/page-objects\";\nimport { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\nimport { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n\n// ── Devnet wallet funding ─────────────────────────────────────────────\n\n/** Minimum SOL balance required to run the test (entry + tx fees). */\nconst MIN_BALANCE_SOL = 0.1;\n\n/** Airdrop amount per request on devnet (max 2 SOL per request). */\nconst AIRDROP_SOL = 1;\n\n/**\n * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n * is below the minimum threshold. Retries once on failure (devnet rate limits).\n */\nasync function ensureFunded(\n  connection: Connection,\n  pubkey: PublicKey,\n  label: string,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    console.log(\n      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    );\n    return;\n  }\n\n  console.log(\n    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n  );\n\n  for (let attempt = 1; attempt <= 2; attempt++) {\n    try {\n      const sig = await connection.requestAirdrop(\n        pubkey,\n        AIRDROP_SOL * LAMPORTS_PER_SOL,\n      );\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      await connection.confirmTransaction(\n        { signature: sig, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      const newBalance = await connection.getBalance(pubkey);\n      console.log(\n        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n      );\n      return;\n    } catch (err) {\n      if (attempt < 2) {\n        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n        await new Promise((r) => setTimeout(r, 2_000));\n      } else {\n        throw new Error(\n          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n        );\n      }\n    }\n  }\n}\n\n// ── VRF fulfillment timeout ───────────────────────────────────────────\n\n/**\n * Timeout for waiting on real VRF fulfillment.\n * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n */\nconst VRF_FULFILLMENT_TIMEOUT = 90_000;\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async ({ devnetConfig }) => {\n  console.log(\"Devnet lifecycle: funding test wallets...\");\n  const connection = new Connection(devnetConfig.rpcUrl, \"confirmed\");\n  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n  playerAPage,\n  playerBPage,\n}) => {\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 30_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // 4. Wait for real VRF fulfillment (no mock shortcut).\n  //    Orao VRF callback resolves the match on-chain, then the frontend\n  //    detects fulfillment via polling and shows the result.\n  console.log(\"Waiting for real VRF fulfillment...\");\n\n  const [resultA, resultB] = await Promise.all([\n    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n  ]);\n\n  console.log(`VRF resolved — Player A: ${resultA}, Player B: ${resultB}`);\n\n  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n  expect(\n    (resultA === \"won\" && resultB === \"lost\") ||\n      (resultA === \"lost\" && resultB === \"won\"),\n  ).toBe(true);\n\n  // 6. Winner claims payout\n  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n\n  await po.claimOrSettle(winnerPage);\n  console.log(`${winnerLabel} claimed payout`);\n\n  // Winner sees \"Back to Lobby\" after successful claim\n  await expect(\n    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 7. Winner returns to lobby\n  await po.backToLobby(winnerPage);\n\n  // 8. Loser settles (closes their view)\n  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n  await po.claimOrSettle(loserPage);\n  await expect(\n    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n  await po.backToLobby(loserPage);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1911,"cache_read_input_tokens":61906,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1911},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c7881ac6-ae6b-4bf4-983d-8efe2357b0da","uuid":"200e5188-5184-4c47-b693-db4f23994584"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G2o5ZbstiDkeNM7cLmfeb7","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts"}]},"parent_tool_use_id":null,"session_id":"c7881ac6-ae6b-4bf4-983d-8efe2357b0da","uuid":"6af1d74d-e1c6-4d58-a399-d63d47999907","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts","content":"/**\n * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. Connects to deployed devnet programs with\n * real Orao VRF fulfillment (no mock resolve shortcut).\n *\n * Prerequisites:\n * - Coinflip + Platform programs deployed to devnet\n * - Orao VRF initialized on devnet\n * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n * - Test wallets funded on devnet (handled in beforeAll)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"../local/helpers/page-objects\";\nimport { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\nimport { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n\n// ── Devnet wallet funding ─────────────────────────────────────────────\n\n/** Minimum SOL balance required to run the test (entry + tx fees). */\nconst MIN_BALANCE_SOL = 0.1;\n\n/** Airdrop amount per request on devnet (max 2 SOL per request). */\nconst AIRDROP_SOL = 1;\n\n/**\n * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n * is below the minimum threshold. Retries once on failure (devnet rate limits).\n */\nasync function ensureFunded(\n  connection: Connection,\n  pubkey: PublicKey,\n  label: string,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    console.log(\n      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    );\n    return;\n  }\n\n  console.log(\n    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n  );\n\n  for (let attempt = 1; attempt <= 2; attempt++) {\n    try {\n      const sig = await connection.requestAirdrop(\n        pubkey,\n        AIRDROP_SOL * LAMPORTS_PER_SOL,\n      );\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      await connection.confirmTransaction(\n        { signature: sig, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      const newBalance = await connection.getBalance(pubkey);\n      console.log(\n        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n      );\n      return;\n    } catch (err) {\n      if (attempt < 2) {\n        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n        await new Promise((r) => setTimeout(r, 2_000));\n      } else {\n        throw new Error(\n          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n        );\n      }\n    }\n  }\n}\n\n// ── VRF fulfillment timeout ───────────────────────────────────────────\n\n/**\n * Timeout for waiting on real VRF fulfillment.\n * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n */\nconst VRF_FULFILLMENT_TIMEOUT = 90_000;\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async ({ devnetConfig }) => {\n  console.log(\"Devnet lifecycle: funding test wallets...\");\n  const connection = new Connection(devnetConfig.rpcUrl, \"confirmed\");\n  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n  playerAPage,\n  playerBPage,\n}) => {\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 30_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // 4. Wait for real VRF fulfillment (no mock shortcut).\n  //    Orao VRF callback resolves the match on-chain, then the frontend\n  //    detects fulfillment via polling and shows the result.\n  console.log(\"Waiting for real VRF fulfillment...\");\n\n  const [resultA, resultB] = await Promise.all([\n    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n  ]);\n\n  console.log(`VRF resolved — Player A: ${resultA}, Player B: ${resultB}`);\n\n  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n  expect(\n    (resultA === \"won\" && resultB === \"lost\") ||\n      (resultA === \"lost\" && resultB === \"won\"),\n  ).toBe(true);\n\n  // 6. Winner claims payout\n  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n\n  await po.claimOrSettle(winnerPage);\n  console.log(`${winnerLabel} claimed payout`);\n\n  // Winner sees \"Back to Lobby\" after successful claim\n  await expect(\n    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 7. Winner returns to lobby\n  await po.backToLobby(winnerPage);\n\n  // 8. Loser settles (closes their view)\n  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n  await po.claimOrSettle(loserPage);\n  await expect(\n    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n  await po.backToLobby(loserPage);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","structuredPatch":[],"originalFile":null}}
