{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RaMDxHeh46Yn4seFF2bTVT","type":"tool_result","content":"     1→/**\n     2→ * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. Connects to deployed devnet programs with\n     6→ * real Orao VRF fulfillment (no mock resolve shortcut).\n     7→ *\n     8→ * Prerequisites:\n     9→ * - Coinflip + Platform programs deployed to devnet\n    10→ * - Orao VRF initialized on devnet\n    11→ * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n    12→ * - Test wallets funded on devnet (handled in beforeAll)\n    13→ */\n    14→import { test, expect } from \"./fixtures\";\n    15→import * as po from \"../local/helpers/page-objects\";\n    16→import { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\n    17→import { validateDevnetEnv } from \"./helpers/env\";\n    18→import { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n    19→\n    20→// ── Devnet wallet funding ─────────────────────────────────────────────\n    21→\n    22→/** Minimum SOL balance required to run the test (entry + tx fees). */\n    23→const MIN_BALANCE_SOL = 0.1;\n    24→\n    25→/** Airdrop amount per request on devnet (max 2 SOL per request). */\n    26→const AIRDROP_SOL = 1;\n    27→\n    28→/**\n    29→ * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n    30→ * is below the minimum threshold. Retries once on failure (devnet rate limits).\n    31→ */\n    32→async function ensureFunded(\n    33→  connection: Connection,\n    34→  pubkey: PublicKey,\n    35→  label: string,\n    36→): Promise<void> {\n    37→  const balance = await connection.getBalance(pubkey);\n    38→  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    39→    console.log(\n    40→      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    41→    );\n    42→    return;\n    43→  }\n    44→\n    45→  console.log(\n    46→    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n    47→  );\n    48→\n    49→  for (let attempt = 1; attempt <= 2; attempt++) {\n    50→    try {\n    51→      const sig = await connection.requestAirdrop(\n    52→        pubkey,\n    53→        AIRDROP_SOL * LAMPORTS_PER_SOL,\n    54→      );\n    55→      const { blockhash, lastValidBlockHeight } =\n    56→        await connection.getLatestBlockhash();\n    57→      await connection.confirmTransaction(\n    58→        { signature: sig, blockhash, lastValidBlockHeight },\n    59→        \"confirmed\",\n    60→      );\n    61→      const newBalance = await connection.getBalance(pubkey);\n    62→      console.log(\n    63→        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n    64→      );\n    65→      return;\n    66→    } catch (err) {\n    67→      if (attempt < 2) {\n    68→        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n    69→        await new Promise((r) => setTimeout(r, 2_000));\n    70→      } else {\n    71→        throw new Error(\n    72→          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n    73→        );\n    74→      }\n    75→    }\n    76→  }\n    77→}\n    78→\n    79→// ── VRF fulfillment timeout ───────────────────────────────────────────\n    80→\n    81→/**\n    82→ * Timeout for waiting on real VRF fulfillment.\n    83→ * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n    84→ */\n    85→const VRF_FULFILLMENT_TIMEOUT = 90_000;\n    86→\n    87→// ── Suite setup ────────────────────────────────────────────────────────\n    88→\n    89→test.beforeAll(async () => {\n    90→  const config = validateDevnetEnv();\n    91→  console.log(\"Devnet lifecycle: funding test wallets...\");\n    92→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n    93→  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n    94→  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n    95→});\n    96→\n    97→// ── Full lifecycle test ────────────────────────────────────────────────\n    98→\n    99→test(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n   100→  playerAPage,\n   101→  playerBPage,\n   102→}) => {\n   103→  // Track console errors in both contexts\n   104→  const consoleA = po.trackConsoleErrors(playerAPage);\n   105→  const consoleB = po.trackConsoleErrors(playerBPage);\n   106→\n   107→  // 1. Player A navigates and creates a match (iron tier, heads)\n   108→  await po.navigateToCoinflip(playerAPage);\n   109→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n   110→\n   111→  // Player A should see the active match in \"waiting\" state\n   112→  await expect(\n   113→    playerAPage.locator(po.sel.activeMatchWaiting),\n   114→  ).toBeVisible({ timeout: 15_000 });\n   115→\n   116→  // 2. Player B navigates (after match is created) and sees it in the lobby\n   117→  await po.navigateToCoinflip(playerBPage);\n   118→  await po.waitForLobbyMatch(playerBPage, 30_000);\n   119→\n   120→  // 3. Player B joins the match\n   121→  await po.joinMatch(playerBPage);\n   122→\n   123→  // 4. Wait for real VRF fulfillment (no mock shortcut).\n   124→  //    Orao VRF callback resolves the match on-chain, then the frontend\n   125→  //    detects fulfillment via polling and shows the result.\n   126→  console.log(\"Waiting for real VRF fulfillment...\");\n   127→\n   128→  const [resultA, resultB] = await Promise.all([\n   129→    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n   130→    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n   131→  ]);\n   132→\n   133→  console.log(`VRF resolved — Player A: ${resultA}, Player B: ${resultB}`);\n   134→\n   135→  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n   136→  expect(\n   137→    (resultA === \"won\" && resultB === \"lost\") ||\n   138→      (resultA === \"lost\" && resultB === \"won\"),\n   139→  ).toBe(true);\n   140→\n   141→  // 6. Winner claims payout\n   142→  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n   143→  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n   144→\n   145→  await po.claimOrSettle(winnerPage);\n   146→  console.log(`${winnerLabel} claimed payout`);\n   147→\n   148→  // Winner sees \"Back to Lobby\" after successful claim\n   149→  await expect(\n   150→    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   151→  ).toBeVisible({ timeout: 15_000 });\n   152→\n   153→  // 7. Winner returns to lobby\n   154→  await po.backToLobby(winnerPage);\n   155→\n   156→  // 8. Loser settles (closes their view)\n   157→  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n   158→  await po.claimOrSettle(loserPage);\n   159→  await expect(\n   160→    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   161→  ).toBeVisible({ timeout: 15_000 });\n   162→  await po.backToLobby(loserPage);\n   163→\n   164→  // No unhandled console errors in either context\n   165→  consoleA.assertClean();\n   166→  consoleB.assertClean();\n   167→});\n   168→"}]},"parent_tool_use_id":"toolu_01E2qhRFBfUs8uq9ca1Q8VQo","session_id":"a862d5c2-6727-4db5-bc9a-88f0e3c68612","uuid":"af162cf5-2cba-4b5a-844d-d27353f0de96"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01WPdCZYMfAbtmB2SFhdqtin","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Wn32njojf9CEHRbM83kyMP","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/fixtures.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":24544,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":24544},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01E2qhRFBfUs8uq9ca1Q8VQo","session_id":"a862d5c2-6727-4db5-bc9a-88f0e3c68612","uuid":"e8b87e52-e532-4217-83c5-09dfb4cf9d9a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wn32njojf9CEHRbM83kyMP","type":"tool_result","content":"     1→/**\n     2→ * Dual-browser-context fixture for devnet E2E tests.\n     3→ *\n     4→ * Same isolated dual-player pattern as local fixtures, but connects\n     5→ * to the devnet RPC instead of a local validator. The RPC URL comes\n     6→ * from the validated devnet env config.\n     7→ *\n     8→ * Usage in tests:\n     9→ * ```ts\n    10→ * import { test, expect } from \"./fixtures\";\n    11→ *\n    12→ * test(\"devnet lifecycle\", async ({ playerAPage, playerBPage, connection }) => {\n    13→ *   // playerAPage and playerBPage target devnet via real RPC\n    14→ * });\n    15→ * ```\n    16→ */\n    17→import { test as base, type BrowserContext, type Page } from \"@playwright/test\";\n    18→import { Keypair, Connection } from \"@solana/web3.js\";\n    19→import { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\n    20→import { type DevnetConfig, validateDevnetEnv } from \"./helpers/env\";\n    21→\n    22→export interface DevnetDualPlayerFixtures {\n    23→  /** Validated devnet configuration (RPC URL, program IDs). */\n    24→  devnetConfig: DevnetConfig;\n    25→  /** Isolated browser context for player A (keypair injected). */\n    26→  playerAContext: BrowserContext;\n    27→  /** Isolated browser context for player B (keypair injected). */\n    28→  playerBContext: BrowserContext;\n    29→  /** Page within player A's context. */\n    30→  playerAPage: Page;\n    31→  /** Page within player B's context. */\n    32→  playerBPage: Page;\n    33→  /** Player A's deterministic keypair. */\n    34→  playerAKeypair: Keypair;\n    35→  /** Player B's deterministic keypair. */\n    36→  playerBKeypair: Keypair;\n    37→  /** Shared RPC connection to the devnet cluster. */\n    38→  connection: Connection;\n    39→}\n    40→\n    41→/**\n    42→ * Inject a 32-byte keypair seed into a new browser context via addInitScript.\n    43→ */\n    44→async function createPlayerContext(\n    45→  browser: BrowserContext[\"browser\"],\n    46→  keypair: Keypair,\n    47→): Promise<BrowserContext> {\n    48→  const context = await browser!.newContext();\n    49→  const seedArray = Array.from(keypair.secretKey.slice(0, 32));\n    50→  await context.addInitScript((seed: number[]) => {\n    51→    (window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ =\n    52→      new Uint8Array(seed);\n    53→  }, seedArray);\n    54→  return context;\n    55→}\n    56→\n    57→export const test = base.extend<DevnetDualPlayerFixtures>({\n    58→  // Validate devnet env once per test (sync, cached by Playwright)\n    59→  // eslint-disable-next-line no-empty-pattern\n    60→  devnetConfig: async ({}, use) => {\n    61→    const config = validateDevnetEnv();\n    62→    await use(config);\n    63→  },\n    64→\n    65→  // Expose keypairs as fixtures\n    66→  playerAKeypair: [PLAYER_A, { option: true }],\n    67→  playerBKeypair: [PLAYER_B, { option: true }],\n    68→\n    69→  // Shared connection to devnet\n    70→  connection: async ({ devnetConfig }, use) => {\n    71→    const conn = new Connection(devnetConfig.rpcUrl, \"confirmed\");\n    72→    await use(conn);\n    73→  },\n    74→\n    75→  // --- Player A context + page ---\n    76→  playerAContext: async ({ browser, playerAKeypair }, use) => {\n    77→    const context = await createPlayerContext(browser, playerAKeypair);\n    78→    await use(context);\n    79→    await context.close();\n    80→  },\n    81→\n    82→  playerAPage: async ({ playerAContext }, use) => {\n    83→    const page = await playerAContext.newPage();\n    84→    await use(page);\n    85→  },\n    86→\n    87→  // --- Player B context + page ---\n    88→  playerBContext: async ({ browser, playerBKeypair }, use) => {\n    89→    const context = await createPlayerContext(browser, playerBKeypair);\n    90→    await use(context);\n    91→    await context.close();\n    92→  },\n    93→\n    94→  playerBPage: async ({ playerBContext }, use) => {\n    95→    const page = await playerBContext.newPage();\n    96→    await use(page);\n    97→  },\n    98→});\n    99→\n   100→export { expect } from \"@playwright/test\";\n   101→"}]},"parent_tool_use_id":"toolu_01E2qhRFBfUs8uq9ca1Q8VQo","session_id":"a862d5c2-6727-4db5-bc9a-88f0e3c68612","uuid":"020fdedc-326b-41ec-915a-51edf4ebaa68"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01WPdCZYMfAbtmB2SFhdqtin","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019oxhQApBLQHz3EircAWoGP","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/helpers/env.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":24544,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":24544},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01E2qhRFBfUs8uq9ca1Q8VQo","session_id":"a862d5c2-6727-4db5-bc9a-88f0e3c68612","uuid":"a94ec110-80d4-4c04-89a9-e65c1ce6f7e6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019oxhQApBLQHz3EircAWoGP","type":"tool_result","content":"     1→/**\n     2→ * Devnet E2E environment contract.\n     3→ *\n     4→ * Validates that all required environment variables are present and well-formed\n     5→ * before any devnet test runs. Fails fast with clear error messages so CI\n     6→ * doesn't waste time on doomed runs.\n     7→ *\n     8→ * Required env vars:\n     9→ *   VITE_RPC_URL             — Devnet RPC endpoint (https URL)\n    10→ *   VITE_COINFLIP_PROGRAM_ID — Deployed coinflip program address (base58)\n    11→ *   VITE_PLATFORM_PROGRAM_ID — Deployed platform program address (base58)\n    12→ *\n    13→ * Optional (with defaults):\n    14→ *   VITE_SOLANA_NETWORK      — Cluster name (default: \"devnet\")\n    15→ */\n    16→\n    17→import { Connection, PublicKey } from \"@solana/web3.js\";\n    18→\n    19→// Orao VRF program ID (hardcoded — same address on all clusters)\n    20→const ORAO_VRF_PROGRAM_ID = new PublicKey(\n    21→  \"VRFzZoJdhFWL8rkvu87LpKM3RbcVezpMEc6X5GVDr7y\",\n    22→);\n    23→\n    24→/** Validated devnet configuration. */\n    25→export interface DevnetConfig {\n    26→  rpcUrl: string;\n    27→  network: string;\n    28→  coinflipProgramId: PublicKey;\n    29→  platformProgramId: PublicKey;\n    30→  oraoVrfProgramId: PublicKey;\n    31→}\n    32→\n    33→/** Validate a base58 public key string. Throws if invalid. */\n    34→function parsePublicKey(value: string, label: string): PublicKey {\n    35→  try {\n    36→    return new PublicKey(value);\n    37→  } catch {\n    38→    throw new Error(\n    39→      `${label} is not a valid Solana address (base58): \"${value}\"`,\n    40→    );\n    41→  }\n    42→}\n    43→\n    44→/** Validate a URL string. Throws if malformed. */\n    45→function parseUrl(value: string, label: string): string {\n    46→  try {\n    47→    const url = new URL(value);\n    48→    if (![\"http:\", \"https:\"].includes(url.protocol)) {\n    49→      throw new Error(\"not http(s)\");\n    50→    }\n    51→    return value;\n    52→  } catch {\n    53→    throw new Error(\n    54→      `${label} is not a valid HTTP(S) URL: \"${value}\"`,\n    55→    );\n    56→  }\n    57→}\n    58→\n    59→/**\n    60→ * Read and validate all required devnet env vars.\n    61→ * Throws with a consolidated error listing every missing/invalid variable.\n    62→ */\n    63→export function validateDevnetEnv(): DevnetConfig {\n    64→  const errors: string[] = [];\n    65→\n    66→  // --- Required ---\n    67→  const rpcUrl = process.env.VITE_RPC_URL;\n    68→  if (!rpcUrl) {\n    69→    errors.push(\"VITE_RPC_URL is required (devnet RPC endpoint)\");\n    70→  }\n    71→\n    72→  const coinflipId = process.env.VITE_COINFLIP_PROGRAM_ID;\n    73→  if (!coinflipId) {\n    74→    errors.push(\n    75→      \"VITE_COINFLIP_PROGRAM_ID is required (deployed coinflip program address)\",\n    76→    );\n    77→  }\n    78→\n    79→  const platformId = process.env.VITE_PLATFORM_PROGRAM_ID;\n    80→  if (!platformId) {\n    81→    errors.push(\n    82→      \"VITE_PLATFORM_PROGRAM_ID is required (deployed platform program address)\",\n    83→    );\n    84→  }\n    85→\n    86→  // Fail fast if any required var is missing\n    87→  if (errors.length > 0) {\n    88→    throw new Error(\n    89→      `Devnet E2E env validation failed:\\n  - ${errors.join(\"\\n  - \")}\\n\\n` +\n    90→        `Hint: copy .env.devnet to .env.local and update program IDs, ` +\n    91→        `or export the variables before running tests.`,\n    92→    );\n    93→  }\n    94→\n    95→  // --- Format validation ---\n    96→  const validatedUrl = parseUrl(rpcUrl!, \"VITE_RPC_URL\");\n    97→  const coinflipProgramId = parsePublicKey(\n    98→    coinflipId!,\n    99→    \"VITE_COINFLIP_PROGRAM_ID\",\n   100→  );\n   101→  const platformProgramId = parsePublicKey(\n   102→    platformId!,\n   103→    \"VITE_PLATFORM_PROGRAM_ID\",\n   104→  );\n   105→\n   106→  // --- Optional with default ---\n   107→  const network = process.env.VITE_SOLANA_NETWORK ?? \"devnet\";\n   108→\n   109→  return {\n   110→    rpcUrl: validatedUrl,\n   111→    network,\n   112→    coinflipProgramId,\n   113→    platformProgramId,\n   114→    oraoVrfProgramId: ORAO_VRF_PROGRAM_ID,\n   115→  };\n   116→}\n   117→\n   118→/**\n   119→ * Verify that the devnet RPC is reachable and that required programs\n   120→ * are deployed. Call this once in globalSetup or the first test's beforeAll.\n   121→ */\n   122→export async function verifyDevnetDeployments(\n   123→  config: DevnetConfig,\n   124→): Promise<void> {\n   125→  const connection = new Connection(config.rpcUrl, \"confirmed\");\n   126→\n   127→  // 1. RPC health check\n   128→  try {\n   129→    await connection.getLatestBlockhash();\n   130→  } catch (err) {\n   131→    throw new Error(\n   132→      `Cannot reach devnet RPC at ${config.rpcUrl}: ${err instanceof Error ? err.message : err}`,\n   133→    );\n   134→  }\n   135→\n   136→  // 2. Coinflip program deployed\n   137→  const coinflipAccount = await connection.getAccountInfo(\n   138→    config.coinflipProgramId,\n   139→  );\n   140→  if (!coinflipAccount || !coinflipAccount.executable) {\n   141→    throw new Error(\n   142→      `Coinflip program not found or not executable at ${config.coinflipProgramId.toBase58()}`,\n   143→    );\n   144→  }\n   145→\n   146→  // 3. Platform program deployed\n   147→  const platformAccount = await connection.getAccountInfo(\n   148→    config.platformProgramId,\n   149→  );\n   150→  if (!platformAccount || !platformAccount.executable) {\n   151→    throw new Error(\n   152→      `Platform program not found or not executable at ${config.platformProgramId.toBase58()}`,\n   153→    );\n   154→  }\n   155→\n   156→  // 4. Orao VRF program deployed\n   157→  const oraoAccount = await connection.getAccountInfo(\n   158→    config.oraoVrfProgramId,\n   159→  );\n   160→  if (!oraoAccount || !oraoAccount.executable) {\n   161→    throw new Error(\n   162→      `Orao VRF program not found or not executable at ${config.oraoVrfProgramId.toBase58()}`,\n   163→    );\n   164→  }\n   165→\n   166→  // 5. Orao VRF network state PDA exists (proves VRF is initialized)\n   167→  const [oraoNetworkState] = PublicKey.findProgramAddressSync(\n   168→    [Buffer.from(\"orao-vrf-network-configuration\")],\n   169→    config.oraoVrfProgramId,\n   170→  );\n   171→  const networkState = await connection.getAccountInfo(oraoNetworkState);\n   172→  if (!networkState) {\n   173→    throw new Error(\n   174→      `Orao VRF network state PDA not found at ${oraoNetworkState.toBase58()} — ` +\n   175→        `VRF provider may not be initialized on this cluster`,\n   176→    );\n   177→  }\n   178→}\n   179→"}]},"parent_tool_use_id":"toolu_01E2qhRFBfUs8uq9ca1Q8VQo","session_id":"a862d5c2-6727-4db5-bc9a-88f0e3c68612","uuid":"b35145dc-92a6-4c93-a8d1-760fc4205267"}
