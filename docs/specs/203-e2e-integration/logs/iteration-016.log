t observed phase (if any). */\n  lastPhase: string | null;\n  /** Transaction signatures on the match PDA (for debugging). */\n  signatures: string[];\n}\n\n// ── Helpers ─────────────────────────────────────────────────────────────\n\n/**\n * Collect recent transaction signatures for a match PDA.\n * Used for failure diagnostics — shows what transactions touched the account.\n */\nexport async function collectMatchSignatures(\n  connection: Connection,\n  matchPda: PublicKey,\n  limit = 10,\n): Promise<string[]> {\n  try {\n    const sigs = await connection.getSignaturesForAddress(matchPda, { limit });\n    return sigs.map((s) => s.signature);\n  } catch {\n    return [];\n  }\n}\n\n/**\n * Format a duration in milliseconds to a human-readable string.\n */\nfunction formatMs(ms: number): string {\n  if (ms < 1_000) return `${ms}ms`;\n  return `${(ms / 1_000).toFixed(1)}s`;\n}\n\n// ── Main polling function ───────────────────────────────────────────────\n\n/**\n * Poll the match PDA on-chain for VRF fulfillment with exponential backoff.\n *\n * Waits for the match phase to transition from \"locked\" to \"resolved\",\n * which indicates the Orao VRF callback has executed. Logs timing budget\n * at each attempt for observability.\n *\n * @param connection - Solana RPC connection\n * @param creator - Match creator's public key (used to derive PDA)\n * @param timeoutMs - Maximum time to poll before giving up\n * @returns VrfPollResult on success\n * @throws VrfTimeoutError with diagnostics on timeout\n */\nexport async function pollVrfFulfillment(\n  connection: Connection,\n  creator: PublicKey,\n  timeoutMs: number,\n): Promise<VrfPollResult> {\n  const [matchPda] = getMatchPda(creator);\n  const startTime = Date.now();\n  let interval = INITIAL_INTERVAL;\n  let attempts = 0;\n  let lastPhase: string | null = null;\n\n  console.log(\n    `[vrf-poll] Starting VRF fulfillment polling for match PDA ${matchPda.toBase58()}`,\n  );\n  console.log(\n    `[vrf-poll] Timeout budget: ${formatMs(timeoutMs)}, initial interval: ${formatMs(INITIAL_INTERVAL)}`,\n  );\n\n  while (true) {\n    const elapsed = Date.now() - startTime;\n    const remaining = timeoutMs - elapsed;\n\n    if (remaining <= 0) {\n      // Timeout — collect diagnostic info\n      console.log(`[vrf-poll] TIMEOUT after ${formatMs(elapsed)} (${attempts} attempts)`);\n      const signatures = await collectMatchSignatures(connection, matchPda);\n      if (signatures.length > 0) {\n        console.log(`[vrf-poll] Match PDA transaction signatures:`);\n        signatures.forEach((sig, i) => console.log(`  [${i}] ${sig}`));\n      } else {\n        console.log(`[vrf-poll] No transaction signatures found on match PDA`);\n      }\n\n      const err = new Error(\n        `VRF fulfillment timed out after ${formatMs(elapsed)} (${attempts} attempts). ` +\n          `Last phase: ${lastPhase ?? \"unknown\"}. ` +\n          `Signatures: ${signatures.length > 0 ? signatures.join(\", \") : \"none\"}`,\n      ) as VrfTimeoutError;\n      err.elapsedMs = elapsed;\n      err.attempts = attempts;\n      err.lastPhase = lastPhase;\n      err.signatures = signatures;\n      throw err;\n    }\n\n    // Wait before polling (skip initial wait on first attempt)\n    if (attempts > 0) {\n      const sleepMs = Math.min(interval, remaining);\n      await new Promise((r) => setTimeout(r, sleepMs));\n    }\n\n    attempts++;\n    const elapsed2 = Date.now() - startTime;\n    const budgetPct = Math.round((elapsed2 / timeoutMs) * 100);\n\n    try {\n      const match = await fetchMatch(connection, matchPda);\n\n      if (!match) {\n        // Match PDA closed (claimed before we could observe resolved state)\n        console.log(\n          `[vrf-poll] Attempt ${attempts}: match PDA closed (already claimed?) ` +\n            `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n        );\n        lastPhase = \"closed\";\n      } else {\n        const phase = Object.keys(match.phase)[0];\n        lastPhase = phase;\n\n        console.log(\n          `[vrf-poll] Attempt ${attempts}: phase=\"${phase}\" ` +\n            `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n        );\n\n        if (phase === \"resolved\") {\n          console.log(\n            `[vrf-poll] VRF fulfilled! Detected in ${formatMs(elapsed2)} after ${attempts} attempts`,\n          );\n\n          // Log the fulfillment transaction signatures\n          const signatures = await collectMatchSignatures(connection, matchPda);\n          if (signatures.length > 0) {\n            console.log(`[vrf-poll] Match PDA transaction signatures:`);\n            signatures.forEach((sig, i) => console.log(`  [${i}] ${sig}`));\n          }\n\n          return {\n            match,\n            matchPda,\n            phase,\n            elapsedMs: elapsed2,\n            attempts,\n          };\n        }\n      }\n    } catch (err) {\n      console.log(\n        `[vrf-poll] Attempt ${attempts}: RPC error — ${err} ` +\n          `[${formatMs(elapsed2)} / ${formatMs(timeoutMs)}, ${budgetPct}% budget]`,\n      );\n    }\n\n    // Exponential backoff\n    interval = Math.min(interval * BACKOFF_FACTOR, MAX_INTERVAL);\n  }\n}\n\n/**\n * Log transaction signatures for a player's recent activity on devnet.\n * Useful for post-failure diagnostics.\n *\n * @param connection - Solana RPC connection\n * @param address - Address to inspect\n * @param label - Human-readable label for logging\n * @param limit - Max signatures to fetch\n */\nexport async function logRecentSignatures(\n  connection: Connection,\n  address: PublicKey,\n  label: string,\n  limit = 5,\n): Promise<string[]> {\n  try {\n    const sigs = await connection.getSignaturesForAddress(address, { limit });\n    if (sigs.length === 0) {\n      console.log(`[tx-log] ${label}: no recent signatures`);\n      return [];\n    }\n    console.log(`[tx-log] ${label}: ${sigs.length} recent signature(s):`);\n    const result: string[] = [];\n    for (const sig of sigs) {\n      const status = sig.err ? `FAILED: ${JSON.stringify(sig.err)}` : \"OK\";\n      console.log(`  ${sig.signature} [slot ${sig.slot}, ${status}]`);\n      result.push(sig.signature);\n    }\n    return result;\n  } catch {\n    console.log(`[tx-log] ${label}: failed to fetch signatures`);\n    return [];\n  }\n}\n","structuredPatch":[],"originalFile":null}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01QXCW2mRS8FhpHaWLY5tUod","type":"message","role":"assistant","content":[{"type":"text","text":"Now update the devnet lifecycle test to use the robust polling and logging:"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2679,"cache_read_input_tokens":60946,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2679},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a862d5c2-6727-4db5-bc9a-88f0e3c68612","uuid":"e6ae5fae-29ae-4ce0-99b4-438e26732d95"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01QXCW2mRS8FhpHaWLY5tUod","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012gsV4EZGs3rkNDagMz6PFi","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts","content":"/**\n * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. Connects to deployed devnet programs with\n * real Orao VRF fulfillment (no mock resolve shortcut).\n *\n * Prerequisites:\n * - Coinflip + Platform programs deployed to devnet\n * - Orao VRF initialized on devnet\n * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n * - Test wallets funded on devnet (handled in beforeAll)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"../local/helpers/page-objects\";\nimport { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\nimport { validateDevnetEnv } from \"./helpers/env\";\nimport {\n  pollVrfFulfillment,\n  logRecentSignatures,\n} from \"./helpers/vrf-polling\";\nimport { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n\n// ── Devnet wallet funding ─────────────────────────────────────────────\n\n/** Minimum SOL balance required to run the test (entry + tx fees). */\nconst MIN_BALANCE_SOL = 0.1;\n\n/** Airdrop amount per request on devnet (max 2 SOL per request). */\nconst AIRDROP_SOL = 1;\n\n/**\n * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n * is below the minimum threshold. Retries once on failure (devnet rate limits).\n */\nasync function ensureFunded(\n  connection: Connection,\n  pubkey: PublicKey,\n  label: string,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    console.log(\n      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    );\n    return;\n  }\n\n  console.log(\n    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n  );\n\n  for (let attempt = 1; attempt <= 2; attempt++) {\n    try {\n      const sig = await connection.requestAirdrop(\n        pubkey,\n        AIRDROP_SOL * LAMPORTS_PER_SOL,\n      );\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      await connection.confirmTransaction(\n        { signature: sig, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      const newBalance = await connection.getBalance(pubkey);\n      console.log(\n        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n      );\n      return;\n    } catch (err) {\n      if (attempt < 2) {\n        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n        await new Promise((r) => setTimeout(r, 2_000));\n      } else {\n        throw new Error(\n          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n        );\n      }\n    }\n  }\n}\n\n// ── VRF fulfillment timeout ───────────────────────────────────────────\n\n/**\n * Timeout for waiting on real VRF fulfillment.\n * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n */\nconst VRF_FULFILLMENT_TIMEOUT = 90_000;\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  const config = validateDevnetEnv();\n  console.log(\"Devnet lifecycle: funding test wallets...\");\n  const connection = new Connection(config.rpcUrl, \"confirmed\");\n  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 30_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // 4. Wait for real VRF fulfillment using dual strategy:\n  //    a) On-chain polling with exponential backoff (detects VRF callback)\n  //    b) UI result wait in parallel (detects frontend state update)\n  //    Whichever resolves first wins — this ensures robustness even if\n  //    the UI polling cycle is slow.\n  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n  const vrfStartTime = Date.now();\n\n  const [vrfPollResult, resultA, resultB] = await Promise.all([\n    // On-chain poll: check match PDA phase with exponential backoff\n    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n      .then((r) => {\n        console.log(\n          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n        );\n        return r;\n      })\n      .catch((err) => {\n        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n        return null; // Don't fail test if UI detects it first\n      }),\n    // UI wait: Playwright waits for result CSS class on Player A's page\n    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n    // UI wait: Playwright waits for result CSS class on Player B's page\n    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n  ]);\n\n  const vrfElapsed = Date.now() - vrfStartTime;\n  console.log(\n    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n  );\n  if (vrfPollResult) {\n    console.log(\n      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n    );\n  }\n\n  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n  expect(\n    (resultA === \"won\" && resultB === \"lost\") ||\n      (resultA === \"lost\" && resultB === \"won\"),\n  ).toBe(true);\n\n  // 6. Winner claims payout\n  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n  const loserLabel = resultA === \"lost\" ? \"Player A\" : \"Player B\";\n\n  await po.claimOrSettle(winnerPage);\n  console.log(`${winnerLabel} claimed payout`);\n\n  // Winner sees \"Back to Lobby\" after successful claim\n  await expect(\n    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 7. Winner returns to lobby\n  await po.backToLobby(winnerPage);\n\n  // 8. Loser settles (closes their view)\n  await po.claimOrSettle(loserPage);\n  await expect(\n    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n  await po.backToLobby(loserPage);\n\n  // 9. Log transaction signatures for both players (diagnostic artifact)\n  console.log(\"\\n--- Transaction Signature Log ---\");\n  await logRecentSignatures(connection, PLAYER_A.publicKey, `${winnerLabel === \"Player A\" ? \"Winner\" : \"Loser\"} (Player A)`);\n  await logRecentSignatures(connection, PLAYER_B.publicKey, `${winnerLabel === \"Player B\" ? \"Winner\" : \"Loser\"} (Player B)`);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2679,"cache_read_input_tokens":60946,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2679},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a862d5c2-6727-4db5-bc9a-88f0e3c68612","uuid":"b77eaf48-4933-4991-8b80-a51bf42cedf2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012gsV4EZGs3rkNDagMz6PFi","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"a862d5c2-6727-4db5-bc9a-88f0e3c68612","uuid":"caaca39a-7708-4d97-b96f-f238723a08ba","tool_use_result":{"type":"update","filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/devnet/lifecycle.spec.ts","content":"/**\n * Devnet lifecycle E2E test: create → join → real VRF resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. Connects to deployed devnet programs with\n * real Orao VRF fulfillment (no mock resolve shortcut).\n *\n * Prerequisites:\n * - Coinflip + Platform programs deployed to devnet\n * - Orao VRF initialized on devnet\n * - VITE_RPC_URL, VITE_COINFLIP_PROGRAM_ID, VITE_PLATFORM_PROGRAM_ID set\n * - Test wallets funded on devnet (handled in beforeAll)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"../local/helpers/page-objects\";\nimport { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";\nimport { validateDevnetEnv } from \"./helpers/env\";\nimport {\n  pollVrfFulfillment,\n  logRecentSignatures,\n} from \"./helpers/vrf-polling\";\nimport { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n\n// ── Devnet wallet funding ─────────────────────────────────────────────\n\n/** Minimum SOL balance required to run the test (entry + tx fees). */\nconst MIN_BALANCE_SOL = 0.1;\n\n/** Airdrop amount per request on devnet (max 2 SOL per request). */\nconst AIRDROP_SOL = 1;\n\n/**\n * Ensure a wallet has enough SOL on devnet. Requests airdrop if balance\n * is below the minimum threshold. Retries once on failure (devnet rate limits).\n */\nasync function ensureFunded(\n  connection: Connection,\n  pubkey: PublicKey,\n  label: string,\n): Promise<void> {\n  const balance = await connection.getBalance(pubkey);\n  if (balance >= MIN_BALANCE_SOL * LAMPORTS_PER_SOL) {\n    console.log(\n      `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL (sufficient)`,\n    );\n    return;\n  }\n\n  console.log(\n    `  ${label}: ${(balance / LAMPORTS_PER_SOL).toFixed(4)} SOL — requesting airdrop...`,\n  );\n\n  for (let attempt = 1; attempt <= 2; attempt++) {\n    try {\n      const sig = await connection.requestAirdrop(\n        pubkey,\n        AIRDROP_SOL * LAMPORTS_PER_SOL,\n      );\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      await connection.confirmTransaction(\n        { signature: sig, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n      const newBalance = await connection.getBalance(pubkey);\n      console.log(\n        `  ${label}: airdrop confirmed — ${(newBalance / LAMPORTS_PER_SOL).toFixed(4)} SOL`,\n      );\n      return;\n    } catch (err) {\n      if (attempt < 2) {\n        console.log(`  ${label}: airdrop attempt ${attempt} failed, retrying...`);\n        await new Promise((r) => setTimeout(r, 2_000));\n      } else {\n        throw new Error(\n          `Failed to fund ${label} on devnet after ${attempt} attempts: ${err}`,\n        );\n      }\n    }\n  }\n}\n\n// ── VRF fulfillment timeout ───────────────────────────────────────────\n\n/**\n * Timeout for waiting on real VRF fulfillment.\n * Orao VRF on devnet typically fulfills within 10-30s, but can be slower.\n */\nconst VRF_FULFILLMENT_TIMEOUT = 90_000;\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  const config = validateDevnetEnv();\n  console.log(\"Devnet lifecycle: funding test wallets...\");\n  const connection = new Connection(config.rpcUrl, \"confirmed\");\n  await ensureFunded(connection, PLAYER_A.publicKey, \"Player A\");\n  await ensureFunded(connection, PLAYER_B.publicKey, \"Player B\");\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 30_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // 4. Wait for real VRF fulfillment using dual strategy:\n  //    a) On-chain polling with exponential backoff (detects VRF callback)\n  //    b) UI result wait in parallel (detects frontend state update)\n  //    Whichever resolves first wins — this ensures robustness even if\n  //    the UI polling cycle is slow.\n  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");\n  const vrfStartTime = Date.now();\n\n  const [vrfPollResult, resultA, resultB] = await Promise.all([\n    // On-chain poll: check match PDA phase with exponential backoff\n    pollVrfFulfillment(connection, PLAYER_A.publicKey, VRF_FULFILLMENT_TIMEOUT)\n      .then((r) => {\n        console.log(\n          `[vrf] On-chain fulfillment detected in ${r.elapsedMs}ms after ${r.attempts} polls`,\n        );\n        return r;\n      })\n      .catch((err) => {\n        console.log(`[vrf] On-chain poll failed: ${err.message}`);\n        return null; // Don't fail test if UI detects it first\n      }),\n    // UI wait: Playwright waits for result CSS class on Player A's page\n    po.waitForResult(playerAPage, VRF_FULFILLMENT_TIMEOUT),\n    // UI wait: Playwright waits for result CSS class on Player B's page\n    po.waitForResult(playerBPage, VRF_FULFILLMENT_TIMEOUT),\n  ]);\n\n  const vrfElapsed = Date.now() - vrfStartTime;\n  console.log(\n    `[vrf] VRF resolved — Player A: ${resultA}, Player B: ${resultB} (total: ${vrfElapsed}ms)`,\n  );\n  if (vrfPollResult) {\n    console.log(\n      `[vrf] On-chain phase: ${vrfPollResult.phase}, polls: ${vrfPollResult.attempts}`,\n    );\n  }\n\n  // 5. Exactly one winner, one loser (real VRF, either outcome is valid)\n  expect(\n    (resultA === \"won\" && resultB === \"lost\") ||\n      (resultA === \"lost\" && resultB === \"won\"),\n  ).toBe(true);\n\n  // 6. Winner claims payout\n  const winnerPage = resultA === \"won\" ? playerAPage : playerBPage;\n  const loserPage = resultA === \"lost\" ? playerAPage : playerBPage;\n  const winnerLabel = resultA === \"won\" ? \"Player A\" : \"Player B\";\n  const loserLabel = resultA === \"lost\" ? \"Player A\" : \"Player B\";\n\n  await po.claimOrSettle(winnerPage);\n  console.log(`${winnerLabel} claimed payout`);\n\n  // Winner sees \"Back to Lobby\" after successful claim\n  await expect(\n    winnerPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n\n  // 7. Winner returns to lobby\n  await po.backToLobby(winnerPage);\n\n  // 8. Loser settles (closes their view)\n  await po.claimOrSettle(loserPage);\n  await expect(\n    loserPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n  await po.backToLobby(loserPage);\n\n  // 9. Log transaction signatures for both players (diagnostic artifact)\n  console.log(\"\\n--- Transaction Signature Log ---\");\n  await logRecentSignatures(connection, PLAYER_A.publicKey, `${winnerLabel === \"Player A\" ? \"Winner\" : \"Loser\"} (Player A)`);\n  await logRecentSignatures(connection, PLAYER_B.publicKey, `${winnerLabel === \"Player B\" ? \"Winner\" : \"Loser\"} (Player B)`);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","structuredPatch":[{"oldStart":15,"oldLines":6,"newStart":15,"newLines":10,"lines":[" import * as po from \"../local/helpers/page-objects\";"," import { PLAYER_A, PLAYER_B } from \"../local/helpers/wallets\";"," import { validateDevnetEnv } from \"./helpers/env\";","+import {","+  pollVrfFulfillment,","+  logRecentSignatures,","+} from \"./helpers/vrf-polling\";"," import { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";"," "," // ── Devnet wallet funding ─────────────────────────────────────────────"]},{"oldStart":99,"oldLines":6,"newStart":103,"newLines":7,"lines":[" test(\"coinflip devnet lifecycle: create → join → real VRF → claim\", async ({","   playerAPage,","   playerBPage,","+  connection,"," }) => {","   // Track console errors in both contexts","   const consoleA = po.trackConsoleErrors(playerAPage);"]},{"oldStart":120,"oldLines":17,"newStart":125,"newLines":42,"lines":["   // 3. Player B joins the match","   await po.joinMatch(playerBPage);"," ","-  // 4. Wait for real VRF fulfillment (no mock shortcut).","-  //    Orao VRF callback resolves the match on-chain, then the frontend","-  //    detects fulfillment via polling and shows the result.","-  console.log(\"Waiting for real VRF fulfillment...\");","+  // 4. Wait for real VRF fulfillment using dual strategy:","+  //    a) On-chain polling with exponential backoff (detects VRF callback)","+  //    b) UI result wait in parallel (detects frontend state update)","+  //    Whichever resolves first wins — this ensures robustness even if","+  //    the UI polling cycle is slow.","+  console.log(\"Waiting for real VRF fulfillment (dual: on-chain poll + UI wait)...\");","+  const vrfStartTime = Date.now();"," ","-  const [resultA, resultB] = await Pro