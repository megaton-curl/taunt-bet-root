{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011AFzp8XCGpz3V7dagU62Uc","type":"tool_result","content":"     1→import { describe, it } from \"mocha\";\n     2→import { expect } from \"chai\";\n     3→import { startAnchor, BankrunProvider } from \"anchor-bankrun\";\n     4→import { Program, AnchorError, Wallet } from \"@coral-xyz/anchor\";\n     5→import {\n     6→  Keypair,\n     7→  PublicKey,\n     8→  SystemProgram,\n     9→  LAMPORTS_PER_SOL,\n    10→} from \"@solana/web3.js\";\n    11→import { Clock } from \"solana-bankrun\";\n    12→import type { Coinflip } from \"../target/types/coinflip\";\n    13→import type { Platform } from \"../target/types/platform\";\n    14→import { readFileSync } from \"fs\";\n    15→import { dirname, join } from \"path\";\n    16→import { fileURLToPath } from \"url\";\n    17→\n    18→const __filename = fileURLToPath(import.meta.url);\n    19→const __dirname = dirname(__filename);\n    20→\n    21→const IDL = JSON.parse(\n    22→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"coinflip.json\"), \"utf8\")\n    23→);\n    24→const PROGRAM_ID = new PublicKey(IDL.address);\n    25→\n    26→const PLATFORM_IDL = JSON.parse(\n    27→  readFileSync(join(__dirname, \"..\", \"target\", \"idl\", \"platform.json\"), \"utf8\")\n    28→);\n    29→const PLATFORM_PROGRAM_ID = new PublicKey(PLATFORM_IDL.address);\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Constants matching shared crate\n    33→// ---------------------------------------------------------------------------\n    34→const SIDE_HEADS = 0;\n    35→const SIDE_TAILS = 1;\n    36→const TIER_IRON = 0;\n    37→const TIER_IRON_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n    38→const TOTAL_FEE_BPS = 300;\n    39→const DEFAULT_RESOLVE_TIMEOUT = 120; // seconds\n    40→\n    41→// Mock VRF randomness buffers (32 bytes each)\n    42→// HEADS: byte[0]=2 → 2%2=0=HEADS, non-zero so is_fulfilled=true\n    43→const RANDOMNESS_HEADS = (() => {\n    44→  const buf = Buffer.alloc(32);\n    45→  buf[0] = 2;\n    46→  return buf;\n    47→})();\n    48→// TAILS: byte[0]=1 → 1%2=1=TAILS, non-zero so is_fulfilled=true\n    49→const RANDOMNESS_TAILS = (() => {\n    50→  const buf = Buffer.alloc(32);\n    51→  buf[0] = 1;\n    52→  return buf;\n    53→})();\n    54→// Unfulfilled: all zeros → is_fulfilled=false\n    55→const RANDOMNESS_UNFULFILLED = Buffer.alloc(32);\n    56→\n    57→// ---------------------------------------------------------------------------\n    58→// PDA helpers\n    59→// ---------------------------------------------------------------------------\n    60→function getMatchPda(creator: PublicKey): PublicKey {\n    61→  const [pda] = PublicKey.findProgramAddressSync(\n    62→    [Buffer.from(\"match\"), creator.toBuffer()],\n    63→    PROGRAM_ID\n    64→  );\n    65→  return pda;\n    66→}\n    67→\n    68→function getConfigPda(): PublicKey {\n    69→  const [pda] = PublicKey.findProgramAddressSync(\n    70→    [Buffer.from(\"coinflip_config\")],\n    71→    PROGRAM_ID\n    72→  );\n    73→  return pda;\n    74→}\n    75→\n    76→function getPlatformConfigPda(): PublicKey {\n    77→  const [pda] = PublicKey.findProgramAddressSync(\n    78→    [Buffer.from(\"platform_config\")],\n    79→    PLATFORM_PROGRAM_ID\n    80→  );\n    81→  return pda;\n    82→}\n    83→\n    84→function getPlayerProfilePda(wallet: PublicKey): PublicKey {\n    85→  const [pda] = PublicKey.findProgramAddressSync(\n    86→    [Buffer.from(\"player_profile\"), wallet.toBuffer()],\n    87→    PLATFORM_PROGRAM_ID\n    88→  );\n    89→  return pda;\n    90→}\n    91→\n    92→// ---------------------------------------------------------------------------\n    93→// Test context factory\n    94→// ---------------------------------------------------------------------------\n    95→function fundedAccountData(lamports = 100 * LAMPORTS_PER_SOL) {\n    96→  return {\n    97→    lamports,\n    98→    data: Buffer.alloc(0),\n    99→    owner: SystemProgram.programId,\n   100→    executable: false,\n   101→  };\n   102→}\n   103→\n   104→interface TestContext {\n   105→  context: Awaited<ReturnType<typeof startAnchor>>;\n   106→  creator: PublicKey;\n   107→  opponent: Keypair;\n   108→  treasury: Keypair;\n   109→  mockRandomness: Keypair;\n   110→  mockOraoProgram: Keypair;\n   111→  mockOraoNetworkState: Keypair;\n   112→  mockOraoTreasury: Keypair;\n   113→  creatorProgram: Program<Coinflip>;\n   114→  opponentProgram: Program<Coinflip>;\n   115→  platformProgram: Program<Platform>;\n   116→  opponentPlatformProgram: Program<Platform>;\n   117→  configPda: PublicKey;\n   118→  matchPda: PublicKey;\n   119→  platformConfigPda: PublicKey;\n   120→  creatorProfilePda: PublicKey;\n   121→  opponentProfilePda: PublicKey;\n   122→}\n   123→\n   124→async function createTestContext(): Promise<TestContext> {\n   125→  const opponent = Keypair.generate();\n   126→  const treasury = Keypair.generate();\n   127→  const mockRandomness = Keypair.generate();\n   128→  const mockOraoProgram = Keypair.generate();\n   129→  const mockOraoNetworkState = Keypair.generate();\n   130→  const mockOraoTreasury = Keypair.generate();\n   131→\n   132→  const context = await startAnchor(\"./\", [], [\n   133→    { address: opponent.publicKey, info: fundedAccountData() },\n   134→    { address: treasury.publicKey, info: fundedAccountData() },\n   135→    // Mock Orao accounts (UncheckedAccount, CPI is no-op under mock-vrf)\n   136→    { address: mockOraoProgram.publicKey, info: fundedAccountData() },\n   137→    { address: mockOraoNetworkState.publicKey, info: fundedAccountData() },\n   138→    { address: mockOraoTreasury.publicKey, info: fundedAccountData() },\n   139→    // Mock randomness account — starts unfulfilled (32 zero bytes)\n   140→    {\n   141→      address: mockRandomness.publicKey,\n   142→      info: {\n   143→        lamports: LAMPORTS_PER_SOL,\n   144→        data: RANDOMNESS_UNFULFILLED,\n   145→        owner: SystemProgram.programId,\n   146→        executable: false,\n   147→      },\n   148→    },\n   149→  ]);\n   150→\n   151→  const creatorProvider = new BankrunProvider(context);\n   152→  const creatorProgram = new Program<Coinflip>(IDL, creatorProvider);\n   153→\n   154→  const opponentProvider = new BankrunProvider(context, new Wallet(opponent));\n   155→  const opponentProgram = new Program<Coinflip>(IDL, opponentProvider);\n   156→\n   157→  const platformProgram = new Program<Platform>(PLATFORM_IDL, creatorProvider);\n   158→  const opponentPlatformProgram = new Program<Platform>(\n   159→    PLATFORM_IDL,\n   160→    opponentProvider\n   161→  );\n   162→\n   163→  const creator = creatorProvider.wallet.publicKey;\n   164→  const configPda = getConfigPda();\n   165→  const matchPda = getMatchPda(creator);\n   166→  const platformConfigPda = getPlatformConfigPda();\n   167→  const creatorProfilePda = getPlayerProfilePda(creator);\n   168→  const opponentProfilePda = getPlayerProfilePda(opponent.publicKey);\n   169→\n   170→  return {\n   171→    context,\n   172→    creator,\n   173→    opponent,\n   174→    treasury,\n   175→    mockRandomness,\n   176→    mockOraoProgram,\n   177→    mockOraoNetworkState,\n   178→    mockOraoTreasury,\n   179→    creatorProgram,\n   180→    opponentProgram,\n   181→    platformProgram,\n   182→    opponentPlatformProgram,\n   183→    configPda,\n   184→    matchPda,\n   185→    platformConfigPda,\n   186→    creatorProfilePda,\n   187→    opponentProfilePda,\n   188→  };\n   189→}\n   190→\n   191→// ---------------------------------------------------------------------------\n   192→// Instruction helpers\n   193→// ---------------------------------------------------------------------------\n   194→async function initConfig(t: TestContext) {\n   195→  await t.creatorProgram.methods\n   196→    .initializeConfig(t.treasury.publicKey)\n   197→    .accounts({\n   198→      authority: t.creator,\n   199→      config: t.configPda,\n   200→      systemProgram: SystemProgram.programId,\n   201→    })\n   202→    .rpc();\n   203→}\n   204→\n   205→async function initPlatform(t: TestContext) {\n   206→  await t.platformProgram.methods\n   207→    .initializePlatform(t.treasury.publicKey)\n   208→    .accounts({\n   209→      authority: t.creator,\n   210→      config: t.platformConfigPda,\n   211→      systemProgram: SystemProgram.programId,\n   212→    })\n   213→    .rpc();\n   214→}\n   215→\n   216→async function createPlayerProfile(\n   217→  t: TestContext,\n   218→  program: Program<Platform>,\n   219→  player: PublicKey\n   220→) {\n   221→  const profilePda = getPlayerProfilePda(player);\n   222→  await program.methods\n   223→    .createPlayerProfile()\n   224→    .accounts({\n   225→      player,\n   226→      profile: profilePda,\n   227→      systemProgram: SystemProgram.programId,\n   228→    })\n   229→    .rpc();\n   230→}\n   231→\n   232→async function setupPlatform(t: TestContext) {\n   233→  await initPlatform(t);\n   234→  await createPlayerProfile(t, t.platformProgram, t.creator);\n   235→  await createPlayerProfile(\n   236→    t,\n   237→    t.opponentPlatformProgram,\n   238→    t.opponent.publicKey\n   239→  );\n   240→}\n   241→\n   242→async function createMatch(\n   243→  t: TestContext,\n   244→  tier = TIER_IRON,\n   245→  side = SIDE_HEADS\n   246→) {\n   247→  await t.creatorProgram.methods\n   248→    .createMatch(tier, side)\n   249→    .accounts({\n   250→      creator: t.creator,\n   251→      coinflipMatch: t.matchPda,\n   252→      config: t.configPda,\n   253→      systemProgram: SystemProgram.programId,\n   254→    })\n   255→    .rpc();\n   256→}\n   257→\n   258→async function joinMatch(t: TestContext) {\n   259→  await t.opponentProgram.methods\n   260→    .joinMatch()\n   261→    .accounts({\n   262→      opponent: t.opponent.publicKey,\n   263→      coinflipMatch: t.matchPda,\n   264→      config: t.configPda,\n   265→      oraoProgram: t.mockOraoProgram.publicKey,\n   266→      oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   267→      oraoTreasury: t.mockOraoTreasury.publicKey,\n   268→      oraoRandom: t.mockRandomness.publicKey,\n   269→      systemProgram: SystemProgram.programId,\n   270→    })\n   271→    .rpc();\n   272→}\n   273→\n   274→async function claimPayout(\n   275→  t: TestContext,\n   276→  callerProgram: Program<Coinflip>,\n   277→  callerPubkey: PublicKey\n   278→) {\n   279→  await callerProgram.methods\n   280→    .claimPayout()\n   281→    .accounts({\n   282→      caller: callerPubkey,\n   283→      coinflipMatch: t.matchPda,\n   284→      config: t.configPda,\n   285→      treasury: t.treasury.publicKey,\n   286→      creator: t.creator,\n   287→      opponent: t.opponent.publicKey,\n   288→      randomnessAccount: t.mockRandomness.publicKey,\n   289→      creatorProfile: t.creatorProfilePda,\n   290→      opponentProfile: t.opponentProfilePda,\n   291→      platformProgram: PLATFORM_PROGRAM_ID,\n   292→      systemProgram: SystemProgram.programId,\n   293→    })\n   294→    .rpc();\n   295→}\n   296→\n   297→async function cancelMatch(t: TestContext) {\n   298→  await t.creatorProgram.methods\n   299→    .cancelMatch()\n   300→    .accounts({\n   301→      creator: t.creator,\n   302→      coinflipMatch: t.matchPda,\n   303→      systemProgram: SystemProgram.programId,\n   304→    })\n   305→    .rpc();\n   306→}\n   307→\n   308→async function timeoutCancel(\n   309→  t: TestContext,\n   310→  callerProgram: Program<Coinflip>,\n   311→  callerPubkey: PublicKey\n   312→) {\n   313→  await callerProgram.methods\n   314→    .timeoutCancel()\n   315→    .accounts({\n   316→      caller: callerPubkey,\n   317→      creator: t.creator,\n   318→      opponent: t.opponent.publicKey,\n   319→      coinflipMatch: t.matchPda,\n   320→      randomnessAccount: t.mockRandomness.publicKey,\n   321→    })\n   322→    .rpc();\n   323→}\n   324→\n   325→function setMockRandomness(t: TestContext, data: Buffer) {\n   326→  t.context.setAccount(t.mockRandomness.publicKey, {\n   327→    lamports: LAMPORTS_PER_SOL,\n   328→    data,\n   329→    owner: SystemProgram.programId,\n   330→    executable: false,\n   331→  });\n   332→}\n   333→\n   334→async function getBalance(t: TestContext, pubkey: PublicKey): Promise<number> {\n   335→  const account = await t.context.banksClient.getAccount(pubkey);\n   336→  return account ? Number(account.lamports) : 0;\n   337→}\n   338→\n   339→async function warpPastDeadline(t: TestContext) {\n   340→  const clock = await t.context.banksClient.getClock();\n   341→  t.context.setClock(\n   342→    new Clock(\n   343→      clock.slot + BigInt(300),\n   344→      clock.epochStartTimestamp,\n   345→      clock.epoch,\n   346→      clock.leaderScheduleEpoch,\n   347→      clock.unixTimestamp + BigInt(DEFAULT_RESOLVE_TIMEOUT + 10)\n   348→    )\n   349→  );\n   350→}\n   351→\n   352→// ===========================================================================\n   353→// Tests\n   354→// ===========================================================================\n   355→describe(\"coinflip\", () => {\n   356→  // -----------------------------------------------------------------------\n   357→  // initialize_config\n   358→  // -----------------------------------------------------------------------\n   359→  describe(\"initialize_config\", () => {\n   360→    it(\"creates config with treasury and paused=false\", async () => {\n   361→      const t = await createTestContext();\n   362→      await initConfig(t);\n   363→\n   364→      const config = await t.creatorProgram.account.coinflipConfig.fetch(\n   365→        t.configPda\n   366→      );\n   367→      expect(config.authority.toBase58()).to.equal(t.creator.toBase58());\n   368→      expect(config.treasury.toBase58()).to.equal(\n   369→        t.treasury.publicKey.toBase58()\n   370→      );\n   371→      expect(config.paused).to.equal(false);\n   372→    });\n   373→  });\n   374→\n   375→  // -----------------------------------------------------------------------\n   376→  // create_match\n   377→  // -----------------------------------------------------------------------\n   378→  describe(\"create_match\", () => {\n   379→    it(\"creates match in Waiting phase with correct escrow\", async () => {\n   380→      const t = await createTestContext();\n   381→      await initConfig(t);\n   382→      await createMatch(t);\n   383→\n   384→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   385→      expect(m.creator.toBase58()).to.equal(t.creator.toBase58());\n   386→      expect(m.opponent.toBase58()).to.equal(PublicKey.default.toBase58());\n   387→      expect(m.tier).to.equal(TIER_IRON);\n   388→      expect(m.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   389→      expect(m.creatorSide).to.equal(SIDE_HEADS);\n   390→      expect(JSON.stringify(m.phase)).to.equal(JSON.stringify({ waiting: {} }));\n   391→      expect(m.claimed).to.equal(false);\n   392→      expect(m.createdAt.toNumber()).to.be.greaterThan(0);\n   393→    });\n   394→\n   395→    it(\"escrows correct lamport amount\", async () => {\n   396→      const t = await createTestContext();\n   397→      await initConfig(t);\n   398→      const balanceBefore = await getBalance(t, t.creator);\n   399→\n   400→      await createMatch(t);\n   401→\n   402→      const matchBalance = await getBalance(t, t.matchPda);\n   403→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   404→      const rentLamports = matchBalance - m.entryAmount.toNumber();\n   405→      expect(rentLamports).to.be.greaterThan(0);\n   406→      expect(m.entryAmount.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   407→\n   408→      const balanceAfter = await getBalance(t, t.creator);\n   409→      const spent = balanceBefore - balanceAfter;\n   410→      // Creator paid entry_amount + rent + tx fee (5000)\n   411→      expect(spent - matchBalance).to.equal(5000);\n   412→    });\n   413→\n   414→    it(\"rejects invalid side\", async () => {\n   415→      const t = await createTestContext();\n   416→      await initConfig(t);\n   417→      try {\n   418→        await t.creatorProgram.methods\n   419→          .createMatch(TIER_IRON, 3)\n   420→          .accounts({\n   421→            creator: t.creator,\n   422→            coinflipMatch: t.matchPda,\n   423→            config: t.configPda,\n   424→            systemProgram: SystemProgram.programId,\n   425→          })\n   426→          .rpc();\n   427→        expect.fail(\"Expected InvalidSide error\");\n   428→      } catch (err) {\n   429→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   430→          \"InvalidSide\"\n   431→        );\n   432→      }\n   433→    });\n   434→\n   435→    it(\"rejects invalid tier\", async () => {\n   436→      const t = await createTestContext();\n   437→      await initConfig(t);\n   438→      try {\n   439→        await t.creatorProgram.methods\n   440→          .createMatch(99, SIDE_HEADS)\n   441→          .accounts({\n   442→            creator: t.creator,\n   443→            coinflipMatch: t.matchPda,\n   444→            config: t.configPda,\n   445→            systemProgram: SystemProgram.programId,\n   446→          })\n   447→          .rpc();\n   448→        expect.fail(\"Expected InvalidTier error\");\n   449→      } catch (err) {\n   450→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   451→          \"InvalidTier\"\n   452→        );\n   453→      }\n   454→    });\n   455→  });\n   456→\n   457→  // -----------------------------------------------------------------------\n   458→  // join_match\n   459→  // -----------------------------------------------------------------------\n   460→  describe(\"join_match\", () => {\n   461→    it(\"transitions to Locked, doubles escrow, sets VRF fields\", async () => {\n   462→      const t = await createTestContext();\n   463→      await initConfig(t);\n   464→      await createMatch(t);\n   465→\n   466→      const escrowBefore = await getBalance(t, t.matchPda);\n   467→      await joinMatch(t);\n   468→\n   469→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   470→      expect(m.opponent.toBase58()).to.equal(\n   471→        t.opponent.publicKey.toBase58()\n   472→      );\n   473→      expect(JSON.stringify(m.phase)).to.equal(\n   474→        JSON.stringify({ locked: {} })\n   475→      );\n   476→      expect(m.vrfRequestKey.toBase58()).to.equal(\n   477→        t.mockRandomness.publicKey.toBase58()\n   478→      );\n   479→      expect(m.resolveDeadline.toNumber()).to.be.greaterThan(0);\n   480→      expect(m.lockedAt.toNumber()).to.be.greaterThan(0);\n   481→\n   482→      const escrowAfter = await getBalance(t, t.matchPda);\n   483→      expect(escrowAfter - escrowBefore).to.equal(TIER_IRON_AMOUNT);\n   484→    });\n   485→\n   486→    it(\"rejects self-join\", async () => {\n   487→      const t = await createTestContext();\n   488→      await initConfig(t);\n   489→      await createMatch(t);\n   490→\n   491→      try {\n   492→        await t.creatorProgram.methods\n   493→          .joinMatch()\n   494→          .accounts({\n   495→            opponent: t.creator,\n   496→            coinflipMatch: t.matchPda,\n   497→            config: t.configPda,\n   498→            oraoProgram: t.mockOraoProgram.publicKey,\n   499→            oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   500→            oraoTreasury: t.mockOraoTreasury.publicKey,\n   501→            oraoRandom: t.mockRandomness.publicKey,\n   502→            systemProgram: SystemProgram.programId,\n   503→          })\n   504→          .rpc();\n   505→        expect.fail(\"Expected CannotJoinOwnMatch error\");\n   506→      } catch (err) {\n   507→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   508→          \"CannotJoinOwnMatch\"\n   509→        );\n   510→      }\n   511→    });\n   512→\n   513→    it(\"rejects join when already Locked\", async () => {\n   514→      const t = await createTestContext();\n   515→      await initConfig(t);\n   516→      await createMatch(t);\n   517→      await joinMatch(t);\n   518→\n   519→      const secondOpponent = Keypair.generate();\n   520→      t.context.setAccount(secondOpponent.publicKey, fundedAccountData());\n   521→      const secondProvider = new BankrunProvider(\n   522→        t.context,\n   523→        new Wallet(secondOpponent)\n   524→      );\n   525→      const secondProgram = new Program<Coinflip>(IDL, secondProvider);\n   526→\n   527→      try {\n   528→        await secondProgram.methods\n   529→          .joinMatch()\n   530→          .accounts({\n   531→            opponent: secondOpponent.publicKey,\n   532→            coinflipMatch: t.matchPda,\n   533→            config: t.configPda,\n   534→            oraoProgram: t.mockOraoProgram.publicKey,\n   535→            oraoNetworkState: t.mockOraoNetworkState.publicKey,\n   536→            oraoTreasury: t.mockOraoTreasury.publicKey,\n   537→            oraoRandom: t.mockRandomness.publicKey,\n   538→            systemProgram: SystemProgram.programId,\n   539→          })\n   540→          .rpc();\n   541→        expect.fail(\"Expected InvalidTransition error\");\n   542→      } catch (err) {\n   543→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   544→          \"InvalidTransition\"\n   545→        );\n   546→      }\n   547→    });\n   548→  });\n   549→\n   550→  // -----------------------------------------------------------------------\n   551→  // claim_payout\n   552→  // -----------------------------------------------------------------------\n   553→  describe(\"claim_payout\", () => {\n   554→    it(\"creator wins with HEADS, fee to treasury\", async () => {\n   555→      const t = await createTestContext();\n   556→      await initConfig(t);\n   557→      await setupPlatform(t);\n   558→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   559→      await joinMatch(t);\n   560→\n   561→      // Write fulfilled randomness: byte[0]=2 → HEADS\n   562→      setMockRandomness(t, RANDOMNESS_HEADS);\n   563→\n   564→      const pool = TIER_IRON_AMOUNT * 2;\n   565→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   566→      const payout = pool - fee;\n   567→\n   568→      const winnerBefore = await getBalance(t, t.creator);\n   569→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   570→\n   571→      await claimPayout(t, t.creatorProgram, t.creator);\n   572→\n   573→      const winnerAfter = await getBalance(t, t.creator);\n   574→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   575→\n   576→      // Creator receives payout + rent refund from closed PDA (minus tx fee)\n   577→      expect(winnerAfter - winnerBefore).to.be.greaterThanOrEqual(payout);\n   578→      // Treasury receives exact fee\n   579→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   580→    });\n   581→\n   582→    it(\"opponent wins with TAILS\", async () => {\n   583→      const t = await createTestContext();\n   584→      await initConfig(t);\n   585→      await setupPlatform(t);\n   586→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   587→      await joinMatch(t);\n   588→\n   589→      setMockRandomness(t, RANDOMNESS_TAILS);\n   590→\n   591→      const pool = TIER_IRON_AMOUNT * 2;\n   592→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   593→      const payout = pool - fee;\n   594→\n   595→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   596→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   597→\n   598→      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n   599→\n   600→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n   601→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   602→\n   603→      // Opponent receives payout (minus tx fee of 5000)\n   604→      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(\n   605→        payout - 5000\n   606→      );\n   607→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   608→    });\n   609→\n   610→    it(\"either player can trigger claim — payout goes to derived winner\", async () => {\n   611→      const t = await createTestContext();\n   612→      await initConfig(t);\n   613→      await setupPlatform(t);\n   614→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   615→      await joinMatch(t);\n   616→\n   617→      // TAILS → opponent wins, but creator triggers claim\n   618→      setMockRandomness(t, RANDOMNESS_TAILS);\n   619→\n   620→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   621→\n   622→      // Creator calls claim, but payout goes to opponent (derived winner)\n   623→      await claimPayout(t, t.creatorProgram, t.creator);\n   624→\n   625→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n   626→      const pool = TIER_IRON_AMOUNT * 2;\n   627→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   628→      const payout = pool - fee;\n   629→\n   630→      // Opponent didn't call any tx, so exact payout (no tx fee deduction)\n   631→      expect(opponentAfter - opponentBefore).to.equal(payout);\n   632→    });\n   633→\n   634→    it(\"match PDA closed after claim\", async () => {\n   635→      const t = await createTestContext();\n   636→      await initConfig(t);\n   637→      await setupPlatform(t);\n   638→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   639→      await joinMatch(t);\n   640→      setMockRandomness(t, RANDOMNESS_HEADS);\n   641→\n   642→      await claimPayout(t, t.creatorProgram, t.creator);\n   643→\n   644→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   645→      expect(matchAccount).to.be.null;\n   646→    });\n   647→\n   648→    it(\"rejects claim with unfulfilled randomness\", async () => {\n   649→      const t = await createTestContext();\n   650→      await initConfig(t);\n   651→      await setupPlatform(t);\n   652→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   653→      await joinMatch(t);\n   654→      // Randomness stays all zeros (unfulfilled)\n   655→\n   656→      try {\n   657→        await claimPayout(t, t.creatorProgram, t.creator);\n   658→        expect.fail(\"Expected RandomnessNotFulfilled error\");\n   659→      } catch (err) {\n   660→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   661→          \"RandomnessNotFulfilled\"\n   662→        );\n   663→      }\n   664→    });\n   665→\n   666→    it(\"rejects double claim (account closed)\", async () => {\n   667→      const t = await createTestContext();\n   668→      await initConfig(t);\n   669→      await setupPlatform(t);\n   670→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   671→      await joinMatch(t);\n   672→      setMockRandomness(t, RANDOMNESS_HEADS);\n   673→\n   674→      await claimPayout(t, t.creatorProgram, t.creator);\n   675→\n   676→      try {\n   677→        await claimPayout(t, t.creatorProgram, t.creator);\n   678→        expect.fail(\"Expected error on double claim\");\n   679→      } catch (err) {\n   680→        // Account is closed — second claim fails\n   681→        expect(err).to.exist;\n   682→      }\n   683→    });\n   684→\n   685→    it(\"rejects unauthorized caller (not creator or opponent)\", async () => {\n   686→      const t = await createTestContext();\n   687→      await initConfig(t);\n   688→      await setupPlatform(t);\n   689→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   690→      await joinMatch(t);\n   691→      setMockRandomness(t, RANDOMNESS_HEADS);\n   692→\n   693→      const thirdParty = Keypair.generate();\n   694→      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n   695→      const thirdProvider = new BankrunProvider(\n   696→        t.context,\n   697→        new Wallet(thirdParty)\n   698→      );\n   699→      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n   700→\n   701→      try {\n   702→        await thirdProgram.methods\n   703→          .claimPayout()\n   704→          .accounts({\n   705→            caller: thirdParty.publicKey,\n   706→            coinflipMatch: t.matchPda,\n   707→            config: t.configPda,\n   708→            treasury: t.treasury.publicKey,\n   709→            creator: t.creator,\n   710→            opponent: t.opponent.publicKey,\n   711→            randomnessAccount: t.mockRandomness.publicKey,\n   712→            creatorProfile: t.creatorProfilePda,\n   713→            opponentProfile: t.opponentProfilePda,\n   714→            platformProgram: PLATFORM_PROGRAM_ID,\n   715→            systemProgram: SystemProgram.programId,\n   716→          })\n   717→          .rpc();\n   718→        expect.fail(\"Expected UnauthorizedCaller error\");\n   719→      } catch (err) {\n   720→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   721→          \"UnauthorizedCaller\"\n   722→        );\n   723→      }\n   724→    });\n   725→\n   726→    it(\"updates player profiles via CPI — creator wins\", async () => {\n   727→      const t = await createTestContext();\n   728→      await initConfig(t);\n   729→      await setupPlatform(t);\n   730→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   731→      await joinMatch(t);\n   732→      setMockRandomness(t, RANDOMNESS_HEADS);\n   733→\n   734→      await claimPayout(t, t.creatorProgram, t.creator);\n   735→\n   736→      const pool = TIER_IRON_AMOUNT * 2;\n   737→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   738→      const payout = pool - fee;\n   739→\n   740→      const cp = await t.platformProgram.account.playerProfile.fetch(\n   741→        t.creatorProfilePda\n   742→      );\n   743→      expect(cp.totalGames.toNumber()).to.equal(1);\n   744→      expect(cp.wins.toNumber()).to.equal(1);\n   745→      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   746→      expect(cp.totalWon.toNumber()).to.equal(payout);\n   747→\n   748→      const op = await t.platformProgram.account.playerProfile.fetch(\n   749→        t.opponentProfilePda\n   750→      );\n   751→      expect(op.totalGames.toNumber()).to.equal(1);\n   752→      expect(op.wins.toNumber()).to.equal(0);\n   753→      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   754→      expect(op.totalWon.toNumber()).to.equal(0);\n   755→    });\n   756→\n   757→    it(\"updates player profiles via CPI — opponent wins\", async () => {\n   758→      const t = await createTestContext();\n   759→      await initConfig(t);\n   760→      await setupPlatform(t);\n   761→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   762→      await joinMatch(t);\n   763→      setMockRandomness(t, RANDOMNESS_TAILS);\n   764→\n   765→      await claimPayout(t, t.opponentProgram, t.opponent.publicKey);\n   766→\n   767→      const pool = TIER_IRON_AMOUNT * 2;\n   768→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   769→      const payout = pool - fee;\n   770→\n   771→      const cp = await t.platformProgram.account.playerProfile.fetch(\n   772→        t.creatorProfilePda\n   773→      );\n   774→      expect(cp.totalGames.toNumber()).to.equal(1);\n   775→      expect(cp.wins.toNumber()).to.equal(0);\n   776→      expect(cp.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   777→      expect(cp.totalWon.toNumber()).to.equal(0);\n   778→\n   779→      const op = await t.platformProgram.account.playerProfile.fetch(\n   780→        t.opponentProfilePda\n   781→      );\n   782→      expect(op.totalGames.toNumber()).to.equal(1);\n   783→      expect(op.wins.toNumber()).to.equal(1);\n   784→      expect(op.totalWagered.toNumber()).to.equal(TIER_IRON_AMOUNT);\n   785→      expect(op.totalWon.toNumber()).to.equal(payout);\n   786→    });\n   787→  });\n   788→\n   789→  // -----------------------------------------------------------------------\n   790→  // cancel_match\n   791→  // -----------------------------------------------------------------------\n   792→  describe(\"cancel_match\", () => {\n   793→    it(\"creator cancels Waiting match, full refund\", async () => {\n   794→      const t = await createTestContext();\n   795→      await initConfig(t);\n   796→      await createMatch(t);\n   797→\n   798→      const balanceBefore = await getBalance(t, t.creator);\n   799→      await cancelMatch(t);\n   800→      const balanceAfter = await getBalance(t, t.creator);\n   801→\n   802→      // Creator gets escrow + rent back (minus tx fee)\n   803→      expect(balanceAfter - balanceBefore).to.be.greaterThanOrEqual(\n   804→        TIER_IRON_AMOUNT\n   805→      );\n   806→\n   807→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   808→      expect(matchAccount).to.be.null;\n   809→    });\n   810→\n   811→    it(\"rejects cancel after Locked (CannotCancel)\", async () => {\n   812→      const t = await createTestContext();\n   813→      await initConfig(t);\n   814→      await createMatch(t);\n   815→      await joinMatch(t);\n   816→\n   817→      try {\n   818→        await cancelMatch(t);\n   819→        expect.fail(\"Expected CannotCancel error\");\n   820→      } catch (err) {\n   821→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   822→          \"CannotCancel\"\n   823→        );\n   824→      }\n   825→    });\n   826→\n   827→    it(\"rejects cancel by non-creator\", async () => {\n   828→      const t = await createTestContext();\n   829→      await initConfig(t);\n   830→      await createMatch(t);\n   831→\n   832→      // Opponent tries to cancel creator's match — PDA mismatch\n   833→      const opponentMatchPda = getMatchPda(t.opponent.publicKey);\n   834→      try {\n   835→        await t.opponentProgram.methods\n   836→          .cancelMatch()\n   837→          .accounts({\n   838→            creator: t.opponent.publicKey,\n   839→            coinflipMatch: opponentMatchPda,\n   840→            systemProgram: SystemProgram.programId,\n   841→          })\n   842→          .rpc();\n   843→        expect.fail(\"Expected error\");\n   844→      } catch (err) {\n   845→        // PDA doesn't exist → AccountNotInitialized\n   846→        expect(err).to.exist;\n   847→      }\n   848→    });\n   849→  });\n   850→\n   851→  // -----------------------------------------------------------------------\n   852→  // timeout_cancel\n   853→  // -----------------------------------------------------------------------\n   854→  describe(\"timeout_cancel\", () => {\n   855→    it(\"permissionless refund after deadline when VRF unfulfilled\", async () => {\n   856→      const t = await createTestContext();\n   857→      await initConfig(t);\n   858→      await createMatch(t);\n   859→      await joinMatch(t);\n   860→      // Randomness stays unfulfilled (all zeros)\n   861→\n   862→      await warpPastDeadline(t);\n   863→\n   864→      const creatorBefore = await getBalance(t, t.creator);\n   865→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   866→\n   867→      // Third party triggers timeout (permissionless)\n   868→      const thirdParty = Keypair.generate();\n   869→      t.context.setAccount(thirdParty.publicKey, fundedAccountData());\n   870→      const thirdProvider = new BankrunProvider(\n   871→        t.context,\n   872→        new Wallet(thirdParty)\n   873→      );\n   874→      const thirdProgram = new Program<Coinflip>(IDL, thirdProvider);\n   875→\n   876→      await timeoutCancel(t, thirdProgram, thirdParty.publicKey);\n   877→\n   878→      const creatorAfter = await getBalance(t, t.creator);\n   879→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n   880→\n   881→      // Both players refunded entry amounts\n   882→      // Creator also gets rent refund from closed PDA\n   883→      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n   884→        TIER_IRON_AMOUNT\n   885→      );\n   886→      expect(opponentAfter - opponentBefore).to.equal(TIER_IRON_AMOUNT);\n   887→\n   888→      const matchAccount = await t.context.banksClient.getAccount(t.matchPda);\n   889→      expect(matchAccount).to.be.null;\n   890→    });\n   891→\n   892→    it(\"rejects timeout before deadline\", async () => {\n   893→      const t = await createTestContext();\n   894→      await initConfig(t);\n   895→      await createMatch(t);\n   896→      await joinMatch(t);\n   897→      // Don't warp clock\n   898→\n   899→      try {\n   900→        await timeoutCancel(t, t.creatorProgram, t.creator);\n   901→        expect.fail(\"Expected LockTimeoutNotElapsed error\");\n   902→      } catch (err) {\n   903→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   904→          \"LockTimeoutNotElapsed\"\n   905→        );\n   906→      }\n   907→    });\n   908→\n   909→    it(\"rejects timeout when VRF IS fulfilled — must claim instead\", async () => {\n   910→      const t = await createTestContext();\n   911→      await initConfig(t);\n   912→      await createMatch(t);\n   913→      await joinMatch(t);\n   914→\n   915→      // Set fulfilled randomness\n   916→      setMockRandomness(t, RANDOMNESS_HEADS);\n   917→      await warpPastDeadline(t);\n   918→\n   919→      try {\n   920→        await timeoutCancel(t, t.creatorProgram, t.creator);\n   921→        expect.fail(\"Expected error — VRF fulfilled, must claim\");\n   922→      } catch (err) {\n   923→        expect((err as AnchorError).error.errorCode.code).to.equal(\n   924→          \"InvalidPhase\"\n   925→        );\n   926→      }\n   927→    });\n   928→  });\n   929→\n   930→  // -----------------------------------------------------------------------\n   931→  // full lifecycle\n   932→  // -----------------------------------------------------------------------\n   933→  describe(\"full lifecycle\", () => {\n   934→    it(\"create → join → claim(HEADS) → PDA closed\", async () => {\n   935→      const t = await createTestContext();\n   936→      await initConfig(t);\n   937→      await setupPlatform(t);\n   938→\n   939→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   940→      let m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   941→      expect(JSON.stringify(m.phase)).to.equal(\n   942→        JSON.stringify({ waiting: {} })\n   943→      );\n   944→\n   945→      await joinMatch(t);\n   946→      m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   947→      expect(JSON.stringify(m.phase)).to.equal(\n   948→        JSON.stringify({ locked: {} })\n   949→      );\n   950→\n   951→      setMockRandomness(t, RANDOMNESS_HEADS);\n   952→\n   953→      const pool = TIER_IRON_AMOUNT * 2;\n   954→      const fee = Math.floor((pool * TOTAL_FEE_BPS) / 10_000);\n   955→      const treasuryBefore = await getBalance(t, t.treasury.publicKey);\n   956→\n   957→      await claimPayout(t, t.creatorProgram, t.creator);\n   958→\n   959→      const treasuryAfter = await getBalance(t, t.treasury.publicKey);\n   960→      expect(treasuryAfter - treasuryBefore).to.equal(fee);\n   961→\n   962→      const closed = await t.context.banksClient.getAccount(t.matchPda);\n   963→      expect(closed).to.be.null;\n   964→    });\n   965→\n   966→    it(\"create → cancel → create again\", async () => {\n   967→      const t = await createTestContext();\n   968→      await initConfig(t);\n   969→\n   970→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   971→      await cancelMatch(t);\n   972→\n   973→      const closed = await t.context.banksClient.getAccount(t.matchPda);\n   974→      expect(closed).to.be.null;\n   975→\n   976→      // Create again (same PDA slot is free)\n   977→      await createMatch(t, TIER_IRON, SIDE_TAILS);\n   978→      const m = await t.creatorProgram.account.coinflipMatch.fetch(t.matchPda);\n   979→      expect(m.creatorSide).to.equal(SIDE_TAILS);\n   980→      expect(JSON.stringify(m.phase)).to.equal(\n   981→        JSON.stringify({ waiting: {} })\n   982→      );\n   983→    });\n   984→\n   985→    it(\"create → join → timeout (VRF unfulfilled) → both refunded\", async () => {\n   986→      const t = await createTestContext();\n   987→      await initConfig(t);\n   988→\n   989→      await createMatch(t, TIER_IRON, SIDE_HEADS);\n   990→      await joinMatch(t);\n   991→\n   992→      await warpPastDeadline(t);\n   993→\n   994→      const creatorBefore = await getBalance(t, t.creator);\n   995→      const opponentBefore = await getBalance(t, t.opponent.publicKey);\n   996→\n   997→      await timeoutCancel(t, t.opponentProgram, t.opponent.publicKey);\n   998→\n   999→      const creatorAfter = await getBalance(t, t.creator);\n  1000→      const opponentAfter = await getBalance(t, t.opponent.publicKey);\n  1001→\n  1002→      expect(creatorAfter - creatorBefore).to.be.greaterThanOrEqual(\n  1003→        TIER_IRON_AMOUNT\n  1004→      );\n  1005→      expect(opponentAfter - opponentBefore).to.be.greaterThanOrEqual(\n  1006→        TIER_IRON_AMOUNT - 5000\n  1007→      ); // minus tx fee\n  1008→    });\n  1009→  });\n  1010→});\n  1011→"}]},"parent_tool_use_id":"toolu_01MHgym5RnB8s2qUH7EZDgyL","session_id":"248c4ef4-b3ae-4077-b882-1fe8d3113a11","uuid":"24cc76ee-9bb3-4080-8277-aaf52e41388e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NgwL7at7SYLZAwXkBsF4Gv","type":"tool_result","content":"     1→# Devnet Integration Test Plan\n     2→\n     3→Manual end-to-end test steps for verifying VRF-backed coinflip on Solana devnet.\n     4→\n     5→## Prerequisites\n     6→\n     7→1. Programs deployed to devnet (`./scripts/deploy-devnet.sh`)\n     8→2. Configs initialized (`npx ts-node --esm scripts/init-devnet-config.ts`)\n     9→3. Two browser wallets funded with devnet SOL (creator + opponent)\n    10→4. Frontend running with `.env.devnet` config (`cp .env.devnet .env.local && pnpm dev`)\n    11→\n    12→### Required Toolchain (Build/Deploy)\n    13→\n    14→- `anchor-cli 0.32.1`\n    15→- Solana CLI/Agave with `cargo-build-sbf` reporting `platform-tools v1.52+`\n    16→- Verify before deploy:\n    17→  - `anchor --version`\n    18→  - `solana --version`\n    19→  - `cargo-build-sbf --version`\n    20→\n    21→If `platform-tools` is below `v1.52`, SBF builds may fail on modern crates. Upgrade global tooling first, then retry deploy.\n    22→\n    23→## Test Flow\n    24→\n    25→### 1. Create Match\n    26→- Connect wallet A (creator)\n    27→- Select tier and side, click Create\n    28→- Verify match appears in lobby (phase: WAITING)\n    29→\n    30→### 2. Join Match (triggers VRF)\n    31→- Connect wallet B (opponent)\n    32→- Join the match from lobby\n    33→- Verify match transitions to LOCKED phase\n    34→- VRF oracle should call `resolve_match` within ~5-10s\n    35→\n    36→### 3. VRF Resolution\n    37→- Wait for match to transition from LOCKED to SETTLED\n    38→- Verify `result` field is populated (heads or tails)\n    39→- Verify `winner` field is set to one of the two players\n    40→\n    41→### 4. Claim Payout\n    42→- Connect as winner\n    43→- Click Claim\n    44→- Verify SOL received (entry * 2 * 0.97)\n    45→- Verify match account is closed\n    46→\n    47→### 5. Fee Verification\n    48→- Check treasury received 3% fee (via Solana Explorer)\n    49→\n    50→## Scripted Two-Party Validation\n    51→\n    52→You can run the same lifecycle without two browser wallets:\n    53→\n    54→`npx tsx scripts/test-devnet-lifecycle.ts`\n    55→\n    56→This script uses deployer wallet as creator and auto-generates/funds an ephemeral opponent wallet for join.\n    57→\n    58→## Troubleshooting\n    59→\n    60→- **Match stuck in LOCKED**: VRF callback may have failed. Check tx logs on Solana Explorer.\n    61→- **\"UnauthorizedOracle\" error**: Config `oracle_authority` doesn't match VRF_PROGRAM_IDENTITY. Re-run init script.\n    62→- **Insufficient balance**: Airdrop more devnet SOL: `solana airdrop 5`\n    63→"}]},"parent_tool_use_id":"toolu_01MHgym5RnB8s2qUH7EZDgyL","session_id":"248c4ef4-b3ae-4077-b882-1fe8d3113a11","uuid":"4cddeb15-91f5-43e1-a47f-dedd42cad8d3"}
