{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UZhgACZ8ac1FJKYzAnAAte","type":"tool_result","content":"     1→import { PublicKey, Transaction } from \"@solana/web3.js\";\n     2→\n     3→export interface WalletState {\n     4→  connected: boolean;\n     5→  connecting: boolean;\n     6→  address: string | null;\n     7→  publicKey: PublicKey | null;\n     8→}\n     9→\n    10→export interface WalletContextValue extends WalletState {\n    11→  connect: () => Promise<void>;\n    12→  disconnect: () => Promise<void>;\n    13→  sendTransaction: (transaction: Transaction) => Promise<string>;\n    14→  signMessage: (message: Uint8Array) => Promise<Uint8Array>;\n    15→  /** True if using mock wallet */\n    16→  isMock?: boolean;\n    17→  /** Get mock balance in SOL (mock mode only) */\n    18→  getBalance?: () => number;\n    19→  /** Get mock balance in lamports (mock mode only) */\n    20→  getBalanceLamports?: () => number;\n    21→  /** Update mock balance (mock mode only) */\n    22→  updateBalance?: (deltaLamports: number) => void;\n    23→}\n    24→"}]},"parent_tool_use_id":"toolu_01MHgym5RnB8s2qUH7EZDgyL","session_id":"248c4ef4-b3ae-4077-b882-1fe8d3113a11","uuid":"8a56edb1-53e7-4f47-8a32-d3e3b1be928e"}
