in title\n    await expect(page.locator(\".rpg-title\")).toBeVisible();\n\n    // Wallet icon is visible (real mode, not connected yet)\n    await expect(page.locator(\".rpg-wallet-icon\")).toBeVisible();\n\n    // No critical console errors\n    expect(consoleErrors).toEqual([]);\n  });\n});\n","numLines":26,"startLine":1,"totalLines":26}}}
