{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F6P8wkd9VsyR9woXvbTxRG","type":"tool_result","content":"     1→/**\n     2→ * Dual-browser-context fixture for local E2E tests.\n     3→ *\n     4→ * Provides two isolated browser contexts (playerA / playerB), each with:\n     5→ * - Its own storage and session state (no cross-contamination)\n     6→ * - A deterministic keypair seed injected via addInitScript so that\n     7→ *   WalletProvider (VITE_TEST_WALLET=true) picks up TestWalletProvider\n     8→ * - A ready-to-use Page instance\n     9→ *\n    10→ * Usage in tests:\n    11→ * ```ts\n    12→ * import { test, expect } from \"./fixtures\";\n    13→ *\n    14→ * test(\"lifecycle\", async ({ playerAPage, playerBPage }) => {\n    15→ *   // playerAPage and playerBPage are independent browser contexts\n    16→ * });\n    17→ * ```\n    18→ */\n    19→import { test as base, type BrowserContext, type Page } from \"@playwright/test\";\n    20→import { Keypair, Connection } from \"@solana/web3.js\";\n    21→import { PLAYER_A, PLAYER_B, LOCAL_RPC_URL } from \"./helpers/wallets\";\n    22→\n    23→export interface DualPlayerFixtures {\n    24→  /** Isolated browser context for player A (keypair injected). */\n    25→  playerAContext: BrowserContext;\n    26→  /** Isolated browser context for player B (keypair injected). */\n    27→  playerBContext: BrowserContext;\n    28→  /** Page within player A's context. */\n    29→  playerAPage: Page;\n    30→  /** Page within player B's context. */\n    31→  playerBPage: Page;\n    32→  /** Player A's deterministic keypair (same as PLAYER_A from wallets.ts). */\n    33→  playerAKeypair: Keypair;\n    34→  /** Player B's deterministic keypair (same as PLAYER_B from wallets.ts). */\n    35→  playerBKeypair: Keypair;\n    36→  /** Shared RPC connection to the local validator. */\n    37→  connection: Connection;\n    38→}\n    39→\n    40→/**\n    41→ * Inject a 32-byte keypair seed into a new browser context via addInitScript.\n    42→ * The seed is set on `window.__TEST_WALLET_SEED__` before any page script runs,\n    43→ * allowing TestWalletWrapper (lazy-loaded by WalletProvider) to construct the\n    44→ * correct Keypair at React render time.\n    45→ */\n    46→async function createPlayerContext(\n    47→  browser: BrowserContext[\"browser\"],\n    48→  keypair: Keypair,\n    49→): Promise<BrowserContext> {\n    50→  const context = await browser!.newContext();\n    51→  // Pass the 32-byte seed as a plain array (serialisable across the browser boundary)\n    52→  const seedArray = Array.from(keypair.secretKey.slice(0, 32));\n    53→  await context.addInitScript((seed: number[]) => {\n    54→    (window as unknown as Record<string, unknown>).__TEST_WALLET_SEED__ =\n    55→      new Uint8Array(seed);\n    56→  }, seedArray);\n    57→  return context;\n    58→}\n    59→\n    60→export const test = base.extend<DualPlayerFixtures>({\n    61→  // Expose keypairs as fixtures so tests can reference public keys, sign, etc.\n    62→  playerAKeypair: [PLAYER_A, { option: true }],\n    63→  playerBKeypair: [PLAYER_B, { option: true }],\n    64→\n    65→  // Shared connection fixture (created once per test)\n    66→  // eslint-disable-next-line no-empty-pattern\n    67→  connection: async ({}, use) => {\n    68→    const conn = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    69→    await use(conn);\n    70→  },\n    71→\n    72→  // --- Player A context + page ---\n    73→  playerAContext: async ({ browser, playerAKeypair }, use) => {\n    74→    const context = await createPlayerContext(browser, playerAKeypair);\n    75→    await use(context);\n    76→    await context.close();\n    77→  },\n    78→\n    79→  playerAPage: async ({ playerAContext }, use) => {\n    80→    const page = await playerAContext.newPage();\n    81→    await use(page);\n    82→  },\n    83→\n    84→  // --- Player B context + page ---\n    85→  playerBContext: async ({ browser, playerBKeypair }, use) => {\n    86→    const context = await createPlayerContext(browser, playerBKeypair);\n    87→    await use(context);\n    88→    await context.close();\n    89→  },\n    90→\n    91→  playerBPage: async ({ playerBContext }, use) => {\n    92→    const page = await playerBContext.newPage();\n    93→    await use(page);\n    94→  },\n    95→});\n    96→\n    97→export { expect } from \"@playwright/test\";\n    98→"}]},"parent_tool_use_id":"toolu_011NmLDGpD21DxpEiJBkRt9S","session_id":"fa72ea81-f347-48b5-9c89-c72eb0bf80d0","uuid":"288e5803-d45f-4d88-bf3e-d1c195618406"}
