{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019zdxT1UDbDF5YbvDtfy3j3","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# localnet-bootstrap.sh — Start a fresh solana-test-validator with coinflip + platform programs.\n     3→# Usage: ./scripts/localnet-bootstrap.sh\n     4→# Writes validator PID to .localnet.pid for teardown.\n     5→set -euo pipefail\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     8→PLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     9→SOLANA_DIR=\"$(cd \"$PLATFORM_DIR/../../solana\" && pwd)\"\n    10→\n    11→COINFLIP_SO=\"$SOLANA_DIR/target/deploy/coinflip.so\"\n    12→PLATFORM_SO=\"$SOLANA_DIR/target/deploy/platform.so\"\n    13→COINFLIP_KEYPAIR=\"$SOLANA_DIR/target/deploy/coinflip-keypair.json\"\n    14→PLATFORM_KEYPAIR=\"$SOLANA_DIR/target/deploy/platform-keypair.json\"\n    15→\n    16→COINFLIP_ID=\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n    17→PLATFORM_ID=\"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n    18→\n    19→# Mock Orao VRF accounts (pre-loaded for deterministic local E2E tests)\n    20→ACCOUNTS_DIR=\"$SCRIPT_DIR/localnet-accounts\"\n    21→\n    22→RPC_URL=\"http://127.0.0.1:8899\"\n    23→PID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\n    24→LEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\n    25→LOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n    26→\n    27→MAX_WAIT=30  # seconds to wait for RPC readiness\n    28→\n    29→# ── Preflight checks ─────────────────────────────────────────────────\n    30→for f in \"$COINFLIP_SO\" \"$PLATFORM_SO\" \"$COINFLIP_KEYPAIR\" \"$PLATFORM_KEYPAIR\"; do\n    31→  if [[ ! -f \"$f\" ]]; then\n    32→    echo \"ERROR: Missing $f — run 'anchor build' first.\" >&2\n    33→    exit 1\n    34→  fi\n    35→done\n    36→\n    37→if ! command -v solana-test-validator &>/dev/null; then\n    38→  echo \"ERROR: solana-test-validator not found on PATH.\" >&2\n    39→  exit 1\n    40→fi\n    41→\n    42→# Solana 3.x requires io_uring; Docker blocks it unless --security-opt=seccomp=unconfined\n    43→if python3 -c \"import ctypes, ctypes.util; libc=ctypes.CDLL(ctypes.util.find_library('c'),use_errno=True); libc.syscall(425,1,ctypes.c_char_p(b'\\0'*120)); import ctypes; exit(0 if ctypes.get_errno()!=38 else 1)\" 2>/dev/null; then\n    44→  : # io_uring available\n    45→else\n    46→  echo \"ERROR: io_uring syscall blocked (ENOSYS). Solana 3.x requires io_uring.\" >&2\n    47→  echo \"       Add '--security-opt=seccomp=unconfined' to your Docker/devcontainer runArgs.\" >&2\n    48→  exit 1\n    49→fi\n    50→\n    51→# ── Kill any existing validator ───────────────────────────────────────\n    52→if [[ -f \"$PID_FILE\" ]]; then\n    53→  OLD_PID=$(cat \"$PID_FILE\")\n    54→  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    55→    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    56→    kill \"$OLD_PID\" 2>/dev/null || true\n    57→    sleep 1\n    58→    kill -9 \"$OLD_PID\" 2>/dev/null || true\n    59→  fi\n    60→  rm -f \"$PID_FILE\"\n    61→fi\n    62→\n    63→# Also kill any stray validator on the same port\n    64→if lsof -ti :8899 &>/dev/null; then\n    65→  echo \"Killing process on port 8899...\"\n    66→  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n    67→  sleep 1\n    68→fi\n    69→\n    70→# ── Clean ledger for fresh state ──────────────────────────────────────\n    71→rm -rf \"$LEDGER_DIR\"\n    72→\n    73→# ── Start validator with programs preloaded at genesis ────────────────\n    74→echo \"Starting solana-test-validator...\"\n    75→solana-test-validator \\\n    76→  --ledger \"$LEDGER_DIR\" \\\n    77→  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n    78→  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n    79→  --account 5ER1oENnV4srxYdAynUfRzWeQCPQaqMiAp4VqyMbSqnK \"$ACCOUNTS_DIR/orao-network-state.json\" \\\n    80→  --account S4ne8ejGPUwNMNsE8L7gtjbTaBLBfVGdWNH6VQrL58a \"$ACCOUNTS_DIR/orao-random-player-a.json\" \\\n    81→  --account Ecs89dz8NsNoSxyUtp54G2HPbmvJr8qZnxnWUqiLT92r \"$ACCOUNTS_DIR/orao-treasury.json\" \\\n    82→  --reset \\\n    83→  --quiet \\\n    84→  > \"$LOG_FILE\" 2>&1 &\n    85→\n    86→VALIDATOR_PID=$!\n    87→echo \"$VALIDATOR_PID\" > \"$PID_FILE\"\n    88→echo \"Validator PID: $VALIDATOR_PID\"\n    89→\n    90→# ── Wait for RPC readiness ────────────────────────────────────────────\n    91→echo -n \"Waiting for RPC at $RPC_URL\"\n    92→ELAPSED=0\n    93→while (( ELAPSED < MAX_WAIT )); do\n    94→  if curl -s \"$RPC_URL\" \\\n    95→    -X POST \\\n    96→    -H \"Content-Type: application/json\" \\\n    97→    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    98→    | grep -q '\"result\"'; then\n    99→    echo \" ready (${ELAPSED}s)\"\n   100→    echo \"Localnet bootstrap complete.\"\n   101→    exit 0\n   102→  fi\n   103→\n   104→  # Check validator is still running\n   105→  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n   106→    echo \"\"\n   107→    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n   108→    tail -20 \"$LOG_FILE\" >&2\n   109→    rm -f \"$PID_FILE\"\n   110→    exit 1\n   111→  fi\n   112→\n   113→  sleep 1\n   114→  (( ELAPSED++ ))\n   115→  echo -n \".\"\n   116→done\n   117→\n   118→echo \"\"\n   119→echo \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\n   120→tail -20 \"$LOG_FILE\" >&2\n   121→kill \"$VALIDATOR_PID\" 2>/dev/null || true\n   122→rm -f \"$PID_FILE\"\n   123→exit 1\n   124→"}]},"parent_tool_use_id":"toolu_011NmLDGpD21DxpEiJBkRt9S","session_id":"fa72ea81-f347-48b5-9c89-c72eb0bf80d0","uuid":"5b91f7d1-e36e-4f53-9005-b66dabfbaca1"}
