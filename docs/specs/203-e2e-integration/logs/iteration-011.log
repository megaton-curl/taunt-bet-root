n  5096→\n  5097→.fairness-page .fairness-header h2 {\n  5098→  font-size: 1.125rem;\n  5099→  color: var(--color-neon-pink);\n  5100→  margin-bottom: 0.5rem;\n  5101→  text-shadow: none;\n  5102→}\n  5103→\n  5104→.fairness-subtitle {\n  5105→  font-size: 0.625rem;\n  5106→  color: var(--color-text-muted);\n  5107→}\n  5108→\n  5109→/* Fairness Tabs */\n  5110→.fairness-tabs {\n  5111→  display: flex;\n  5112→  gap: 0.5rem;\n  5113→  margin-bottom: 1.5rem;\n  5114→  border-bottom: 2px solid var(--color-surface-elevated);\n  5115→  padding-bottom: 0.5rem;\n  5116→}\n  5117→\n  5118→.fairness-tab {\n  5119→  font-family: var(--font-pixel);\n  5120→  font-size: 0.625rem;\n  5121→  background: transparent;\n  5122→  color: var(--color-text-dim);\n  5123→  border: 2px solid transparent;\n  5124→  padding: 0.625rem 1rem;\n  5125→  cursor: pointer;\n  5126→  text-transform: uppercase;\n  5127→  transition: all 0.2s;\n  5128→}\n  5129→\n  5130→.fairness-tab:hover {\n  5131→  color: var(--color-neon-pink);\n  5132→  text-shadow: none;\n  5133→}\n  5134→\n  5135→.fairness-tab.active {\n  5136→  color: var(--color-neon-cyan);\n  5137→  border-color: var(--color-neon-cyan);\n  5138→  background: rgba(160, 184, 208, 0.1);\n  5139→  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);"}]},"parent_tool_use_id":"toolu_01VpNLGkQCRfw2LavP3xMSER","session_id":"9011bcd3-c1e3-4ba2-996b-dc56e2b15fd6","uuid":"b4444e9c-0283-4f3c-bf04-b0c8c69ae652"}
