{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LSFpPAfVhijzrMDw68wnWF","type":"tool_result","content":"     1→import { ReactNode } from \"react\";\n     2→\n     3→export interface ToastProps {\n     4→  variant: \"success\" | \"error\" | \"warning\" | \"info\";\n     5→  message: ReactNode;\n     6→  onClose?: () => void;\n     7→}\n     8→\n     9→export function Toast({ variant, message, onClose }: ToastProps) {\n    10→  return (\n    11→    <div className={`rng-toast rng-toast--${variant}`} role=\"alert\">\n    12→      <span className=\"rng-toast__message\">{message}</span>\n    13→      {onClose && (\n    14→        <button className=\"rng-toast__close\" onClick={onClose}>\n    15→          &times;\n    16→        </button>\n    17→      )}\n    18→    </div>\n    19→  );\n    20→}\n    21→"}]},"parent_tool_use_id":"toolu_01VpNLGkQCRfw2LavP3xMSER","session_id":"9011bcd3-c1e3-4ba2-996b-dc56e2b15fd6","uuid":"ebda2b22-ea7e-4c98-95a7-0758c93b27ff"}
