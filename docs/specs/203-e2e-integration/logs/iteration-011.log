{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GLx2mtvfziea5G77Qd5tUQ","type":"tool_result","content":"     1→import { Component, ReactNode, ErrorInfo } from \"react\";\n     2→\n     3→interface Props {\n     4→  children: ReactNode;\n     5→}\n     6→\n     7→interface State {\n     8→  hasError: boolean;\n     9→  error: Error | null;\n    10→  errorInfo: ErrorInfo | null;\n    11→}\n    12→\n    13→export class ErrorBoundary extends Component<Props, State> {\n    14→  constructor(props: Props) {\n    15→    super(props);\n    16→    this.state = { hasError: false, error: null, errorInfo: null };\n    17→  }\n    18→\n    19→  static getDerivedStateFromError(error: Error): Partial<State> {\n    20→    return { hasError: true, error };\n    21→  }\n    22→\n    23→  componentDidCatch(error: Error, errorInfo: ErrorInfo): void {\n    24→    this.setState({ errorInfo });\n    25→    console.error(\"ErrorBoundary caught an error:\", error, errorInfo);\n    26→  }\n    27→\n    28→  render() {\n    29→    if (this.state.hasError) {\n    30→      return (\n    31→        <div\n    32→          style={{\n    33→            padding: \"2rem\",\n    34→            backgroundColor: \"#1a0c2e\",\n    35→            color: \"#f0b820\",\n    36→            fontFamily: \"monospace\",\n    37→            minHeight: \"100vh\",\n    38→          }}\n    39→        >\n    40→          <h1 style={{ marginBottom: \"1rem\" }}>Something went wrong</h1>\n    41→          <pre\n    42→            style={{\n    43→              backgroundColor: \"#0a0010\",\n    44→              padding: \"1rem\",\n    45→              borderRadius: \"4px\",\n    46→              overflow: \"auto\",\n    47→              marginBottom: \"1rem\",\n    48→            }}\n    49→          >\n    50→            {this.state.error?.toString()}\n    51→          </pre>\n    52→          {this.state.errorInfo && (\n    53→            <details style={{ marginTop: \"1rem\" }}>\n    54→              <summary style={{ cursor: \"pointer\", marginBottom: \"0.5rem\" }}>\n    55→                Component Stack\n    56→              </summary>\n    57→              <pre\n    58→                style={{\n    59→                  backgroundColor: \"#0a0010\",\n    60→                  padding: \"1rem\",\n    61→                  borderRadius: \"4px\",\n    62→                  overflow: \"auto\",\n    63→                  fontSize: \"0.75rem\",\n    64→                }}\n    65→              >\n    66→                {this.state.errorInfo.componentStack}\n    67→              </pre>\n    68→            </details>\n    69→          )}\n    70→          <button\n    71→            onClick={() => window.location.reload()}\n    72→            style={{\n    73→              marginTop: \"1rem\",\n    74→              padding: \"0.5rem 1rem\",\n    75→              backgroundColor: \"#f0b820\",\n    76→              color: \"white\",\n    77→              border: \"none\",\n    78→              borderRadius: \"4px\",\n    79→              cursor: \"pointer\",\n    80→            }}\n    81→          >\n    82→            Reload Page\n    83→          </button>\n    84→        </div>\n    85→      );\n    86→    }\n    87→\n    88→    return this.props.children;\n    89→  }\n    90→}\n    91→"}]},"parent_tool_use_id":"toolu_01VpNLGkQCRfw2LavP3xMSER","session_id":"9011bcd3-c1e3-4ba2-996b-dc56e2b15fd6","uuid":"4de2422e-af7b-41de-8941-027fd57f05dc"}
