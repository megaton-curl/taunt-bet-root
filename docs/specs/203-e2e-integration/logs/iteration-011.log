{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FnkeKi7xTjB5RvBhWKuFaT","type":"tool_result","content":"     1→/**\n     2→ * Shared E2E page-object helpers for coinflip tests.\n     3→ *\n     4→ * CSS-class-based selectors matching the actual component markup.\n     5→ * Provides create, join, claim, cancel actions and reusable wait/assert primitives.\n     6→ */\n     7→import { type Page, type Locator, expect } from \"@playwright/test\";\n     8→\n     9→// ---------------------------------------------------------------------------\n    10→// Selectors (CSS classes from CoinflipPage, ActiveMatchView, OpenMatchesList)\n    11→// ---------------------------------------------------------------------------\n    12→\n    13→export const sel = {\n    14→  // Page structure\n    15→  lobby: \".coinflip-lobby\",\n    16→  sidebar: \".coinflip-sidebar\",\n    17→  main: \".coinflip-main\",\n    18→\n    19→  // Sidebar — create flow\n    20→  sidebarTitle: \".coinflip-sidebar__title\",\n    21→  tierSelector: \".rng-tier-selector\",\n    22→  tierButton: (tier: string) => `.rng-tier-btn:has(.rng-tier-gem--${tier})`,\n    23→  tierButtonSelected: \".rng-tier-btn--selected\",\n    24→  sideSelector: \".coinflip-side-selector\",\n    25→  sideButtonHeads: \".coinflip-side-btn--heads\",\n    26→  sideButtonTails: \".coinflip-side-btn--tails\",\n    27→  sideButtonSelected: \".coinflip-side-btn--selected\",\n    28→  summary: \".coinflip-sidebar__summary\",\n    29→  actionButton: \".coinflip-action-btn\",\n    30→  actionButtonSecondary: \".coinflip-action-btn--secondary\",\n    31→\n    32→  // Lobby — open matches\n    33→  matchesList: \".coinflip-matches__list\",\n    34→  matchesCount: \".coinflip-matches__count\",\n    35→  matchCard: \".coinflip-match-card\",\n    36→  matchCardOwn: \".coinflip-match-card--own\",\n    37→  matchCardClaimable: \".coinflip-match-card--claimable\",\n    38→  matchCardJoinBtn: \".coinflip-match-card__join-btn\",\n    39→  matchCardAmount: \".coinflip-match-card__amount\",\n    40→  matchCardAddress: \".coinflip-match-card__address\",\n    41→\n    42→  // Active match view\n    43→  activeMatch: \".coinflip-active-match\",\n    44→  activeMatchTitle: \".coinflip-active-match__title\",\n    45→  activeMatchTitleWon: \".coinflip-active-match__title--won\",\n    46→  activeMatchTitleLost: \".coinflip-active-match__title--lost\",\n    47→  activeMatchWaiting: \".coinflip-active-match__waiting\",\n    48→  activeMatchPlaying: \".coinflip-active-match__playing\",\n    49→\n    50→  // Result\n    51→  resultOutcome: \".coinflip-result__outcome\",\n    52→  resultPayout: \".coinflip-result__payout\",\n    53→\n    54→  // Post-claim\n    55→  postClaim: \".coinflip-active-match__post-claim\",\n    56→\n    57→  // Error\n    58→  errorToast: \".coinflip-error-toast\",\n    59→  toastMessage: \".rng-toast__message\",\n    60→\n    61→  // Sidebar — active match info\n    62→  sidebarStatus: \".coinflip-sidebar__status\",\n    63→  sidebarPot: \".coinflip-sidebar__pot\",\n    64→} as const;\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Types\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export type CoinSide = \"heads\" | \"tails\";\n    71→export type Tier =\n    72→  | \"iron\"\n    73→  | \"bronze\"\n    74→  | \"silver\"\n    75→  | \"gold\"\n    76→  | \"platinum\"\n    77→  | \"diamond\";\n    78→\n    79→// ---------------------------------------------------------------------------\n    80→// Page-object actions\n    81→// ---------------------------------------------------------------------------\n    82→\n    83→/**\n    84→ * Navigate to the coinflip page and wait for the lobby to render.\n    85→ */\n    86→export async function navigateToCoinflip(page: Page): Promise<void> {\n    87→  await page.goto(\"/coinflip\", { waitUntil: \"networkidle\" });\n    88→  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 10_000 });\n    89→}\n    90→\n    91→/**\n    92→ * Select a tier in the sidebar tier selector.\n    93→ */\n    94→export async function selectTier(page: Page, tier: Tier): Promise<void> {\n    95→  await page.click(sel.tierButton(tier));\n    96→  await expect(page.locator(sel.tierButton(tier))).toHaveClass(/rng-tier-btn--selected/);\n    97→}\n    98→\n    99→/**\n   100→ * Select a coin side (heads or tails) in the sidebar.\n   101→ */\n   102→export async function selectSide(page: Page, side: CoinSide): Promise<void> {\n   103→  const selector =\n   104→    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n   105→  await page.click(selector);\n   106→  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n   107→}\n   108→\n   109→/**\n   110→ * Create a match: select tier, select side, click \"Create Game\".\n   111→ * Returns when the active match view (waiting state) is visible.\n   112→ */\n   113→export async function createMatch(\n   114→  page: Page,\n   115→  tier: Tier,\n   116→  side: CoinSide,\n   117→): Promise<void> {\n   118→  await selectTier(page, tier);\n   119→  await selectSide(page, side);\n   120→\n   121→  // Click create — button text is \"Create Game\"\n   122→  const createBtn = page.locator(sel.actionButton, {\n   123→    hasText: \"Create Game\",\n   124→  });\n   125→  await expect(createBtn).toBeEnabled();\n   126→  await createBtn.click();\n   127→\n   128→  // Wait for transition to active match (waiting for opponent)\n   129→  await page.waitForSelector(sel.activeMatch, {\n   130→    state: \"visible\",\n   131→    timeout: 15_000,\n   132→  });\n   133→}\n   134→\n   135→/**\n   136→ * Join a match visible in the lobby. If `matchIndex` is provided, join that\n   137→ * specific card (0-based). Otherwise joins the first joinable match.\n   138→ */\n   139→export async function joinMatch(\n   140→  page: Page,\n   141→  matchIndex = 0,\n   142→): Promise<void> {\n   143→  const cards = page.locator(\n   144→    `${sel.matchCard}:not(${sel.matchCardOwn}):not(${sel.matchCardClaimable})`,\n   145→  );\n   146→  const joinBtn = cards.nth(matchIndex).locator(sel.matchCardJoinBtn);\n   147→  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n   148→  await joinBtn.click();\n   149→\n   150→  // Wait for active match view to appear\n   151→  await page.waitForSelector(sel.activeMatch, {\n   152→    state: \"visible\",\n   153→    timeout: 15_000,\n   154→  });\n   155→}\n   156→\n   157→/**\n   158→ * Cancel the currently active match (phase = \"created\", waiting for opponent).\n   159→ * Clicks \"Cancel Match\" button in the ActiveMatchView.\n   160→ */\n   161→export async function cancelMatch(page: Page): Promise<void> {\n   162→  const cancelBtn = page.locator(\"button\", { hasText: \"Cancel Match\" });\n   163→  await expect(cancelBtn).toBeVisible({ timeout: 5_000 });\n   164→  await cancelBtn.click();\n   165→\n   166→  // Wait for lobby to reappear\n   167→  await page.waitForSelector(sel.lobby, {\n   168→    state: \"visible\",\n   169→    timeout: 15_000,\n   170→  });\n   171→}\n   172→\n   173→/**\n   174→ * Claim payout for the winner, or settle for the loser.\n   175→ * Clicks the \"Claim Payout\" or \"Settle & Return\" button in the sidebar.\n   176→ */\n   177→export async function claimOrSettle(page: Page): Promise<void> {\n   178→  // The claim/settle button is in the sidebar (CoinflipPage renders it there)\n   179→  const claimBtn = page.locator(sel.sidebar).locator(sel.actionButton).first();\n   180→  await expect(claimBtn).toBeEnabled({ timeout: 15_000 });\n   181→  await claimBtn.click();\n   182→\n   183→  // Wait for \"Back to Lobby\" button to confirm claim completed\n   184→  await expect(\n   185→    page.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   186→  ).toBeVisible({ timeout: 15_000 });\n   187→}\n   188→\n   189→/**\n   190→ * Click \"Back to Lobby\" to return after claiming.\n   191→ */\n   192→export async function backToLobby(page: Page): Promise<void> {\n   193→  const btn = page.locator(\"button\", { hasText: \"Back to Lobby\" });\n   194→  await expect(btn).toBeVisible();\n   195→  await btn.click();\n   196→  await page.waitForSelector(sel.lobby, {\n   197→    state: \"visible\",\n   198→    timeout: 10_000,\n   199→  });\n   200→}\n   201→\n   202→// ---------------------------------------------------------------------------\n   203→// Wait / assert primitives\n   204→// ---------------------------------------------------------------------------\n   205→\n   206→/**\n   207→ * Wait until the sidebar status text matches the expected phase label.\n   208→ * Phase labels: \"Waiting...\", \"Ready!\", \"Countdown...\", \"Flipping...\", \"Complete\"\n   209→ */\n   210→export async function waitForPhaseLabel(\n   211→  page: Page,\n   212→  label: string,\n   213→  timeout = 30_000,\n   214→): Promise<void> {\n   215→  await expect(page.locator(sel.sidebarStatus)).toHaveText(label, {\n   216→    timeout,\n   217→  });\n   218→}\n   219→\n   220→/**\n   221→ * Wait for the active match title to indicate a win or loss.\n   222→ */\n   223→export async function waitForResult(\n   224→  page: Page,\n   225→  timeout = 30_000,\n   226→): Promise<\"won\" | \"lost\"> {\n   227→  // Wait for either won or lost title class to appear\n   228→  const wonLocator = page.locator(sel.activeMatchTitleWon);\n   229→  const lostLocator = page.locator(sel.activeMatchTitleLost);\n   230→\n   231→  await expect(wonLocator.or(lostLocator)).toBeVisible({ timeout });\n   232→\n   233→  if (await wonLocator.isVisible()) return \"won\";\n   234→  return \"lost\";\n   235→}\n   236→\n   237→/**\n   238→ * Wait for a match to appear in the lobby's open match list.\n   239→ */\n   240→export async function waitForLobbyMatch(\n   241→  page: Page,\n   242→  timeout = 15_000,\n   243→): Promise<Locator> {\n   244→  const card = page.locator(\n   245→    `${sel.matchCard}:not(${sel.matchCardClaimable})`,\n   246→  ).first();\n   247→  await expect(card).toBeVisible({ timeout });\n   248→  return card;\n   249→}\n   250→\n   251→/**\n   252→ * Assert the lobby is empty (no open matches).\n   253→ */\n   254→export async function assertLobbyEmpty(\n   255→  page: Page,\n   256→  timeout = 10_000,\n   257→): Promise<void> {\n   258→  // Either the empty state text or zero non-claimable match cards\n   259→  await expect(\n   260→    page.locator(`${sel.matchCard}:not(${sel.matchCardClaimable})`),\n   261→  ).toHaveCount(0, { timeout });\n   262→}\n   263→\n   264→/**\n   265→ * Assert that an error toast is visible with the given message substring.\n   266→ */\n   267→export async function assertErrorToast(\n   268→  page: Page,\n   269→  messageSubstring: string,\n   270→  timeout = 5_000,\n   271→): Promise<void> {\n   272→  const toast = page.locator(sel.errorToast);\n   273→  await expect(toast).toBeVisible({ timeout });\n   274→  await expect(toast).toContainText(messageSubstring);\n   275→}\n   276→\n   277→/**\n   278→ * Assert that no error toasts are visible.\n   279→ */\n   280→export async function assertNoErrorToast(page: Page): Promise<void> {\n   281→  await expect(page.locator(sel.errorToast)).toHaveCount(0);\n   282→}\n   283→\n   284→/**\n   285→ * Get the current balance displayed or fetched from connection for a wallet.\n   286→ * This is a convenience wrapper for reading SOL balance via RPC, not UI-based.\n   287→ */\n   288→export async function getSolBalance(\n   289→  page: Page,\n   290→  walletAddress: string,\n   291→  rpcUrl = \"http://127.0.0.1:8899\",\n   292→): Promise<number> {\n   293→  return page.evaluate(\n   294→    async ({ address, rpc }) => {\n   295→      const res = await fetch(rpc, {\n   296→        method: \"POST\",\n   297→        headers: { \"Content-Type\": \"application/json\" },\n   298→        body: JSON.stringify({\n   299→          jsonrpc: \"2.0\",\n   300→          id: 1,\n   301→          method: \"getBalance\",\n   302→          params: [address, { commitment: \"confirmed\" }],\n   303→        }),\n   304→      });\n   305→      const json = await res.json();\n   306→      return (json.result?.value ?? 0) / 1_000_000_000;\n   307→    },\n   308→    { address: walletAddress, rpc: rpcUrl },\n   309→  );\n   310→}\n   311→\n   312→/**\n   313→ * Collect console errors from a page. Returns a cleanup function\n   314→ * and an array that accumulates errors.\n   315→ */\n   316→export function trackConsoleErrors(page: Page): {\n   317→  errors: string[];\n   318→  assertClean: () => void;\n   319→} {\n   320→  const errors: string[] = [];\n   321→  page.on(\"console\", (msg) => {\n   322→    if (msg.type() === \"error\") errors.push(msg.text());\n   323→  });\n   324→  return {\n   325→    errors,\n   326→    assertClean: () => {\n   327→      // Filter out known non-critical browser noise\n   328→      const real = errors.filter(\n   329→        (e) =>\n   330→          !e.includes(\"favicon.ico\") &&\n   331→          !e.includes(\"downloadable font\") &&\n   332→          !e.includes(\"third-party cookie\"),\n   333→      );\n   334→      expect(real).toEqual([]);\n   335→    },\n   336→  };\n   337→}\n   338→\n   339→/**\n   340→ * Wait for a specific text to appear anywhere on the page.\n   341→ */\n   342→export async function waitForText(\n   343→  page: Page,\n   344→  text: string,\n   345→  timeout = 10_000,\n   346→): Promise<void> {\n   347→  await expect(page.getByText(text).first()).toBeVisible({ timeout });\n   348→}\n   349→\n   350→/**\n   351→ * Wait for the lobby to be visible (no active match).\n   352→ */\n   353→export async function waitForLobby(\n   354→  page: Page,\n   355→  timeout = 15_000,\n   356→): Promise<void> {\n   357→  await page.waitForSelector(sel.lobby, {\n   358→    state: \"visible\",\n   359→    timeout,\n   360→  });\n   361→}\n   362→"}]},"parent_tool_use_id":null,"session_id":"9011bcd3-c1e3-4ba2-996b-dc56e2b15fd6","uuid":"221542d3-ac17-4ed9-aa29-03766da07e5d","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/page-objects.ts","content":"/**\n * Shared E2E page-object helpers for coinflip tests.\n *\n * CSS-class-based selectors matching the actual component markup.\n * Provides create, join, claim, cancel actions and reusable wait/assert primitives.\n */\nimport { type Page, type Locator, expect } from \"@playwright/test\";\n\n// ---------------------------------------------------------------------------\n// Selectors (CSS classes from CoinflipPage, ActiveMatchView, OpenMatchesList)\n// ---------------------------------------------------------------------------\n\nexport const sel = {\n  // Page structure\n  lobby: \".coinflip-lobby\",\n  sidebar: \".coinflip-sidebar\",\n  main: \".coinflip-main\",\n\n  // Sidebar — create flow\n  sidebarTitle: \".coinflip-sidebar__title\",\n  tierSelector: \".rng-tier-selector\",\n  tierButton: (tier: string) => `.rng-tier-btn:has(.rng-tier-gem--${tier})`,\n  tierButtonSelected: \".rng-tier-btn--selected\",\n  sideSelector: \".coinflip-side-selector\",\n  sideButtonHeads: \".coinflip-side-btn--heads\",\n  sideButtonTails: \".coinflip-side-btn--tails\",\n  sideButtonSelected: \".coinflip-side-btn--selected\",\n  summary: \".coinflip-sidebar__summary\",\n  actionButton: \".coinflip-action-btn\",\n  actionButtonSecondary: \".coinflip-action-btn--secondary\",\n\n  // Lobby — open matches\n  matchesList: \".coinflip-matches__list\",\n  matchesCount: \".coinflip-matches__count\",\n  matchCard: \".coinflip-match-card\",\n  matchCardOwn: \".coinflip-match-card--own\",\n  matchCardClaimable: \".coinflip-match-card--claimable\",\n  matchCardJoinBtn: \".coinflip-match-card__join-btn\",\n  matchCardAmount: \".coinflip-match-card__amount\",\n  matchCardAddress: \".coinflip-match-card__address\",\n\n  // Active match view\n  activeMatch: \".coinflip-active-match\",\n  activeMatchTitle: \".coinflip-active-match__title\",\n  activeMatchTitleWon: \".coinflip-active-match__title--won\",\n  activeMatchTitleLost: \".coinflip-active-match__title--lost\",\n  activeMatchWaiting: \".coinflip-active-match__waiting\",\n  activeMatchPlaying: \".coinflip-active-match__playing\",\n\n  // Result\n  resultOutcome: \".coinflip-result__outcome\",\n  resultPayout: \".coinflip-result__payout\",\n\n  // Post-claim\n  postClaim: \".coinflip-active-match__post-claim\",\n\n  // Error\n  errorToast: \".coinflip-error-toast\",\n  toastMessage: \".rng-toast__message\",\n\n  // Sidebar — active match info\n  sidebarStatus: \".coinflip-sidebar__status\",\n  sidebarPot: \".coinflip-sidebar__pot\",\n} as const;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type CoinSide = \"heads\" | \"tails\";\nexport type Tier =\n  | \"iron\"\n  | \"bronze\"\n  | \"silver\"\n  | \"gold\"\n  | \"platinum\"\n  | \"diamond\";\n\n// ---------------------------------------------------------------------------\n// Page-object actions\n// ---------------------------------------------------------------------------\n\n/**\n * Navigate to the coinflip page and wait for the lobby to render.\n */\nexport async function navigateToCoinflip(page: Page): Promise<void> {\n  await page.goto(\"/coinflip\", { waitUntil: \"networkidle\" });\n  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 10_000 });\n}\n\n/**\n * Select a tier in the sidebar tier selector.\n */\nexport async function selectTier(page: Page, tier: Tier): Promise<void> {\n  await page.click(sel.tierButton(tier));\n  await expect(page.locator(sel.tierButton(tier))).toHaveClass(/rng-tier-btn--selected/);\n}\n\n/**\n * Select a coin side (heads or tails) in the sidebar.\n */\nexport async function selectSide(page: Page, side: CoinSide): Promise<void> {\n  const selector =\n    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n  await page.click(selector);\n  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n}\n\n/**\n * Create a match: select tier, select side, click \"Create Game\".\n * Returns when the active match view (waiting state) is visible.\n */\nexport async function createMatch(\n  page: Page,\n  tier: Tier,\n  side: CoinSide,\n): Promise<void> {\n  await selectTier(page, tier);\n  await selectSide(page, side);\n\n  // Click create — button text is \"Create Game\"\n  const createBtn = page.locator(sel.actionButton, {\n    hasText: \"Create Game\",\n  });\n  await expect(createBtn).toBeEnabled();\n  await createBtn.click();\n\n  // Wait for transition to active match (waiting for opponent)\n  await page.waitForSelector(sel.activeMatch, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Join a match visible in the lobby. If `matchIndex` is provided, join that\n * specific card (0-based). Otherwise joins the first joinable match.\n */\nexport async function joinMatch(\n  page: Page,\n  matchIndex = 0,\n): Promise<void> {\n  const cards = page.locator(\n    `${sel.matchCard}:not(${sel.matchCardOwn}):not(${sel.matchCardClaimable})`,\n  );\n  const joinBtn = cards.nth(matchIndex).locator(sel.matchCardJoinBtn);\n  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n  await joinBtn.click();\n\n  // Wait for active match view to appear\n  await page.waitForSelector(sel.activeMatch, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Cancel the currently active match (phase = \"created\", waiting for opponent).\n * Clicks \"Cancel Match\" button in the ActiveMatchView.\n */\nexport async function cancelMatch(page: Page): Promise<void> {\n  const cancelBtn = page.locator(\"button\", { hasText: \"Cancel Match\" });\n  await expect(cancelBtn).toBeVisible({ timeout: 5_000 });\n  await cancelBtn.click();\n\n  // Wait for lobby to reappear\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout: 15_000,\n  });\n}\n\n/**\n * Claim payout for the winner, or settle for the loser.\n * Clicks the \"Claim Payout\" or \"Settle & Return\" button in the sidebar.\n */\nexport async function claimOrSettle(page: Page): Promise<void> {\n  // The claim/settle button is in the sidebar (CoinflipPage renders it there)\n  const claimBtn = page.locator(sel.sidebar).locator(sel.actionButton).first();\n  await expect(claimBtn).toBeEnabled({ timeout: 15_000 });\n  await claimBtn.click();\n\n  // Wait for \"Back to Lobby\" button to confirm claim completed\n  await expect(\n    page.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible({ timeout: 15_000 });\n}\n\n/**\n * Click \"Back to Lobby\" to return after claiming.\n */\nexport async function backToLobby(page: Page): Promise<void> {\n  const btn = page.locator(\"button\", { hasText: \"Back to Lobby\" });\n  await expect(btn).toBeVisible();\n  await btn.click();\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout: 10_000,\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Wait / assert primitives\n// ---------------------------------------------------------------------------\n\n/**\n * Wait until the sidebar status text matches the expected phase label.\n * Phase labels: \"Waiting...\", \"Ready!\", \"Countdown...\", \"Flipping...\", \"Complete\"\n */\nexport async function waitForPhaseLabel(\n  page: Page,\n  label: string,\n  timeout = 30_000,\n): Promise<void> {\n  await expect(page.locator(sel.sidebarStatus)).toHaveText(label, {\n    timeout,\n  });\n}\n\n/**\n * Wait for the active match title to indicate a win or loss.\n */\nexport async function waitForResult(\n  page: Page,\n  timeout = 30_000,\n): Promise<\"won\" | \"lost\"> {\n  // Wait for either won or lost title class to appear\n  const wonLocator = page.locator(sel.activeMatchTitleWon);\n  const lostLocator = page.locator(sel.activeMatchTitleLost);\n\n  await expect(wonLocator.or(lostLocator)).toBeVisible({ timeout });\n\n  if (await wonLocator.isVisible()) return \"won\";\n  return \"lost\";\n}\n\n/**\n * Wait for a match to appear in the lobby's open match list.\n */\nexport async function waitForLobbyMatch(\n  page: Page,\n  timeout = 15_000,\n): Promise<Locator> {\n  const card = page.locator(\n    `${sel.matchCard}:not(${sel.matchCardClaimable})`,\n  ).first();\n  await expect(card).toBeVisible({ timeout });\n  return card;\n}\n\n/**\n * Assert the lobby is empty (no open matches).\n */\nexport async function assertLobbyEmpty(\n  page: Page,\n  timeout = 10_000,\n): Promise<void> {\n  // Either the empty state text or zero non-claimable match cards\n  await expect(\n    page.locator(`${sel.matchCard}:not(${sel.matchCardClaimable})`),\n  ).toHaveCount(0, { timeout });\n}\n\n/**\n * Assert that an error toast is visible with the given message substring.\n */\nexport async function assertErrorToast(\n  page: Page,\n  messageSubstring: string,\n  timeout = 5_000,\n): Promise<void> {\n  const toast = page.locator(sel.errorToast);\n  await expect(toast).toBeVisible({ timeout });\n  await expect(toast).toContainText(messageSubstring);\n}\n\n/**\n * Assert that no error toasts are visible.\n */\nexport async function assertNoErrorToast(page: Page): Promise<void> {\n  await expect(page.locator(sel.errorToast)).toHaveCount(0);\n}\n\n/**\n * Get the current balance displayed or fetched from connection for a wallet.\n * This is a convenience wrapper for reading SOL balance via RPC, not UI-based.\n */\nexport async function getSolBalance(\n  page: Page,\n  walletAddress: string,\n  rpcUrl = \"http://127.0.0.1:8899\",\n): Promise<number> {\n  return page.evaluate(\n    async ({ address, rpc }) => {\n      const res = await fetch(rpc, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          jsonrpc: \"2.0\",\n          id: 1,\n          method: \"getBalance\",\n          params: [address, { commitment: \"confirmed\" }],\n        }),\n      });\n      const json = await res.json();\n      return (json.result?.value ?? 0) / 1_000_000_000;\n    },\n    { address: walletAddress, rpc: rpcUrl },\n  );\n}\n\n/**\n * Collect console errors from a page. Returns a cleanup function\n * and an array that accumulates errors.\n */\nexport function trackConsoleErrors(page: Page): {\n  errors: string[];\n  assertClean: () => void;\n} {\n  const errors: string[] = [];\n  page.on(\"console\", (msg) => {\n    if (msg.type() === \"error\") errors.push(msg.text());\n  });\n  return {\n    errors,\n    assertClean: () => {\n      // Filter out known non-critical browser noise\n      const real = errors.filter(\n        (e) =>\n          !e.includes(\"favicon.ico\") &&\n          !e.includes(\"downloadable font\") &&\n          !e.includes(\"third-party cookie\"),\n      );\n      expect(real).toEqual([]);\n    },\n  };\n}\n\n/**\n * Wait for a specific text to appear anywhere on the page.\n */\nexport async function waitForText(\n  page: Page,\n  text: string,\n  timeout = 10_000,\n): Promise<void> {\n  await expect(page.getByText(text).first()).toBeVisible({ timeout });\n}\n\n/**\n * Wait for the lobby to be visible (no active match).\n */\nexport async function waitForLobby(\n  page: Page,\n  timeout = 15_000,\n): Promise<void> {\n  await page.waitForSelector(sel.lobby, {\n    state: \"visible\",\n    timeout,\n  });\n}\n","numLines":362,"startLine":1,"totalLines":362}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MFuv8iLBYFyaqQEF6mjZWX","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WaJBx2CeFFVVD2NxoUP4Pu","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/lifecycle.spec.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":12948,"cache_read_input_tokens":60456,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":12948},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9011bcd3-c1e3-4ba2-996b-dc56e2b15fd6","uuid":"ce9065df-a3c5-46cb-a67b-67263ab64287"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WaJBx2CeFFVVD2NxoUP4Pu","type":"tool_result","content":"     1→/**\n     2→ * Local lifecycle E2E test: create → join → resolve → claim.\n     3→ *\n     4→ * Uses two isolated browser contexts (Player A and Player B) with\n     5→ * deterministic keypairs. The local validator has mock-VRF enabled,\n     6→ * and the randomness account is pre-loaded with fulfilled data\n     7→ * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n     8→ *\n     9→ * Prerequisites (handled by localnet-bootstrap.sh):\n    10→ * - solana-test-validator running with coinflip + platform programs\n    11→ * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n    12→ */\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import { fundTestWallets, PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    16→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    17→import {\n    18→  assertMatchCreated,\n    19→  assertMatchClosed,\n    20→  assertTreasuryFee,\n    21→  assertPlayerProfileDelta,\n    22→  snapshotBalance,\n    23→  snapshotPlayerProfile,\n    24→  getTreasuryAddress,\n    25→  calculateExpectedFee,\n    26→} from \"./helpers/on-chain\";\n    27→\n    28→// ── Suite setup ────────────────────────────────────────────────────────\n    29→\n    30→test.beforeAll(async () => {\n    31→  // Fund test wallets and initialize program configs\n    32→  await fundTestWallets();\n    33→  await initializeLocalnet();\n    34→});\n    35→\n    36→// ── Full lifecycle test ────────────────────────────────────────────────\n    37→\n    38→test(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n    39→  playerAPage,\n    40→  playerBPage,\n    41→  connection,\n    42→}) => {\n    43→  // On-chain constants for iron tier\n    44→  const TIER_IRON = 0;\n    45→  const SIDE_HEADS = 0;\n    46→  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n    47→\n    48→  // Track console errors in both contexts\n    49→  const consoleA = po.trackConsoleErrors(playerAPage);\n    50→  const consoleB = po.trackConsoleErrors(playerBPage);\n    51→\n    52→  // 1. Player A navigates and creates a match (iron tier, heads)\n    53→  await po.navigateToCoinflip(playerAPage);\n    54→  await po.createMatch(playerAPage, \"iron\", \"heads\");\n    55→\n    56→  // Player A should see the active match in \"waiting\" state\n    57→  await expect(\n    58→    playerAPage.locator(po.sel.activeMatchWaiting),\n    59→  ).toBeVisible({ timeout: 10_000 });\n    60→\n    61→  // ── On-chain: verify match PDA after creation ──\n    62→  const { matchPda } = await assertMatchCreated(\n    63→    connection,\n    64→    PLAYER_A.publicKey,\n    65→    TIER_IRON,\n    66→    SIDE_HEADS,\n    67→  );\n    68→\n    69→  // 2. Player B navigates (after match is created) and sees it in the lobby\n    70→  await po.navigateToCoinflip(playerBPage);\n    71→  await po.waitForLobbyMatch(playerBPage, 15_000);\n    72→\n    73→  // 3. Player B joins the match\n    74→  await po.joinMatch(playerBPage);\n    75→\n    76→  // ── On-chain: snapshot treasury + profiles before resolution/claim ──\n    77→  const treasury = await getTreasuryAddress(connection);\n    78→  const treasuryBefore = await snapshotBalance(connection, treasury);\n    79→  const profileABefore = await snapshotPlayerProfile(connection, PLAYER_A.publicKey);\n    80→  const profileBBefore = await snapshotPlayerProfile(connection, PLAYER_B.publicKey);\n    81→\n    82→  // 4. Both players wait for the result.\n    83→  //    VRF is pre-fulfilled (HEADS) → creator (Player A) wins.\n    84→  //    The frontend polls every 5s for VRF fulfillment, then shows\n    85→  //    a 3s flip animation before the \"complete\" phase.\n    86→  const [resultA, resultB] = await Promise.all([\n    87→    po.waitForResult(playerAPage, 30_000),\n    88→    po.waitForResult(playerBPage, 30_000),\n    89→  ]);\n    90→\n    91→  // 5. Verify results: Player A (creator, chose HEADS) should win\n    92→  expect(resultA).toBe(\"won\");\n    93→  expect(resultB).toBe(\"lost\");\n    94→\n    95→  // 6. Player A (winner) claims payout\n    96→  await po.claimOrSettle(playerAPage);\n    97→\n    98→  // Player A sees \"Back to Lobby\" after successful claim\n    99→  await expect(\n   100→    playerAPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n   101→  ).toBeVisible();\n   102→\n   103→  // ── On-chain: verify match PDA is closed after claim ──\n   104→  await assertMatchClosed(connection, matchPda);\n   105→\n   106→  // ── On-chain: verify treasury received the 3% fee ──\n   107→  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n   108→\n   109→  // ── On-chain: verify player profile updates ──\n   110→  const { payout } = calculateExpectedFee(ENTRY_AMOUNT);\n   111→\n   112→  // Player A (winner): +1 game, +1 win, wagered entry, won payout\n   113→  await assertPlayerProfileDelta(connection, PLAYER_A.publicKey, profileABefore, {\n   114→    totalGames: 1,\n   115→    wins: 1,\n   116→    totalWagered: ENTRY_AMOUNT,\n   117→    totalWon: payout,\n   118→  });\n   119→\n   120→  // Player B (loser): +1 game, +0 wins, wagered entry, won nothing\n   121→  await assertPlayerProfileDelta(connection, PLAYER_B.publicKey, profileBBefore, {\n   122→    totalGames: 1,\n   123→    wins: 0,\n   124→    totalWagered: ENTRY_AMOUNT,\n   125→    totalWon: 0,\n   126→  });\n   127→\n   128→  // 7. Player A returns to lobby\n   129→  await po.backToLobby(playerAPage);\n   130→\n   131→  // No unhandled console errors in either context\n   132→  consoleA.assertClean();\n   133→  consoleB.assertClean();\n   134→});\n   135→"}]},"parent_tool_use_id":null,"session_id":"9011bcd3-c1e3-4ba2-996b-dc56e2b15fd6","uuid":"a3071e8f-3edf-471c-97e8-a01e3e2cddd1","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/lifecycle.spec.ts","content":"/**\n * Local lifecycle E2E test: create → join → resolve → claim.\n *\n * Uses two isolated browser contexts (Player A and Player B) with\n * deterministic keypairs. The local validator has mock-VRF enabled,\n * and the randomness account is pre-loaded with fulfilled data\n * (byte[0] = 2 → HEADS → creator wins when they chose HEADS).\n *\n * Prerequisites (handled by localnet-bootstrap.sh):\n * - solana-test-validator running with coinflip + platform programs\n * - Orao mock accounts pre-loaded (network state, treasury, randomness)\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport { fundTestWallets, PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\nimport {\n  assertMatchCreated,\n  assertMatchClosed,\n  assertTreasuryFee,\n  assertPlayerProfileDelta,\n  snapshotBalance,\n  snapshotPlayerProfile,\n  getTreasuryAddress,\n  calculateExpectedFee,\n} from \"./helpers/on-chain\";\n\n// ── Suite setup ────────────────────────────────────────────────────────\n\ntest.beforeAll(async () => {\n  // Fund test wallets and initialize program configs\n  await fundTestWallets();\n  await initializeLocalnet();\n});\n\n// ── Full lifecycle test ────────────────────────────────────────────────\n\ntest(\"coinflip full lifecycle: create → join → resolve → claim\", async ({\n  playerAPage,\n  playerBPage,\n  connection,\n}) => {\n  // On-chain constants for iron tier\n  const TIER_IRON = 0;\n  const SIDE_HEADS = 0;\n  const ENTRY_AMOUNT = 5_000_000; // 0.005 SOL in lamports\n\n  // Track console errors in both contexts\n  const consoleA = po.trackConsoleErrors(playerAPage);\n  const consoleB = po.trackConsoleErrors(playerBPage);\n\n  // 1. Player A navigates and creates a match (iron tier, heads)\n  await po.navigateToCoinflip(playerAPage);\n  await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n  // Player A should see the active match in \"waiting\" state\n  await expect(\n    playerAPage.locator(po.sel.activeMatchWaiting),\n  ).toBeVisible({ timeout: 10_000 });\n\n  // ── On-chain: verify match PDA after creation ──\n  const { matchPda } = await assertMatchCreated(\n    connection,\n    PLAYER_A.publicKey,\n    TIER_IRON,\n    SIDE_HEADS,\n  );\n\n  // 2. Player B navigates (after match is created) and sees it in the lobby\n  await po.navigateToCoinflip(playerBPage);\n  await po.waitForLobbyMatch(playerBPage, 15_000);\n\n  // 3. Player B joins the match\n  await po.joinMatch(playerBPage);\n\n  // ── On-chain: snapshot treasury + profiles before resolution/claim ──\n  const treasury = await getTreasuryAddress(connection);\n  const treasuryBefore = await snapshotBalance(connection, treasury);\n  const profileABefore = await snapshotPlayerProfile(connection, PLAYER_A.publicKey);\n  const profileBBefore = await snapshotPlayerProfile(connection, PLAYER_B.publicKey);\n\n  // 4. Both players wait for the result.\n  //    VRF is pre-fulfilled (HEADS) → creator (Player A) wins.\n  //    The frontend polls every 5s for VRF fulfillment, then shows\n  //    a 3s flip animation before the \"complete\" phase.\n  const [resultA, resultB] = await Promise.all([\n    po.waitForResult(playerAPage, 30_000),\n    po.waitForResult(playerBPage, 30_000),\n  ]);\n\n  // 5. Verify results: Player A (creator, chose HEADS) should win\n  expect(resultA).toBe(\"won\");\n  expect(resultB).toBe(\"lost\");\n\n  // 6. Player A (winner) claims payout\n  await po.claimOrSettle(playerAPage);\n\n  // Player A sees \"Back to Lobby\" after successful claim\n  await expect(\n    playerAPage.locator(\"button\", { hasText: \"Back to Lobby\" }),\n  ).toBeVisible();\n\n  // ── On-chain: verify match PDA is closed after claim ──\n  await assertMatchClosed(connection, matchPda);\n\n  // ── On-chain: verify treasury received the 3% fee ──\n  await assertTreasuryFee(connection, treasury, treasuryBefore, ENTRY_AMOUNT);\n\n  // ── On-chain: verify player profile updates ──\n  const { payout } = calculateExpectedFee(ENTRY_AMOUNT);\n\n  // Player A (winner): +1 game, +1 win, wagered entry, won payout\n  await assertPlayerProfileDelta(connection, PLAYER_A.publicKey, profileABefore, {\n    totalGames: 1,\n    wins: 1,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: payout,\n  });\n\n  // Player B (loser): +1 game, +0 wins, wagered entry, won nothing\n  await assertPlayerProfileDelta(connection, PLAYER_B.publicKey, profileBBefore, {\n    totalGames: 1,\n    wins: 0,\n    totalWagered: ENTRY_AMOUNT,\n    totalWon: 0,\n  });\n\n  // 7. Player A returns to lobby\n  await po.backToLobby(playerAPage);\n\n  // No unhandled console errors in either context\n  consoleA.assertClean();\n  consoleB.assertClean();\n});\n","numLines":135,"startLine":1,"totalLines":135}}}
