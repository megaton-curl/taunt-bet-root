{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MDh684PL4y4rvhc1urKict","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014k3htVkeHqwEBrJMvaGHxs","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/error-flow.spec.ts","content":"/**\n * Local error-flow E2E tests: insufficient balance, join unavailable match,\n * settle already-claimed match.\n *\n * Tests run serially because later tests depend on chain state left by earlier\n * ones (e.g. additional airdrop in test 2).\n *\n * Prerequisites (handled by localnet-bootstrap.sh):\n * - solana-test-validator running with coinflip + platform programs\n * - Orao mock accounts pre-loaded (required for lifecycle in test 3)\n */\nimport { Connection } from \"@solana/web3.js\";\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport {\n  fundWallet,\n  PLAYER_A,\n  PLAYER_B,\n  LOCAL_RPC_URL,\n} from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\nimport { assertMatchClosed, getMatchPda } from \"./helpers/on-chain\";\n\n// ── Serial execution: skip remaining tests if one fails ───────────────\n\ntest.describe(\"Error flow tests\", () => {\n  test.describe.configure({ mode: \"serial\" });\n\n  test.beforeAll(async () => {\n    await initializeLocalnet();\n    const connection = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    // Fund Player A with minimal SOL — insufficient for iron tier (0.005 SOL)\n    await fundWallet(connection, PLAYER_A.publicKey, 0.001);\n    // Fund Player B with standard amount\n    await fundWallet(connection, PLAYER_B.publicKey, 10);\n  });\n\n  // ── Test 1: Insufficient balance ─────────────────────────────────────\n\n  test(\"insufficient balance: creating match shows error toast\", async ({\n    playerAPage,\n    connection,\n  }) => {\n    await po.navigateToCoinflip(playerAPage);\n    await po.selectTier(playerAPage, \"iron\");\n    await po.selectSide(playerAPage, \"heads\");\n\n    // Click \"Create Game\" — balance (0.001 SOL) < iron entry (0.005 SOL)\n    const createBtn = playerAPage.locator(po.sel.actionButton, {\n      hasText: \"Create Game\",\n    });\n    await expect(createBtn).toBeEnabled();\n    await createBtn.click();\n\n    // Error toast should appear with insufficient balance message\n    await po.assertErrorToast(playerAPage, \"Insufficient balance\", 10_000);\n\n    // Verify no match was created on-chain\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n  });\n\n  // ── Test 2: Join unavailable (cancelled) match ───────────────────────\n\n  test(\"joining unavailable match shows error toast\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n  }) => {\n    // Fund A properly for this test (previous test left A with 0.001 SOL)\n    await fundWallet(connection, PLAYER_A.publicKey, 10);\n\n    // A creates a match (iron tier, heads)\n    await po.navigateToCoinflip(playerAPage);\n    await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n    // B navigates and sees the match in lobby\n    await po.navigateToCoinflip(playerBPage);\n    await po.waitForLobbyMatch(playerBPage, 15_000);\n\n    // A cancels the match — PDA closes on-chain\n    await po.cancelMatch(playerAPage);\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n\n    // B tries to join the stale lobby card (lobby hasn't re-polled yet)\n    const joinBtn = playerBPage\n      .locator(\n        `${po.sel.matchCard}:not(${po.sel.matchCardOwn}):not(${po.sel.matchCardClaimable})`,\n      )\n      .first()\n      .locator(po.sel.matchCardJoinBtn);\n    await joinBtn.click();\n\n    // Error toast should appear on B's page\n    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n      timeout: 10_000,\n    });\n  });\n\n  // ── Test 3: Settle already-claimed match ─────────────────────────────\n\n  test(\"settling already-claimed match shows error toast\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n  }) => {\n    // A creates a match (iron tier, heads)\n    await po.navigateToCoinflip(playerAPage);\n    await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n    // B navigates and joins\n    await po.navigateToCoinflip(playerBPage);\n    await po.waitForLobbyMatch(playerBPage, 15_000);\n    await po.joinMatch(playerBPage);\n\n    // Both wait for VRF resolution (pre-loaded: HEADS → A wins)\n    const [resultA, resultB] = await Promise.all([\n      po.waitForResult(playerAPage, 30_000),\n      po.waitForResult(playerBPage, 30_000),\n    ]);\n    expect(resultA).toBe(\"won\");\n    expect(resultB).toBe(\"lost\");\n\n    // A (winner) claims payout — match PDA closes\n    await po.claimOrSettle(playerAPage);\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n\n    // B still sees \"Settle & Return\" because B's context hasn't refreshed.\n    // B tries to settle — fails because match PDA is already closed.\n    const settleBtn = playerBPage\n      .locator(po.sel.sidebar)\n      .locator(po.sel.actionButton)\n      .first();\n    await expect(settleBtn).toBeVisible({ timeout: 5_000 });\n    await settleBtn.click();\n\n    // Error toast should appear on B's page\n    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n      timeout: 10_000,\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":759,"cache_read_input_tokens":105382,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":759},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9011bcd3-c1e3-4ba2-996b-dc56e2b15fd6","uuid":"f8ab036c-56c8-427d-8341-516f78ad19ba"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014k3htVkeHqwEBrJMvaGHxs","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/error-flow.spec.ts"}]},"parent_tool_use_id":null,"session_id":"9011bcd3-c1e3-4ba2-996b-dc56e2b15fd6","uuid":"f1277ba1-2c79-4fc4-88b0-1892f1d2ee42","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/error-flow.spec.ts","content":"/**\n * Local error-flow E2E tests: insufficient balance, join unavailable match,\n * settle already-claimed match.\n *\n * Tests run serially because later tests depend on chain state left by earlier\n * ones (e.g. additional airdrop in test 2).\n *\n * Prerequisites (handled by localnet-bootstrap.sh):\n * - solana-test-validator running with coinflip + platform programs\n * - Orao mock accounts pre-loaded (required for lifecycle in test 3)\n */\nimport { Connection } from \"@solana/web3.js\";\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport {\n  fundWallet,\n  PLAYER_A,\n  PLAYER_B,\n  LOCAL_RPC_URL,\n} from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\nimport { assertMatchClosed, getMatchPda } from \"./helpers/on-chain\";\n\n// ── Serial execution: skip remaining tests if one fails ───────────────\n\ntest.describe(\"Error flow tests\", () => {\n  test.describe.configure({ mode: \"serial\" });\n\n  test.beforeAll(async () => {\n    await initializeLocalnet();\n    const connection = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    // Fund Player A with minimal SOL — insufficient for iron tier (0.005 SOL)\n    await fundWallet(connection, PLAYER_A.publicKey, 0.001);\n    // Fund Player B with standard amount\n    await fundWallet(connection, PLAYER_B.publicKey, 10);\n  });\n\n  // ── Test 1: Insufficient balance ─────────────────────────────────────\n\n  test(\"insufficient balance: creating match shows error toast\", async ({\n    playerAPage,\n    connection,\n  }) => {\n    await po.navigateToCoinflip(playerAPage);\n    await po.selectTier(playerAPage, \"iron\");\n    await po.selectSide(playerAPage, \"heads\");\n\n    // Click \"Create Game\" — balance (0.001 SOL) < iron entry (0.005 SOL)\n    const createBtn = playerAPage.locator(po.sel.actionButton, {\n      hasText: \"Create Game\",\n    });\n    await expect(createBtn).toBeEnabled();\n    await createBtn.click();\n\n    // Error toast should appear with insufficient balance message\n    await po.assertErrorToast(playerAPage, \"Insufficient balance\", 10_000);\n\n    // Verify no match was created on-chain\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n  });\n\n  // ── Test 2: Join unavailable (cancelled) match ───────────────────────\n\n  test(\"joining unavailable match shows error toast\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n  }) => {\n    // Fund A properly for this test (previous test left A with 0.001 SOL)\n    await fundWallet(connection, PLAYER_A.publicKey, 10);\n\n    // A creates a match (iron tier, heads)\n    await po.navigateToCoinflip(playerAPage);\n    await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n    // B navigates and sees the match in lobby\n    await po.navigateToCoinflip(playerBPage);\n    await po.waitForLobbyMatch(playerBPage, 15_000);\n\n    // A cancels the match — PDA closes on-chain\n    await po.cancelMatch(playerAPage);\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n\n    // B tries to join the stale lobby card (lobby hasn't re-polled yet)\n    const joinBtn = playerBPage\n      .locator(\n        `${po.sel.matchCard}:not(${po.sel.matchCardOwn}):not(${po.sel.matchCardClaimable})`,\n      )\n      .first()\n      .locator(po.sel.matchCardJoinBtn);\n    await joinBtn.click();\n\n    // Error toast should appear on B's page\n    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n      timeout: 10_000,\n    });\n  });\n\n  // ── Test 3: Settle already-claimed match ─────────────────────────────\n\n  test(\"settling already-claimed match shows error toast\", async ({\n    playerAPage,\n    playerBPage,\n    connection,\n  }) => {\n    // A creates a match (iron tier, heads)\n    await po.navigateToCoinflip(playerAPage);\n    await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n    // B navigates and joins\n    await po.navigateToCoinflip(playerBPage);\n    await po.waitForLobbyMatch(playerBPage, 15_000);\n    await po.joinMatch(playerBPage);\n\n    // Both wait for VRF resolution (pre-loaded: HEADS → A wins)\n    const [resultA, resultB] = await Promise.all([\n      po.waitForResult(playerAPage, 30_000),\n      po.waitForResult(playerBPage, 30_000),\n    ]);\n    expect(resultA).toBe(\"won\");\n    expect(resultB).toBe(\"lost\");\n\n    // A (winner) claims payout — match PDA closes\n    await po.claimOrSettle(playerAPage);\n    const [matchPda] = getMatchPda(PLAYER_A.publicKey);\n    await assertMatchClosed(connection, matchPda);\n\n    // B still sees \"Settle & Return\" because B's context hasn't refreshed.\n    // B tries to settle — fails because match PDA is already closed.\n    const settleBtn = playerBPage\n      .locator(po.sel.sidebar)\n      .locator(po.sel.actionButton)\n      .first();\n    await expect(settleBtn).toBeVisible({ timeout: 5_000 });\n    await settleBtn.click();\n\n    // Error toast should appear on B's page\n    await expect(playerBPage.locator(po.sel.errorToast)).toBeVisible({\n      timeout: 10_000,\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
