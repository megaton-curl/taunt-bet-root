{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01X2S9Qd2Nvqb3urUoST66jx","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01R4CHgQqYfEzDDwXrCXqpYF","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/scripts/localnet-teardown.sh","content":"#!/usr/bin/env bash\n# localnet-teardown.sh — Stop solana-test-validator and clean temp files.\n# Usage: ./scripts/localnet-teardown.sh [--keep-logs]\n# Reads PID from .localnet.pid (written by localnet-bootstrap.sh).\n# Safe to call multiple times or when no validator is running.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nPLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n\nPID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\nLEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\nLOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n\nKEEP_LOGS=false\nif [[ \"${1:-}\" == \"--keep-logs\" ]]; then\n  KEEP_LOGS=true\nfi\n\nCLEANED=false\n\n# ── Stop validator by PID file ───────────────────────────────────────\nif [[ -f \"$PID_FILE\" ]]; then\n  PID=$(cat \"$PID_FILE\")\n  if kill -0 \"$PID\" 2>/dev/null; then\n    echo \"Stopping validator (PID $PID)...\"\n    kill \"$PID\" 2>/dev/null || true\n    # Wait up to 5s for graceful shutdown\n    for _ in $(seq 1 10); do\n      if ! kill -0 \"$PID\" 2>/dev/null; then\n        break\n      fi\n      sleep 0.5\n    done\n    # Force kill if still running\n    if kill -0 \"$PID\" 2>/dev/null; then\n      echo \"Force-killing validator (PID $PID)...\"\n      kill -9 \"$PID\" 2>/dev/null || true\n    fi\n    CLEANED=true\n  fi\n  rm -f \"$PID_FILE\"\nfi\n\n# ── Kill any stray validator on port 8899 ────────────────────────────\nif command -v lsof &>/dev/null && lsof -ti :8899 &>/dev/null; then\n  STRAY_PID=$(lsof -ti :8899)\n  echo \"Killing stray process on port 8899 (PID $STRAY_PID)...\"\n  kill \"$STRAY_PID\" 2>/dev/null || true\n  sleep 1\n  kill -9 \"$STRAY_PID\" 2>/dev/null || true\n  CLEANED=true\nfi\n\n# ── Clean temp ledger ────────────────────────────────────────────────\nif [[ -d \"$LEDGER_DIR\" ]]; then\n  echo \"Removing ledger directory: $LEDGER_DIR\"\n  rm -rf \"$LEDGER_DIR\"\n  CLEANED=true\nfi\n\n# ── Clean log file (unless --keep-logs) ──────────────────────────────\nif [[ \"$KEEP_LOGS\" == false && -f \"$LOG_FILE\" ]]; then\n  echo \"Removing log file: $LOG_FILE\"\n  rm -f \"$LOG_FILE\"\n  CLEANED=true\nfi\n\nif [[ \"$CLEANED\" == true ]]; then\n  echo \"Localnet teardown complete.\"\nelse\n  echo \"Nothing to clean up (no running validator or temp files found).\"\nfi\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":908,"cache_read_input_tokens":45079,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":908},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d5435ef2-ead0-44c9-9cba-d5f84572c358","uuid":"a8077e54-f174-4f5f-afee-5b7c5fbc2e03"}
