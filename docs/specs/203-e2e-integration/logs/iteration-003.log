{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NdGfpF9Fz8EdZJCqpusCVp","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# localnet-bootstrap.sh — Start a fresh solana-test-validator with coinflip + platform programs.\n     3→# Usage: ./scripts/localnet-bootstrap.sh\n     4→# Writes validator PID to .localnet.pid for teardown.\n     5→set -euo pipefail\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     8→PLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     9→SOLANA_DIR=\"$(cd \"$PLATFORM_DIR/../../solana\" && pwd)\"\n    10→\n    11→COINFLIP_SO=\"$SOLANA_DIR/target/deploy/coinflip.so\"\n    12→PLATFORM_SO=\"$SOLANA_DIR/target/deploy/platform.so\"\n    13→COINFLIP_KEYPAIR=\"$SOLANA_DIR/target/deploy/coinflip-keypair.json\"\n    14→PLATFORM_KEYPAIR=\"$SOLANA_DIR/target/deploy/platform-keypair.json\"\n    15→\n    16→COINFLIP_ID=\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n    17→PLATFORM_ID=\"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n    18→\n    19→RPC_URL=\"http://127.0.0.1:8899\"\n    20→PID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\n    21→LEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\n    22→LOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n    23→\n    24→MAX_WAIT=30  # seconds to wait for RPC readiness\n    25→\n    26→# ── Preflight checks ─────────────────────────────────────────────────\n    27→for f in \"$COINFLIP_SO\" \"$PLATFORM_SO\" \"$COINFLIP_KEYPAIR\" \"$PLATFORM_KEYPAIR\"; do\n    28→  if [[ ! -f \"$f\" ]]; then\n    29→    echo \"ERROR: Missing $f — run 'anchor build' first.\" >&2\n    30→    exit 1\n    31→  fi\n    32→done\n    33→\n    34→if ! command -v solana-test-validator &>/dev/null; then\n    35→  echo \"ERROR: solana-test-validator not found on PATH.\" >&2\n    36→  exit 1\n    37→fi\n    38→\n    39→# Solana 3.x requires io_uring; Docker blocks it unless --security-opt=seccomp=unconfined\n    40→if python3 -c \"import ctypes, ctypes.util; libc=ctypes.CDLL(ctypes.util.find_library('c'),use_errno=True); libc.syscall(425,1,ctypes.c_char_p(b'\\0'*120)); import ctypes; exit(0 if ctypes.get_errno()!=38 else 1)\" 2>/dev/null; then\n    41→  : # io_uring available\n    42→else\n    43→  echo \"ERROR: io_uring syscall blocked (ENOSYS). Solana 3.x requires io_uring.\" >&2\n    44→  echo \"       Add '--security-opt=seccomp=unconfined' to your Docker/devcontainer runArgs.\" >&2\n    45→  exit 1\n    46→fi\n    47→\n    48→# ── Kill any existing validator ───────────────────────────────────────\n    49→if [[ -f \"$PID_FILE\" ]]; then\n    50→  OLD_PID=$(cat \"$PID_FILE\")\n    51→  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    52→    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    53→    kill \"$OLD_PID\" 2>/dev/null || true\n    54→    sleep 1\n    55→    kill -9 \"$OLD_PID\" 2>/dev/null || true\n    56→  fi\n    57→  rm -f \"$PID_FILE\"\n    58→fi\n    59→\n    60→# Also kill any stray validator on the same port\n    61→if lsof -ti :8899 &>/dev/null; then\n    62→  echo \"Killing process on port 8899...\"\n    63→  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n    64→  sleep 1\n    65→fi\n    66→\n    67→# ── Clean ledger for fresh state ──────────────────────────────────────\n    68→rm -rf \"$LEDGER_DIR\"\n    69→\n    70→# ── Start validator with programs preloaded at genesis ────────────────\n    71→echo \"Starting solana-test-validator...\"\n    72→solana-test-validator \\\n    73→  --ledger \"$LEDGER_DIR\" \\\n    74→  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n    75→  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n    76→  --reset \\\n    77→  --quiet \\\n    78→  > \"$LOG_FILE\" 2>&1 &\n    79→\n    80→VALIDATOR_PID=$!\n    81→echo \"$VALIDATOR_PID\" > \"$PID_FILE\"\n    82→echo \"Validator PID: $VALIDATOR_PID\"\n    83→\n    84→# ── Wait for RPC readiness ────────────────────────────────────────────\n    85→echo -n \"Waiting for RPC at $RPC_URL\"\n    86→ELAPSED=0\n    87→while (( ELAPSED < MAX_WAIT )); do\n    88→  if curl -s \"$RPC_URL\" \\\n    89→    -X POST \\\n    90→    -H \"Content-Type: application/json\" \\\n    91→    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    92→    | grep -q '\"result\"'; then\n    93→    echo \" ready (${ELAPSED}s)\"\n    94→    echo \"Localnet bootstrap complete.\"\n    95→    exit 0\n    96→  fi\n    97→\n    98→  # Check validator is still running\n    99→  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n   100→    echo \"\"\n   101→    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n   102→    tail -20 \"$LOG_FILE\" >&2\n   103→    rm -f \"$PID_FILE\"\n   104→    exit 1\n   105→  fi\n   106→\n   107→  sleep 1\n   108→  (( ELAPSED++ ))\n   109→  echo -n \".\"\n   110→done\n   111→\n   112→echo \"\"\n   113→echo \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\n   114→tail -20 \"$LOG_FILE\" >&2\n   115→kill \"$VALIDATOR_PID\" 2>/dev/null || true\n   116→rm -f \"$PID_FILE\"\n   117→exit 1\n   118→"}]},"parent_tool_use_id":null,"session_id":"d5435ef2-ead0-44c9-9cba-d5f84572c358","uuid":"cfa126e6-fb9a-4518-a7cf-e49cb57b5122","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/scripts/localnet-bootstrap.sh","content":"#!/usr/bin/env bash\n# localnet-bootstrap.sh — Start a fresh solana-test-validator with coinflip + platform programs.\n# Usage: ./scripts/localnet-bootstrap.sh\n# Writes validator PID to .localnet.pid for teardown.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nPLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\nSOLANA_DIR=\"$(cd \"$PLATFORM_DIR/../../solana\" && pwd)\"\n\nCOINFLIP_SO=\"$SOLANA_DIR/target/deploy/coinflip.so\"\nPLATFORM_SO=\"$SOLANA_DIR/target/deploy/platform.so\"\nCOINFLIP_KEYPAIR=\"$SOLANA_DIR/target/deploy/coinflip-keypair.json\"\nPLATFORM_KEYPAIR=\"$SOLANA_DIR/target/deploy/platform-keypair.json\"\n\nCOINFLIP_ID=\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\nPLATFORM_ID=\"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n\nRPC_URL=\"http://127.0.0.1:8899\"\nPID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\nLEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\nLOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n\nMAX_WAIT=30  # seconds to wait for RPC readiness\n\n# ── Preflight checks ─────────────────────────────────────────────────\nfor f in \"$COINFLIP_SO\" \"$PLATFORM_SO\" \"$COINFLIP_KEYPAIR\" \"$PLATFORM_KEYPAIR\"; do\n  if [[ ! -f \"$f\" ]]; then\n    echo \"ERROR: Missing $f — run 'anchor build' first.\" >&2\n    exit 1\n  fi\ndone\n\nif ! command -v solana-test-validator &>/dev/null; then\n  echo \"ERROR: solana-test-validator not found on PATH.\" >&2\n  exit 1\nfi\n\n# Solana 3.x requires io_uring; Docker blocks it unless --security-opt=seccomp=unconfined\nif python3 -c \"import ctypes, ctypes.util; libc=ctypes.CDLL(ctypes.util.find_library('c'),use_errno=True); libc.syscall(425,1,ctypes.c_char_p(b'\\0'*120)); import ctypes; exit(0 if ctypes.get_errno()!=38 else 1)\" 2>/dev/null; then\n  : # io_uring available\nelse\n  echo \"ERROR: io_uring syscall blocked (ENOSYS). Solana 3.x requires io_uring.\" >&2\n  echo \"       Add '--security-opt=seccomp=unconfined' to your Docker/devcontainer runArgs.\" >&2\n  exit 1\nfi\n\n# ── Kill any existing validator ───────────────────────────────────────\nif [[ -f \"$PID_FILE\" ]]; then\n  OLD_PID=$(cat \"$PID_FILE\")\n  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    kill \"$OLD_PID\" 2>/dev/null || true\n    sleep 1\n    kill -9 \"$OLD_PID\" 2>/dev/null || true\n  fi\n  rm -f \"$PID_FILE\"\nfi\n\n# Also kill any stray validator on the same port\nif lsof -ti :8899 &>/dev/null; then\n  echo \"Killing process on port 8899...\"\n  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n  sleep 1\nfi\n\n# ── Clean ledger for fresh state ──────────────────────────────────────\nrm -rf \"$LEDGER_DIR\"\n\n# ── Start validator with programs preloaded at genesis ────────────────\necho \"Starting solana-test-validator...\"\nsolana-test-validator \\\n  --ledger \"$LEDGER_DIR\" \\\n  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n  --reset \\\n  --quiet \\\n  > \"$LOG_FILE\" 2>&1 &\n\nVALIDATOR_PID=$!\necho \"$VALIDATOR_PID\" > \"$PID_FILE\"\necho \"Validator PID: $VALIDATOR_PID\"\n\n# ── Wait for RPC readiness ────────────────────────────────────────────\necho -n \"Waiting for RPC at $RPC_URL\"\nELAPSED=0\nwhile (( ELAPSED < MAX_WAIT )); do\n  if curl -s \"$RPC_URL\" \\\n    -X POST \\\n    -H \"Content-Type: application/json\" \\\n    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    | grep -q '\"result\"'; then\n    echo \" ready (${ELAPSED}s)\"\n    echo \"Localnet bootstrap complete.\"\n    exit 0\n  fi\n\n  # Check validator is still running\n  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n    echo \"\"\n    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n    tail -20 \"$LOG_FILE\" >&2\n    rm -f \"$PID_FILE\"\n    exit 1\n  fi\n\n  sleep 1\n  (( ELAPSED++ ))\n  echo -n \".\"\ndone\n\necho \"\"\necho \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\ntail -20 \"$LOG_FILE\" >&2\nkill \"$VALIDATOR_PID\" 2>/dev/null || true\nrm -f \"$PID_FILE\"\nexit 1\n","numLines":118,"startLine":1,"totalLines":118}}}
