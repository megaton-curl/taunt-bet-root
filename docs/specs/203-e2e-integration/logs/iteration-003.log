f -ti :8899)\n  echo \"Killing stray process on port 8899 (PID $STRAY_PID)...\"\n  kill \"$STRAY_PID\" 2>/dev/null || true\n  sleep 1\n  kill -9 \"$STRAY_PID\" 2>/dev/null || true\n  CLEANED=true\nfi\n\n# ── Clean temp ledger ────────────────────────────────────────────────\nif [[ -d \"$LEDGER_DIR\" ]]; then\n  echo \"Removing ledger directory: $LEDGER_DIR\"\n  rm -rf \"$LEDGER_DIR\"\n  CLEANED=true\nfi\n\n# ── Clean log file (unless --keep-logs) ──────────────────────────────\nif [[ \"$KEEP_LOGS\" == false && -f \"$LOG_FILE\" ]]; then\n  echo \"Removing log file: $LOG_FILE\"\n  rm -f \"$LOG_FILE\"\n  CLEANED=true\nfi\n\nif [[ \"$CLEANED\" == true ]]; then\n  echo \"Localnet teardown complete.\"\nelse\n  echo \"Nothing to clean up (no running validator or temp files found).\"\nfi\n","structuredPatch":[],"originalFile":null}}
