ment(secret);\n43\t    expect(a.equals(b)).toBe(true);\n44\t  });\n45\t\n46\t  it(\"produces different commitments for different secrets\", () => {\n47\t    const a = computeCommitment(Buffer.alloc(32, 0x01));\n48\t    const b = computeCommitment(Buffer.alloc(32, 0x02));\n49\t    expect(a.equals(b)).toBe(false);\n50\t  });\n51\t});\n52\t\n53\tdescribe(\"generateMatchId\", () => {\n54\t  it(\"returns an 8-byte buffer\", () => {\n55\t    const id = generateMatchId();\n56\t    expect(Buffer.isBuffer(id)).toBe(true);\n57\t    expect(id.length).toBe(8);\n58\t  });\n59\t});\n60\t\n61\tdescribe(\"deriveMatchPda\", () => {\n62\t  const creator = Keypair.generate().publicKey;\n63\t  const programId = new PublicKey(\n64\t    \"sCLNVCC3x85cTvTHawJd6ZwiHpRRFTHEsE1NibyRg2Z\",\n65\t  );\n66\t\n67\t  it(\"returns a PublicKey and bump seed\", () => {\n68\t    const matchId = randomBytes(8);\n69\t    const [pda, bump] = deriveMatchPda(creator, matchId);\n70\t    expect(pda).toBeInstanceOf(PublicKey);\n71\t    expect(typeof bump).toBe(\"number\");\n72\t    expect(bump).toBeGreaterThanOrEqual(0);\n73\t    expect(bump).toBeLessThanOrEqual(255);\n74\t  });\n75\t\n76\t  it(\"matches manual PDA derivation with seeds [match, creator, matchId]\", () => {\n77\t    const matchId = Buffer.from(\"deadbeef01234567\", \"hex\");\n78\t\n79\t    const [expected] = PublicKey.findProgramAddressSync(\n80\t      [Buffer.from(\"match\"), creator.toBuffer(), matchId],\n81\t      programId,\n82\t    );\n83\t\n84\t    const [actual] = deriveMatchPda(creator, matchId);\n85\t    expect(actual.equals(expected)).toBe(true);\n86\t  });\n87\t\n88\t  it(\"is deterministic for the same matchId\", () => {\n89\t    const matchId = randomBytes(8);\n90\t    const [a] = deriveMatchPda(creator, matchId);\n91\t    const [b] = deriveMatchPda(creator, matchId);\n92\t    expect(a.equals(b)).toBe(true);\n93\t  });\n94\t\n95\t  it(\"produces different PDAs for different matchIds\", () => {\n96\t    const [a] = deriveMatchPda(creator, randomBytes(8));\n97\t    const [b] = deriveMatchPda(creator, randomBytes(8));\n98\t    expect(a.equals(b)).toBe(false);\n99\t  });\n100\t\n101\t  it(\"produces different PDAs for different creators\", () => {\n102\t    const other = Keypair.generate().publicKey;\n103\t    const matchId = randomBytes(8);\n104\t    const [a] = deriveMatchPda(creator, matchId);\n105\t    const [b] = deriveMatchPda(other, matchId);\n106\t    expect(a.equals(b)).toBe(false);\n107\t  });\n108\t});\n109\t"}]},"parent_tool_use_id":null,"session_id":"5131cb3a-2a57-452d-8340-6050c3efd05f","uuid":"11cacf65-82ec-4a4e-b993-fc9f0176c739","timestamp":"2026-05-01T19:44:56.937Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/fairness.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { createHash, randomBytes } from \"node:crypto\";\nimport { Keypair, PublicKey } from \"@solana/web3.js\";\nimport { generateSecret, computeCommitment, deriveMatchPda, generateMatchId } from \"../fairness.js\";\n\ndescribe(\"generateSecret\", () => {\n  it(\"returns a 32-byte buffer\", () => {\n    const secret = generateSecret();\n    expect(Buffer.isBuffer(secret)).toBe(true);\n    expect(secret.length).toBe(32);\n  });\n});\n\ndescribe(\"computeCommitment\", () => {\n  it(\"returns sha256 of the secret bytes\", () => {\n    // sha256 of the zero byte (0x00) — well-known constant\n    const zeroByte = Buffer.from([0x00]);\n    const expected =\n      \"6e340b9cffb37a989ca544e6bb780a2c78901d3fb33738768511a30617afa01d\";\n    expect(computeCommitment(zeroByte).toString(\"hex\")).toBe(expected);\n  });\n\n  it(\"matches the packages/fairness commitment algorithm\", () => {\n    // The fairness package computes sha256(hexToBytes(hexSeed)).\n    // Our backend computes sha256(secretBuffer).\n    // They must agree when given the same bytes.\n    const seedHex =\n      \"abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789\";\n    const seedBytes = Buffer.from(seedHex, \"hex\");\n\n    const backendCommitment = computeCommitment(seedBytes).toString(\"hex\");\n\n    // Independently compute using Node crypto for cross-check\n    const nodeCommitment = createHash(\"sha256\").update(seedBytes).digest(\"hex\");\n\n    expect(backendCommitment).toBe(nodeCommitment);\n  });\n\n  it(\"is deterministic\", () => {\n    const secret = Buffer.alloc(32, 0x42);\n    const a = computeCommitment(secret);\n    const b = computeCommitment(secret);\n    expect(a.equals(b)).toBe(true);\n  });\n\n  it(\"produces different commitments for different secrets\", () => {\n    const a = computeCommitment(Buffer.alloc(32, 0x01));\n    const b = computeCommitment(Buffer.alloc(32, 0x02));\n    expect(a.equals(b)).toBe(false);\n  });\n});\n\ndescribe(\"generateMatchId\", () => {\n  it(\"returns an 8-byte buffer\", () => {\n    const id = generateMatchId();\n    expect(Buffer.isBuffer(id)).toBe(true);\n    expect(id.length).toBe(8);\n  });\n});\n\ndescribe(\"deriveMatchPda\", () => {\n  const creator = Keypair.generate().publicKey;\n  const programId = new PublicKey(\n    \"sCLNVCC3x85cTvTHawJd6ZwiHpRRFTHEsE1NibyRg2Z\",\n  );\n\n  it(\"returns a PublicKey and bump seed\", () => {\n    const matchId = randomBytes(8);\n    const [pda, bump] = deriveMatchPda(creator, matchId);\n    expect(pda).toBeInstanceOf(PublicKey);\n    expect(typeof bump).toBe(\"number\");\n    expect(bump).toBeGreaterThanOrEqual(0);\n    expect(bump).toBeLessThanOrEqual(255);\n  });\n\n  it(\"matches manual PDA derivation with seeds [match, creator, matchId]\", () => {\n    const matchId = Buffer.from(\"deadbeef01234567\", \"hex\");\n\n    const [expected] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"match\"), creator.toBuffer(), matchId],\n      programId,\n    );\n\n    const [actual] = deriveMatchPda(creator, matchId);\n    expect(actual.equals(expected)).toBe(true);\n  });\n\n  it(\"is deterministic for the same matchId\", () => {\n    const matchId = randomBytes(8);\n    const [a] = deriveMatchPda(creator, matchId);\n    const [b] = deriveMatchPda(creator, matchId);\n    expect(a.equals(b)).toBe(true);\n  });\n\n  it(\"produces different PDAs for different matchIds\", () => {\n    const [a] = deriveMatchPda(creator, randomBytes(8));\n    const [b] = deriveMatchPda(creator, randomBytes(8));\n    expect(a.equals(b)).toBe(false);\n  });\n\n  it(\"produces different PDAs for different creators\", () => {\n    const other = Keypair.generate().publicKey;\n    const matchId = randomBytes(8);\n    const [a] = deriveMatchPda(creator, matchId);\n    const [b] = deriveMatchPda(other, matchId);\n    expect(a.equals(b)).toBe(false);\n  });\n});\n","numLines":109,"startLine":1,"totalLines":109}}}
