{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014wXBV3P982AdTu3aTtYSYp","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\t/**\n3\t * Referral route tests — set code, apply, stats, earnings, claim flows.\n4\t *\n5\t * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n6\t * between tests for isolation.\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport { Keypair } from \"@solana/web3.js\";\n12\timport { SignJWT } from \"jose\";\n13\timport postgres from \"postgres\";\n14\timport { createDb, type Db } from \"../db.js\";\n15\timport { createReferralRoutes } from \"../routes/referral.js\";\n16\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n17\timport type { Config } from \"../config.js\";\n18\t\n19\t// ---------------------------------------------------------------------------\n20\t// Constants\n21\t// ---------------------------------------------------------------------------\n22\t\n23\tconst DATABASE_URL =\n24\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n25\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n26\t\n27\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n28\tfunction makeSql() {\n29\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n30\t  // Dev container: postgres listens on Unix socket only\n31\t  return postgres({\n32\t    host: \"/var/run/postgresql\",\n33\t    user: \"vscode\",\n34\t    database: \"taunt_bet_dev\",\n35\t  });\n36\t}\n37\t\n38\t// ---------------------------------------------------------------------------\n39\t// Helpers\n40\t// ---------------------------------------------------------------------------\n41\t\n42\tasync function makeJwt(wallet: string): Promise<string> {\n43\t  const now = Math.floor(Date.now() / 1000);\n44\t  return new SignJWT({})\n45\t    .setProtectedHeader({ alg: \"HS256\" })\n46\t    .setSubject(userIdFromWallet(wallet))\n47\t    .setIssuedAt(now)\n48\t    .setExpirationTime(now + 3600)\n49\t    .sign(JWT_SECRET);\n50\t}\n51\t\n52\tfunction json(body: Record<string, any>) {\n53\t  return {\n54\t    headers: { \"Content-Type\": \"application/json\" },\n55\t    body: JSON.stringify(body),\n56\t  };\n57\t}\n58\t\n59\tfunction userIdFromWallet(wallet: string) {\n60\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n61\t}\n62\t\n63\t// ---------------------------------------------------------------------------\n64\t// Test suite\n65\t// ---------------------------------------------------------------------------\n66\t\n67\tdescribe(\"Referral routes\", () => {\n68\t  let rawSql: ReturnType<typeof postgres>;\n69\t  let db: Db;\n70\t  let app: Hono;\n71\t\n72\t  const referrerKp = Keypair.generate();\n73\t  const refereeKp = Keypair.generate();\n74\t  const referrer = referrerKp.publicKey.toBase58();\n75\t  const referee = refereeKp.publicKey.toBase58();\n76\t  const referrerUserId = userIdFromWallet(referrer);\n77\t  const refereeUserId = userIdFromWallet(referee);\n78\t\n79\t  const testConfig = {\n80\t    referralDefaultRateBps: 1000,"}]},"parent_tool_use_id":null,"session_id":"5131cb3a-2a57-452d-8340-6050c3efd05f","uuid":"1cd093fb-a1a8-4913-baca-3ffb334f19ab","timestamp":"2026-05-01T19:45:41.037Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/referral-routes.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\n/**\n * Referral route tests — set code, apply, stats, earnings, claim flows.\n *\n * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n * between tests for isolation.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userIdFromWallet(wallet))\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction json(body: Record<string, any>) {\n  return {\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify(body),\n  };\n}\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Referral routes\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n  let app: Hono;\n\n  const referrerKp = Keypair.generate();\n  const refereeKp = Keypair.generate();\n  const referrer = referrerKp.publicKey.toBase58();\n  const referee = refereeKp.publicKey.toBase58();\n  const referrerUserId = userIdFromWallet(referrer);\n  const refereeUserId = userIdFromWallet(referee);\n\n  const testConfig = {\n    referralDefaultRateBps: 1000,","numLines":80,"startLine":1,"totalLines":997}}}
