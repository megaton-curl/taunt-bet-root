{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QpBAxpsz7byXfEbPtBQeQx","type":"tool_result","content":"1\timport { SignJWT } from \"jose\";\n2\timport bs58 from \"bs58\";\n3\timport postgres from \"postgres\";\n4\timport {\n5\t  LAMPORTS_PER_SOL,\n6\t  PublicKey,\n7\t  SystemProgram,\n8\t} from \"@solana/web3.js\";\n9\timport { createDb, type Db } from \"../db.js\";\n10\timport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\n11\timport {\n12\t  PLATFORM_PROGRAM_ID,\n13\t  derivePlatformConfigPda,\n14\t} from \"../platform-config.js\";\n15\timport {\n16\t  encodeFlipYouConfig,\n17\t  encodeFlipYouMatch,\n18\t} from \"../worker/account-decoder.js\";\n19\t\n20\texport const DATABASE_URL =\n21\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n22\texport const AMOUNT_LAMPORTS = 5_000_000;\n23\texport const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n24\texport const SIDE_HEADS = 0;\n25\texport const PHASE_LOCKED = 1;\n26\texport const JWT_SECRET = new TextEncoder().encode(\n27\t  \"test-secret-for-integration-tests\",\n28\t);\n29\t\n30\tconst RESET_TABLES = [\n31\t  \"rounds\",\n32\t  \"closecall_rounds\",\n33\t  \"closecall_candles\",\n34\t  \"operator_events\",\n35\t  \"event_queue\",\n36\t  \"game_entries\",\n37\t  \"transactions\",\n38\t  \"player_profiles\",\n39\t  \"referral_codes\",\n40\t  \"referral_links\",\n41\t  \"referral_earnings\",\n42\t  \"referral_claims\",\n43\t  \"referral_kol_rates\",\n44\t  \"reward_pool_fundings\",\n45\t  \"point_grants\",\n46\t  \"point_balances\",\n47\t  \"point_rate_versions\",\n48\t  \"multiplier_modifiers\",\n49\t  \"multiplier_ladder_steps\",\n50\t  \"multiplier_ladders\",\n51\t  \"events\",\n52\t  \"seasons\",\n53\t  \"crate_drops\",\n54\t  \"progress_events\",\n55\t  \"challenge_assignments\",\n56\t  \"bonus_completions\",\n57\t].join(\", \");\n58\t\n59\texport type TestSql = ReturnType<typeof postgres>;\n60\t\n61\texport interface IntegrationDbContext {\n62\t  db: Db;\n63\t  rawSql: TestSql;\n64\t}\n65\t\n66\tlet referralTablesEnsured = false;\n67\tlet rewardEconomyTablesEnsured = false;\n68\t\n69\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n70\texport function makeSql() {\n71\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n72\t  return postgres({\n73\t    host: \"/var/run/postgresql\",\n74\t    user: \"vscode\",\n75\t    database: \"taunt_bet_dev\",\n76\t  });\n77\t}\n78\t\n79\texport async function openIntegrationDb(): Promise<IntegrationDbContext> {\n80\t  const rawSql = makeSql();\n81\t  await ensureReferralTables(rawSql);\n82\t  await ensureRewardEconomyTables(rawSql);\n83\t  return {\n84\t    rawSql,\n85\t    db: createDb(DATABASE_URL, rawSql),\n86\t  };\n87\t}\n88\t\n89\texport async function closeIntegrationDb(ctx: IntegrationDbContext) {\n90\t  await ctx.db.close();\n91\t  await ctx.rawSql.end();\n92\t}\n93\t\n94\t/**\n95\t * Seed a player_profile row for a test. Production creates profiles via the\n96\t * auth flow before any wager fires; tests that bypass auth and call the\n97\t * points-grant handler directly need to pre-create the row, since the\n98\t * handler now updates the profile in-place for materialized economy state.\n99\t */\n100\texport async function seedPlayerProfile(\n101\t  rawSql: TestSql,\n102\t  userId: string,\n103\t  wallet: string,\n104\t  username: string = `tester-${userId}`,\n105\t): Promise<void> {\n106\t  await rawSql`\n107\t    INSERT INTO player_profiles (user_id, wallet, username)\n108\t    VALUES (${userId}, ${wallet}, ${username})\n109\t    ON CONFLICT (user_id) DO NOTHING\n110\t  `;\n111\t}\n112\t\n113\texport async function resetIntegrationState(rawSql: TestSql) {\n114\t  await ensureReferralTables(rawSql);\n115\t  await ensureRewardEconomyTables(rawSql);\n116\t  await rawSql.begin(async (tx) => {\n117\t    const sql = tx as unknown as TestSql;\n118\t    await sql`SELECT pg_advisory_xact_lock(401402)`;\n119\t    await sql.unsafe(`TRUNCATE ${RESET_TABLES} RESTART IDENTITY CASCADE`);\n120\t    await sql`\n121\t    INSERT INTO reward_pool (\n122\t      id,\n123\t      balance_lamports,\n124\t      lifetime_funded,\n125\t      lifetime_paid,\n126\t      updated_at\n127\t    )\n128\t    VALUES (1, 0, 0, 0, now())\n129\t    ON CONFLICT (id) DO UPDATE\n130\t    SET\n131\t      balance_lamports = EXCLUDED.balance_lamports,\n132\t      lifetime_funded = EXCLUDED.lifetime_funded,\n133\t      lifetime_paid = EXCLUDED.lifetime_paid,\n134\t      updated_at = EXCLUDED.updated_at\n135\t  `;\n136\t    await sql`\n137\t    INSERT INTO seasons (slug, name, starts_at, status)\n138\t    VALUES ('season-1', 'Season 1', '2026-01-01T00:00:00Z', 'active')\n139\t  `;\n140\t    await sql`\n141\t    INSERT INTO point_rate_versions (rate_per_usd, effective_from, label)\n142\t    VALUES (100, '2026-01-01T00:00:00Z', 'Launch default')\n143\t  `;\n144\t    await sql`\n145\t      DELETE FROM reward_config\n146\t      WHERE key IN ('points_per_dollar', 'dogpile_default_multiplier')\n147\t    `;\n148\t    await sql`\n149\t      INSERT INTO reward_config (key, value)\n150\t      VALUES\n151\t        ('reward_pool_fee_share', '0.20'),\n152\t        ('points_crate_drop_rate', '0.05'),\n153\t        ('sol_crate_drop_rate', '0.01'),\n154\t        ('sol_crate_pool_pct', '0.10'),\n155\t        ('sol_crate_min_value', '10000000'),\n156\t        ('points_crate_min', '500'),\n157\t        ('points_crate_max', '5000'),\n158\t        ('daily_challenge_count', '3'),\n159\t        ('weekly_challenge_count', '2')\n160\t      ON CONFLICT (key) DO UPDATE\n161\t      SET value = EXCLUDED.value, updated_at = now()\n162\t    `;\n163\t    await sql`\n164\t    WITH lifetime_ladder AS (\n165\t      INSERT INTO multiplier_ladders (scope, metric, effective_from, label)\n166\t      VALUES ('lifetime', 'wagered_usd', '2026-01-01T00:00:00Z', 'Launch lifetime ladder')\n167\t      RETURNING id\n168\t    )\n169\t    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n170\t    SELECT id, level, threshold_usd, multiplier, level\n171\t    FROM lifetime_ladder\n172\t    CROSS JOIN (VALUES\n173\t      (1, 1000, 1.10),\n174\t      (2, 10000, 1.20),\n175\t      (3, 50000, 1.30),\n176\t      (4, 100000, 1.40),\n177\t      (5, 250000, 1.50),\n178\t      (6, 500000, 1.60),\n179\t      (7, 1000000, 1.70),\n180\t      (8, 2500000, 1.80),\n181\t      (9, 5000000, 1.90),\n182\t      (10, 10000000, 2.00)\n183\t    ) AS steps(level, threshold_usd, multiplier)\n184\t  `;\n185\t    await sql`\n186\t    WITH active_season AS (\n187\t      SELECT id FROM seasons WHERE status = 'active' LIMIT 1\n188\t    ),\n189\t    season_ladder AS (\n190\t      INSERT INTO multiplier_ladders (scope, metric, season_id, effective_from, label)\n191\t      SELECT 'season', 'wagered_usd', id, '2026-01-01T00:00:00Z', 'Launch season ladder'\n192\t      FROM active_season\n193\t      RETURNING id\n194\t    )\n195\t    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n196\t    SELECT id, level, threshold_usd, multiplier, level\n197\t    FROM season_ladder\n198\t    CROSS JOIN (VALUES\n199\t      (1, 500, 1.20),\n200\t      (2, 5000, 1.50),\n201\t      (3, 25000, 2.00),\n202\t      (4, 100000, 2.50),\n203\t      (5, 250000, 3.00)\n204\t    ) AS steps(level, threshold_usd, multiplier)\n205\t  `;\n206\t  });\n207\t}\n208\t\n209\texport async function makeJwt(\n210\t  wallet: string,\n211\t  userId = userIdFromWallet(wallet),\n212\t) {\n213\t  const now = Math.floor(Date.now() / 1000);\n214\t  return new SignJWT({ wallet })\n215\t    .setProtectedHeader({ alg: \"HS256\" })\n216\t    .setSubject(userId)\n217\t    .setIssuedAt(now)\n218\t    .setExpirationTime(now + 3600)\n219\t    .sign(JWT_SECRET);\n220\t}\n221\t\n222\texport function userIdFromWallet(wallet: string) {\n223\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n224\t}\n225\t\n226\t/**\n227\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n228\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n229\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n230\t */\n231\texport class MockConnection {\n232\t  private _slot = 200;\n233\t  private _accounts = new Map<\n234\t    string,\n235\t    {\n236\t      data: Buffer;\n237\t      lamports: number;\n238\t      owner: PublicKey;\n239\t      executable: boolean;\n240\t    }\n241\t  >();\n242\t  lastRawTx: Buffer | null = null;\n243\t\n244\t  set slot(s: number) {\n245\t    this._slot = s;\n246\t  }\n247\t\n248\t  get slot() {\n249\t    return this._slot;\n250\t  }\n251\t\n252\t  setAccount(\n253\t    pubkey: PublicKey,\n254\t    data: Buffer,\n255\t    opts?: { lamports?: number; owner?: PublicKey },\n256\t  ) {\n257\t    this._accounts.set(pubkey.toBase58(), {\n258\t      data,\n259\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n260\t      owner: opts?.owner ?? SystemProgram.programId,\n261\t      executable: false,\n262\t    });\n263\t  }\n264\t\n265\t  removeAccount(pubkey: PublicKey) {\n266\t    this._accounts.delete(pubkey.toBase58());\n267\t  }\n268\t\n269\t  async getLatestBlockhash() {\n270\t    return {\n271\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n272\t      lastValidBlockHeight: 999_999,\n273\t    };\n274\t  }\n275\t\n276\t  async getSlot() {\n277\t    return this._slot;\n278\t  }\n279\t\n280\t  async getAccountInfo(pubkey: PublicKey) {\n281\t    const acc = this._accounts.get(pubkey.toBase58());\n282\t    if (!acc) return null;\n283\t    return { ...acc, rentEpoch: 0 };\n284\t  }\n285\t\n286\t  async getProgramAccounts(\n287\t    programId: PublicKey,\n288\t    config?: {\n289\t      filters?: Array<\n290\t        | { dataSize: number }\n291\t        | { memcmp: { offset: number; bytes: string } }\n292\t      >;\n293\t    },\n294\t  ) {\n295\t    const results: Array<{\n296\t      pubkey: PublicKey;\n297\t      account: {\n298\t        data: Buffer;\n299\t        lamports: number;\n300\t        owner: PublicKey;\n301\t        executable: boolean;\n302\t        rentEpoch: number;\n303\t      };\n304\t    }> = [];\n305\t\n306\t    for (const [key, acc] of this._accounts) {\n307\t      if (!acc.owner.equals(programId)) continue;\n308\t\n309\t      let matches = true;\n310\t      if (config?.filters) {\n311\t        for (const filter of config.filters) {\n312\t          if (\"dataSize\" in filter && acc.data.length !== filter.dataSize) {\n313\t            matches = false;\n314\t            break;\n315\t          }\n316\t\n317\t          if (\"memcmp\" in filter) {\n318\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n319\t            const actual = acc.data.subarray(\n320\t              filter.memcmp.offset,\n321\t              filter.memcmp.offset + expected.length,\n322\t            );\n323\t            if (Buffer.compare(actual, expected) !== 0) {\n324\t              matches = false;\n325\t              break;\n326\t            }\n327\t          }\n328\t        }\n329\t      }\n330\t\n331\t      if (matches) {\n332\t        results.push({\n333\t          pubkey: new PublicKey(key),\n334\t          account: { ...acc, rentEpoch: 0 },\n335\t        });\n336\t      }\n337\t    }\n338\t\n339\t    return results;\n340\t  }\n341\t\n342\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n343\t    this.lastRawTx = Buffer.from(rawTx);\n344\t    return bs58.encode(Buffer.alloc(64, 0x01));\n345\t  }\n346\t\n347\t  async confirmTransaction() {\n348\t    return { value: { err: null }, context: { slot: this._slot } };\n349\t  }\n350\t\n351\t  async getBlockTime(_slot: number) {\n352\t    return Math.floor(Date.now() / 1000);\n353\t  }\n354\t\n355\t  async getBalance() {\n356\t    return 2 * LAMPORTS_PER_SOL;\n357\t  }\n358\t}\n359\t\n360\texport async function buildMatchAccountData(params: {\n361\t  creator: PublicKey;\n362\t  opponent: PublicKey;\n363\t  server: PublicKey;\n364\t  entryAmount: bigint;\n365\t  creatorSide: number;\n366\t  phase: number;\n367\t  commitment: Buffer;\n368\t  algorithmVer: number;\n369\t  targetSlot: bigint;\n370\t  resolveDeadline: bigint;\n371\t  matchId: Buffer;\n372\t}): Promise<Buffer> {\n373\t  return encodeFlipYouMatch({\n374\t    creator: params.creator,\n375\t    opponent: params.opponent,\n376\t    server: params.server,\n377\t    entryAmount: params.entryAmount,\n378\t    creatorSide: params.creatorSide,\n379\t    phase: params.phase,\n380\t    commitment: [...params.commitment],\n381\t    algorithmVer: params.algorithmVer,\n382\t    targetSlot: params.targetSlot,\n383\t    resolveDeadline: params.resolveDeadline,\n384\t    resultHash: new Array(32).fill(0),\n385\t    result: 0,\n386\t    winner: PublicKey.default,\n387\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n388\t    matchId: [...params.matchId],\n389\t    bump: 0,\n390\t  });\n391\t}\n392\t\n393\texport async function seedSettlementProgramAccounts(\n394\t  mockConn: MockConnection,\n395\t  params: {\n396\t    entropyAccount: PublicKey;\n397\t    entropyData: Buffer;\n398\t    treasury: PublicKey;\n399\t  },\n400\t) {\n401\t  mockConn.setAccount(params.entropyAccount, params.entropyData);\n402\t\n403\t  const [configPda] = PublicKey.findProgramAddressSync(\n404\t    [Buffer.from(\"flipyou_config\")],\n405\t    FLIPYOU_PROGRAM_ID,\n406\t  );\n407\t  mockConn.setAccount(\n408\t    configPda,\n409\t    await buildConfigAccountData(params.treasury),\n410\t    { owner: FLIPYOU_PROGRAM_ID },\n411\t  );\n412\t\n413\t  const [platformConfigPda] = derivePlatformConfigPda();\n414\t  mockConn.setAccount(\n415\t    platformConfigPda,\n416\t    buildPlatformConfigData(params.treasury, 500),\n417\t    { owner: PLATFORM_PROGRAM_ID },\n418\t  );\n419\t}\n420\t\n421\tasync function ensureReferralTables(rawSql: TestSql) {\n422\t  if (referralTablesEnsured) {\n423\t    return;\n424\t  }\n425\t\n426\t  await rawSql`\n427\t    CREATE TABLE IF NOT EXISTS referral_codes (\n428\t      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n429\t      user_id TEXT NOT NULL UNIQUE,\n430\t      wallet TEXT NOT NULL UNIQUE,\n431\t      code TEXT NOT NULL UNIQUE,\n432\t      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n433\t      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n434\t    )\n435\t  `;\n436\t  await rawSql`\n437\t    CREATE TABLE IF NOT EXISTS referral_links (\n438\t      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n439\t      referrer_user_id TEXT NOT NULL,\n440\t      referee_user_id TEXT NOT NULL UNIQUE,\n441\t      referrer_wallet TEXT NOT NULL,\n442\t      referee_wallet TEXT NOT NULL,\n443\t      created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n444\t    )\n445\t  `;\n446\t  await rawSql`\n447\t    CREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n448\t    ON referral_links (referrer_user_id)\n449\t  `;\n450\t  await rawSql`\n451\t    CREATE TABLE IF NOT EXISTS referral_earnings (\n452\t      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n453\t      referrer_user_id TEXT NOT NULL,\n454\t      referee_user_id TEXT NOT NULL,\n455\t      referrer_wallet TEXT NOT NULL,\n456\t      referee_wallet TEXT NOT NULL,\n457\t      round_id TEXT NOT NULL,\n458\t      game_type TEXT NOT NULL,\n459\t      wager_lamports BIGINT NOT NULL,\n460\t      fee_lamports BIGINT NOT NULL,\n461\t      referrer_earned_lamports BIGINT NOT NULL,\n462\t      referrer_rate_bps INTEGER NOT NULL,\n463\t      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n464\t      CONSTRAINT uq_referral_earnings_referee_round\n465\t        UNIQUE (referee_user_id, round_id)\n466\t    )\n467\t  `;\n468\t  await rawSql`\n469\t    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n470\t    ON referral_earnings (referrer_user_id, created_at)\n471\t  `;\n472\t  await rawSql`\n473\t    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n474\t    ON referral_earnings (referee_user_id, created_at)\n475\t  `;\n476\t  await rawSql`\n477\t    CREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n478\t    ON referral_earnings (round_id)\n479\t  `;\n480\t  await rawSql`\n481\t    CREATE TABLE IF NOT EXISTS referral_claims (\n482\t      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n483\t      user_id TEXT NOT NULL,\n484\t      wallet TEXT NOT NULL,\n485\t      amount_lamports BIGINT NOT NULL,\n486\t      status TEXT NOT NULL DEFAULT 'pending'\n487\t        CHECK (\n488\t          status IN ('pending', 'processing', 'error', 'completed', 'failed')\n489\t        ),\n490\t      retry_count INTEGER NOT NULL DEFAULT 0,\n491\t      tx_signature TEXT,\n492\t      error TEXT,\n493\t      requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n494\t      processed_at TIMESTAMPTZ\n495\t    )\n496\t  `;\n497\t  await rawSql`\n498\t    CREATE INDEX IF NOT EXISTS idx_referral_claims_user_id\n499\t    ON referral_claims (user_id, requested_at)\n500\t  `;\n501\t  await rawSql`\n502\t    CREATE INDEX IF NOT EXISTS idx_referral_claims_status\n503\t    ON referral_claims (status)\n504\t    WHERE status IN ('pending', 'processing')\n505\t  `;\n506\t  await rawSql`\n507\t    CREATE UNIQUE INDEX IF NOT EXISTS idx_referral_claims_user_active\n508\t    ON referral_claims (user_id)\n509\t    WHERE status IN ('pending', 'processing', 'error')\n510\t  `;\n511\t  await rawSql`\n512\t    CREATE TABLE IF NOT EXISTS referral_kol_rates (\n513\t      user_id TEXT PRIMARY KEY,\n514\t      wallet TEXT NOT NULL UNIQUE,\n515\t      rate_bps INTEGER NOT NULL,\n516\t      set_by TEXT NOT NULL,\n517\t      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n518\t      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n519\t    )\n520\t  `;\n521\t\n522\t  referralTablesEnsured = true;\n523\t}\n524\t\n525\tasync function ensureRewardEconomyTables(rawSql: TestSql) {\n526\t  if (rewardEconomyTablesEnsured) {\n527\t    return;\n528\t  }\n529\t\n530\t  await rawSql`SELECT pg_advisory_lock(401401)`;\n531\t  try {\n532\t    await rawSql`\n533\t      CREATE TABLE IF NOT EXISTS seasons (\n534\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n535\t        slug TEXT NOT NULL UNIQUE,\n536\t        name TEXT NOT NULL,\n537\t        starts_at TIMESTAMPTZ NOT NULL,\n538\t        ends_at TIMESTAMPTZ,\n539\t        status TEXT NOT NULL CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n540\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n541\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n542\t      )\n543\t    `;\n544\t    await rawSql`\n545\t      CREATE UNIQUE INDEX IF NOT EXISTS idx_seasons_one_active\n546\t      ON seasons ((status))\n547\t      WHERE status = 'active'\n548\t    `;\n549\t    await rawSql`\n550\t      CREATE TABLE IF NOT EXISTS point_rate_versions (\n551\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n552\t        rate_per_usd NUMERIC(18,6) NOT NULL,\n553\t        effective_from TIMESTAMPTZ NOT NULL,\n554\t        label TEXT,\n555\t        created_by TEXT,\n556\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n557\t      )\n558\t    `;\n559\t    await rawSql`\n560\t      CREATE TABLE IF NOT EXISTS point_balances (\n561\t        user_id TEXT NOT NULL,\n562\t        season_id BIGINT NOT NULL REFERENCES seasons(id),\n563\t        wallet TEXT NOT NULL,\n564\t        balance BIGINT NOT NULL DEFAULT 0,\n565\t        season_earned BIGINT NOT NULL DEFAULT 0,\n566\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n567\t        PRIMARY KEY (user_id, season_id)\n568\t      )\n569\t    `;\n570\t    await rawSql`\n571\t      ALTER TABLE player_profiles\n572\t      ADD COLUMN IF NOT EXISTS lifetime_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n573\t    `;\n574\t    await rawSql`\n575\t      ALTER TABLE player_profiles\n576\t      ADD COLUMN IF NOT EXISTS current_season_id BIGINT REFERENCES seasons(id)\n577\t    `;\n578\t    await rawSql`\n579\t      ALTER TABLE player_profiles\n580\t      ADD COLUMN IF NOT EXISTS current_season_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n581\t    `;\n582\t    await rawSql`\n583\t      ALTER TABLE player_profiles\n584\t      ADD COLUMN IF NOT EXISTS cached_lifetime_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n585\t    `;\n586\t    await rawSql`\n587\t      ALTER TABLE player_profiles\n588\t      ADD COLUMN IF NOT EXISTS cached_season_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n589\t    `;\n590\t    await rawSql`\n591\t      CREATE TABLE IF NOT EXISTS multiplier_ladders (\n592\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n593\t        scope TEXT NOT NULL CHECK (scope IN ('lifetime', 'season')),\n594\t        metric TEXT NOT NULL CHECK (metric IN ('wagered_usd')),\n595\t        season_id BIGINT REFERENCES seasons(id),\n596\t        effective_from TIMESTAMPTZ NOT NULL,\n597\t        label TEXT,\n598\t        created_by TEXT,\n599\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n600\t      )\n601\t    `;\n602\t    await rawSql`\n603\t      CREATE TABLE IF NOT EXISTS multiplier_ladder_steps (\n604\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n605\t        ladder_id BIGINT NOT NULL REFERENCES multiplier_ladders(id) ON DELETE CASCADE,\n606\t        level INT NOT NULL,\n607\t        threshold_usd NUMERIC(20,6) NOT NULL,\n608\t        multiplier NUMERIC(12,6) NOT NULL CHECK (multiplier >= 0 AND multiplier <= 10),\n609\t        sort_order INT NOT NULL DEFAULT 0,\n610\t        UNIQUE (ladder_id, threshold_usd),\n611\t        UNIQUE (ladder_id, level)\n612\t      )\n613\t    `;\n614\t    await rawSql`\n615\t      CREATE TABLE IF NOT EXISTS events (\n616\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n617\t        season_id BIGINT REFERENCES seasons(id),\n618\t        event_type TEXT NOT NULL DEFAULT 'generic',\n619\t        display_name TEXT NOT NULL,\n620\t        starts_at TIMESTAMPTZ NOT NULL,\n621\t        ends_at TIMESTAMPTZ NOT NULL,\n622\t        status TEXT NOT NULL DEFAULT 'scheduled'\n623\t          CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n624\t        config JSONB NOT NULL DEFAULT '{}',\n625\t        created_by TEXT,\n626\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n627\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n628\t      )\n629\t    `;\n630\t    await rawSql`\n631\t      CREATE TABLE IF NOT EXISTS multiplier_modifiers (\n632\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n633\t        user_id TEXT,\n634\t        season_id BIGINT NOT NULL REFERENCES seasons(id),\n635\t        source_type TEXT NOT NULL CHECK (source_type IN ('event', 'admin', 'reward')),\n636\t        source_id TEXT NOT NULL,\n637\t        mode TEXT NOT NULL DEFAULT 'set_value'\n638\t          CHECK (mode IN ('multiply', 'set_min', 'set_value')),\n639\t        value NUMERIC(12,6) NOT NULL CHECK (value >= 0 AND value <= 10),\n640\t        priority INT NOT NULL DEFAULT 0,\n641\t        starts_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n642\t        ends_at TIMESTAMPTZ,\n643\t        created_by TEXT,\n644\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n645\t      )\n646\t    `;\n647\t    // Tighten season_id on dev DBs that already have the table from an\n648\t    // earlier run when season_id was nullable.\n649\t    await rawSql`\n650\t      UPDATE multiplier_modifiers\n651\t      SET season_id = (SELECT id FROM seasons WHERE status = 'active' LIMIT 1)\n652\t      WHERE season_id IS NULL\n653\t    `;\n654\t    await rawSql`\n655\t      ALTER TABLE multiplier_modifiers\n656\t      ALTER COLUMN season_id SET NOT NULL\n657\t    `;\n658\t    await rawSql`\n659\t      ALTER TABLE point_grants\n660\t      ADD COLUMN IF NOT EXISTS season_id BIGINT REFERENCES seasons(id)\n661\t    `;\n662\t    await rawSql`\n663\t      ALTER TABLE point_grants\n664\t      ADD COLUMN IF NOT EXISTS effective_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n665\t    `;\n666\t    await rawSql`\n667\t      ALTER TABLE point_grants\n668\t      ADD COLUMN IF NOT EXISTS point_rate_version_id BIGINT REFERENCES point_rate_versions(id)\n669\t    `;\n670\t    await rawSql`\n671\t      ALTER TABLE point_grants\n672\t      DROP CONSTRAINT IF EXISTS point_grants_source_type_check\n673\t    `;\n674\t    await rawSql`\n675\t      ALTER TABLE point_grants\n676\t      ADD CONSTRAINT point_grants_source_type_check\n677\t      CHECK (source_type IN (\n678\t        'wager',\n679\t        'challenge_completed',\n680\t        'bonus_completed',\n681\t        'crate_points',\n682\t        'admin_adjustment',\n683\t        'reward',\n684\t        'migration_adjustment'\n685\t      ))\n686\t    `;\n687\t\n688\t    rewardEconomyTablesEnsured = true;\n689\t  } finally {\n690\t    await rawSql`SELECT pg_advisory_unlock(401401)`;\n691\t  }\n692\t}\n693\t\n694\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n695\t  return encodeFlipYouConfig({\n696\t    authority: PublicKey.default,\n697\t    treasury,\n698\t    paused: false,\n699\t    bump: 0,\n700\t  });\n701\t}\n702\t\n703\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n704\t  const buf = Buffer.alloc(74);\n705\t  PublicKey.default.toBuffer().copy(buf, 8);\n706\t  treasury.toBuffer().copy(buf, 40);\n707\t  buf.writeUInt16LE(feeBps, 72);\n708\t  return buf;\n709\t}\n710\t"}]},"parent_tool_use_id":null,"session_id":"5131cb3a-2a57-452d-8340-6050c3efd05f","uuid":"71a6e183-5560-4881-b838-f588a486823b","timestamp":"2026-05-01T19:44:40.251Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/integration-test-helpers.ts","content":"import { SignJWT } from \"jose\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport {\n  LAMPORTS_PER_SOL,\n  PublicKey,\n  SystemProgram,\n} from \"@solana/web3.js\";\nimport { createDb, type Db } from \"../db.js\";\nimport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\nimport {\n  PLATFORM_PROGRAM_ID,\n  derivePlatformConfigPda,\n} from \"../platform-config.js\";\nimport {\n  encodeFlipYouConfig,\n  encodeFlipYouMatch,\n} from \"../worker/account-decoder.js\";\n\nexport const DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\nexport const AMOUNT_LAMPORTS = 5_000_000;\nexport const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\nexport const SIDE_HEADS = 0;\nexport const PHASE_LOCKED = 1;\nexport const JWT_SECRET = new TextEncoder().encode(\n  \"test-secret-for-integration-tests\",\n);\n\nconst RESET_TABLES = [\n  \"rounds\",\n  \"closecall_rounds\",\n  \"closecall_candles\",\n  \"operator_events\",\n  \"event_queue\",\n  \"game_entries\",\n  \"transactions\",\n  \"player_profiles\",\n  \"referral_codes\",\n  \"referral_links\",\n  \"referral_earnings\",\n  \"referral_claims\",\n  \"referral_kol_rates\",\n  \"reward_pool_fundings\",\n  \"point_grants\",\n  \"point_balances\",\n  \"point_rate_versions\",\n  \"multiplier_modifiers\",\n  \"multiplier_ladder_steps\",\n  \"multiplier_ladders\",\n  \"events\",\n  \"seasons\",\n  \"crate_drops\",\n  \"progress_events\",\n  \"challenge_assignments\",\n  \"bonus_completions\",\n].join(\", \");\n\nexport type TestSql = ReturnType<typeof postgres>;\n\nexport interface IntegrationDbContext {\n  db: Db;\n  rawSql: TestSql;\n}\n\nlet referralTablesEnsured = false;\nlet rewardEconomyTablesEnsured = false;\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nexport function makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nexport async function openIntegrationDb(): Promise<IntegrationDbContext> {\n  const rawSql = makeSql();\n  await ensureReferralTables(rawSql);\n  await ensureRewardEconomyTables(rawSql);\n  return {\n    rawSql,\n    db: createDb(DATABASE_URL, rawSql),\n  };\n}\n\nexport async function closeIntegrationDb(ctx: IntegrationDbContext) {\n  await ctx.db.close();\n  await ctx.rawSql.end();\n}\n\n/**\n * Seed a player_profile row for a test. Production creates profiles via the\n * auth flow before any wager fires; tests that bypass auth and call the\n * points-grant handler directly need to pre-create the row, since the\n * handler now updates the profile in-place for materialized economy state.\n */\nexport async function seedPlayerProfile(\n  rawSql: TestSql,\n  userId: string,\n  wallet: string,\n  username: string = `tester-${userId}`,\n): Promise<void> {\n  await rawSql`\n    INSERT INTO player_profiles (user_id, wallet, username)\n    VALUES (${userId}, ${wallet}, ${username})\n    ON CONFLICT (user_id) DO NOTHING\n  `;\n}\n\nexport async function resetIntegrationState(rawSql: TestSql) {\n  await ensureReferralTables(rawSql);\n  await ensureRewardEconomyTables(rawSql);\n  await rawSql.begin(async (tx) => {\n    const sql = tx as unknown as TestSql;\n    await sql`SELECT pg_advisory_xact_lock(401402)`;\n    await sql.unsafe(`TRUNCATE ${RESET_TABLES} RESTART IDENTITY CASCADE`);\n    await sql`\n    INSERT INTO reward_pool (\n      id,\n      balance_lamports,\n      lifetime_funded,\n      lifetime_paid,\n      updated_at\n    )\n    VALUES (1, 0, 0, 0, now())\n    ON CONFLICT (id) DO UPDATE\n    SET\n      balance_lamports = EXCLUDED.balance_lamports,\n      lifetime_funded = EXCLUDED.lifetime_funded,\n      lifetime_paid = EXCLUDED.lifetime_paid,\n      updated_at = EXCLUDED.updated_at\n  `;\n    await sql`\n    INSERT INTO seasons (slug, name, starts_at, status)\n    VALUES ('season-1', 'Season 1', '2026-01-01T00:00:00Z', 'active')\n  `;\n    await sql`\n    INSERT INTO point_rate_versions (rate_per_usd, effective_from, label)\n    VALUES (100, '2026-01-01T00:00:00Z', 'Launch default')\n  `;\n    await sql`\n      DELETE FROM reward_config\n      WHERE key IN ('points_per_dollar', 'dogpile_default_multiplier')\n    `;\n    await sql`\n      INSERT INTO reward_config (key, value)\n      VALUES\n        ('reward_pool_fee_share', '0.20'),\n        ('points_crate_drop_rate', '0.05'),\n        ('sol_crate_drop_rate', '0.01'),\n        ('sol_crate_pool_pct', '0.10'),\n        ('sol_crate_min_value', '10000000'),\n        ('points_crate_min', '500'),\n        ('points_crate_max', '5000'),\n        ('daily_challenge_count', '3'),\n        ('weekly_challenge_count', '2')\n      ON CONFLICT (key) DO UPDATE\n      SET value = EXCLUDED.value, updated_at = now()\n    `;\n    await sql`\n    WITH lifetime_ladder AS (\n      INSERT INTO multiplier_ladders (scope, metric, effective_from, label)\n      VALUES ('lifetime', 'wagered_usd', '2026-01-01T00:00:00Z', 'Launch lifetime ladder')\n      RETURNING id\n    )\n    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n    SELECT id, level, threshold_usd, multiplier, level\n    FROM lifetime_ladder\n    CROSS JOIN (VALUES\n      (1, 1000, 1.10),\n      (2, 10000, 1.20),\n      (3, 50000, 1.30),\n      (4, 100000, 1.40),\n      (5, 250000, 1.50),\n      (6, 500000, 1.60),\n      (7, 1000000, 1.70),\n      (8, 2500000, 1.80),\n      (9, 5000000, 1.90),\n      (10, 10000000, 2.00)\n    ) AS steps(level, threshold_usd, multiplier)\n  `;\n    await sql`\n    WITH active_season AS (\n      SELECT id FROM seasons WHERE status = 'active' LIMIT 1\n    ),\n    season_ladder AS (\n      INSERT INTO multiplier_ladders (scope, metric, season_id, effective_from, label)\n      SELECT 'season', 'wagered_usd', id, '2026-01-01T00:00:00Z', 'Launch season ladder'\n      FROM active_season\n      RETURNING id\n    )\n    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n    SELECT id, level, threshold_usd, multiplier, level\n    FROM season_ladder\n    CROSS JOIN (VALUES\n      (1, 500, 1.20),\n      (2, 5000, 1.50),\n      (3, 25000, 2.00),\n      (4, 100000, 2.50),\n      (5, 250000, 3.00)\n    ) AS steps(level, threshold_usd, multiplier)\n  `;\n  });\n}\n\nexport async function makeJwt(\n  wallet: string,\n  userId = userIdFromWallet(wallet),\n) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nexport function userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n/**\n * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n */\nexport class MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getSlot() {\n    return this._slot;\n  }\n\n  async getAccountInfo(pubkey: PublicKey) {\n    const acc = this._accounts.get(pubkey.toBase58());\n    if (!acc) return null;\n    return { ...acc, rentEpoch: 0 };\n  }\n\n  async getProgramAccounts(\n    programId: PublicKey,\n    config?: {\n      filters?: Array<\n        | { dataSize: number }\n        | { memcmp: { offset: number; bytes: string } }\n      >;\n    },\n  ) {\n    const results: Array<{\n      pubkey: PublicKey;\n      account: {\n        data: Buffer;\n        lamports: number;\n        owner: PublicKey;\n        executable: boolean;\n        rentEpoch: number;\n      };\n    }> = [];\n\n    for (const [key, acc] of this._accounts) {\n      if (!acc.owner.equals(programId)) continue;\n\n      let matches = true;\n      if (config?.filters) {\n        for (const filter of config.filters) {\n          if (\"dataSize\" in filter && acc.data.length !== filter.dataSize) {\n            matches = false;\n            break;\n          }\n\n          if (\"memcmp\" in filter) {\n            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n            const actual = acc.data.subarray(\n              filter.memcmp.offset,\n              filter.memcmp.offset + expected.length,\n            );\n            if (Buffer.compare(actual, expected) !== 0) {\n              matches = false;\n              break;\n            }\n          }\n        }\n      }\n\n      if (matches) {\n        results.push({\n          pubkey: new PublicKey(key),\n          account: { ...acc, rentEpoch: 0 },\n        });\n      }\n    }\n\n    return results;\n  }\n\n  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n    this.lastRawTx = Buffer.from(rawTx);\n    return bs58.encode(Buffer.alloc(64, 0x01));\n  }\n\n  async confirmTransaction() {\n    return { value: { err: null }, context: { slot: this._slot } };\n  }\n\n  async getBlockTime(_slot: number) {\n    return Math.floor(Date.now() / 1000);\n  }\n\n  async getBalance() {\n    return 2 * LAMPORTS_PER_SOL;\n  }\n}\n\nexport async function buildMatchAccountData(params: {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: Buffer;\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  matchId: Buffer;\n}): Promise<Buffer> {\n  return encodeFlipYouMatch({\n    creator: params.creator,\n    opponent: params.opponent,\n    server: params.server,\n    entryAmount: params.entryAmount,\n    creatorSide: params.creatorSide,\n    phase: params.phase,\n    commitment: [...params.commitment],\n    algorithmVer: params.algorithmVer,\n    targetSlot: params.targetSlot,\n    resolveDeadline: params.resolveDeadline,\n    resultHash: new Array(32).fill(0),\n    result: 0,\n    winner: PublicKey.default,\n    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n    matchId: [...params.matchId],\n    bump: 0,\n  });\n}\n\nexport async function seedSettlementProgramAccounts(\n  mockConn: MockConnection,\n  params: {\n    entropyAccount: PublicKey;\n    entropyData: Buffer;\n    treasury: PublicKey;\n  },\n) {\n  mockConn.setAccount(params.entropyAccount, params.entropyData);\n\n  const [configPda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"flipyou_config\")],\n    FLIPYOU_PROGRAM_ID,\n  );\n  mockConn.setAccount(\n    configPda,\n    await buildConfigAccountData(params.treasury),\n    { owner: FLIPYOU_PROGRAM_ID },\n  );\n\n  const [platformConfigPda] = derivePlatformConfigPda();\n  mockConn.setAccount(\n    platformConfigPda,\n    buildPlatformConfigData(params.treasury, 500),\n    { owner: PLATFORM_PROGRAM_ID },\n  );\n}\n\nasync function ensureReferralTables(rawSql: TestSql) {\n  if (referralTablesEnsured) {\n    return;\n  }\n\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_codes (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      user_id TEXT NOT NULL UNIQUE,\n      wallet TEXT NOT NULL UNIQUE,\n      code TEXT NOT NULL UNIQUE,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_links (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      referrer_user_id TEXT NOT NULL,\n      referee_user_id TEXT NOT NULL UNIQUE,\n      referrer_wallet TEXT NOT NULL,\n      referee_wallet TEXT NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n    ON referral_links (referrer_user_id)\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_earnings (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      referrer_user_id TEXT NOT NULL,\n      referee_user_id TEXT NOT NULL,\n      referrer_wallet TEXT NOT NULL,\n      referee_wallet TEXT NOT NULL,\n      round_id TEXT NOT NULL,\n      game_type TEXT NOT NULL,\n      wager_lamports BIGINT NOT NULL,\n      fee_lamports BIGINT NOT NULL,\n      referrer_earned_lamports BIGINT NOT NULL,\n      referrer_rate_bps INTEGER NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      CONSTRAINT uq_referral_earnings_referee_round\n        UNIQUE (referee_user_id, round_id)\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n    ON referral_earnings (referrer_user_id, created_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n    ON referral_earnings (referee_user_id, created_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n    ON referral_earnings (round_id)\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_claims (\n      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n      user_id TEXT NOT NULL,\n      wallet TEXT NOT NULL,\n      amount_lamports BIGINT NOT NULL,\n      status TEXT NOT NULL DEFAULT 'pending'\n        CHECK (\n          status IN ('pending', 'processing', 'error', 'completed', 'failed')\n        ),\n      retry_count INTEGER NOT NULL DEFAULT 0,\n      tx_signature TEXT,\n      error TEXT,\n      requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      processed_at TIMESTAMPTZ\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_claims_user_id\n    ON referral_claims (user_id, requested_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_claims_status\n    ON referral_claims (status)\n    WHERE status IN ('pending', 'processing')\n  `;\n  await rawSql`\n    CREATE UNIQUE INDEX IF NOT EXISTS idx_referral_claims_user_active\n    ON referral_claims (user_id)\n    WHERE status IN ('pending', 'processing', 'error')\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_kol_rates (\n      user_id TEXT PRIMARY KEY,\n      wallet TEXT NOT NULL UNIQUE,\n      rate_bps INTEGER NOT NULL,\n      set_by TEXT NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n\n  referralTablesEnsured = true;\n}\n\nasync function ensureRewardEconomyTables(rawSql: TestSql) {\n  if (rewardEconomyTablesEnsured) {\n    return;\n  }\n\n  await rawSql`SELECT pg_advisory_lock(401401)`;\n  try {\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS seasons (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        slug TEXT NOT NULL UNIQUE,\n        name TEXT NOT NULL,\n        starts_at TIMESTAMPTZ NOT NULL,\n        ends_at TIMESTAMPTZ,\n        status TEXT NOT NULL CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX IF NOT EXISTS idx_seasons_one_active\n      ON seasons ((status))\n      WHERE status = 'active'\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS point_rate_versions (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        rate_per_usd NUMERIC(18,6) NOT NULL,\n        effective_from TIMESTAMPTZ NOT NULL,\n        label TEXT,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS point_balances (\n        user_id TEXT NOT NULL,\n        season_id BIGINT NOT NULL REFERENCES seasons(id),\n        wallet TEXT NOT NULL,\n        balance BIGINT NOT NULL DEFAULT 0,\n        season_earned BIGINT NOT NULL DEFAULT 0,\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        PRIMARY KEY (user_id, season_id)\n      )\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS lifetime_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS current_season_id BIGINT REFERENCES seasons(id)\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS current_season_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS cached_lifetime_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS cached_season_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_ladders (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        scope TEXT NOT NULL CHECK (scope IN ('lifetime', 'season')),\n        metric TEXT NOT NULL CHECK (metric IN ('wagered_usd')),\n        season_id BIGINT REFERENCES seasons(id),\n        effective_from TIMESTAMPTZ NOT NULL,\n        label TEXT,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_ladder_steps (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        ladder_id BIGINT NOT NULL REFERENCES multiplier_ladders(id) ON DELETE CASCADE,\n        level INT NOT NULL,\n        threshold_usd NUMERIC(20,6) NOT NULL,\n        multiplier NUMERIC(12,6) NOT NULL CHECK (multiplier >= 0 AND multiplier <= 10),\n        sort_order INT NOT NULL DEFAULT 0,\n        UNIQUE (ladder_id, threshold_usd),\n        UNIQUE (ladder_id, level)\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS events (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        season_id BIGINT REFERENCES seasons(id),\n        event_type TEXT NOT NULL DEFAULT 'generic',\n        display_name TEXT NOT NULL,\n        starts_at TIMESTAMPTZ NOT NULL,\n        ends_at TIMESTAMPTZ NOT NULL,\n        status TEXT NOT NULL DEFAULT 'scheduled'\n          CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n        config JSONB NOT NULL DEFAULT '{}',\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_modifiers (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id TEXT,\n        season_id BIGINT NOT NULL REFERENCES seasons(id),\n        source_type TEXT NOT NULL CHECK (source_type IN ('event', 'admin', 'reward')),\n        source_id TEXT NOT NULL,\n        mode TEXT NOT NULL DEFAULT 'set_value'\n          CHECK (mode IN ('multiply', 'set_min', 'set_value')),\n        value NUMERIC(12,6) NOT NULL CHECK (value >= 0 AND value <= 10),\n        priority INT NOT NULL DEFAULT 0,\n        starts_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        ends_at TIMESTAMPTZ,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    // Tighten season_id on dev DBs that already have the table from an\n    // earlier run when season_id was nullable.\n    await rawSql`\n      UPDATE multiplier_modifiers\n      SET season_id = (SELECT id FROM seasons WHERE status = 'active' LIMIT 1)\n      WHERE season_id IS NULL\n    `;\n    await rawSql`\n      ALTER TABLE multiplier_modifiers\n      ALTER COLUMN season_id SET NOT NULL\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS season_id BIGINT REFERENCES seasons(id)\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS effective_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS point_rate_version_id BIGINT REFERENCES point_rate_versions(id)\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      DROP CONSTRAINT IF EXISTS point_grants_source_type_check\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD CONSTRAINT point_grants_source_type_check\n      CHECK (source_type IN (\n        'wager',\n        'challenge_completed',\n        'bonus_completed',\n        'crate_points',\n        'admin_adjustment',\n        'reward',\n        'migration_adjustment'\n      ))\n    `;\n\n    rewardEconomyTablesEnsured = true;\n  } finally {\n    await rawSql`SELECT pg_advisory_unlock(401401)`;\n  }\n}\n\nasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n  return encodeFlipYouConfig({\n    authority: PublicKey.default,\n    treasury,\n    paused: false,\n    bump: 0,\n  });\n}\n\nfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n  const buf = Buffer.alloc(74);\n  PublicKey.default.toBuffer().copy(buf, 8);\n  treasury.toBuffer().copy(buf, 40);\n  buf.writeUInt16LE(feeBps, 72);\n  return buf;\n}\n","numLines":710,"startLine":1,"totalLines":710}}}
