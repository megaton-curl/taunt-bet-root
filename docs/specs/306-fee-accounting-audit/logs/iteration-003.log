dParams, OperatorEventType, OperatorEvent, RoundsDb } from \"./db/rounds.js\";\n26\texport type { PlayerStats, PublicPlayerStats, WinStreaks, GameBreakdownStats, LeaderboardEntry, LeaderboardResult, StatsDb } from \"./db/stats.js\";\n27\texport type { TelegramLinkStatus, TelegramLinkToken, TelegramLinksDb } from \"./db/telegram-links.js\";\n28\texport type {\n29\t  LinkedAccountStatus,\n30\t  LinkedAccountProvider,\n31\t  LinkedAccount,\n32\t  LinkedAccountsDb,\n33\t} from \"./db/linked-accounts.js\";\n34\texport type {\n35\t  FeeBucket,\n36\t  FeeBucketDebitStatus,\n37\t  FeeAllocation,\n38\t  InsertFeeAllocationParams,\n39\t  InsertFeeBucketDebitParams,\n40\t  FeeAllocationEventRow,\n41\t  FeeBucketDebitRow,\n42\t  FeeAuditBucketSummary,\n43\t  FeeAuditSnapshot,\n44\t  FeeAccountingDb,\n45\t} from \"./db/fee-accounting.js\";\n46\texport { calculateFeeAllocation } from \"./db/fee-accounting.js\";\n47\t\n48\t// ---------------------------------------------------------------------------\n49\t// DB client\n50\t// ---------------------------------------------------------------------------\n51\t\n52\texport interface Db\n53\t  extends ReferralsDb,\n54\t    ProfilesDb,\n55\t    CloseCallDb,\n56\t    CloseCallCandlesDb,\n57\t    TransactionsDb,\n58\t    GameEntriesDb,\n59\t    RoundsDb,\n60\t    StatsDb,\n61\t    TelegramLinksDb,\n62\t    LinkedAccountsDb,\n63\t    FeeAccountingDb {\n64\t  /**\n65\t   * Execute a function within a database transaction.\n66\t   * All db methods called on the transactional Db share the same transaction.\n67\t   * Rolls back on error, commits on success.\n68\t   */\n69\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n70\t\n71\t  /** Expose the underlying SQL/transaction handle for use with emitEvent(). */\n72\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n73\t  readonly rawSql: any;\n74\t\n75\t  /** Gracefully close the connection pool. */\n76\t  close(): Promise<void>;\n77\t}\n78\t\n79\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n80\texport function createDb(databaseUrl: string, _txSql?: any): Db {"}]},"parent_tool_use_id":null,"session_id":"5131cb3a-2a57-452d-8340-6050c3efd05f","uuid":"4b24e397-b347-487e-aca8-a652ebe245da","timestamp":"2026-05-01T19:47:08.177Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/db.ts","content":"/**\n * Database client composition shell — imports domain modules and composes\n * the unified Db interface. See db/ for domain implementations.\n */\n\nimport postgres from \"postgres\";\nimport { createReferralsDb, type ReferralsDb } from \"./db/referrals.js\";\nimport { createProfilesDb, type ProfilesDb } from \"./db/profiles.js\";\nimport { createCloseCallDb, type CloseCallDb } from \"./db/closecall.js\";\nimport { createCloseCallCandlesDb, type CloseCallCandlesDb } from \"./db/closecall-candles.js\";\nimport { createTransactionsDb, type TransactionsDb } from \"./db/transactions.js\";\nimport { createGameEntriesDb, type GameEntriesDb } from \"./db/game-entries.js\";\nimport { createRoundsDb, type RoundsDb } from \"./db/rounds.js\";\nimport { createStatsDb, type StatsDb } from \"./db/stats.js\";\nimport { createTelegramLinksDb, type TelegramLinksDb } from \"./db/telegram-links.js\";\nimport { createLinkedAccountsDb, type LinkedAccountsDb } from \"./db/linked-accounts.js\";\nimport { createFeeAccountingDb, type FeeAccountingDb } from \"./db/fee-accounting.js\";\n\nexport type { ReferralCode, ReferralLink, ReferralEarning, ReferralStats, ReferralClaim, ReferralsDb } from \"./db/referrals.js\";\nexport type { PlayerProfile, ProfilesDb } from \"./db/profiles.js\";\nexport type { CloseCallPhase, CloseCallOutcome, CloseCallRound, InsertCloseCallRoundParams, CloseCallDb } from \"./db/closecall.js\";\nexport type { CloseCallCandle, CloseCallCandlesDb } from \"./db/closecall-candles.js\";\nexport type { TransactionType, Transaction, InsertTransactionParams, TransactionsDb } from \"./db/transactions.js\";\nexport type { GameEntryUpsert, GameEntryInsert, GameEntry, GameEntriesDb } from \"./db/game-entries.js\";\nexport type { RoundPhase, Round, InsertRoundParams, OperatorEventType, OperatorEvent, RoundsDb } from \"./db/rounds.js\";\nexport type { PlayerStats, PublicPlayerStats, WinStreaks, GameBreakdownStats, LeaderboardEntry, LeaderboardResult, StatsDb } from \"./db/stats.js\";\nexport type { TelegramLinkStatus, TelegramLinkToken, TelegramLinksDb } from \"./db/telegram-links.js\";\nexport type {\n  LinkedAccountStatus,\n  LinkedAccountProvider,\n  LinkedAccount,\n  LinkedAccountsDb,\n} from \"./db/linked-accounts.js\";\nexport type {\n  FeeBucket,\n  FeeBucketDebitStatus,\n  FeeAllocation,\n  InsertFeeAllocationParams,\n  InsertFeeBucketDebitParams,\n  FeeAllocationEventRow,\n  FeeBucketDebitRow,\n  FeeAuditBucketSummary,\n  FeeAuditSnapshot,\n  FeeAccountingDb,\n} from \"./db/fee-accounting.js\";\nexport { calculateFeeAllocation } from \"./db/fee-accounting.js\";\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db\n  extends ReferralsDb,\n    ProfilesDb,\n    CloseCallDb,\n    CloseCallCandlesDb,\n    TransactionsDb,\n    GameEntriesDb,\n    RoundsDb,\n    StatsDb,\n    TelegramLinksDb,\n    LinkedAccountsDb,\n    FeeAccountingDb {\n  /**\n   * Execute a function within a database transaction.\n   * All db methods called on the transactional Db share the same transaction.\n   * Rolls back on error, commits on success.\n   */\n  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n\n  /** Expose the underlying SQL/transaction handle for use with emitEvent(). */\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  readonly rawSql: any;\n\n  /** Gracefully close the connection pool. */\n  close(): Promise<void>;\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nexport function createDb(databaseUrl: string, _txSql?: any): Db {","numLines":80,"startLine":1,"totalLines":120}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_013GTH7zV6X1xNTZQiwx8si7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011LbXzUPfCQskz6b6wgizfr","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/__tests__/fee-accounting.test.ts","content":"/**\n * Fee accounting unit + DB constraint coverage.\n *\n * - `calculateFeeAllocation`: pure FR-2 split (referral floor → promotions\n *   floor on remainder × 20% → profit absorbs dust).\n * - `fee_allocation_events` CHECK constraint: the DB rejects rows whose\n *   referral + promotions + profit components do not sum to `fee_lamports`.\n *\n * The DB-backed test mirrors the safety net the audit snapshot relies on —\n * if a future refactor of `insertFeeAllocation` or migration weakens the\n * constraint, this test fails before the snapshot ever sees a bad row.\n */\n\nimport { describe, it, expect, afterAll } from \"vitest\";\nimport postgres from \"postgres\";\nimport { calculateFeeAllocation } from \"../db/fee-accounting.js\";\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// calculateFeeAllocation — pure FR-2 split\n// ---------------------------------------------------------------------------\n\ndescribe(\"calculateFeeAllocation\", () => {\n  it(\"0 bps referral: referral=0, promotions=20% floor, profit=remainder\", () => {\n    const split = calculateFeeAllocation(1000, 0);\n    expect(split.referralLamports).toBe(0);\n    expect(split.promotionsLamports).toBe(200);\n    expect(split.profitLamports).toBe(800);\n  });\n\n  it(\"10000 bps (100%) referral: referral=fee, promotions=0, profit=0\", () => {\n    const split = calculateFeeAllocation(1000, 10000);\n    expect(split.referralLamports).toBe(1000);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(0);\n  });\n\n  it(\"mid-range bps splits cleanly when math is integer\", () => {\n    // 500 referral, 100 promotions (20% of 500 remaining), 400 profit.\n    const split = calculateFeeAllocation(1000, 5000);\n    expect(split.referralLamports).toBe(500);\n    expect(split.promotionsLamports).toBe(100);\n    expect(split.profitLamports).toBe(400);\n  });\n\n  it(\"dust from referral floor lands in profit, never in promotions\", () => {\n    // fee=7, bps=5000 → referral=floor(3.5)=3, post=4, promo=floor(0.8)=0, profit=4.\n    const split = calculateFeeAllocation(7, 5000);\n    expect(split.referralLamports).toBe(3);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(4);\n  });\n\n  it(\"single-lamport fee with non-zero referral rate puts the lamport in profit\", () => {\n    // fee=1, bps=1 → referral=floor(0.0001)=0, promo=floor(0.2)=0, profit=1.\n    const split = calculateFeeAllocation(1, 1);\n    expect(split.referralLamports).toBe(0);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(1);\n  });\n\n  it(\"feeLamports=0 produces zero across all buckets regardless of bps\", () => {\n    for (const bps of [0, 1, 1000, 5000, 9999, 10000]) {\n      const split = calculateFeeAllocation(0, bps);\n      expect(split.referralLamports).toBe(0);\n      expect(split.promotionsLamports).toBe(0);\n      expect(split.profitLamports).toBe(0);\n    }\n  });\n\n  it(\"max-bps (10000) leaves nothing for promotions or profit even with dust\", () => {\n    // The floor at 100% bps consumes the entire fee.\n    const split = calculateFeeAllocation(13, 10000);\n    expect(split.referralLamports).toBe(13);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(0);\n  });\n\n  it(\"components always sum exactly to feeLamports across a wide grid\", () => {\n    const fees = [0, 1, 7, 500, 1000, 5000, 12345, 1_000_000, 9_999_999];\n    const bpsValues = [0, 1, 100, 500, 1000, 2500, 5000, 7500, 9999, 10000];\n\n    for (const fee of fees) {\n      for (const bps of bpsValues) {\n        const split = calculateFeeAllocation(fee, bps);\n        const sum =\n          split.referralLamports +\n          split.promotionsLamports +\n          split.profitLamports;\n        expect(sum, `fee=${fee}, bps=${bps}`).toBe(fee);\n        expect(split.referralLamports).toBeGreaterThanOrEqual(0);\n        expect(split.promotionsLamports).toBeGreaterThanOrEqual(0);\n        expect(split.profitLamports).toBeGreaterThanOrEqual(0);\n      }\n    }\n  });\n\n  it(\"rejects negative fee, non-integer fee, and out-of-range bps\", () => {\n    expect(() => calculateFeeAllocation(-1, 0)).toThrow();\n    expect(() => calculateFeeAllocation(1.5, 0)).toThrow();\n    expect(() => calculateFeeAllocation(100, -1)).toThrow();\n    expect(() => calculateFeeAllocation(100, 10001)).toThrow();\n    expect(() => calculateFeeAllocation(100, 1.5)).toThrow();\n  });\n});\n\n// ---------------------------------------------------------------------------\n// DB CHECK constraint — components must sum to fee_lamports\n// ---------------------------------------------------------------------------\n\ndescribe(\"fee_allocation_events CHECK ck_fee_allocation_components_sum\", () => {\n  const sql = makeSql();\n\n  afterAll(async () => {\n    await sql.end();\n  });\n\n  it(\"rejects an allocation row whose components do not sum to fee_lamports\", async () => {\n    const sourceId = `test-${Date.now()}-${Math.random().toString(36).slice(2)}`;\n    const wallet = `wallet-${Math.random().toString(36).slice(2)}`;\n\n    await expect(\n      sql`\n        INSERT INTO fee_allocation_events (\n          source_type, source_id, game_type, wallet,\n          wager_lamports, fee_lamports,\n          referral_rate_bps,\n          referral_lamports, promotions_lamports, profit_lamports\n        ) VALUES (\n          'unit_test',\n          ${sourceId},\n          'flipyou',\n          ${wallet},\n          1000000,\n          1000,\n          0,\n          0, 200, 700\n        )\n      `,\n    ).rejects.toThrow(/ck_fee_allocation_components_sum/);\n\n    const rows = await sql<{ count: string }[]>`\n      SELECT COUNT(*)::TEXT AS count\n      FROM fee_allocation_events\n      WHERE source_id = ${sourceId}\n    `;\n    expect(rows[0]!.count).toBe(\"0\");\n  });\n\n  it(\"accepts an allocation row whose components sum to fee_lamports\", async () => {\n    const sourceId = `test-${Date.now()}-${Math.random().toString(36).slice(2)}`;\n    const wallet = `wallet-${Math.random().toString(36).slice(2)}`;\n\n    await sql`\n      INSERT INTO fee_allocation_events (\n        source_type, source_id, game_type, wallet,\n        wager_lamports, fee_lamports,\n        referral_rate_bps,\n        referral_lamports, promotions_lamports, profit_lamports\n      ) VALUES (\n        'unit_test',\n        ${sourceId},\n        'flipyou',\n        ${wallet},\n        1000000,\n        1000,\n        0,\n        0, 200, 800\n      )\n    `;\n\n    try {\n      const rows = await sql<{ count: string }[]>`\n        SELECT COUNT(*)::TEXT AS count\n        FROM fee_allocation_events\n        WHERE source_id = ${sourceId}\n      `;\n      expect(rows[0]!.count).toBe(\"1\");\n    } finally {\n      await sql`\n        DELETE FROM fee_allocation_events WHERE source_id = ${sourceId}\n      `;\n    }\n  });\n\n  // Reference DATABASE_URL constant so dead-code lint stays happy when the\n  // test file is opened in IDEs that don't run the integration suite.\n  it(\"connects via DATABASE_URL or the local Unix socket fallback\", () => {\n    expect(typeof DATABASE_URL).toBe(\"string\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2795,"cache_read_input_tokens":98578,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2795},"output_tokens":55,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"5131cb3a-2a57-452d-8340-6050c3efd05f","uuid":"73399d0f-1a41-4ac2-abfa-862d0930b731"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011LbXzUPfCQskz6b6wgizfr","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/backend/src/__tests__/fee-accounting.test.ts"}]},"parent_tool_use_id":null,"session_id":"5131cb3a-2a57-452d-8340-6050c3efd05f","uuid":"0c110b53-33ae-43d3-b563-b7b558e0ac28","timestamp":"2026-05-01T19:47:42.622Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/backend/src/__tests__/fee-accounting.test.ts","content":"/**\n * Fee accounting unit + DB constraint coverage.\n *\n * - `calculateFeeAllocation`: pure FR-2 split (referral floor → promotions\n *   floor on remainder × 20% → profit absorbs dust).\n * - `fee_allocation_events` CHECK constraint: the DB rejects rows whose\n *   referral + promotions + profit components do not sum to `fee_lamports`.\n *\n * The DB-backed test mirrors the safety net the audit snapshot relies on —\n * if a future refactor of `insertFeeAllocation` or migration weakens the\n * constraint, this test fails before the snapshot ever sees a bad row.\n */\n\nimport { describe, it, expect, afterAll } from \"vitest\";\nimport postgres from \"postgres\";\nimport { calculateFeeAllocation } from \"../db/fee-accounting.js\";\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// calculateFeeAllocation — pure FR-2 split\n// ---------------------------------------------------------------------------\n\ndescribe(\"calculateFeeAllocation\", () => {\n  it(\"0 bps referral: referral=0, promotions=20% floor, profit=remainder\", () => {\n    const split = calculateFeeAllocation(1000, 0);\n    expect(split.referralLamports).toBe(0);\n    expect(split.promotionsLamports).toBe(200);\n    expect(split.profitLamports).toBe(800);\n  });\n\n  it(\"10000 bps (100%) referral: referral=fee, promotions=0, profit=0\", () => {\n    const split = calculateFeeAllocation(1000, 10000);\n    expect(split.referralLamports).toBe(1000);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(0);\n  });\n\n  it(\"mid-range bps splits cleanly when math is integer\", () => {\n    // 500 referral, 100 promotions (20% of 500 remaining), 400 profit.\n    const split = calculateFeeAllocation(1000, 5000);\n    expect(split.referralLamports).toBe(500);\n    expect(split.promotionsLamports).toBe(100);\n    expect(split.profitLamports).toBe(400);\n  });\n\n  it(\"dust from referral floor lands in profit, never in promotions\", () => {\n    // fee=7, bps=5000 → referral=floor(3.5)=3, post=4, promo=floor(0.8)=0, profit=4.\n    const split = calculateFeeAllocation(7, 5000);\n    expect(split.referralLamports).toBe(3);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(4);\n  });\n\n  it(\"single-lamport fee with non-zero referral rate puts the lamport in profit\", () => {\n    // fee=1, bps=1 → referral=floor(0.0001)=0, promo=floor(0.2)=0, profit=1.\n    const split = calculateFeeAllocation(1, 1);\n    expect(split.referralLamports).toBe(0);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(1);\n  });\n\n  it(\"feeLamports=0 produces zero across all buckets regardless of bps\", () => {\n    for (const bps of [0, 1, 1000, 5000, 9999, 10000]) {\n      const split = calculateFeeAllocation(0, bps);\n      expect(split.referralLamports).toBe(0);\n      expect(split.promotionsLamports).toBe(0);\n      expect(split.profitLamports).toBe(0);\n    }\n  });\n\n  it(\"max-bps (10000) leaves nothing for promotions or profit even with dust\", () => {\n    // The floor at 100% bps consumes the entire fee.\n    const split = calculateFeeAllocation(13, 10000);\n    expect(split.referralLamports).toBe(13);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(0);\n  });\n\n  it(\"components always sum exactly to feeLamports across a wide grid\", () => {\n    const fees = [0, 1, 7, 500, 1000, 5000, 12345, 1_000_000, 9_999_999];\n    const bpsValues = [0, 1, 100, 500, 1000, 2500, 5000, 7500, 9999, 10000];\n\n    for (const fee of fees) {\n      for (const bps of bpsValues) {\n        const split = calculateFeeAllocation(fee, bps);\n        const sum =\n          split.referralLamports +\n          split.promotionsLamports +\n          split.profitLamports;\n        expect(sum, `fee=${fee}, bps=${bps}`).toBe(fee);\n        expect(split.referralLamports).toBeGreaterThanOrEqual(0);\n        expect(split.promotionsLamports).toBeGreaterThanOrEqual(0);\n        expect(split.profitLamports).toBeGreaterThanOrEqual(0);\n      }\n    }\n  });\n\n  it(\"rejects negative fee, non-integer fee, and out-of-range bps\", () => {\n    expect(() => calculateFeeAllocation(-1, 0)).toThrow();\n    expect(() => calculateFeeAllocation(1.5, 0)).toThrow();\n    expect(() => calculateFeeAllocation(100, -1)).toThrow();\n    expect(() => calculateFeeAllocation(100, 10001)).toThrow();\n    expect(() => calculateFeeAllocation(100, 1.5)).toThrow();\n  });\n});\n\n// ---------------------------------------------------------------------------\n// DB CHECK constraint — components must sum to fee_lamports\n// ---------------------------------------------------------------------------\n\ndescribe(\"fee_allocation_events CHECK ck_fee_allocation_components_sum\", () => {\n  const sql = makeSql();\n\n  afterAll(async () => {\n    await sql.end();\n  });\n\n  it(\"rejects an allocation row whose components do not sum to fee_lamports\", async () => {\n    const sourceId = `test-${Date.now()}-${Math.random().toString(36).slice(2)}`;\n    const wallet = `wallet-${Math.random().toString(36).slice(2)}`;\n\n    await expect(\n      sql`\n        INSERT INTO fee_allocation_events (\n          source_type, source_id, game_type, wallet,\n          wager_lamports, fee_lamports,\n          referral_rate_bps,\n          referral_lamports, promotions_lamports, profit_lamports\n        ) VALUES (\n          'unit_test',\n          ${sourceId},\n          'flipyou',\n          ${wallet},\n          1000000,\n          1000,\n          0,\n          0, 200, 700\n        )\n      `,\n    ).rejects.toThrow(/ck_fee_allocation_components_sum/);\n\n    const rows = await sql<{ count: string }[]>`\n      SELECT COUNT(*)::TEXT AS count\n      FROM fee_allocation_events\n      WHERE source_id = ${sourceId}\n    `;\n    expect(rows[0]!.count).toBe(\"0\");\n  });\n\n  it(\"accepts an allocation row whose components sum to fee_lamports\", async () => {\n    const sourceId = `test-${Date.now()}-${Math.random().toString(36).slice(2)}`;\n    const wallet = `wallet-${Math.random().toString(36).slice(2)}`;\n\n    await sql`\n      INSERT INTO fee_allocation_events (\n        source_type, source_id, game_type, wallet,\n        wager_lamports, fee_lamports,\n        referral_rate_bps,\n        referral_lamports, promotions_lamports, profit_lamports\n      ) VALUES (\n        'unit_test',\n        ${sourceId},\n        'flipyou',\n        ${wallet},\n        1000000,\n        1000,\n        0,\n        0, 200, 800\n      )\n    `;\n\n    try {\n      const rows = await sql<{ count: string }[]>`\n        SELECT COUNT(*)::TEXT AS count\n        FROM fee_allocation_events\n        WHERE source_id = ${sourceId}\n      `;\n      expect(rows[0]!.count).toBe(\"1\");\n    } finally {\n      await sql`\n        DELETE FROM fee_allocation_events WHERE source_id = ${sourceId}\n      `;\n    }\n  });\n\n  // Reference DATABASE_URL constant so dead-code lint stays happy when the\n  // test file is opened in IDEs that don't run the integration suite.\n  it(\"connects via DATABASE_URL or the local Unix socket fallback\", () => {\n    expect(typeof DATABASE_URL).toBe(\"string\");\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
