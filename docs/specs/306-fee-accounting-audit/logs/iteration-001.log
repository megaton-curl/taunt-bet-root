{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_013MzVYRWoWtvq4F1eTCRMPu","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01APYZdG7p143TeLqs5nXWSV","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/migrations/026_fee_accounting_audit.sql","content":"-- 026_fee_accounting_audit.sql — Durable accounting trail for platform fees.\n--\n-- Three ledgers and one acceleration table:\n--   * fee_allocation_events  — one row per (settlement source, player) splitting\n--                              the fee into referral / promotions / profit\n--                              virtual buckets. Immutable.\n--   * fee_bucket_debits      — bucket spends (e.g. referral claims). Status is\n--                              kept in lockstep with the originating record.\n--   * fee_audit_checkpoints  — bounded-window acceleration snapshots so routine\n--                              audits do not need to re-scan the full ledger.\n\nCREATE TABLE fee_allocation_events (\n  id                    BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  source_type           TEXT         NOT NULL,\n  source_id             TEXT         NOT NULL,\n  game_type             TEXT         NOT NULL,\n  wallet                TEXT         NOT NULL,\n  user_id               TEXT,\n  wager_lamports        BIGINT       NOT NULL,\n  fee_lamports          BIGINT       NOT NULL,\n  referrer_user_id      TEXT,\n  referral_rate_bps     INTEGER      NOT NULL DEFAULT 0,\n  referral_lamports     BIGINT       NOT NULL DEFAULT 0,\n  promotions_lamports   BIGINT       NOT NULL DEFAULT 0,\n  profit_lamports       BIGINT       NOT NULL DEFAULT 0,\n  created_at            TIMESTAMPTZ  NOT NULL DEFAULT now(),\n\n  CONSTRAINT uq_fee_allocation_source_wallet\n    UNIQUE (source_type, source_id, wallet),\n\n  CONSTRAINT ck_fee_allocation_components_sum\n    CHECK (referral_lamports + promotions_lamports + profit_lamports = fee_lamports),\n\n  CONSTRAINT ck_fee_allocation_rate_bps_range\n    CHECK (referral_rate_bps BETWEEN 0 AND 10000),\n\n  CONSTRAINT ck_fee_allocation_amounts_non_negative\n    CHECK (\n      wager_lamports >= 0\n      AND fee_lamports >= 0\n      AND referral_lamports >= 0\n      AND promotions_lamports >= 0\n      AND profit_lamports >= 0\n    )\n);\n\nCREATE INDEX idx_fee_allocation_events_created_at\n  ON fee_allocation_events (created_at);\n\nCREATE INDEX idx_fee_allocation_events_referrer\n  ON fee_allocation_events (referrer_user_id, created_at)\n  WHERE referrer_user_id IS NOT NULL;\n\nCREATE INDEX idx_fee_allocation_events_user\n  ON fee_allocation_events (user_id, created_at)\n  WHERE user_id IS NOT NULL;\n\nCREATE TABLE fee_bucket_debits (\n  id                BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  bucket            TEXT         NOT NULL,\n  debit_type        TEXT         NOT NULL,\n  source_id         TEXT         NOT NULL,\n  user_id           TEXT,\n  wallet            TEXT,\n  amount_lamports   BIGINT       NOT NULL,\n  status            TEXT         NOT NULL DEFAULT 'pending',\n  created_at        TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  updated_at        TIMESTAMPTZ  NOT NULL DEFAULT now(),\n\n  CONSTRAINT uq_fee_bucket_debits_source\n    UNIQUE (bucket, debit_type, source_id),\n\n  CONSTRAINT ck_fee_bucket_debits_bucket\n    CHECK (bucket IN ('referral', 'promotions', 'profit')),\n\n  CONSTRAINT ck_fee_bucket_debits_status\n    CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n\n  CONSTRAINT ck_fee_bucket_debits_amount_non_negative\n    CHECK (amount_lamports >= 0)\n);\n\nCREATE INDEX idx_fee_bucket_debits_bucket_status\n  ON fee_bucket_debits (bucket, status);\n\nCREATE INDEX idx_fee_bucket_debits_created_at\n  ON fee_bucket_debits (created_at);\n\nCREATE INDEX idx_fee_bucket_debits_user\n  ON fee_bucket_debits (user_id, bucket, status)\n  WHERE user_id IS NOT NULL;\n\nCREATE TABLE fee_audit_checkpoints (\n  id                          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  period_start                TIMESTAMPTZ  NOT NULL,\n  period_end                  TIMESTAMPTZ  NOT NULL,\n  allocation_row_count        BIGINT       NOT NULL,\n  debit_row_count             BIGINT       NOT NULL,\n  fee_lamports_total          BIGINT       NOT NULL,\n  referral_allocated          BIGINT       NOT NULL,\n  promotions_allocated        BIGINT       NOT NULL,\n  profit_allocated            BIGINT       NOT NULL,\n  referral_ending_balance     BIGINT       NOT NULL,\n  promotions_ending_balance   BIGINT       NOT NULL,\n  profit_ending_balance       BIGINT       NOT NULL,\n  previous_checkpoint_hash    TEXT,\n  source_hash                 TEXT         NOT NULL,\n  created_at                  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n\n  CONSTRAINT uq_fee_audit_checkpoints_period_end\n    UNIQUE (period_end),\n\n  CONSTRAINT ck_fee_audit_checkpoints_period_order\n    CHECK (period_end > period_start),\n\n  CONSTRAINT ck_fee_audit_checkpoints_counts_non_negative\n    CHECK (\n      allocation_row_count >= 0\n      AND debit_row_count >= 0\n      AND fee_lamports_total >= 0\n      AND referral_allocated >= 0\n      AND promotions_allocated >= 0\n      AND profit_allocated >= 0\n    )\n);\n\nCREATE INDEX idx_fee_audit_checkpoints_period_end\n  ON fee_audit_checkpoints (period_end DESC);\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2543,"cache_read_input_tokens":65627,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2543},"output_tokens":53,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"a9387aeb-1158-4488-9f6a-135920c2e04b","uuid":"2c11282d-2c01-4c9e-bcbe-595b31106e16"}
