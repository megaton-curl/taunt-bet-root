{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MKd71i4sZRAuAFuodNLfFZ","type":"tool_result","content":"1\t-- 018_reward_economy.sql — Generic reward economy: seasons, point rates,\n2\t-- multiplier ladders/modifiers, generic events, and season-scoped balances.\n3\t\n4\t-- Seasons: exactly one active season is enforced by a partial unique index.\n5\tCREATE TABLE seasons (\n6\t  id          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n7\t  slug        TEXT NOT NULL UNIQUE,\n8\t  name        TEXT NOT NULL,\n9\t  starts_at   TIMESTAMPTZ NOT NULL,\n10\t  ends_at     TIMESTAMPTZ,\n11\t  status      TEXT NOT NULL CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n12\t  created_at  TIMESTAMPTZ NOT NULL DEFAULT now(),\n13\t  updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()\n14\t);\n15\t\n16\tCREATE UNIQUE INDEX idx_seasons_one_active ON seasons ((status)) WHERE status = 'active';\n17\tCREATE INDEX idx_seasons_status_starts ON seasons (status, starts_at);\n18\t\n19\tINSERT INTO seasons (slug, name, starts_at, status)\n20\tVALUES ('season-1', 'Season 1', '2026-01-01T00:00:00Z', 'active');\n21\t\n22\t-- Versioned point issuance rates.\n23\tCREATE TABLE point_rate_versions (\n24\t  id             BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n25\t  rate_per_usd   NUMERIC(18,6) NOT NULL,\n26\t  effective_from TIMESTAMPTZ NOT NULL,\n27\t  label          TEXT,\n28\t  created_by     TEXT,\n29\t  created_at     TIMESTAMPTZ NOT NULL DEFAULT now()\n30\t);\n31\t\n32\tCREATE INDEX idx_point_rate_versions_effective\n33\t  ON point_rate_versions (effective_from DESC);\n34\t\n35\tINSERT INTO point_rate_versions (rate_per_usd, effective_from, label)\n36\tVALUES (100, '2026-01-01T00:00:00Z', 'Launch default');\n37\t\n38\t-- Season-scoped point balances.\n39\tCREATE TABLE point_balances (\n40\t  user_id       TEXT NOT NULL,\n41\t  season_id     BIGINT NOT NULL REFERENCES seasons(id),\n42\t  wallet        TEXT NOT NULL,\n43\t  balance       BIGINT NOT NULL DEFAULT 0,\n44\t  season_earned BIGINT NOT NULL DEFAULT 0,\n45\t  updated_at    TIMESTAMPTZ NOT NULL DEFAULT now(),\n46\t  PRIMARY KEY (user_id, season_id)\n47\t);\n48\t\n49\tCREATE INDEX idx_point_balances_season_balance\n50\t  ON point_balances (season_id, balance DESC);\n51\t\n52\t-- Generic multiplier ladders.\n53\tCREATE TABLE multiplier_ladders (\n54\t  id             BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n55\t  scope          TEXT NOT NULL CHECK (scope IN ('lifetime', 'season')),\n56\t  metric         TEXT NOT NULL CHECK (metric IN ('wagered_usd')),\n57\t  season_id      BIGINT REFERENCES seasons(id),\n58\t  effective_from TIMESTAMPTZ NOT NULL,\n59\t  label          TEXT,\n60\t  created_by     TEXT,\n61\t  created_at     TIMESTAMPTZ NOT NULL DEFAULT now()\n62\t);\n63\t\n64\tCREATE INDEX idx_multiplier_ladders_lookup\n65\t  ON multiplier_ladders (scope, season_id, effective_from DESC);\n66\t\n67\tCREATE TABLE multiplier_ladder_steps (\n68\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n69\t  ladder_id        BIGINT NOT NULL REFERENCES multiplier_ladders(id) ON DELETE CASCADE,\n70\t  level            INT NOT NULL,\n71\t  threshold_usd    NUMERIC(20,6) NOT NULL,\n72\t  multiplier       NUMERIC(12,6) NOT NULL,\n73\t  sort_order       INT NOT NULL DEFAULT 0,\n74\t  UNIQUE (ladder_id, threshold_usd),\n75\t  UNIQUE (ladder_id, level)\n76\t);\n77\t\n78\tWITH lifetime_ladder AS (\n79\t  INSERT INTO multiplier_ladders (scope, metric, effective_from, label)\n80\t  VALUES ('lifetime', 'wagered_usd', '2026-01-01T00:00:00Z', 'Launch lifetime ladder')\n81\t  RETURNING id\n82\t)\n83\tINSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n84\tSELECT id, level, threshold_usd, multiplier, level\n85\tFROM lifetime_ladder\n86\tCROSS JOIN (VALUES\n87\t  (1, 1000, 1.10),\n88\t  (2, 10000, 1.20),\n89\t  (3, 50000, 1.30),\n90\t  (4, 100000, 1.40),\n91\t  (5, 250000, 1.50),\n92\t  (6, 500000, 1.60),\n93\t  (7, 1000000, 1.70),\n94\t  (8, 2500000, 1.80),\n95\t  (9, 5000000, 1.90),\n96\t  (10, 10000000, 2.00)\n97\t) AS steps(level, threshold_usd, multiplier);\n98\t\n99\tWITH active_season AS (\n100\t  SELECT id FROM seasons WHERE status = 'active' LIMIT 1\n101\t),\n102\tseason_ladder AS (\n103\t  INSERT INTO multiplier_ladders (scope, metric, season_id, effective_from, label)\n104\t  SELECT 'season', 'wagered_usd', id, '2026-01-01T00:00:00Z', 'Launch season ladder'\n105\t  FROM active_season\n106\t  RETURNING id\n107\t)\n108\tINSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n109\tSELECT id, level, threshold_usd, multiplier, level\n110\tFROM season_ladder\n111\tCROSS JOIN (VALUES\n112\t  (1, 500, 1.20),\n113\t  (2, 5000, 1.50),\n114\t  (3, 25000, 2.00),\n115\t  (4, 100000, 2.50),\n116\t  (5, 250000, 3.00)\n117\t) AS steps(level, threshold_usd, multiplier);\n118\t\n119\t-- Generic scheduled economy events.\n120\tCREATE TABLE events (\n121\t  id            BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n122\t  season_id     BIGINT REFERENCES seasons(id),\n123\t  event_type    TEXT NOT NULL DEFAULT 'generic',\n124\t  display_name  TEXT NOT NULL,\n125\t  starts_at     TIMESTAMPTZ NOT NULL,\n126\t  ends_at       TIMESTAMPTZ NOT NULL,\n127\t  status        TEXT NOT NULL DEFAULT 'scheduled'\n128\t    CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n129\t  config        JSONB NOT NULL DEFAULT '{}',\n130\t  created_by    TEXT,\n131\t  created_at    TIMESTAMPTZ NOT NULL DEFAULT now(),\n132\t  updated_at    TIMESTAMPTZ NOT NULL DEFAULT now()\n133\t);\n134\t\n135\tCREATE INDEX idx_events_active\n136\t  ON events (status, starts_at, ends_at)\n137\t  WHERE status IN ('scheduled', 'active');\n138\t\n139\tCREATE TABLE multiplier_modifiers (\n140\t  id            BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n141\t  user_id       TEXT,\n142\t  season_id     BIGINT REFERENCES seasons(id),\n143\t  source_type   TEXT NOT NULL CHECK (source_type IN ('event', 'admin', 'reward')),\n144\t  source_id     TEXT NOT NULL,\n145\t  mode          TEXT NOT NULL DEFAULT 'set_value'\n146\t    CHECK (mode IN ('multiply', 'set_min', 'set_value')),\n147\t  value         NUMERIC(12,6) NOT NULL,\n148\t  priority      INT NOT NULL DEFAULT 0,\n149\t  starts_at     TIMESTAMPTZ NOT NULL DEFAULT now(),\n150\t  ends_at       TIMESTAMPTZ,\n151\t  created_by    TEXT,\n152\t  created_at    TIMESTAMPTZ NOT NULL DEFAULT now()\n153\t);\n154\t\n155\tCREATE INDEX idx_multiplier_modifiers_active\n156\t  ON multiplier_modifiers (season_id, user_id, starts_at, ends_at);\n157\t\n158\t-- Point grant ledger becomes season/rate/multiplier-attributed.\n159\tALTER TABLE point_grants\n160\t  DROP CONSTRAINT IF EXISTS point_grants_source_type_check;\n161\t\n162\tALTER TABLE point_grants\n163\t  ADD CONSTRAINT point_grants_source_type_check\n164\t  CHECK (source_type IN ('wager', 'challenge_completed', 'bonus_completed', 'crate_points', 'admin_adjustment', 'reward', 'migration_adjustment'));\n165\t\n166\tALTER TABLE point_grants\n167\t  ADD COLUMN season_id BIGINT REFERENCES seasons(id),\n168\t  ADD COLUMN effective_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0,\n169\t  ADD COLUMN point_rate_version_id BIGINT REFERENCES point_rate_versions(id);\n170\t\n171\tUPDATE point_grants\n172\tSET season_id = (SELECT id FROM seasons WHERE status = 'active' LIMIT 1)\n173\tWHERE season_id IS NULL;\n174\t\n175\tALTER TABLE point_grants ALTER COLUMN season_id SET NOT NULL;\n176\t\n177\tCREATE INDEX idx_point_grants_user_season_created\n178\t  ON point_grants (user_id, season_id, created_at DESC);\n179\t\n180\t-- Hard cutoff: discard pre-season aggregate/event tables instead of carrying\n181\t-- compatibility rows into the generic reward economy.\n182\tDROP TABLE IF EXISTS player_points;\n183\tDROP TABLE IF EXISTS dogpile_events;\n184\t\n185\t-- Campaign/challenge vocabulary cleanup.\n186\tALTER TABLE campaigns DROP CONSTRAINT IF EXISTS campaigns_campaign_type_check;\n187\tDELETE FROM challenges WHERE action = 'dogpile_game';\n188\tDELETE FROM completion_bonuses\n189\tWHERE campaign_id IN (SELECT id FROM campaigns WHERE campaign_type = 'dogpile');\n190\tDELETE FROM campaigns WHERE campaign_type = 'dogpile';\n191\tALTER TABLE campaigns\n192\t  ADD CONSTRAINT campaigns_campaign_type_check\n193\t  CHECK (campaign_type IN ('daily', 'weekly', 'onboarding', 'event'));\n194\t\n195\t-- Point issuance moved to point_rate_versions.\n196\tDELETE FROM reward_config WHERE key IN ('points_per_dollar', 'dogpile_default_multiplier');\n197\t"}]},"parent_tool_use_id":null,"session_id":"a9387aeb-1158-4488-9f6a-135920c2e04b","uuid":"3c18a2e4-1fb9-4b50-9433-f9331f0c05f7","timestamp":"2026-05-01T19:32:39.207Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/018_reward_economy.sql","content":"-- 018_reward_economy.sql — Generic reward economy: seasons, point rates,\n-- multiplier ladders/modifiers, generic events, and season-scoped balances.\n\n-- Seasons: exactly one active season is enforced by a partial unique index.\nCREATE TABLE seasons (\n  id          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  slug        TEXT NOT NULL UNIQUE,\n  name        TEXT NOT NULL,\n  starts_at   TIMESTAMPTZ NOT NULL,\n  ends_at     TIMESTAMPTZ,\n  status      TEXT NOT NULL CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n  created_at  TIMESTAMPTZ NOT NULL DEFAULT now(),\n  updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\nCREATE UNIQUE INDEX idx_seasons_one_active ON seasons ((status)) WHERE status = 'active';\nCREATE INDEX idx_seasons_status_starts ON seasons (status, starts_at);\n\nINSERT INTO seasons (slug, name, starts_at, status)\nVALUES ('season-1', 'Season 1', '2026-01-01T00:00:00Z', 'active');\n\n-- Versioned point issuance rates.\nCREATE TABLE point_rate_versions (\n  id             BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  rate_per_usd   NUMERIC(18,6) NOT NULL,\n  effective_from TIMESTAMPTZ NOT NULL,\n  label          TEXT,\n  created_by     TEXT,\n  created_at     TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\nCREATE INDEX idx_point_rate_versions_effective\n  ON point_rate_versions (effective_from DESC);\n\nINSERT INTO point_rate_versions (rate_per_usd, effective_from, label)\nVALUES (100, '2026-01-01T00:00:00Z', 'Launch default');\n\n-- Season-scoped point balances.\nCREATE TABLE point_balances (\n  user_id       TEXT NOT NULL,\n  season_id     BIGINT NOT NULL REFERENCES seasons(id),\n  wallet        TEXT NOT NULL,\n  balance       BIGINT NOT NULL DEFAULT 0,\n  season_earned BIGINT NOT NULL DEFAULT 0,\n  updated_at    TIMESTAMPTZ NOT NULL DEFAULT now(),\n  PRIMARY KEY (user_id, season_id)\n);\n\nCREATE INDEX idx_point_balances_season_balance\n  ON point_balances (season_id, balance DESC);\n\n-- Generic multiplier ladders.\nCREATE TABLE multiplier_ladders (\n  id             BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  scope          TEXT NOT NULL CHECK (scope IN ('lifetime', 'season')),\n  metric         TEXT NOT NULL CHECK (metric IN ('wagered_usd')),\n  season_id      BIGINT REFERENCES seasons(id),\n  effective_from TIMESTAMPTZ NOT NULL,\n  label          TEXT,\n  created_by     TEXT,\n  created_at     TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\nCREATE INDEX idx_multiplier_ladders_lookup\n  ON multiplier_ladders (scope, season_id, effective_from DESC);\n\nCREATE TABLE multiplier_ladder_steps (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  ladder_id        BIGINT NOT NULL REFERENCES multiplier_ladders(id) ON DELETE CASCADE,\n  level            INT NOT NULL,\n  threshold_usd    NUMERIC(20,6) NOT NULL,\n  multiplier       NUMERIC(12,6) NOT NULL,\n  sort_order       INT NOT NULL DEFAULT 0,\n  UNIQUE (ladder_id, threshold_usd),\n  UNIQUE (ladder_id, level)\n);\n\nWITH lifetime_ladder AS (\n  INSERT INTO multiplier_ladders (scope, metric, effective_from, label)\n  VALUES ('lifetime', 'wagered_usd', '2026-01-01T00:00:00Z', 'Launch lifetime ladder')\n  RETURNING id\n)\nINSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\nSELECT id, level, threshold_usd, multiplier, level\nFROM lifetime_ladder\nCROSS JOIN (VALUES\n  (1, 1000, 1.10),\n  (2, 10000, 1.20),\n  (3, 50000, 1.30),\n  (4, 100000, 1.40),\n  (5, 250000, 1.50),\n  (6, 500000, 1.60),\n  (7, 1000000, 1.70),\n  (8, 2500000, 1.80),\n  (9, 5000000, 1.90),\n  (10, 10000000, 2.00)\n) AS steps(level, threshold_usd, multiplier);\n\nWITH active_season AS (\n  SELECT id FROM seasons WHERE status = 'active' LIMIT 1\n),\nseason_ladder AS (\n  INSERT INTO multiplier_ladders (scope, metric, season_id, effective_from, label)\n  SELECT 'season', 'wagered_usd', id, '2026-01-01T00:00:00Z', 'Launch season ladder'\n  FROM active_season\n  RETURNING id\n)\nINSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\nSELECT id, level, threshold_usd, multiplier, level\nFROM season_ladder\nCROSS JOIN (VALUES\n  (1, 500, 1.20),\n  (2, 5000, 1.50),\n  (3, 25000, 2.00),\n  (4, 100000, 2.50),\n  (5, 250000, 3.00)\n) AS steps(level, threshold_usd, multiplier);\n\n-- Generic scheduled economy events.\nCREATE TABLE events (\n  id            BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  season_id     BIGINT REFERENCES seasons(id),\n  event_type    TEXT NOT NULL DEFAULT 'generic',\n  display_name  TEXT NOT NULL,\n  starts_at     TIMESTAMPTZ NOT NULL,\n  ends_at       TIMESTAMPTZ NOT NULL,\n  status        TEXT NOT NULL DEFAULT 'scheduled'\n    CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n  config        JSONB NOT NULL DEFAULT '{}',\n  created_by    TEXT,\n  created_at    TIMESTAMPTZ NOT NULL DEFAULT now(),\n  updated_at    TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\nCREATE INDEX idx_events_active\n  ON events (status, starts_at, ends_at)\n  WHERE status IN ('scheduled', 'active');\n\nCREATE TABLE multiplier_modifiers (\n  id            BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id       TEXT,\n  season_id     BIGINT REFERENCES seasons(id),\n  source_type   TEXT NOT NULL CHECK (source_type IN ('event', 'admin', 'reward')),\n  source_id     TEXT NOT NULL,\n  mode          TEXT NOT NULL DEFAULT 'set_value'\n    CHECK (mode IN ('multiply', 'set_min', 'set_value')),\n  value         NUMERIC(12,6) NOT NULL,\n  priority      INT NOT NULL DEFAULT 0,\n  starts_at     TIMESTAMPTZ NOT NULL DEFAULT now(),\n  ends_at       TIMESTAMPTZ,\n  created_by    TEXT,\n  created_at    TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\nCREATE INDEX idx_multiplier_modifiers_active\n  ON multiplier_modifiers (season_id, user_id, starts_at, ends_at);\n\n-- Point grant ledger becomes season/rate/multiplier-attributed.\nALTER TABLE point_grants\n  DROP CONSTRAINT IF EXISTS point_grants_source_type_check;\n\nALTER TABLE point_grants\n  ADD CONSTRAINT point_grants_source_type_check\n  CHECK (source_type IN ('wager', 'challenge_completed', 'bonus_completed', 'crate_points', 'admin_adjustment', 'reward', 'migration_adjustment'));\n\nALTER TABLE point_grants\n  ADD COLUMN season_id BIGINT REFERENCES seasons(id),\n  ADD COLUMN effective_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0,\n  ADD COLUMN point_rate_version_id BIGINT REFERENCES point_rate_versions(id);\n\nUPDATE point_grants\nSET season_id = (SELECT id FROM seasons WHERE status = 'active' LIMIT 1)\nWHERE season_id IS NULL;\n\nALTER TABLE point_grants ALTER COLUMN season_id SET NOT NULL;\n\nCREATE INDEX idx_point_grants_user_season_created\n  ON point_grants (user_id, season_id, created_at DESC);\n\n-- Hard cutoff: discard pre-season aggregate/event tables instead of carrying\n-- compatibility rows into the generic reward economy.\nDROP TABLE IF EXISTS player_points;\nDROP TABLE IF EXISTS dogpile_events;\n\n-- Campaign/challenge vocabulary cleanup.\nALTER TABLE campaigns DROP CONSTRAINT IF EXISTS campaigns_campaign_type_check;\nDELETE FROM challenges WHERE action = 'dogpile_game';\nDELETE FROM completion_bonuses\nWHERE campaign_id IN (SELECT id FROM campaigns WHERE campaign_type = 'dogpile');\nDELETE FROM campaigns WHERE campaign_type = 'dogpile';\nALTER TABLE campaigns\n  ADD CONSTRAINT campaigns_campaign_type_check\n  CHECK (campaign_type IN ('daily', 'weekly', 'onboarding', 'event'));\n\n-- Point issuance moved to point_rate_versions.\nDELETE FROM reward_config WHERE key IN ('points_per_dollar', 'dogpile_default_multiplier');\n","numLines":197,"startLine":1,"totalLines":197}}}
