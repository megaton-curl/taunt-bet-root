{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C14DrYRHGs2Tihw7KoPXVq","type":"tool_result","content":"1\t-- 026_fee_accounting_audit.sql — Durable accounting trail for platform fees.\n2\t--\n3\t-- Three ledgers and one acceleration table:\n4\t--   * fee_allocation_events  — one row per (settlement source, player) splitting\n5\t--                              the fee into referral / promotions / profit\n6\t--                              virtual buckets. Immutable.\n7\t--   * fee_bucket_debits      — bucket spends (e.g. referral claims). Status is\n8\t--                              kept in lockstep with the originating record.\n9\t--   * fee_audit_checkpoints  — bounded-window acceleration snapshots so routine\n10\t--                              audits do not need to re-scan the full ledger.\n11\t\n12\tCREATE TABLE fee_allocation_events (\n13\t  id                    BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n14\t  source_type           TEXT         NOT NULL,\n15\t  source_id             TEXT         NOT NULL,\n16\t  game_type             TEXT         NOT NULL,\n17\t  wallet                TEXT         NOT NULL,\n18\t  user_id               TEXT,\n19\t  wager_lamports        BIGINT       NOT NULL,\n20\t  fee_lamports          BIGINT       NOT NULL,\n21\t  referrer_user_id      TEXT,\n22\t  referral_rate_bps     INTEGER      NOT NULL DEFAULT 0,\n23\t  referral_lamports     BIGINT       NOT NULL DEFAULT 0,\n24\t  promotions_lamports   BIGINT       NOT NULL DEFAULT 0,\n25\t  profit_lamports       BIGINT       NOT NULL DEFAULT 0,\n26\t  created_at            TIMESTAMPTZ  NOT NULL DEFAULT now(),\n27\t\n28\t  CONSTRAINT uq_fee_allocation_source_wallet\n29\t    UNIQUE (source_type, source_id, wallet),\n30\t\n31\t  CONSTRAINT ck_fee_allocation_components_sum\n32\t    CHECK (referral_lamports + promotions_lamports + profit_lamports = fee_lamports),\n33\t\n34\t  CONSTRAINT ck_fee_allocation_rate_bps_range\n35\t    CHECK (referral_rate_bps BETWEEN 0 AND 10000),\n36\t\n37\t  CONSTRAINT ck_fee_allocation_amounts_non_negative\n38\t    CHECK (\n39\t      wager_lamports >= 0\n40\t      AND fee_lamports >= 0\n41\t      AND referral_lamports >= 0\n42\t      AND promotions_lamports >= 0\n43\t      AND profit_lamports >= 0\n44\t    )\n45\t);\n46\t\n47\tCREATE INDEX idx_fee_allocation_events_created_at\n48\t  ON fee_allocation_events (created_at);\n49\t\n50\tCREATE INDEX idx_fee_allocation_events_referrer\n51\t  ON fee_allocation_events (referrer_user_id, created_at)\n52\t  WHERE referrer_user_id IS NOT NULL;\n53\t\n54\tCREATE INDEX idx_fee_allocation_events_user\n55\t  ON fee_allocation_events (user_id, created_at)\n56\t  WHERE user_id IS NOT NULL;\n57\t\n58\tCREATE TABLE fee_bucket_debits (\n59\t  id                BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n60\t  bucket            TEXT         NOT NULL,\n61\t  debit_type        TEXT         NOT NULL,\n62\t  source_id         TEXT         NOT NULL,\n63\t  user_id           TEXT,\n64\t  wallet            TEXT,\n65\t  amount_lamports   BIGINT       NOT NULL,\n66\t  status            TEXT         NOT NULL DEFAULT 'pending',\n67\t  created_at        TIMESTAMPTZ  NOT NULL DEFAULT now(),\n68\t  updated_at        TIMESTAMPTZ  NOT NULL DEFAULT now(),\n69\t\n70\t  CONSTRAINT uq_fee_bucket_debits_source\n71\t    UNIQUE (bucket, debit_type, source_id),\n72\t\n73\t  CONSTRAINT ck_fee_bucket_debits_bucket\n74\t    CHECK (bucket IN ('referral', 'promotions', 'profit')),\n75\t\n76\t  CONSTRAINT ck_fee_bucket_debits_status\n77\t    CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n78\t\n79\t  CONSTRAINT ck_fee_bucket_debits_amount_non_negative\n80\t    CHECK (amount_lamports >= 0)\n81\t);\n82\t\n83\tCREATE INDEX idx_fee_bucket_debits_bucket_status\n84\t  ON fee_bucket_debits (bucket, status);\n85\t\n86\tCREATE INDEX idx_fee_bucket_debits_created_at\n87\t  ON fee_bucket_debits (created_at);\n88\t\n89\tCREATE INDEX idx_fee_bucket_debits_user\n90\t  ON fee_bucket_debits (user_id, bucket, status)\n91\t  WHERE user_id IS NOT NULL;\n92\t\n93\tCREATE TABLE fee_audit_checkpoints (\n94\t  id                          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n95\t  period_start                TIMESTAMPTZ  NOT NULL,\n96\t  period_end                  TIMESTAMPTZ  NOT NULL,\n97\t  allocation_row_count        BIGINT       NOT NULL,\n98\t  debit_row_count             BIGINT       NOT NULL,\n99\t  fee_lamports_total          BIGINT       NOT NULL,\n100\t  referral_allocated          BIGINT       NOT NULL,\n101\t  promotions_allocated        BIGINT       NOT NULL,\n102\t  profit_allocated            BIGINT       NOT NULL,\n103\t  referral_ending_balance     BIGINT       NOT NULL,\n104\t  promotions_ending_balance   BIGINT       NOT NULL,\n105\t  profit_ending_balance       BIGINT       NOT NULL,\n106\t  previous_checkpoint_hash    TEXT,\n107\t  source_hash                 TEXT         NOT NULL,\n108\t  created_at                  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n109\t\n110\t  CONSTRAINT uq_fee_audit_checkpoints_period_end\n111\t    UNIQUE (period_end),\n112\t\n113\t  CONSTRAINT ck_fee_audit_checkpoints_period_order\n114\t    CHECK (period_end > period_start),\n115\t\n116\t  CONSTRAINT ck_fee_audit_checkpoints_counts_non_negative\n117\t    CHECK (\n118\t      allocation_row_count >= 0\n119\t      AND debit_row_count >= 0\n120\t      AND fee_lamports_total >= 0\n121\t      AND referral_allocated >= 0\n122\t      AND promotions_allocated >= 0\n123\t      AND profit_allocated >= 0\n124\t    )\n125\t);\n126\t\n127\tCREATE INDEX idx_fee_audit_checkpoints_period_end\n128\t  ON fee_audit_checkpoints (period_end DESC);\n129\t"}]},"parent_tool_use_id":null,"session_id":"0593b00d-aabc-4ab9-a640-568a57e4b2f3","uuid":"6007707d-46c6-4ea5-be97-1e08c6dc1949","timestamp":"2026-05-01T19:36:53.521Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/026_fee_accounting_audit.sql","content":"-- 026_fee_accounting_audit.sql — Durable accounting trail for platform fees.\n--\n-- Three ledgers and one acceleration table:\n--   * fee_allocation_events  — one row per (settlement source, player) splitting\n--                              the fee into referral / promotions / profit\n--                              virtual buckets. Immutable.\n--   * fee_bucket_debits      — bucket spends (e.g. referral claims). Status is\n--                              kept in lockstep with the originating record.\n--   * fee_audit_checkpoints  — bounded-window acceleration snapshots so routine\n--                              audits do not need to re-scan the full ledger.\n\nCREATE TABLE fee_allocation_events (\n  id                    BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  source_type           TEXT         NOT NULL,\n  source_id             TEXT         NOT NULL,\n  game_type             TEXT         NOT NULL,\n  wallet                TEXT         NOT NULL,\n  user_id               TEXT,\n  wager_lamports        BIGINT       NOT NULL,\n  fee_lamports          BIGINT       NOT NULL,\n  referrer_user_id      TEXT,\n  referral_rate_bps     INTEGER      NOT NULL DEFAULT 0,\n  referral_lamports     BIGINT       NOT NULL DEFAULT 0,\n  promotions_lamports   BIGINT       NOT NULL DEFAULT 0,\n  profit_lamports       BIGINT       NOT NULL DEFAULT 0,\n  created_at            TIMESTAMPTZ  NOT NULL DEFAULT now(),\n\n  CONSTRAINT uq_fee_allocation_source_wallet\n    UNIQUE (source_type, source_id, wallet),\n\n  CONSTRAINT ck_fee_allocation_components_sum\n    CHECK (referral_lamports + promotions_lamports + profit_lamports = fee_lamports),\n\n  CONSTRAINT ck_fee_allocation_rate_bps_range\n    CHECK (referral_rate_bps BETWEEN 0 AND 10000),\n\n  CONSTRAINT ck_fee_allocation_amounts_non_negative\n    CHECK (\n      wager_lamports >= 0\n      AND fee_lamports >= 0\n      AND referral_lamports >= 0\n      AND promotions_lamports >= 0\n      AND profit_lamports >= 0\n    )\n);\n\nCREATE INDEX idx_fee_allocation_events_created_at\n  ON fee_allocation_events (created_at);\n\nCREATE INDEX idx_fee_allocation_events_referrer\n  ON fee_allocation_events (referrer_user_id, created_at)\n  WHERE referrer_user_id IS NOT NULL;\n\nCREATE INDEX idx_fee_allocation_events_user\n  ON fee_allocation_events (user_id, created_at)\n  WHERE user_id IS NOT NULL;\n\nCREATE TABLE fee_bucket_debits (\n  id                BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  bucket            TEXT         NOT NULL,\n  debit_type        TEXT         NOT NULL,\n  source_id         TEXT         NOT NULL,\n  user_id           TEXT,\n  wallet            TEXT,\n  amount_lamports   BIGINT       NOT NULL,\n  status            TEXT         NOT NULL DEFAULT 'pending',\n  created_at        TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  updated_at        TIMESTAMPTZ  NOT NULL DEFAULT now(),\n\n  CONSTRAINT uq_fee_bucket_debits_source\n    UNIQUE (bucket, debit_type, source_id),\n\n  CONSTRAINT ck_fee_bucket_debits_bucket\n    CHECK (bucket IN ('referral', 'promotions', 'profit')),\n\n  CONSTRAINT ck_fee_bucket_debits_status\n    CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n\n  CONSTRAINT ck_fee_bucket_debits_amount_non_negative\n    CHECK (amount_lamports >= 0)\n);\n\nCREATE INDEX idx_fee_bucket_debits_bucket_status\n  ON fee_bucket_debits (bucket, status);\n\nCREATE INDEX idx_fee_bucket_debits_created_at\n  ON fee_bucket_debits (created_at);\n\nCREATE INDEX idx_fee_bucket_debits_user\n  ON fee_bucket_debits (user_id, bucket, status)\n  WHERE user_id IS NOT NULL;\n\nCREATE TABLE fee_audit_checkpoints (\n  id                          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  period_start                TIMESTAMPTZ  NOT NULL,\n  period_end                  TIMESTAMPTZ  NOT NULL,\n  allocation_row_count        BIGINT       NOT NULL,\n  debit_row_count             BIGINT       NOT NULL,\n  fee_lamports_total          BIGINT       NOT NULL,\n  referral_allocated          BIGINT       NOT NULL,\n  promotions_allocated        BIGINT       NOT NULL,\n  profit_allocated            BIGINT       NOT NULL,\n  referral_ending_balance     BIGINT       NOT NULL,\n  promotions_ending_balance   BIGINT       NOT NULL,\n  profit_ending_balance       BIGINT       NOT NULL,\n  previous_checkpoint_hash    TEXT,\n  source_hash                 TEXT         NOT NULL,\n  created_at                  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n\n  CONSTRAINT uq_fee_audit_checkpoints_period_end\n    UNIQUE (period_end),\n\n  CONSTRAINT ck_fee_audit_checkpoints_period_order\n    CHECK (period_end > period_start),\n\n  CONSTRAINT ck_fee_audit_checkpoints_counts_non_negative\n    CHECK (\n      allocation_row_count >= 0\n      AND debit_row_count >= 0\n      AND fee_lamports_total >= 0\n      AND referral_allocated >= 0\n      AND promotions_allocated >= 0\n      AND profit_allocated >= 0\n    )\n);\n\nCREATE INDEX idx_fee_audit_checkpoints_period_end\n  ON fee_audit_checkpoints (period_end DESC);\n","numLines":129,"startLine":1,"totalLines":129}}}
