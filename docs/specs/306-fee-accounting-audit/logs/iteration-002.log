rofilesDb } from \"./db/profiles.js\";\nexport type { CloseCallPhase, CloseCallOutcome, CloseCallRound, InsertCloseCallRoundParams, CloseCallDb } from \"./db/closecall.js\";\nexport type { CloseCallCandle, CloseCallCandlesDb } from \"./db/closecall-candles.js\";\nexport type { TransactionType, Transaction, InsertTransactionParams, TransactionsDb } from \"./db/transactions.js\";\nexport type { GameEntryUpsert, GameEntryInsert, GameEntry, GameEntriesDb } from \"./db/game-entries.js\";\nexport type { RoundPhase, Round, InsertRoundParams, OperatorEventType, OperatorEvent, RoundsDb } from \"./db/rounds.js\";\nexport type { PlayerStats, PublicPlayerStats, WinStreaks, GameBreakdownStats, LeaderboardEntry, LeaderboardResult, StatsDb } from \"./db/stats.js\";\nexport type { TelegramLinkStatus, TelegramLinkToken, TelegramLinksDb } from \"./db/telegram-links.js\";\nexport type {\n  LinkedAccountStatus,\n  LinkedAccountProvider,\n  LinkedAccount,\n  LinkedAccountsDb,\n} from \"./db/linked-accounts.js\";\nexport type {\n  FeeBucket,\n  FeeBucketDebitStatus,\n  FeeAllocation,\n  InsertFeeAllocationParams,\n  InsertFeeBucketDebitParams,\n  FeeAllocationEventRow,\n  FeeBucketDebitRow,\n  FeeAuditBucketSummary,\n  FeeAuditSnapshot,\n  FeeAccountingDb,\n} from \"./db/fee-accounting.js\";\nexport { calculateFeeAllocation } from \"./db/fee-accounting.js\";\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db\n  extends ReferralsDb,\n    ProfilesDb,\n    CloseCallDb,\n    CloseCallCandlesDb,\n    TransactionsDb,\n    GameEntriesDb,\n    RoundsDb,\n    StatsDb,\n    TelegramLinksDb,\n    LinkedAccountsDb,\n    FeeAccountingDb {\n  /**\n   * Execute a function within a database transaction.\n   * All db methods called on the transactional Db share the same transaction.\n   * Rolls back on error, commits on success.\n   */\n  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n\n  /** Expose the underlying SQL/transaction handle for use with emitEvent(). */\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  readonly rawSql: any;\n\n  /** Gracefully close the connection pool. */\n  close(): Promise<void>;\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nexport function createDb(databaseUrl: string, _txSql?: any): Db {\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const sql: any = _txSql ?? postgres(databaseUrl);\n  const _isOwner = !_txSql;\n\n  return {\n    rawSql: sql,\n\n    ...createRoundsDb(sql),\n\n    ...createCloseCallDb(sql),\n\n    ...createGameEntriesDb(sql),\n\n    ...createCloseCallCandlesDb(sql),\n\n    ...createTransactionsDb(sql),\n\n    ...createReferralsDb(sql),\n\n    ...createProfilesDb(sql),\n\n    ...createStatsDb(sql),\n\n    ...createTelegramLinksDb(sql),\n\n    ...createLinkedAccountsDb(sql),\n\n    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n    },\n\n    async close() {\n      if (_isOwner) await sql.end();\n    },\n  };\n}\n","structuredPatch":[{"oldStart":105,"oldLines":6,"newStart":105,"newLines":8,"lines":[" ","     ...createLinkedAccountsDb(sql),"," ","+    ...createFeeAccountingDb(sql),","+","     async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {","       // eslint-disable-next-line @typescript-eslint/no-explicit-any","       return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));"]}],"userModified":false,"replaceAll":false}}
