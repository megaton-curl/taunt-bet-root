interface ReferralsDb {\n67\t  // -------------------------------------------------------------------------\n68\t  // Referral — codes\n69\t  // -------------------------------------------------------------------------\n70\t\n71\t  /** Insert a new referral code for a user. Throws on duplicate user, wallet, or code. */\n72\t  insertReferralCode(\n73\t    userId: string,\n74\t    wallet: string,\n75\t    code: string,\n76\t  ): Promise<ReferralCode>;\n77\t\n78\t  /** Get a user's referral code. Returns `undefined` if none set. */\n79\t  getReferralCodeByUserId(userId: string): Promise<ReferralCode | undefined>;\n80\t\n81\t  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n82\t  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n83\t\n84\t  // -------------------------------------------------------------------------\n85\t  // Referral — links\n86\t  // -------------------------------------------------------------------------\n87\t\n88\t  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n89\t  insertReferralLink(params: {\n90\t    referrerUserId: string;\n91\t    refereeUserId: string;\n92\t    referrerWallet: string;\n93\t    refereeWallet: string;\n94\t  }): Promise<ReferralLink>;\n95\t\n96\t  /** Get the referral link for a referee user. Returns `undefined` if not referred. */\n97\t  getReferralLinkByRefereeUserId(\n98\t    refereeUserId: string,\n99\t  ): Promise<ReferralLink | undefined>;\n100\t\n101\t  /** Get all referral links where the given user is the referrer. */\n102\t  getReferralLinksByReferrerUserId(referrerUserId: string): Promise<ReferralLink[]>;\n103\t\n104\t  // -------------------------------------------------------------------------\n105\t  // Referral — earnings & stats\n106\t  // -------------------------------------------------------------------------\n107\t\n108\t  /** Insert a referral earning row. Throws on duplicate (referee_user_id, round_id). */\n109\t  insertReferralEarning(params: {\n110\t    referrerUserId: string;\n111\t    refereeUserId: string;\n112\t    referrerWallet: string;\n113\t    refereeWallet: string;\n114\t    roundId: string;\n115\t    gameType: string;\n116\t    wagerLamports: number;\n117\t    feeLamports: number;\n118\t    referrerEarnedLamports: number;\n119\t    referrerRateBps: number;\n120\t  }): Promise<ReferralEarning>;\n121\t\n122\t  /**\n123\t   * Get the pending (unclaimed) balance for a user.\n124\t   * Sum of referrer_earned where user_id=referrer minus sum of claims for that user.\n125\t   * Returns a lamport string.\n126\t   */\n127\t  getPendingBalanceByUserId(userId: string): Promise<string>;\n128\t\n129\t  /** Get paginated per-game earnings for a user (as referrer). Newest first. */\n130\t  getReferralEarningsByUserId(\n131\t    userId: string,\n132\t    page: number,\n133\t    limit: number,\n134\t  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n135\t\n136\t  /** Get referral summary stats for a user. */\n137\t  getReferralStatsByUserId(userId: string): Promise<ReferralStats>;\n138\t\n139\t  /**\n140\t   * Get top referrers with optional user rank. Returns entries with RANK()\n141\t   * and the requesting user's rank/count if userId is provided.\n142\t   */\n143\t  getReferralLeaderboard(\n144\t    limit: number,\n145\t    userId?: string,\n146\t  ): Promise<{\n147\t    entries: { rank: number; username: string; count: number }[];\n148\t    userRank: number | null;\n149\t    userCount: number;\n150\t  }>;\n151\t\n152\t  // -------------------------------------------------------------------------\n153\t  // Referral — claims & rates\n154\t  // -------------------------------------------------------------------------\n155\t\n156\t  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n157\t  insertReferralClaim(\n158\t    userId: string,\n159\t    wallet: string,\n160\t    amountLamports: string,\n161\t  ): Promise<ReferralClaim>;\n162\t\n163\t  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n164\t  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n165\t\n166\t  /**\n167\t   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n168\t   * Returns the updated claim.\n169\t   */\n170\t  updateClaimStatus(\n171\t    claimId: string,\n172\t    status: ReferralClaim[\"status\"],\n173\t    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n174\t  ): Promise<ReferralClaim>;\n175\t\n176\t  /**\n177\t   * Get the effective referrer rate for a user in bps.\n178\t   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n179\t   */\n180\t  getReferrerRate(\n181\t    userId: string,\n182\t    defaultRateBps: number,\n183\t  ): Promise<number>;\n184\t}\n185\t\n186\t// ---------------------------------------------------------------------------\n187\t// Normalizer\n188\t// ---------------------------------------------------------------------------\n189\t\n190\tfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n191\t  return {\n192\t    ...row,\n193\t    wager_lamports: Number(row.wager_lamports),\n194\t    fee_lamports: Number(row.fee_lamports),\n195\t    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n196\t    referrer_rate_bps: Number(row.referrer_rate_bps),\n197\t  };\n198\t}\n199\t\n200\t// ---------------------------------------------------------------------------\n201\t// Factory\n202\t// ---------------------------------------------------------------------------\n203\t\n204\t \n205\texport function createReferralsDb(sql: ReturnType<typeof postgres>): ReferralsDb {\n206\t  return {\n207\t    // -----------------------------------------------------------------------\n208\t    // Referral — codes\n209\t    // -----------------------------------------------------------------------\n210\t\n211\t    async insertReferralCode(userId, wallet, code) {\n212\t      const rows = await sql<ReferralCode[]>`\n213\t        INSERT INTO referral_codes (user_id, wallet, code)\n214\t        VALUES (${userId}, ${wallet}, ${code})\n215\t        RETURNING *\n216\t      `;\n217\t      return rows[0]!;\n218\t    },\n219\t\n220\t    async getReferralCodeByUserId(userId) {\n221\t      const rows = await sql<ReferralCode[]>`\n222\t        SELECT * FROM referral_codes WHERE user_id = ${userId}\n223\t      `;\n224\t      return rows[0];\n225\t    },\n226\t\n227\t    async getReferralCodeByCode(code) {\n228\t      const rows = await sql<ReferralCode[]>`\n229\t        SELECT * FROM referral_codes WHERE code = ${code}\n230\t      `;\n231\t      return rows[0];\n232\t    },\n233\t\n234\t    // -- Referral links -------------------------------------------------------\n235\t\n236\t    async insertReferralLink(params) {\n237\t      const rows = await sql<ReferralLink[]>`\n238\t        INSERT INTO referral_links (\n239\t          referrer_user_id,\n240\t          referee_user_id,\n241\t          referrer_wallet,\n242\t          referee_wallet\n243\t        )\n244\t        VALUES (\n245\t          ${params.referrerUserId},\n246\t          ${params.refereeUserId},\n247\t          ${params.referrerWallet},\n248\t          ${params.refereeWallet}\n249\t        )\n250\t        RETURNING *\n251\t      `;\n252\t      return rows[0]!;\n253\t    },\n254\t\n255\t    async getReferralLinkByRefereeUserId(refereeUserId) {\n256\t      const rows = await sql<ReferralLink[]>`\n257\t        SELECT * FROM referral_links WHERE referee_user_id = ${refereeUserId}\n258\t      `;\n259\t      return rows[0];\n260\t    },\n261\t\n262\t    async getReferralLinksByReferrerUserId(referrerUserId) {\n263\t      const rows = await sql<ReferralLink[]>`\n264\t        SELECT * FROM referral_links WHERE referrer_user_id = ${referrerUserId}\n265\t        ORDER BY created_at DESC\n266\t      `;\n267\t      return rows;\n268\t    },\n269\t\n270\t    // -- Referral earnings & stats --------------------------------------------\n271\t\n272\t    async insertReferralEarning(params) {\n273\t      const rows = await sql<ReferralEarning[]>`\n274\t        INSERT INTO referral_earnings (\n275\t          referrer_user_id, referee_user_id,\n276\t          referrer_wallet, referee_wallet, round_id, game_type,\n277\t          wager_lamports, fee_lamports,\n278\t          referrer_earned_lamports, referrer_rate_bps\n279\t        ) VALUES (\n280\t          ${params.referrerUserId}, ${params.refereeUserId},\n281\t          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n282\t          ${params.wagerLamports}, ${params.feeLamports},\n283\t          ${params.referrerEarnedLamports}, ${params.referrerRateBps}\n284\t        )\n285\t        RETURNING *\n286\t      `;\n287\t      return normalizeReferralEarning(rows[0]!);\n288\t    },\n289\t\n290\t    async getPendingBalanceByUserId(userId) {\n291\t      const rows = await sql<{ pending: string }[]>`\n292\t        SELECT COALESCE(\n293\t          (\n294\t            SELECT SUM(referrer_earned_lamports)\n295\t            FROM referral_earnings WHERE referrer_user_id = ${userId}\n296\t          ), 0\n297\t        ) - COALESCE(\n298\t          (\n299\t            SELECT SUM(amount_lamports)\n300\t            FROM referral_claims WHERE user_id = ${userId} AND status IN ('pending', 'processing', 'error', 'completed')\n301\t          ), 0\n302\t        ) AS pending\n303\t      `;\n304\t      return rows[0]!.pending;\n305\t    },\n306\t\n307\t    async getReferralEarningsByUserId(userId, page, limit) {\n308\t      const offset = (page - 1) * limit;\n309\t      const [countRows, rows] = await Promise.all([\n310\t        sql<{ count: string }[]>`\n311\t          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n312\t          WHERE referrer_user_id = ${userId}\n313\t        `,\n314\t        sql<ReferralEarning[]>`\n315\t          SELECT * FROM referral_earnings\n316\t          WHERE referrer_user_id = ${userId}\n317\t          ORDER BY created_at DESC\n318\t          LIMIT ${limit} OFFSET ${offset}\n319\t        `,\n320\t      ]);\n321\t      const total = Number(countRows[0]!.count);\n322\t      const totalPages = Math.max(1, Math.ceil(total / limit));\n323\t      return { items: rows.map(normalizeReferralEarning), totalPages };\n324\t    },\n325\t\n326\t    async getReferralStatsByUserId(userId) {\n327\t      const rows = await sql<ReferralStats[]>`\n328\t        SELECT\n329\t          (SELECT COUNT(*) FROM referral_links WHERE referrer_user_id = ${userId})::INT\n330\t            AS referred_count,\n331\t          (\n332\t            SELECT COUNT(DISTINCT re.referee_user_id)\n333\t            FROM referral_earnings re\n334\t            JOIN referral_links rl\n335\t              ON rl.referee_user_id = re.referee_user_id\n336\t             AND rl.referrer_user_id = ${userId}\n337\t            WHERE re.created_at > now() - INTERVAL '7 days'\n338\t          )::INT AS active_count,\n339\t          COALESCE(\n340\t            (\n341\t              SELECT SUM(re.wager_lamports)::TEXT\n342\t              FROM referral_earnings re\n343\t              JOIN referral_links rl\n344\t                ON rl.referee_user_id = re.referee_user_id\n345\t               AND rl.referrer_user_id = ${userId}\n346\t            ), '0'\n347\t          ) AS total_volume_lamports,\n348\t          COALESCE(\n349\t            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_user_id = ${userId}),\n350\t            '0'\n351\t          ) AS total_earned_lamports,\n352\t          (\n353\t            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_user_id = ${userId}), 0)\n354\t            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE user_id = ${userId} AND status IN ('pending','processing','error','completed')), 0)\n355\t          )::TEXT AS pending_lamports\n356\t      `;\n357\t      return rows[0]!;\n358\t    },\n359\t\n360\t    async getReferralLeaderboard(limit, userId) {\n361\t      // Single query: top N + user's own row (if userId provided).\n362\t      // When userId is null, the OR clause is a no-op (= NULL is always false).\n363\t      interface Row { rank: number; username: string; referral_count: number; is_self: boolean }\n364\t      const uid = userId ?? null;\n365\t\n366\t      const rows = await sql<Row[]>`\n367\t        WITH ranked AS (\n368\t          SELECT\n369\t            pp.username,\n370\t            rl.referrer_user_id,\n371\t            COUNT(rl.id)::INT AS referral_count,\n372\t            RANK() OVER (ORDER BY COUNT(rl.id) DESC)::INT AS rank\n373\t          FROM referral_links rl\n374\t          JOIN player_profiles pp ON pp.user_id = rl.referrer_user_id\n375\t          GROUP BY rl.referrer_user_id, pp.username\n376\t        )\n377\t        SELECT rank, username, referral_count, (referrer_user_id = ${uid}) AS is_self\n378\t        FROM ranked\n379\t        WHERE rank <= ${limit} OR referrer_user_id = ${uid}\n380\t        ORDER BY rank ASC\n381\t      `;\n382\t\n383\t      const entries: { rank: number; username: string; count: number }[] = [];\n384\t      let userRank: number | null = null;\n385\t      let userCount = 0;\n386\t\n387\t      for (const row of rows) {\n388\t        if (row.is_self) {\n389\t          userRank = row.rank;\n390\t          userCount = row.referral_count;\n391\t        }\n392\t        if (row.rank <= limit) {\n393\t          entries.push({ rank: row.rank, username: row.username, count: row.referral_count });\n394\t        }\n395\t      }\n396\t\n397\t      return { entries, userRank, userCount };\n398\t    },\n399\t\n400\t    // -----------------------------------------------------------------------\n401\t    // Referral — claims & rates\n402\t    // -----------------------------------------------------------------------\n403\t\n404\t    async insertReferralClaim(userId, wallet, amountLamports) {\n405\t      const rows = await sql<ReferralClaim[]>`\n406\t        INSERT INTO referral_claims (user_id, wallet, amount_lamports, status)\n407\t        VALUES (${userId}, ${wallet}, ${amountLamports}, 'pending')\n408\t        RETURNING *\n409\t      `;\n410\t      return rows[0]!;\n411\t    },\n412\t\n413\t    async getReferralClaim(claimId) {\n414\t      const rows = await sql<ReferralClaim[]>`\n415\t        SELECT * FROM referral_claims WHERE id = ${claimId}\n416\t      `;\n417\t      return rows[0];\n418\t    },\n419\t\n420\t    async updateClaimStatus(claimId, status, meta) {\n421\t      const rows = await sql<ReferralClaim[]>`\n422\t        UPDATE referral_claims\n423\t        SET\n424\t          status = ${status},\n425\t          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n426\t          error = COALESCE(${meta?.error ?? null}, error),\n427\t          retry_count = ${meta?.incrementRetry ? sql`retry_count + 1` : sql`retry_count`},\n428\t          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n429\t        WHERE id = ${claimId}\n430\t        RETURNING *\n431\t      `;\n432\t      return rows[0]!;\n433\t    },\n434\t\n435\t    async getReferrerRate(userId, defaultRateBps) {\n436\t      const rows = await sql<{ rate_bps: number }[]>`\n437\t        SELECT rate_bps FROM referral_kol_rates WHERE user_id = ${userId}\n438\t      `;\n439\t      return rows[0]?.rate_bps ?? defaultRateBps;\n440\t    },\n441\t  };\n442\t}\n443\t"}]},"parent_tool_use_id":null,"session_id":"0593b00d-aabc-4ab9-a640-568a57e4b2f3","uuid":"0c966e24-19ae-41f5-9c8b-901d5cf965b2","timestamp":"2026-05-01T19:37:30.885Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/db/referrals.ts","content":" \nimport type postgres from \"postgres\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface ReferralCode {\n  id: number;\n  user_id: string;\n  wallet: string;\n  code: string;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface ReferralLink {\n  id: number;\n  referrer_user_id: string;\n  referee_user_id: string;\n  referrer_wallet: string;\n  referee_wallet: string;\n  created_at: Date;\n}\n\nexport interface ReferralEarning {\n  id: number;\n  referrer_user_id: string;\n  referee_user_id: string;\n  referrer_wallet: string;\n  referee_wallet: string;\n  round_id: string;\n  game_type: string;\n  wager_lamports: number;\n  fee_lamports: number;\n  referrer_earned_lamports: number;\n  referrer_rate_bps: number;\n  created_at: Date;\n}\n\nexport interface ReferralStats {\n  referred_count: number;\n  active_count: number;\n  total_volume_lamports: string;\n  total_earned_lamports: string;\n  pending_lamports: string;\n}\n\nexport interface ReferralClaim {\n  id: string;\n  user_id: string;\n  wallet: string;\n  amount_lamports: string;\n  status: \"pending\" | \"processing\" | \"error\" | \"completed\" | \"failed\";\n  retry_count: number;\n  tx_signature: string | null;\n  error: string | null;\n  requested_at: Date;\n  processed_at: Date | null;\n}\n\n// ---------------------------------------------------------------------------\n// Interface\n// ---------------------------------------------------------------------------\n\nexport interface ReferralsDb {\n  // -------------------------------------------------------------------------\n  // Referral — codes\n  // -------------------------------------------------------------------------\n\n  /** Insert a new referral code for a user. Throws on duplicate user, wallet, or code. */\n  insertReferralCode(\n    userId: string,\n    wallet: string,\n    code: string,\n  ): Promise<ReferralCode>;\n\n  /** Get a user's referral code. Returns `undefined` if none set. */\n  getReferralCodeByUserId(userId: string): Promise<ReferralCode | undefined>;\n\n  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n\n  // -------------------------------------------------------------------------\n  // Referral — links\n  // -------------------------------------------------------------------------\n\n  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n  insertReferralLink(params: {\n    referrerUserId: string;\n    refereeUserId: string;\n    referrerWallet: string;\n    refereeWallet: string;\n  }): Promise<ReferralLink>;\n\n  /** Get the referral link for a referee user. Returns `undefined` if not referred. */\n  getReferralLinkByRefereeUserId(\n    refereeUserId: string,\n  ): Promise<ReferralLink | undefined>;\n\n  /** Get all referral links where the given user is the referrer. */\n  getReferralLinksByReferrerUserId(referrerUserId: string): Promise<ReferralLink[]>;\n\n  // -------------------------------------------------------------------------\n  // Referral — earnings & stats\n  // -------------------------------------------------------------------------\n\n  /** Insert a referral earning row. Throws on duplicate (referee_user_id, round_id). */\n  insertReferralEarning(params: {\n    referrerUserId: string;\n    refereeUserId: string;\n    referrerWallet: string;\n    refereeWallet: string;\n    roundId: string;\n    gameType: string;\n    wagerLamports: number;\n    feeLamports: number;\n    referrerEarnedLamports: number;\n    referrerRateBps: number;\n  }): Promise<ReferralEarning>;\n\n  /**\n   * Get the pending (unclaimed) balance for a user.\n   * Sum of referrer_earned where user_id=referrer minus sum of claims for that user.\n   * Returns a lamport string.\n   */\n  getPendingBalanceByUserId(userId: string): Promise<string>;\n\n  /** Get paginated per-game earnings for a user (as referrer). Newest first. */\n  getReferralEarningsByUserId(\n    userId: string,\n    page: number,\n    limit: number,\n  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n\n  /** Get referral summary stats for a user. */\n  getReferralStatsByUserId(userId: string): Promise<ReferralStats>;\n\n  /**\n   * Get top referrers with optional user rank. Returns entries with RANK()\n   * and the requesting user's rank/count if userId is provided.\n   */\n  getReferralLeaderboard(\n    limit: number,\n    userId?: string,\n  ): Promise<{\n    entries: { rank: number; username: string; count: number }[];\n    userRank: number | null;\n    userCount: number;\n  }>;\n\n  // -------------------------------------------------------------------------\n  // Referral — claims & rates\n  // -------------------------------------------------------------------------\n\n  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n  insertReferralClaim(\n    userId: string,\n    wallet: string,\n    amountLamports: string,\n  ): Promise<ReferralClaim>;\n\n  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n\n  /**\n   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n   * Returns the updated claim.\n   */\n  updateClaimStatus(\n    claimId: string,\n    status: ReferralClaim[\"status\"],\n    meta?: { txSignature?: string; error?: string; incrementRetry?: boolean },\n  ): Promise<ReferralClaim>;\n\n  /**\n   * Get the effective referrer rate for a user in bps.\n   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n   */\n  getReferrerRate(\n    userId: string,\n    defaultRateBps: number,\n  ): Promise<number>;\n}\n\n// ---------------------------------------------------------------------------\n// Normalizer\n// ---------------------------------------------------------------------------\n\nfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n  return {\n    ...row,\n    wager_lamports: Number(row.wager_lamports),\n    fee_lamports: Number(row.fee_lamports),\n    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n    referrer_rate_bps: Number(row.referrer_rate_bps),\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\n \nexport function createReferralsDb(sql: ReturnType<typeof postgres>): ReferralsDb {\n  return {\n    // -----------------------------------------------------------------------\n    // Referral — codes\n    // -----------------------------------------------------------------------\n\n    async insertReferralCode(userId, wallet, code) {\n      const rows = await sql<ReferralCode[]>`\n        INSERT INTO referral_codes (user_id, wallet, code)\n        VALUES (${userId}, ${wallet}, ${code})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralCodeByUserId(userId) {\n      const rows = await sql<ReferralCode[]>`\n        SELECT * FROM referral_codes WHERE user_id = ${userId}\n      `;\n      return rows[0];\n    },\n\n    async getReferralCodeByCode(code) {\n      const rows = await sql<ReferralCode[]>`\n        SELECT * FROM referral_codes WHERE code = ${code}\n      `;\n      return rows[0];\n    },\n\n    // -- Referral links -------------------------------------------------------\n\n    async insertReferralLink(params) {\n      const rows = await sql<ReferralLink[]>`\n        INSERT INTO referral_links (\n          referrer_user_id,\n          referee_user_id,\n          referrer_wallet,\n          referee_wallet\n        )\n        VALUES (\n          ${params.referrerUserId},\n          ${params.refereeUserId},\n          ${params.referrerWallet},\n          ${params.refereeWallet}\n        )\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralLinkByRefereeUserId(refereeUserId) {\n      const rows = await sql<ReferralLink[]>`\n        SELECT * FROM referral_links WHERE referee_user_id = ${refereeUserId}\n      `;\n      return rows[0];\n    },\n\n    async getReferralLinksByReferrerUserId(referrerUserId) {\n      const rows = await sql<ReferralLink[]>`\n        SELECT * FROM referral_links WHERE referrer_user_id = ${referrerUserId}\n        ORDER BY created_at DESC\n      `;\n      return rows;\n    },\n\n    // -- Referral earnings & stats --------------------------------------------\n\n    async insertReferralEarning(params) {\n      const rows = await sql<ReferralEarning[]>`\n        INSERT INTO referral_earnings (\n          referrer_user_id, referee_user_id,\n          referrer_wallet, referee_wallet, round_id, game_type,\n          wager_lamports, fee_lamports,\n          referrer_earned_lamports, referrer_rate_bps\n        ) VALUES (\n          ${params.referrerUserId}, ${params.refereeUserId},\n          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n          ${params.wagerLamports}, ${params.feeLamports},\n          ${params.referrerEarnedLamports}, ${params.referrerRateBps}\n        )\n        RETURNING *\n      `;\n      return normalizeReferralEarning(rows[0]!);\n    },\n\n    async getPendingBalanceByUserId(userId) {\n      const rows = await sql<{ pending: string }[]>`\n        SELECT COALESCE(\n          (\n            SELECT SUM(referrer_earned_lamports)\n            FROM referral_earnings WHERE referrer_user_id = ${userId}\n          ), 0\n        ) - COALESCE(\n          (\n            SELECT SUM(amount_lamports)\n            FROM referral_claims WHERE user_id = ${userId} AND status IN ('pending', 'processing', 'error', 'completed')\n          ), 0\n        ) AS pending\n      `;\n      return rows[0]!.pending;\n    },\n\n    async getReferralEarningsByUserId(userId, page, limit) {\n      const offset = (page - 1) * limit;\n      const [countRows, rows] = await Promise.all([\n        sql<{ count: string }[]>`\n          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n          WHERE referrer_user_id = ${userId}\n        `,\n        sql<ReferralEarning[]>`\n          SELECT * FROM referral_earnings\n          WHERE referrer_user_id = ${userId}\n          ORDER BY created_at DESC\n          LIMIT ${limit} OFFSET ${offset}\n        `,\n      ]);\n      const total = Number(countRows[0]!.count);\n      const totalPages = Math.max(1, Math.ceil(total / limit));\n      return { items: rows.map(normalizeReferralEarning), totalPages };\n    },\n\n    async getReferralStatsByUserId(userId) {\n      const rows = await sql<ReferralStats[]>`\n        SELECT\n          (SELECT COUNT(*) FROM referral_links WHERE referrer_user_id = ${userId})::INT\n            AS referred_count,\n          (\n            SELECT COUNT(DISTINCT re.referee_user_id)\n            FROM referral_earnings re\n            JOIN referral_links rl\n              ON rl.referee_user_id = re.referee_user_id\n             AND rl.referrer_user_id = ${userId}\n            WHERE re.created_at > now() - INTERVAL '7 days'\n          )::INT AS active_count,\n          COALESCE(\n            (\n              SELECT SUM(re.wager_lamports)::TEXT\n              FROM referral_earnings re\n              JOIN referral_links rl\n                ON rl.referee_user_id = re.referee_user_id\n               AND rl.referrer_user_id = ${userId}\n            ), '0'\n          ) AS total_volume_lamports,\n          COALESCE(\n            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_user_id = ${userId}),\n            '0'\n          ) AS total_earned_lamports,\n          (\n            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_user_id = ${userId}), 0)\n            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE user_id = ${userId} AND status IN ('pending','processing','error','completed')), 0)\n          )::TEXT AS pending_lamports\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralLeaderboard(limit, userId) {\n      // Single query: top N + user's own row (if userId provided).\n      // When userId is null, the OR clause is a no-op (= NULL is always false).\n      interface Row { rank: number; username: string; referral_count: number; is_self: boolean }\n      const uid = userId ?? null;\n\n      const rows = await sql<Row[]>`\n        WITH ranked AS (\n          SELECT\n            pp.username,\n            rl.referrer_user_id,\n            COUNT(rl.id)::INT AS referral_count,\n            RANK() OVER (ORDER BY COUNT(rl.id) DESC)::INT AS rank\n          FROM referral_links rl\n          JOIN player_profiles pp ON pp.user_id = rl.referrer_user_id\n          GROUP BY rl.referrer_user_id, pp.username\n        )\n        SELECT rank, username, referral_count, (referrer_user_id = ${uid}) AS is_self\n        FROM ranked\n        WHERE rank <= ${limit} OR referrer_user_id = ${uid}\n        ORDER BY rank ASC\n      `;\n\n      const entries: { rank: number; username: string; count: number }[] = [];\n      let userRank: number | null = null;\n      let userCount = 0;\n\n      for (const row of rows) {\n        if (row.is_self) {\n          userRank = row.rank;\n          userCount = row.referral_count;\n        }\n        if (row.rank <= limit) {\n          entries.push({ rank: row.rank, username: row.username, count: row.referral_count });\n        }\n      }\n\n      return { entries, userRank, userCount };\n    },\n\n    // -----------------------------------------------------------------------\n    // Referral — claims & rates\n    // -----------------------------------------------------------------------\n\n    async insertReferralClaim(userId, wallet, amountLamports) {\n      const rows = await sql<ReferralClaim[]>`\n        INSERT INTO referral_claims (user_id, wallet, amount_lamports, status)\n        VALUES (${userId}, ${wallet}, ${amountLamports}, 'pending')\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferralClaim(claimId) {\n      const rows = await sql<ReferralClaim[]>`\n        SELECT * FROM referral_claims WHERE id = ${claimId}\n      `;\n      return rows[0];\n    },\n\n    async updateClaimStatus(claimId, status, meta) {\n      const rows = await sql<ReferralClaim[]>`\n        UPDATE referral_claims\n        SET\n          status = ${status},\n          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n          error = COALESCE(${meta?.error ?? null}, error),\n          retry_count = ${meta?.incrementRetry ? sql`retry_count + 1` : sql`retry_count`},\n          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n        WHERE id = ${claimId}\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getReferrerRate(userId, defaultRateBps) {\n      const rows = await sql<{ rate_bps: number }[]>`\n        SELECT rate_bps FROM referral_kol_rates WHERE user_id = ${userId}\n      `;\n      return rows[0]?.rate_bps ?? defaultRateBps;\n    },\n  };\n}\n","numLines":443,"startLine":1,"totalLines":443}}}
