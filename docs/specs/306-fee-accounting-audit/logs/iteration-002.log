{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019FsRrrFRJ747XBRTBA3j4s","type":"tool_result","content":"1\t \n2\timport type postgres from \"postgres\";\n3\t\n4\t// ---------------------------------------------------------------------------\n5\t// Types\n6\t// ---------------------------------------------------------------------------\n7\t\n8\texport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n9\t\n10\texport interface Transaction {\n11\t  id: string;\n12\t  wallet: string;\n13\t  game: string;\n14\t  match_id: string;\n15\t  tx_type: TransactionType;\n16\t  amount_lamports: number;\n17\t  tx_sig: string;\n18\t  created_at: Date;\n19\t}\n20\t\n21\texport interface InsertTransactionParams {\n22\t  userId?: string;\n23\t  wallet: string;\n24\t  game: string;\n25\t  matchId: string;\n26\t  txType: TransactionType;\n27\t  amountLamports: number;\n28\t  txSig: string;\n29\t}\n30\t\n31\t// ---------------------------------------------------------------------------\n32\t// Interface\n33\t// ---------------------------------------------------------------------------\n34\t\n35\texport interface TransactionsDb {\n36\t  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n37\t  insertTransaction(params: InsertTransactionParams): Promise<void>;\n38\t\n39\t  /** Insert multiple transactions in a single batch. */\n40\t  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n41\t\n42\t  /** Get paginated transactions for a wallet, newest first. */\n43\t  getTransactions(\n44\t    wallet: string,\n45\t    cursor?: string,\n46\t    limit?: number,\n47\t    game?: string,\n48\t  ): Promise<Transaction[]>;\n49\t\n50\t  /** Get paginated transactions for an authenticated user_id, newest first. */\n51\t  getTransactionsByUserId(\n52\t    userId: string,\n53\t    cursor?: string,\n54\t    limit?: number,\n55\t    game?: string,\n56\t  ): Promise<Transaction[]>;\n57\t}\n58\t\n59\t// ---------------------------------------------------------------------------\n60\t// Normalizer\n61\t// ---------------------------------------------------------------------------\n62\t\n63\tfunction normalizeTransaction(row: Transaction): Transaction {\n64\t  return {\n65\t    ...row,\n66\t    amount_lamports: Number(row.amount_lamports),\n67\t  };\n68\t}\n69\t\n70\t// ---------------------------------------------------------------------------\n71\t// Factory\n72\t// ---------------------------------------------------------------------------\n73\t\n74\t \n75\texport function createTransactionsDb(sql: ReturnType<typeof postgres>): TransactionsDb {\n76\t  return {\n77\t    async insertTransaction(params) {\n78\t      await sql`\n79\t        INSERT INTO transactions (user_id, wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n80\t        VALUES (\n81\t          ${params.userId ?? null},\n82\t          ${params.wallet},\n83\t          ${params.game},\n84\t          ${params.matchId},\n85\t          ${params.txType},\n86\t          ${params.amountLamports},\n87\t          ${params.txSig}\n88\t        )\n89\t        ON CONFLICT DO NOTHING\n90\t      `;\n91\t    },\n92\t\n93\t    async insertTransactions(params) {\n94\t      if (params.length === 0) return;\n95\t      const values = params.map((p) => ({\n96\t        user_id: p.userId ?? null,\n97\t        wallet: p.wallet,\n98\t        game: p.game,\n99\t        match_id: p.matchId,\n100\t        tx_type: p.txType,\n101\t        amount_lamports: p.amountLamports,\n102\t        tx_sig: p.txSig,\n103\t      }));\n104\t      await sql`\n105\t        INSERT INTO transactions ${sql(values, \"user_id\", \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n106\t        ON CONFLICT DO NOTHING\n107\t      `;\n108\t    },\n109\t\n110\t    async getTransactions(wallet, cursor, limit = 20, game) {\n111\t      const effectiveLimit = Math.min(limit, 50);\n112\t      if (cursor && game) {\n113\t        const rows = await sql<Transaction[]>`\n114\t          SELECT * FROM transactions\n115\t          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n116\t          ORDER BY id DESC\n117\t          LIMIT ${effectiveLimit}\n118\t        `;\n119\t        return rows.map(normalizeTransaction);\n120\t      }\n121\t      if (cursor) {\n122\t        const rows = await sql<Transaction[]>`\n123\t          SELECT * FROM transactions\n124\t          WHERE wallet = ${wallet} AND id < ${cursor}\n125\t          ORDER BY id DESC\n126\t          LIMIT ${effectiveLimit}\n127\t        `;\n128\t        return rows.map(normalizeTransaction);\n129\t      }\n130\t      if (game) {\n131\t        const rows = await sql<Transaction[]>`\n132\t          SELECT * FROM transactions\n133\t          WHERE wallet = ${wallet} AND game = ${game}\n134\t          ORDER BY id DESC\n135\t          LIMIT ${effectiveLimit}\n136\t        `;\n137\t        return rows.map(normalizeTransaction);\n138\t      }\n139\t      const rows = await sql<Transaction[]>`\n140\t        SELECT * FROM transactions\n141\t        WHERE wallet = ${wallet}\n142\t        ORDER BY id DESC\n143\t        LIMIT ${effectiveLimit}\n144\t      `;\n145\t      return rows.map(normalizeTransaction);\n146\t    },\n147\t\n148\t    async getTransactionsByUserId(userId, cursor, limit = 20, game) {\n149\t      const effectiveLimit = Math.min(limit, 50);\n150\t      const cursorFilter = cursor ? sql`AND t.id < ${cursor}` : sql``;\n151\t      const gameFilter = game ? sql`AND t.game = ${game}` : sql``;\n152\t      const rows = await sql<Transaction[]>`\n153\t        SELECT t.*\n154\t        FROM transactions t\n155\t        JOIN player_profiles p ON p.wallet = t.wallet\n156\t        WHERE p.user_id = ${userId}\n157\t          ${cursorFilter}\n158\t          ${gameFilter}\n159\t        ORDER BY t.id DESC\n160\t        LIMIT ${effectiveLimit}\n161\t      `;\n162\t      return rows.map(normalizeTransaction);\n163\t    },\n164\t  };\n165\t}\n166\t"}]},"parent_tool_use_id":null,"session_id":"0593b00d-aabc-4ab9-a640-568a57e4b2f3","uuid":"a15791cd-1d90-4acc-8e76-6606d4fa61d6","timestamp":"2026-05-01T19:37:43.217Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/db/transactions.ts","content":" \nimport type postgres from \"postgres\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n\nexport interface Transaction {\n  id: string;\n  wallet: string;\n  game: string;\n  match_id: string;\n  tx_type: TransactionType;\n  amount_lamports: number;\n  tx_sig: string;\n  created_at: Date;\n}\n\nexport interface InsertTransactionParams {\n  userId?: string;\n  wallet: string;\n  game: string;\n  matchId: string;\n  txType: TransactionType;\n  amountLamports: number;\n  txSig: string;\n}\n\n// ---------------------------------------------------------------------------\n// Interface\n// ---------------------------------------------------------------------------\n\nexport interface TransactionsDb {\n  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n  insertTransaction(params: InsertTransactionParams): Promise<void>;\n\n  /** Insert multiple transactions in a single batch. */\n  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n\n  /** Get paginated transactions for a wallet, newest first. */\n  getTransactions(\n    wallet: string,\n    cursor?: string,\n    limit?: number,\n    game?: string,\n  ): Promise<Transaction[]>;\n\n  /** Get paginated transactions for an authenticated user_id, newest first. */\n  getTransactionsByUserId(\n    userId: string,\n    cursor?: string,\n    limit?: number,\n    game?: string,\n  ): Promise<Transaction[]>;\n}\n\n// ---------------------------------------------------------------------------\n// Normalizer\n// ---------------------------------------------------------------------------\n\nfunction normalizeTransaction(row: Transaction): Transaction {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\n \nexport function createTransactionsDb(sql: ReturnType<typeof postgres>): TransactionsDb {\n  return {\n    async insertTransaction(params) {\n      await sql`\n        INSERT INTO transactions (user_id, wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n        VALUES (\n          ${params.userId ?? null},\n          ${params.wallet},\n          ${params.game},\n          ${params.matchId},\n          ${params.txType},\n          ${params.amountLamports},\n          ${params.txSig}\n        )\n        ON CONFLICT DO NOTHING\n      `;\n    },\n\n    async insertTransactions(params) {\n      if (params.length === 0) return;\n      const values = params.map((p) => ({\n        user_id: p.userId ?? null,\n        wallet: p.wallet,\n        game: p.game,\n        match_id: p.matchId,\n        tx_type: p.txType,\n        amount_lamports: p.amountLamports,\n        tx_sig: p.txSig,\n      }));\n      await sql`\n        INSERT INTO transactions ${sql(values, \"user_id\", \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n        ON CONFLICT DO NOTHING\n      `;\n    },\n\n    async getTransactions(wallet, cursor, limit = 20, game) {\n      const effectiveLimit = Math.min(limit, 50);\n      if (cursor && game) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      if (cursor) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND id < ${cursor}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      if (game) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND game = ${game}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      const rows = await sql<Transaction[]>`\n        SELECT * FROM transactions\n        WHERE wallet = ${wallet}\n        ORDER BY id DESC\n        LIMIT ${effectiveLimit}\n      `;\n      return rows.map(normalizeTransaction);\n    },\n\n    async getTransactionsByUserId(userId, cursor, limit = 20, game) {\n      const effectiveLimit = Math.min(limit, 50);\n      const cursorFilter = cursor ? sql`AND t.id < ${cursor}` : sql``;\n      const gameFilter = game ? sql`AND t.game = ${game}` : sql``;\n      const rows = await sql<Transaction[]>`\n        SELECT t.*\n        FROM transactions t\n        JOIN player_profiles p ON p.wallet = t.wallet\n        WHERE p.user_id = ${userId}\n          ${cursorFilter}\n          ${gameFilter}\n        ORDER BY t.id DESC\n        LIMIT ${effectiveLimit}\n      `;\n      return rows.map(normalizeTransaction);\n    },\n  };\n}\n","numLines":166,"startLine":1,"totalLines":166}}}
