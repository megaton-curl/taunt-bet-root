{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0145Asaurr7PzFCysJFwZDnb","type":"tool_result","content":"1\t/**\n2\t * Close Call clock worker — precise minute-boundary price capture + settlement.\n3\t *\n4\t * Scheduling:\n5\t *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n6\t *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n7\t *   - Caches the boundary price (both close of old candle, open of next)\n8\t *   - Settles any open rounds whose candle has closed\n9\t *   - Schedules next tick at (next minute + 1s)\n10\t *\n11\t * Rounds are created on-demand by the first bettor (via /closecall/bet).\n12\t * On start, loads the latest boundary price from DB to seed the cache.\n13\t */\n14\t\n15\timport { performance } from \"node:perf_hooks\";\n16\timport {\n17\t  Connection,\n18\t  Keypair,\n19\t  PublicKey,\n20\t  Transaction,\n21\t} from \"@solana/web3.js\";\n22\timport type { Db } from \"../db.js\";\n23\timport { logger } from \"../logger.js\";\n24\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n25\timport { getPlatformConfig } from \"../platform-config.js\";\n26\timport {\n27\t  buildCloseCallSettleRoundIx,\n28\t} from \"./settle-tx.js\";\n29\timport { emitEvent } from \"../queue/emit-event.js\";\n30\timport { EventTypes } from \"../queue/event-types.js\";\n31\timport {\n32\t  closeCallRoundDiscriminatorFilter,\n33\t  decodeCloseCallRound,\n34\t} from \"./account-decoder.js\";\n35\timport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n36\t\n37\t/** Close Call on-chain phase values */\n38\tconst PHASE_OPEN = 0;\n39\t\n40\t/** How long to wait after minute boundary before first Hermes poll (ms). */\n41\tconst BOUNDARY_OFFSET_MS = 1_000;\n42\t\n43\t/** Poll Hermes every 1s when waiting for boundary price. */\n44\tconst HERMES_POLL_INTERVAL_MS = 1_000;\n45\t\n46\t/** Max attempts to fetch a fresh boundary price (10s total). */\n47\tconst HERMES_MAX_RETRIES = 10;\n48\t\n49\t/** Maximum retry attempts for a single tx submission. */\n50\tconst MAX_TX_RETRIES = 3;\n51\tconst TX_RETRY_DELAY_MS = 2_000;\n52\t\n53\t// ---------------------------------------------------------------------------\n54\t// Types\n55\t// ---------------------------------------------------------------------------\n56\t\n57\texport interface BoundaryPrice {\n58\t  price: bigint;\n59\t  expo: number;\n60\t  minuteTs: number;\n61\t  priceHuman: number;\n62\t}\n63\t\n64\texport interface CloseCallClockDeps {\n65\t  connection: Connection;\n66\t  serverKeypair: Keypair;\n67\t  /** Typed database client. */\n68\t  db: Db;\n69\t  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n70\t  hermesEndpoint?: string;\n71\t  /** Optional injectable HermesFetcher (for testing). */\n72\t  hermesFetcher?: HermesFetcher;\n73\t}\n74\t\n75\texport interface CloseCallClockWorker {\n76\t  start(): void;\n77\t  stop(): void;\n78\t  readonly isRunning: boolean;\n79\t  /** Run a single tick (exposed for testing). */\n80\t  tick(): Promise<void>;\n81\t  /** Get the most recent minute-boundary price (from cache). */\n82\t  getLatestBoundaryPrice(): BoundaryPrice | null;\n83\t}\n84\t\n85\t// ---------------------------------------------------------------------------\n86\t// Factory\n87\t// ---------------------------------------------------------------------------\n88\t\n89\texport function createCloseCallClockWorker(\n90\t  deps: CloseCallClockDeps,\n91\t): CloseCallClockWorker {\n92\t  const { connection, serverKeypair, hermesEndpoint, db } = deps;\n93\t\n94\t  const hermes: HermesFetcher = deps.hermesFetcher ?? createHermesFetcher(hermesEndpoint);\n95\t\n96\t  let running = false;\n97\t  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n98\t\n99\t  /** Cached latest boundary price (in-memory). */\n100\t  let cachedBoundaryPrice: BoundaryPrice | null = null;\n101\t\n102\t  // -----------------------------------------------------------------------\n103\t  // Scheduling\n104\t  // -----------------------------------------------------------------------\n105\t\n106\t  /** Milliseconds until the next minute boundary + offset. */\n107\t  function msUntilNextBoundary(): number {\n108\t    const now = Date.now();\n109\t    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n110\t    return nextMinute - now + BOUNDARY_OFFSET_MS;\n111\t  }\n112\t\n113\t  // -----------------------------------------------------------------------\n114\t  // Helpers\n115\t  // -----------------------------------------------------------------------\n116\t\n117\t  /** Send a legacy Transaction with retry. Uses the tx's original blockhash for confirmation. */\n118\t  async function sendAndConfirm(\n119\t    tx: Transaction,\n120\t    label: string,\n121\t    txBlockhash: string,\n122\t    txLastValidBlockHeight: number,\n123\t  ): Promise<string> {\n124\t    let lastError: unknown;\n125\t\n126\t    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n127\t      try {\n128\t        const sig = await connection.sendRawTransaction(tx.serialize(), {\n129\t          skipPreflight: false,\n130\t        });\n131\t        const confirmation = await connection.confirmTransaction(\n132\t          { signature: sig, blockhash: txBlockhash, lastValidBlockHeight: txLastValidBlockHeight },\n133\t          \"confirmed\",\n134\t        );\n135\t        if (confirmation.value.err) {\n136\t          throw new Error(\n137\t            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n138\t          );\n139\t        }\n140\t        return sig;\n141\t      } catch (err) {\n142\t        lastError = err;\n143\t        if (attempt < MAX_TX_RETRIES - 1) {\n144\t          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n145\t            error: err instanceof Error ? err.message : String(err),\n146\t          });\n147\t          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n148\t        }\n149\t      }\n150\t    }\n151\t\n152\t    throw lastError;\n153\t  }\n154\t\n155\t  /** Read treasury and feeBps from the shared PlatformConfig account. */\n156\t  async function readPlatformConfig(): Promise<{ treasury: PublicKey; feeBps: number } | null> {\n157\t    try {\n158\t      return await getPlatformConfig(connection);\n159\t    } catch {\n160\t      return null;\n161\t    }\n162\t  }\n163\t\n164\t  // -----------------------------------------------------------------------\n165\t  // Candle DB operations\n166\t  // -----------------------------------------------------------------------\n167\t\n168\t  /** Save a boundary price to the closecall_candles table (upsert). */\n169\t  async function saveBoundaryPrice(\n170\t    minuteTs: number,\n171\t    price: bigint,\n172\t    expo: number,\n173\t    priceHuman: number,\n174\t    hermesVaa: string | null,\n175\t  ): Promise<void> {\n176\t    try {\n177\t      await db.insertCloseCallCandle(minuteTs, price, expo, priceHuman, hermesVaa);\n178\t    } catch (err) {\n179\t      logger.error(\"closecall clock: failed to save boundary price\", {\n180\t        minuteTs,\n181\t        error: err instanceof Error ? err.message : String(err),\n182\t      });\n183\t    }\n184\t  }\n185\t\n186\t  /** Load the latest boundary price from DB (for startup cache seeding). */\n187\t  async function loadLatestBoundaryFromDb(): Promise<void> {\n188\t    try {\n189\t      const candle = await db.getLatestCloseCallCandle();\n190\t      if (candle) {\n191\t        cachedBoundaryPrice = {\n192\t          price: candle.price,\n193\t          expo: candle.expo,\n194\t          minuteTs: candle.minuteTs,\n195\t          priceHuman: candle.priceHuman,\n196\t        };\n197\t        logger.info(\"closecall clock: loaded boundary price from DB\", {\n198\t          minuteTs: cachedBoundaryPrice.minuteTs,\n199\t          priceHuman: cachedBoundaryPrice.priceHuman,\n200\t        });\n201\t      }\n202\t    } catch (err) {\n203\t      logger.warn(\"closecall clock: failed to load boundary price from DB\", {\n204\t        error: err instanceof Error ? err.message : String(err),\n205\t      });\n206\t    }\n207\t  }\n208\t\n209\t  // -----------------------------------------------------------------------\n210\t  // Boundary price capture — poll Hermes until fresh price arrives\n211\t  // -----------------------------------------------------------------------\n212\t\n213\t  /**\n214\t   * Poll Hermes every 1s until we get a price with publishTime >= boundaryTs.\n215\t   * Returns the captured price or null if max retries exceeded.\n216\t   */\n217\t  async function captureBoundaryPrice(\n218\t    boundaryTs: number,\n219\t  ): Promise<BoundaryPrice | null> {\n220\t    for (let attempt = 0; attempt < HERMES_MAX_RETRIES; attempt++) {\n221\t      try {\n222\t        const result = await hermes.fetchLatestBtcPrice();\n223\t        if (result && result.publishTime >= boundaryTs) {\n224\t          const bp: BoundaryPrice = {\n225\t            price: result.price,\n226\t            expo: result.expo,\n227\t            minuteTs: boundaryTs,\n228\t            priceHuman: result.priceHuman,\n229\t          };\n230\t\n231\t          // Save to DB with VAA proof\n232\t          await saveBoundaryPrice(\n233\t            boundaryTs,\n234\t            result.price,\n235\t            result.expo,\n236\t            result.priceHuman,\n237\t            result.vaaBase64,\n238\t          );\n239\t\n240\t          cachedBoundaryPrice = bp;\n241\t\n242\t          logger.info(\"closecall clock: boundary price captured\", {\n243\t            minuteTs: boundaryTs,\n244\t            priceHuman: result.priceHuman,\n245\t            publishTime: result.publishTime,\n246\t            attempts: attempt + 1,\n247\t          });\n248\t\n249\t          return bp;\n250\t        }\n251\t\n252\t        if (result) {\n253\t          logger.debug(\"closecall clock: Hermes price not yet at boundary\", {\n254\t            publishTime: result.publishTime,\n255\t            boundaryTs,\n256\t            attempt: attempt + 1,\n257\t          });\n258\t        }\n259\t      } catch (err) {\n260\t        logger.warn(\"closecall clock: Hermes poll failed\", {\n261\t          attempt: attempt + 1,\n262\t          error: err instanceof Error ? err.message : String(err),\n263\t        });\n264\t      }\n265\t\n266\t      // Wait 1s before next attempt\n267\t      if (attempt < HERMES_MAX_RETRIES - 1) {\n268\t        await new Promise((r) => setTimeout(r, HERMES_POLL_INTERVAL_MS));\n269\t      }\n270\t    }\n271\t\n272\t    logger.warn(\"closecall clock: failed to capture boundary price after max retries\", {\n273\t      boundaryTs,\n274\t    });\n275\t    return null;\n276\t  }\n277\t\n278\t  // -----------------------------------------------------------------------\n279\t  // Round discovery\n280\t  // -----------------------------------------------------------------------\n281\t\n282\t  /**\n283\t   * Discover ALL existing open rounds owned by this server.\n284\t   */\n285\t  async function discoverOpenRounds(): Promise<\n286\t    Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }>\n287\t  > {\n288\t    const results: Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }> = [];\n289\t    try {\n290\t      const accounts = await connection.getProgramAccounts(\n291\t        CLOSECALL_PROGRAM_ID,\n292\t        { filters: [closeCallRoundDiscriminatorFilter()] },\n293\t      );\n294\t\n295\t      const now = Math.floor(Date.now() / 1000);\n296\t\n297\t      for (const { pubkey, account } of accounts) {\n298\t        try {\n299\t          const round = decodeCloseCallRound(Buffer.from(account.data));\n300\t\n301\t          // Skip rounds with garbage minuteTs (old format / random bytes)\n302\t          const ts = Number(round.minuteTs);\n303\t          if (ts < 1700000000 || ts > now + 120) continue;\n304\t\n305\t          if (\n306\t            round.phase === PHASE_OPEN &&\n307\t            round.server.equals(serverKeypair.publicKey)\n308\t          ) {\n309\t            results.push({ pda: pubkey, minuteTs: round.minuteTs, round });\n310\t          }\n311\t        } catch {\n312\t          // Skip undecodeable accounts\n313\t        }\n314\t      }\n315\t    } catch (err) {\n316\t      logger.warn(\"closecall clock: discovery scan failed\", {\n317\t        error: err instanceof Error ? err.message : String(err),\n318\t      });\n319\t    }\n320\t    return results;\n321\t  }\n322\t\n323\t  // -----------------------------------------------------------------------\n324\t  // Settlement\n325\t  // -----------------------------------------------------------------------\n326\t\n327\t  /**\n328\t   * Settle a single round. Returns true on success.\n329\t   */\n330\t  async function settleRound(\n331\t    roundPda: PublicKey,\n332\t    minuteTs: bigint,\n333\t    round: ReturnType<typeof decodeCloseCallRound>,\n334\t  ): Promise<boolean> {\n335\t    try {\n336\t      const nowSec = Math.floor(Date.now() / 1000);\n337\t      const candleCloseTime = Number(minuteTs) + 60;\n338\t\n339\t      if (nowSec < candleCloseTime) {\n340\t        logger.debug(\"closecall clock: candle not closed yet\", {\n341\t          pda: roundPda.toBase58(),\n342\t          secondsRemaining: candleCloseTime - nowSec,\n343\t        });\n344\t        return false;\n345\t      }\n346\t\n347\t      const greenCount = round.greenEntries.length;\n348\t      const redCount = round.redEntries.length;\n349\t      const totalCount = greenCount + redCount;\n350\t\n351\t      // Fetch platform config (treasury + feeBps) + close price\n352\t      const [platformConfig, hermesPrice] = await Promise.all([\n353\t        readPlatformConfig(),\n354\t        hermes.fetchLatestBtcPrice(),\n355\t      ]);\n356\t\n357\t      if (!platformConfig) {\n358\t        logger.error(\"closecall clock: cannot read platform config treasury\");\n359\t        return false;\n360\t      }\n361\t      const { treasury, feeBps } = platformConfig;\n362\t      if (!hermesPrice) {\n363\t        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n364\t        return false;\n365\t      }\n366\t\n367\t      if (totalCount === 0) {\n368\t        logger.info(\"closecall clock: settling empty round\", {\n369\t          pda: roundPda.toBase58(),\n370\t        });\n371\t      }\n372\t\n373\t      // Pre-determine outcome\n374\t      const hasBothSides = greenCount > 0 && redCount > 0;\n375\t      const isRefund =\n376\t        totalCount === 0 ||\n377\t        !hasBothSides ||\n378\t        totalCount === 1 ||\n379\t        hermesPrice.price === round.openPrice;\n380\t\n381\t      let remainingAccounts: PublicKey[];\n382\t      if (isRefund) {\n383\t        remainingAccounts = [\n384\t          ...round.greenEntries.map((e) => e.player),\n385\t          ...round.redEntries.map((e) => e.player),\n386\t        ];\n387\t      } else if (hermesPrice.price > round.openPrice) {\n388\t        remainingAccounts = round.greenEntries.map((e) => e.player);\n389\t      } else {\n390\t        remainingAccounts = round.redEntries.map((e) => e.player);\n391\t      }\n392\t\n393\t      const ix = buildCloseCallSettleRoundIx(\n394\t        serverKeypair.publicKey,\n395\t        minuteTs,\n396\t        hermesPrice.price,\n397\t        hermesPrice.expo,\n398\t        treasury,\n399\t        remainingAccounts,\n400\t      );\n401\t\n402\t      const { blockhash, lastValidBlockHeight } =\n403\t        await connection.getLatestBlockhash();\n404\t      const tx = new Transaction({\n405\t        feePayer: serverKeypair.publicKey,\n406\t        blockhash,\n407\t        lastValidBlockHeight,\n408\t      });\n409\t      tx.add(ix);\n410\t      tx.sign(serverKeypair);\n411\t\n412\t      const sig = await sendAndConfirm(tx, \"settle\", blockhash, lastValidBlockHeight);\n413\t\n414\t      const outcomeStr = isRefund\n415\t        ? \"refund\"\n416\t        : hermesPrice.price > round.openPrice\n417\t          ? \"green\"\n418\t          : \"red\";\n419\t\n420\t      logger.info(\"closecall clock: round settled\", {\n421\t        pda: roundPda.toBase58(),\n422\t        tx: sig,\n423\t        totalEntries: totalCount,\n424\t        outcome: outcomeStr,\n425\t      });\n426\t\n427\t      // Persist settlement to DB (atomic transaction)\n428\t      try {\n429\t        const greenEntries = round.greenEntries.map((e) => ({\n430\t          player: e.player.toBase58(),\n431\t          amountLamports: Number(e.amountLamports),\n432\t        }));\n433\t        const redEntries = round.redEntries.map((e) => ({\n434\t          player: e.player.toBase58(),\n435\t          amountLamports: Number(e.amountLamports),\n436\t        }));\n437\t\n438\t        const totalPool = Number(round.greenPool) + Number(round.redPool);\n439\t        const computedFee = isRefund ? 0 : Math.floor(totalPool * feeBps / 10_000);\n440\t        const netPool = totalPool - computedFee;\n441\t        const roundId = String(Number(minuteTs));\n442\t        const pdaStr = roundPda.toBase58();\n443\t\n444\t        await db.withTransaction(async (txDb) => {\n445\t          // Ensure round record exists\n446\t          await txDb.insertCloseCallRound({\n447\t            roundId,\n448\t            pda: pdaStr,\n449\t            serverKey: serverKeypair.publicKey.toBase58(),\n450\t            openPrice: Number(round.openPrice),\n451\t            openPriceExpo: round.openPriceExpo,\n452\t          });\n453\t\n454\t          // Settle round\n455\t          await txDb.settleCloseCallRound(roundId, {\n456\t            phase: isRefund ? \"refunded\" : \"settled\",\n457\t            outcome: outcomeStr as \"green\" | \"red\" | \"refund\",\n458\t            closePrice: Number(hermesPrice.price),\n459\t            greenPool: Number(round.greenPool),\n460\t            redPool: Number(round.redPool),\n461\t            totalFee: computedFee,\n462\t            settleTx: sig,\n463\t          });\n464\t\n465\t          // Resolve profiles for all participants (used by both tx inserts and game entries)\n466\t          const allEntries = [\n467\t            ...greenEntries.map((e) => ({ ...e, side: \"green\" as const })),\n468\t            ...redEntries.map((e) => ({ ...e, side: \"red\" as const })),\n469\t          ];\n470\t\n471\t          const profileResults = allEntries.length > 0\n472\t            ? await Promise.all(\n473\t                allEntries.map(async (e) => {\n474\t                  const profile = await txDb.getProfileByWallet(e.player);\n475\t                  return [e.player, profile] as const;\n476\t                }),\n477\t              )\n478\t            : [];\n479\t          const profileMap = new Map(\n480\t            profileResults.filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1]),\n481\t          );\n482\t\n483\t          // Transaction rows — real SOL movements\n484\t          const txParams: Array<{\n485\t            userId?: string;\n486\t            wallet: string;\n487\t            game: string;\n488\t            matchId: string;\n489\t            txType: \"deposit\" | \"payout\" | \"refund\";\n490\t            amountLamports: number;\n491\t            txSig: string;\n492\t          }> = [];\n493\t\n494\t          for (const entry of greenEntries) {\n495\t            const userId = profileMap.get(entry.player)?.user_id;\n496\t            if (isRefund) {\n497\t              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n498\t            } else if (outcomeStr === \"green\") {\n499\t              const greenPool = Number(round.greenPool);\n500\t              const payout = greenPool > 0 ? Math.floor((entry.amountLamports / greenPool) * netPool) : 0;\n501\t              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n502\t            }\n503\t          }\n504\t          for (const entry of redEntries) {\n505\t            const userId = profileMap.get(entry.player)?.user_id;\n506\t            if (isRefund) {\n507\t              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n508\t            } else if (outcomeStr === \"red\") {\n509\t              const redPool = Number(round.redPool);\n510\t              const payout = redPool > 0 ? Math.floor((entry.amountLamports / redPool) * netPool) : 0;\n511\t              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n512\t            }\n513\t          }\n514\t\n515\t          if (txParams.length > 0) {\n516\t            await txDb.insertTransactions(txParams);\n517\t          }\n518\t\n519\t          // Game entries — UPSERT with settlement result\n520\t          if (allEntries.length > 0) {\n521\t            const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);\n522\t            if (missingWallets.length > 0) {\n523\t              logger.warn(\"closecall settle: missing profiles for participants — skipping their game entries\", {\n524\t                pda: pdaStr,\n525\t                missingWallets,\n526\t              });\n527\t            }\n528\t            const profileMap = new Map(\n529\t              profileResults\n530\t                .filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1])\n531\t                .map(([w, p]) => [w, p.user_id]),\n532\t            );\n533\t\n534\t            const gameEntries = allEntries\n535\t              .filter((e) => profileMap.has(e.player))\n536\t              .map((e) => {\n537\t                let entryIsWinner: boolean | undefined;\n538\t                let entryPayout: number;\n539\t\n540\t                if (isRefund) {\n541\t                  entryIsWinner = undefined; // null = refund, no winner/loser\n542\t                  entryPayout = e.amountLamports;\n543\t                } else {\n544\t                  const isWinningSide = e.side === outcomeStr;\n545\t                  entryIsWinner = isWinningSide;\n546\t                  if (isWinningSide) {\n547\t                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n548\t                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n549\t                  } else {\n550\t                    entryPayout = 0;\n551\t                  }\n552\t                }\n553\t\n554\t                return {\n555\t                  userId: profileMap.get(e.player)!,\n556\t                  wallet: e.player,\n557\t                  game: \"closecall\",\n558\t                  roundPda: pdaStr,\n559\t                  matchId: roundId,\n560\t                  amountLamports: e.amountLamports,\n561\t                  side: e.side,\n562\t                  isWinner: entryIsWinner,\n563\t                  payoutLamports: entryPayout,\n564\t                  settledAt: new Date(),\n565\t                };\n566\t              });\n567\t\n568\t            if (gameEntries.length > 0) {\n569\t              await txDb.upsertGameEntries(gameEntries);\n570\t            }\n571\t          }\n572\t\n573\t          // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n574\t          if (allEntries.length > 0) {\n575\t            const settledAt = new Date().toISOString();\n576\t            // Build per-player entries; for closecall, no single \"creator\" — first entry is treated as creator\n577\t            const firstPlayer = allEntries[0]?.player;\n578\t\n579\t            const players = allEntries\n580\t              .filter((e) => profileMap.has(e.player))\n581\t              .map((e) => {\n582\t                const userId = profileMap.get(e.player)!.user_id;\n583\t                let entryIsWinner: boolean | null;\n584\t                let entryPayout: number;\n585\t\n586\t                if (isRefund) {\n587\t                  entryIsWinner = null; // null = refund\n588\t                  entryPayout = e.amountLamports;\n589\t                } else {\n590\t                  const isWinningSide = e.side === outcomeStr;\n591\t                  entryIsWinner = isWinningSide;\n592\t                  if (isWinningSide) {\n593\t                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n594\t                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n595\t                  } else {\n596\t                    entryPayout = 0;\n597\t                  }\n598\t                }\n599\t\n600\t                return {\n601\t                  userId,\n602\t                  wallet: e.player,\n603\t                  amountLamports: String(e.amountLamports),\n604\t                  isWinner: entryIsWinner,\n605\t                  payoutLamports: String(entryPayout),\n606\t                  isCreator: e.player === firstPlayer,\n607\t                };\n608\t              });\n609\t\n610\t            if (players.length > 0) {\n611\t              await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n612\t                roundId,\n613\t                roundPda: pdaStr,\n614\t                game: \"closecall\",\n615\t                players,\n616\t                feeLamports: String(computedFee),\n617\t                settledAt,\n618\t              });\n619\t\n620\t              // Emit ticker publish for the on-site news ticker (skip refunds)\n621\t              if (!isRefund && (outcomeStr === \"green\" || outcomeStr === \"red\")) {\n622\t                await emitEvent(txDb.rawSql, EventTypes.TICKER_PUBLISH, {\n623\t                  kind: \"closecall.round_settled\",\n624\t                  winningSide: outcomeStr,\n625\t                  roundNumber: Number(minuteTs),\n626\t                  poolLamports: String(totalPool),\n627\t                });\n628\t              }\n629\t            }\n630\t          }\n631\t        });\n632\t      } catch (dbErr) {\n633\t        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n634\t          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n635\t        });\n636\t      }\n637\t\n638\t      return true;\n639\t    } catch (err) {\n640\t      logger.error(\"closecall clock: settlement failed\", {\n641\t        pda: roundPda.toBase58(),\n642\t        error: err instanceof Error ? err.message : String(err),\n643\t      });\n644\t      return false;\n645\t    }\n646\t  }\n647\t\n648\t  // -----------------------------------------------------------------------\n649\t  // Tick — fires at minute boundary + 1s\n650\t  // -----------------------------------------------------------------------\n651\t\n652\t  async function tick(): Promise<void> {\n653\t    const t0 = performance.now();\n654\t    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n655\t\n656\t    // Step 1: Capture boundary price (poll Hermes until fresh)\n657\t    await captureBoundaryPrice(boundaryTs);\n658\t\n659\t    // Step 2: Discover + settle all open rounds whose candle has closed\n660\t    const openRounds = await discoverOpenRounds();\n661\t\n662\t    for (const { pda, minuteTs, round } of openRounds) {\n663\t      await settleRound(pda, minuteTs, round);\n664\t    }\n665\t\n666\t    const elapsed = Math.round(performance.now() - t0);\n667\t    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n668\t  }\n669\t\n670\t  async function loop(): Promise<void> {\n671\t    if (!running) return;\n672\t    try {\n673\t      await tick();\n674\t    } catch (err) {\n675\t      logger.error(\"closecall clock loop error\", {\n676\t        error: err instanceof Error ? err.message : String(err),\n677\t      });\n678\t    }\n679\t    if (running) {\n680\t      const delay = msUntilNextBoundary();\n681\t      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n682\t      timeoutId = setTimeout(loop, delay);\n683\t    }\n684\t  }\n685\t\n686\t  // -----------------------------------------------------------------------\n687\t  // Public interface\n688\t  // -----------------------------------------------------------------------\n689\t\n690\t  return {\n691\t    start() {\n692\t      if (running) return;\n693\t      running = true;\n694\t\n695\t      logger.info(\"closecall clock started\", {\n696\t        serverKey: serverKeypair.publicKey.toBase58(),\n697\t        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n698\t      });\n699\t\n700\t      // Load latest boundary price from DB, then schedule first tick\n701\t      loadLatestBoundaryFromDb()\n702\t        .then(() => {\n703\t          if (!running) return;\n704\t          const delay = msUntilNextBoundary();\n705\t          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n706\t          timeoutId = setTimeout(loop, delay);\n707\t        })\n708\t        .catch((err) => {\n709\t          logger.error(\"closecall clock: startup init failed\", {\n710\t            error: err instanceof Error ? err.message : String(err),\n711\t          });\n712\t          if (running) {\n713\t            const delay = msUntilNextBoundary();\n714\t            timeoutId = setTimeout(loop, delay);\n715\t          }\n716\t        });\n717\t    },\n718\t\n719\t    stop() {\n720\t      running = false;\n721\t      if (timeoutId) {\n722\t        clearTimeout(timeoutId);\n723\t        timeoutId = null;\n724\t      }\n725\t      logger.info(\"closecall clock stopped\");\n726\t    },\n727\t\n728\t    get isRunning() {\n729\t      return running;\n730\t    },\n731\t\n732\t    tick,\n733\t\n734\t    getLatestBoundaryPrice(): BoundaryPrice | null {\n735\t      return cachedBoundaryPrice;\n736\t    },\n737\t  };\n738\t}\n739\t"}]},"parent_tool_use_id":null,"session_id":"e3c7d110-2ea6-42c9-849d-99f9f7e2fbbb","uuid":"ed78fcce-3683-4eb3-bb5c-55ecd6c970d0","timestamp":"2026-05-01T19:59:44.261Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/worker/closecall-clock.ts","content":"/**\n * Close Call clock worker — precise minute-boundary price capture + settlement.\n *\n * Scheduling:\n *   - Tick fires at minute boundary + 1s (e.g., 19:43:01)\n *   - Polls Hermes every 1s until we get a price with publishTime >= boundary\n *   - Caches the boundary price (both close of old candle, open of next)\n *   - Settles any open rounds whose candle has closed\n *   - Schedules next tick at (next minute + 1s)\n *\n * Rounds are created on-demand by the first bettor (via /closecall/bet).\n * On start, loads the latest boundary price from DB to seed the cache.\n */\n\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { getPlatformConfig } from \"../platform-config.js\";\nimport {\n  buildCloseCallSettleRoundIx,\n} from \"./settle-tx.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport {\n  closeCallRoundDiscriminatorFilter,\n  decodeCloseCallRound,\n} from \"./account-decoder.js\";\nimport { createHermesFetcher, type HermesFetcher } from \"./pyth-poster.js\";\n\n/** Close Call on-chain phase values */\nconst PHASE_OPEN = 0;\n\n/** How long to wait after minute boundary before first Hermes poll (ms). */\nconst BOUNDARY_OFFSET_MS = 1_000;\n\n/** Poll Hermes every 1s when waiting for boundary price. */\nconst HERMES_POLL_INTERVAL_MS = 1_000;\n\n/** Max attempts to fetch a fresh boundary price (10s total). */\nconst HERMES_MAX_RETRIES = 10;\n\n/** Maximum retry attempts for a single tx submission. */\nconst MAX_TX_RETRIES = 3;\nconst TX_RETRY_DELAY_MS = 2_000;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface BoundaryPrice {\n  price: bigint;\n  expo: number;\n  minuteTs: number;\n  priceHuman: number;\n}\n\nexport interface CloseCallClockDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n  /** Typed database client. */\n  db: Db;\n  /** Hermes endpoint (defaults to https://hermes.pyth.network). */\n  hermesEndpoint?: string;\n  /** Optional injectable HermesFetcher (for testing). */\n  hermesFetcher?: HermesFetcher;\n}\n\nexport interface CloseCallClockWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single tick (exposed for testing). */\n  tick(): Promise<void>;\n  /** Get the most recent minute-boundary price (from cache). */\n  getLatestBoundaryPrice(): BoundaryPrice | null;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nexport function createCloseCallClockWorker(\n  deps: CloseCallClockDeps,\n): CloseCallClockWorker {\n  const { connection, serverKeypair, hermesEndpoint, db } = deps;\n\n  const hermes: HermesFetcher = deps.hermesFetcher ?? createHermesFetcher(hermesEndpoint);\n\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  /** Cached latest boundary price (in-memory). */\n  let cachedBoundaryPrice: BoundaryPrice | null = null;\n\n  // -----------------------------------------------------------------------\n  // Scheduling\n  // -----------------------------------------------------------------------\n\n  /** Milliseconds until the next minute boundary + offset. */\n  function msUntilNextBoundary(): number {\n    const now = Date.now();\n    const nextMinute = Math.ceil(now / 60_000) * 60_000;\n    return nextMinute - now + BOUNDARY_OFFSET_MS;\n  }\n\n  // -----------------------------------------------------------------------\n  // Helpers\n  // -----------------------------------------------------------------------\n\n  /** Send a legacy Transaction with retry. Uses the tx's original blockhash for confirmation. */\n  async function sendAndConfirm(\n    tx: Transaction,\n    label: string,\n    txBlockhash: string,\n    txLastValidBlockHeight: number,\n  ): Promise<string> {\n    let lastError: unknown;\n\n    for (let attempt = 0; attempt < MAX_TX_RETRIES; attempt++) {\n      try {\n        const sig = await connection.sendRawTransaction(tx.serialize(), {\n          skipPreflight: false,\n        });\n        const confirmation = await connection.confirmTransaction(\n          { signature: sig, blockhash: txBlockhash, lastValidBlockHeight: txLastValidBlockHeight },\n          \"confirmed\",\n        );\n        if (confirmation.value.err) {\n          throw new Error(\n            `${label} tx ${sig} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n          );\n        }\n        return sig;\n      } catch (err) {\n        lastError = err;\n        if (attempt < MAX_TX_RETRIES - 1) {\n          logger.warn(`closecall clock: ${label} tx attempt ${attempt + 1} failed, retrying`, {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          await new Promise((r) => setTimeout(r, TX_RETRY_DELAY_MS));\n        }\n      }\n    }\n\n    throw lastError;\n  }\n\n  /** Read treasury and feeBps from the shared PlatformConfig account. */\n  async function readPlatformConfig(): Promise<{ treasury: PublicKey; feeBps: number } | null> {\n    try {\n      return await getPlatformConfig(connection);\n    } catch {\n      return null;\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Candle DB operations\n  // -----------------------------------------------------------------------\n\n  /** Save a boundary price to the closecall_candles table (upsert). */\n  async function saveBoundaryPrice(\n    minuteTs: number,\n    price: bigint,\n    expo: number,\n    priceHuman: number,\n    hermesVaa: string | null,\n  ): Promise<void> {\n    try {\n      await db.insertCloseCallCandle(minuteTs, price, expo, priceHuman, hermesVaa);\n    } catch (err) {\n      logger.error(\"closecall clock: failed to save boundary price\", {\n        minuteTs,\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  /** Load the latest boundary price from DB (for startup cache seeding). */\n  async function loadLatestBoundaryFromDb(): Promise<void> {\n    try {\n      const candle = await db.getLatestCloseCallCandle();\n      if (candle) {\n        cachedBoundaryPrice = {\n          price: candle.price,\n          expo: candle.expo,\n          minuteTs: candle.minuteTs,\n          priceHuman: candle.priceHuman,\n        };\n        logger.info(\"closecall clock: loaded boundary price from DB\", {\n          minuteTs: cachedBoundaryPrice.minuteTs,\n          priceHuman: cachedBoundaryPrice.priceHuman,\n        });\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: failed to load boundary price from DB\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Boundary price capture — poll Hermes until fresh price arrives\n  // -----------------------------------------------------------------------\n\n  /**\n   * Poll Hermes every 1s until we get a price with publishTime >= boundaryTs.\n   * Returns the captured price or null if max retries exceeded.\n   */\n  async function captureBoundaryPrice(\n    boundaryTs: number,\n  ): Promise<BoundaryPrice | null> {\n    for (let attempt = 0; attempt < HERMES_MAX_RETRIES; attempt++) {\n      try {\n        const result = await hermes.fetchLatestBtcPrice();\n        if (result && result.publishTime >= boundaryTs) {\n          const bp: BoundaryPrice = {\n            price: result.price,\n            expo: result.expo,\n            minuteTs: boundaryTs,\n            priceHuman: result.priceHuman,\n          };\n\n          // Save to DB with VAA proof\n          await saveBoundaryPrice(\n            boundaryTs,\n            result.price,\n            result.expo,\n            result.priceHuman,\n            result.vaaBase64,\n          );\n\n          cachedBoundaryPrice = bp;\n\n          logger.info(\"closecall clock: boundary price captured\", {\n            minuteTs: boundaryTs,\n            priceHuman: result.priceHuman,\n            publishTime: result.publishTime,\n            attempts: attempt + 1,\n          });\n\n          return bp;\n        }\n\n        if (result) {\n          logger.debug(\"closecall clock: Hermes price not yet at boundary\", {\n            publishTime: result.publishTime,\n            boundaryTs,\n            attempt: attempt + 1,\n          });\n        }\n      } catch (err) {\n        logger.warn(\"closecall clock: Hermes poll failed\", {\n          attempt: attempt + 1,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n\n      // Wait 1s before next attempt\n      if (attempt < HERMES_MAX_RETRIES - 1) {\n        await new Promise((r) => setTimeout(r, HERMES_POLL_INTERVAL_MS));\n      }\n    }\n\n    logger.warn(\"closecall clock: failed to capture boundary price after max retries\", {\n      boundaryTs,\n    });\n    return null;\n  }\n\n  // -----------------------------------------------------------------------\n  // Round discovery\n  // -----------------------------------------------------------------------\n\n  /**\n   * Discover ALL existing open rounds owned by this server.\n   */\n  async function discoverOpenRounds(): Promise<\n    Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }>\n  > {\n    const results: Array<{ pda: PublicKey; minuteTs: bigint; round: ReturnType<typeof decodeCloseCallRound> }> = [];\n    try {\n      const accounts = await connection.getProgramAccounts(\n        CLOSECALL_PROGRAM_ID,\n        { filters: [closeCallRoundDiscriminatorFilter()] },\n      );\n\n      const now = Math.floor(Date.now() / 1000);\n\n      for (const { pubkey, account } of accounts) {\n        try {\n          const round = decodeCloseCallRound(Buffer.from(account.data));\n\n          // Skip rounds with garbage minuteTs (old format / random bytes)\n          const ts = Number(round.minuteTs);\n          if (ts < 1700000000 || ts > now + 120) continue;\n\n          if (\n            round.phase === PHASE_OPEN &&\n            round.server.equals(serverKeypair.publicKey)\n          ) {\n            results.push({ pda: pubkey, minuteTs: round.minuteTs, round });\n          }\n        } catch {\n          // Skip undecodeable accounts\n        }\n      }\n    } catch (err) {\n      logger.warn(\"closecall clock: discovery scan failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    return results;\n  }\n\n  // -----------------------------------------------------------------------\n  // Settlement\n  // -----------------------------------------------------------------------\n\n  /**\n   * Settle a single round. Returns true on success.\n   */\n  async function settleRound(\n    roundPda: PublicKey,\n    minuteTs: bigint,\n    round: ReturnType<typeof decodeCloseCallRound>,\n  ): Promise<boolean> {\n    try {\n      const nowSec = Math.floor(Date.now() / 1000);\n      const candleCloseTime = Number(minuteTs) + 60;\n\n      if (nowSec < candleCloseTime) {\n        logger.debug(\"closecall clock: candle not closed yet\", {\n          pda: roundPda.toBase58(),\n          secondsRemaining: candleCloseTime - nowSec,\n        });\n        return false;\n      }\n\n      const greenCount = round.greenEntries.length;\n      const redCount = round.redEntries.length;\n      const totalCount = greenCount + redCount;\n\n      // Fetch platform config (treasury + feeBps) + close price\n      const [platformConfig, hermesPrice] = await Promise.all([\n        readPlatformConfig(),\n        hermes.fetchLatestBtcPrice(),\n      ]);\n\n      if (!platformConfig) {\n        logger.error(\"closecall clock: cannot read platform config treasury\");\n        return false;\n      }\n      const { treasury, feeBps } = platformConfig;\n      if (!hermesPrice) {\n        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n        return false;\n      }\n\n      if (totalCount === 0) {\n        logger.info(\"closecall clock: settling empty round\", {\n          pda: roundPda.toBase58(),\n        });\n      }\n\n      // Pre-determine outcome\n      const hasBothSides = greenCount > 0 && redCount > 0;\n      const isRefund =\n        totalCount === 0 ||\n        !hasBothSides ||\n        totalCount === 1 ||\n        hermesPrice.price === round.openPrice;\n\n      let remainingAccounts: PublicKey[];\n      if (isRefund) {\n        remainingAccounts = [\n          ...round.greenEntries.map((e) => e.player),\n          ...round.redEntries.map((e) => e.player),\n        ];\n      } else if (hermesPrice.price > round.openPrice) {\n        remainingAccounts = round.greenEntries.map((e) => e.player);\n      } else {\n        remainingAccounts = round.redEntries.map((e) => e.player);\n      }\n\n      const ix = buildCloseCallSettleRoundIx(\n        serverKeypair.publicKey,\n        minuteTs,\n        hermesPrice.price,\n        hermesPrice.expo,\n        treasury,\n        remainingAccounts,\n      );\n\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash();\n      const tx = new Transaction({\n        feePayer: serverKeypair.publicKey,\n        blockhash,\n        lastValidBlockHeight,\n      });\n      tx.add(ix);\n      tx.sign(serverKeypair);\n\n      const sig = await sendAndConfirm(tx, \"settle\", blockhash, lastValidBlockHeight);\n\n      const outcomeStr = isRefund\n        ? \"refund\"\n        : hermesPrice.price > round.openPrice\n          ? \"green\"\n          : \"red\";\n\n      logger.info(\"closecall clock: round settled\", {\n        pda: roundPda.toBase58(),\n        tx: sig,\n        totalEntries: totalCount,\n        outcome: outcomeStr,\n      });\n\n      // Persist settlement to DB (atomic transaction)\n      try {\n        const greenEntries = round.greenEntries.map((e) => ({\n          player: e.player.toBase58(),\n          amountLamports: Number(e.amountLamports),\n        }));\n        const redEntries = round.redEntries.map((e) => ({\n          player: e.player.toBase58(),\n          amountLamports: Number(e.amountLamports),\n        }));\n\n        const totalPool = Number(round.greenPool) + Number(round.redPool);\n        const computedFee = isRefund ? 0 : Math.floor(totalPool * feeBps / 10_000);\n        const netPool = totalPool - computedFee;\n        const roundId = String(Number(minuteTs));\n        const pdaStr = roundPda.toBase58();\n\n        await db.withTransaction(async (txDb) => {\n          // Ensure round record exists\n          await txDb.insertCloseCallRound({\n            roundId,\n            pda: pdaStr,\n            serverKey: serverKeypair.publicKey.toBase58(),\n            openPrice: Number(round.openPrice),\n            openPriceExpo: round.openPriceExpo,\n          });\n\n          // Settle round\n          await txDb.settleCloseCallRound(roundId, {\n            phase: isRefund ? \"refunded\" : \"settled\",\n            outcome: outcomeStr as \"green\" | \"red\" | \"refund\",\n            closePrice: Number(hermesPrice.price),\n            greenPool: Number(round.greenPool),\n            redPool: Number(round.redPool),\n            totalFee: computedFee,\n            settleTx: sig,\n          });\n\n          // Resolve profiles for all participants (used by both tx inserts and game entries)\n          const allEntries = [\n            ...greenEntries.map((e) => ({ ...e, side: \"green\" as const })),\n            ...redEntries.map((e) => ({ ...e, side: \"red\" as const })),\n          ];\n\n          const profileResults = allEntries.length > 0\n            ? await Promise.all(\n                allEntries.map(async (e) => {\n                  const profile = await txDb.getProfileByWallet(e.player);\n                  return [e.player, profile] as const;\n                }),\n              )\n            : [];\n          const profileMap = new Map(\n            profileResults.filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1]),\n          );\n\n          // Transaction rows — real SOL movements\n          const txParams: Array<{\n            userId?: string;\n            wallet: string;\n            game: string;\n            matchId: string;\n            txType: \"deposit\" | \"payout\" | \"refund\";\n            amountLamports: number;\n            txSig: string;\n          }> = [];\n\n          for (const entry of greenEntries) {\n            const userId = profileMap.get(entry.player)?.user_id;\n            if (isRefund) {\n              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n            } else if (outcomeStr === \"green\") {\n              const greenPool = Number(round.greenPool);\n              const payout = greenPool > 0 ? Math.floor((entry.amountLamports / greenPool) * netPool) : 0;\n              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n            }\n          }\n          for (const entry of redEntries) {\n            const userId = profileMap.get(entry.player)?.user_id;\n            if (isRefund) {\n              txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"refund\", amountLamports: entry.amountLamports, txSig: sig });\n            } else if (outcomeStr === \"red\") {\n              const redPool = Number(round.redPool);\n              const payout = redPool > 0 ? Math.floor((entry.amountLamports / redPool) * netPool) : 0;\n              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n            }\n          }\n\n          if (txParams.length > 0) {\n            await txDb.insertTransactions(txParams);\n          }\n\n          // Game entries — UPSERT with settlement result\n          if (allEntries.length > 0) {\n            const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);\n            if (missingWallets.length > 0) {\n              logger.warn(\"closecall settle: missing profiles for participants — skipping their game entries\", {\n                pda: pdaStr,\n                missingWallets,\n              });\n            }\n            const profileMap = new Map(\n              profileResults\n                .filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1])\n                .map(([w, p]) => [w, p.user_id]),\n            );\n\n            const gameEntries = allEntries\n              .filter((e) => profileMap.has(e.player))\n              .map((e) => {\n                let entryIsWinner: boolean | undefined;\n                let entryPayout: number;\n\n                if (isRefund) {\n                  entryIsWinner = undefined; // null = refund, no winner/loser\n                  entryPayout = e.amountLamports;\n                } else {\n                  const isWinningSide = e.side === outcomeStr;\n                  entryIsWinner = isWinningSide;\n                  if (isWinningSide) {\n                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n                  } else {\n                    entryPayout = 0;\n                  }\n                }\n\n                return {\n                  userId: profileMap.get(e.player)!,\n                  wallet: e.player,\n                  game: \"closecall\",\n                  roundPda: pdaStr,\n                  matchId: roundId,\n                  amountLamports: e.amountLamports,\n                  side: e.side,\n                  isWinner: entryIsWinner,\n                  payoutLamports: entryPayout,\n                  settledAt: new Date(),\n                };\n              });\n\n            if (gameEntries.length > 0) {\n              await txDb.upsertGameEntries(gameEntries);\n            }\n          }\n\n          // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n          if (allEntries.length > 0) {\n            const settledAt = new Date().toISOString();\n            // Build per-player entries; for closecall, no single \"creator\" — first entry is treated as creator\n            const firstPlayer = allEntries[0]?.player;\n\n            const players = allEntries\n              .filter((e) => profileMap.has(e.player))\n              .map((e) => {\n                const userId = profileMap.get(e.player)!.user_id;\n                let entryIsWinner: boolean | null;\n                let entryPayout: number;\n\n                if (isRefund) {\n                  entryIsWinner = null; // null = refund\n                  entryPayout = e.amountLamports;\n                } else {\n                  const isWinningSide = e.side === outcomeStr;\n                  entryIsWinner = isWinningSide;\n                  if (isWinningSide) {\n                    const pool = e.side === \"green\" ? Number(round.greenPool) : Number(round.redPool);\n                    entryPayout = pool > 0 ? Math.floor((e.amountLamports / pool) * netPool) : 0;\n                  } else {\n                    entryPayout = 0;\n                  }\n                }\n\n                return {\n                  userId,\n                  wallet: e.player,\n                  amountLamports: String(e.amountLamports),\n                  isWinner: entryIsWinner,\n                  payoutLamports: String(entryPayout),\n                  isCreator: e.player === firstPlayer,\n                };\n              });\n\n            if (players.length > 0) {\n              await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n                roundId,\n                roundPda: pdaStr,\n                game: \"closecall\",\n                players,\n                feeLamports: String(computedFee),\n                settledAt,\n              });\n\n              // Emit ticker publish for the on-site news ticker (skip refunds)\n              if (!isRefund && (outcomeStr === \"green\" || outcomeStr === \"red\")) {\n                await emitEvent(txDb.rawSql, EventTypes.TICKER_PUBLISH, {\n                  kind: \"closecall.round_settled\",\n                  winningSide: outcomeStr,\n                  roundNumber: Number(minuteTs),\n                  poolLamports: String(totalPool),\n                });\n              }\n            }\n          }\n        });\n      } catch (dbErr) {\n        logger.warn(\"closecall clock: DB persist failed (settlement still on-chain)\", {\n          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n        });\n      }\n\n      return true;\n    } catch (err) {\n      logger.error(\"closecall clock: settlement failed\", {\n        pda: roundPda.toBase58(),\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return false;\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Tick — fires at minute boundary + 1s\n  // -----------------------------------------------------------------------\n\n  async function tick(): Promise<void> {\n    const t0 = performance.now();\n    const boundaryTs = Math.floor(Date.now() / 60_000) * 60;\n\n    // Step 1: Capture boundary price (poll Hermes until fresh)\n    await captureBoundaryPrice(boundaryTs);\n\n    // Step 2: Discover + settle all open rounds whose candle has closed\n    const openRounds = await discoverOpenRounds();\n\n    for (const { pda, minuteTs, round } of openRounds) {\n      await settleRound(pda, minuteTs, round);\n    }\n\n    const elapsed = Math.round(performance.now() - t0);\n    logger.debug(\"closecall clock tick\", { elapsedMs: elapsed, boundaryTs, openRounds: openRounds.length });\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await tick();\n    } catch (err) {\n      logger.error(\"closecall clock loop error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      const delay = msUntilNextBoundary();\n      logger.debug(\"closecall clock: next tick scheduled\", { delayMs: delay });\n      timeoutId = setTimeout(loop, delay);\n    }\n  }\n\n  // -----------------------------------------------------------------------\n  // Public interface\n  // -----------------------------------------------------------------------\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n\n      logger.info(\"closecall clock started\", {\n        serverKey: serverKeypair.publicKey.toBase58(),\n        hermesEndpoint: hermesEndpoint ?? \"https://hermes.pyth.network\",\n      });\n\n      // Load latest boundary price from DB, then schedule first tick\n      loadLatestBoundaryFromDb()\n        .then(() => {\n          if (!running) return;\n          const delay = msUntilNextBoundary();\n          logger.info(\"closecall clock: first tick scheduled\", { delayMs: delay });\n          timeoutId = setTimeout(loop, delay);\n        })\n        .catch((err) => {\n          logger.error(\"closecall clock: startup init failed\", {\n            error: err instanceof Error ? err.message : String(err),\n          });\n          if (running) {\n            const delay = msUntilNextBoundary();\n            timeoutId = setTimeout(loop, delay);\n          }\n        });\n    },\n\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"closecall clock stopped\");\n    },\n\n    get isRunning() {\n      return running;\n    },\n\n    tick,\n\n    getLatestBoundaryPrice(): BoundaryPrice | null {\n      return cachedBoundaryPrice;\n    },\n  };\n}\n","numLines":739,"startLine":1,"totalLines":739}}}
