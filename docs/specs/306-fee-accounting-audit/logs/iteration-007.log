\"./routes/points.js\";\nimport { createEventRoutes } from \"./routes/events.js\";\nimport { createAdminRoutes } from \"./routes/admin.js\";\nimport { createTelegramLinkRoutes } from \"./routes/telegram-link.js\";\nimport { swaggerUI } from \"@hono/swagger-ui\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\nimport { createEventStatusWorker } from \"./worker/event-status-worker.js\";\nimport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\nimport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\nimport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\nimport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\nimport { createCrateSolPayoutHandler } from \"./queue/handlers/crate-sol-payout.js\";\nimport { createProfileUsernameSetHandler } from \"./queue/handlers/profile-username-set.js\";\nimport { createTickerPublishHandler } from \"./queue/handlers/ticker-publish.js\";\nimport { fetchSolPrice } from \"./routes/price.js\";\nimport { CloudflareImagesClient } from \"./lib/cloudflare-images.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Single postgres pool shared by game DB, auth DB, and all workers\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl, sql);\nconst authDb = createAuthDb(sql);\n\nconst cloudflareImages = new CloudflareImagesClient({\n  accountId: config.cloudflareAccountId,\n  token: config.cloudflareImagesToken,\n});\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new OpenAPIHono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Key\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    db,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    authWhitelistEnabled: config.authWhitelistEnabled,\n  }),\n);\n\n// Profile routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/profile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\n  \"/profile\",\n  createProfileRoutes({\n    db,\n    cloudflareImages,\n    cloudflareAccountHash: config.cloudflareAccountHash,\n    cloudflareImagesVariant: config.cloudflareImagesVariant,\n  }),\n);\n\n// Public profile routes — no auth required\napp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\napp.route(\"/public-referral\", createPublicReferralRoutes({ db }));\n\n// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\napp.use(\n  \"/referral/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/flip-you/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n// JWT auth middleware for game endpoints\napp.use(\n  \"/flip-you/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/pot-shot/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\napp.use(\n  \"/pot-shot/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  db,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Close Call clock worker — fetches boundary prices + settles open rounds\n// Rounds are created on-demand by players via /closecall/bet\nconst closeCallClock = createCloseCallClockWorker({\n  connection,\n  serverKeypair: config.serverKeypair,\n  db,\n});\ncloseCallClock.start();\n\n// Register event handlers before starting the worker\nregisterHandler(\n  EventTypes.REFERRAL_CLAIM_REQUESTED,\n  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\nregisterHandler(\n  EventTypes.GAME_SETTLED,\n  createGameSettledHandler({ db }),\n);\nregisterHandler(\n  EventTypes.REWARD_POOL_FUND,\n  createRewardPoolFundHandler({ db }),\n);\nregisterHandler(\n  EventTypes.POINTS_GRANT,\n  createPointsGrantHandler({\n    db,\n    getSolPrice: async () => {\n      const result = await fetchSolPrice();\n      return result?.price ?? null;\n    },\n  }),\n);\nregisterHandler(\n  EventTypes.CRATE_DROP,\n  createCrateDropHandler({ db }),\n);\nregisterHandler(\n  EventTypes.CRATE_SOL_PAYOUT,\n  createCrateSolPayoutHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\nregisterHandler(\n  EventTypes.PROFILE_USERNAME_SET,\n  createProfileUsernameSetHandler({ db }),\n);\nregisterHandler(\n  EventTypes.TICKER_PUBLISH,\n  createTickerPublishHandler({\n    chatBaseUrl: config.chatBaseUrl,\n    chatFeedToken: config.chatFeedToken,\n  }),\n);\n\n// Event status worker — transitions scheduled→active→ended\nconst eventStatusWorker = createEventStatusWorker({ db, pollIntervalMs: 10_000 });\neventStatusWorker.start();\n\n// Event queue worker — processes async side-effects (rewards, notifications, etc.)\nconst eventWorker = createEventWorker(sql, {\n  pollIntervalMs: config.eventQueuePollMs,\n});\neventWorker.start();\nlogger.info(\"Event queue worker started\", {\n  pollIntervalMs: config.eventQueuePollMs,\n});\n\n// Game-specific routes\napp.route(\n  \"/flip-you\",\n  createFlipYouRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/pot-shot\",\n  createPotShotRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Close Call — rate limiting + JWT on POST /bet (co-signs with server keypair)\napp.use(\n  \"/closecall/bet\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\napp.use(\n  \"/closecall/bet\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Close Call routes (read endpoints are public, /bet is auth'd above)\napp.route(\"/closecall\", createCloseCallRoutes({\n  db,\n  connection,\n  serverKeypair: config.serverKeypair,\n  clockWorker: closeCallClock,\n}));\n\n// Challenge routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/challenges/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/challenges\", createChallengeRoutes({ db }));\n\n// Points routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/points/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/points\", createPointsRoutes({ db }));\n\n// Crate routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/crates/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/crates\", createCrateRoutes({ db }));\n\n// Event routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/events/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/events\", createEventRoutes({ db }));\n\n// Admin API routes — requires ADMIN_API_KEY env var\nif (config.adminApiKey) {\n  app.route(\"/admin\", createAdminRoutes({ db, adminApiKey: config.adminApiKey }));\n  logger.info(\"Admin API routes enabled at /admin\");\n}\n\n// Telegram link routes — generate-link requires JWT, redeem-link uses webhook secret\nif (config.telegramBotUsername && config.telegramWebhookSecret) {\n  app.use(\n    \"/telegram/generate-link\",\n    createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n  );\n  app.route(\n    \"/telegram\",\n    createTelegramLinkRoutes({\n      db,\n      telegramBotUsername: config.telegramBotUsername,\n      telegramWebhookSecret: config.telegramWebhookSecret,\n      communityInviteUrl: config.telegramCommunityInviteUrl,\n      linkTokenTtlSeconds: config.telegramLinkTokenTtlSeconds,\n    }),\n  );\n  logger.info(\"Telegram link routes enabled at /telegram\");\n}\n\n// Leaderboard routes — public, no auth\napp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n\n// Price routes — public, no auth\napp.route(\"/price\", createPriceRoutes());\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    isWorkerRunning: () => worker.isRunning,\n  }),\n);\n\n// Register security scheme for OpenAPI spec\napp.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n  type: \"http\",\n  scheme: \"bearer\",\n  bearerFormat: \"JWT\",\n  description:\n    \"HS256 JWT obtained via /auth/verify. Payload: { sub: userId (usr_* format) }. \" +\n    \"No wallet claim - wallet resolved from player profile when needed.\",\n});\n\n// OpenAPI docs — only when ADMIN_TOKEN is set (dev/devnet only)\nif (config.adminToken) {\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: {\n      title: \"Taunt Bet API\",\n      description:\n        \"Backend API for Taunt Bet - handles game round creation, \" +\n        \"settlement verification, player profiles, referrals, and price feeds.\\n\\n\" +\n        \"## Response envelope contract\\n\\n\" +\n        \"Every public JSON response uses one of two body shapes:\\n\\n\" +\n        \"- Success: `{ ok: true, data }` at `200` / `201` / `202` (or `204 No Content`).\\n\" +\n        \"- Failure: `{ ok: false, error: { code, message, retryable?, details? } }` at \" +\n        \"`400` / `401` / `403` / `404` / `409` / `422` / `429` / `5xx`.\\n\\n\" +\n        \"`ok` is the discriminator; HTTP status codes keep their transport and application \" +\n        \"meaning (validation → `422`, auth → `401/403`, cooldown → `429`, conflict → `409`, \" +\n        \"missing → `404`). Empty-state reads (e.g. `GET /referral/code`, `GET /referral/referrer`, \" +\n        \"`GET /points/mine`) return `200` with nullable or default payloads when absence is the \" +\n        \"documented success answer. Error `code` values come from the stable catalog in \" +\n        \"`backend/src/contracts/api-errors.ts`.\\n\\n\" +\n        \"Canonical reference: `docs/specs/304-response-envelope/spec.md`.\",\n      version: \"0.1.0\",\n    },\n    servers: [\n      { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n      { url: \"http://localhost:3100\", description: \"Local\" },\n      { url: \"https://api.taunt.bet\", description: \"Production\" },\n    ],\n  });\n  app.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n  logger.info(\"OpenAPI docs enabled at /docs and /openapi.json\");\n}\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", {\n  port,\n  publicAppUrl: config.publicAppUrl,\n  publicAppDomain: config.publicAppDomain,\n});\n\nserve({\n  fetch: app.fetch,\n  port,\n  hostname: \"0.0.0.0\",\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","structuredPatch":[{"oldStart":222,"oldLines":6,"newStart":222,"newLines":7,"lines":["   connection,","   serverKeypair: config.serverKeypair,","   db,","+  referralDefaultRateBps: config.referralDefaultRateBps,"," });"," closeCallClock.start();"," "]}],"userModified":false,"replaceAll":false}}
