ePdas.has(key)) continue;\n202\t      try {\n203\t        const round = decodeLordRound(Buffer.from(account.data));\n204\t        if (round.phase !== LORD_PHASE_ACTIVE_VALUE || !round.server.equals(serverKey)) continue;\n205\t        if (round.targetEntropySlot <= 0n) continue;\n206\t        await handleDiscoveredRound(key, round.targetEntropySlot, currentSlot, slotTime);\n207\t      } catch {\n208\t        undecodeablePdas.add(key);\n209\t        logger.warn(\"skipping undecodeable lord account\", { pda: key });\n210\t      }\n211\t    }\n212\t    const tEnd = performance.now();\n213\t\n214\t    logger.debug(\"settlement poll cycle\", {\n215\t      slotMs: Math.round(tSlot - t0),\n216\t      flipyouFetchMs: Math.round(tFlipYou - tSlot),\n217\t      lordFetchMs: Math.round(tLord - tFlipYou),\n218\t      totalMs: Math.round(tEnd - t0),\n219\t      flipyouAccounts: flipyouAccounts.length,\n220\t      lordAccounts: lordAccounts.length,\n221\t      currentSlot,\n222\t      slotTime,\n223\t    });\n224\t  }\n225\t\n226\t  async function loop(): Promise<void> {\n227\t    if (!running) return;\n228\t    try {\n229\t      await poll();\n230\t    } catch (err) {\n231\t      // Log but don't crash — transient RPC errors are expected\n232\t      logger.error(\"settlement worker poll error\", {\n233\t        error: err instanceof Error ? err.message : String(err),\n234\t      });\n235\t    }\n236\t    if (running) {\n237\t      timeoutId = setTimeout(loop, pollIntervalMs);\n238\t    }\n239\t  }\n240\t\n241\t  return {\n242\t    start() {\n243\t      if (running) return;\n244\t      running = true;\n245\t      const rpcUrl = connection.rpcEndpoint;\n246\t      const trimmedRpc = (() => {\n247\t        try {\n248\t          const u = new URL(rpcUrl);\n249\t          return `${u.host}${u.pathname}`;\n250\t        } catch {\n251\t          return rpcUrl.slice(0, 40) + \"…\";\n252\t        }\n253\t      })();\n254\t      logger.info(\"settlement worker started\", {\n255\t        serverKey: serverKey.toBase58(),\n256\t        pollIntervalMs,\n257\t        rpc: trimmedRpc,\n258\t      });\n259\t      loop();\n260\t    },\n261\t    stop() {\n262\t      running = false;\n263\t      if (timeoutId) {\n264\t        clearTimeout(timeoutId);\n265\t        timeoutId = null;\n266\t      }\n267\t      logger.info(\"settlement worker stopped\", {\n268\t        serverKey: serverKey.toBase58(),\n269\t      });\n270\t    },\n271\t    get isRunning() {\n272\t      return running;\n273\t    },\n274\t    poll,\n275\t  };\n276\t}\n277\t"}]},"parent_tool_use_id":null,"session_id":"e3c7d110-2ea6-42c9-849d-99f9f7e2fbbb","uuid":"c4b44ee8-bbfc-4dd8-bca0-d10f6edb1d5d","timestamp":"2026-05-01T19:59:41.319Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/worker/settlement.ts","content":"/**\n * Settlement worker — polls the chain for server-owned rounds that are ready\n * for backend settlement across supported games.\n */\n\nimport { performance } from \"node:perf_hooks\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { FLIPYOU_PROGRAM_ID, POTSHOT_PROGRAM_ID } from \"../tx-builder.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  flipyouMatchSize,\n  decodeFlipYouMatch,\n  decodeLordRound,\n  lordRoundDiscriminatorFilter,\n} from \"./account-decoder.js\";\n\nconst PHASE_LOCKED_VALUE = 1;\nconst LORD_PHASE_ACTIVE_VALUE = 1;\n\nexport interface SettlementWorkerDeps {\n  db: Db;\n  connection: Connection;\n  serverKey: PublicKey;\n  pollIntervalMs: number;\n  /** Called when a match is detected as ready for settlement (target_slot reached). */\n  onSettleReady?: (pda: string) => Promise<void>;\n  /** Called to check if a PDA is finalized (settled or permanently failed). */\n  isFinalized?: (pda: string) => boolean;\n}\n\nexport interface SettlementWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single poll cycle (exposed for testing). */\n  poll(): Promise<void>;\n}\n\nexport function createSettlementWorker(\n  deps: SettlementWorkerDeps,\n): SettlementWorker {\n  const { db, connection, serverKey, pollIntervalMs } = deps;\n  const discoveredPdas = new Set<string>();\n  const readyPdas = new Set<string>();\n  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n  const undecodeablePdas = new Set<string>();\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  async function handleDiscoveredRound(\n    pda: string,\n    targetSlot: bigint,\n    currentSlot: number,\n    slotTime: string | null,\n  ): Promise<void> {\n    const round = await db.getRoundByPda(pda);\n    if (!round) {\n      return;\n    }\n\n    if (!discoveredPdas.has(pda)) {\n      discoveredPdas.add(pda);\n      if (round.phase === \"created\") {\n        await db.updateRoundPhase(pda, \"locked\", {\n          target_slot: targetSlot.toString(),\n        });\n        await db.insertOperatorEvent(pda, \"match_detected\", {\n          targetSlot: targetSlot.toString(),\n          currentSlot,\n          game: round.game,\n        });\n        logger.info(\"settlement worker detected locked round\", {\n          pda,\n          creator: round.creator,\n          targetSlot: targetSlot.toString(),\n          currentSlot,\n          slotTime,\n          game: round.game,\n        });\n      }\n    }\n\n    if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n      if (deps.isFinalized?.(pda)) {\n        // Clean up tracking sets for finalized PDAs to prevent unbounded growth\n        discoveredPdas.delete(pda);\n        readyPdas.delete(pda);\n        return;\n      }\n\n      const slotsAhead = currentSlot - Number(targetSlot);\n      if (!readyPdas.has(pda)) {\n        readyPdas.add(pda);\n        logger.info(\"settlement worker found round ready\", {\n          pda,\n          targetSlot: targetSlot.toString(),\n          currentSlot,\n          slotsAhead,\n          estimatedDelayMs: slotsAhead * 400,\n          slotTime,\n        });\n      }\n      const tSettle0 = performance.now();\n      await deps.onSettleReady(pda);\n      const tSettle1 = performance.now();\n      logger.debug(\"settlement worker onSettleReady completed\", {\n        pda: pda.slice(0, 12),\n        settleMs: Math.round(tSettle1 - tSettle0),\n      });\n    }\n  }\n\n  // Track when we last ran the stale-round cleanup (once per 5 min, not every poll)\n  let lastStaleCleanup = 0;\n  const STALE_CLEANUP_INTERVAL_MS = 5 * 60_000;\n\n  /**\n   * Expire DB rounds whose on-chain PDAs no longer exist.\n   * This handles: program redeployed, PDA closed externally, etc.\n   */\n  async function expireOrphanedDbRounds(): Promise<void> {\n    const [active, locked, settling] = await Promise.all([\n      db.getRoundsByPhase(\"created\"),\n      db.getRoundsByPhase(\"locked\"),\n      db.getRoundsByPhase(\"settling\"),\n    ]);\n    const candidates = [...active, ...locked, ...settling];\n    if (candidates.length === 0) return;\n\n    // Batch RPC call — up to 100 accounts per request\n    const keys = candidates.map((r) => new PublicKey(r.pda));\n    let accounts: (null | { data: Buffer })[];\n    try {\n      accounts = (await connection.getMultipleAccountsInfo(keys)) as (null | { data: Buffer })[];\n    } catch {\n      return; // RPC error — retry next cycle\n    }\n\n    for (let i = 0; i < candidates.length; i++) {\n      if (!accounts[i]) {\n        const round = candidates[i]!;\n        await db.updateRoundPhase(round.pda, \"expired\");\n        logger.warn(\"expired orphaned DB round (PDA not found on-chain)\", {\n          pda: round.pda.slice(0, 16),\n          game: round.game,\n          phase: round.phase,\n          matchId: round.match_id,\n        });\n      }\n    }\n  }\n\n  async function poll(): Promise<void> {\n    // Periodic stale-round cleanup\n    const now = Date.now();\n    if (now - lastStaleCleanup > STALE_CLEANUP_INTERVAL_MS) {\n      lastStaleCleanup = now;\n      try {\n        await expireOrphanedDbRounds();\n      } catch (err) {\n        logger.error(\"stale round cleanup failed\", {\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n    }\n\n    const t0 = performance.now();\n    const currentSlot = await connection.getSlot();\n    const blockTime = await connection.getBlockTime(currentSlot).catch(() => null);\n    const slotTime = blockTime ? new Date(blockTime * 1000).toISOString() : null;\n    const tSlot = performance.now();\n\n    // FlipYou: fetch by dataSize (distinguishes Match from Config), decode + filter\n    const flipyouAccounts = await connection.getProgramAccounts(FLIPYOU_PROGRAM_ID, {\n      filters: [{ dataSize: flipyouMatchSize() }],\n    });\n    const tFlipYou = performance.now();\n\n    for (const { pubkey, account } of flipyouAccounts) {\n      const key = pubkey.toBase58();\n      if (undecodeablePdas.has(key)) continue;\n      try {\n        const match = decodeFlipYouMatch(Buffer.from(account.data));\n        if (match.phase !== PHASE_LOCKED_VALUE || !match.server.equals(serverKey)) continue;\n        await handleDiscoveredRound(key, match.targetSlot, currentSlot, slotTime);\n      } catch {\n        undecodeablePdas.add(key);\n        logger.warn(\"skipping undecodeable flipyou account\", { pda: key });\n      }\n    }\n\n    // Lord: fetch by discriminator (variable-size accounts), decode + filter\n    const lordAccounts = await connection.getProgramAccounts(POTSHOT_PROGRAM_ID, {\n      filters: [lordRoundDiscriminatorFilter()],\n    });\n    const tLord = performance.now();\n\n    for (const { pubkey, account } of lordAccounts) {\n      const key = pubkey.toBase58();\n      if (undecodeablePdas.has(key)) continue;\n      try {\n        const round = decodeLordRound(Buffer.from(account.data));\n        if (round.phase !== LORD_PHASE_ACTIVE_VALUE || !round.server.equals(serverKey)) continue;\n        if (round.targetEntropySlot <= 0n) continue;\n        await handleDiscoveredRound(key, round.targetEntropySlot, currentSlot, slotTime);\n      } catch {\n        undecodeablePdas.add(key);\n        logger.warn(\"skipping undecodeable lord account\", { pda: key });\n      }\n    }\n    const tEnd = performance.now();\n\n    logger.debug(\"settlement poll cycle\", {\n      slotMs: Math.round(tSlot - t0),\n      flipyouFetchMs: Math.round(tFlipYou - tSlot),\n      lordFetchMs: Math.round(tLord - tFlipYou),\n      totalMs: Math.round(tEnd - t0),\n      flipyouAccounts: flipyouAccounts.length,\n      lordAccounts: lordAccounts.length,\n      currentSlot,\n      slotTime,\n    });\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await poll();\n    } catch (err) {\n      // Log but don't crash — transient RPC errors are expected\n      logger.error(\"settlement worker poll error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      timeoutId = setTimeout(loop, pollIntervalMs);\n    }\n  }\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n      const rpcUrl = connection.rpcEndpoint;\n      const trimmedRpc = (() => {\n        try {\n          const u = new URL(rpcUrl);\n          return `${u.host}${u.pathname}`;\n        } catch {\n          return rpcUrl.slice(0, 40) + \"…\";\n        }\n      })();\n      logger.info(\"settlement worker started\", {\n        serverKey: serverKey.toBase58(),\n        pollIntervalMs,\n        rpc: trimmedRpc,\n      });\n      loop();\n    },\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"settlement worker stopped\", {\n        serverKey: serverKey.toBase58(),\n      });\n    },\n    get isRunning() {\n      return running;\n    },\n    poll,\n  };\n}\n","numLines":277,"startLine":