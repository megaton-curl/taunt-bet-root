{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L7d8PPeoinfyqBHPcAcYKV","type":"tool_result","content":"1\t/**\n2\t * Settlement worker — polls the chain for server-owned rounds that are ready\n3\t * for backend settlement across supported games.\n4\t */\n5\t\n6\timport { performance } from \"node:perf_hooks\";\n7\timport { Connection, PublicKey } from \"@solana/web3.js\";\n8\timport { FLIPYOU_PROGRAM_ID, POTSHOT_PROGRAM_ID } from \"../tx-builder.js\";\n9\timport type { Db } from \"../db.js\";\n10\timport { logger } from \"../logger.js\";\n11\timport {\n12\t  flipyouMatchSize,\n13\t  decodeFlipYouMatch,\n14\t  decodeLordRound,\n15\t  lordRoundDiscriminatorFilter,\n16\t} from \"./account-decoder.js\";\n17\t\n18\tconst PHASE_LOCKED_VALUE = 1;\n19\tconst LORD_PHASE_ACTIVE_VALUE = 1;\n20\t\n21\texport interface SettlementWorkerDeps {\n22\t  db: Db;\n23\t  connection: Connection;\n24\t  serverKey: PublicKey;\n25\t  pollIntervalMs: number;\n26\t  /** Called when a match is detected as ready for settlement (target_slot reached). */\n27\t  onSettleReady?: (pda: string) => Promise<void>;\n28\t  /** Called to check if a PDA is finalized (settled or permanently failed). */\n29\t  isFinalized?: (pda: string) => boolean;\n30\t}\n31\t\n32\texport interface SettlementWorker {\n33\t  start(): void;\n34\t  stop(): void;\n35\t  readonly isRunning: boolean;\n36\t  /** Run a single poll cycle (exposed for testing). */\n37\t  poll(): Promise<void>;\n38\t}\n39\t\n40\texport function createSettlementWorker(\n41\t  deps: SettlementWorkerDeps,\n42\t): SettlementWorker {\n43\t  const { db, connection, serverKey, pollIntervalMs } = deps;\n44\t  const discoveredPdas = new Set<string>();\n45\t  const readyPdas = new Set<string>();\n46\t  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n47\t  const undecodeablePdas = new Set<string>();\n48\t  let running = false;\n49\t  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n50\t\n51\t  async function handleDiscoveredRound(\n52\t    pda: string,\n53\t    targetSlot: bigint,\n54\t    currentSlot: number,\n55\t    slotTime: string | null,\n56\t  ): Promise<void> {\n57\t    const round = await db.getRoundByPda(pda);\n58\t    if (!round) {\n59\t      return;\n60\t    }\n61\t\n62\t    if (!discoveredPdas.has(pda)) {\n63\t      discoveredPdas.add(pda);\n64\t      if (round.phase === \"created\") {\n65\t        await db.updateRoundPhase(pda, \"locked\", {\n66\t          target_slot: targetSlot.toString(),\n67\t        });\n68\t        await db.insertOperatorEvent(pda, \"match_detected\", {\n69\t          targetSlot: targetSlot.toString(),\n70\t          currentSlot,\n71\t          game: round.game,\n72\t        });\n73\t        logger.info(\"settlement worker detected locked round\", {\n74\t          pda,\n75\t          creator: round.creator,\n76\t          targetSlot: targetSlot.toString(),\n77\t          currentSlot,\n78\t          slotTime,\n79\t          game: round.game,\n80\t        });\n81\t      }\n82\t    }\n83\t\n84\t    if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n85\t      if (deps.isFinalized?.(pda)) {\n86\t        // Clean up tracking sets for finalized PDAs to prevent unbounded growth\n87\t        discoveredPdas.delete(pda);\n88\t        readyPdas.delete(pda);\n89\t        return;\n90\t      }\n91\t\n92\t      const slotsAhead = currentSlot - Number(targetSlot);\n93\t      if (!readyPdas.has(pda)) {\n94\t        readyPdas.add(pda);\n95\t        logger.info(\"settlement worker found round ready\", {\n96\t          pda,\n97\t          targetSlot: targetSlot.toString(),\n98\t          currentSlot,\n99\t          slotsAhead,\n100\t          estimatedDelayMs: slotsAhead * 400,\n101\t          slotTime,\n102\t        });\n103\t      }\n104\t      const tSettle0 = performance.now();\n105\t      await deps.onSettleReady(pda);\n106\t      const tSettle1 = performance.now();\n107\t      logger.debug(\"settlement worker onSettleReady completed\", {\n108\t        pda: pda.slice(0, 12),\n109\t        settleMs: Math.round(tSettle1 - tSettle0),\n110\t      });\n111\t    }\n112\t  }\n113\t\n114\t  // Track when we last ran the stale-round cleanup (once per 5 min, not every poll)\n115\t  let lastStaleCleanup = 0;\n116\t  const STALE_CLEANUP_INTERVAL_MS = 5 * 60_000;\n117\t\n118\t  /**\n119\t   * Expire DB rounds whose on-chain PDAs no longer exist.\n120\t   * This handles: program redeployed, PDA closed externally, etc.\n121\t   */\n122\t  async function expireOrphanedDbRounds(): Promise<void> {\n123\t    const [active, locked, settling] = await Promise.all([\n124\t      db.getRoundsByPhase(\"created\"),\n125\t      db.getRoundsByPhase(\"locked\"),\n126\t      db.getRoundsByPhase(\"settling\"),\n127\t    ]);\n128\t    const candidates = [...active, ...locked, ...settling];\n129\t    if (candidates.length === 0) return;\n130\t\n131\t    // Batch RPC call — up to 100 accounts per request\n132\t    const keys = candidates.map((r) => new PublicKey(r.pda));\n133\t    let accounts: (null | { data: Buffer })[];\n134\t    try {\n135\t      accounts = (await connection.getMultipleAccountsInfo(keys)) as (null | { data: Buffer })[];\n136\t    } catch {\n137\t      return; // RPC error — retry next cycle\n138\t    }\n139\t\n140\t    for (let i = 0; i < candidates.length; i++) {\n141\t      if (!accounts[i]) {\n142\t        const round = candidates[i]!;\n143\t        await db.updateRoundPhase(round.pda, \"expired\");\n144\t        logger.warn(\"expired orphaned DB round (PDA not found on-chain)\", {\n145\t          pda: round.pda.slice(0, 16),\n146\t          game: round.game,\n147\t          phase: round.phase,\n148\t          matchId: round.match_id,\n149\t        });\n150\t      }\n151\t    }\n152\t  }\n153\t\n154\t  async function poll(): Promise<void> {\n155\t    // Periodic stale-round cleanup\n156\t    const now = Date.now();\n157\t    if (now - lastStaleCleanup > STALE_CLEANUP_INT