{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MRHsm31JXAHvQ4gbQ8A948","type":"tool_result","content":"150\t      )\n151\t    `;\n152\t    await rawSql`\n153\t      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n154\t    `;\n155\t    await rawSql`\n156\t      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n157\t    `;\n158\t    await rawSql`\n159\t      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n160\t    `;\n161\t    await rawSql`\n162\t      CREATE TABLE referral_kol_rates (\n163\t        user_id TEXT PRIMARY KEY,\n164\t        wallet TEXT NOT NULL UNIQUE,\n165\t        rate_bps INTEGER NOT NULL,\n166\t        set_by TEXT NOT NULL,\n167\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n168\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n169\t      )\n170\t    `;\n171\t  });\n172\t\n173\t  afterAll(async () => {\n174\t    if (db) await db.close();\n175\t    await rawSql.end();\n176\t  });\n177\t\n178\t  beforeEach(async () => {\n179\t    await rawSql`TRUNCATE referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, event_queue RESTART IDENTITY CASCADE`;\n180\t    // Clean + recreate profiles for test wallets — routes resolve wallet\n181\t    // from profile via db.getProfileByUserId(userId).\n182\t    await rawSql`DELETE FROM player_profiles WHERE user_id IN (${referrerUserId}, ${refereeUserId})`;\n183\t    await rawSql`\n184\t      INSERT INTO player_profiles (user_id, wallet, username)\n185\t      VALUES (${referrerUserId}, ${referrer}, ${\"ref-er-\" + Date.now()}),\n186\t             (${refereeUserId}, ${referee}, ${\"ref-ee-\" + Date.now()})\n187\t    `;\n188\t\n189\t    db = createDb(DATABASE_URL, rawSql);\n190\t\n191\t    app = new Hono();\n192\t    app.use(\n193\t      \"/referral/*\",\n194\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n195\t    );\n196\t    app.route(\n197\t      \"/referral\",\n198\t      createReferralRoutes({ db, sql: rawSql, config: testConfig }),\n199\t    );\n200\t  });\n201\t\n202\t  // -----------------------------------------------------------------------\n203\t  // POST /referral/code — set custom code\n204\t  // -----------------------------------------------------------------------\n205\t\n206\t  describe(\"POST /referral/code\", () => {\n207\t    it(\"sets a valid custom code and returns code + url\", async () => {\n208\t      const token = await makeJwt(referrer);\n209\t      const res = await app.request(\"/referral/code\", {\n210\t        method: \"POST\",\n211\t        ...json({ code: \"my-code-123\" }),\n212\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n213\t      });\n214\t\n215\t      expect(res.status).toBe(200);\n216\t      const body = (await res.json()) as { ok: true; data: { code: string } };\n217\t      expect(body.ok).toBe(true);\n218\t      expect(body.data.code).toBe(\"my-code-123\");\n219\t    });\n220\t\n221\t    it(\"rejects code shorter than 3 chars\", async () => {\n222\t      const token = await makeJwt(referrer);\n223\t      const res = await app.request(\"/referral/code\", {\n224\t        method: \"POST\",\n225\t        ...json({ code: \"ab\" }),\n226\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n227\t      });\n228\t\n229\t      expect(res.status).toBe(422);\n230\t      const body = (await res.json()) as {\n231\t        ok: false;\n232\t        error: { code: string };\n233\t      };\n234\t      expect(body.ok).toBe(false);\n235\t      expect(body.error.code).toBe(\"INVALID_CODE\");\n236\t    });\n237\t\n238\t    it(\"rejects code longer than 16 chars\", async () => {\n239\t      const token = await makeJwt(referrer);\n240\t      const res = await app.request(\"/referral/code\", {\n241\t        method: \"