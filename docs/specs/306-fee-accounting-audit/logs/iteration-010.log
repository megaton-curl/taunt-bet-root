{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WD2qqXHSgfVbzGHDKbyTKi","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\t/**\n3\t * Referral route tests — set code, apply, stats, earnings, claim flows.\n4\t *\n5\t * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n6\t * between tests for isolation.\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport { Keypair } from \"@solana/web3.js\";\n12\timport { SignJWT } from \"jose\";\n13\timport postgres from \"postgres\";\n14\timport { createDb, type Db } from \"../db.js\";\n15\timport { createReferralRoutes } from \"../routes/referral.js\";\n16\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n17\timport type { Config } from \"../config.js\";\n18\t\n19\t// ---------------------------------------------------------------------------\n20\t// Constants\n21\t// ---------------------------------------------------------------------------\n22\t\n23\tconst DATABASE_URL =\n24\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n25\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n26\t\n27\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n28\tfunction makeSql() {\n29\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n30\t  // Dev container: postgres listens on Unix socket only\n31\t  return postgres({\n32\t    host: \"/var/run/postgresql\",\n33\t    user: \"vscode\",\n34\t    database: \"taunt_bet_dev\",\n35\t  });\n36\t}\n37\t\n38\t// ---------------------------------------------------------------------------\n39\t// Helpers\n40\t// ---------------------------------------------------------------------------\n41\t\n42\tasync function makeJwt(wallet: string): Promise<string> {\n43\t  const now = Math.floor(Date.now() / 1000);\n44\t  return new SignJWT({})\n45\t    .setProtectedHeader({ alg: \"HS256\" })\n46\t    .setSubject(userIdFromWallet(wallet))\n47\t    .setIssuedAt(now)\n48\t    .setExpirationTime(now + 3600)\n49\t    .sign(JWT_SECRET);\n50\t}\n51\t\n52\tfunction json(body: Record<string, any>) {\n53\t  return {\n54\t    headers: { \"Content-Type\": \"application/json\" },\n55\t    body: JSON.stringify(body),\n56\t  };\n57\t}\n58\t\n59\tfunction userIdFromWallet(wallet: string) {\n60\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n61\t}\n62\t\n63\t// ---------------------------------------------------------------------------\n64\t// Test suite\n65\t// ---------------------------------------------------------------------------\n66\t\n67\tdescribe(\"Referral routes\", () => {\n68\t  let rawSql: ReturnType<typeof postgres>;\n69\t  let db: Db;\n70\t  let app: Hono;\n71\t\n72\t  const referrerKp = Keypair.generate();\n73\t  const refereeKp = Keypair.generate();\n74\t  const referrer = referrerKp.publicKey.toBase58();\n75\t  const referee = refereeKp.publicKey.toBase58();\n76\t  const referrerUserId = userIdFromWallet(referrer);\n77\t  const refereeUserId = userIdFromWallet(referee);\n78\t\n79\t  const testConfig = {\n80\t    referralDefaultRateBps: 1000,\n81\t    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n82\t  } as Config;\n83\t\n84\t  beforeAll(async () => {\n85\t    rawSql = makeSql();\n86\t    await rawSql`\n87\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n88\t    `;\n89\t    await rawSql`\n90\t      CREATE TABLE referral_codes (\n91\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n92\t        user_id TEXT NOT NULL UNIQUE,\n93\t        wallet TEXT NOT NULL UNIQUE,\n94\t        code TEXT NOT NULL UNIQUE,\n95\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n96\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n97\t      )\n98\t    `;\n99\t    await rawSql`\n100\t      CREATE TABLE referral_links (\n101\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n102\t        referrer_user_id TEXT NOT NULL,\n103\t        referee_user_id TEXT NOT NULL UNIQUE,\n104\t        referrer_wallet TEXT NOT NULL,\n105\t        referee_wallet TEXT NOT NULL,\n106\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n107\t      )\n108\t    `;\n109\t    await rawSql`\n110\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n111\t    `;\n112\t    await rawSql`\n113\t      CREATE TABLE referral_earnings (\n114\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n115\t        referrer_user_id TEXT NOT NULL,\n116\t        referee_user_id TEXT NOT NULL,\n117\t        referrer_wallet TEXT NOT NULL,\n118\t        referee_wallet TEXT NOT NULL,\n119\t        round_id TEXT NOT NULL,\n120\t        game_type TEXT NOT NULL,\n121\t        wager_lamports BIGINT NOT NULL,\n122\t        fee_lamports BIGINT NOT NULL,\n123\t        referrer_earned_lamports BIGINT NOT NULL,\n124\t        referrer_rate_bps INTEGER NOT NULL,\n125\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n126\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n127\t      )\n128\t    `;\n129\t    await rawSql`\n130\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n131\t    `;\n132\t    await rawSql`\n133\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n134\t    `;\n135\t    await rawSql`\n136\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n137\t    `;\n138\t    await rawSql`\n139\t      CREATE TABLE referral_claims (\n140\t        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n141\t        user_id TEXT NOT NULL,\n142\t        wallet TEXT NOT NULL,\n143\t        amount_lamports BIGINT NOT NULL,\n144\t        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n145\t        retry_count INTEGER NOT NULL DEFAULT 0,\n146\t        tx_signature TEXT,\n147\t        error TEXT,\n148\t        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n149\t        processed_at TIMESTAMPTZ\n150\t      )"}]},"parent_tool_use_id":null,"session_id":"5319c272-d901-4665-9699-082f2d4ef4a9","uuid":"0761a821-9066-489c-b937-cf6575f594af","timestamp":"2026-05-01T20:15:54.418Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/referral-routes.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\n/**\n * Referral route tests — set code, apply, stats, earnings, claim flows.\n *\n * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n * between tests for isolation.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userIdFromWallet(wallet))\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction json(body: Record<string, any>) {\n  return {\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify(body),\n  };\n}\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Referral routes\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n  let app: Hono;\n\n  const referrerKp = Keypair.generate();\n  const refereeKp = Keypair.generate();\n  const referrer = referrerKp.publicKey.toBase58();\n  const referee = refereeKp.publicKey.toBase58();\n  const referrerUserId = userIdFromWallet(referrer);\n  const refereeUserId = userIdFromWallet(referee);\n\n  const testConfig = {\n    referralDefaultRateBps: 1000,\n    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n  } as Config;\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    await rawSql`\n      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n    `;\n    await rawSql`\n      CREATE TABLE referral_codes (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id TEXT NOT NULL UNIQUE,\n        wallet TEXT NOT NULL UNIQUE,\n        code TEXT NOT NULL UNIQUE,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE referral_links (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL UNIQUE,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_earnings (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        round_id TEXT NOT NULL,\n        game_type TEXT NOT NULL,\n        wager_lamports BIGINT NOT NULL,\n        fee_lamports BIGINT NOT NULL,\n        referrer_earned_lamports BIGINT NOT NULL,\n        referrer_rate_bps INTEGER NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_claims (\n        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        amount_lamports BIGINT NOT NULL,\n        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n        retry_count INTEGER NOT NULL DEFAULT 0,\n        tx_signature TEXT,\n        error TEXT,\n        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        processed_at TIMESTAMPTZ\n      )","numLines":150,"startLine":1,"totalLines":997}}}
