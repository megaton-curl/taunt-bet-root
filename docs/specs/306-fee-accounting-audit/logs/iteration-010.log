{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Rbg7fHgo5khFrJmAhDcUC","type":"tool_result","content":"1\t/**\n2\t * Database client composition shell — imports domain modules and composes\n3\t * the unified Db interface. See db/ for domain implementations.\n4\t */\n5\t\n6\timport postgres from \"postgres\";\n7\timport { createReferralsDb, type ReferralsDb } from \"./db/referrals.js\";\n8\timport { createProfilesDb, type ProfilesDb } from \"./db/profiles.js\";\n9\timport { createCloseCallDb, type CloseCallDb } from \"./db/closecall.js\";\n10\timport { createCloseCallCandlesDb, type CloseCallCandlesDb } from \"./db/closecall-candles.js\";\n11\timport { createTransactionsDb, type TransactionsDb } from \"./db/transactions.js\";\n12\timport { createGameEntriesDb, type GameEntriesDb } from \"./db/game-entries.js\";\n13\timport { createRoundsDb, type RoundsDb } from \"./db/rounds.js\";\n14\timport { createStatsDb, type StatsDb } from \"./db/stats.js\";\n15\timport { createTelegramLinksDb, type TelegramLinksDb } from \"./db/telegram-links.js\";\n16\timport { createLinkedAccountsDb, type LinkedAccountsDb } from \"./db/linked-accounts.js\";\n17\timport { createFeeAccountingDb, type FeeAccountingDb } from \"./db/fee-accounting.js\";\n18\t\n19\texport type { ReferralCode, ReferralLink, ReferralEarning, ReferralStats, ReferralClaim, ReferralsDb } from \"./db/referrals.js\";\n20\texport type { PlayerProfile, ProfilesDb } from \"./db/profiles.js\";\n21\texport type { CloseCallPhase, CloseCallOutcome, CloseCallRound, InsertCloseCallRoundParams, CloseCallDb } from \"./db/closecall.js\";\n22\texport type { CloseCallCandle, CloseCallCandlesDb } from \"./db/closecall-candles.js\";\n23\texport type { TransactionType, Transaction, InsertTransactionParams, TransactionsDb } from \"./db/transactions.js\";\n24\texport type { GameEntryUpsert, GameEntryInsert, GameEntry, GameEntriesDb } from \"./db/game-entries.js\";\n25\texport type { RoundPhase, Round, InsertRoundParams, OperatorEventType, OperatorEvent, RoundsDb } from \"./db/rounds.js\";\n26\texport type { PlayerStats, PublicPlayerStats, WinStreaks, GameBreakdownStats, LeaderboardEntry, LeaderboardResult, StatsDb } from \"./db/stats.js\";\n27\texport type { TelegramLinkStatus, TelegramLinkToken, TelegramLinksDb } from \"./db/telegram-links.js\";\n28\texport type {\n29\t  LinkedAccountStatus,\n30\t  LinkedAccountProvider,\n31\t  LinkedAccount,\n32\t  LinkedAccountsDb,\n33\t} from \"./db/linked-accounts.js\";\n34\texport type {\n35\t  FeeBucket,\n36\t  FeeBucketDebitStatus,\n37\t  FeeAllocation,\n38\t  InsertFeeAllocationParams,\n39\t  InsertFeeBucketDebitParams,\n40\t  FeeAllocationEventRow,\n41\t  FeeBucketDebitRow,\n42\t  FeeAuditBucketSummary,\n43\t  FeeAuditSnapshot,\n44\t  FeeAccountingDb,\n45\t} from \"./db/fee-accounting.js\";\n46\texport { calculateFeeAllocation } from \"./db/fee-accounting.js\";\n47\t\n48\t// ---------------------------------------------------------------------------\n49\t// DB client\n50\t// ---------------------------------------------------------------------------\n51\t\n52\texport interface Db\n53\t  extends ReferralsDb,\n54\t    ProfilesDb,\n55\t    CloseCallDb,\n56\t    CloseCallCandlesDb,\n57\t    TransactionsDb,\n58\t    GameEntriesDb,\n59\t    RoundsDb,\n60\t    StatsDb,\n61\t    TelegramLinksDb,\n62\t    LinkedAccountsDb,\n63\t    FeeAccountingDb {\n64\t  /**\n65\t   * Execute a function within a database transaction.\n66\t   * All db methods called on the transactional Db share the same transaction.\n67\t   * Rolls back on error, commits on success.\n68\t   */\n69\t  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n70\t\n71\t  /** Expose the underlying SQL/transaction handle for use with emitEvent(). */\n72\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n73\t  readonly rawSql: any;\n74\t\n75\t  /** Gracefully close the connection pool. */\n76\t  close(): Promise<void>;\n77\t}\n78\t\n79\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n80\texport function createDb(databaseUrl: string, _txSql?: any): Db {\n81\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n82\t  const sql: any = _txSql ?? postgres(databaseUrl);\n83\t  const _isOwner = !_txSql;\n84\t\n85\t  return {\n86\t    rawSql: sql,\n87\t\n88\t    ...createRoundsDb(sql),\n89\t\n90\t    ...createCloseCallDb(sql),\n91\t\n92\t    ...createGameEntriesDb(sql),\n93\t\n94\t    ...createCloseCallCandlesDb(sql),\n95\t\n96\t    ...createTransactionsDb(sql),\n97\t\n98\t    ...createReferralsDb(sql),\n99\t\n100\t    ...createProfilesDb(sql),\n101\t\n102\t    ...createStatsDb(sql),\n103\t\n104\t    ...createTelegramLinksDb(sql),\n105\t\n106\t    ...createLinkedAccountsDb(sql),\n107\t\n108\t    ...createFeeAccountingDb(sql),\n109\t\n110\t    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n111\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n112\t      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n113\t    },\n114\t\n115\t    async close() {\n116\t      if (_isOwner) await sql.end();\n117\t    },\n118\t  };\n119\t}\n120\t"}]},"parent_tool_use_id":null,"session_id":"5319c272-d901-4665-9699-082f2d4ef4a9","uuid":"4a2eb04a-0b02-4921-b0bb-6f3ccd5b62d5","timestamp":"2026-05-01T20:14:59.631Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/db.ts","content":"/**\n * Database client composition shell — imports domain modules and composes\n * the unified Db interface. See db/ for domain implementations.\n */\n\nimport postgres from \"postgres\";\nimport { createReferralsDb, type ReferralsDb } from \"./db/referrals.js\";\nimport { createProfilesDb, type ProfilesDb } from \"./db/profiles.js\";\nimport { createCloseCallDb, type CloseCallDb } from \"./db/closecall.js\";\nimport { createCloseCallCandlesDb, type CloseCallCandlesDb } from \"./db/closecall-candles.js\";\nimport { createTransactionsDb, type TransactionsDb } from \"./db/transactions.js\";\nimport { createGameEntriesDb, type GameEntriesDb } from \"./db/game-entries.js\";\nimport { createRoundsDb, type RoundsDb } from \"./db/rounds.js\";\nimport { createStatsDb, type StatsDb } from \"./db/stats.js\";\nimport { createTelegramLinksDb, type TelegramLinksDb } from \"./db/telegram-links.js\";\nimport { createLinkedAccountsDb, type LinkedAccountsDb } from \"./db/linked-accounts.js\";\nimport { createFeeAccountingDb, type FeeAccountingDb } from \"./db/fee-accounting.js\";\n\nexport type { ReferralCode, ReferralLink, ReferralEarning, ReferralStats, ReferralClaim, ReferralsDb } from \"./db/referrals.js\";\nexport type { PlayerProfile, ProfilesDb } from \"./db/profiles.js\";\nexport type { CloseCallPhase, CloseCallOutcome, CloseCallRound, InsertCloseCallRoundParams, CloseCallDb } from \"./db/closecall.js\";\nexport type { CloseCallCandle, CloseCallCandlesDb } from \"./db/closecall-candles.js\";\nexport type { TransactionType, Transaction, InsertTransactionParams, TransactionsDb } from \"./db/transactions.js\";\nexport type { GameEntryUpsert, GameEntryInsert, GameEntry, GameEntriesDb } from \"./db/game-entries.js\";\nexport type { RoundPhase, Round, InsertRoundParams, OperatorEventType, OperatorEvent, RoundsDb } from \"./db/rounds.js\";\nexport type { PlayerStats, PublicPlayerStats, WinStreaks, GameBreakdownStats, LeaderboardEntry, LeaderboardResult, StatsDb } from \"./db/stats.js\";\nexport type { TelegramLinkStatus, TelegramLinkToken, TelegramLinksDb } from \"./db/telegram-links.js\";\nexport type {\n  LinkedAccountStatus,\n  LinkedAccountProvider,\n  LinkedAccount,\n  LinkedAccountsDb,\n} from \"./db/linked-accounts.js\";\nexport type {\n  FeeBucket,\n  FeeBucketDebitStatus,\n  FeeAllocation,\n  InsertFeeAllocationParams,\n  InsertFeeBucketDebitParams,\n  FeeAllocationEventRow,\n  FeeBucketDebitRow,\n  FeeAuditBucketSummary,\n  FeeAuditSnapshot,\n  FeeAccountingDb,\n} from \"./db/fee-accounting.js\";\nexport { calculateFeeAllocation } from \"./db/fee-accounting.js\";\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db\n  extends ReferralsDb,\n    ProfilesDb,\n    CloseCallDb,\n    CloseCallCandlesDb,\n    TransactionsDb,\n    GameEntriesDb,\n    RoundsDb,\n    StatsDb,\n    TelegramLinksDb,\n    LinkedAccountsDb,\n    FeeAccountingDb {\n  /**\n   * Execute a function within a database transaction.\n   * All db methods called on the transactional Db share the same transaction.\n   * Rolls back on error, commits on success.\n   */\n  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n\n  /** Expose the underlying SQL/transaction handle for use with emitEvent(). */\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  readonly rawSql: any;\n\n  /** Gracefully close the connection pool. */\n  close(): Promise<void>;\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nexport function createDb(databaseUrl: string, _txSql?: any): Db {\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const sql: any = _txSql ?? postgres(databaseUrl);\n  const _isOwner = !_txSql;\n\n  return {\n    rawSql: sql,\n\n    ...createRoundsDb(sql),\n\n    ...createCloseCallDb(sql),\n\n    ...createGameEntriesDb(sql),\n\n    ...createCloseCallCandlesDb(sql),\n\n    ...createTransactionsDb(sql),\n\n    ...createReferralsDb(sql),\n\n    ...createProfilesDb(sql),\n\n    ...createStatsDb(sql),\n\n    ...createTelegramLinksDb(sql),\n\n    ...createLinkedAccountsDb(sql),\n\n    ...createFeeAccountingDb(sql),\n\n    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n    },\n\n    async close() {\n      if (_isOwner) await sql.end();\n    },\n  };\n}\n","numLines":120,"startLine":1,"totalLines":120}}}
