{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X45s67CPvZBomjtEj4SGED","type":"tool_result","content":"1\t/**\n2\t * Event producer — inserts an event into the queue within an existing\n3\t * database transaction so the event is committed atomically with the\n4\t * triggering operation.\n5\t */\n6\t\n7\timport type postgres from \"postgres\";\n8\timport type { EventType } from \"./event-types.js\";\n9\t\n10\t/** The transaction/sql handle accepted by emitEvent — works with both sql and tx from sql.begin(). */\n11\texport type SqlOrTransaction = postgres.Sql;\n12\t\n13\texport interface EmitEventOptions {\n14\t  maxAttempts?: number; // default: 3\n15\t  scheduledAt?: Date; // default: now\n16\t}\n17\t\n18\texport async function emitEvent(\n19\t  tx: SqlOrTransaction,\n20\t  eventType: EventType,\n21\t  payload: Record<string, unknown>,\n22\t  options?: EmitEventOptions,\n23\t): Promise<{ eventId: bigint }> {\n24\t  const maxAttempts = options?.maxAttempts ?? 3;\n25\t  const scheduledAt = options?.scheduledAt ?? new Date();\n26\t\n27\t  const rows = await tx<{ id: string }[]>`\n28\t    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n29\t    VALUES (${eventType}, ${tx.json(payload as postgres.JSONValue)}, ${maxAttempts}, ${scheduledAt})\n30\t    RETURNING id\n31\t  `;\n32\t\n33\t  return { eventId: BigInt(rows[0]!.id) };\n34\t}\n35\t"}]},"parent_tool_use_id":null,"session_id":"5319c272-d901-4665-9699-082f2d4ef4a9","uuid":"e99bdc86-a15c-4772-8c13-7cac3b879fa1","timestamp":"2026-05-01T20:15:40.532Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/queue/emit-event.ts","content":"/**\n * Event producer — inserts an event into the queue within an existing\n * database transaction so the event is committed atomically with the\n * triggering operation.\n */\n\nimport type postgres from \"postgres\";\nimport type { EventType } from \"./event-types.js\";\n\n/** The transaction/sql handle accepted by emitEvent — works with both sql and tx from sql.begin(). */\nexport type SqlOrTransaction = postgres.Sql;\n\nexport interface EmitEventOptions {\n  maxAttempts?: number; // default: 3\n  scheduledAt?: Date; // default: now\n}\n\nexport async function emitEvent(\n  tx: SqlOrTransaction,\n  eventType: EventType,\n  payload: Record<string, unknown>,\n  options?: EmitEventOptions,\n): Promise<{ eventId: bigint }> {\n  const maxAttempts = options?.maxAttempts ?? 3;\n  const scheduledAt = options?.scheduledAt ?? new Date();\n\n  const rows = await tx<{ id: string }[]>`\n    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n    VALUES (${eventType}, ${tx.json(payload as postgres.JSONValue)}, ${maxAttempts}, ${scheduledAt})\n    RETURNING id\n  `;\n\n  return { eventId: BigInt(rows[0]!.id) };\n}\n","numLines":35,"startLine":1,"totalLines":35}}}
