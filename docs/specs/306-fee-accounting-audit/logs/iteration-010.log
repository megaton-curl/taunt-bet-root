00\t        ok: true;\n901\t        data: { claimId: string };\n902\t      };\n903\t      const claim = claimBody.data;\n904\t\n905\t      // Try to view as referee (different wallet)\n906\t      const refereeToken = await makeJwt(referee);\n907\t      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n908\t        method: \"GET\",\n909\t        headers: { Authorization: `Bearer ${refereeToken}` },\n910\t      });\n911\t\n912\t      expect(res.status).toBe(404);\n913\t      const body = (await res.json()) as {\n914\t        ok: false;\n915\t        error: { code: string };\n916\t      };\n917\t      expect(body.ok).toBe(false);\n918\t      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n919\t    });\n920\t  });\n921\t\n922\t  // -----------------------------------------------------------------------\n923\t  // GET /referral/referrer — check referrer status\n924\t  // -----------------------------------------------------------------------\n925\t\n926\t  describe(\"GET /referral/referrer\", () => {\n927\t    it(\"returns 200 with null fields when not referred\", async () => {\n928\t      const token = await makeJwt(referee);\n929\t      const res = await app.request(\"/referral/referrer\", {\n930\t        method: \"GET\",\n931\t        headers: { Authorization: `Bearer ${token}` },\n932\t      });\n933\t\n934\t      expect(res.status).toBe(200);\n935\t      const body = (await res.json()) as {\n936\t        ok: true;\n937\t        data: {\n938\t          referrerUserId: string | null;\n939\t          referrerUsername: string | null;\n940\t          referrerCode: string | null;\n941\t          linkedAt: string | null;\n942\t        };\n943\t      };\n944\t      expect(body.ok).toBe(true);\n945\t      expect(body.data.referrerUserId).toBeNull();\n946\t      expect(body.data.referrerUsername).toBeNull();\n947\t      expect(body.data.referrerCode).toBeNull();\n948\t      expect(body.data.linkedAt).toBeNull();\n949\t    });\n950\t\n951\t    it(\"returns referrer wallet after linking\", async () => {\n952\t      // Set up code + apply\n953\t      const referrerToken = await makeJwt(referrer);\n954\t      await app.request(\"/referral/code\", {\n955\t        method: \"POST\",\n956\t        ...json({ code: \"referrer-test\" }),\n957\t        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n958\t      });\n959\t\n960\t      const refereeToken = await makeJwt(referee);\n961\t      await app.request(\"/referral/apply\", {\n962\t        method: \"POST\",\n963\t        ...json({ code: \"referrer-test\" }),\n964\t        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n965\t      });\n966\t\n967\t      const res = await app.request(\"/referral/referrer\", {\n968\t        method: \"GET\",\n969\t        headers: { Authorization: `Bearer ${refereeToken}` },"}]},"parent_tool_use_id":null,"session_id":"5319c272-d901-4665-9699-082f2d4ef4a9","uuid":"782bd8bd-f235-4e93-9fc8-8174247db576","timestamp":"2026-05-01T20:17:17.798Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/referral-routes.test.ts","content":"        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.claimId).toBe(claim.claimId);\n      expect(body.data.status).toBe(\"pending\");\n    });\n\n    it(\"returns 404 for non-existent claim\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\n        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n    });\n\n    it(\"returns 404 when another wallet tries to view a claim\", async () => {\n      // Create earning + claim as referrer\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"auth-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n      });\n\n      const referrerToken = await makeJwt(referrer);\n      const claimRes = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${referrerToken}`,\n        },\n      });\n      const claimBody = (await claimRes.json()) as {\n        ok: true;\n        data: { claimId: string };\n      };\n      const claim = claimBody.data;\n\n      // Try to view as referee (different wallet)\n      const refereeToken = await makeJwt(referee);\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${refereeToken}` },\n      });\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/referrer — check referrer status\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/referrer\", () => {\n    it(\"returns 200 with null fields when not referred\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/referrer\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          referrerUserId: string | null;\n          referrerUsername: string | null;\n          referrerCode: string | null;\n          linkedAt: string | null;\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.referrerUserId).toBeNull();\n      expect(body.data.referrerUsername).toBeNull();\n      expect(body.data.referrerCode).toBeNull();\n      expect(body.data.linkedAt).toBeNull();\n    });\n\n    it(\"returns referrer wallet after linking\", async () => {\n      // Set up code + apply\n      const referrerToken = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"referrer-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n      });\n\n      const refereeToken = await makeJwt(referee);\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"referrer-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n      });\n\n      const res = await app.request(\"/referral/referrer\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${refereeToken}` },","numLines":120,"startLine":850,"totalLines":997}}}
