\",\n292\t        ...json({ code: \"first-code\" }),\n293\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n294\t      });\n295\t\n296\t      // Attempt to change — must be rejected\n297\t      const res = await app.request(\"/referral/code\", {\n298\t        method: \"POST\",\n299\t        ...json({ code: \"second-code\" }),\n300\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n301\t      });\n302\t\n303\t      expect(res.status).toBe(409);\n304\t      const body = (await res.json()) as {\n305\t        ok: false;\n306\t        error: { code: string };\n307\t      };\n308\t      expect(body.ok).toBe(false);\n309\t      expect(body.error.code).toBe(\"CODE_ALREADY_SET\");\n310\t    });\n311\t\n312\t    it(\"rejects missing body\", async () => {\n313\t      const token = await makeJwt(referrer);\n314\t      const res = await app.request(\"/referral/code\", {\n315\t        method: \"POST\",\n316\t        headers: { Authorization: `Bearer ${token}` },\n317\t      });\n318\t\n319\t      expect(res.status).toBe(422);\n320\t      const body = (await res.json()) as {\n321\t        ok: false;\n322\t        error: { code: string };\n323\t      };\n324\t      expect(body.ok).toBe(false);\n325\t      expect(body.error.code).toBe(\"INVALID_CODE\");\n326\t    });\n327\t  });\n328\t\n329\t  // -----------------------------------------------------------------------\n330\t  // GET /referral/code — retrieve current code\n331\t  // -----------------------------------------------------------------------\n332\t\n333\t  describe(\"GET /referral/code\", () => {\n334\t    it(\"returns existing code for wallet\", async () => {\n335\t      const token = await makeJwt(referrer);\n336\t\n337\t      // Set code first\n338\t      await app.request(\"/referral/code\", {\n339\t        method: \"POST\",\n340\t        ...json({ code: \"get-test\" }),\n341\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n342\t      }