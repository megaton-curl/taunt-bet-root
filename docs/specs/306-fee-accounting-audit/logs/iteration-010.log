{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QW54qEZgxcHsrVWSDP7ks3","type":"tool_result","content":"655\t  });\n656\t\n657\t  // -----------------------------------------------------------------------\n658\t  // POST /referral/claim — claim flow\n659\t  // -----------------------------------------------------------------------\n660\t\n661\t  describe(\"POST /referral/claim\", () => {\n662\t    it(\"rejects claim with zero balance\", async () => {\n663\t      const token = await makeJwt(referrer);\n664\t      const res = await app.request(\"/referral/claim\", {\n665\t        method: \"POST\",\n666\t        headers: {\n667\t          \"Content-Type\": \"application/json\",\n668\t          Authorization: `Bearer ${token}`,\n669\t        },\n670\t      });\n671\t\n672\t      expect(res.status).toBe(422);\n673\t      const body = (await res.json()) as {\n674\t        ok: false;\n675\t        error: { code: string };\n676\t      };\n677\t      expect(body.ok).toBe(false);\n678\t      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n679\t    });\n680\t\n681\t    it(\"rejects claim below minimum threshold\", async () => {\n682\t      // Insert a small earning (below 0.01 SOL threshold)\n683\t      await db.insertReferralEarning({\n684\t        referrerUserId,\n685\t        refereeUserId,\n686\t        referrerWallet: referrer,\n687\t        refereeWallet: referee,\n688\t        roundId: \"small-round\",\n689\t        gameType: \"flipyou\",\n690\t        wagerLamports: 100_000_000, // 0.1 SOL\n691\t        feeLamports: 5_000_000, // 0.005 SOL\n692\t        referrerEarnedLamports: 500_000, // 0.0005 SOL — below 0.01 threshold\n693\t        referrerRateBps: 1000,\n694\t      });\n695\t\n696\t      const token = await makeJwt(referrer);\n697\t      const res = await app.request(\"/referral/claim\", {\n698\t        method: \"POST\",\n699\t        headers: {\n700\t          \"Content-Type\": \"application/json\",\n701\t          Authorization: `Bearer ${token}`,\n702\t        },\n703\t      });\n704\t\n705\t      expect(res.status).toBe(422);\n706\t      const body = (await res.json()) as {\n707\t        ok: false;\n708\t        error: { code: string };\n709\t      };\n710\t      expect(body.ok).toBe(false);\n711\t      expect(body.error.code).toBe(\"BELOW_THRESHOLD\");\n712\t    });\n713\t\n714\t    it(\"creates a pending claim for valid balance\", async () => {\n715\t      // Insert a large enough earning\n716\t      await db.insertReferralEarning({\n717\t        referrerUserId,\n718\t        refereeUserId,\n719\t        referrerWallet: referrer,\n720\t        refereeWallet: referee,\n721\t        roundId: \"big-round\",\n722\t        gameType: \"flipyou\",\n723\t        wagerLamports: 10_000_000_000, // 10 SOL\n724\t        feeLamports: 500_000_000, // 0.5 SOL\n725\t        referrerEarnedLamports: 50_000_000, // 0.05 SOL — above threshold\n726\t        referrerRateBps: 1000,\n727\t      });\n728\t\n729\t      const token = await makeJwt(referrer);\n730\t      const res = await app.request(\"/referral/claim\", {\n731\t        method: \"POST\",\n732\t        headers: {\n733\t          \"Content-Type\": \"application/json\",\n734\t          Authorization: `Bearer ${token}`,\n735\t        },\n736\t      });\n737\t\n738\t      expect(res.status).toBe(202);\n739\t      const body = (await res.json()) as {\n740\t        ok: true;\n741\t        data: {\n742\t          claimId: string;\n743\t          amountLamports: string;\n744\t          status: string;\n745\t        };\n746\t      };\n747\t      expect(body.ok).toBe(true);\n748\t      expect(body.data.claimId).toBeDefined();\n749\t      expect(body.data.amountLamports).toBe(\"50000000\");\n750\t      expect(body.data.status).toBe(\"pending\");\n751\t\n752\t      // Verify event was emitted\n753\t      const events =\n754\t        await rawSql`SELECT * FROM event_queue WHERE event_type = 'referral.claim_requested'`;\n755\t      expect(events.length).toBe(1);\n756\t    });\n757\t\n758\t    it(\"prevents double-claim by deducting pending balance\", async () => {\n759\t      // Insert earning\n760\t      await db.insertReferralEarning({\n761\t        referrerUserId,\n762\t        refereeUserId,\n763\t        referrerWallet: referrer,\n764\t        refereeWallet: referee,\n765\t        roundId: \"double-round\",\n766\t        gameType: \"flipyou\",\n767\t        wagerLamports: 10_000_000_000,\n768\t        feeLamports: 500_000_000,\n769\t        referrerEarnedLamports: 50_000_000,\n770\t        referrerRateBps: 1000,\n771\t      });\n772\t\n773\t      const token = await makeJwt(referrer);\n774\t\n775\t      // First claim succeeds\n776\t      const res1 = await app.request(\"/referral/claim\", {\n777\t        method: \"POST\",\n778\t        headers: {\n779\t          \"Content-Type\": \"application/json\",\n780\t          Authorization: `Bearer ${token}`,\n781\t        },\n782\t      });\n783\t      expect(res1.status).toBe(202);\n784\t\n785\t      // Second claim fails — balance consumed by pending claim\n786\t      const res2 = await app.request(\"/referral/claim\", {\n787\t        method: \"POST\",\n788\t        headers: {\n789\t          \"Content-Type\": \"application/json\",\n790\t          Authorization: `Bearer ${token}`,\n791\t        },\n792\t      });\n793\t      expect(res2.status).toBe(422);\n794\t      const body = (await res2.json()) as {\n795\t        ok: false;\n796\t        error: { code: string };\n797\t      };\n798\t      expect(body.ok).toBe(false);\n799\t      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n800\t    });\n801\t  });\n802\t\n803\t  // -----------------------------------------------------------------------\n804\t  // GET /referral/claim/:claimId — poll claim status\n805\t  // -----------------------------------------------------------------------\n806\t\n807\t  describe(\"GET /referral/claim/:claimId\", () => {\n808\t    it(\"returns claim status for the owner\", async () => {\n809\t      // Insert earning + create claim\n810\t      await db.insertReferralEarning({\n811\t        referrerUserId,\n812\t        refereeUserId,\n813\t        referrerWallet: referrer,\n814\t        refereeWallet: referee,\n815\t        roundId: \"poll-round\",\n816\t        gameType: \"flipyou\",\n817\t        wagerLamports: 10_000_000_000,\n818\t        feeLamports: 500_000_000,\n819\t        referrerEarnedLamports: 50_000_000,\n820\t        referrerRateBps: 1000,\n821\t      });\n822\t\n823\t      const token = await makeJwt(referrer);\n824\t      const claimRes = await app.request(\"/referral/claim\", {\n825\t        method: \"POST\",\n826\t        headers: {\n827\t          \"Content-Type\": \"application/json\",\n828\t          Authorization: `Bearer ${token}`,\n829\t        },\n830\t      });\n831\t      const claimBody = (await claimRes.json()) as {\n832\t        ok: true;\n833\t        data: { claimId: string };\n834\t      };\n835\t      const claim = claimBody.data;\n836\t\n837\t      // Poll status\n838\t      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n839\t        method: \"GET\",\n840\t        headers: { Authorization: `Bearer ${token}` },\n841\t      });\n842\t\n843\t      expect(res.status).toBe(200);\n844\t      const body = (await res.json()) as {\n845\t        ok: true;\n846\t        data: {\n847\t          claimId: string;\n848\t          amountLamports: string;\n849\t          status: string;\n850\t        };\n851\t      };\n852\t      expect(body.ok).toBe(true);\n853\t      expect(body.data.claimId).toBe(claim.claimId);\n854\t      expect(body.data.status).toBe(\"pending\");\n855\t    });\n856\t\n857\t    it(\"returns 404 for non-existent claim\", async () => {\n858\t      const token = await makeJwt(referrer);\n859\t      const res = await app.request(\n860\t        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n861\t        {\n862\t          method: \"GET\",\n863\t          headers: { Authorization: `Bearer ${token}` },\n864\t        },\n865\t      );\n866\t\n867\t      expect(res.status).toBe(404);\n868\t      const body = (await res.json()) as {\n869\t        ok: false;\n870\t        error: { code: string };\n871\t      };\n872\t      expect(body.ok).toBe(false);\n873\t      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n874\t    });"}]},"parent_tool_use_id":null,"session_id":"5319c272-d901-4665-9699-082f2d4ef4a9","uuid":"7c4bc38f-ec01-40d4-9df4-2c65e6427842","timestamp":"2026-05-01T20:16:15.850Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/referral-routes.test.ts","content":"  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/claim — claim flow\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/claim\", () => {\n    it(\"rejects claim with zero balance\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n\n    it(\"rejects claim below minimum threshold\", async () => {\n      // Insert a small earning (below 0.01 SOL threshold)\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"small-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 100_000_000, // 0.1 SOL\n        feeLamports: 5_000_000, // 0.005 SOL\n        referrerEarnedLamports: 500_000, // 0.0005 SOL — below 0.01 threshold\n        referrerRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"BELOW_THRESHOLD\");\n    });\n\n    it(\"creates a pending claim for valid balance\", async () => {\n      // Insert a large enough earning\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"big-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000, // 10 SOL\n        feeLamports: 500_000_000, // 0.5 SOL\n        referrerEarnedLamports: 50_000_000, // 0.05 SOL — above threshold\n        referrerRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(202);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          claimId: string;\n          amountLamports: string;\n          status: string;\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.claimId).toBeDefined();\n      expect(body.data.amountLamports).toBe(\"50000000\");\n      expect(body.data.status).toBe(\"pending\");\n\n      // Verify event was emitted\n      const events =\n        await rawSql`SELECT * FROM event_queue WHERE event_type = 'referral.claim_requested'`;\n      expect(events.length).toBe(1);\n    });\n\n    it(\"prevents double-claim by deducting pending balance\", async () => {\n      // Insert earning\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"double-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n\n      // First claim succeeds\n      const res1 = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      expect(res1.status).toBe(202);\n\n      // Second claim fails — balance consumed by pending claim\n      const res2 = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      expect(res2.status).toBe(422);\n      const body = (await res2.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/claim/:claimId — poll claim status\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/claim/:claimId\", () => {\n    it(\"returns claim status for the owner\", async () => {\n      // Insert earning + create claim\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"poll-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const claimRes = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      const claimBody = (await claimRes.json()) as {\n        ok: true;\n        data: { claimId: string };\n      };\n      const claim = claimBody.data;\n\n      // Poll status\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          claimId: string;\n          amountLamports: string;\n          status: string;\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.claimId).toBe(claim.claimId);\n      expect(body.data.status).toBe(\"pending\");\n    });\n\n    it(\"returns 404 for non-existent claim\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\n        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n    });","numLines":220,"startLine":655,"totalLines":997}}}
