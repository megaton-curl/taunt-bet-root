n298\t      `FlipYou entropy expired for target slot ${targetSlot.toString()} (current slot ${currentSlot.toString()}); waiting for timeout refund`,\n299\t    );\n300\t  }\n301\t\n302\t  const pool = entryAmount * 2n;\n303\t  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n304\t  const payoutAmount = Number(pool) - feeAmount;\n305\t\n306\t  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n307\t\n308\t  // 5. Pre-compute result\n309\t  const matchPdaBytes = matchPubkey.toBuffer();\n310\t  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n311\t  const resultSide = resultHash[0]! % 2;\n312\t  const winner = resultSide === creatorSide ? creator : opponent;\n313\t\n314\t  // 6. Build settle instruction (8 accounts, no profile CPI)\n315\t  const data = encodeSettleData(secret);\n316\t\n317\t  const instruction = new TransactionInstruction({\n318\t    keys: [\n319\t      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller"}]},"parent_tool_use_id":null,"session_id":"7a59072f-9629-42fa-9b0e-370a41c8b6fc","uuid":"bfce52a9-1363-4b05-8c00-c02cb4b4a192","timestamp":"2026-05-01T20:12:41.806Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/worker/settle-tx.ts","content":"  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")\n    .update(secret)\n    .update(entropy)\n    .update(matchPdaBytes)\n    .update(Buffer.from([algoVer]))\n    .digest();\n}\n\n// ---------------------------------------------------------------------------\n// Fee allocation + referral earnings hook\n// ---------------------------------------------------------------------------\n\n/**\n * After a game settles, write one `fee_allocation_events` row per unique\n * player (referred or not), and an additional `referral_earnings` row for\n * referred players.\n *\n * For each unique player: look up profile + referral