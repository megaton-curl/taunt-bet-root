location.referralLamports,\n        promotionsLamports: allocation.promotionsLamports,\n        profitLamports: allocation.profitLamports,\n      });\n\n      if (link && refereeProfile) {\n        await db.insertReferralEarning({\n          referrerUserId: link.referrer_user_id,\n          refereeUserId: refereeProfile.user_id,\n          referrerWallet: link.referrer_wallet,\n          refereeWallet: wallet,\n          roundId,\n          gameType,\n          wagerLamports,\n          feeLamports,\n          referrerEarnedLamports: allocation.referralLamports,\n          referrerRateBps,\n        });\n\n        logger.info(\"referral earning recorded\", {\n          roundId,\n          gameType,\n          referrerUserId: link.referrer_user_id,\n          refereeUserId: refereeProfile.user_id,\n          referrerEarnedLamports: allocation.referralLamports,\n        });\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n        logger.info(\"fee accounting row already recorded (idempotent skip)\", {\n          roundId,\n          wallet,\n        });\n      } else {\n        logger.error(\"failed to record fee accounting row\", {\n          roundId,\n          wallet,\n          error: msg,\n        });\n      }\n    }\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage ŌĆö account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on co