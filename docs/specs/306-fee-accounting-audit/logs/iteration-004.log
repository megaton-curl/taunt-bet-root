{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qx7bdrFc6xa96tVbk18T5Y","type":"tool_result","content":"1\t/**\n2\t * Fee accounting unit + DB constraint coverage.\n3\t *\n4\t * - `calculateFeeAllocation`: pure FR-2 split (referral floor → promotions\n5\t *   floor on remainder × 20% → profit absorbs dust).\n6\t * - `fee_allocation_events` CHECK constraint: the DB rejects rows whose\n7\t *   referral + promotions + profit components do not sum to `fee_lamports`.\n8\t *\n9\t * The DB-backed test mirrors the safety net the audit snapshot relies on —\n10\t * if a future refactor of `insertFeeAllocation` or migration weakens the\n11\t * constraint, this test fails before the snapshot ever sees a bad row.\n12\t */\n13\t\n14\timport { describe, it, expect, afterAll } from \"vitest\";\n15\timport postgres from \"postgres\";\n16\timport { calculateFeeAllocation } from \"../db/fee-accounting.js\";\n17\t\n18\tconst DATABASE_URL =\n19\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n20\t\n21\tfunction makeSql() {\n22\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n23\t  return postgres({\n24\t    host: \"/var/run/postgresql\",\n25\t    user: \"vscode\",\n26\t    database: \"taunt_bet_dev\",\n27\t  });\n28\t}\n29\t\n30\t// ---------------------------------------------------------------------------\n31\t// calculateFeeAllocation — pure FR-2 split\n32\t// ---------------------------------------------------------------------------\n33\t\n34\tdescribe(\"calculateFeeAllocation\", () => {\n35\t  it(\"0 bps referral: referral=0, promotions=20% floor, profit=remainder\", () => {\n36\t    const split = calculateFeeAllocation(1000, 0);\n37\t    expect(split.referralLamports).toBe(0);\n38\t    expect(split.promotionsLamports).toBe(200);\n39\t    expect(split.profitLamports).toBe(800);\n40\t  });\n41\t\n42\t  it(\"10000 bps (100%) referral: referral=fee, promotions=0, profit=0\", () => {\n43\t    const split = calculateFeeAllocation(1000, 10000);\n44\t    expect(split.referralLamports).toBe(1000);\n45\t    expect(split.promotionsLamports).toBe(0);\n46\t    expect(split.profitLamports).toBe(0);\n47\t  });\n48\t\n49\t  it(\"mid-range bps splits cleanly when math is integer\", () => {\n50\t    // 500 referral, 100 promotions (20% of 500 remaining), 400 profit.\n51\t    const split = calculateFeeAllocation(1000, 5000);\n52\t    expect(split.referralLamports).toBe(500);\n53\t    expect(split.promotionsLamports).toBe(100);\n54\t    expect(split.profitLamports).toBe(400);\n55\t  });\n56\t\n57\t  it(\"dust from referral floor lands in profit, never in promotions\", () => {\n58\t    // fee=7, bps=5000 → referral=floor(3.5)=3, post=4, promo=floor(0.8)=0, profit=4.\n59\t    const split = calculateFeeAllocation(7, 5000);\n60\t    expect(split.referralLamports).toBe(3);\n61\t    expect(split.promotionsLamports).toBe(0);\n62\t    expect(split.profitLamports).toBe(4);\n63\t  });\n64\t\n65\t  it(\"single-lamport fee with non-zero referral rate puts the lamport in profit\", () => {\n66\t    // fee=1, bps=1 → referral=floor(0.0001)=0, promo=floor(0.2)=0, profit=1.\n67\t    const split = calculateFeeAllocation(1, 1);\n68\t    expect(split.referralLamports).toBe(0);\n69\t    expect(split.promotionsLamports).toBe(0);\n70\t    expect(split.profitLamports).toBe(1);\n71\t  });\n72\t\n73\t  it(\"feeLamports=0 produces zero across all buckets regardless of bps\", () => {\n74\t    for (const bps of [0, 1, 1000, 5000, 9999, 10000]) {\n75\t      const split = calculateFeeAllocation(0, bps);\n76\t      expect(split.referralLamports).toBe(0);\n77\t      expect(split.promotionsLamports).toBe(0);\n78\t      expect(split.profitLamports).toBe(0);\n79\t    }\n80\t  });\n81\t\n82\t  it(\"max-bps (10000) leaves nothing for promotions or profit even with dust\", () => {\n83\t    // The floor at 100% bps consumes the entire fee.\n84\t    const split = calculateFeeAllocation(13, 10000);\n85\t    expect(split.referralLamports).toBe(13);\n86\t    expect(split.promotionsLamports).toBe(0);\n87\t    expect(split.profitLamports).toBe(0);\n88\t  });\n89\t\n90\t  it(\"components always sum exactly to feeLamports across a wide grid\", () => {\n91\t    const fees = [0, 1, 7, 500, 1000, 5000, 12345, 1_000_000, 9_999_999];\n92\t    const bpsValues = [0, 1, 100, 500, 1000, 2500, 5000, 7500, 9999, 10000];\n93\t\n94\t    for (const fee of fees) {\n95\t      for (const bps of bpsValues) {\n96\t        const split = calculateFeeAllocation(fee, bps);\n97\t        const sum =\n98\t          split.referralLamports +\n99\t          split.promotionsLamports +\n100\t          split.profitLamports;\n101\t        expect(sum, `fee=${fee}, bps=${bps}`).toBe(fee);\n102\t        expect(split.referralLamports).toBeGreaterThanOrEqual(0);\n103\t        expect(split.promotionsLamports).toBeGreaterThanOrEqual(0);\n104\t        expect(split.profitLamports).toBeGreaterThanOrEqual(0);\n105\t      }\n106\t    }\n107\t  });\n108\t\n109\t  it(\"rejects negative fee, non-integer fee, and out-of-range bps\", () => {\n110\t    expect(() => calculateFeeAllocation(-1, 0)).toThrow();\n111\t    expect(() => calculateFeeAllocation(1.5, 0)).toThrow();\n112\t    expect(() => calculateFeeAllocation(100, -1)).toThrow();\n113\t    expect(() => calculateFeeAllocation(100, 10001)).toThrow();\n114\t    expect(() => calculateFeeAllocation(100, 1.5)).toThrow();\n115\t  });\n116\t});\n117\t\n118\t// ---------------------------------------------------------------------------\n119\t// DB CHECK constraint — components must sum to fee_lamports\n120\t// ---------------------------------------------------------------------------\n121\t\n122\tdescribe(\"fee_allocation_events CHECK ck_fee_allocation_components_sum\", () => {\n123\t  const sql = makeSql();\n124\t\n125\t  afterAll(async () => {\n126\t    await sql.end();\n127\t  });\n128\t\n129\t  it(\"rejects an allocation row whose components do not sum to fee_lamports\", async () => {\n130\t    const sourceId = `test-${Date.now()}-${Math.random().toString(36).slice(2)}`;\n131\t    const wallet = `wallet-${Math.random().toString(36).slice(2)}`;\n132\t\n133\t    await expect(\n134\t      sql`\n135\t        INSERT INTO fee_allocation_events (\n136\t          source_type, source_id, game_type, wallet,\n137\t          wager_lamports, fee_lamports,\n138\t          referral_rate_bps,\n139\t          referral_lamports, promotions_lamports, profit_lamports\n140\t        ) VALUES (\n141\t          'unit_test',\n142\t          ${sourceId},\n143\t          'flipyou',\n144\t          ${wallet},\n145\t          1000000,\n146\t          1000,\n147\t          0,\n148\t          0, 200, 700\n149\t        )\n150\t      `,\n151\t    ).rejects.toThrow(/ck_fee_allocation_components_sum/);\n152\t\n153\t    const rows = await sql<{ count: string }[]>`\n154\t      SELECT COUNT(*)::TEXT AS count\n155\t      FROM fee_allocation_events\n156\t      WHERE source_id = ${sourceId}\n157\t    `;\n158\t    expect(rows[0]!.count).toBe(\"0\");\n159\t  });\n160\t\n161\t  it(\"accepts an allocation row whose components sum to fee_lamports\", async () => {\n162\t    const sourceId = `test-${Date.now()}-${Math.random().toString(36).slice(2)}`;\n163\t    const wallet = `wallet-${Math.random().toString(36).slice(2)}`;\n164\t\n165\t    await sql`\n166\t      INSERT INTO fee_allocation_events (\n167\t        source_type, source_id, game_type, wallet,\n168\t        wager_lamports, fee_lamports,\n169\t        referral_rate_bps,\n170\t        referral_lamports, promotions_lamports, profit_lamports\n171\t      ) VALUES (\n172\t        'unit_test',\n173\t        ${sourceId},\n174\t        'flipyou',\n175\t        ${wallet},\n176\t        1000000,\n177\t        1000,\n178\t        0,\n179\t        0, 200, 800\n180\t      )\n181\t    `;\n182\t\n183\t    try {\n184\t      const rows = await sql<{ count: string }[]>`\n185\t        SELECT COUNT(*)::TEXT AS count\n186\t        FROM fee_allocation_events\n187\t        WHERE source_id = ${sourceId}\n188\t      `;\n189\t      expect(rows[0]!.count).toBe(\"1\");\n190\t    } finally {\n191\t      await sql`\n192\t        DELETE FROM fee_allocation_events WHERE source_id = ${sourceId}\n193\t      `;\n194\t    }\n195\t  });\n196\t\n197\t  // Reference DATABASE_URL constant so dead-code lint stays happy when the\n198\t  // test file is opened in IDEs that don't run the integration suite.\n199\t  it(\"connects via DATABASE_URL or the local Unix socket fallback\", () => {\n200\t    expect(typeof DATABASE_URL).toBe(\"string\");\n201\t  });\n202\t});\n203\t"}]},"parent_tool_use_id":null,"session_id":"95bddc66-9130-4a20-a282-3ebe2ee80e9c","uuid":"6a985d2d-0482-4bcc-9a50-a2beb1afecf6","timestamp":"2026-05-01T19:50:42.717Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/fee-accounting.test.ts","content":"/**\n * Fee accounting unit + DB constraint coverage.\n *\n * - `calculateFeeAllocation`: pure FR-2 split (referral floor → promotions\n *   floor on remainder × 20% → profit absorbs dust).\n * - `fee_allocation_events` CHECK constraint: the DB rejects rows whose\n *   referral + promotions + profit components do not sum to `fee_lamports`.\n *\n * The DB-backed test mirrors the safety net the audit snapshot relies on —\n * if a future refactor of `insertFeeAllocation` or migration weakens the\n * constraint, this test fails before the snapshot ever sees a bad row.\n */\n\nimport { describe, it, expect, afterAll } from \"vitest\";\nimport postgres from \"postgres\";\nimport { calculateFeeAllocation } from \"../db/fee-accounting.js\";\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// calculateFeeAllocation — pure FR-2 split\n// ---------------------------------------------------------------------------\n\ndescribe(\"calculateFeeAllocation\", () => {\n  it(\"0 bps referral: referral=0, promotions=20% floor, profit=remainder\", () => {\n    const split = calculateFeeAllocation(1000, 0);\n    expect(split.referralLamports).toBe(0);\n    expect(split.promotionsLamports).toBe(200);\n    expect(split.profitLamports).toBe(800);\n  });\n\n  it(\"10000 bps (100%) referral: referral=fee, promotions=0, profit=0\", () => {\n    const split = calculateFeeAllocation(1000, 10000);\n    expect(split.referralLamports).toBe(1000);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(0);\n  });\n\n  it(\"mid-range bps splits cleanly when math is integer\", () => {\n    // 500 referral, 100 promotions (20% of 500 remaining), 400 profit.\n    const split = calculateFeeAllocation(1000, 5000);\n    expect(split.referralLamports).toBe(500);\n    expect(split.promotionsLamports).toBe(100);\n    expect(split.profitLamports).toBe(400);\n  });\n\n  it(\"dust from referral floor lands in profit, never in promotions\", () => {\n    // fee=7, bps=5000 → referral=floor(3.5)=3, post=4, promo=floor(0.8)=0, profit=4.\n    const split = calculateFeeAllocation(7, 5000);\n    expect(split.referralLamports).toBe(3);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(4);\n  });\n\n  it(\"single-lamport fee with non-zero referral rate puts the lamport in profit\", () => {\n    // fee=1, bps=1 → referral=floor(0.0001)=0, promo=floor(0.2)=0, profit=1.\n    const split = calculateFeeAllocation(1, 1);\n    expect(split.referralLamports).toBe(0);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(1);\n  });\n\n  it(\"feeLamports=0 produces zero across all buckets regardless of bps\", () => {\n    for (const bps of [0, 1, 1000, 5000, 9999, 10000]) {\n      const split = calculateFeeAllocation(0, bps);\n      expect(split.referralLamports).toBe(0);\n      expect(split.promotionsLamports).toBe(0);\n      expect(split.profitLamports).toBe(0);\n    }\n  });\n\n  it(\"max-bps (10000) leaves nothing for promotions or profit even with dust\", () => {\n    // The floor at 100% bps consumes the entire fee.\n    const split = calculateFeeAllocation(13, 10000);\n    expect(split.referralLamports).toBe(13);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(0);\n  });\n\n  it(\"components always sum exactly to feeLamports across a wide grid\", () => {\n    const fees = [0, 1, 7, 500, 1000, 5000, 12345, 1_000_000, 9_999_999];\n    const bpsValues = [0, 1, 100, 500, 1000, 2500, 5000, 7500, 9999, 10000];\n\n    for (const fee of fees) {\n      for (const bps of bpsValues) {\n        const split = calculateFeeAllocation(fee, bps);\n        const sum =\n          split.referralLamports +\n          split.promotionsLamports +\n          split.profitLamports;\n        expect(sum, `fee=${fee}, bps=${bps}`).toBe(fee);\n        expect(split.referralLamports).toBeGreaterThanOrEqual(0);\n        expect(split.promotionsLamports).toBeGreaterThanOrEqual(0);\n        expect(split.profitLamports).toBeGreaterThanOrEqual(0);\n      }\n    }\n  });\n\n  it(\"rejects negative fee, non-integer fee, and out-of-range bps\", () => {\n    expect(() => calculateFeeAllocation(-1, 0)).toThrow();\n    expect(() => calculateFeeAllocation(1.5, 0)).toThrow();\n    expect(() => calculateFeeAllocation(100, -1)).toThrow();\n    expect(() => calculateFeeAllocation(100, 10001)).toThrow();\n    expect(() => calculateFeeAllocation(100, 1.5)).toThrow();\n  });\n});\n\n// ---------------------------------------------------------------------------\n// DB CHECK constraint — components must sum to fee_lamports\n// ---------------------------------------------------------------------------\n\ndescribe(\"fee_allocation_events CHECK ck_fee_allocation_components_sum\", () => {\n  const sql = makeSql();\n\n  afterAll(async () => {\n    await sql.end();\n  });\n\n  it(\"rejects an allocation row whose components do not sum to fee_lamports\", async () => {\n    const sourceId = `test-${Date.now()}-${Math.random().toString(36).slice(2)}`;\n    const wallet = `wallet-${Math.random().toString(36).slice(2)}`;\n\n    await expect(\n      sql`\n        INSERT INTO fee_allocation_events (\n          source_type, source_id, game_type, wallet,\n          wager_lamports, fee_lamports,\n          referral_rate_bps,\n          referral_lamports, promotions_lamports, profit_lamports\n        ) VALUES (\n          'unit_test',\n          ${sourceId},\n          'flipyou',\n          ${wallet},\n          1000000,\n          1000,\n          0,\n          0, 200, 700\n        )\n      `,\n    ).rejects.toThrow(/ck_fee_allocation_components_sum/);\n\n    const rows = await sql<{ count: string }[]>`\n      SELECT COUNT(*)::TEXT AS count\n      FROM fee_allocation_events\n      WHERE source_id = ${sourceId}\n    `;\n    expect(rows[0]!.count).toBe(\"0\");\n  });\n\n  it(\"accepts an allocation row whose components sum to fee_lamports\", async () => {\n    const sourceId = `test-${Date.now()}-${Math.random().toString(36).slice(2)}`;\n    const wallet = `wallet-${Math.random().toString(36).slice(2)}`;\n\n    await sql`\n      INSERT INTO fee_allocation_events (\n        source_type, source_id, game_type, wallet,\n        wager_lamports, fee_lamports,\n        referral_rate_bps,\n        referral_lamports, promotions_lamports, profit_lamports\n      ) VALUES (\n        'unit_test',\n        ${sourceId},\n        'flipyou',\n        ${wallet},\n        1000000,\n        1000,\n        0,\n        0, 200, 800\n      )\n    `;\n\n    try {\n      const rows = await sql<{ count: string }[]>`\n        SELECT COUNT(*)::TEXT AS count\n        FROM fee_allocation_events\n        WHERE source_id = ${sourceId}\n      `;\n      expect(rows[0]!.count).toBe(\"1\");\n    } finally {\n      await sql`\n        DELETE FROM fee_allocation_events WHERE source_id = ${sourceId}\n      `;\n    }\n  });\n\n  // Reference DATABASE_URL constant so dead-code lint stays happy when the\n  // test file is opened in IDEs that don't run the integration suite.\n  it(\"connects via DATABASE_URL or the local Unix socket fallback\", () => {\n    expect(typeof DATABASE_URL).toBe(\"string\");\n  });\n});\n","numLines":203,"startLine":1,"totalLines":203}}}
