\t  const [platformConfigPda] = derivePlatformConfigPda();\n269\t  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n270\t    await Promise.all([\n271\t      connection.getAccountInfo(matchPubkey),\n272\t      getPlatformConfig(connection),\n273\t      connection.getAccountInfo(entropyAccount),\n274\t      connection.getLatestBlockhash(),\n275\t    ]);\n276\t  const tFetch = performance.now();\n277\t\n278\t  if (!matchAccountInfo) {\n279\t    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n280\t  }\n281\t  if (!entropyInfo) {\n282\t    throw new TransientSettleError(\"Entropy account not available yet\");\n283\t  }\n284\t\n285\t  // IDL-driven decode — no manual byte offsets\n286\t  const match = decodeFlipYouMatch(Buffer.from(matchAccountInfo.data));\n287\t  const { feeBps, treasury } = platformConfig;\n288\t\n289\t  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer, targetSlot } = match;\n290\t\n291\t  const currentSlot = BigInt(await connection.getSlot(\"confirmed\"));\n292\t  if (\n293\t    targetSlot > 0n &&\n294\t    currentSlot > targetSlot &&\n295\t    currentSlot - targetSlot > SLOT_HASHES_WINDOW_SLOTS\n296\t  ) {\n297\t    throw new EntropyExpiredSettleError(\n298\t      `FlipYou entropy expired for target slot ${targetSlot.toString()} (current slot ${currentSlot.toString()}); waiting for timeout refund`,\n299\t    );\n300\t  }\n301\t\n302\t  const pool = entryAmount * 2n;\n303\t  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n304\t  const payoutAmount = Number(pool) - feeAmount;\n305\t\n306\t  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n307\t\n308\t  // 5. Pre-compute result\n309\t  const matchPdaBytes = matchPubkey.toBuffer();\n310\t  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n311\t  const resultSide = resultHash[0]! % 2;\n312\t  const winner = resultSide === creatorSide ? creator : opponent;\n313\t\n314\t  // 6. Build settle instruction (8 accounts, no profile CPI)\n315\t  const data = encodeSettleData(secret);\n316\t\n317\t  const instruction = new TransactionInstruction({\n318\t    keys: [\n319\t      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n320\t      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // flipyou_match\n321\t      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n322\t      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n323\t      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n324\t      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n325\t      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n326\t      {\n327\t        pubkey: SystemProgram.programId,\n328\t        isSigner: false,\n329\t        isWritable: false,\n330\t      }, // system_program\n331\t    ],\n332\t    programId: FLIPYOU_PROGRAM_ID,\n333\t    data,\n334\t  });\n335\t\n336\t  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n337\t\n338\t  const tx = new Transaction({\n339\t    feePayer: serverKeypair.publicKey,\n340\t    blockhash,\n341\t    lastValidBlockHeight,\n342\t  });\n343\t  tx.add(instruction);\n344\t  tx.sign(serverKeypair);\n345\t\n346\t  // 7. Submit and confirm\n347\t  const rawTx = tx.serialize();\n348\t  const tBuild = performance.now();\n349\t  const txSignature = await connection.sendRawTransaction(rawTx, {"}]},"parent_tool_use_id":null,"session_id":"578af45b-198a-413d-ab1a-ea47ca34e7b2","uuid":"8767e923-8a72-4ea5-950c-b1b53e588947","timestamp":"2026-05-01T20:04:49.940Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/worker/settle-tx.ts","content":" * referred players.\n *\n * For each unique player: look up profile + referral link → compute the\n * deterministic fee split via `calculateFeeAllocation` → write the\n * allocation row. If a referrer is present, also write the legacy\n * `referral_earnings` row.\n *\n * Errors are logged but never bubble — accounting must not fail settlement.\n * Idempotency: `fee_allocation_events` UNIQUE on (source_type, source_id,\n * wallet) plus `ON CONFLICT DO NOTHING` in `insertFeeAllocation`;\n * `referral_earnings` UNIQUE on (referee_user_id, round_id).\n */\nexport async function recordReferralEarnings(\n  db: Db,\n  params: {\n    roundId: string;\n    gameType: string;\n    feeBps: number;\n    referralDefaultRateBps: number;\n    players: Array<{ wallet: string; wagerLamports: number }>;\n  },\n): Promise<void> {\n  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n\n  // Deduplicate players (Pot Shot can have multiple entries per player)\n  const playerWagers = new Map<string, number>();\n  for (const p of players) {\n    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n  }\n\n  for (const [wallet, wagerLamports] of playerWagers) {\n    try {\n      const refereeProfile = await db.getProfileByWallet(wallet);\n      const link = refereeProfile\n        ? await db.getReferralLinkByRefereeUserId(refereeProfile.user_id)\n        : undefined;\n\n      const referrerRateBps = link\n        ? await db.getReferrerRate(link.referrer_user_id, referralDefaultRateBps)\n        : 0;\n\n      const feeLamports = Math.floor((wagerLamports * feeBps) / 10_000);\n      const allocation = calculateFeeAllocation(feeLamports, referrerRateBps);\n\n      await db.insertFeeAllocation({\n        sourceType: gameType,\n        sourceId: roundId,\n        gameType,\n        wallet,\n        userId: refereeProfile?.user_id ?? null,\n        wagerLamports,\n        feeLamports,\n        referrerUserId: link?.referrer_user_id ?? null,\n        referralRateBps: referrerRateBps,\n        referralLamports: allocation.referralLamports,\n        promotionsLamports: allocation.promotionsLamports,\n        profitLamports: allocation.profitLamports,\n      });\n\n      if (link && refereeProfile) {\n        await db.insertReferralEarning({\n          referrerUserId: link.referrer_user_id,\n          refereeUserId: refereeProfile.user_id,\n          referrerWallet: link.referrer_wallet,\n          refereeWallet: wallet,\n          roundId,\n          gameType,\n          wagerLamports,\n          feeLamports,\n          referrerEarnedLamports: allocation.referralLamports,\n          referrerRateBps,\n        });\n\n        logger.info(\"referral earning recorded\", {\n          roundId,\n          gameType,\n          referrerUserId: link.referrer_user_id,\n          refereeUserId: refereeProfile.user_id,\n          referrerEarnedLamports: allocation.referralLamports,\n        });\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n        logger.info(\"fee accounting row already recorded (idempotent skip)\", {\n          roundId,\n          wallet,\n        });\n      } else {\n        logger.error(\"failed to record fee accounting row\", {\n          roundId,\n          wallet,\n          error: msg,\n        });\n      }\n    }\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on confirmation\n */\nexport async function settleMatch(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const matchPubkey = new PublicKey(pda);\n\n  // 1. Retrieve secret from DB\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  // Transition to settling (locked → settling)\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  // Log settle_submitted\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n  });\n\n  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n  const [platformConfigPda] = derivePlatformConfigPda();\n  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(matchPubkey),\n      getPlatformConfig(connection),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n  const tFetch = performance.now();\n\n  if (!matchAccountInfo) {\n    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets\n  const match = decodeFlipYouMatch(Buffer.from(matchAccountInfo.data));\n  const { feeBps, treasury } = platformConfig;\n\n  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer, targetSlot } = match;\n\n  const currentSlot = BigInt(await connection.getSlot(\"confirmed\"));\n  if (\n    targetSlot > 0n &&\n    currentSlot > targetSlot &&\n    currentSlot - targetSlot > SLOT_HASHES_WINDOW_SLOTS\n  ) {\n    throw new EntropyExpiredSettleError(\n      `FlipYou entropy expired for target slot ${targetSlot.toString()} (current slot ${currentSlot.toString()}); waiting for timeout refund`,\n    );\n  }\n\n  const pool = entryAmount * 2n;\n  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n  const payoutAmount = Number(pool) - feeAmount;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n\n  // 5. Pre-compute result\n  const matchPdaBytes = matchPubkey.toBuffer();\n  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n  const resultSide = resultHash[0]! % 2;\n  const winner = resultSide === creatorSide ? creator : opponent;\n\n  // 6. Build settle instruction (8 accounts, no profile CPI)\n  const data = encodeSettleData(secret);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // flipyou_match\n      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      }, // system_program\n    ],\n    programId: FLIPYOU_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  // 7. Submit and confirm\n  const rawTx = tx.serialize();\n  const tBuild = performance.now();\n  con