{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018t5BpDxTvLwKvJXPoAT5AD","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/__tests__/integration-test-helpers.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"578af45b-198a-413d-ab1a-ea47ca34e7b2","uuid":"5f5464c8-768d-4d44-98c9-dbddc7d6802b","timestamp":"2026-05-01T20:06:03.797Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/integration-test-helpers.ts","oldString":"const RESET_TABLES = [\n  \"rounds\",\n  \"closecall_rounds\",\n  \"closecall_candles\",\n  \"operator_events\",\n  \"event_queue\",\n  \"game_entries\",\n  \"transactions\",\n  \"player_profiles\",\n  \"referral_codes\",\n  \"referral_links\",\n  \"referral_earnings\",\n  \"referral_claims\",\n  \"referral_kol_rates\",\n  \"reward_pool_fundings\",\n  \"point_grants\",\n  \"point_balances\",\n  \"point_rate_versions\",\n  \"multiplier_modifiers\",\n  \"multiplier_ladder_steps\",\n  \"multiplier_ladders\",\n  \"events\",\n  \"seasons\",\n  \"crate_drops\",\n  \"progress_events\",\n  \"challenge_assignments\",\n  \"bonus_completions\",\n].join(\", \");","newString":"const RESET_TABLES = [\n  \"rounds\",\n  \"closecall_rounds\",\n  \"closecall_candles\",\n  \"operator_events\",\n  \"event_queue\",\n  \"game_entries\",\n  \"transactions\",\n  \"player_profiles\",\n  \"referral_codes\",\n  \"referral_links\",\n  \"referral_earnings\",\n  \"referral_claims\",\n  \"referral_kol_rates\",\n  \"reward_pool_fundings\",\n  \"point_grants\",\n  \"point_balances\",\n  \"point_rate_versions\",\n  \"multiplier_modifiers\",\n  \"multiplier_ladder_steps\",\n  \"multiplier_ladders\",\n  \"events\",\n  \"seasons\",\n  \"crate_drops\",\n  \"progress_events\",\n  \"challenge_assignments\",\n  \"bonus_completions\",\n  \"fee_allocation_events\",\n  \"fee_bucket_debits\",\n  \"fee_audit_checkpoints\",\n].join(\", \");","originalFile":"import { SignJWT } from \"jose\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport {\n  LAMPORTS_PER_SOL,\n  PublicKey,\n  SystemProgram,\n} from \"@solana/web3.js\";\nimport { createDb, type Db } from \"../db.js\";\nimport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\nimport {\n  PLATFORM_PROGRAM_ID,\n  derivePlatformConfigPda,\n} from \"../platform-config.js\";\nimport {\n  encodeFlipYouConfig,\n  encodeFlipYouMatch,\n} from \"../worker/account-decoder.js\";\n\nexport const DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\nexport const AMOUNT_LAMPORTS = 5_000_000;\nexport const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\nexport const SIDE_HEADS = 0;\nexport const PHASE_LOCKED = 1;\nexport const JWT_SECRET = new TextEncoder().encode(\n  \"test-secret-for-integration-tests\",\n);\n\nconst RESET_TABLES = [\n  \"rounds\",\n  \"closecall_rounds\",\n  \"closecall_candles\",\n  \"operator_events\",\n  \"event_queue\",\n  \"game_entries\",\n  \"transactions\",\n  \"player_profiles\",\n  \"referral_codes\",\n  \"referral_links\",\n  \"referral_earnings\",\n  \"referral_claims\",\n  \"referral_kol_rates\",\n  \"reward_pool_fundings\",\n  \"point_grants\",\n  \"point_balances\",\n  \"point_rate_versions\",\n  \"multiplier_modifiers\",\n  \"multiplier_ladder_steps\",\n  \"multiplier_ladders\",\n  \"events\",\n  \"seasons\",\n  \"crate_drops\",\n  \"progress_events\",\n  \"challenge_assignments\",\n  \"bonus_completions\",\n].join(\", \");\n\nexport type TestSql = ReturnType<typeof postgres>;\n\nexport interface IntegrationDbContext {\n  db: Db;\n  rawSql: TestSql;\n}\n\nlet referralTablesEnsured = false;\nlet rewardEconomyTablesEnsured = false;\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nexport function makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nexport async function openIntegrationDb(): Promise<IntegrationDbContext> {\n  const rawSql = makeSql();\n  await ensureReferralTables(rawSql);\n  await ensureRewardEconomyTables(rawSql);\n  return {\n    rawSql,\n    db: createDb(DATABASE_URL, rawSql),\n  };\n}\n\nexport async function closeIntegrationDb(ctx: IntegrationDbContext) {\n  await ctx.db.close();\n  await ctx.rawSql.end();\n}\n\n/**\n * Seed a player_profile row for a test. Production creates profiles via the\n * auth flow before any wager fires; tests that bypass auth and call the\n * points-grant handler directly need to pre-create the row, since the\n * handler now updates the profile in-place for materialized economy state.\n */\nexport async function seedPlayerProfile(\n  rawSql: TestSql,\n  userId: string,\n  wallet: string,\n  username: string = `tester-${userId}`,\n): Promise<void> {\n  await rawSql`\n    INSERT INTO player_profiles (user_id, wallet, username)\n    VALUES (${userId}, ${wallet}, ${username})\n    ON CONFLICT (user_id) DO NOTHING\n  `;\n}\n\nexport async function resetIntegrationState(rawSql: TestSql) {\n  await ensureReferralTables(rawSql);\n  await ensureRewardEconomyTables(rawSql);\n  await rawSql.begin(async (tx) => {\n    const sql = tx as unknown as TestSql;\n    await sql`SELECT pg_advisory_xact_lock(401402)`;\n    await sql.unsafe(`TRUNCATE ${RESET_TABLES} RESTART IDENTITY CASCADE`);\n    await sql`\n    INSERT INTO reward_pool (\n      id,\n      balance_lamports,\n      lifetime_funded,\n      lifetime_paid,\n      updated_at\n    )\n    VALUES (1, 0, 0, 0, now())\n    ON CONFLICT (id) DO UPDATE\n    SET\n      balance_lamports = EXCLUDED.balance_lamports,\n      lifetime_funded = EXCLUDED.lifetime_funded,\n      lifetime_paid = EXCLUDED.lifetime_paid,\n      updated_at = EXCLUDED.updated_at\n  `;\n    await sql`\n    INSERT INTO seasons (slug, name, starts_at, status)\n    VALUES ('season-1', 'Season 1', '2026-01-01T00:00:00Z', 'active')\n  `;\n    await sql`\n    INSERT INTO point_rate_versions (rate_per_usd, effective_from, label)\n    VALUES (100, '2026-01-01T00:00:00Z', 'Launch default')\n  `;\n    await sql`\n      DELETE FROM reward_config\n      WHERE key IN ('points_per_dollar', 'dogpile_default_multiplier')\n    `;\n    await sql`\n      INSERT INTO reward_config (key, value)\n      VALUES\n        ('reward_pool_fee_share', '0.20'),\n        ('points_crate_drop_rate', '0.05'),\n        ('sol_crate_drop_rate', '0.01'),\n        ('sol_crate_pool_pct', '0.10'),\n        ('sol_crate_min_value', '10000000'),\n        ('points_crate_min', '500'),\n        ('points_crate_max', '5000'),\n        ('daily_challenge_count', '3'),\n        ('weekly_challenge_count', '2')\n      ON CONFLICT (key) DO UPDATE\n      SET value = EXCLUDED.value, updated_at = now()\n    `;\n    await sql`\n    WITH lifetime_ladder AS (\n      INSERT INTO multiplier_ladders (scope, metric, effective_from, label)\n      VALUES ('lifetime', 'wagered_usd', '2026-01-01T00:00:00Z', 'Launch lifetime ladder')\n      RETURNING id\n    )\n    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n    SELECT id, level, threshold_usd, multiplier, level\n    FROM lifetime_ladder\n    CROSS JOIN (VALUES\n      (1, 1000, 1.10),\n      (2, 10000, 1.20),\n      (3, 50000, 1.30),\n      (4, 100000, 1.40),\n      (5, 250000, 1.50),\n      (6, 500000, 1.60),\n      (7, 1000000, 1.70),\n      (8, 2500000, 1.80),\n      (9, 5000000, 1.90),\n      (10, 10000000, 2.00)\n    ) AS steps(level, threshold_usd, multiplier)\n  `;\n    await sql`\n    WITH active_season AS (\n      SELECT id FROM seasons WHERE status = 'active' LIMIT 1\n    ),\n    season_ladder AS (\n      INSERT INTO multiplier_ladders (scope, metric, season_id, effective_from, label)\n      SELECT 'season', 'wagered_usd', id, '2026-01-01T00:00:00Z', 'Launch season ladder'\n      FROM active_season\n      RETURNING id\n    )\n    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n    SELECT id, level, threshold_usd, multiplier, level\n    FROM season_ladder\n    CROSS JOIN (VALUES\n      (1, 500, 1.20),\n      (2, 5000, 1.50),\n      (3, 25000, 2.00),\n      (4, 100000, 2.50),\n      (5, 250000, 3.00)\n    ) AS steps(level, threshold_usd, multiplier)\n  `;\n  });\n}\n\nexport async function makeJwt(\n  wallet: string,\n  userId = userIdFromWallet(wallet),\n) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nexport function userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n/**\n * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n */\nexport class MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getSlot() {\n    return this._slot;\n  }\n\n  async getAccountInfo(pubkey: PublicKey) {\n    const acc = this._accounts.get(pubkey.toBase58());\n    if (!acc) return null;\n    return { ...acc, rentEpoch: 0 };\n  }\n\n  async getProgramAccounts(\n    programId: PublicKey,\n    config?: {\n      filters?: Array<\n        | { dataSize: number }\n        | { memcmp: { offset: number; bytes: string } }\n      >;\n    },\n  ) {\n    const results: Array<{\n      pubkey: PublicKey;\n      account: {\n        data: Buffer;\n        lamports: number;\n        owner: PublicKey;\n        executable: boolean;\n        rentEpoch: number;\n      };\n    }> = [];\n\n    for (const [key, acc] of this._accounts) {\n      if (!acc.owner.equals(programId)) continue;\n\n      let matches = true;\n      if (config?.filters) {\n        for (const filter of config.filters) {\n          if (\"dataSize\" in filter && acc.data.length !== filter.dataSize) {\n            matches = false;\n            break;\n          }\n\n          if (\"memcmp\" in filter) {\n            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n            const actual = acc.data.subarray(\n              filter.memcmp.offset,\n              filter.memcmp.offset + expected.length,\n            );\n            if (Buffer.compare(actual, expected) !== 0) {\n              matches = false;\n              break;\n            }\n          }\n        }\n      }\n\n      if (matches) {\n        results.push({\n          pubkey: new PublicKey(key),\n          account: { ...acc, rentEpoch: 0 },\n        });\n      }\n    }\n\n    return results;\n  }\n\n  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n    this.lastRawTx = Buffer.from(rawTx);\n    return bs58.encode(Buffer.alloc(64, 0x01));\n  }\n\n  async confirmTransaction() {\n    return { value: { err: null }, context: { slot: this._slot } };\n  }\n\n  async getBlockTime(_slot: number) {\n    return Math.floor(Date.now() / 1000);\n  }\n\n  async getBalance() {\n    return 2 * LAMPORTS_PER_SOL;\n  }\n}\n\nexport async function buildMatchAccountData(params: {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: Buffer;\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  matchId: Buffer;\n}): Promise<Buffer> {\n  return encodeFlipYouMatch({\n    creator: params.creator,\n    opponent: params.opponent,\n    server: params.server,\n    entryAmount: params.entryAmount,\n    creatorSide: params.creatorSide,\n    phase: params.phase,\n    commitment: [...params.commitment],\n    algorithmVer: params.algorithmVer,\n    targetSlot: params.targetSlot,\n    resolveDeadline: params.resolveDeadline,\n    resultHash: new Array(32).fill(0),\n    result: 0,\n    winner: PublicKey.default,\n    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n    matchId: [...params.matchId],\n    bump: 0,\n  });\n}\n\nexport async function seedSettlementProgramAccounts(\n  mockConn: MockConnection,\n  params: {\n    entropyAccount: PublicKey;\n    entropyData: Buffer;\n    treasury: PublicKey;\n  },\n) {\n  mockConn.setAccount(params.entropyAccount, params.entropyData);\n\n  const [configPda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"flipyou_config\")],\n    FLIPYOU_PROGRAM_ID,\n  );\n  mockConn.setAccount(\n    configPda,\n    await buildConfigAccountData(params.treasury),\n    { owner: FLIPYOU_PROGRAM_ID },\n  );\n\n  const [platformConfigPda] = derivePlatformConfigPda();\n  mockConn.setAccount(\n    platformConfigPda,\n    buildPlatformConfigData(params.treasury, 500),\n    { owner: PLATFORM_PROGRAM_ID },\n  );\n}\n\nasync function ensureReferralTables(rawSql: TestSql) {\n  if (referralTablesEnsured) {\n    return;\n  }\n\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_codes (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      user_id TEXT NOT NULL UNIQUE,\n      wallet TEXT NOT NULL UNIQUE,\n      code TEXT NOT NULL UNIQUE,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_links (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      referrer_user_id TEXT NOT NULL,\n      referee_user_id TEXT NOT NULL UNIQUE,\n      referrer_wallet TEXT NOT NULL,\n      referee_wallet TEXT NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n    ON referral_links (referrer_user_id)\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_earnings (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      referrer_user_id TEXT NOT NULL,\n      referee_user_id TEXT NOT NULL,\n      referrer_wallet TEXT NOT NULL,\n      referee_wallet TEXT NOT NULL,\n      round_id TEXT NOT NULL,\n      game_type TEXT NOT NULL,\n      wager_lamports BIGINT NOT NULL,\n      fee_lamports BIGINT NOT NULL,\n      referrer_earned_lamports BIGINT NOT NULL,\n      referrer_rate_bps INTEGER NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      CONSTRAINT uq_referral_earnings_referee_round\n        UNIQUE (referee_user_id, round_id)\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n    ON referral_earnings (referrer_user_id, created_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n    ON referral_earnings (referee_user_id, created_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n    ON referral_earnings (round_id)\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_claims (\n      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n      user_id TEXT NOT NULL,\n      wallet TEXT NOT NULL,\n      amount_lamports BIGINT NOT NULL,\n      status TEXT NOT NULL DEFAULT 'pending'\n        CHECK (\n          status IN ('pending', 'processing', 'error', 'completed', 'failed')\n        ),\n      retry_count INTEGER NOT NULL DEFAULT 0,\n      tx_signature TEXT,\n      error TEXT,\n      requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      processed_at TIMESTAMPTZ\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_claims_user_id\n    ON referral_claims (user_id, requested_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_claims_status\n    ON referral_claims (status)\n    WHERE status IN ('pending', 'processing')\n  `;\n  await rawSql`\n    CREATE UNIQUE INDEX IF NOT EXISTS idx_referral_claims_user_active\n    ON referral_claims (user_id)\n    WHERE status IN ('pending', 'processing', 'error')\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_kol_rates (\n      user_id TEXT PRIMARY KEY,\n      wallet TEXT NOT NULL UNIQUE,\n      rate_bps INTEGER NOT NULL,\n      set_by TEXT NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n\n  referralTablesEnsured = true;\n}\n\nasync function ensureRewardEconomyTables(rawSql: TestSql) {\n  if (rewardEconomyTablesEnsured) {\n    return;\n  }\n\n  await rawSql`SELECT pg_advisory_lock(401401)`;\n  try {\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS seasons (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        slug TEXT NOT NULL UNIQUE,\n        name TEXT NOT NULL,\n        starts_at TIMESTAMPTZ NOT NULL,\n        ends_at TIMESTAMPTZ,\n        status TEXT NOT NULL CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX IF NOT EXISTS idx_seasons_one_active\n      ON seasons ((status))\n      WHERE status = 'active'\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS point_rate_versions (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        rate_per_usd NUMERIC(18,6) NOT NULL,\n        effective_from TIMESTAMPTZ NOT NULL,\n        label TEXT,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS point_balances (\n        user_id TEXT NOT NULL,\n        season_id BIGINT NOT NULL REFERENCES seasons(id),\n        wallet TEXT NOT NULL,\n        balance BIGINT NOT NULL DEFAULT 0,\n        season_earned BIGINT NOT NULL DEFAULT 0,\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        PRIMARY KEY (user_id, season_id)\n      )\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS lifetime_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS current_season_id BIGINT REFERENCES seasons(id)\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS current_season_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS cached_lifetime_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS cached_season_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_ladders (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        scope TEXT NOT NULL CHECK (scope IN ('lifetime', 'season')),\n        metric TEXT NOT NULL CHECK (metric IN ('wagered_usd')),\n        season_id BIGINT REFERENCES seasons(id),\n        effective_from TIMESTAMPTZ NOT NULL,\n        label TEXT,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_ladder_steps (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        ladder_id BIGINT NOT NULL REFERENCES multiplier_ladders(id) ON DELETE CASCADE,\n        level INT NOT NULL,\n        threshold_usd NUMERIC(20,6) NOT NULL,\n        multiplier NUMERIC(12,6) NOT NULL CHECK (multiplier >= 0 AND multiplier <= 10),\n        sort_order INT NOT NULL DEFAULT 0,\n        UNIQUE (ladder_id, threshold_usd),\n        UNIQUE (ladder_id, level)\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS events (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        season_id BIGINT REFERENCES seasons(id),\n        event_type TEXT NOT NULL DEFAULT 'generic',\n        display_name TEXT NOT NULL,\n        starts_at TIMESTAMPTZ NOT NULL,\n        ends_at TIMESTAMPTZ NOT NULL,\n        status TEXT NOT NULL DEFAULT 'scheduled'\n          CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n        config JSONB NOT NULL DEFAULT '{}',\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_modifiers (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id TEXT,\n        season_id BIGINT NOT NULL REFERENCES seasons(id),\n        source_type TEXT NOT NULL CHECK (source_type IN ('event', 'admin', 'reward')),\n        source_id TEXT NOT NULL,\n        mode TEXT NOT NULL DEFAULT 'set_value'\n          CHECK (mode IN ('multiply', 'set_min', 'set_value')),\n        value NUMERIC(12,6) NOT NULL CHECK (value >= 0 AND value <= 10),\n        priority INT NOT NULL DEFAULT 0,\n        starts_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        ends_at TIMESTAMPTZ,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    // Tighten season_id on dev DBs that already have the table from an\n    // earlier run when season_id was nullable.\n    await rawSql`\n      UPDATE multiplier_modifiers\n      SET season_id = (SELECT id FROM seasons WHERE status = 'active' LIMIT 1)\n      WHERE season_id IS NULL\n    `;\n    await rawSql`\n      ALTER TABLE multiplier_modifiers\n      ALTER COLUMN season_id SET NOT NULL\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS season_id BIGINT REFERENCES seasons(id)\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS effective_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS point_rate_version_id BIGINT REFERENCES point_rate_versions(id)\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      DROP CONSTRAINT IF EXISTS point_grants_source_type_check\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD CONSTRAINT point_grants_source_type_check\n      CHECK (source_type IN (\n        'wager',\n        'challenge_completed',\n        'bonus_completed',\n        'crate_points',\n        'admin_adjustment',\n        'reward',\n        'migration_adjustment'\n      ))\n    `;\n\n    rewardEconomyTablesEnsured = true;\n  } finally {\n    await rawSql`SELECT pg_advisory_unlock(401401)`;\n  }\n}\n\nasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n  return encodeFlipYouConfig({\n    authority: PublicKey.default,\n    treasury,\n    paused: false,\n    bump: 0,\n  });\n}\n\nfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n  const buf = Buffer.alloc(74);\n  PublicKey.default.toBuffer().copy(buf, 8);\n  treasury.toBuffer().copy(buf, 40);\n  buf.writeUInt16LE(feeBps, 72);\n  return buf;\n}\n","structuredPatch":[{"oldStart":54,"oldLines":6,"newStart":54,"newLines":9,"lines":["   \"progress_events\",","   \"challenge_assignments\",","   \"bonus_completions\",","+  \"fee_allocation_events\",","+  \"fee_bucket_debits\",","+  \"fee_audit_checkpoints\","," ].join(\", \");"," "," export type TestSql = ReturnType<typeof postgres>;"]}],"userModified":false,"replaceAll":false}}
