});\n\n      // Persist settlement to DB (atomic transaction)\n      try {\n        const greenEntries = round.greenEntries.map((e) => ({\n          player: e.player.toBase58(),\n          amountLamports: Number(e.amountLamports),\n        }));\n        const redEntries = round.redEntries.map((e) => ({\n          player: e.player.toBase58(),\n          amountLamports: Number(e.amountLamports),\n        }));\n\n        const totalPool = Number(round.greenPool) + Number(round.redPool);\n        const computedFee = isRefund ? 0 : Math.floor(totalPool * feeBps / 10_000);\n        const netPool = totalPool - computedFee;\n        const roundId = String(Number(minuteTs));\n        const pdaStr = roundPda.toBase58();\n\n        await db.withTransaction(async (txDb) => {\n          // Ensure round record exists\n          await txDb.insertCloseCallRound({\n            roundId,\n            pda: pdaStr,\n            serverKey: serverKeypair.publicKey.toBase58(),\n            openPrice: Number(round.openPrice),\n            openPriceExpo: round.openPriceExpo,\n          });\n\n          // Settle round\n          await txDb.settleCloseCallRound(roundId, {\n            phase: isRefund ? \"refunded\" : \"settled\",","numLines":35,"startLine":425,"totalLines":757}}}
