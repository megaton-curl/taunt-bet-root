{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01GPcfKjSGtxT8gRpwGTApDJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015Qfz2TqWwzzGiRT5ty2Hef","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/__tests__/integration-fee-allocation.test.ts","old_string":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";","new_string":"import { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":680,"cache_read_input_tokens":128235,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":680},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"578af45b-198a-413d-ab1a-ea47ca34e7b2","uuid":"27b62315-d844-43f9-b0ad-f8ce2e4a3b08"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015Qfz2TqWwzzGiRT5ty2Hef","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/__tests__/integration-fee-allocation.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"578af45b-198a-413d-ab1a-ea47ca34e7b2","uuid":"5487ddec-e441-4be3-a0ba-6d2f04c477c8","timestamp":"2026-05-01T20:09:27.655Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/integration-fee-allocation.test.ts","oldString":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";","newString":"import { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";","originalFile":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch, recordReferralEarnings } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\nimport { resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCloseCallRound } from \"../worker/account-decoder.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\nimport {\n  AMOUNT_LAMPORTS,\n  AMOUNT_LAMPORTS_BIGINT,\n  JWT_SECRET,\n  PHASE_LOCKED,\n  SIDE_HEADS,\n  type IntegrationDbContext,\n  type TestSql,\n  buildMatchAccountData,\n  closeIntegrationDb,\n  makeJwt,\n  MockConnection,\n  openIntegrationDb,\n  resetIntegrationState,\n  seedSettlementProgramAccounts,\n} from \"./integration-test-helpers.js\";\n\n// Platform config seeded by `seedSettlementProgramAccounts` is fee_bps = 500.\nconst SETTLED_FEE_BPS = 500;\n// recordReferralEarnings/settle deps default to 1000 bps for referrers.\nconst REFERRER_RATE_BPS = 1000;\n\ninterface FeeAllocationRow {\n  source_type: string;\n  source_id: string;\n  game_type: string;\n  wallet: string;\n  user_id: string | null;\n  wager_lamports: string;\n  fee_lamports: string;\n  referrer_user_id: string | null;\n  referral_rate_bps: number;\n  referral_lamports: string;\n  promotions_lamports: string;\n  profit_lamports: string;\n}\n\nfunction expectComponentsSumToFee(row: FeeAllocationRow) {\n  const sum =\n    BigInt(row.referral_lamports) +\n    BigInt(row.promotions_lamports) +\n    BigInt(row.profit_lamports);\n  expect(sum.toString()).toBe(String(row.fee_lamports));\n}\n\ndescribe(\"Fee allocation integration: settlement writes ledger rows for all three games\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n    resetPlatformConfigCache();\n\n    mockConn = new MockConnection();\n    await seedSettlementProgramAccounts(mockConn, {\n      entropyAccount,\n      entropyData,\n      treasury: treasuryKeypair.publicKey,\n    });\n\n    app = new Hono();\n    app.use(\"/flipyou/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n    app.route(\n      \"/flipyou\",\n      createFlipYouRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n  });\n\n  it(\"FlipYou settle writes one allocation row per player — referred + non-referred — with components summing to fee\", async () => {\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n\n    await db.insertReferralCode(\n      referrerProfile.user_id,\n      referrerWallet,\n      \"alloc-test-ref\",\n    );\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: opponentProfile.user_id,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n    // Note: creator has no referral link → non-referred allocation row expected.\n\n    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createBody = (await createRes.json()) as {\n      ok: true;\n      data: { matchPda: string; matchId: string; commitment: string };\n    };\n    const createJson = createBody.data;\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: REFERRER_RATE_BPS,\n          },\n          pda,\n        ),\n    });\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const rows = await rawSql<FeeAllocationRow[]>`\n      SELECT * FROM fee_allocation_events\n      WHERE source_type = 'flipyou' AND source_id = ${createJson.matchId}\n      ORDER BY wallet\n    `;\n    expect(rows.length).toBe(2);\n\n    const creatorRow = rows.find((r) => r.wallet === creatorWallet)!;\n    const opponentRow = rows.find((r) => r.wallet === opponentWallet)!;\n    expect(creatorRow).toBeDefined();\n    expect(opponentRow).toBeDefined();\n\n    // Non-referred creator: no referrer, 0 rate, components sum to fee.\n    expect(creatorRow.referrer_user_id).toBeNull();\n    expect(creatorRow.referral_rate_bps).toBe(0);\n    expect(creatorRow.referral_lamports).toBe(\"0\");\n    expect(Number(creatorRow.fee_lamports)).toBe(\n      Math.floor((AMOUNT_LAMPORTS * SETTLED_FEE_BPS) / 10_000),\n    );\n    expect(creatorRow.user_id).toBe(creatorProfile.user_id);\n    expectComponentsSumToFee(creatorRow);\n\n    // Referred opponent: referrer set, default rate, components sum to fee.\n    expect(opponentRow.referrer_user_id).toBe(referrerProfile.user_id);\n    expect(opponentRow.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n    expect(Number(opponentRow.referral_lamports)).toBe(\n      Math.floor(\n        (Number(opponentRow.fee_lamports) * REFERRER_RATE_BPS) / 10_000,\n      ),\n    );\n    expect(opponentRow.user_id).toBe(opponentProfile.user_id);\n    expectComponentsSumToFee(opponentRow);\n\n    // Idempotent retry: replay the helper directly with the same inputs.\n    // Production retry hits the same UNIQUE / ON CONFLICT path, so a second\n    // call must not duplicate rows.\n    await recordReferralEarnings(db, {\n      roundId: createJson.matchId,\n      gameType: \"flipyou\",\n      feeBps: SETTLED_FEE_BPS,\n      referralDefaultRateBps: REFERRER_RATE_BPS,\n      players: [\n        { wallet: creatorWallet, wagerLamports: AMOUNT_LAMPORTS },\n        { wallet: opponentWallet, wagerLamports: AMOUNT_LAMPORTS },\n      ],\n    });\n\n    const rowsAfterRetry = await rawSql<FeeAllocationRow[]>`\n      SELECT id FROM fee_allocation_events\n      WHERE source_type = 'flipyou' AND source_id = ${createJson.matchId}\n    `;\n    expect(rowsAfterRetry.length).toBe(2);\n  }, 20_000);\n\n  it(\"Pot Shot helper collapses multiple wallet entries into one allocation row per (round, wallet)\", async () => {\n    // Pot Shot can have multiple entries from the same wallet inside one round.\n    // The shared `recordReferralEarnings` helper dedupes them to a single\n    // allocation keyed on (source_type, source_id, wallet). Asserted directly\n    // because Pot Shot lacks the test infrastructure (account decoder + on-chain\n    // settle path) that FlipYou and Close Call have.\n    const playerAKeypair = Keypair.generate();\n    const playerBKeypair = Keypair.generate();\n    const playerAWallet = playerAKeypair.publicKey.toBase58();\n    const playerBWallet = playerBKeypair.publicKey.toBase58();\n\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const playerAProfile = await db.getOrCreateProfile(playerAWallet);\n    await db.getOrCreateProfile(playerBWallet);\n\n    await db.insertReferralCode(\n      referrerProfile.user_id,\n      referrerWallet,\n      \"potshot-ref\",\n    );\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: playerAProfile.user_id,\n      referrerWallet,\n      refereeWallet: playerAWallet,\n    });\n    // playerB intentionally non-referred.\n\n    const roundId = \"potshot-round-001\";\n    await recordReferralEarnings(db, {\n      roundId,\n      gameType: \"potshot\",\n      feeBps: SETTLED_FEE_BPS,\n      referralDefaultRateBps: REFERRER_RATE_BPS,\n      // playerA contributes two entries; total wager is summed by the helper.\n      players: [\n        { wallet: playerAWallet, wagerLamports: 3_000_000 },\n        { wallet: playerAWallet, wagerLamports: 2_000_000 },\n        { wallet: playerBWallet, wagerLamports: 4_000_000 },\n      ],\n    });\n\n    const rows = await rawSql<FeeAllocationRow[]>`\n      SELECT * FROM fee_allocation_events\n      WHERE source_type = 'potshot' AND source_id = ${roundId}\n      ORDER BY wallet\n    `;\n    expect(rows.length).toBe(2);\n\n    const rowA = rows.find((r) => r.wallet === playerAWallet)!;\n    const rowB = rows.find((r) => r.wallet === playerBWallet)!;\n\n    // playerA: collapsed to a single row with summed wager 5_000_000.\n    expect(Number(rowA.wager_lamports)).toBe(5_000_000);\n    expect(Number(rowA.fee_lamports)).toBe(\n      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n    );\n    expect(rowA.referrer_user_id).toBe(referrerProfile.user_id);\n    expect(rowA.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n    expectComponentsSumToFee(rowA);\n\n    // playerB: non-referred, components still sum to fee.\n    expect(Number(rowB.wager_lamports)).toBe(4_000_000);\n    expect(rowB.referrer_user_id).toBeNull();\n    expect(rowB.referral_rate_bps).toBe(0);\n    expect(rowB.referral_lamports).toBe(\"0\");\n    expectComponentsSumToFee(rowB);\n\n    // Replay the same settlement: UNIQUE on (source_type, source_id, wallet)\n    // makes this a no-op.\n    await recordReferralEarnings(db, {\n      roundId,\n      gameType: \"potshot\",\n      feeBps: SETTLED_FEE_BPS,\n      referralDefaultRateBps: REFERRER_RATE_BPS,\n      players: [\n        { wallet: playerAWallet, wagerLamports: 3_000_000 },\n        { wallet: playerAWallet, wagerLamports: 2_000_000 },\n        { wallet: playerBWallet, wagerLamports: 4_000_000 },\n      ],\n    });\n    const rowsAfterRetry = await rawSql<FeeAllocationRow[]>`\n      SELECT id FROM fee_allocation_events\n      WHERE source_type = 'potshot' AND source_id = ${roundId}\n    `;\n    expect(rowsAfterRetry.length).toBe(2);\n  });\n\n  it(\"Close Call clock tick writes allocation rows for both green and red players\", async () => {\n    const greenPlayer = Keypair.generate();\n    const redPlayer = Keypair.generate();\n    const greenWallet = greenPlayer.publicKey.toBase58();\n    const redWallet = redPlayer.publicKey.toBase58();\n\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const greenProfile = await db.getOrCreateProfile(greenWallet);\n    await db.getOrCreateProfile(redWallet);\n\n    await db.insertReferralCode(\n      referrerProfile.user_id,\n      referrerWallet,\n      \"closecall-ref\",\n    );\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: greenProfile.user_id,\n      referrerWallet,\n      refereeWallet: greenWallet,\n    });\n    // Red player intentionally non-referred.\n\n    const nowSec = Math.floor(Date.now() / 1000);\n    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n    const openPrice = 69500_00n;\n\n    const minuteTsBuf = Buffer.alloc(8);\n    minuteTsBuf.writeBigInt64LE(minuteTs);\n    const [roundPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n      CLOSECALL_PROGRAM_ID,\n    );\n\n    const roundAccountData = await encodeCloseCallRound({\n      minuteTs,\n      server: serverKeypair.publicKey,\n      phase: 0,\n      greenEntries: [\n        { player: greenPlayer.publicKey, amountLamports: 5_000_000n },\n      ],\n      redEntries: [\n        { player: redPlayer.publicKey, amountLamports: 5_000_000n },\n      ],\n      greenPool: 5_000_000n,\n      redPool: 5_000_000n,\n      openPrice,\n      openPriceExpo: -2,\n      closePrice: 0n,\n      createdAt: minuteTs,\n      bettingEndsAt: minuteTs + 45n,\n      resolveDeadline: minuteTs + 300n,\n      outcome: 0,\n      totalFee: 0n,\n      bump: 0,\n    });\n    mockConn.setAccount(roundPda, roundAccountData, {\n      owner: CLOSECALL_PROGRAM_ID,\n    });\n\n    const closePrice = 69600_00n;\n    const mockHermes: HermesFetcher = {\n      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n        price: closePrice,\n        expo: -2,\n        publishTime: Math.floor(Date.now() / 1000),\n        priceHuman: 69600.0,\n        vaaBase64: null,\n      }),\n    };\n\n    const clock = createCloseCallClockWorker({\n      connection: mockConn as unknown as Connection,\n      serverKeypair,\n      db,\n      hermesFetcher: mockHermes,\n      referralDefaultRateBps: REFERRER_RATE_BPS,\n    });\n\n    await clock.tick();\n\n    const roundId = String(Number(minuteTs));\n    const rows = await rawSql<FeeAllocationRow[]>`\n      SELECT * FROM fee_allocation_events\n      WHERE source_type = 'closecall' AND source_id = ${roundId}\n      ORDER BY wallet\n    `;\n    expect(rows.length).toBe(2);\n\n    const greenRow = rows.find((r) => r.wallet === greenWallet)!;\n    const redRow = rows.find((r) => r.wallet === redWallet)!;\n\n    // Green: referred — non-zero referral split.\n    expect(greenRow.referrer_user_id).toBe(referrerProfile.user_id);\n    expect(greenRow.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n    expect(Number(greenRow.fee_lamports)).toBe(\n      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n    );\n    expect(Number(greenRow.referral_lamports)).toBeGreaterThan(0);\n    expectComponentsSumToFee(greenRow);\n\n    // Red: non-referred — referral_lamports = 0 but row still written.\n    expect(redRow.referrer_user_id).toBeNull();\n    expect(redRow.referral_rate_bps).toBe(0);\n    expect(redRow.referral_lamports).toBe(\"0\");\n    expect(Number(redRow.fee_lamports)).toBe(\n      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n    );\n    expectComponentsSumToFee(redRow);\n  }, 20_000);\n});\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":3,"lines":["-/* eslint-disable @typescript-eslint/no-explicit-any */"," import { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";"," import { Hono } from \"hono\";"," import { Keypair, PublicKey } from \"@solana/web3.js\";"]}],"userModified":false,"replaceAll":false}}
