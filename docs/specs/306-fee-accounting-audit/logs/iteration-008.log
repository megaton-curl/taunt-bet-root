ol > 0 ? Math.floor((entry.amountLamports / redPool) * netPool) : 0;\n              if (payout > 0) txParams.push({ userId, wallet: entry.player, game: \"closecall\", matchId: roundId, txType: \"payout\", amountLamports: payout, txSig: sig });\n            }\n          }\n\n          if (txParams.length > 0) {\n            await txDb.insertTransactions(txParams);\n          }\n\n          // Fee allocation hook — same transaction for atomicity (System Invariant 4)\n          // Only runs for non-refund settlements; refunds take no on-chain fee.\n          if (!isRefund && allEntries.length > 0) {\n            await recordReferralEarnings(txDb, {\n              roundId,\n              gameType: \"closecall\",\n              feeBps,\n              referralDefaultRateBps: deps.referralDefaultRateBps,\n              players: allEntries.map((e) => ({\n                wallet: e.player,\n                wagerLamports: e.amountLamports,\n              })),\n            });\n          }\n\n          // Game entries — UPSERT with settlement result\n          if (allEntries.length > 0) {\n            const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);","numLines":90,"startLine":450,"totalLines":757}}}
