) + close price\n      const [platformConfig, hermesPrice] = await Promise.all([\n        readPlatformConfig(),\n        hermes.fetchLatestBtcPrice(),\n      ]);\n\n      if (!platformConfig) {\n        logger.error(\"closecall clock: cannot read platform config treasury\");\n        return false;\n      }\n      const { treasury, feeBps } = platformConfig;\n      if (!hermesPrice) {\n        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n        return false;\n      }\n\n      if (totalCount === 0) {\n        logger.info(\"closecall clock: settling empty round\", {\n          pda: roundPda.toBase58(),\n        });\n      }\n\n      // Pre-determine outcome\n      const hasBothSides = greenCount > 0 && redCount > 0;\n      const isRefund =\n        totalCount === 0 ||\n        !hasBothSides ||\n        totalCount === 1 ||\n        hermesPrice.price === round.openPrice;\n\n      let remainingAccounts: PublicKey[];\n      if (isRefund) {\n        remainingAccounts = [\n          ...round.greenEntries.map((e) => e.player),\n          ...round.redEntries.map((e) => e.player),\n        ];\n      } else if (hermesPrice.price > round.openPrice) {\n        remainingAccounts = round.greenEntries.map((e) => e.player);\n      } else {\n        remainingAccounts = round.redEntries.map((e) => e.player);\n      }\n\n      const ix = buildCloseCallSettleRoundIx(\n        serverKeypair.publicKey,\n        minuteTs,\n        hermesPrice.price,","numLines":100,"startLine":300,"totalLines":757}}}
