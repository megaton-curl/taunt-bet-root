{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DR1zL4x7LAQiocPPwzocit","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\timport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\n3\timport { Hono } from \"hono\";\n4\timport { Keypair, PublicKey } from \"@solana/web3.js\";\n5\timport type { Connection } from \"@solana/web3.js\";\n6\timport type { Db } from \"../db.js\";\n7\timport { createFlipYouRoutes } from \"../routes/create.js\";\n8\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n9\timport { createSettlementWorker } from \"../worker/settlement.js\";\n10\timport { settleMatch } from \"../worker/settle-tx.js\";\n11\timport { createRetrySettler } from \"../worker/retry.js\";\n12\timport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\n13\timport { resetPlatformConfigCache } from \"../platform-config.js\";\n14\timport { encodeCloseCallRound } from \"../worker/account-decoder.js\";\n15\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n16\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n17\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n18\timport {\n19\t  AMOUNT_LAMPORTS,\n20\t  AMOUNT_LAMPORTS_BIGINT,\n21\t  JWT_SECRET,\n22\t  PHASE_LOCKED,\n23\t  SIDE_HEADS,\n24\t  type IntegrationDbContext,\n25\t  type TestSql,\n26\t  buildMatchAccountData,\n27\t  closeIntegrationDb,\n28\t  makeJwt,\n29\t  MockConnection,\n30\t  openIntegrationDb,\n31\t  resetIntegrationState,\n32\t  seedSettlementProgramAccounts,\n33\t  userIdFromWallet,\n34\t} from \"./integration-test-helpers.js\";\n35\t\n36\tdescribe(\"Settlement integration: create, settle, and emit events\", () => {\n37\t  let ctx: IntegrationDbContext;\n38\t  let rawSql: TestSql;\n39\t  let db: Db;\n40\t  let mockConn: MockConnection;\n41\t  let app: Hono;\n42\t\n43\t  const serverKeypair = Keypair.generate();\n44\t  const creatorKeypair = Keypair.generate();\n45\t  const opponentKeypair = Keypair.generate();\n46\t  const treasuryKeypair = Keypair.generate();\n47\t  const entropyKeypair = Keypair.generate();\n48\t  const entropyAccount = entropyKeypair.publicKey;\n49\t\n50\t  const entropyData = Buffer.alloc(32);\n51\t  entropyData[0] = 0xab;\n52\t  entropyData[1] = 0xcd;\n53\t  entropyData[15] = 0x42;\n54\t\n55\t  beforeAll(async () => {\n56\t    ctx = await openIntegrationDb();\n57\t    rawSql = ctx.rawSql;\n58\t    db = ctx.db;\n59\t  });\n60\t\n61\t  afterAll(async () => {\n62\t    await closeIntegrationDb(ctx);\n63\t  });\n64\t\n65\t  beforeEach(async () => {\n66\t    await resetIntegrationState(rawSql);\n67\t    resetPlatformConfigCache();\n68\t\n69\t    mockConn = new MockConnection();\n70\t    await seedSettlementProgramAccounts(mockConn, {\n71\t      entropyAccount,\n72\t      entropyData,\n73\t      treasury: treasuryKeypair.publicKey,\n74\t    });\n75\t\n76\t    app = new Hono();\n77\t    app.use(\"/flipyou/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n78\t    app.route(\n79\t      \"/flipyou\",\n80\t      createFlipYouRoutes({\n81\t        db,\n82\t        connection: mockConn as unknown as Connection,\n83\t        serverKeypair,\n84\t      }),\n85\t    );\n86\t  });\n87\t\n88\t  it(\"full lifecycle: create, join, settle, verify\", async () => {\n89\t    const wallet = creatorKeypair.publicKey.toBase58();\n90\t    const token = await makeJwt(wallet);\n91\t\n92\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n93\t    const createRes = await app.request(\"/flipyou/create\", {\n94\t      method: \"POST\",\n95\t      headers: {\n96\t        \"Content-Type\": \"application/json\",\n97\t        Authorization: `Bearer ${token}`,\n98\t      },\n99\t      body: JSON.stringify(body),\n100\t    });\n101\t\n102\t    expect(createRes.status).toBe(200);\n103\t    const createBody = (await createRes.json()) as {\n104\t      ok: true;\n105\t      data: {\n106\t        transaction: string;\n107\t        matchPda: string;\n108\t        matchId: string;\n109\t        commitment: string;\n110\t        lastValidBlockHeight: number;\n111\t      };\n112\t    };\n113\t    const createJson = createBody.data;\n114\t    expect(createJson.transaction).toBeDefined();\n115\t    expect(createJson.matchPda).toBeDefined();\n116\t    expect(createJson.commitment).toBeDefined();\n117\t    expect(createJson.lastValidBlockHeight).toBeDefined();\n118\t\n119\t    const round = await db.getRoundByPda(createJson.matchPda);\n120\t    expect(round).toBeDefined();\n121\t    expect(round!.phase).toBe(\"created\");\n122\t    expect(round!.game).toBe(\"flipyou\");\n123\t    expect(round!.creator).toBe(wallet);\n124\t    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n125\t    expect(round!.side).toBe(SIDE_HEADS);\n126\t    expect(round!.commitment.toString(\"hex\")).toBe(createJson.commitment);\n127\t    expect(round!.secret).toBeDefined();\n128\t    expect(round!.secret.length).toBe(32);\n129\t\n130\t    const events =\n131\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n132\t    expect(events.length).toBe(1);\n133\t    expect(events[0]!.event_type).toBe(\"secret_generated\");\n134\t\n135\t    const matchPubkey = new PublicKey(createJson.matchPda);\n136\t    const matchAccountData = await buildMatchAccountData({\n137\t      creator: creatorKeypair.publicKey,\n138\t      opponent: opponentKeypair.publicKey,\n139\t      server: serverKeypair.publicKey,\n140\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n141\t      creatorSide: SIDE_HEADS,\n142\t      phase: PHASE_LOCKED,\n143\t      commitment: Buffer.from(createJson.commitment, \"hex\"),\n144\t      algorithmVer: 1,\n145\t      targetSlot: 150n,\n146\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n147\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n148\t    });\n149\t\n150\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n151\t      owner: FLIPYOU_PROGRAM_ID,\n152\t    });\n153\t    mockConn.slot = 200;\n154\t\n155\t    let settlePromise: Promise<void> | null = null;\n156\t    const retrySettler = createRetrySettler({\n157\t      db,\n158\t      connection: mockConn as unknown as Connection,\n159\t      settleRound: (pda) =>\n160\t        settleMatch(\n161\t          {\n162\t            db,\n163\t            connection: mockConn as unknown as Connection,\n164\t            serverKeypair,\n165\t            entropyAccount,\n166\t            referralDefaultRateBps: 1000,\n167\t          },\n168\t          pda,\n169\t        ),\n170\t    });\n171\t\n172\t    const worker = createSettlementWorker({\n173\t      db,\n174\t      connection: mockConn as unknown as Connection,\n175\t      serverKey: serverKeypair.publicKey,\n176\t      pollIntervalMs: 60_000,\n177\t      onSettleReady: (pda) => {\n178\t        settlePromise = retrySettler.attemptSettle(pda);\n179\t        return settlePromise;\n180\t      },\n181\t    });\n182\t\n183\t    await worker.poll();\n184\t    if (settlePromise) await settlePromise;\n185\t\n186\t    const settled = await db.getRoundByPda(createJson.matchPda);\n187\t    expect(settled).toBeDefined();\n188\t    expect(settled!.phase).toBe(\"settled\");\n189\t    expect(settled!.settle_tx).toBeDefined();\n190\t    expect(settled!.result_hash).toBeDefined();\n191\t    expect(settled!.result_hash!.length).toBe(32);\n192\t    expect(settled!.result_side).toBeDefined();\n193\t    expect([0, 1]).toContain(settled!.result_side);\n194\t    expect(settled!.winner).toBeDefined();\n195\t    expect([\n196\t      creatorKeypair.publicKey.toBase58(),\n197\t      opponentKeypair.publicKey.toBase58(),\n198\t    ]).toContain(settled!.winner);\n199\t\n200\t    const allEvents =\n201\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n202\t    const eventTypes = allEvents.map(\n203\t      (e) => (e as Record<string, any>).event_type,\n204\t    );\n205\t    expect(eventTypes).toContain(\"secret_generated\");\n206\t    expect(eventTypes).toContain(\"match_detected\");\n207\t    expect(eventTypes).toContain(\"settle_submitted\");\n208\t    expect(eventTypes).toContain(\"settle_confirmed\");\n209\t\n210\t    const roundsRes = await app.request(`/flipyou/verify/${createJson.matchPda}`);\n211\t    expect(roundsRes.status).toBe(200);\n212\t\n213\t    const roundsBody = (await roundsRes.json()) as {\n214\t      ok: true;\n215\t      data: Record<string, any>;\n216\t    };\n217\t    const roundsJson = roundsBody.data;\n218\t    expect(roundsJson.pda).toBe(createJson.matchPda);\n219\t    expect(roundsJson.phase).toBe(\"settled\");\n220\t    expect(roundsJson.game).toBe(\"flip-you\");\n221\t    expect(roundsJson.creator).toBe(wallet);\n222\t    expect(roundsJson.commitment).toBe(createJson.commitment);\n223\t    expect(roundsJson.secret).toBeDefined();\n224\t    expect(typeof roundsJson.secret).toBe(\"string\");\n225\t    expect((roundsJson.secret as string).length).toBe(64);\n226\t    expect(roundsJson.resultHash).toBeDefined();\n227\t    expect(roundsJson.resultSide).toBeDefined();\n228\t    expect(roundsJson.winner).toBeDefined();\n229\t    expect(roundsJson.settleTx).toBeDefined();\n230\t\n231\t    const verification = roundsJson.verification as Record<string, string>;\n232\t    expect(verification).toBeDefined();\n233\t    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n234\t    expect(verification.resultFormula).toContain(\"sha256(secret\");\n235\t    expect(verification.entropySource).toContain(\"SlotHashes\");\n236\t  }, 20_000);\n237\t\n238\t  it(\"GET /flipyou/verify/:pda returns 404 for unknown PDA\", async () => {\n239\t    const unknownPda = Keypair.generate().publicKey.toBase58();\n240\t    const res = await app.request(`/flipyou/verify/${unknownPda}`);\n241\t    expect(res.status).toBe(404);\n242\t  });\n243\t\n244\t  it(\"unsettled round does not expose secret\", async () => {\n245\t    const wallet = creatorKeypair.publicKey.toBase58();\n246\t    const token = await makeJwt(wallet);\n247\t\n248\t    const res = await app.request(\"/flipyou/create\", {\n249\t      method: \"POST\",\n250\t      headers: {\n251\t        \"Content-Type\": \"application/json\",\n252\t        Authorization: `Bearer ${token}`,\n253\t      },\n254\t      body: JSON.stringify({\n255\t        wallet,\n256\t        amountLamports: AMOUNT_LAMPORTS,\n257\t        side: SIDE_HEADS,\n258\t      }),\n259\t    });\n260\t    expect(res.status).toBe(200);\n261\t    const body = (await res.json()) as { ok: true; data: { matchPda: string } };\n262\t    const json = body.data;\n263\t\n264\t    const roundRes = await app.request(`/flipyou/verify/${json.matchPda}`);\n265\t    expect(roundRes.status).toBe(200);\n266\t    const roundBody = (await roundRes.json()) as {\n267\t      ok: true;\n268\t      data: Record<string, any>;\n269\t    };\n270\t    const roundJson = roundBody.data;\n271\t    expect(roundJson.phase).toBe(\"created\");\n272\t    expect(roundJson.secret).toBeUndefined();\n273\t    expect(roundJson.resultHash).toBeUndefined();\n274\t    expect(roundJson.verification).toBeUndefined();\n275\t  });\n276\t\n277\t  it(\"two creates from same wallet succeed with different match IDs\", async () => {\n278\t    const wallet = creatorKeypair.publicKey.toBase58();\n279\t    const token = await makeJwt(wallet);\n280\t\n281\t    const res1 = await app.request(\"/flipyou/create\", {\n282\t      method: \"POST\",\n283\t      headers: {\n284\t        \"Content-Type\": \"application/json\",\n285\t        Authorization: `Bearer ${token}`,\n286\t      },\n287\t      body: JSON.stringify({\n288\t        wallet,\n289\t        amountLamports: AMOUNT_LAMPORTS,\n290\t        side: SIDE_HEADS,\n291\t      }),\n292\t    });\n293\t    expect(res1.status).toBe(200);\n294\t\n295\t    const res2 = await app.request(\"/flipyou/create\", {\n296\t      method: \"POST\",\n297\t      headers: {\n298\t        \"Content-Type\": \"application/json\",\n299\t        Authorization: `Bearer ${token}`,\n300\t      },\n301\t      body: JSON.stringify({\n302\t        wallet,\n303\t        amountLamports: AMOUNT_LAMPORTS,\n304\t        side: SIDE_HEADS,\n305\t      }),\n306\t    });\n307\t    expect(res2.status).toBe(200);\n308\t\n309\t    const body1 = (await res1.json()) as {\n310\t      ok: true;\n311\t      data: { matchPda: string; matchId: string };\n312\t    };\n313\t    const body2 = (await res2.json()) as {\n314\t      ok: true;\n315\t      data: { matchPda: string; matchId: string };\n316\t    };\n317\t    const json1 = body1.data;\n318\t    const json2 = body2.data;\n319\t    expect(json1.matchPda).not.toBe(json2.matchPda);\n320\t    expect(json1.matchId).not.toBe(json2.matchId);\n321\t  });\n322\t\n323\t  it(\"settlement records referral earnings for referred players\", async () => {\n324\t    const referrerKeypair = Keypair.generate();\n325\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n326\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n327\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n328\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n329\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n330\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n331\t\n332\t    await db.insertReferralCode(referrerProfile.user_id, referrerWallet, \"test-ref\");\n333\t    await db.insertReferralLink({\n334\t      referrerUserId: referrerProfile.user_id,\n335\t      refereeUserId: opponentProfile.user_id,\n336\t      referrerWallet,\n337\t      refereeWallet: opponentWallet,\n338\t    });\n339\t\n340\t    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n341\t    const createRes = await app.request(\"/flipyou/create\", {\n342\t      method: \"POST\",\n343\t      headers: {\n344\t        \"Content-Type\": \"application/json\",\n345\t        Authorization: `Bearer ${token}`,\n346\t      },\n347\t      body: JSON.stringify({\n348\t        wallet: creatorWallet,\n349\t        amountLamports: AMOUNT_LAMPORTS,\n350\t        side: SIDE_HEADS,\n351\t      }),\n352\t    });\n353\t    expect(createRes.status).toBe(200);\n354\t    const createBody = (await createRes.json()) as {\n355\t      ok: true;\n356\t      data: {\n357\t        matchPda: string;\n358\t        matchId: string;\n359\t        commitment: string;\n360\t      };\n361\t    };\n362\t    const createJson = createBody.data;\n363\t\n364\t    const matchAccountData = await buildMatchAccountData({\n365\t      creator: creatorKeypair.publicKey,\n366\t      opponent: opponentKeypair.publicKey,\n367\t      server: serverKeypair.publicKey,\n368\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n369\t      creatorSide: SIDE_HEADS,\n370\t      phase: PHASE_LOCKED,\n371\t      commitment: Buffer.from(createJson.commitment, \"hex\"),\n372\t      algorithmVer: 1,\n373\t      targetSlot: 150n,\n374\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n375\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n376\t    });\n377\t\n378\t    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n379\t      owner: FLIPYOU_PROGRAM_ID,\n380\t    });\n381\t    mockConn.slot = 200;\n382\t\n383\t    let settlePromise: Promise<void> | null = null;\n384\t    const retrySettler = createRetrySettler({\n385\t      db,\n386\t      connection: mockConn as unknown as Connection,\n387\t      settleRound: (pda) =>\n388\t        settleMatch(\n389\t          {\n390\t            db,\n391\t            connection: mockConn as unknown as Connection,\n392\t            serverKeypair,\n393\t            entropyAccount,\n394\t            referralDefaultRateBps: 1000,\n395\t          },\n396\t          pda,\n397\t        ),\n398\t    });\n399\t    const worker = createSettlementWorker({\n400\t      db,\n401\t      connection: mockConn as unknown as Connection,\n402\t      serverKey: serverKeypair.publicKey,\n403\t      pollIntervalMs: 60_000,\n404\t      onSettleReady: (pda) => {\n405\t        settlePromise = retrySettler.attemptSettle(pda);\n406\t        return settlePromise;\n407\t      },\n408\t    });\n409\t\n410\t    await worker.poll();\n411\t    if (settlePromise) await settlePromise;\n412\t\n413\t    const earnings =\n414\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentProfile.user_id}`;\n415\t    expect(earnings.length).toBe(1);\n416\t\n417\t    const earning = earnings[0]!;\n418\t    expect(earning.referrer_user_id).toBe(referrerProfile.user_id);\n419\t    expect(earning.referee_user_id).toBe(opponentProfile.user_id);\n420\t    expect(earning.referrer_wallet).toBe(referrerWallet);\n421\t    expect(earning.referee_wallet).toBe(opponentWallet);\n422\t    expect(earning.round_id).toBe(createJson.matchId);\n423\t    expect(earning.game_type).toBe(\"flipyou\");\n424\t    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS);\n425\t    expect(Number(earning.fee_lamports)).toBe(250_000);\n426\t    expect(Number(earning.referrer_earned_lamports)).toBe(25_000);\n427\t    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n428\t\n429\t    const creatorEarnings =\n430\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${creatorProfile.user_id}`;\n431\t    expect(creatorEarnings.length).toBe(0);\n432\t  });\n433\t\n434\t  it(\"settlement uses KOL custom rates for referrer earnings\", async () => {\n435\t    const referrerKeypair = Keypair.generate();\n436\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n437\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n438\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n439\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n440\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n441\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n442\t\n443\t    await db.insertReferralCode(referrerProfile.user_id, referrerWallet, \"kol-code\");\n444\t    await db.insertReferralLink({\n445\t      referrerUserId: referrerProfile.user_id,\n446\t      refereeUserId: opponentProfile.user_id,\n447\t      referrerWallet,\n448\t      refereeWallet: opponentWallet,\n449\t    });\n450\t    await rawSql`\n451\t      INSERT INTO referral_kol_rates (user_id, wallet, rate_bps, set_by)\n452\t      VALUES (${referrerProfile.user_id}, ${referrerWallet}, 2000, 'admin')\n453\t    `;\n454\t\n455\t    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n456\t    const createRes = await app.request(\"/flipyou/create\", {\n457\t      method: \"POST\",\n458\t      headers: {\n459\t        \"Content-Type\": \"application/json\",\n460\t        Authorization: `Bearer ${token}`,\n461\t      },\n462\t      body: JSON.stringify({\n463\t        wallet: creatorWallet,\n464\t        amountLamports: AMOUNT_LAMPORTS,\n465\t        side: SIDE_HEADS,\n466\t      }),\n467\t    });\n468\t    expect(createRes.status).toBe(200);\n469\t    const createBody = (await createRes.json()) as {\n470\t      ok: true;\n471\t      data: {\n472\t        matchPda: string;\n473\t        matchId: string;\n474\t        commitment: string;\n475\t      };\n476\t    };\n477\t    const createJson = createBody.data;\n478\t\n479\t    const matchAccountData = await buildMatchAccountData({\n480\t      creator: creatorKeypair.publicKey,\n481\t      opponent: opponentKeypair.publicKey,\n482\t      server: serverKeypair.publicKey,\n483\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n484\t      creatorSide: SIDE_HEADS,\n485\t      phase: PHASE_LOCKED,\n486\t      commitment: Buffer.from(createJson.commitment, \"hex\"),\n487\t      algorithmVer: 1,\n488\t      targetSlot: 150n,\n489\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n490\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n491\t    });\n492\t\n493\t    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n494\t      owner: FLIPYOU_PROGRAM_ID,\n495\t    });\n496\t    mockConn.slot = 200;\n497\t\n498\t    let settlePromise: Promise<void> | null = null;\n499\t    const retrySettler = createRetrySettler({\n500\t      db,\n501\t      connection: mockConn as unknown as Connection,\n502\t      settleRound: (pda) =>\n503\t        settleMatch(\n504\t          {\n505\t            db,\n506\t            connection: mockConn as unknown as Connection,\n507\t            serverKeypair,\n508\t            entropyAccount,\n509\t            referralDefaultRateBps: 1000,\n510\t          },\n511\t          pda,\n512\t        ),\n513\t    });\n514\t    const worker = createSettlementWorker({\n515\t      db,\n516\t      connection: mockConn as unknown as Connection,\n517\t      serverKey: serverKeypair.publicKey,\n518\t      pollIntervalMs: 60_000,\n519\t      onSettleReady: (pda) => {\n520\t        settlePromise = retrySettler.attemptSettle(pda);\n521\t        return settlePromise;\n522\t      },\n523\t    });\n524\t\n525\t    await worker.poll();\n526\t    if (settlePromise) await settlePromise;\n527\t\n528\t    const settled = await db.getRoundByPda(createJson.matchPda);\n529\t    expect(settled!.phase).toBe(\"settled\");\n530\t\n531\t    const earnings =\n532\t      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentProfile.user_id}`;\n533\t    expect(earnings.length).toBe(1);\n534\t    expect(Number(earnings[0]!.referrer_earned_lamports)).toBe(50_000);\n535\t    expect(Number(earnings[0]!.referrer_rate_bps)).toBe(2000);\n536\t  });\n537\t\n538\t  it(\"settlement emits flipyou game.settled payloads with the expected shape\", async () => {\n539\t    const wallet = creatorKeypair.publicKey.toBase58();\n540\t    const token = await makeJwt(wallet);\n541\t    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n542\t    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n543\t\n544\t    await rawSql`\n545\t      INSERT INTO player_profiles (user_id, wallet, username)\n546\t      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n547\t      ON CONFLICT (user_id) DO NOTHING\n548\t    `;\n549\t    await rawSql`\n550\t      INSERT INTO player_profiles (user_id, wallet, username)\n551\t      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n552\t      ON CONFLICT (user_id) DO NOTHING\n553\t    `;\n554\t\n555\t    const createRes = await app.request(\"/flipyou/create\", {\n556\t      method: \"POST\",\n557\t      headers: {\n558\t        \"Content-Type\": \"application/json\",\n559\t        Authorization: `Bearer ${token}`,\n560\t      },\n561\t      body: JSON.stringify({\n562\t        wallet,\n563\t        amountLamports: AMOUNT_LAMPORTS,\n564\t        side: SIDE_HEADS,\n565\t      }),\n566\t    });\n567\t    expect(createRes.status).toBe(200);\n568\t    const createBody = (await createRes.json()) as {\n569\t      ok: true;\n570\t      data: {\n571\t        matchPda: string;\n572\t        matchId: string;\n573\t        commitment: string;\n574\t      };\n575\t    };\n576\t    const createJson = createBody.data;\n577\t\n578\t    const matchAccountData = await buildMatchAccountData({\n579\t      creator: creatorKeypair.publicKey,\n580\t      opponent: opponentKeypair.publicKey,\n581\t      server: serverKeypair.publicKey,\n582\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n583\t      creatorSide: SIDE_HEADS,\n584\t      phase: PHASE_LOCKED,\n585\t      commitment: Buffer.from(createJson.commitment, \"hex\"),\n586\t      algorithmVer: 1,\n587\t      targetSlot: 150n,\n588\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n589\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n590\t    });\n591\t    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n592\t      owner: FLIPYOU_PROGRAM_ID,\n593\t    });\n594\t\n595\t    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n596\t    await settleMatch(\n597\t      {\n598\t        db,\n599\t        connection: mockConn as unknown as Connection,\n600\t        serverKeypair,\n601\t        entropyAccount,\n602\t        referralDefaultRateBps: 1000,\n603\t      },\n604\t      createJson.matchPda,\n605\t    );\n606\t\n607\t    const events = await rawSql`\n608\t      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n609\t    `;\n610\t    expect(events.length).toBe(1);\n611\t    expect(events[0]!.status).toBe(\"pending\");\n612\t\n613\t    const payload = events[0]!.payload as Record<string, any>;\n614\t    expect(payload.roundId).toBe(createJson.matchId);\n615\t    expect(payload.roundPda).toBe(createJson.matchPda);\n616\t    expect(payload.game).toBe(\"flipyou\");\n617\t    expect(payload.feeLamports).toBeDefined();\n618\t    expect(payload.settledAt).toBeDefined();\n619\t    expect(payload.players).toHaveLength(2);\n620\t\n621\t    const creator = payload.players.find(\n622\t      (player: Record<string, string>) =>\n623\t        player.wallet === creatorKeypair.publicKey.toBase58(),\n624\t    );\n625\t    const opponent = payload.players.find(\n626\t      (player: Record<string, string>) =>\n627\t        player.wallet === opponentKeypair.publicKey.toBase58(),\n628\t    );\n629\t    expect(creator).toBeDefined();\n630\t    expect(opponent).toBeDefined();\n631\t    expect(creator.isCreator).toBe(true);\n632\t    expect(opponent.isCreator).toBe(false);\n633\t    expect(creator.userId).toBe(creatorUserId);\n634\t    expect(opponent.userId).toBe(opponentUserId);\n635\t    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n636\t    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n637\t    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n638\t\n639\t    const winner = creator.isWinner ? creator : opponent;\n640\t    const loser = creator.isWinner ? opponent : creator;\n641\t    expect(Number(winner.payoutLamports)).toBeGreaterThan(0);\n642\t    expect(loser.payoutLamports).toBe(\"0\");\n643\t    expect(payload.feeLamports).toBe(String(500_000));\n644\t  });\n645\t\n646\t  it(\"closecall settlement emits game.settled payloads with the expected shape\", async () => {\n647\t    const greenPlayer = Keypair.generate();\n648\t    const redPlayer = Keypair.generate();\n649\t    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());\n650\t    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n651\t\n652\t    await rawSql`\n653\t      INSERT INTO player_profiles (user_id, wallet, username)\n654\t      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n655\t      ON CONFLICT (user_id) DO NOTHING\n656\t    `;\n657\t    await rawSql`\n658\t      INSERT INTO player_profiles (user_id, wallet, username)\n659\t      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n660\t      ON CONFLICT (user_id) DO NOTHING\n661\t    `;\n662\t\n663\t    const nowSec = Math.floor(Date.now() / 1000);\n664\t    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n665\t    const openPrice = 69500_00n;\n666\t\n667\t    const minuteTsBuf = Buffer.alloc(8);\n668\t    minuteTsBuf.writeBigInt64LE(minuteTs);\n669\t    const [roundPda] = PublicKey.findProgramAddressSync(\n670\t      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n671\t      CLOSECALL_PROGRAM_ID,\n672\t    );\n673\t\n674\t    const roundAccountData = await encodeCloseCallRound({\n675\t      minuteTs,\n676\t      server: serverKeypair.publicKey,\n677\t      phase: 0,\n678\t      greenEntries: [\n679\t        { player: greenPlayer.publicKey, amountLamports: 5_000_000n },\n680\t      ],\n681\t      redEntries: [{ player: redPlayer.publicKey, amountLamports: 5_000_000n }],\n682\t      greenPool: 5_000_000n,\n683\t      redPool: 5_000_000n,\n684\t      openPrice,\n685\t      openPriceExpo: -2,\n686\t      closePrice: 0n,\n687\t      createdAt: minuteTs,\n688\t      bettingEndsAt: minuteTs + 45n,\n689\t      resolveDeadline: minuteTs + 300n,\n690\t      outcome: 0,\n691\t      totalFee: 0n,\n692\t      bump: 0,\n693\t    });\n694\t\n695\t    mockConn.setAccount(roundPda, roundAccountData, {\n696\t      owner: CLOSECALL_PROGRAM_ID,\n697\t    });\n698\t\n699\t    const closePrice = 69600_00n;\n700\t    const mockHermes: HermesFetcher = {\n701\t      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n702\t        price: closePrice,\n703\t        expo: -2,\n704\t        publishTime: Math.floor(Date.now() / 1000),\n705\t        priceHuman: 69600.0,\n706\t        vaaBase64: null,\n707\t      }),\n708\t    };\n709\t\n710\t    const clock = createCloseCallClockWorker({\n711\t      connection: mockConn as unknown as Connection,\n712\t      serverKeypair,\n713\t      db,\n714\t      hermesFetcher: mockHermes,\n715\t      referralDefaultRateBps: 1000,\n716\t    });\n717\t\n718\t    await clock.tick();\n719\t\n720\t    const events = await rawSql<{\n721\t      status: string;\n722\t      payload: Record<string, any>;\n723\t    }[]>`\n724\t      SELECT status, payload FROM event_queue WHERE event_type = 'game.settled'\n725\t    `;\n726\t    const matchingEvents = events.filter(\n727\t      (event) =>\n728\t        (event.payload as Record<string, any>).roundId ===\n729\t        String(Number(minuteTs)),\n730\t    );\n731\t    expect(matchingEvents.length).toBe(1);\n732\t    expect(matchingEvents[0]!.status).toBe(\"pending\");\n733\t\n734\t    const payload = matchingEvents[0]!.payload as Record<string, any>;\n735\t    expect(payload.roundId).toBe(String(Number(minuteTs)));\n736\t    expect(payload.roundPda).toBe(roundPda.toBase58());\n737\t    expect(payload.game).toBe(\"closecall\");\n738\t    expect(payload.feeLamports).toBeDefined();\n739\t    expect(payload.settledAt).toBeDefined();\n740\t    expect(payload.players).toHaveLength(2);\n741\t\n742\t    const green = payload.players.find(\n743\t      (player: Record<string, string>) =>\n744\t        player.wallet === greenPlayer.publicKey.toBase58(),\n745\t    );\n746\t    const red = payload.players.find(\n747\t      (player: Record<string, string>) =>\n748\t        player.wallet === redPlayer.publicKey.toBase58(),\n749\t    );\n750\t    expect(green).toBeDefined();\n751\t    expect(red).toBeDefined();\n752\t    expect(green.userId).toBe(greenUserId);\n753\t    expect(red.userId).toBe(redUserId);\n754\t    expect(green.amountLamports).toBe(String(5_000_000n));\n755\t    expect(red.amountLamports).toBe(String(5_000_000n));\n756\t    expect(green.isWinner).toBe(true);\n757\t    expect(red.isWinner).toBe(false);\n758\t    expect(Number(green.payoutLamports)).toBeGreaterThan(0);\n759\t    expect(red.payoutLamports).toBe(\"0\");\n760\t    expect(payload.feeLamports).toBe(String(500_000));\n761\t    expect(green.isCreator).toBe(true);\n762\t    expect(red.isCreator).toBe(false);\n763\t  });\n764\t});\n765\t"}]},"parent_tool_use_id":null,"session_id":"578af45b-198a-413d-ab1a-ea47ca34e7b2","uuid":"6d65cd8e-090a-47e5-9640-b1744d9a0906","timestamp":"2026-05-01T20:04:33.134Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/integration-settlement.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\nimport { resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCloseCallRound } from \"../worker/account-decoder.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\nimport {\n  AMOUNT_LAMPORTS,\n  AMOUNT_LAMPORTS_BIGINT,\n  JWT_SECRET,\n  PHASE_LOCKED,\n  SIDE_HEADS,\n  type IntegrationDbContext,\n  type TestSql,\n  buildMatchAccountData,\n  closeIntegrationDb,\n  makeJwt,\n  MockConnection,\n  openIntegrationDb,\n  resetIntegrationState,\n  seedSettlementProgramAccounts,\n  userIdFromWallet,\n} from \"./integration-test-helpers.js\";\n\ndescribe(\"Settlement integration: create, settle, and emit events\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n    resetPlatformConfigCache();\n\n    mockConn = new MockConnection();\n    await seedSettlementProgramAccounts(mockConn, {\n      entropyAccount,\n      entropyData,\n      treasury: treasuryKeypair.publicKey,\n    });\n\n    app = new Hono();\n    app.use(\"/flipyou/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n    app.route(\n      \"/flipyou\",\n      createFlipYouRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n  });\n\n  it(\"full lifecycle: create, join, settle, verify\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n\n    expect(createRes.status).toBe(200);\n    const createBody = (await createRes.json()) as {\n      ok: true;\n      data: {\n        transaction: string;\n        matchPda: string;\n        matchId: string;\n        commitment: string;\n        lastValidBlockHeight: number;\n      };\n    };\n    const createJson = createBody.data;\n    expect(createJson.transaction).toBeDefined();\n    expect(createJson.matchPda).toBeDefined();\n    expect(createJson.commitment).toBeDefined();\n    expect(createJson.lastValidBlockHeight).toBeDefined();\n\n    const round = await db.getRoundByPda(createJson.matchPda);\n    expect(round).toBeDefined();\n    expect(round!.phase).toBe(\"created\");\n    expect(round!.game).toBe(\"flipyou\");\n    expect(round!.creator).toBe(wallet);\n    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n    expect(round!.side).toBe(SIDE_HEADS);\n    expect(round!.commitment.toString(\"hex\")).toBe(createJson.commitment);\n    expect(round!.secret).toBeDefined();\n    expect(round!.secret.length).toBe(32);\n\n    const events =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n    expect(events.length).toBe(1);\n    expect(events[0]!.event_type).toBe(\"secret_generated\");\n\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n    expect(settled!.settle_tx).toBeDefined();\n    expect(settled!.result_hash).toBeDefined();\n    expect(settled!.result_hash!.length).toBe(32);\n    expect(settled!.result_side).toBeDefined();\n    expect([0, 1]).toContain(settled!.result_side);\n    expect(settled!.winner).toBeDefined();\n    expect([\n      creatorKeypair.publicKey.toBase58(),\n      opponentKeypair.publicKey.toBase58(),\n    ]).toContain(settled!.winner);\n\n    const allEvents =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n    const eventTypes = allEvents.map(\n      (e) => (e as Record<string, any>).event_type,\n    );\n    expect(eventTypes).toContain(\"secret_generated\");\n    expect(eventTypes).toContain(\"match_detected\");\n    expect(eventTypes).toContain(\"settle_submitted\");\n    expect(eventTypes).toContain(\"settle_confirmed\");\n\n    const roundsRes = await app.request(`/flipyou/verify/${createJson.matchPda}`);\n    expect(roundsRes.status).toBe(200);\n\n    const roundsBody = (await roundsRes.json()) as {\n      ok: true;\n      data: Record<string, any>;\n    };\n    const roundsJson = roundsBody.data;\n    expect(roundsJson.pda).toBe(createJson.matchPda);\n    expect(roundsJson.phase).toBe(\"settled\");\n    expect(roundsJson.game).toBe(\"flip-you\");\n    expect(roundsJson.creator).toBe(wallet);\n    expect(roundsJson.commitment).toBe(createJson.commitment);\n    expect(roundsJson.secret).toBeDefined();\n    expect(typeof roundsJson.secret).toBe(\"string\");\n    expect((roundsJson.secret as string).length).toBe(64);\n    expect(roundsJson.resultHash).toBeDefined();\n    expect(roundsJson.resultSide).toBeDefined();\n    expect(roundsJson.winner).toBeDefined();\n    expect(roundsJson.settleTx).toBeDefined();\n\n    const verification = roundsJson.verification as Record<string, string>;\n    expect(verification).toBeDefined();\n    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n    expect(verification.resultFormula).toContain(\"sha256(secret\");\n    expect(verification.entropySource).toContain(\"SlotHashes\");\n  }, 20_000);\n\n  it(\"GET /flipyou/verify/:pda returns 404 for unknown PDA\", async () => {\n    const unknownPda = Keypair.generate().publicKey.toBase58();\n    const res = await app.request(`/flipyou/verify/${unknownPda}`);\n    expect(res.status).toBe(404);\n  });\n\n  it(\"unsettled round does not expose secret\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const res = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as { ok: true; data: { matchPda: string } };\n    const json = body.data;\n\n    const roundRes = await app.request(`/flipyou/verify/${json.matchPda}`);\n    expect(roundRes.status).toBe(200);\n    const roundBody = (await roundRes.json()) as {\n      ok: true;\n      data: Record<string, any>;\n    };\n    const roundJson = roundBody.data;\n    expect(roundJson.phase).toBe(\"created\");\n    expect(roundJson.secret).toBeUndefined();\n    expect(roundJson.resultHash).toBeUndefined();\n    expect(roundJson.verification).toBeUndefined();\n  });\n\n  it(\"two creates from same wallet succeed with different match IDs\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const res1 = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res1.status).toBe(200);\n\n    const res2 = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res2.status).toBe(200);\n\n    const body1 = (await res1.json()) as {\n      ok: true;\n      data: { matchPda: string; matchId: string };\n    };\n    const body2 = (await res2.json()) as {\n      ok: true;\n      data: { matchPda: string; matchId: string };\n    };\n    const json1 = body1.data;\n    const json2 = body2.data;\n    expect(json1.matchPda).not.toBe(json2.matchPda);\n    expect(json1.matchId).not.toBe(json2.matchId);\n  });\n\n  it(\"settlement records referral earnings for referred players\", async () => {\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n\n    await db.insertReferralCode(referrerProfile.user_id, referrerWallet, \"test-ref\");\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: opponentProfile.user_id,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n\n    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createBody = (await createRes.json()) as {\n      ok: true;\n      data: {\n        matchPda: string;\n        matchId: string;\n        commitment: string;\n      };\n    };\n    const createJson = createBody.data;\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentProfile.user_id}`;\n    expect(earnings.length).toBe(1);\n\n    const earning = earnings[0]!;\n    expect(earning.referrer_user_id).toBe(referrerProfile.user_id);\n    expect(earning.referee_user_id).toBe(opponentProfile.user_id);\n    expect(earning.referrer_wallet).toBe(referrerWallet);\n    expect(earning.referee_wallet).toBe(opponentWallet);\n    expect(earning.round_id).toBe(createJson.matchId);\n    expect(earning.game_type).toBe(\"flipyou\");\n    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS);\n    expect(Number(earning.fee_lamports)).toBe(250_000);\n    expect(Number(earning.referrer_earned_lamports)).toBe(25_000);\n    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n\n    const creatorEarnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${creatorProfile.user_id}`;\n    expect(creatorEarnings.length).toBe(0);\n  });\n\n  it(\"settlement uses KOL custom rates for referrer earnings\", async () => {\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n\n    await db.insertReferralCode(referrerProfile.user_id, referrerWallet, \"kol-code\");\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: opponentProfile.user_id,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n    await rawSql`\n      INSERT INTO referral_kol_rates (user_id, wallet, rate_bps, set_by)\n      VALUES (${referrerProfile.user_id}, ${referrerWallet}, 2000, 'admin')\n    `;\n\n    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createBody = (await createRes.json()) as {\n      ok: true;\n      data: {\n        matchPda: string;\n        matchId: string;\n        commitment: string;\n      };\n    };\n    const createJson = createBody.data;\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled!.phase).toBe(\"settled\");\n\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentProfile.user_id}`;\n    expect(earnings.length).toBe(1);\n    expect(Number(earnings[0]!.referrer_earned_lamports)).toBe(50_000);\n    expect(Number(earnings[0]!.referrer_rate_bps)).toBe(2000);\n  });\n\n  it(\"settlement emits flipyou game.settled payloads with the expected shape\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createBody = (await createRes.json()) as {\n      ok: true;\n      data: {\n        matchPda: string;\n        matchId: string;\n        commitment: string;\n      };\n    };\n    const createJson = createBody.data;\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n\n    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n    await settleMatch(\n      {\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n        entropyAccount,\n        referralDefaultRateBps: 1000,\n      },\n      createJson.matchPda,\n    );\n\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n    expect(events[0]!.status).toBe(\"pending\");\n\n    const payload = events[0]!.payload as Record<string, any>;\n    expect(payload.roundId).toBe(createJson.matchId);\n    expect(payload.roundPda).toBe(createJson.matchPda);\n    expect(payload.game).toBe(\"flipyou\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n    expect(payload.players).toHaveLength(2);\n\n    const creator = payload.players.find(\n      (player: Record<string, string>) =>\n        player.wallet === creatorKeypair.publicKey.toBase58(),\n    );\n    const opponent = payload.players.find(\n      (player: Record<string, string>) =>\n        player.wallet === opponentKeypair.publicKey.toBase58(),\n    );\n    expect(creator).toBeDefined();\n    expect(opponent).toBeDefined();\n    expect(creator.isCreator).toBe(true);\n    expect(opponent.isCreator).toBe(false);\n    expect(creator.userId).toBe(creatorUserId);\n    expect(opponent.userId).toBe(opponentUserId);\n    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n\n    const winner = creator.isWinner ? creator : opponent;\n    const loser = creator.isWinner ? opponent : creator;\n    expect(Number(winner.payoutLamports)).toBeGreaterThan(0);\n    expect(loser.payoutLamports).toBe(\"0\");\n    expect(payload.feeLamports).toBe(String(500_000));\n  });\n\n  it(\"closecall settlement emits game.settled payloads with the expected shape\", async () => {\n    const greenPlayer = Keypair.generate();\n    const redPlayer = Keypair.generate();\n    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());\n    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    const nowSec = Math.floor(Date.now() / 1000);\n    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n    const openPrice = 69500_00n;\n\n    const minuteTsBuf = Buffer.alloc(8);\n    minuteTsBuf.writeBigInt64LE(minuteTs);\n    const [roundPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n      CLOSECALL_PROGRAM_ID,\n    );\n\n    const roundAccountData = await encodeCloseCallRound({\n      minuteTs,\n      server: serverKeypair.publicKey,\n      phase: 0,\n      greenEntries: [\n        { player: greenPlayer.publicKey, amountLamports: 5_000_000n },\n      ],\n      redEntries: [{ player: redPlayer.publicKey, amountLamports: 5_000_000n }],\n      greenPool: 5_000_000n,\n      redPool: 5_000_000n,\n      openPrice,\n      openPriceExpo: -2,\n      closePrice: 0n,\n      createdAt: minuteTs,\n      bettingEndsAt: minuteTs + 45n,\n      resolveDeadline: minuteTs + 300n,\n      outcome: 0,\n      totalFee: 0n,\n      bump: 0,\n    });\n\n    mockConn.setAccount(roundPda, roundAccountData, {\n      owner: CLOSECALL_PROGRAM_ID,\n    });\n\n    const closePrice = 69600_00n;\n    const mockHermes: HermesFetcher = {\n      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n        price: closePrice,\n        expo: -2,\n        publishTime: Math.floor(Date.now() / 1000),\n        priceHuman: 69600.0,\n        vaaBase64: null,\n      }),\n    };\n\n    const clock = createCloseCallClockWorker({\n      connection: mockConn as unknown as Connection,\n      serverKeypair,\n      db,\n      hermesFetcher: mockHermes,\n      referralDefaultRateBps: 1000,\n    });\n\n    await clock.tick();\n\n    const events = await rawSql<{\n      status: string;\n      payload: Record<string, any>;\n    }[]>`\n      SELECT status, payload FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    const matchingEvents = events.filter(\n      (event) =>\n        (event.payload as Record<string, any>).roundId ===\n        String(Number(minuteTs)),\n    );\n    expect(matchingEvents.length).toBe(1);\n    expect(matchingEvents[0]!.status).toBe(\"pending\");\n\n    const payload = matchingEvents[0]!.payload as Record<string, any>;\n    expect(payload.roundId).toBe(String(Number(minuteTs)));\n    expect(payload.roundPda).toBe(roundPda.toBase58());\n    expect(payload.game).toBe(\"closecall\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n    expect(payload.players).toHaveLength(2);\n\n    const green = payload.players.find(\n      (player: Record<string, string>) =>\n        player.wallet === greenPlayer.publicKey.toBase58(),\n    );\n    const red = payload.players.find(\n      (player: Record<string, string>) =>\n        player.wallet === redPlayer.publicKey.toBase58(),\n    );\n    expect(green).toBeDefined();\n    expect(red).toBeDefined();\n    expect(green.userId).toBe(greenUserId);\n    expect(red.userId).toBe(redUserId);\n    expect(green.amountLamports).toBe(String(5_000_000n));\n    expect(red.amountLamports).toBe(String(5_000_000n));\n    expect(green.isWinner).toBe(true);\n    expect(red.isWinner).toBe(false);\n    expect(Number(green.payoutLamports)).toBeGreaterThan(0);\n    expect(red.payoutLamports).toBe(\"0\");\n    expect(payload.feeLamports).toBe(String(500_000));\n    expect(green.isCreator).toBe(true);\n    expect(red.isCreator).toBe(false);\n  });\n});\n","numLines":765,"startLine":1,"totalLines":765}}}
