on = calculateFeeAllocation(feeLamports, referrerRateBps);\n163\t\n164\t      await db.insertFeeAllocation({\n165\t        sourceType: gameType,\n166\t        sourceId: roundId,\n167\t        gameType,\n168\t        wallet,\n169\t        userId: refereeProfile?.user_id ?? null,\n170\t        wagerLamports,\n171\t        feeLamports,\n172\t        referrerUserId: link?.referrer_user_id ?? null,\n173\t        referralRateBps: referrerRateBps,\n174\t        referralLamports: allocation.referralLamports,\n175\t        promotionsLamports: allocation.promotionsLamports,\n176\t        profitLamports: allocation.profitLamports,\n177\t      });\n178\t\n179\t      if (link && refereeProfile) {\n180\t        await db.insertReferralEarning({\n181\t          referrerUserId: link.referrer_user_id,\n182\t          refereeUserId: refereeProfile.user_id,\n183\t          referrerWallet: link.referrer_wallet,\n184\t          refereeWallet: wallet,\n185\t          roundId,\n186\t          gameType,\n187\t          wagerLamports,\n188\t          feeLamports,\n189\t          referrerEarnedLamports: allocation.referralLamports,\n190\t          referrerRateBps,\n191\t        });\n192\t\n193\t        logger.info(\"referral earning recorded\", {\n194\t          roundId,\n195\t          gameType,\n196\t          referrerUserId: link.referrer_user_id,\n197\t          refereeUserId: refereeProfile.user_id,\n198\t          referrerEarnedLamports: allocation.referralLamports,\n199\t        });\n200\t      }\n201\t    } catch (err: unknown) {\n202\t      const msg = err instanceof Error ? err.message : String(err);\n203\t      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n204\t        logger.info(\"fee accounting row already recorded (idempotent skip)\", {\n205\t          roundId,\n206\t          wallet,\n207\t        });\n208\t      } else {\n209\t        logger.error(\"failed to record fee accounting row\", {\n210\t          roundId,\n211\t          wallet,\n212\